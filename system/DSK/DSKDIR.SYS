; Action script for DSKDIR. The app calls these sections from buttons, key shortcuts, and event blocks.
;
title=Add Directory Link
ui=LAYOUT
single_instance=1
resizable=0
modal=1
FILE_PICK_DIALOG=SYSTEM\DSK\DSKPICK.SYS
DIR_PICK_DIALOG=SYSTEM\DSK\DSKDPK.SYS

[WINDOW]
X=110
Y=72
W=520
H=252

[LABEL]
TEXT=Display name
X=12
Y=16

[TEXTBOX]
NAME=DISP_NAME
X=120
Y=12
W=372
H=22
TEXT=
BIND_FILE=SYSTEM\DSKDIR.TMP
BIND_SECTION=ICON
BIND_KEY=DISPLAY

[LABEL]
TEXT=Directory path
X=12
Y=46

[TEXTBOX]
NAME=TARGET_PATH
X=120
Y=42
W=372
H=22
TEXT=
READONLY=1
BIND_FILE=SYSTEM\DSKDIR.TMP
BIND_SECTION=ICON
BIND_KEY=TARGET

[LABEL]
TEXT=Icon path
X=12
Y=76

[TEXTBOX]
NAME=ICON_PATH
X=120
Y=72
W=372
H=22
TEXT=
READONLY=1
BIND_FILE=SYSTEM\DSKDIR.TMP
BIND_SECTION=ICON
BIND_KEY=ICON

[LABEL]
TEXT=Desktop X
X=12
Y=106

[TEXTBOX]
NAME=ICON_X
X=120
Y=102
W=80
H=22
TEXT=
BIND_FILE=SYSTEM\DSKDIR.TMP
BIND_SECTION=ICON
BIND_KEY=X

[LABEL]
TEXT=Desktop Y
X=232
Y=106

[TEXTBOX]
NAME=ICON_Y
X=332
Y=102
W=80
H=22
TEXT=
BIND_FILE=SYSTEM\DSKDIR.TMP
BIND_SECTION=ICON
BIND_KEY=Y

[BUTTON]
NAME=TARGET_BTN
TEXT=Directory...
X=244
Y=144
W=92
H=24
ACTION=DIR_PICK TARGET_PATH . SYSTEM\DSK\DSKDPK.SYS

[BUTTON]
NAME=ICON_BTN
TEXT=Icon...
X=344
Y=144
W=72
H=24
ACTION=FILE_PICK ICON_PATH ICONS\48 *.BMP

[BUTTON]
NAME=SAVE_BTN
TEXT=Save
X=332
Y=186
W=72
H=24
ACTION=DESKTOP_ICON_ADD_DIR_SAVE

[BUTTON]
NAME=CANCEL_BTN
TEXT=Cancel
X=420
Y=186
W=72
H=24
ACTION=CLOSE_WINDOW

[EVENTS]
ON ACTION DIR_PICK TARGET_PATH . SYSTEM\DSK\DSKDPK.SYS
    HOST DIR_PICK TARGET_PATH . SYSTEM\DSK\DSKDPK.SYS
END

ON ACTION FILE_PICK ICON_PATH ICONS\48 *.BMP
    HOST FILE_PICK ICON_PATH ICONS\48 *.BMP
END

ON ACTION DESKTOP_ICON_ADD_DIR_SAVE
    HOST DESKTOP_ICON_ADD_DIR_SAVE
END

ON ACTION CLOSE_WINDOW
    HOST CLOSE_WINDOW
END
