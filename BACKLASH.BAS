                    ELSE
                        taskbarScrollHit = TaskbarScrollButtonFromPoint(smx, smy)
                        IF taskbarScrollHit <> 0 THEN
                        NormalizeTaskbarScroll
                        taskbarScrollCap = TaskbarVisibleCapacity()
                        taskbarScrollMax = TaskbarOpenWindowCount() - taskbarScrollCap
