ClearDosRequestFiles
BDbgTrace "STARTUP_AFTER_CLEAR_DOS_REQUESTS"
BDbgTrace "STARTUP_BEFORE_RESTORE_DOS_SESSION"
restoredDosSession = RestoreSessionAfterDosUnload()
BDbgTrace "STARTUP_AFTER_RESTORE_DOS_SESSION restored=" + BDbgNum(restoredDosSession)
restoredShutdownSession = 0
IF restoredDosSession = 0 AND layoutWindowCount = 0 THEN
    BDbgTrace "STARTUP_BEFORE_RESTORE_SHUTDOWN_SESSION"
    restoredShutdownSession = RestoreSessionAfterShutdown()
    BDbgTrace "STARTUP_AFTER_RESTORE_SHUTDOWN_SESSION restored=" + BDbgNum(restoredShutdownSession)
