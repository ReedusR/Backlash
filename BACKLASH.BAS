    SetCfgValueInSection DesktopIconAddTextTempPath(), "ICON", "DISPLAY", desktopIcons(newIdx).caption
    SetCfgValueInSection DesktopIconAddTextTempPath(), "ICON", "TARGET", NormalizePath(addTarget)
    SetCfgValueInSection DesktopIconAddTextTempPath(), "ICON", "ICON", desktopIcons(newIdx).bmpFile
    SetCfgValueInSection DesktopIconAddTextTempPath(), "ICON", "X", LTRIM$(STR$(desktopIcons(newIdx).x))
    SetCfgValueInSection DesktopIconAddTextTempPath(), "ICON", "Y", LTRIM$(STR$(desktopIcons(newIdx).y))

    SaveDesktopIcons
    LoadSingleDesktopIcon newIdx
    InvalidateDesktopCache

    desktopAddMode = 0
    desktopAddX = 0
    desktopAddY = 0
    selectedIcon = newIdx

    IF winIdx >= LBOUND(layoutWindows) AND winIdx <= UBOUND(layoutWindows) THEN
        IF layoutWindows(winIdx).used <> 0 THEN CloseLayoutWindow winIdx
    END IF
END SUB

FUNCTION DesktopDirectoryLinkTargetPath() AS STRING
    RETURN ShellHandlerPath("DIRECTORY_LINK_OPEN")
END FUNCTION

SUB OpenDesktopDirectoryLink(BYVAL dirPath AS STRING)
    DIM appPath AS STRING
    DIM savedWin AS INTEGER
    DIM openedWin AS INTEGER

    dirPath = AbsoluteDirPath(dirPath)
    IF dirPath = "" THEN
        ShowGuiMessageBox "EMPTY DIRECTORY LINK:", "No directory path was supplied."
        EXIT SUB
    END IF

    appPath = DesktopDirectoryLinkTargetPath()
    IF appPath = "" OR DIR(LayoutFilePath(appPath)) = "" THEN
        ShowGuiMessageBox "DIRECTORY LINK APP NOT FOUND:", appPath
        EXIT SUB
    END IF

    savedWin = activeLayoutWindow
    IF savedWin >= LBOUND(layoutWindows) AND savedWin <= UBOUND(layoutWindows) THEN
        IF layoutWindows(savedWin).used <> 0 THEN SyncLayoutWindowFromGlobals savedWin
    END IF

    startMenuOpen = 0
    OpenLayoutAppWindow appPath
    openedWin = activeLayoutWindow

    IF openedWin >= LBOUND(layoutWindows) AND openedWin <= UBOUND(layoutWindows) THEN
        IF layoutWindows(openedWin).used <> 0 THEN
            ConfigureFileBrowserWindow openedWin, dirPath
            SyncLayoutWindowFromGlobals openedWin

            IF layoutLoopRunning = 0 THEN
                layoutResumeOnly = -1
                ExecuteAppFile RTRIM$(layoutWindows(openedWin).appPath)
            END IF
        END IF
    END IF
END SUB

SUB OpenDesktopFileLink(BYVAL filePath AS STRING)
    DIM assocActionText AS STRING

    filePath = NormalizePath(filePath)
    IF filePath = "" THEN
        ShowGuiMessageBox "EMPTY FILE LINK:", "No file path was supplied."
        EXIT SUB
    END IF

    assocActionText = LookupFileAssociation(filePath)
    IF assocActionText = "" THEN
        ShowGuiMessageBox "NO FILE ASSOCIATION:", filePath
        EXIT SUB
    END IF

    OpenFileByAssociation filePath, assocActionText
END SUB

SUB ShowDesktopProperties()
    DIM appPath AS STRING
    DIM openedWin AS INTEGER

    appPath = DesktopPropertiesTargetPath()
    IF DIR(LayoutFilePath(appPath)) = "" THEN
        ShowGuiMessageBox "DESKTOP PROPERTIES:", "Desktop Properties app is unavailable."
        EXIT SUB
    END IF

    OpenLayoutAppWindow appPath
    openedWin = activeLayoutWindow

    IF openedWin >= LBOUND(layoutWindows) AND openedWin <= UBOUND(layoutWindows) THEN
        IF layoutWindows(openedWin).used <> 0 THEN
            SyncLayoutWindowFromGlobals openedWin

            IF layoutLoopRunning = 0 THEN
                layoutResumeOnly = -1
                ExecuteAppFile RTRIM$(layoutWindows(openedWin).appPath)
            END IF
        END IF
    END IF
END SUB

SUB HandleDesktopContextAction(BYVAL rowIdx AS INTEGER)
    IF rowIdx < 1 THEN EXIT SUB

    IF desktopCtxMode = 1 THEN
        IF desktopCtxIcon < 1 OR desktopCtxIcon > iconCount THEN EXIT SUB
        selectedIcon = desktopCtxIcon
        IF DesktopIconBmpIsTrashAware(desktopIcons(desktopCtxIcon).bmpFile) <> 0 THEN
            IF rowIdx = 1 THEN
                HostAppAction 0, "TRASH_EMPTY"
            END IF
        ELSEIF rowIdx = 1 THEN
            ShowDesktopIconProperties desktopCtxIcon
        ELSEIF rowIdx = 2 THEN
            ShowDesktopIconEdit desktopCtxIcon
        ELSEIF rowIdx = 3 THEN
            ShowDesktopIconDelete desktopCtxIcon
        END IF
    ELSEIF desktopCtxMode = 2 THEN
        IF rowIdx = 1 THEN
            ShowDesktopAddApp desktopCtxX, desktopCtxY
        ELSEIF rowIdx = 2 THEN
            ShowDesktopAddDosProgram desktopCtxX, desktopCtxY
        ELSEIF rowIdx = 3 THEN
            ShowDesktopAddDirLink desktopCtxX, desktopCtxY
        ELSEIF rowIdx = 4 THEN
            ShowDesktopAddTextLink desktopCtxX, desktopCtxY
        ELSEIF rowIdx = 5 THEN
            ShowDesktopProperties
        END IF
    END IF
END SUB


' ---------------------------
' Cursor drawing and small-area redraw helpers
' ---------------------------

SUB DrawCursorGlyph(BYVAL mx AS INTEGER, BYVAL my AS INTEGER, BYVAL fillCol AS UINTEGER, BYVAL edgeCol AS UINTEGER)
    DIM y AS INTEGER
    DIM x2 AS INTEGER

    ' Draw a larger software pointer with a solid dark backplate and light fill.
    ' The hotspot remains at mx,my so click and drag math stays unchanged.
    FOR y = 0 TO 16
        x2 = y
        IF x2 > 16 THEN x2 = 16
        LINE (mx, my + y)-(mx + x2, my + y), edgeCol
    NEXT

    FOR y = 17 TO 22
        x2 = 22 - y
        LINE (mx, my + y)-(mx + x2, my + y), edgeCol
    NEXT

    LINE (mx + 5, my + 14)-(mx + 12, my + 25), edgeCol
    LINE (mx + 6, my + 14)-(mx + 13, my + 25), edgeCol
    LINE (mx + 7, my + 14)-(mx + 14, my + 25), edgeCol

    FOR y = 2 TO 14
        x2 = y - 1
        IF x2 >= 2 THEN LINE (mx + 2, my + y)-(mx + x2, my + y), fillCol
    NEXT

    FOR y = 15 TO 19
        x2 = 20 - y
        IF x2 >= 2 THEN LINE (mx + 2, my + y)-(mx + x2, my + y), fillCol
    NEXT

    LINE (mx + 7, my + 16)-(mx + 11, my + 24), fillCol
    LINE (mx + 8, my + 16)-(mx + 12, my + 24), fillCol
END SUB

SUB DrawBusyCursorGlyph(BYVAL mx AS INTEGER, BYVAL my AS INTEGER)
    ' Static wristwatch/clock cursor used only while the shell is launching work.
    ' It is drawn from simple primitives so no bitmap asset or app-specific file is needed.
    LINE (mx - 2, my - 10)-(mx + 2, my - 7), COL_TEXT, BF
    LINE (mx - 2, my + 7)-(mx + 2, my + 10), COL_TEXT, BF

    LINE (mx - 2, my - 6)-(mx + 2, my - 6), COL_BUTTON
    LINE (mx - 4, my - 5)-(mx + 4, my - 5), COL_BUTTON
    LINE (mx - 5, my - 4)-(mx + 5, my - 4), COL_BUTTON
    LINE (mx - 6, my - 3)-(mx + 6, my - 3), COL_BUTTON
    LINE (mx - 6, my - 2)-(mx + 6, my - 2), COL_BUTTON
    LINE (mx - 7, my - 1)-(mx + 7, my - 1), COL_BUTTON
    LINE (mx - 7, my)-(mx + 7, my), COL_BUTTON
    LINE (mx - 7, my + 1)-(mx + 7, my + 1), COL_BUTTON
    LINE (mx - 6, my + 2)-(mx + 6, my + 2), COL_BUTTON
    LINE (mx - 6, my + 3)-(mx + 6, my + 3), COL_BUTTON
    LINE (mx - 5, my + 4)-(mx + 5, my + 4), COL_BUTTON
    LINE (mx - 4, my + 5)-(mx + 4, my + 5), COL_BUTTON
    LINE (mx - 2, my + 6)-(mx + 2, my + 6), COL_BUTTON

    CIRCLE (mx, my), 7, COL_TEXT
    CIRCLE (mx, my), 5, COL_BEVEL_HI
    LINE (mx, my)-(mx, my - 4), COL_TEXT
    LINE (mx, my)-(mx + 3, my + 2), COL_TEXT
    PSET (mx, my), COL_TEXT_INV
END SUB

SUB UpdateCursorTrail(BYVAL mx AS INTEGER, BYVAL my AS INTEGER)
    DIM i AS INTEGER

    IF cursorTrailCount = 0 THEN
        cursorTrailX(1) = mx
        cursorTrailY(1) = my
        cursorTrailCount = 1
        EXIT SUB
    END IF

    IF cursorTrailX(1) = mx AND cursorTrailY(1) = my THEN EXIT SUB

    IF cursorTrailCount < CURSOR_TRAIL_COUNT THEN cursorTrailCount = cursorTrailCount + 1

    FOR i = cursorTrailCount TO 2 STEP -1
        cursorTrailX(i) = cursorTrailX(i - 1)
        cursorTrailY(i) = cursorTrailY(i - 1)
    NEXT

    cursorTrailX(1) = mx
    cursorTrailY(1) = my
END SUB

SUB DrawCursor(BYVAL mx AS INTEGER, BYVAL my AS INTEGER)
    DIM i AS INTEGER
    DIM tx AS INTEGER
    DIM ty AS INTEGER

    IF cursorMode = CURSOR_MODE_BUSY THEN
        cursorTrailCount = 0
        DrawBusyCursorGlyph mx, my
        cursorDrawValid = -1
        cursorDrawX = mx
        cursorDrawY = my
        cursorDrawMode = cursorMode
        cursorDrawTrailEffect = cfg.trailEffect
        EXIT SUB
    END IF

    IF cfg.trailEffect <> 0 THEN
        UpdateCursorTrail mx, my
        FOR i = cursorTrailCount TO 2 STEP -1
            tx = cursorTrailX(i)
            ty = cursorTrailY(i)
            IF ABS(tx - mx) <= ((CURSOR_TRAIL_BACK_W \ 2) - 12) AND ABS(ty - my) <= ((CURSOR_TRAIL_BACK_H \ 2) - 14) THEN
                SELECT CASE i
                CASE 4
                    DrawCursorGlyph tx, ty, COL_BEVEL_LO, COL_BEVEL_LO
                CASE 3
                    DrawCursorGlyph tx, ty, COL_BEVEL_HI, COL_BEVEL_LO
                CASE ELSE
                    DrawCursorGlyph tx, ty, COL_TEXT, COL_BEVEL_LO
                END SELECT
            END IF
        NEXT
    ELSE
        cursorTrailCount = 0
    END IF

    DrawCursorGlyph mx, my, RGB(255, 255, 255), RGB(0, 0, 0)
    cursorDrawValid = -1
    cursorDrawX = mx
    cursorDrawY = my
    cursorDrawMode = cursorMode
    cursorDrawTrailEffect = cfg.trailEffect
END SUB

SUB InitCursorBackBuffer()
    DIM needW AS INTEGER
    DIM needH AS INTEGER

    IF cursorMode = CURSOR_MODE_BUSY THEN
        needW = CURSOR_BUSY_BACK_W
        needH = CURSOR_BUSY_BACK_H
    ELSEIF cfg.trailEffect <> 0 THEN
        needW = CURSOR_TRAIL_BACK_W
        needH = CURSOR_TRAIL_BACK_H
    ELSE
        needW = CURSOR_BACK_W
        needH = CURSOR_BACK_H
    END IF

    IF cursorBack <> 0 THEN
        IF cursorBackW <> needW OR cursorBackH <> needH THEN
            ImageDestroy cursorBack
            cursorBack = 0
            cursorBackValid = 0
            cursorDrawValid = 0
        END IF
    END IF

    IF cursorBack = 0 THEN
        cursorBack = ImageCreate(needW, needH, 0)
        cursorBackW = needW
        cursorBackH = needH
    END IF
    cursorBackValid = 0
END SUB

SUB FreeCursorBackBuffer()
    IF cursorBack <> 0 THEN
        ImageDestroy cursorBack
        cursorBack = 0
    END IF
    cursorBackW = 0
    cursorBackH = 0
    cursorBackValid = 0
    cursorDrawValid = 0
END SUB

SUB FreeDisplayModeBuffers()
    FreeCursorBackBuffer
    FreeLayoutDragOutlineBackBuffer
    FreeDesktopCache
    FreeAllLayoutWindowDrawCaches
    FreeScriptPreviewCache
    ClearLayoutOverlayCache
    FreeTaskbarCache
    FreeStartMenuBackBuffer
    FreeContextOverlayBackBuffer
    FreeGradientCaches
    FreeBackgroundCache
    FreeStartStrip
    FreeLaunchButtonBmp
    FreeAllIcons
    FreeMenuIcons
END SUB

SUB RestoreCursorBackBuffer()
    IF cursorBack <> 0 AND cursorBackValid <> 0 THEN
        PUT (cursorBackX, cursorBackY), cursorBack, PSET
        cursorBackValid = 0
        cursorDrawValid = 0
    END IF
END SUB

SUB SaveCursorBackBuffer(BYVAL mx AS INTEGER, BYVAL my AS INTEGER)
    InitCursorBackBuffer
    IF cursorBack = 0 THEN EXIT SUB

    IF cursorMode = CURSOR_MODE_BUSY THEN
        cursorBackX = mx - (cursorBackW \ 2)
        cursorBackY = my - (cursorBackH \ 2)
    ELSEIF cfg.trailEffect <> 0 THEN
        cursorBackX = mx - (cursorBackW \ 2)
        cursorBackY = my - (cursorBackH \ 2)
    ELSE
        cursorBackX = mx - 5
        cursorBackY = my - 5
    END IF

    IF cursorBackX < 0 THEN cursorBackX = 0
    IF cursorBackY < 0 THEN cursorBackY = 0
    IF cursorBackX + cursorBackW > SCR_W THEN cursorBackX = SCR_W - cursorBackW
    IF cursorBackY + cursorBackH > SCR_H THEN cursorBackY = SCR_H - cursorBackH
    IF cursorBackX < 0 OR cursorBackY < 0 THEN EXIT SUB

    GET (cursorBackX, cursorBackY)-(cursorBackX + cursorBackW - 1, cursorBackY + cursorBackH - 1), cursorBack
    cursorBackValid = -1
END SUB

SUB DrawCursorOnly(BYVAL mx AS INTEGER, BYVAL my AS INTEGER)
    ' Cursor-only passes are hot while the mouse moves. If the cursor is already
    ' drawn at the same spot with the same mode/effect, leave the screen alone.
    IF mx < 0 OR my < 0 OR mx >= SCR_W OR my >= SCR_H THEN
        IF cursorBackValid <> 0 THEN
            SCREENLOCK
            RestoreCursorBackBuffer
            SCREENUNLOCK
        END IF
        cursorDrawValid = 0
        EXIT SUB
    END IF

    IF cursorDrawValid <> 0 AND cursorBackValid <> 0 THEN
        IF cursorDrawX = mx AND cursorDrawY = my AND cursorDrawMode = cursorMode AND cursorDrawTrailEffect = cfg.trailEffect THEN EXIT SUB
    END IF

    SCREENLOCK
    RestoreCursorBackBuffer
    SaveCursorBackBuffer mx, my
    DrawCursor mx, my
    SCREENUNLOCK
END SUB

SUB SetCursorBusy(BYVAL busy AS INTEGER)
    DIM newMode AS INTEGER
    DIM mx AS INTEGER
    DIM my AS INTEGER
    DIM mw AS INTEGER
    DIM mb AS INTEGER

    IF busy <> 0 THEN
        newMode = CURSOR_MODE_BUSY
    ELSE
        newMode = CURSOR_MODE_NORMAL
    END IF

    IF cursorMode = newMode THEN EXIT SUB

    cursorMode = newMode
    cursorTrailCount = 0
    cursorDrawValid = 0
    GETMOUSE mx, my, mw, mb
    DrawCursorOnly mx, my
END SUB

SUB DrawScreen(BYVAL hoverIndex AS INTEGER, BYVAL startPressed AS INTEGER, BYVAL mx AS INTEGER, BYVAL my AS INTEGER)
    SCREENLOCK
    RestoreCursorBackBuffer
    DrawDesktop
    DrawWindows
    DrawTaskbar startPressed
    DrawSoundVolumePopup
    DrawClockPopups
    IF startMenuOpen THEN
        CaptureStartMenuBackBuffer 0
        DrawStartMenu hoverIndex
    END IF
    IF launchCtxOpen <> 0 THEN
        CaptureContextOverlayBackBuffer launchCtxX, launchCtxY, launchCtxX + LAUNCH_CTX_W, launchCtxY + LAUNCH_CTX_H
        DrawLaunchMenuContext
    ELSEIF desktopCtxOpen <> 0 THEN
        CaptureContextOverlayBackBuffer desktopCtxX, desktopCtxY, desktopCtxX + DesktopContextWidth(), desktopCtxY + DesktopContextHeight()
        DrawDesktopContextMenu
    ELSE
        InvalidateContextOverlayBackBuffer
    END IF
    SaveCursorBackBuffer mx, my
    DrawCursor mx, my
    SCREENUNLOCK
END SUB

SUB CaptureStartMenuBackBuffer(BYVAL reuseIfSameRect AS INTEGER)
    DIM rx1 AS INTEGER
    DIM ry1 AS INTEGER
    DIM rx2 AS INTEGER
    DIM ry2 AS INTEGER
    DIM reqW AS INTEGER
    DIM reqH AS INTEGER
    DIM capX1 AS INTEGER
    DIM capY1 AS INTEGER
    DIM capX2 AS INTEGER
    DIM capY2 AS INTEGER
    DIM capW AS INTEGER
    DIM capH AS INTEGER

    IF startMenuOpen = 0 THEN
        startMenuBackValid = 0
        EXIT SUB
    END IF

    rx1 = -1
    ry1 = -1
    rx2 = -1
    ry2 = -1
    ComputeStartMenuBackRect 0, MENU_X1, MenuY1(), 0, rx1, ry1, rx2, ry2

    IF rx1 < 0 OR ry1 < 0 OR rx2 < rx1 OR ry2 < ry1 THEN
        rx1 = 0
        ry1 = 0
        rx2 = SCR_W - 1
        ry2 = SCR_H - 1
    END IF

    reqW = rx2 - rx1 + 1
    reqH = ry2 - ry1 + 1

    ' Launch-menu redraw used to destroy/recreate the backing bitmap whenever a
    ' submenu changed the overlay size. Keep a grow-only reserve instead. If the
    ' current backing rectangle already covers the needed menu area, reuse it and
    ' avoid both image allocation and video-memory readback during hover.
    IF reuseIfSameRect <> 0 THEN
        IF startMenuBackBuffer <> 0 AND startMenuBackValid <> 0 THEN
            IF startMenuBackX <= rx1 AND startMenuBackY <= ry1 AND _
               startMenuBackX + startMenuBackW - 1 >= rx2 AND _
               startMenuBackY + startMenuBackH - 1 >= ry2 THEN
                EXIT SUB
            END IF
        END IF
    END IF

    IF startMenuBackBuffer = 0 OR startMenuBackW < reqW OR startMenuBackH < reqH THEN
        IF startMenuBackBuffer <> 0 THEN
            ImageDestroy startMenuBackBuffer
            startMenuBackBuffer = 0
        END IF

        capW = reqW + 96
        capH = reqH + 48
        IF capW > SCR_W THEN capW = SCR_W
        IF capH > SCR_H THEN capH = SCR_H
        IF capW < reqW THEN capW = reqW
        IF capH < reqH THEN capH = reqH

        startMenuBackBuffer = ImageCreate(capW, capH, 0)
        startMenuBackW = capW
        startMenuBackH = capH
    END IF

    IF startMenuBackBuffer = 0 THEN
        startMenuBackValid = 0
        EXIT SUB
    END IF

    capW = startMenuBackW
    capH = startMenuBackH
    capX1 = rx1
    capY1 = ry1

    IF capX1 + capW - 1 > SCR_W - 1 THEN capX1 = SCR_W - capW
    IF capY1 + capH - 1 > SCR_H - 1 THEN capY1 = SCR_H - capH
    IF capX1 < 0 THEN capX1 = 0
    IF capY1 < 0 THEN capY1 = 0

    capX2 = capX1 + capW - 1
    capY2 = capY1 + capH - 1

    startMenuBackX = capX1
    startMenuBackY = capY1
    GET (capX1, capY1)-(capX2, capY2), startMenuBackBuffer
    startMenuBackValid = -1
END SUB

SUB CaptureContextOverlayBackBuffer(BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER)
    DIM newW AS INTEGER
    DIM newH AS INTEGER

    IF x1 < 0 THEN x1 = 0
    IF y1 < 0 THEN y1 = 0
    IF x2 > SCR_W - 1 THEN x2 = SCR_W - 1
    IF y2 > SCR_H - 1 THEN y2 = SCR_H - 1
    IF x2 < x1 OR y2 < y1 THEN
        contextOverlayBackValid = 0
        EXIT SUB
    END IF

    newW = x2 - x1 + 1
    newH = y2 - y1 + 1

    IF contextOverlayBackBuffer = 0 OR contextOverlayBackW <> newW OR contextOverlayBackH <> newH THEN
        FreeContextOverlayBackBuffer
        contextOverlayBackBuffer = ImageCreate(newW, newH, 0)
    END IF

    IF contextOverlayBackBuffer = 0 THEN
        contextOverlayBackValid = 0
        EXIT SUB
    END IF

    contextOverlayBackX = x1
    contextOverlayBackY = y1
    contextOverlayBackW = newW
    contextOverlayBackH = newH
    GET (x1, y1)-(x2, y2), contextOverlayBackBuffer
    contextOverlayBackValid = -1
END SUB

SUB DrawContextOverlayCloseOnly(BYVAL mx AS INTEGER, BYVAL my AS INTEGER)
    IF contextOverlayBackBuffer = 0 OR contextOverlayBackValid = 0 THEN EXIT SUB

    SCREENLOCK
    RestoreCursorBackBuffer
    PUT (contextOverlayBackX, contextOverlayBackY), contextOverlayBackBuffer, PSET
    contextOverlayBackValid = 0
    SaveCursorBackBuffer mx, my
    DrawCursor mx, my
    SCREENUNLOCK
END SUB


SUB DrawStartMenuItemRow(BYVAL itemIdx AS INTEGER, BYVAL hoverIndex AS INTEGER)
    DIM parentIdx AS INTEGER
    DIM rowY AS INTEGER
    DIM rowH AS INTEGER
    DIM contentX1 AS INTEGER
    DIM panelX2 AS INTEGER
    DIM rowX1 AS INTEGER
    DIM rowX2 AS INTEGER
    DIM rowY2 AS INTEGER
    DIM txtCol AS UINTEGER
    DIM isHot AS INTEGER
    DIM hasIcons AS INTEGER
    DIM textX AS INTEGER
    DIM itemLevel AS INTEGER

    IF itemIdx < 1 OR itemIdx > menuCount THEN EXIT SUB
    IF menuItemRowVisible(itemIdx) = 0 THEN EXIT SUB

    parentIdx = menuItems(itemIdx).parentIdx
    BuildMenuPanelMetrics parentIdx
    hasIcons = menuPanelHasIconsCache(parentIdx)

    rowX1 = menuItemRowX1(itemIdx)
    rowY = menuItemRowY1(itemIdx)
    rowX2 = menuItemRowX2(itemIdx)
    rowY2 = menuItemRowY2(itemIdx)
    rowH = rowY2 - rowY + 1
    contentX1 = rowX1 - 2
    panelX2 = rowX2 + 2

    LINE (rowX1, rowY)-(rowX2, rowY2), COL_TASKBAR, BF

    IF menuItemIsDivider(itemIdx) <> 0 THEN
        LINE (contentX1 + MENU_PAD_X + 2, rowY + rowH \ 2)-(panelX2 - MENU_PAD_X - 2, rowY + rowH \ 2), COL_BEVEL_LO
        LINE (contentX1 + MENU_PAD_X + 2, rowY + rowH \ 2 + 1)-(panelX2 - MENU_PAD_X - 2, rowY + rowH \ 2 + 1), COL_BEVEL_HI
        EXIT SUB
    END IF

    isHot = 0
    IF itemIdx = hoverIndex THEN isHot = -1
    IF menuItemHasSubmenu(itemIdx) <> 0 THEN
        itemLevel = menuItemRowLevel(itemIdx)
        IF itemLevel >= 0 AND itemLevel <= 8 THEN
            IF menuOpenItem(itemLevel) = itemIdx THEN isHot = -1
        END IF
    END IF

    IF isHot <> 0 THEN
        LINE (contentX1 + 3, rowY + 1)-(panelX2 - 3, rowY2 - 1), COL_SELECT, BF
        txtCol = COL_SELECTED_TEXT
    ELSE
        txtCol = COL_TEXT
    END IF

    IF hasIcons <> 0 THEN
        DrawMenuItemIcon itemIdx, contentX1 + MENU_ICON_X, rowY + MENU_ROW_PAD_Y - 1
        textX = contentX1 + MENU_TEXT_X
    ELSE
        textX = contentX1 + MENU_PAD_X
    END IF

    DRAW STRING (textX, rowY + MENU_ROW_PAD_Y + 1), menuItems(itemIdx).caption, txtCol

    IF menuItemHasSubmenu(itemIdx) <> 0 THEN
        DrawSubmenuArrow panelX2 - MENU_ARROW_PAD, rowY + MENU_ROW_PAD_Y + 1, txtCol
    END IF
END SUB

SUB DrawStartMenuRowsOnly(BYVAL oldHoverIndex AS INTEGER, BYVAL newHoverIndex AS INTEGER, BYVAL mx AS INTEGER, BYVAL my AS INTEGER)
    IF startMenuOpen = 0 THEN EXIT SUB
    IF startMenuBackValid = 0 THEN
        DrawStartMenuOverlay newHoverIndex, mx, my
        EXIT SUB
    END IF

    SCREENLOCK
    RestoreCursorBackBuffer
    IF oldHoverIndex >= 1 AND oldHoverIndex <= menuCount THEN DrawStartMenuItemRow oldHoverIndex, newHoverIndex
    IF newHoverIndex >= 1 AND newHoverIndex <= menuCount THEN
        IF newHoverIndex <> oldHoverIndex THEN DrawStartMenuItemRow newHoverIndex, newHoverIndex
    END IF
    SaveCursorBackBuffer mx, my
    DrawCursor mx, my
    SCREENUNLOCK
END SUB


SUB DrawStartButtonOnly(BYVAL startPressed AS INTEGER)
    IF cfg.showTaskbar = 0 THEN EXIT SUB

    DrawButtonBevelBox START_X1, START_Y1, START_X2, START_Y2, startPressed

    IF DrawLaunchButtonBmp(START_X1, START_Y1, START_X2, START_Y2, startPressed) = 0 THEN
        IF startPressed THEN
            DRAW STRING (START_X1 + 14, START_Y1 + 6), cfg.launchLabel, COL_TEXT
        ELSE
            DRAW STRING (START_X1 + 13, START_Y1 + 5), cfg.launchLabel, COL_TEXT
        END IF
    END IF
END SUB


SUB DrawStartMenuOpenOnly(BYVAL hoverIndex AS INTEGER, BYVAL startPressed AS INTEGER, BYVAL mx AS INTEGER, BYVAL my AS INTEGER)
    IF startMenuOpen = 0 THEN EXIT SUB

    SCREENLOCK
    RestoreCursorBackBuffer

    ' Opening the Launch menu should not repaint the whole desktop and every window.
    ' The existing screen is already correct; update the taskbar button, save what
    ' sits under the menu rectangle, and draw the menu overlay directly.
    DrawStartButtonOnly startPressed
    CaptureStartMenuBackBuffer 0
    DrawStartMenu hoverIndex

    SaveCursorBackBuffer mx, my
    DrawCursor mx, my
    SCREENUNLOCK
END SUB

SUB DrawStartMenuCloseOnly(BYVAL startPressed AS INTEGER, BYVAL mx AS INTEGER, BYVAL my AS INTEGER)
    IF startMenuBackBuffer = 0 OR startMenuBackValid = 0 THEN
        ' This is only a safety fallback if the backing store was not available.
        ' The normal Start-button close path should restore directly.
        DrawScreen 0, startPressed, mx, my
        EXIT SUB
    END IF

    SCREENLOCK
    RestoreCursorBackBuffer

    ' Put back only the screen area that the Launch menu covered.
    ' Do not redraw the desktop or windows just to close that overlay.
    PUT (startMenuBackX, startMenuBackY), startMenuBackBuffer, PSET
    startMenuBackValid = 0
    DrawStartButtonOnly startPressed

    SaveCursorBackBuffer mx, my
    DrawCursor mx, my
    SCREENUNLOCK
END SUB


SUB DrawStartMenuOverlay(BYVAL hoverIndex AS INTEGER, BYVAL mx AS INTEGER, BYVAL my AS INTEGER)
    IF startMenuOpen = 0 THEN EXIT SUB

    IF startMenuBranchChangeLevel >= 0 AND startMenuBranchChangeLevel <= 8 THEN
        IF DrawStartMenuBranchOnly(hoverIndex, mx, my) <> 0 THEN
            startMenuBranchChangeLevel = 9
            startMenuBranchOldItem = 0
            startMenuBranchNewItem = 0
            EXIT SUB
        END IF
        startMenuBranchChangeLevel = 9
        startMenuBranchOldItem = 0
        startMenuBranchNewItem = 0
    END IF

    IF startMenuBackBuffer = 0 OR startMenuBackValid = 0 THEN
        DrawScreen hoverIndex, 0, mx, my
        EXIT SUB
    END IF

    SCREENLOCK
    RestoreCursorBackBuffer
    PUT (startMenuBackX, startMenuBackY), startMenuBackBuffer, PSET
    CaptureStartMenuBackBuffer -1
    DrawStartMenu hoverIndex
    SaveCursorBackBuffer mx, my
    DrawCursor mx, my
    SCREENUNLOCK
END SUB

FUNCTION DrawStartMenuProtectedActiveRedraw(BYVAL hoverIndex AS INTEGER, BYVAL mx AS INTEGER, BYVAL my AS INTEGER, BYVAL skipFullCache AS INTEGER) AS INTEGER
    DrawStartMenuProtectedActiveRedraw = 0

    IF startMenuOpen = 0 THEN EXIT FUNCTION
    IF startMenuBackBuffer = 0 OR startMenuBackValid = 0 THEN EXIT FUNCTION
    IF activeLayoutWindow < LBOUND(layoutWindows) OR activeLayoutWindow > UBOUND(layoutWindows) THEN EXIT FUNCTION
    IF layoutWindows(activeLayoutWindow).used = 0 THEN EXIT FUNCTION
    IF layoutWindows(activeLayoutWindow).minimized <> 0 THEN EXIT FUNCTION

    SCREENLOCK
    RestoreCursorBackBuffer

    ' Restore the Launch-menu backing first so the active window redraws behind it,
    ' then recapture that backing before drawing the menu again.
    PUT (startMenuBackX, startMenuBackY), startMenuBackBuffer, PSET

    IF skipFullCache <> 0 THEN
        layoutDrawCacheValid(activeLayoutWindow) = 0
        layoutSkipFullWindowCacheCapture = -1
        DrawLayoutWindowCached activeLayoutWindow
        layoutSkipFullWindowCacheCapture = 0
    ELSE
        DrawLayoutWindowCached activeLayoutWindow
    END IF

    DrawSoundVolumePopup
    CaptureStartMenuBackBuffer -1
    DrawStartMenu hoverIndex

    SaveCursorBackBuffer mx, my
    DrawCursor mx, my
    SCREENUNLOCK

    DrawStartMenuProtectedActiveRedraw = -1
END FUNCTION

SUB DrawTaskbarClockOnly(BYVAL mx AS INTEGER, BYVAL my AS INTEGER)
