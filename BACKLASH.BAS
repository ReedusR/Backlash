SUB FreeInactiveLayoutWindowCaches(BYVAL keepWin AS INTEGER)
    DIM winIdx AS INTEGER

    ' Keep persistent image caches only for the active/top window. Multiple
    ' open windows can otherwise retain full-window/static/chrome/element
    ' buffers at the same time, which exhausts DOS graphics memory during
    ' repeated open/close testing.
    FOR winIdx = LBOUND(layoutWindows) TO UBOUND(layoutWindows)
        IF winIdx <> keepWin THEN
            FreeLayoutWindowDrawCache winIdx
            FreeLayoutWindowStaticCache winIdx
            FreeLayoutWindowChromeCache winIdx
            FreeLayoutWindowElementCaches winIdx
        END IF
    NEXT
END SUB

SUB InvalidateLivePreviewCachesForWindow(BYVAL winIdx AS INTEGER)
    DIM elemIdx AS INTEGER
    DIM elemKind AS STRING

    IF winIdx < 1 OR winIdx > 12 THEN EXIT SUB
    IF layoutWindows(winIdx).used = 0 THEN EXIT SUB

    FOR elemIdx = 1 TO layoutUiCount(winIdx)
        elemKind = layoutUiElems(winIdx, elemIdx).kindKey
        IF elemKind = "PREVIEW" THEN
            FreeLayoutElementDrawCache winIdx, elemIdx
        END IF
    NEXT

    ' The live preview renderer has its own shared backing image.
    ' When any control value changes, dependent previews must not reuse it.
    FreeScriptPreviewCache
    layoutDrawCacheValid(winIdx) = 0
END SUB

SUB InvalidateLivePreviewCachesForControl(BYVAL winIdx AS INTEGER, BYVAL changedElemIdx AS INTEGER)
    DIM elemIdx AS INTEGER
    DIM elemKind AS STRING
    DIM elemMode AS STRING
    DIM changedKind AS STRING
    DIM changedName AS STRING
    DIM changedGroup AS STRING
    DIM previewSource AS STRING
    DIM previewAffected AS INTEGER
    DIM sysPreviewAffected AS INTEGER
    DIM anyPreviewAffected AS INTEGER

    IF winIdx < 1 OR winIdx > 12 THEN EXIT SUB
    IF layoutWindows(winIdx).used = 0 THEN EXIT SUB
    IF changedElemIdx < 1 OR changedElemIdx > uiCount THEN EXIT SUB

    changedKind = uiElems(changedElemIdx).kindKey
    changedName = uiElems(changedElemIdx).nameKey
    changedGroup = uiElems(changedElemIdx).groupKey
    sysPreviewAffected = 0
    anyPreviewAffected = 0

    IF TRIM$(uiElems(changedElemIdx).bindKey) <> "" THEN sysPreviewAffected = -1

    FOR elemIdx = 1 TO uiCount
        elemKind = uiElems(elemIdx).kindKey
        IF elemKind = "PREVIEW" OR elemKind = "OVERLAY" THEN
            elemMode = uiElems(elemIdx).modeKey
            previewAffected = 0

            IF elemKind = "PREVIEW" AND elemMode = "SYS" THEN
                IF sysPreviewAffected <> 0 THEN previewAffected = -1
            ELSE
                previewSource = uiElems(elemIdx).sourceControlKey
                IF previewSource <> "" AND previewSource = changedName THEN previewAffected = -1

                IF elemKind = "PREVIEW" AND changedKind = "RADIO" AND changedGroup <> "" THEN
                    IF elemMode <> "" AND elemMode = changedGroup THEN previewAffected = -1
                END IF
            END IF

            IF previewAffected <> 0 THEN
                IF elemKind = "OVERLAY" THEN
                    MarkLayoutWindowDirty winIdx
                ELSE
                    FreeLayoutElementDrawCache winIdx, elemIdx
                    MarkLayoutDirtyElement winIdx, elemIdx
                END IF
                anyPreviewAffected = -1
            END IF
        END IF
    NEXT

    IF sysPreviewAffected <> 0 AND anyPreviewAffected <> 0 THEN FreeScriptPreviewCache
    IF anyPreviewAffected <> 0 THEN layoutDrawCacheValid(winIdx) = 0
END SUB

SUB FreeAllLayoutWindowDrawCaches()
    DIM i AS INTEGER

    layoutRenderVersion = layoutRenderVersion + 1
    IF layoutRenderVersion > 1000000000 THEN layoutRenderVersion = 1

    FOR i = LBOUND(layoutDrawCache) TO UBOUND(layoutDrawCache)
        FreeLayoutWindowDrawCache i
        FreeLayoutWindowStaticCache i
        FreeLayoutWindowChromeCache i
        FreeLayoutWindowElementCaches i
    NEXT
END SUB

