    DRAW STRING (x1 + 18, y1 + 43), "Current time", COL_TEXT
    DrawBevelBox x1 + 76, y1 + 38, x2 - 18, y1 + 63, 1
    timeText = ClockPad2(clockSetHour) + ":" + ClockPad2(clockSetMinute)
    tx = x1 + 76 + (((x2 - 18) - (x1 + 76) + 1 - LEN(timeText) * 8) \ 2)
    DRAW STRING (tx, y1 + 47), timeText, COL_TEXT
    DrawButtonBevelBox x1 + 28, y1 + 74, x1 + 59, y1 + 94, 0
    DRAW STRING (x1 + 36, y1 + 80), "H-", COL_TEXT
    DrawButtonBevelBox x1 + 66, y1 + 74, x1 + 97, y1 + 94, 0
    DRAW STRING (x1 + 74, y1 + 80), "H+", COL_TEXT
    DrawButtonBevelBox x1 + 126, y1 + 74, x1 + 157, y1 + 94, 0
    DRAW STRING (x1 + 134, y1 + 80), "M-", COL_TEXT
    DrawButtonBevelBox x1 + 164, y1 + 74, x1 + 195, y1 + 94, 0
    DRAW STRING (x1 + 172, y1 + 80), "M+", COL_TEXT
    DRAW STRING (x1 + 18, y1 + 105), "Apply changes DOS time.", COL_TEXT
    DrawButtonBevelBox x1 + 48, y2 - 30, x1 + 107, y2 - 10, 0
    DRAW STRING (x1 + 60, y2 - 24), "Apply", COL_TEXT
    DrawButtonBevelBox x2 - 70, y2 - 30, x2 - 12, y2 - 10, 0
    DRAW STRING (x2 - 58, y2 - 24), "Close", COL_TEXT
