SUB ShowDesktopIconDelete(BYVAL iconIdx AS INTEGER)
    DIM dlgPath AS STRING

    IF iconIdx < 1 OR iconIdx > iconCount THEN EXIT SUB
    IF DesktopIconBmpIsTrashAware(desktopIcons(iconIdx).bmpFile) <> 0 THEN EXIT SUB

    desktopDeleteIconIdx = iconIdx
    WriteDesktopIconDeleteTemp iconIdx
    dlgPath = DesktopIconDeleteDialogPath()

    IF dlgPath = "" OR DIR(LayoutFilePath(dlgPath)) = "" THEN
        ShowGuiMessageBox "Desktop Icon", "Delete layout is unavailable."
        EXIT SUB
    END IF

    startMenuOpen = 0
    launchCtxOpen = 0
    desktopCtxOpen = 0
    ExecuteAppFile dlgPath
END SUB

SUB ApplyDesktopIconDelete()
    DIM oldCount AS INTEGER
    DIM i AS INTEGER

    IF desktopDeleteIconIdx < 1 OR desktopDeleteIconIdx > iconCount THEN EXIT SUB
    IF DesktopIconBmpIsTrashAware(desktopIcons(desktopDeleteIconIdx).bmpFile) <> 0 THEN
        desktopDeleteIconIdx = 0
        desktopCtxIcon = 0
        desktopCtxOpen = 0
        EXIT SUB
    END IF
    IF TrashMoveDesktopIconToTrash(desktopDeleteIconIdx) = 0 THEN
        ShowGuiMessageBox "Desktop Icon", "Could not move icon to Waste Basket."
        EXIT SUB
    END IF

    oldCount = iconCount
    FreeDesktopIconImage desktopDeleteIconIdx

    FOR i = desktopDeleteIconIdx TO oldCount - 1
        MoveDesktopIconSlot i, i + 1
    NEXT

    ClearDesktopIconSlot oldCount

    iconCount = oldCount - 1
    selectedIcon = 0
    desktopCtxIcon = 0
    desktopCtxOpen = 0
    desktopDeleteIconIdx = 0
    desktopEditIconIdx = 0

    SaveDesktopIcons
    RefreshTrashAwareDesktopIcons
    InvalidateDesktopCache
END SUB

