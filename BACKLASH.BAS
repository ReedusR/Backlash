    outText = outText + "AdLib/OPL" + eol
    outText = outText + "adlib_detect_enabled=" + SoundBoolText(soundAdlibDetectEnabled) + eol
    outText = outText + "adlib_base_hex=" + SoundHexWord(soundAdlibBase) + eol
    outText = outText + "adlib_detected=" + SoundBoolText(soundAdlibDetected) + eol
    outText = outText + eol
    outText = outText + "Sound Blaster" + eol
    outText = outText + "blaster_env=" + sbEnv + eol
    outText = outText + "sb_detect_enabled=" + SoundBoolText(soundSbDetectEnabled) + eol
    outText = outText + "sb_base_hex=" + SoundHexWord(soundSbBase) + eol
    outText = outText + "sb_irq=" + LTRIM$(STR$(soundSbIrq)) + eol
    outText = outText + "sb_dma8=" + LTRIM$(STR$(soundSbDma8)) + eol
    outText = outText + "sb_dma16=" + LTRIM$(STR$(soundSbDma16)) + eol
    outText = outText + "sb_type=" + LTRIM$(STR$(soundSbType)) + eol
    outText = outText + "sb_dsp_detected=" + SoundBoolText(soundSbDetected) + eol
    IF soundSbDspVersionMajor >= 0 THEN
        outText = outText + "sb_dsp_version_known=YES" + eol
        outText = outText + "sb_dsp_version_major=" + LTRIM$(STR$(soundSbDspVersionMajor)) + eol
        outText = outText + "sb_dsp_version_minor=" + LTRIM$(STR$(soundSbDspVersionMinor)) + eol
    ELSE
        outText = outText + "sb_dsp_version_known=NO" + eol
        outText = outText + "sb_dsp_version_major=-1" + eol
