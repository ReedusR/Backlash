        itemCount = DelimitedListCount(selectedList)
        IF itemCount > 0 THEN
            dlgPath = AppDialogPath(winIdx, "DELETE_DIALOG", "")

            IF dlgPath = "" OR DIR(LayoutFilePath(dlgPath)) = "" THEN
                IF itemCount = 1 THEN
                    statusText = "Delete dialog unavailable for " + selectedList
                ELSE
