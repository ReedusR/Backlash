    ELSE
        outText = outText + "sb_direct_test_ready=NO" + eol
    END IF
    outText = outText + "sb_dma8_channel_valid=" + SoundBoolText(SoundBlasterDma8ChannelValid(soundSbDma8)) + eol
    outText = outText + "sb_dma_test_ready=" + SoundBoolText(SoundBlasterDma8TestReady()) + eol
