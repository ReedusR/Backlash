    FOR i = 1 TO 192
        layoutUiElems(idx, i).kind = ""
        layoutUiElems(idx, i).kindKey = ""
        layoutUiElems(idx, i).pageKey = ""
        layoutUiElems(idx, i).nameKey = ""
        layoutUiElems(idx, i).groupKey = ""
        layoutUiElems(idx, i).modeKey = ""
        layoutUiElems(idx, i).sourceControlKey = ""
        layoutUiElems(idx, i).drawStyleKey = ""
        layoutUiElems(idx, i).kindId = UI_KIND_NONE
        layoutUiElems(idx, i).modeId = UI_MODE_NONE
        layoutUiElems(idx, i).sourceKindId = UI_SOURCE_NONE
        layoutUiElems(idx, i).drawStyleId = UI_DRAW_NONE
        layoutUiElems(idx, i).text = ""
        layoutUiElems(idx, i).x = 0
        layoutUiElems(idx, i).y = 0
