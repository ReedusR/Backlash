    CASE "FILE_BROWSER_DELETE_APPLY"
        fileControlName = NextActionToken(args)
        controlName = NextActionToken(args)
        recursiveControlName = NextActionToken(args)
        permanentControlName = NextActionToken(args)
        deleteRecursiveOpt = GetControlStateByName(recursiveControlName)
        deletePermanentOpt = GetControlStateByName(permanentControlName)

        selectedPath = ResolveDeletePathForApply(TRIM$(GetTextboxTextByName(fileControlName)), 0)
        selectedList = ""
        IF selectedPath = "" THEN
            IF INSTR(deleteFilePath, CHR$(1)) > 0 THEN
                selectedList = deleteFilePath
            ELSE
                selectedPath = ResolveDeletePathForApply(TRIM$(deleteFilePath), 0)
            END IF
        END IF
        IF selectedList = "" THEN selectedList = selectedPath
        itemCount = DelimitedListCount(selectedList)

        IF itemCount < 1 THEN
            statusText = "Delete unavailable"
        ELSEIF itemCount > 1 THEN
            itemList = selectedList
            successCount = 0
            failCount = 0
            parentDir = ""

            DO WHILE itemList <> ""
                sepPos = INSTR(itemList, CHR$(1))
                IF sepPos > 0 THEN
                    itemPath = LEFT$(itemList, sepPos - 1)
                    itemList = MID$(itemList, sepPos + 1)
                ELSE
                    itemPath = itemList
                    itemList = ""
                END IF

                selectedPath = ResolveDeletePathForApply(TRIM$(itemPath), 0)
                IF parentDir = "" AND selectedPath <> "" THEN parentDir = ParentPath(selectedPath)

                IF selectedPath = "" THEN
                    failCount = failCount + 1
                ELSEIF INSTR(selectedPath, "*") > 0 OR INSTR(selectedPath, "?") > 0 THEN
                    failCount = failCount + 1
                ELSEIF PathExistsAny(selectedPath) = 0 THEN
                    failCount = failCount + 1
                ELSEIF deletePermanentOpt <> 0 THEN
                    deleteFilesDone = 0
                    deleteDirsDone = 0
                    deleteFailsDone = 0
                    deletedOk = DeletePathPermanent(selectedPath, deleteRecursiveOpt, deleteFilesDone, deleteDirsDone, deleteFailsDone)
                    IF deletedOk <> 0 THEN
                        successCount = successCount + 1
                    ELSE
                        failCount = failCount + 1
                    END IF
                ELSEIF deleteRecursiveOpt <> 0 AND DirectoryExistsForDelete(selectedPath) <> 0 THEN
                    deleteFilesDone = 0
                    deleteDirsDone = 0
                    deleteFailsDone = 0
                    deletedOk = TrashMovePathToTrash(selectedPath, deleteRecursiveOpt)
                    IF deletedOk <> 0 THEN
                        successCount = successCount + 1
                    ELSE
                        failCount = failCount + 1
                    END IF
                ELSEIF TrashMovePathToTrash(selectedPath, deleteRecursiveOpt) <> 0 THEN
                    successCount = successCount + 1
                ELSE
                    failCount = failCount + 1
                END IF
            LOOP

            IF successCount > 0 THEN
                deleteFilePath = ""

                IF deleteSourceWin >= LBOUND(layoutWindows) AND deleteSourceWin <= UBOUND(layoutWindows) THEN
                    IF layoutWindows(deleteSourceWin).used <> 0 THEN
                        restoreWin = activeLayoutWindow
                        ClearComboItemCache
                        FreeLayoutWindowElementCaches deleteSourceWin
                        FreeLayoutWindowDrawCache deleteSourceWin
                        ConfigureFileBrowserWindow deleteSourceWin, parentDir
                        activeLayoutWindow = restoreWin
                        IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
                            IF layoutWindows(activeLayoutWindow).used <> 0 THEN
                                FOR i = LBOUND(layoutWindows) TO UBOUND(layoutWindows)
                                    IF layoutWindows(i).used <> 0 THEN layoutWindows(i).active = 0
                                NEXT
                                layoutWindows(activeLayoutWindow).active = -1
                                MoveLayoutWindowToFront activeLayoutWindow
                                SyncGlobalsFromLayoutWindow activeLayoutWindow
                            END IF
                        END IF
                    END IF
                END IF

            END IF

            IF successCount = 0 THEN
                statusText = "Delete failed"
            ELSEIF failCount > 0 THEN
                IF deletePermanentOpt <> 0 THEN
                    statusText = "Deleted " + LTRIM$(STR$(successCount)) + ", failed " + LTRIM$(STR$(failCount))
                ELSE
                    statusText = "Moved " + LTRIM$(STR$(successCount)) + ", failed " + LTRIM$(STR$(failCount))
                END IF
            ELSEIF deletePermanentOpt <> 0 THEN
                statusText = "Deleted " + LTRIM$(STR$(successCount)) + " items permanently"
            ELSE
                statusText = "Moved " + LTRIM$(STR$(successCount)) + " items to Waste Basket"
            END IF
        ELSE
            selectedPath = ResolveDeletePathForApply(TRIM$(selectedList), 0)
            IF selectedPath = "" THEN
                statusText = "Delete unavailable"
            ELSEIF INSTR(selectedPath, "*") > 0 OR INSTR(selectedPath, "?") > 0 THEN
                statusText = "Invalid file path"
            ELSEIF PathExistsAny(selectedPath) = 0 THEN
                statusText = "Item not found"
            ELSE
                parentDir = ParentPath(selectedPath)
                deleteFilesDone = 0
                deleteDirsDone = 0
                deleteFailsDone = 0
                IF deletePermanentOpt <> 0 THEN
                    deletedOk = DeletePathPermanent(selectedPath, deleteRecursiveOpt, deleteFilesDone, deleteDirsDone, deleteFailsDone)
                ELSE
                    deletedOk = TrashMovePathToTrash(selectedPath, deleteRecursiveOpt)
                END IF
                IF deletedOk <> 0 THEN
                    deleteFilePath = ""
                    IF deleteFailsDone > 0 THEN
                        IF deletePermanentOpt <> 0 THEN
                            statusText = "Deleted permanently with " + LTRIM$(STR$(deleteFailsDone)) + " failures"
                        ELSE
                            statusText = "Moved to Waste Basket with " + LTRIM$(STR$(deleteFailsDone)) + " failures"
                        END IF
                    ELSEIF deletePermanentOpt <> 0 THEN
                        statusText = "Deleted " + FileNameOnly(selectedPath) + " permanently"
                    ELSE
                        statusText = "Moved " + FileNameOnly(selectedPath) + " to Waste Basket"
                    END IF

                    IF deleteSourceWin >= LBOUND(layoutWindows) AND deleteSourceWin <= UBOUND(layoutWindows) THEN
                        IF layoutWindows(deleteSourceWin).used <> 0 THEN
                            restoreWin = activeLayoutWindow
                            ClearComboItemCache
                            FreeLayoutWindowElementCaches deleteSourceWin
                            FreeLayoutWindowDrawCache deleteSourceWin
                            ConfigureFileBrowserWindow deleteSourceWin, parentDir
                            activeLayoutWindow = restoreWin
                            IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
                                IF layoutWindows(activeLayoutWindow).used <> 0 THEN
                                    FOR i = LBOUND(layoutWindows) TO UBOUND(layoutWindows)
                                        IF layoutWindows(i).used <> 0 THEN layoutWindows(i).active = 0
                                    NEXT
                                    layoutWindows(activeLayoutWindow).active = -1
                                    MoveLayoutWindowToFront activeLayoutWindow
                                    SyncGlobalsFromLayoutWindow activeLayoutWindow
                                END IF
                            END IF
                        END IF
                    END IF
                ELSE
                    statusText = "Delete failed"
                END IF
            END IF
        END IF

        SetTextboxTextByName controlName, statusText
        uiPressedIndex = 0
        IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
            IF layoutWindows(activeLayoutWindow).used <> 0 THEN
                layoutWindows(activeLayoutWindow).pressedIndex = 0
                SyncLayoutWindowFromGlobals activeLayoutWindow
            END IF
        END IF
    CASE "TRASH_REFRESH"
        trashListControlName = NextActionToken(args)
        controlName = NextActionToken(args)
        TrashRefreshControls winIdx, trashListControlName, controlName

    CASE "TRASH_RESTORE"
        trashListControlName = NextActionToken(args)
        controlName = NextActionToken(args)
        trashIdList = ""
        clearIdx = GetControlIndexByName(trashListControlName)
        IF clearIdx >= 1 AND clearIdx <= uiCount THEN
            trashSelectedValue = ControlValueFromListControl(clearIdx)
            trashIdList = layoutListMultiSel(winIdx, clearIdx)
            IF TRIM$(trashIdList) = "" THEN trashIdList = trashSelectedValue
        END IF

        successCount = 0
        failCount = 0
        DO WHILE trashIdList <> ""
            sepPos = INSTR(trashIdList, CHR$(1))
            IF sepPos > 0 THEN
                trashId = LEFT$(trashIdList, sepPos - 1)
                trashIdList = MID$(trashIdList, sepPos + 1)
            ELSE
                trashId = trashIdList
                trashIdList = ""
            END IF
            IF TrashRestoreId(trashId) <> 0 THEN
                successCount = successCount + 1
            ELSE
                failCount = failCount + 1
            END IF
        LOOP

        IF successCount = 0 AND failCount = 0 THEN
            statusText = "Select an item to restore"
        ELSEIF failCount > 0 THEN
            statusText = "Restored " + LTRIM$(STR$(successCount)) + ", failed " + LTRIM$(STR$(failCount))
        ELSE
            statusText = "Restored " + LTRIM$(STR$(successCount)) + " items"
        END IF
        TrashRefreshControls winIdx, trashListControlName, controlName
        IF controlName <> "" THEN SetTextboxTextByName controlName, statusText

    CASE "TRASH_DELETE"
        trashListControlName = NextActionToken(args)
        controlName = NextActionToken(args)
        trashIdList = ""
        clearIdx = GetControlIndexByName(trashListControlName)
        IF clearIdx >= 1 AND clearIdx <= uiCount THEN
            trashSelectedValue = ControlValueFromListControl(clearIdx)
            trashIdList = layoutListMultiSel(winIdx, clearIdx)
            IF TRIM$(trashIdList) = "" THEN trashIdList = trashSelectedValue
        END IF

        successCount = 0
        failCount = 0
        DO WHILE trashIdList <> ""
            sepPos = INSTR(trashIdList, CHR$(1))
            IF sepPos > 0 THEN
                trashId = LEFT$(trashIdList, sepPos - 1)
                trashIdList = MID$(trashIdList, sepPos + 1)
            ELSE
                trashId = trashIdList
                trashIdList = ""
            END IF
            IF TrashDeleteIdPermanent(trashId) <> 0 THEN
                successCount = successCount + 1
            ELSE
                failCount = failCount + 1
            END IF
        LOOP

        IF successCount = 0 AND failCount = 0 THEN
            statusText = "Select an item to delete permanently"
        ELSEIF failCount > 0 THEN
            statusText = "Deleted " + LTRIM$(STR$(successCount)) + ", failed " + LTRIM$(STR$(failCount))
        ELSE
            statusText = "Deleted " + LTRIM$(STR$(successCount)) + " items permanently"
        END IF
        TrashRefreshControls winIdx, trashListControlName, controlName
        IF controlName <> "" THEN SetTextboxTextByName controlName, statusText

    CASE "TRASH_EMPTY"
        trashListControlName = NextActionToken(args)
        controlName = NextActionToken(args)
        trashIdList = ""
        TrashEnsure
        trashFileNum = FREEFILE
        IF OPEN(PATH_TRASHIDX FOR INPUT AS #trashFileNum) = 0 THEN
            DO WHILE NOT EOF(trashFileNum)
                LINE INPUT #trashFileNum, trashId
                trashId = UCASE$(TRIM$(trashId))
                IF trashId <> "" THEN
                    IF trashIdList <> "" THEN trashIdList = trashIdList + CHR$(1)
                    trashIdList = trashIdList + trashId
                END IF
            LOOP
            CLOSE #trashFileNum
        END IF

        successCount = 0
        failCount = 0
        DO WHILE trashIdList <> ""
            sepPos = INSTR(trashIdList, CHR$(1))
            IF sepPos > 0 THEN
                trashId = LEFT$(trashIdList, sepPos - 1)
                trashIdList = MID$(trashIdList, sepPos + 1)
            ELSE
                trashId = trashIdList
                trashIdList = ""
            END IF
            IF TrashDeleteIdPermanent(trashId) <> 0 THEN
                successCount = successCount + 1
            ELSE
                failCount = failCount + 1
            END IF
        LOOP

        IF successCount = 0 AND failCount = 0 THEN
            statusText = "Waste Basket is already empty"
        ELSEIF failCount > 0 THEN
            statusText = "Emptied " + LTRIM$(STR$(successCount)) + ", failed " + LTRIM$(STR$(failCount))
        ELSE
            statusText = "Waste Basket emptied"
        END IF
        TrashRefreshControls winIdx, trashListControlName, controlName
        IF controlName <> "" THEN SetTextboxTextByName controlName, statusText

    CASE "FILE_BROWSER_FILE_PROPERTIES"
        fileControlName = NextActionToken(args)
        controlName = NextActionToken(args)
        IF fileControlName = "" THEN fileControlName = AppControlNameValue(winIdx, "FILE_BROWSER_FILE_CONTROL", "")
        IF controlName = "" THEN controlName = AppControlNameValue(winIdx, "FILE_BROWSER_STATUS_CONTROL", "")

        selectedName = ""
        clearIdx = GetControlIndexByName(fileControlName)
        IF clearIdx >= 1 AND clearIdx <= uiCount THEN
            IF uiElems(clearIdx).kindId = UI_KIND_LISTBOX THEN
                selectedName = ControlValueFromListControl(clearIdx)
            END IF
        END IF

        selectedPath = ""
        propItemIsDir = 0
        IF LEFT$(UCASE$(selectedName), 2) = "F:" THEN
            selectedPath = NormalizePath(MID$(selectedName, 3))
        ELSEIF LEFT$(UCASE$(selectedName), 2) = "D:" THEN
            selectedPath = AbsoluteDirPath(MID$(selectedName, 3))
            propItemIsDir = -1
        ELSEIF selectedName <> "" THEN
            selectedPath = NormalizePath(selectedName)
        END IF

        IF selectedPath <> "" THEN
            IF propItemIsDir <> 0 THEN
                dlgPath = AppDialogPath(winIdx, "DIR_PROPERTIES_DIALOG", "")
                IF dlgPath = "" THEN dlgPath = AppDialogPath(winIdx, "PROPERTIES_DIALOG", "")
            ELSE
                dlgPath = AppDialogPath(winIdx, "PROPERTIES_DIALOG", "")
            END IF

            IF dlgPath = "" OR DIR(LayoutFilePath(dlgPath)) = "" THEN
                statusText = "Properties dialog unavailable for " + selectedPath
                SetTextboxTextByName controlName, statusText
            ELSE
                statusText = "Properties " + selectedPath
                SetTextboxTextByName controlName, statusText
                propertiesSourceWin = winIdx
                ShowFileProperties selectedPath, dlgPath, propItemIsDir
            END IF
        END IF

    CASE "FILE_BROWSER_ATTR_APPLY"
        ApplyPropertiesAttributeChange

    CASE "LAUNCH_APP"
        launchPath = ResolveAppLocalFilePath(winIdx, NextActionToken(args))
        IF launchPath <> "" THEN
            ExecuteLaunchTarget launchPath
        ELSE
            ShowGuiMessageBox "EMPTY LAUNCH TARGET:", "LAUNCH_APP"
        END IF
    END SELECT
END SUB

