                                listItemCount = ComboFastItemCount(releaseIndex, listCacheSlot)
                                comboRowsLoop = EffectiveComboRows(releaseIndex, ex, ey, ew, eh)
                                IF listItemCount < comboRowsLoop THEN comboRowsLoop = listItemCount
                                IF comboRowsLoop < 1 THEN comboRowsLoop = 1
                                comboItemHLoop = 16
                                comboHitTop = ey + eh
                                IF listCacheSlot > 0 THEN
                                    comboHitBottom = comboHitTop + ComboCachedPopupVisibleHeight(listCacheSlot, comboScrollTop(activeLayoutWindow, releaseIndex), comboRowsLoop)
                                ELSE
                                    comboHitBottom = comboHitTop + ComboPopupVisibleHeight(comboScrollTop(activeLayoutWindow, releaseIndex), comboRowsLoop)
                                END IF
                                comboPopupWLoop = ComboPopupWidth(releaseIndex, ew)
                                IF ex + comboPopupWLoop > contentRightLoop THEN comboPopupWLoop = contentRightLoop - ex
                                IF comboPopupWLoop < ew THEN comboPopupWLoop = ew
                                showComboScroll = 0
                                IF listItemCount > comboRowsLoop THEN showComboScroll = -1

                                IF smx >= ex AND smx <= ex + comboPopupWLoop AND smy >= comboHitTop AND smy <= comboHitBottom THEN
                                    IF showComboScroll <> 0 THEN
                                        comboScrollLeft = ex + comboPopupWLoop - 14
                                    ELSE
                                        comboScrollLeft = ex + comboPopupWLoop + 1
                                    END IF

                                    IF showComboScroll <> 0 AND smx >= comboScrollLeft THEN
                                        comboTrackTop = comboHitTop + 3
                                        comboTrackBottom = comboHitBottom - 3
                                        comboTrackH = comboTrackBottom - comboTrackTop + 1
                                        comboThumbH = CalcScrollThumbSize(comboRowsLoop, listItemCount, comboTrackH, 12)

                                        newTopIdx = ClampScrollPos(comboScrollTop(activeLayoutWindow, releaseIndex), listItemCount - comboRowsLoop)
                                        comboThumbTop = CalcScrollThumbTop(newTopIdx, listItemCount - comboRowsLoop, comboTrackTop, comboTrackH, comboThumbH)
                                        comboThumbBottom = comboThumbTop + comboThumbH - 1

                                        IF smy < comboThumbTop THEN
                                            newTopIdx = ClampScrollPos(newTopIdx - comboRowsLoop, listItemCount - comboRowsLoop)
                                        ELSEIF smy > comboThumbBottom THEN
                                            newTopIdx = ClampScrollPos(newTopIdx + comboRowsLoop, listItemCount - comboRowsLoop)
                                        ELSE
                                            comboThumbTop = smy - (comboThumbH \ 2)
                                            newTopIdx = CalcScrollPosFromThumbTop(comboThumbTop, comboTrackTop, comboTrackH, comboThumbH, listItemCount - comboRowsLoop)
                                        END IF
                                        comboScrollTop(activeLayoutWindow, releaseIndex) = newTopIdx
                                    ELSE
                                        IF listCacheSlot > 0 THEN
                                            comboSelIdx = ComboCachedPopupHitItem(listCacheSlot, smy, comboHitTop, comboScrollTop(activeLayoutWindow, releaseIndex), comboRowsLoop)
                                        ELSE
                                            comboSelIdx = ComboPopupHitItem(smy, comboHitTop, comboScrollTop(activeLayoutWindow, releaseIndex), comboRowsLoop)
                                        END IF
                                        IF comboSelIdx >= 1 AND comboSelIdx <= listItemCount THEN
                                            IF (listCacheSlot = 0 AND ComboItemIsDivider(comboSelIdx) = 0) OR _
                                               (listCacheSlot > 0 AND ComboCachedItemIsDivider(listCacheSlot, comboSelIdx) = 0) THEN
                                                uiElems(releaseIndex).text = ComboFastItemText(listCacheSlot, comboSelIdx)
                                                InvalidateLivePreviewCachesForControl activeLayoutWindow, releaseIndex
                                                IF TRIM$(uiElems(releaseIndex).bindFile) <> "" AND TRIM$(uiElems(releaseIndex).bindKey) <> "" THEN MarkWindowPresetDirty activeLayoutWindow
                                                AppRuntime_HandleEvent activeLayoutWindow, "CHANGE", uiElems(releaseIndex).name, uiElems(releaseIndex).text, uiElems(releaseIndex).action
                                                comboOpenIndex(activeLayoutWindow) = 0
                                                needRedraw = -1
                                            END IF
                                        END IF
                                    END IF
                                ELSEIF smx >= ex AND smx <= ex + ew AND smy >= ey AND smy <= ey + eh THEN
                                    comboOpenIndex(activeLayoutWindow) = 0
                                ELSE
                                    comboOpenIndex(activeLayoutWindow) = 0
                                END IF
                            ELSE
                                comboOpenIndex(activeLayoutWindow) = releaseIndex
                                comboScrollTop(activeLayoutWindow, releaseIndex) = 0
                            END IF
                            SyncLayoutWindowFromGlobals activeLayoutWindow
                            IF needRedraw = 0 THEN activeWindowOnlyRedraw = -1
                            oldMx = -1
                            oldMy = -1
                        END IF
                    END IF

                END IF

                uiPressedIndex = 0
                SyncLayoutWindowPressedOnly activeLayoutWindow
                    END IF


            altTabDown = LayoutAltTabDown()
            IF altTabDown <> 0 THEN
                keyIn = INKEY$
                keyIn = ""
                IF altTabWasDown = 0 THEN
                    ResetScreensaverIdle
                    startMenuOpen = 0
                    launchCtxOpen = 0
                    desktopCtxOpen = 0
                    ctxMenuOpen = 0
                    contextOverlayBackValid = 0
                    draggingLayoutWin = 0
                    resizingLayoutWin = 0
                    draggingVScroll = 0
                    draggingHScroll = 0
                    draggingComboScroll = 0
                    draggingListScroll = 0
                    draggingTextScroll = 0
                    draggingSplitter = 0
                    appViewDragElem = 0
                    appViewDragButton = 0
                    mouseDownIcon = 0
                    draggingIcon = 0
                    dragMoved = 0
                    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
                        comboOpenIndex(activeLayoutWindow) = 0
                    END IF
                    IF LayoutAltTabCycle() <> 0 THEN
                        needRedraw = -1
                        oldMx = -1
                        oldMy = -1
                    END IF
                END IF
            ELSE
                keyIn = INKEY$
            END IF
            altTabWasDown = altTabDown

            IF keyIn <> "" THEN
                ResetScreensaverIdle
                DIM appKeyAction AS STRING
                DIM appKeyToken AS STRING
                DIM textboxFocusEditable AS INTEGER
                DIM keyActionText AS STRING
                DIM keyActiveOnlyRedraw AS INTEGER
                DIM keyStartWin AS INTEGER
                DIM keyStartWindowCount AS INTEGER
                DIM focusedKeyRedrawMode AS INTEGER

                textboxFocusEditable = ActiveEditableTextboxFocused()
                appKeyAction = ""
                IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
                    IF layoutWindows(activeLayoutWindow).used <> 0 THEN
                        appKeyAction = layoutKeyAction(activeLayoutWindow)
                    END IF
                END IF
                IF appKeyAction <> "" AND textboxFocusEditable = 0 THEN
                    appKeyToken = LayoutKeyActionToken(keyIn)
                    IF appKeyToken <> "" THEN
                        keyActionText = appKeyAction + " " + appKeyToken
                        keyActiveOnlyRedraw = HostActionDirectActiveWindowRedrawOnly(keyActionText)
                        keyStartWin = activeLayoutWindow
                        keyStartWindowCount = layoutWindowCount
                        HostAppAction activeLayoutWindow, keyActionText
                        IF appKeyToken = "SPACE" OR appKeyToken = "CTRL_SPACE" THEN layoutSpaceWasDown = -1
                        keyIn = ""
                        ' Simple key actions can redraw only the active window.
                        ' Helper/dialog actions still force a full redraw.
                        IF keyActiveOnlyRedraw <> 0 AND activeLayoutWindow = keyStartWin AND layoutWindowCount = keyStartWindowCount AND _
                           startMenuOpen = 0 AND ctxMenuOpen = 0 AND launchCtxOpen = 0 AND desktopCtxOpen = 0 THEN
                            activeWindowOnlyRedraw = -1
                        ELSE
                            needRedraw = -1
                        END IF
                    END IF
                END IF

                IF keyIn <> "" THEN
                    IF LEN(keyIn) = 1 THEN
                        IF ASC(keyIn) = 19 OR ((MULTIKEY(29) OR MULTIKEY(157)) AND UCASE$(keyIn) = "S") THEN
                            DIM ctrlSAction AS STRING
                            ctrlSAction = ""
                            IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
                                IF layoutWindows(activeLayoutWindow).used <> 0 THEN
                                    ctrlSAction = layoutCtrlSAction(activeLayoutWindow)
                                END IF
                            END IF
                            IF ctrlSAction <> "" THEN
                                keyActiveOnlyRedraw = HostActionDirectActiveWindowRedrawOnly(ctrlSAction)
                                keyStartWin = activeLayoutWindow
                                keyStartWindowCount = layoutWindowCount
                                HostAppAction activeLayoutWindow, ctrlSAction
                                keyIn = ""
                                ' Ctrl+S usually saves or opens dialogs, so the classifier
                                ' keeps those actions on the full-redraw path.
                                IF keyActiveOnlyRedraw <> 0 AND activeLayoutWindow = keyStartWin AND layoutWindowCount = keyStartWindowCount AND _
                                   startMenuOpen = 0 AND ctxMenuOpen = 0 AND launchCtxOpen = 0 AND desktopCtxOpen = 0 THEN
                                    activeWindowOnlyRedraw = -1
                                ELSE
                                    needRedraw = -1
                                END IF
                            END IF
                        END IF
                    END IF
                END IF

                IF keyIn <> "" THEN
                    focusedKeyRedrawMode = DispatchFocusedControlKeyAction(keyIn)
                    IF focusedKeyRedrawMode <> 0 THEN
                        keyIn = ""
                        IF focusedKeyRedrawMode = 2 THEN
                            activeWindowOnlyRedraw = -1
                        ELSE
                            needRedraw = -1
                        END IF
                    END IF
                END IF

                IF keyIn <> "" THEN
                IF uiFocusIndex >= 1 AND uiFocusIndex <= uiCount THEN
                    IF uiElems(uiFocusIndex).kindId = UI_KIND_TEXTBOX AND uiElems(uiFocusIndex).noEdit = 0 THEN
                        DIM tbMulti AS INTEGER
                        DIM tbCols AS INTEGER
                        DIM clipHandled AS INTEGER
                        DIM findDialogOpenedFromTextbox AS INTEGER
                        DIM tabDirection AS INTEGER
                        DIM oldTbText AS STRING
                        DIM tbOldTextLen AS INTEGER
                        DIM tbTextChanged AS INTEGER
                        DIM tbPlainTypeInput AS INTEGER
                        DIM tbHadSelection AS INTEGER
                        DIM tbMetricInsertSafe AS INTEGER
                        DIM tbMetricInsertApplied AS INTEGER
                        DIM tbMetricShiftLine AS INTEGER
                        DIM tbNeedOldText AS INTEGER
                        DIM tbExtCode AS INTEGER
                        DIM tbOldCaretPos AS INTEGER
                        DIM tbOldCaretLine AS INTEGER
                        DIM tbNewCaretLine AS INTEGER
                        DIM tbOldLineCount AS INTEGER
                        DIM tbNewLineCount AS INTEGER
                        DIM tbOldLineStart AS INTEGER
                        DIM tbNewLineStart AS INTEGER
                        DIM tbOldLineEnd AS INTEGER
                        DIM tbNewLineEnd AS INTEGER
                        DIM tbOldScrollTop AS INTEGER
                        DIM tbNewScrollTop AS INTEGER
                        DIM tbFastLineRedraw AS INTEGER
                        DIM tbSimpleDeleteInput AS INTEGER
                        DIM tbMetricDeleteSafe AS INTEGER
                        DIM tbDeleteCharPos AS INTEGER
                        DIM tbDeleteCharCode AS INTEGER

                        tabDirection = 0
                        oldTbText = ""
                        tbOldTextLen = 0
                        tbMetricInsertSafe = 0
                        tbMetricInsertApplied = 0
                        tbSimpleDeleteInput = 0
                        tbMetricDeleteSafe = 0
                        tbDeleteCharPos = 0
                        tbDeleteCharCode = 0
                        tbNeedOldText = -1
                        tbExtCode = -1
                        IF LEN(keyIn) = 1 THEN
                            IF ASC(keyIn) = 9 THEN
                                tabDirection = 1
                                IF (MULTIKEY(42) OR MULTIKEY(54)) THEN tabDirection = -1
                            END IF
                        ELSEIF LEN(keyIn) = 2 THEN
                            IF ASC(RIGHT$(keyIn, 1)) = 15 THEN tabDirection = -1
                        END IF

                        IF tabDirection <> 0 THEN
                            IF FocusNextTextboxInActivePage(tabDirection) <> 0 THEN
                                keyIn = ""
                                activeWindowOnlyRedraw = -1
                            END IF
                        END IF

                        IF keyIn <> "" THEN
                        tbMulti = TextboxIsMultiline(uiFocusIndex)
                        tbCols = TextboxCols(uiFocusIndex)
                        maxChars = tbCols
                        IF uiElems(uiFocusIndex).maxLen > 0 THEN maxChars = uiElems(uiFocusIndex).maxLen
                        IF tbMulti <> 0 THEN maxChars = 40000

                        IF uiEdit(uiFocusIndex).txtLen = 0 THEN
                            Ed_LoadTxt uiEdit(uiFocusIndex), uiElems(uiFocusIndex).text, uiCaretPos
                        END IF

                        tbOldTextLen = uiEdit(uiFocusIndex).txtLen
                        tbPlainTypeInput = 0
                        IF LEN(keyIn) = 1 THEN
                            IF ASC(keyIn) >= 32 AND ASC(keyIn) <> 127 THEN
                                IF (MULTIKEY(29) OR MULTIKEY(157)) = 0 THEN tbPlainTypeInput = -1
                            END IF
                        END IF

                        tbHadSelection = Ed_SelHas(uiEdit(uiFocusIndex))
                        IF tbHadSelection = 0 AND (MULTIKEY(29) OR MULTIKEY(157)) = 0 THEN
                            IF LEN(keyIn) = 1 THEN
                                IF ASC(keyIn) = 8 THEN
                                    IF uiEdit(uiFocusIndex).curPos > 0 THEN
                                        tbSimpleDeleteInput = -1
                                        tbDeleteCharPos = uiEdit(uiFocusIndex).curPos
                                    END IF
                                ELSEIF ASC(keyIn) = 127 THEN
                                    IF uiEdit(uiFocusIndex).curPos < uiEdit(uiFocusIndex).txtLen THEN
                                        tbSimpleDeleteInput = -1
                                        tbDeleteCharPos = uiEdit(uiFocusIndex).curPos + 1
                                    END IF
                                END IF
                            ELSEIF LEN(keyIn) = 2 THEN
                                IF ASC(RIGHT$(keyIn, 1)) = 83 THEN
                                    IF uiEdit(uiFocusIndex).curPos < uiEdit(uiFocusIndex).txtLen THEN
                                        tbSimpleDeleteInput = -1
                                        tbDeleteCharPos = uiEdit(uiFocusIndex).curPos + 1
                                    END IF
                                END IF
                            END IF
                            IF tbDeleteCharPos > 0 THEN tbDeleteCharCode = TextboxCharCodeAt(uiEdit(uiFocusIndex).txt, tbDeleteCharPos)
                        END IF

                        IF tbPlainTypeInput <> 0 AND tbHadSelection = 0 AND uiEdit(uiFocusIndex).insertMode = 0 THEN
                            tbNeedOldText = 0
                        ELSEIF tbSimpleDeleteInput <> 0 AND tbHadSelection = 0 THEN
                            tbNeedOldText = 0
                        ELSEIF LEN(keyIn) = 1 THEN
                            SELECT CASE ASC(keyIn)
                            CASE 1, 3, 6, 19, 23
                                ' Select/copy/find/save/wrap keys do not change textbox text.
                                tbNeedOldText = 0
                            CASE ELSE
                                tbNeedOldText = -1
                            END SELECT
                        ELSEIF LEN(keyIn) >= 2 THEN
                            tbExtCode = ASC(RIGHT$(keyIn, 1))
                            SELECT CASE tbExtCode
                            CASE ASC("K"), ASC("M"), ASC("G"), ASC("O"), ASC("H"), ASC("P"), ASC("I"), ASC("Q"), ASC("R"), 115, 116, 117, 119
                                ' Caret movement and Insert-mode toggle must not copy the whole text buffer.
                                tbNeedOldText = 0
                            CASE ELSE
                                tbNeedOldText = -1
                            END SELECT
                        END IF
                        IF tbNeedOldText <> 0 THEN
                            oldTbText = uiEdit(uiFocusIndex).txt
                        END IF
                        tbOldCaretPos = uiEdit(uiFocusIndex).curPos
                        tbOldCaretLine = 0
                        tbOldLineCount = 0
                        tbOldLineStart = 0
                        tbOldLineEnd = 0
                        tbOldScrollTop = 0

                        IF tbMulti <> 0 AND tbHadSelection = 0 THEN
                            IF (tbPlainTypeInput <> 0 AND uiEdit(uiFocusIndex).insertMode = 0) OR tbSimpleDeleteInput <> 0 THEN
                                IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
                                    IF layoutWindows(activeLayoutWindow).used <> 0 THEN tbOldScrollTop = comboScrollTop(activeLayoutWindow, uiFocusIndex)
                                END IF
                                tbOldCaretLine = TextboxMetricCaretLine(uiFocusIndex, uiEdit(uiFocusIndex).txt, tbOldCaretPos, tbCols)
                                tbOldLineCount = TextboxMetricLineCount(uiFocusIndex, uiEdit(uiFocusIndex).txt, tbCols)
                                tbOldLineStart = TextboxMetricLineStart(uiFocusIndex, uiEdit(uiFocusIndex).txt, tbOldCaretLine, tbCols)
                                IF TextboxWordWrap(uiFocusIndex) <> 0 THEN
                                    tbOldLineEnd = TbWrappedLineEndPos(uiEdit(uiFocusIndex).txt, tbOldLineStart, tbCols)
                                    IF tbPlainTypeInput <> 0 AND uiEdit(uiFocusIndex).insertMode = 0 THEN
                                        IF tbOldLineEnd - tbOldLineStart < tbCols THEN tbMetricInsertSafe = -1
                                    ELSEIF tbSimpleDeleteInput <> 0 THEN
                                        IF tbDeleteCharCode <> 13 AND tbDeleteCharCode <> 10 THEN
                                            IF tbOldLineEnd - tbOldLineStart < tbCols THEN tbMetricDeleteSafe = -1
                                        END IF
                                    END IF
                                ELSE
                                    tbOldLineEnd = TbLineEndPos(uiEdit(uiFocusIndex).txt, tbOldLineStart)
                                    IF tbPlainTypeInput <> 0 AND uiEdit(uiFocusIndex).insertMode = 0 THEN tbMetricInsertSafe = -1
                                    IF tbSimpleDeleteInput <> 0 AND tbDeleteCharCode <> 13 AND tbDeleteCharCode <> 10 THEN tbMetricDeleteSafe = -1
                                END IF
                                IF tbMetricCacheValid = 0 OR tbMetricCacheElem <> uiFocusIndex OR tbMetricCacheWin <> activeLayoutWindow THEN
                                    tbMetricInsertSafe = 0
                                    tbMetricDeleteSafe = 0
                                END IF
                            END IF
                        END IF

                        clipHandled = 0
                        findDialogOpenedFromTextbox = 0
                        IF LEN(keyIn) = 1 THEN
                            IF ASC(keyIn) = 6 THEN
                                IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
                                    IF layoutWindows(activeLayoutWindow).used <> 0 THEN
                                        IF uiFocusIndex >= 1 AND uiFocusIndex <= uiCount THEN
                                            IF uiElems(uiFocusIndex).kindId = UI_KIND_TEXTBOX THEN
                                                findTargetWin = activeLayoutWindow
                                                findTargetIdx = uiFocusIndex
                                                SaveActiveTextboxDrawStateToWindow activeLayoutWindow, uiFocusIndex
                                                MarkLayoutDirtyElement activeLayoutWindow, uiFocusIndex
                                            END IF
                                        END IF
                                    END IF
                                END IF
                                findDlgPath = AppDialogPath(activeLayoutWindow, "FIND_DIALOG", "")
                                IF findDlgPath <> "" THEN
                                    OpenLayoutAppWindow findDlgPath
                                    ' Opening Find from inside a textbox must force the whole dialog to draw.
                                    findDialogOpenedFromTextbox = -1
                                    needRedraw = -1
                                    keyIn = ""
                                END IF
                                clipHandled = -1
                            ELSEIF (MULTIKEY(29) OR MULTIKEY(157)) AND (UCASE$(keyIn) = "F") THEN
                                IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
                                    IF layoutWindows(activeLayoutWindow).used <> 0 THEN
                                        IF uiFocusIndex >= 1 AND uiFocusIndex <= uiCount THEN
                                            IF uiElems(uiFocusIndex).kindId = UI_KIND_TEXTBOX THEN
                                                findTargetWin = activeLayoutWindow
                                                findTargetIdx = uiFocusIndex
                                                SaveActiveTextboxDrawStateToWindow activeLayoutWindow, uiFocusIndex
                                                MarkLayoutDirtyElement activeLayoutWindow, uiFocusIndex
                                            END IF
                                        END IF
                                    END IF
                                END IF
                                findDlgPath = AppDialogPath(activeLayoutWindow, "FIND_DIALOG", "")
                                IF findDlgPath <> "" THEN
                                    OpenLayoutAppWindow findDlgPath
                                    ' Opening Find from inside a textbox must force the whole dialog to draw.
                                    findDialogOpenedFromTextbox = -1
                                    needRedraw = -1
                                    keyIn = ""
                                END IF
                                clipHandled = -1
                            END IF
                        END IF
                        IF findDialogOpenedFromTextbox = 0 THEN
                        IF clipHandled = 0 THEN
                            IF LEN(keyIn) = 1 THEN
                                IF ASC(keyIn) = 23 OR ((MULTIKEY(29) OR MULTIKEY(157)) AND UCASE$(keyIn) = "W") THEN
                                    IF TextboxWordWrap(uiFocusIndex) <> 0 THEN
                                        uiElems(uiFocusIndex).wordWrap = 0
                                    ELSE
                                        uiElems(uiFocusIndex).wordWrap = -1
                                    END IF
                                    InvalidateTextboxMetrics uiFocusIndex
                                    SyncTextboxScrollToCaret uiFocusIndex
                                    clipHandled = -1
                                END IF
                            END IF
                        END IF
                        IF clipHandled = 0 THEN
                            IF HandleTextboxNavigationKey(uiFocusIndex, keyIn, uiEdit(uiFocusIndex), uiPrefCol(uiFocusIndex), (MULTIKEY(42) OR MULTIKEY(54)), (MULTIKEY(29) OR MULTIKEY(157))) <> 0 THEN
                                clipHandled = -1
                            END IF
                        END IF
                        IF clipHandled = 0 THEN
                            Ed_ClipKey uiEdit(uiFocusIndex), keyIn, maxChars, uiPrefCol(uiFocusIndex), clipHandled
                        END IF
                        IF clipHandled = 0 THEN
                            Ed_KeyInputGlue uiEdit(uiFocusIndex), keyIn, tbMulti, maxChars, uiPrefCol(uiFocusIndex), (MULTIKEY(42) OR MULTIKEY(54)), (MULTIKEY(29) OR MULTIKEY(157))
                        END IF
                        tbTextChanged = 0
                        IF tbPlainTypeInput <> 0 AND tbHadSelection = 0 AND uiEdit(uiFocusIndex).insertMode = 0 THEN
                            IF uiEdit(uiFocusIndex).txtLen = tbOldTextLen + 1 THEN tbTextChanged = -1
                        ELSEIF tbSimpleDeleteInput <> 0 AND tbHadSelection = 0 THEN
                            IF uiEdit(uiFocusIndex).txtLen = tbOldTextLen - 1 THEN tbTextChanged = -1
                        ELSEIF tbNeedOldText <> 0 THEN
                            IF uiEdit(uiFocusIndex).txt <> oldTbText THEN tbTextChanged = -1
                        END IF

                        IF tbTextChanged <> 0 THEN
                            ' Only copy the full text string and rebuild text metrics when text really changed.
                            ' Arrow/Home/End/Page keys only move the caret and must stay out of that heavy path.
                            Ed_SyncGlue uiEdit(uiFocusIndex), uiElems(uiFocusIndex).text, uiCaretPos
                            IF tbMetricInsertSafe <> 0 AND uiEdit(uiFocusIndex).txtLen = tbOldTextLen + 1 AND _
                               tbMetricCacheValid <> 0 AND tbMetricCacheElem = uiFocusIndex AND tbMetricCacheWin = activeLayoutWindow THEN
                                tbMetricCacheLen = uiEdit(uiFocusIndex).txtLen
                                IF tbMetricCacheCharValid <> 0 THEN tbMetricCacheCharCount = tbMetricCacheCharCount + 1
                                FOR tbMetricShiftLine = tbOldCaretLine + 1 TO tbMetricCacheLineCount - 1
                                    tbMetricLineStarts(tbMetricShiftLine) = tbMetricLineStarts(tbMetricShiftLine) + 1
                                NEXT
                                tbMetricInsertApplied = -1
                            ELSEIF tbMetricDeleteSafe <> 0 AND uiEdit(uiFocusIndex).txtLen = tbOldTextLen - 1 AND _
                               tbMetricCacheValid <> 0 AND tbMetricCacheElem = uiFocusIndex AND tbMetricCacheWin = activeLayoutWindow THEN
                                tbMetricCacheLen = uiEdit(uiFocusIndex).txtLen
                                IF tbMetricCacheCharValid <> 0 THEN
                                    tbMetricCacheCharCount = tbMetricCacheCharCount - 1
                                    IF tbMetricCacheCharCount < 0 THEN tbMetricCacheCharCount = 0
                                END IF
                                FOR tbMetricShiftLine = tbOldCaretLine + 1 TO tbMetricCacheLineCount - 1
                                    tbMetricLineStarts(tbMetricShiftLine) = tbMetricLineStarts(tbMetricShiftLine) - 1
                                NEXT
                            ELSE
                                InvalidateTextboxMetrics uiFocusIndex
                            END IF
                        ELSE
                            Ed_Normalize uiEdit(uiFocusIndex)
                            uiCaretPos = uiEdit(uiFocusIndex).curPos
                        END IF
                        SyncTextboxScrollToCaret uiFocusIndex
                        IF tbTextChanged = 0 AND uiCaretPos <> tbOldCaretPos THEN
                            MarkTextStatsLabelsDirtyForSource activeLayoutWindow, uiFocusIndex
                        END IF

                        tbFastLineRedraw = 0
                        IF tbTextChanged <> 0 AND tbPlainTypeInput <> 0 AND tbMulti <> 0 AND tbHadSelection = 0 AND uiEdit(uiFocusIndex).insertMode = 0 THEN
                            IF uiEdit(uiFocusIndex).txtLen = tbOldTextLen + 1 THEN
                                tbNewScrollTop = 0
                                IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
                                    IF layoutWindows(activeLayoutWindow).used <> 0 THEN tbNewScrollTop = comboScrollTop(activeLayoutWindow, uiFocusIndex)
                                END IF
                                IF tbMetricInsertApplied <> 0 THEN
                                    tbNewCaretLine = tbOldCaretLine
                                    tbNewLineCount = tbOldLineCount
                                    tbNewLineStart = tbOldLineStart
                                    tbNewLineEnd = tbOldLineEnd + 1
                                ELSE
                                    tbNewCaretLine = TextboxMetricCaretLine(uiFocusIndex, uiElems(uiFocusIndex).text, uiCaretPos, tbCols)
                                    tbNewLineCount = TextboxMetricLineCount(uiFocusIndex, uiElems(uiFocusIndex).text, tbCols)
                                    tbNewLineStart = TextboxMetricLineStart(uiFocusIndex, uiElems(uiFocusIndex).text, tbNewCaretLine, tbCols)
                                    IF TextboxWordWrap(uiFocusIndex) <> 0 THEN
                                        tbNewLineEnd = TbWrappedLineEndPos(uiElems(uiFocusIndex).text, tbNewLineStart, tbCols)
                                    ELSE
                                        tbNewLineEnd = TbLineEndPos(uiElems(uiFocusIndex).text, tbNewLineStart)
                                    END IF
                                END IF

                                IF tbNewScrollTop = tbOldScrollTop AND _
                                   tbNewCaretLine = tbOldCaretLine AND _
                                   tbNewLineCount = tbOldLineCount AND _
                                   tbNewLineStart = tbOldLineStart AND _
                                   tbNewLineEnd = tbOldLineEnd + 1 THEN
                                    tbFastLineRedraw = -1
                                END IF
                            END IF
                        END IF

                        IF tbTextChanged <> 0 THEN
                            IF activeLayoutWindow >= 1 AND activeLayoutWindow <= 12 THEN
                                InvalidateLivePreviewCachesForControl activeLayoutWindow, uiFocusIndex
                                IF TRIM$(uiElems(uiFocusIndex).bindFile) <> "" AND TRIM$(uiElems(uiFocusIndex).bindKey) <> "" THEN MarkWindowPresetDirty activeLayoutWindow
                                AppRuntime_HandleEvent activeLayoutWindow, "CHANGE", uiElems(uiFocusIndex).name, "", uiElems(uiFocusIndex).action
                                ClearActiveTextSaveStatusForEdit uiFocusIndex
                            END IF
                        END IF

                        SaveActiveTextboxDrawStateToWindow activeLayoutWindow, uiFocusIndex
                        uiCaretVisible = -1
                        uiLastCaretBlink = nowTime
                        IF tbFastLineRedraw <> 0 THEN
                            layoutFastTextboxPending = -1
                            layoutFastTextboxWin = activeLayoutWindow
                            layoutFastTextboxElem = uiFocusIndex
                            layoutFastTextboxLine = tbNewCaretLine
                        ELSE
                            MarkLayoutDirtyElement activeLayoutWindow, uiFocusIndex
                        END IF
                        dirtyElementsOnlyRedraw = -1
                        END IF
                        END IF
                    ELSEIF uiElems(uiFocusIndex).kindId = UI_KIND_LISTBOX THEN
                        listKeyHandled = 0
                        listFocusName = UCASE$(TRIM$(uiElems(uiFocusIndex).name))
                        listFocusKind = UCASE$(TRIM$(uiElems(uiFocusIndex).sourceKind))
                        listDirControlName = AppControlNameValue(activeLayoutWindow, "FILE_BROWSER_DIR_CONTROL", "")
                        listFileControlName = AppControlNameValue(activeLayoutWindow, "FILE_BROWSER_FILE_CONTROL", "")
                        listPathControlName = AppControlNameValue(activeLayoutWindow, "FILE_BROWSER_PATH_CONTROL", "")
                        listStatusControlName = AppControlNameValue(activeLayoutWindow, "FILE_BROWSER_STATUS_CONTROL", "")
                        listStatusSuffix = ""
                        IF listStatusControlName <> "" THEN listStatusSuffix = " " + listStatusControlName

                        IF LEN(keyIn) = 1 THEN
                            IF ASC(keyIn) = 9 THEN
                                navDirIdx = GetControlIndexByName(listDirControlName)
                                navFileIdx = GetControlIndexByName(listFileControlName)
                                IF navDirIdx >= 1 AND navDirIdx <= uiCount AND navFileIdx >= 1 AND navFileIdx <= uiCount THEN
                                    IF uiFocusIndex = navDirIdx THEN
                                        uiFocusIndex = navFileIdx
                                    ELSEIF uiFocusIndex = navFileIdx THEN
                                        uiFocusIndex = navDirIdx
                                    END IF
                                    SyncLayoutWindowFocusOnly activeLayoutWindow
                                    activeWindowOnlyRedraw = -1
                                    listKeyHandled = -1
                                END IF
                            END IF
                        END IF

                        IF listKeyHandled = 0 THEN
                            IF LEN(keyIn) = 2 THEN
                                listMoveCode = ASC(RIGHT$(keyIn, 1))
                                IF listMoveCode = 72 OR listMoveCode = 80 THEN
                                    listItemCount = ComboFastItemCount(uiFocusIndex, listCacheSlot)
                                    IF listItemCount > 0 THEN
                                        listCurIdx = 0
                                        listCurrentTextKey = UCASE$(RTRIM$(uiElems(uiFocusIndex).text))
                                        FOR i = 1 TO listItemCount
                                            listFastValue = ComboFastItemValue(listCacheSlot, i)
                                            IF UCASE$(listFastValue) = listCurrentTextKey THEN
                                                listCurIdx = i
                                                EXIT FOR
                                            END IF
                                        NEXT
                                        IF listCurIdx = 0 THEN
                                            FOR i = 1 TO listItemCount
                                                listFastText = ComboFastItemText(listCacheSlot, i)
                                                IF UCASE$(listFastText) = listCurrentTextKey THEN
                                                    listCurIdx = i
                                                    EXIT FOR
                                                END IF
                                            NEXT
                                        END IF

                                        IF listCurIdx < 1 THEN
                                            listNewIdx = 1
                                        ELSE
                                            listNewIdx = listCurIdx
                                            IF listMoveCode = 72 THEN listNewIdx = listCurIdx - 1
                                            IF listMoveCode = 80 THEN listNewIdx = listCurIdx + 1
                                            IF listNewIdx < 1 THEN listNewIdx = 1
                                            IF listNewIdx > listItemCount THEN listNewIdx = listItemCount
                                        END IF

                                        listFastValue = ComboFastItemValue(listCacheSlot, listNewIdx)
                                        listFastText = ComboFastItemText(listCacheSlot, listNewIdx)
                                        IF LEFT$(listFastValue, 2) = "P:" THEN
                                            uiElems(uiFocusIndex).text = listFastValue
                                        ELSE
                                            uiElems(uiFocusIndex).text = listFastText
                                        END IF
                                        layoutListAnchorIdx(activeLayoutWindow, uiFocusIndex) = listNewIdx
                                        IF uiElems(uiFocusIndex).multiSelect <> 0 THEN
                                            listValueKey = listFastValue
                                            ListSelectionClear activeLayoutWindow, uiFocusIndex
                                            IF listValueKey <> "" THEN ListSelectionAdd activeLayoutWindow, uiFocusIndex, listValueKey
                                        END IF

                                        comboItemHLoop = 16
                                        listRowsKey = (uiElems(uiFocusIndex).h - 4) \ comboItemHLoop
                                        IF listRowsKey < 1 THEN listRowsKey = 1
                                        listTopKey = comboScrollTop(activeLayoutWindow, uiFocusIndex)
                                        IF listNewIdx <= listTopKey THEN listTopKey = listNewIdx - 1
                                        IF listNewIdx > listTopKey + listRowsKey THEN listTopKey = listNewIdx - listRowsKey
                                        comboScrollTop(activeLayoutWindow, uiFocusIndex) = ClampScrollPos(listTopKey, listItemCount - listRowsKey)

                                        ' Arrow-key list movement changes one selected control, not the whole window.
                                        ' Save that one listbox and keep the 192-control deep sync out of file scrolling.
                                        IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
                                            IF layoutWindows(activeLayoutWindow).used <> 0 THEN
                                                layoutWindows(activeLayoutWindow).focusIndex = uiFocusIndex
                                                layoutUiElems(activeLayoutWindow, uiFocusIndex) = uiElems(uiFocusIndex)
                                                MarkLayoutWindowVisualDirty activeLayoutWindow
                                            END IF
                                        END IF
                                        IF listFocusKind = "FILES" THEN
                                            AppRuntime_HandleEvent activeLayoutWindow, "CHANGE", uiElems(uiFocusIndex).name, uiElems(uiFocusIndex).text, uiElems(uiFocusIndex).action
                                        END IF
                                        MarkLayoutDirtyElement activeLayoutWindow, uiFocusIndex
                                        dirtyElementsOnlyRedraw = -1
                                    END IF
                                    listKeyHandled = -1
                                END IF
                            END IF
                        END IF

                        IF listKeyHandled = 0 THEN
                            IF LEN(keyIn) = 1 THEN
                                IF ASC(keyIn) = 13 THEN
                                    IF listFocusKind = "FILES" THEN
                                        HostAppAction activeLayoutWindow, "FILE_BROWSER_FILE_OPEN " + uiElems(uiFocusIndex).name + listStatusSuffix
                                        needRedraw = -1
                                        listKeyHandled = -1
                                    ELSEIF listFocusKind = "DIRS" THEN
                                        IF listFileControlName <> "" AND listPathControlName <> "" THEN
                                            HostAppAction activeLayoutWindow, "FILE_BROWSER_DIR_SELECT " + uiElems(uiFocusIndex).name + " " + listFileControlName + " " + listPathControlName
                                            navFileIdx = GetControlIndexByName(listFileControlName)
                                            IF navFileIdx >= 1 AND navFileIdx <= uiCount THEN
                                                uiFocusIndex = navFileIdx
                                                comboScrollTop(activeLayoutWindow, navFileIdx) = 0
                                                ListSelectionClear activeLayoutWindow, navFileIdx
                                                layoutListAnchorIdx(activeLayoutWindow, navFileIdx) = 0
                                                BuildComboItems navFileIdx
                                                IF tempComboItemCount > 0 THEN
                                                    uiElems(navFileIdx).text = RTRIM$(tempComboItems(1))
                                                    layoutListAnchorIdx(activeLayoutWindow, navFileIdx) = 1
                                                    IF uiElems(navFileIdx).multiSelect <> 0 THEN
                                                        listValueKey = RTRIM$(tempComboValues(1))
                                                        IF listValueKey <> "" THEN ListSelectionAdd activeLayoutWindow, navFileIdx, listValueKey
                                                    END IF
                                                ELSE
                                                    uiElems(navFileIdx).text = ""
                                                END IF
                                                layoutWindows(activeLayoutWindow).focusIndex = uiFocusIndex
                                                SyncLayoutWindowFromGlobals activeLayoutWindow
                                            END IF
                                        END IF
                                        activeWindowOnlyRedraw = -1
                                        listKeyHandled = -1
                                    END IF
                                END IF
                            END IF
                        END IF

                        IF listKeyHandled = 0 THEN
                            deleteKeyHit = 0
                            IF LEN(keyIn) = 1 THEN
                                IF ASC(keyIn) = 127 THEN deleteKeyHit = -1
                            ELSEIF LEN(keyIn) = 2 THEN
                                IF ASC(RIGHT$(keyIn, 1)) = 83 THEN deleteKeyHit = -1
                            END IF

                            IF deleteKeyHit <> 0 THEN
                                deleteKeyValue = ControlValueFromListControl(uiFocusIndex)
                                IF listFocusKind = "DIRS" THEN
                                    ' Directory Delete uses the same confirmation dialog as right-click Delete.
                                    IF LEFT$(UCASE$(RTRIM$(deleteKeyValue)), 2) = "D:" THEN
                                        HostAppAction activeLayoutWindow, "FILE_BROWSER_FILE_DELETE " + uiElems(uiFocusIndex).name + listStatusSuffix
                                        needRedraw = -1
                                    END IF
                                ELSEIF ListSelectionFilePaths(activeLayoutWindow, uiFocusIndex, deleteKeyValue) <> "" THEN
                                    deleteKeyAction = ""
                                    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
                                        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
                                            deleteKeyAction = TRIM$(AppCfgValue(RTRIM$(layoutWindows(activeLayoutWindow).appPath), "CONTEXT_DELETE_ACTION", ""))
                                        END IF
                                    END IF

                                    IF deleteKeyAction = "" THEN deleteKeyAction = "FILE_BROWSER_FILE_DELETE " + uiElems(uiFocusIndex).name + listStatusSuffix
                                    HostAppAction activeLayoutWindow, deleteKeyAction
                                    needRedraw = -1
                                END IF
                            ELSEIF LEN(keyIn) = 1 THEN
                                deleteKeyValue = ControlValueFromListControl(uiFocusIndex)
                                IF ASC(keyIn) = 3 OR ((MULTIKEY(29) OR MULTIKEY(157)) AND UCASE$(keyIn) = "C") THEN
                                    IF listFocusKind = "DIRS" THEN
                                        HostAppAction activeLayoutWindow, "FILE_BROWSER_DIR_COPY " + uiElems(uiFocusIndex).name + listStatusSuffix
                                        needRedraw = -1
                                    ELSEIF ListSelectionFilePaths(activeLayoutWindow, uiFocusIndex, deleteKeyValue) <> "" THEN
                                        deleteKeyAction = ""
                                        IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
                                            IF layoutWindows(activeLayoutWindow).used <> 0 THEN
                                                deleteKeyAction = TRIM$(AppCfgValue(RTRIM$(layoutWindows(activeLayoutWindow).appPath), "CONTEXT_COPY_ACTION", ""))
                                            END IF
                                        END IF
                                        IF deleteKeyAction <> "" THEN
                                            HostAppAction activeLayoutWindow, deleteKeyAction + " " + uiElems(uiFocusIndex).name + listStatusSuffix
                                            needRedraw = -1
                                        END IF
                                    END IF
                                ELSEIF ASC(keyIn) = 24 OR ((MULTIKEY(29) OR MULTIKEY(157)) AND UCASE$(keyIn) = "X") THEN
                                    IF ListSelectionFilePaths(activeLayoutWindow, uiFocusIndex, deleteKeyValue) <> "" THEN
                                        deleteKeyAction = ""
                                        IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
                                            IF layoutWindows(activeLayoutWindow).used <> 0 THEN
                                                deleteKeyAction = TRIM$(AppCfgValue(RTRIM$(layoutWindows(activeLayoutWindow).appPath), "CONTEXT_CUT_ACTION", ""))
                                            END IF
                                        END IF
                                        IF deleteKeyAction <> "" THEN
                                            HostAppAction activeLayoutWindow, deleteKeyAction + " " + uiElems(uiFocusIndex).name + listStatusSuffix
                                            needRedraw = -1
                                        END IF
                                    END IF
                                ELSEIF ASC(keyIn) = 22 OR ((MULTIKEY(29) OR MULTIKEY(157)) AND UCASE$(keyIn) = "V") THEN
                                    IF (UCASE$(TRIM$(fileBrowserClipboardMode)) = "COPY" OR UCASE$(TRIM$(fileBrowserClipboardMode)) = "CUT") AND TRIM$(fileBrowserClipboardPath) <> "" THEN
                                        deleteKeyAction = ""
                                        IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
                                            IF layoutWindows(activeLayoutWindow).used <> 0 THEN
                                                deleteKeyAction = TRIM$(AppCfgValue(RTRIM$(layoutWindows(activeLayoutWindow).appPath), "CONTEXT_PASTE_ACTION", ""))
                                            END IF
                                        END IF
                                        IF deleteKeyAction <> "" THEN
                                            HostAppAction activeLayoutWindow, deleteKeyAction
                                            needRedraw = -1
                                        END IF
                                    END IF
                                ELSEIF uiElems(uiFocusIndex).multiSelect <> 0 THEN
                                    IF ASC(keyIn) = 1 OR ((MULTIKEY(29) OR MULTIKEY(157)) AND UCASE$(keyIn) = "A") THEN
                                        ListSelectionSelectAll activeLayoutWindow, uiFocusIndex
                                        SyncLayoutWindowElementOnly activeLayoutWindow, uiFocusIndex
                                        MarkLayoutDirtyElement activeLayoutWindow, uiFocusIndex
                                        dirtyElementsOnlyRedraw = -1
                                    END IF
                                END IF
                            END IF
                        END IF

                    END IF
                END IF
                END IF

                IF keyIn <> "" THEN
                    KeyQueuePushInkey activeLayoutWindow, keyIn
                END IF
            END IF

            DIM layoutSpaceDown AS INTEGER
            DIM layoutSpaceAction AS STRING
            DIM layoutSpaceActionText AS STRING
            DIM layoutSpaceActiveOnlyRedraw AS INTEGER
            DIM layoutSpaceStartWin AS INTEGER
            DIM layoutSpaceStartWindowCount AS INTEGER
            layoutSpaceDown = 0
            IF ActiveEditableTextboxFocused() = 0 THEN
                IF MULTIKEY(57) THEN layoutSpaceDown = -1
            END IF
            IF layoutSpaceDown <> 0 AND layoutSpaceWasDown = 0 THEN
                layoutSpaceAction = ""
                IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
                    IF layoutWindows(activeLayoutWindow).used <> 0 THEN
                        layoutSpaceAction = TRIM$(AppCfgValue(RTRIM$(layoutWindows(activeLayoutWindow).appPath), "KEY_ACTION", ""))
                    END IF
                END IF
                IF layoutSpaceAction <> "" THEN
                    IF MULTIKEY(29) OR MULTIKEY(157) THEN
                        layoutSpaceActionText = layoutSpaceAction + " CTRL_SPACE"
                    ELSE
                        layoutSpaceActionText = layoutSpaceAction + " SPACE"
                    END IF
                    layoutSpaceActiveOnlyRedraw = HostActionDirectActiveWindowRedrawOnly(layoutSpaceActionText)
                    layoutSpaceStartWin = activeLayoutWindow
                    layoutSpaceStartWindowCount = layoutWindowCount
                    HostAppAction activeLayoutWindow, layoutSpaceActionText
                    ' Space-key app shortcuts reuse the same redraw classifier as clicks.
                    IF layoutSpaceActiveOnlyRedraw <> 0 AND activeLayoutWindow = layoutSpaceStartWin AND layoutWindowCount = layoutSpaceStartWindowCount AND _
                       startMenuOpen = 0 AND ctxMenuOpen = 0 AND launchCtxOpen = 0 AND desktopCtxOpen = 0 THEN
                        activeWindowOnlyRedraw = -1
                    ELSE
                        needRedraw = -1
                    END IF
                    oldMx = -1
                    oldMy = -1
                END IF
            END IF
            layoutSpaceWasDown = layoutSpaceDown

            IF appViewDragElem > 0 AND appViewDragButton = 2 THEN
                IF startMenuOpen <> 0 OR launchCtxOpen <> 0 OR ctxMenuOpen <> 0 OR desktopCtxOpen <> 0 THEN
                    appViewDragElem = 0
                    appViewDragButton = 0
                    appViewLastX = -1000
                    appViewLastY = -1000
                ELSEIF rightBtn <> 0 THEN
                    IF smx <> appViewLastX OR smy <> appViewLastY THEN
                        DispatchAppViewMouseEvent appViewDragElem, "RIGHT_DRAG", smx, smy, 2
                        IF appViewTool(activeLayoutWindow) < 2 OR appViewTool(activeLayoutWindow) > 4 THEN
                            MarkLayoutDirtyElement activeLayoutWindow, appViewDragElem
                            dirtyElementsOnlyRedraw = -1
                        END IF
                        appViewLastX = smx
                        appViewLastY = smy
                    END IF
                ELSEIF prevRightBtn <> 0 THEN
                    DispatchAppViewMouseEvent appViewDragElem, "RIGHT_UP", smx, smy, 0
                    MarkLayoutDirtyElement activeLayoutWindow, appViewDragElem
                    dirtyElementsOnlyRedraw = -1
                    appViewDragElem = 0
                    appViewDragButton = 0
                    appViewLastX = -1000
                    appViewLastY = -1000
                    uiPressedIndex = 0
                END IF
            END IF

            IF screenSaverConfigEnabled <> 0 AND screenSaverConfigTimeoutSeconds > 0 THEN
                IF screenSaverLastIdleCheck = 0 OR TimerElapsedSecondsAt(screenSaverLastIdleCheck, nowTime) >= .5 THEN
                    IF CheckScreensaverIdleAt(nowTime) <> 0 THEN
                        needRedraw = -1
                        oldMx = -1
                        oldMy = -1
                        ssMouseReady = 0
                    END IF
                END IF
            END IF

            layoutLoopBusy = 0
            IF needRedraw <> 0 THEN layoutLoopBusy = -1
            IF dirtyElementsOnlyRedraw <> 0 THEN layoutLoopBusy = -1
            IF activeWindowOnlyRedraw <> 0 THEN layoutLoopBusy = -1
            IF layoutOnlyRedraw <> 0 THEN layoutLoopBusy = -1
            IF cursorOnlyRedraw <> 0 THEN layoutLoopBusy = -1
            IF menuOnlyRedraw <> 0 THEN layoutLoopBusy = -1
            IF menuRowRedraw <> 0 THEN layoutLoopBusy = -1
            IF taskbarOnlyRedraw <> 0 THEN layoutLoopBusy = -1
            IF taskbarOnlyRedrawPending <> 0 THEN layoutLoopBusy = -1
            IF startMenuFastOpenPending <> 0 THEN layoutLoopBusy = -1
            IF startMenuFastClosePending <> 0 THEN layoutLoopBusy = -1
            IF contextOverlayFastClosePending <> 0 THEN layoutLoopBusy = -1
            IF smx <> oldMx OR smy <> oldMy THEN layoutLoopBusy = -1
            IF keyIn <> "" THEN layoutLoopBusy = -1
            IF curBtn <> 0 OR rightBtn <> 0 THEN layoutLoopBusy = -1
            IF wheelDelta <> 0 THEN layoutLoopBusy = -1
            IF draggingLayoutWin <> 0 OR resizingLayoutWin <> 0 THEN layoutLoopBusy = -1
            IF draggingVScroll <> 0 OR draggingHScroll <> 0 THEN layoutLoopBusy = -1
            IF draggingComboScroll <> 0 OR draggingListScroll <> 0 OR draggingTextScroll <> 0 THEN layoutLoopBusy = -1
            IF draggingSplitter <> 0 OR appViewDragElem <> 0 THEN layoutLoopBusy = -1
            IF layoutSpaceDown <> 0 THEN layoutLoopBusy = -1
            IF activeLayoutWindow >= 1 AND activeLayoutWindow <= 12 THEN IF canvasTickEnabled(activeLayoutWindow) <> 0 THEN layoutLoopBusy = -1

            prevBtn = curBtn
            prevRightBtn = rightBtn
            GuiAdaptiveSleep layoutLoopBusy
        LOOP

        layoutLoopRunning = 0
        IF bdbgEnabled <> 0 THEN BDbgWindowEvent "LAYOUT_LOOP_EXIT path=" + appPath, activeLayoutWindow

        IF running = 0 THEN EXIT SUB
        IF layoutWindowCount = 0 THEN
            activeLayoutWindow = 0
            uiWindowActive = 0
            uiPressedIndex = 0
            uiFocusIndex = 0
            uiCaretPos = 0
            uiScrollY = 0
            uiScrollX = 0
            uiSelectedTab = 0
            uiCount = 0
            uiTitle = ""
            uiWinX = 0
            uiWinY = 0
            uiWinW = 0
            uiWinH = 0
            uiResizable = 0

            ' Returning to the desktop loop resumes an older outer-loop timestamp.
            ' Reset here so that stale timestamp cannot trip the saver immediately.
            ResetScreensaverIdle
            EXIT SUB
        END IF

        ResumeGuiAfterShell
        ResetScreensaverIdle
        EXIT SUB
    END IF

    SELECT CASE modeVal
        CASE "SHELL", "DOS", "RUN"
            cmdVal = TRIM$(AppCfgValue(appPath, "command", ""))
            runModeVal = TRIM$(AppCfgValue(appPath, "runmode", ""))
            IF cmdVal = "" THEN cmdVal = "COMMAND.COM"
            IF DosRunModeValue(runModeVal) = "" THEN runModeVal = DosDefaultRunModeForCommand(cmdVal)
            LaunchDosProgram cmdVal, runModeVal

        CASE ELSE
            ShowGuiMessageBox "APP MODE NOT SUPPORTED:", appPath
    END SELECT
END SUB

' ---------------------------
' Run control helpers and top-level shell action dispatch
' ---------------------------

SUB LaunchFromControl(BYVAL commandControlName AS STRING, BYVAL externalControlName AS STRING, BYVAL statusControlName AS STRING)
    DIM cmdLine AS STRING
    DIM cmdUpper AS STRING
    DIM programText AS STRING
    DIM programUpper AS STRING
    DIM externalFlag AS INTEGER

    commandControlName = TRIM$(commandControlName)
    externalControlName = TRIM$(externalControlName)
    statusControlName = TRIM$(statusControlName)

    IF commandControlName = "" THEN EXIT SUB

    cmdLine = TRIM$(GetControlTextValue(commandControlName))
    IF cmdLine = "" THEN
        IF statusControlName <> "" THEN SetTextboxTextByName statusControlName, "No command entered"
        ShowGuiMessageBox "EMPTY LAUNCH COMMAND:", "Enter a program or Backlash app path."
        EXIT SUB
    END IF

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN SyncLayoutWindowFromGlobals activeLayoutWindow
    END IF

    externalFlag = GetControlStateByName(externalControlName)
    IF externalFlag <> 0 THEN
        IF statusControlName <> "" THEN SetTextboxTextByName statusControlName, "Launching external DOS program"
        LaunchDosProgram cmdLine, "UNLOAD"
        EXIT SUB
    END IF

    cmdUpper = UpperCachedText(cmdLine)
    programText = DosCommandProgram(cmdLine)
    programUpper = UpperCachedText(programText)

    IF LEFT$(cmdUpper, 4) = "DOS:" OR LEFT$(cmdUpper, 4) = "RUN:" THEN
        IF statusControlName <> "" THEN SetTextboxTextByName statusControlName, "Launching"
        ExecuteLaunchTarget cmdLine
        EXIT SUB
    END IF

    IF RIGHT$(programUpper, 4) = ".APP" THEN
        IF statusControlName <> "" THEN SetTextboxTextByName statusControlName, "Opening Backlash app"
        ExecuteLaunchTarget programText
        EXIT SUB
    END IF

    SELECT CASE cmdUpper
    CASE "SHELL", "DOS", "COMMAND", "COMMAND.COM", "EXIT", "QUIT", "SHUTDOWN", "SHUT DOWN"
        IF statusControlName <> "" THEN SetTextboxTextByName statusControlName, "Launching"
        ExecuteLaunchTarget cmdLine
    CASE ELSE
        IF statusControlName <> "" THEN SetTextboxTextByName statusControlName, "Running without unloading Backlash"
        LaunchDosProgram cmdLine, "RESIDENT"
    END SELECT
END SUB


SUB RunShell()
    SetCursorBusy -1
    SoundStop
    SCREEN 0
    WIDTH 80, 25
    COLOR 7, 0
    CLS
    PRINT "Type EXIT to return to the GUI."
    SHELL
    ResumeGuiAfterShell
END SUB

SUB ExecuteLaunchTarget(BYVAL actIn AS STRING)
    DIM act AS STRING
    DIM actRaw AS STRING
    DIM dosCmd AS STRING
    DIM dosMode AS STRING
    DIM dosCmdUpper AS STRING
    DIM colonPos AS INTEGER
    DIM soundLaunchArgs AS STRING
    DIM soundLaunchCmd AS STRING
    DIM soundToneRest AS STRING
    DIM soundToneSep AS INTEGER
    DIM soundFileArg AS STRING

    IF NormalizeActionRawUpperCached(actIn, actRaw, act) = 0 THEN
        BDbgTrace "LAUNCH_EMPTY_TARGET"
        ShowGuiMessageBox "EMPTY LAUNCH TARGET:", "No launch target was supplied."
        EXIT SUB
    END IF

    BDbgTrace "LAUNCH_REQUEST raw=" + actRaw + " normalized=" + act

    IF RIGHT$(act, 4) = ".APP" THEN
        startMenuOpen = 0
        BDbgTrace "LAUNCH_ROUTE_APP path=" + actRaw
        ExecuteAppFile actRaw
        EXIT SUB
    END IF

    IF LEFT$(act, 4) = "DIR:" THEN
        startMenuOpen = 0
        BDbgTrace "LAUNCH_ROUTE_DIR target=" + MID$(actRaw, 5)
        OpenDesktopDirectoryLink MID$(actRaw, 5)
        EXIT SUB
    END IF

    IF LEFT$(act, 5) = "FILE:" THEN
        startMenuOpen = 0
        BDbgTrace "LAUNCH_ROUTE_FILE target=" + MID$(actRaw, 6)
        OpenDesktopFileLink MID$(actRaw, 6)
        EXIT SUB
    END IF

    IF LEFT$(act, 4) = "DOS:" THEN
        startMenuOpen = 0
        dosCmd = TRIM$(MID$(actRaw, 5))
        dosMode = ""

        IF dosCmd = "" THEN
            ShowGuiMessageBox "MALFORMED DOS COMMAND:", actRaw
            EXIT SUB
        END IF

        dosCmdUpper = UpperCachedText(dosCmd)
        IF LEFT$(dosCmdUpper, 7) = "UNLOAD:" THEN
            dosMode = "UNLOAD"
            dosCmd = TRIM$(MID$(dosCmd, 8))
        ELSEIF LEFT$(dosCmdUpper, 9) = "RESIDENT:" THEN
            dosMode = "RESIDENT"
            dosCmd = TRIM$(MID$(dosCmd, 10))
        ELSE
            ShowGuiMessageBox "MALFORMED DOS COMMAND:", actRaw
            EXIT SUB
        END IF

        IF dosCmd = "" THEN
            ShowGuiMessageBox "EMPTY LAUNCH TARGET:", actRaw
            EXIT SUB
        END IF

        BDbgTrace "LAUNCH_ROUTE_DOS cmd=" + dosCmd + " mode=" + dosMode
        LaunchDosProgram dosCmd, dosMode
        EXIT SUB
    END IF

    IF LEFT$(act, 4) = "RUN:" THEN
        startMenuOpen = 0
        dosCmd = TRIM$(MID$(actRaw, 5))
        dosMode = ""

        IF dosCmd = "" THEN
            ShowGuiMessageBox "MALFORMED DOS COMMAND:", actRaw
            EXIT SUB
        END IF

        dosCmdUpper = UpperCachedText(dosCmd)
        IF LEFT$(dosCmdUpper, 7) = "UNLOAD:" THEN
            dosMode = "UNLOAD"
            dosCmd = TRIM$(MID$(dosCmd, 8))
        ELSEIF LEFT$(dosCmdUpper, 9) = "RESIDENT:" THEN
            dosMode = "RESIDENT"
            dosCmd = TRIM$(MID$(dosCmd, 10))
        END IF

        IF dosCmd = "" THEN
            ShowGuiMessageBox "EMPTY LAUNCH TARGET:", actRaw
            EXIT SUB
        END IF

        IF dosMode = "" THEN dosMode = DosDefaultRunModeForCommand(dosCmd)
        BDbgTrace "LAUNCH_ROUTE_RUN cmd=" + dosCmd + " mode=" + dosMode
        LaunchDosProgram dosCmd, dosMode
        EXIT SUB
    END IF

    IF LEFT$(act, 6) = "SOUND:" THEN
        startMenuOpen = 0
        soundLaunchArgs = TRIM$(MID$(actRaw, 7))
        soundLaunchCmd = UpperCachedText(TRIM$(soundLaunchArgs))
        IF soundLaunchCmd = "" OR soundLaunchCmd = "BEEP" THEN
            SoundStartTone soundDefaultFreq, soundDefaultMs
            EXIT SUB
        ELSEIF soundLaunchCmd = "STOP" THEN
            SoundStop
            EXIT SUB
        ELSEIF soundLaunchCmd = "PAUSE" THEN
            IF SoundPcmPause() = 0 THEN ShowGuiMessageBox "Sound PCM", "PCM pause failed"
            SoundWriteStatus
            EXIT SUB
        ELSEIF soundLaunchCmd = "RESUME" THEN
            IF SoundPcmResume() = 0 THEN ShowGuiMessageBox "Sound PCM", "PCM resume failed"
            SoundWriteStatus
            EXIT SUB
        ELSEIF LEFT$(soundLaunchCmd, 4) = "PCM:" THEN
            soundFileArg = NormalizePath(TRIM$(MID$(soundLaunchArgs, 5)))
            IF SoundPcmStartRaw16Stereo44100(soundFileArg) = 0 THEN ShowGuiMessageBox "Sound PCM", "16-bit stereo PCM playback failed"
            SoundWriteStatus
            EXIT SUB
        ELSEIF soundLaunchCmd = "STATUS" THEN
            SoundWriteStatus
            ShowGuiMessageBoxInfo "Sound Status", "Wrote " + soundStatusFile
            EXIT SUB
        ELSEIF soundLaunchCmd = "SBTEST" THEN
            IF SoundBlasterDirectClick() = 0 THEN ShowGuiMessageBox "Sound Blaster Test", "DSP direct test failed"
            SoundWriteStatus
            EXIT SUB
        ELSEIF soundLaunchCmd = "SBDMA" THEN
            IF SoundBlasterDmaTest() = 0 THEN ShowGuiMessageBox "Sound Blaster DMA Test", "8-bit DMA test failed"
            SoundWriteStatus
            EXIT SUB
        ELSEIF LEFT$(soundLaunchCmd, 4) = "WAV:" OR LEFT$(soundLaunchCmd, 5) = "PLAY:" THEN
            IF LEFT$(soundLaunchCmd, 4) = "WAV:" THEN
                soundFileArg = NormalizePath(TRIM$(MID$(soundLaunchArgs, 5)))
            ELSE
                soundFileArg = NormalizePath(TRIM$(MID$(soundLaunchArgs, 6)))
            END IF
            IF SoundBlasterPlayWav8Mono(soundFileArg) = 0 THEN ShowGuiMessageBox "Sound WAV", "8-bit mono WAV playback failed"
            SoundWriteStatus
            EXIT SUB
        ELSEIF LEFT$(soundLaunchCmd, 5) = "TONE:" THEN
            soundToneRest = MID$(soundLaunchArgs, 6)
            soundToneSep = INSTR(soundToneRest, ":")
            IF soundToneSep > 0 THEN
                SoundStartTone VALINT(LEFT$(soundToneRest, soundToneSep - 1)), VALINT(MID$(soundToneRest, soundToneSep + 1))
            ELSE
                SoundStartTone VALINT(soundToneRest), soundDefaultMs
            END IF
            EXIT SUB
        ELSE
            ShowGuiMessageBox "MALFORMED SOUND COMMAND:", actRaw
            EXIT SUB
        END IF
    END IF

    IF act = "SOUND_BEEP" OR act = "BEEP" THEN
        startMenuOpen = 0
        SoundStartTone soundDefaultFreq, soundDefaultMs
        EXIT SUB
    END IF

    IF act = "SOUND_STOP" THEN
        startMenuOpen = 0
        SoundStop
        EXIT SUB
    END IF

    IF act = "SOUND_STATUS" THEN
        startMenuOpen = 0
        SoundWriteStatus
        ShowGuiMessageBoxInfo "Sound Status", "Wrote " + soundStatusFile
        EXIT SUB
    END IF

    IF act = "SOUND_SBTEST" OR act = "SBTEST" THEN
        startMenuOpen = 0
        IF SoundBlasterDirectClick() = 0 THEN ShowGuiMessageBox "Sound Blaster Test", "DSP direct test failed"
        SoundWriteStatus
        EXIT SUB
    END IF

    IF act = "SOUND_SBDMA" OR act = "SBDMA" THEN
        startMenuOpen = 0
        IF SoundBlasterDmaTest() = 0 THEN ShowGuiMessageBox "Sound Blaster DMA Test", "8-bit DMA test failed"
        SoundWriteStatus
        EXIT SUB
    END IF

    IF LEFT$(act, 15) = "SOUND_PCM_PLAY:" THEN
        startMenuOpen = 0
        soundFileArg = NormalizePath(TRIM$(MID$(actRaw, 16)))
        IF SoundPcmStartRaw16Stereo44100(soundFileArg) = 0 THEN ShowGuiMessageBox "Sound PCM", "16-bit stereo PCM playback failed"
        SoundWriteStatus
        EXIT SUB
    END IF

    IF act = "SOUND_PCM_STOP" THEN
        startMenuOpen = 0
        SoundStop
        SoundPcmWriteStatus "STOPPED"
        SoundWriteStatus
        EXIT SUB
    END IF

    IF act = "SOUND_PCM_PAUSE" THEN
        startMenuOpen = 0
        IF SoundPcmPause() = 0 THEN ShowGuiMessageBox "Sound PCM", "PCM pause failed"
        SoundWriteStatus
        EXIT SUB
    END IF

    IF act = "SOUND_PCM_RESUME" THEN
        startMenuOpen = 0
        IF SoundPcmResume() = 0 THEN ShowGuiMessageBox "Sound PCM", "PCM resume failed"
        SoundWriteStatus
        EXIT SUB
    END IF

    colonPos = INSTR(actRaw, ":")
    IF colonPos > 0 AND colonPos <> 2 THEN
        ShowGuiMessageBox "UNSUPPORTED LAUNCH TARGET:", actRaw
        EXIT SUB
    END IF

    SELECT CASE act
        CASE "SHELL", "DOS", "COMMAND", "COMMAND.COM"
            startMenuOpen = 0
            BDbgTrace "LAUNCH_ROUTE_SHELL"
            RunShell

        CASE "EXIT", "QUIT", "SHUTDOWN", "SHUT DOWN"
            BDbgTrace "LAUNCH_ROUTE_SHUTDOWN"
            BeginGuiShutdown

        CASE ELSE
            startMenuOpen = 0
            dosMode = DosDefaultRunModeForCommand(actRaw)
            BDbgTrace "LAUNCH_ROUTE_DOS_DEFAULT cmd=" + actRaw + " mode=" + dosMode
            LaunchDosProgram actRaw, dosMode
    END SELECT
END SUB

SUB ExecuteAction(BYVAL actIn AS STRING)
    ExecuteLaunchTarget actIn
END SUB

SUB ExecuteMenuAction(BYVAL idx AS INTEGER)
    DIM menuActionText AS STRING
    DIM menuActionUpper AS STRING

    BDbgTrace "MENU_ACTION_REQUEST idx=" + BDbgNum(idx)
    IF idx < 1 OR idx > menuCount THEN EXIT SUB
    IF menuItemIsDivider(idx) <> 0 THEN EXIT SUB
    IF menuItemHasSubmenu(idx) <> 0 THEN EXIT SUB

    menuActionText = menuItems(idx).action
    BDbgTrace "MENU_ACTION_EXEC idx=" + BDbgNum(idx) + " action=" + menuActionText
    menuActionUpper = UCASE$(TRIM$(menuActionText))
    IF menuActionUpper <> "EXIT" AND menuActionUpper <> "QUIT" AND menuActionUpper <> "SHUTDOWN" AND menuActionUpper <> "SHUT DOWN" THEN SoundUiEvent "MENU"
    ExecuteLaunchTarget menuActionText
END SUB

SUB ExecuteIconAction(BYVAL idx AS INTEGER)
    BDbgTrace "ICON_ACTION_REQUEST idx=" + BDbgNum(idx)
    IF idx < 1 OR idx > iconCount THEN EXIT SUB
    BDbgTrace "ICON_ACTION_EXEC idx=" + BDbgNum(idx) + " action=" + desktopIcons(idx).action
    ExecuteLaunchTarget desktopIcons(idx).action
END SUB

FUNCTION IsPrimaryButtonPressed(BYVAL buttons AS INTEGER) AS INTEGER
    IF cfg.leftHanded <> 0 THEN
        RETURN ((buttons AND 2) <> 0)
    ELSE
        RETURN ((buttons AND 1) <> 0)
    END IF
END FUNCTION

