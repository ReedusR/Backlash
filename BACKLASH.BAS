' Metadata reset and visual refresh helpers
' ---------------------------

SUB RestoreDefaultsFromMetadata()
    DIM i AS INTEGER

    FOR i = 1 TO uiCount
        SELECT CASE uiElems(i).kindKey
        CASE "COMBO"
            IF TRIM$(uiElems(i).defaultValue) <> "" THEN
                SetComboSelectionFromBoundValue i, uiElems(i).defaultValue
            END IF

        CASE "RADIO"
            IF TRIM$(uiElems(i).defaultValue) <> "" THEN
                IF UCASE$(TRIM$(uiElems(i).bindValue)) = UCASE$(TRIM$(uiElems(i).defaultValue)) THEN
                    uiElems(i).state = -1
                ELSEIF TRIM$(uiElems(i).groupName) <> "" THEN
                    uiElems(i).state = 0
                END IF
            END IF
        END SELECT
    NEXT

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
            comboOpenIndex(activeLayoutWindow) = 0
            SyncLayoutWindowFromGlobals activeLayoutWindow
        END IF
    END IF
END SUB

SUB RefreshDisplayFromCurrentConfig()
    BDbgTrace "REFRESH_DISPLAY_BEGIN"
    LoadAllConfig
    BDbgTrace "REFRESH_DISPLAY_AFTER_LOADCONFIG"
    ApplyResolution
    BuildLayout
    BDbgTrace "REFRESH_DISPLAY_FREE_MODE_BUFFERS_BEGIN"
    FreeDisplayModeBuffers
    BDbgTrace "REFRESH_DISPLAY_FREE_MODE_BUFFERS_DONE"
    BDbgTrace "REFRESH_DISPLAY_BEFORE_SCREENRES depth=" + BDbgNum(cfg.colorDepth) + " w=" + BDbgNum(SCR_W) + " h=" + BDbgNum(SCR_H)

    IF SCREENRES(SCR_W, SCR_H, cfg.colorDepth) <> 0 THEN
        BDbgTrace "REFRESH_DISPLAY_SCREENRES_FAILED depth=" + BDbgNum(cfg.colorDepth)
        SCR_W = 800
        SCR_H = 600
        cfg.colorDepth = 16
        BuildLayout

        BDbgTrace "REFRESH_DISPLAY_FALLBACK_SCREENRES_BEGIN"
        IF SCREENRES(SCR_W, SCR_H, cfg.colorDepth) <> 0 THEN
            BDbgTrace "REFRESH_DISPLAY_FALLBACK_FAILED"
            SCREEN 0
            WIDTH 80, 25
            COLOR 7, 0
            CLS
            PRINT "ERROR: requested video mode not supported."
            END 1
        END IF
        BDbgTrace "REFRESH_DISPLAY_FALLBACK_SCREENRES_DONE"
    END IF

    HideFreeBasicMouseCursor
    BDbgTrace "REFRESH_DISPLAY_SCREENRES_DONE"
    ApplyBacklash256Palette
    BDbgTrace "REFRESH_DISPLAY_PALETTE_DONE"
    cursorBackValid = 0
    ReloadShellAssets
    BDbgTrace "REFRESH_DISPLAY_ASSETS_DONE"

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
            SyncLayoutWindowFromGlobals activeLayoutWindow
            ApplyBacklash256Palette
            BDbgTrace "REFRESH_DISPLAY_SYNC_ACTIVE_DONE"
        END IF
    END IF
    BDbgTrace "REFRESH_DISPLAY_DONE"
END SUB

SUB RefreshVisualConfigFast()
    DIM oldResMode AS INTEGER
    DIM oldColorDepth AS INTEGER
    DIM oldDesktopColor AS UINTEGER
    DIM oldWallpaperPath AS STRING
    DIM oldWallpaperMode AS INTEGER
    DIM oldLaunchButtonPath AS STRING
    DIM oldStartStripPath AS STRING
    DIM oldStartStripPadTop AS INTEGER
    DIM oldStartStripPadBot AS INTEGER
    DIM oldStartStripTopR AS INTEGER
    DIM oldStartStripTopG AS INTEGER
    DIM oldStartStripTopB AS INTEGER
    DIM oldStartStripBotR AS INTEGER
    DIM oldStartStripBotG AS INTEGER
    DIM oldStartStripBotB AS INTEGER
    DIM wallpaperChanged AS INTEGER
    DIM startStripChanged AS INTEGER

    oldResMode = cfg.resMode
    oldColorDepth = cfg.colorDepth
    oldDesktopColor = COL_DESKTOP
    oldWallpaperPath = theme.wallpaperPath
    oldWallpaperMode = theme.wallpaperMode
    oldLaunchButtonPath = theme.launchButtonPath
    oldStartStripPath = theme.startStripPath
    oldStartStripPadTop = theme.startStripPadTop
    oldStartStripPadBot = theme.startStripPadBot
    oldStartStripTopR = theme.startStripTopR
    oldStartStripTopG = theme.startStripTopG
    oldStartStripTopB = theme.startStripTopB
    oldStartStripBotR = theme.startStripBotR
    oldStartStripBotG = theme.startStripBotG
    oldStartStripBotB = theme.startStripBotB

    LoadShellConfig
    LoadThemeConfig
    LoadLayoutConfig
    LoadClockConfig
    BuildThemeColors
    LoadUIStyleConfig

    IF cfg.resMode <> oldResMode OR cfg.colorDepth <> oldColorDepth THEN
        RefreshDisplayFromCurrentConfig
        EXIT SUB
    END IF

    ApplyBacklash256Palette

    wallpaperChanged = 0
    IF UCASE$(theme.wallpaperPath) <> UCASE$(oldWallpaperPath) THEN wallpaperChanged = -1
    IF theme.wallpaperMode <> oldWallpaperMode THEN wallpaperChanged = -1
    IF COL_DESKTOP <> oldDesktopColor THEN wallpaperChanged = -1

    IF wallpaperChanged <> 0 THEN
        IF UCASE$(theme.wallpaperPath) <> UCASE$(oldWallpaperPath) THEN LoadWallpaper
        BuildBackgroundCache
    ELSEIF bgCache = 0 THEN
        BuildBackgroundCache
    END IF

    startStripChanged = 0
    IF UCASE$(theme.startStripPath) <> UCASE$(oldStartStripPath) THEN startStripChanged = -1
    IF theme.startStripPadTop <> oldStartStripPadTop THEN startStripChanged = -1
    IF theme.startStripPadBot <> oldStartStripPadBot THEN startStripChanged = -1
    IF theme.startStripTopR <> oldStartStripTopR THEN startStripChanged = -1
    IF theme.startStripTopG <> oldStartStripTopG THEN startStripChanged = -1
    IF theme.startStripTopB <> oldStartStripTopB THEN startStripChanged = -1
    IF theme.startStripBotR <> oldStartStripBotR THEN startStripChanged = -1
    IF theme.startStripBotG <> oldStartStripBotG THEN startStripChanged = -1
    IF theme.startStripBotB <> oldStartStripBotB THEN startStripChanged = -1

    IF startStripChanged <> 0 THEN
        FreeStartStrip
        LoadStartStrip
    END IF

    IF UCASE$(theme.launchButtonPath) <> UCASE$(oldLaunchButtonPath) THEN LoadLaunchButtonBmp

    FreeAllLayoutWindowDrawCaches
    FreeScriptPreviewCache
    InvalidateDesktopCache
    InvalidateTaskbarCache
    InvalidateStartMenuBackBuffer
    InvalidateGradientCaches

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
            SyncLayoutWindowFromGlobals activeLayoutWindow
            SaveBindingSnapshotFromGlobals activeLayoutWindow
        END IF
    END IF

    cursorBackValid = 0
END SUB

