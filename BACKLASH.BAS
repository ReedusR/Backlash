SUB DrawNewLayoutWindowOpenOnly(BYVAL previousWin AS INTEGER, BYVAL menuOverlayWasOpen AS INTEGER, BYVAL startPressed AS INTEGER, BYVAL mx AS INTEGER, BYVAL my AS INTEGER)
    ' Opening a new top-level layout window should not redraw the desktop and every window.
    ' Restore only the Launch-menu overlay when needed, refresh the window that just
    ' lost focus, draw the new top window, then update the taskbar.
    IF menuOverlayWasOpen <> 0 THEN
        IF startMenuBackBuffer = 0 OR startMenuBackValid = 0 THEN
            SCREENLOCK
            RestoreCursorBackBuffer
            DrawDesktop
            DrawAllLayoutWindows
            DrawTaskbar startPressed
            SaveCursorBackBuffer mx, my
            DrawCursor mx, my
            SCREENUNLOCK
            EXIT SUB
        END IF
    END IF

    SCREENLOCK
    RestoreCursorBackBuffer

    IF menuOverlayWasOpen <> 0 THEN
        PUT (startMenuBackX, startMenuBackY), startMenuBackBuffer, PSET
        startMenuBackValid = 0
    END IF

    IF previousWin >= LBOUND(layoutWindows) AND previousWin <= UBOUND(layoutWindows) THEN
        IF previousWin <> activeLayoutWindow THEN
            IF layoutWindows(previousWin).used <> 0 AND layoutWindows(previousWin).minimized = 0 THEN
                DrawLayoutWindowCached previousWin
            END IF
        END IF
    END IF

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 AND layoutWindows(activeLayoutWindow).minimized = 0 THEN
            DrawLayoutWindowCached activeLayoutWindow
        END IF
    END IF

    DrawTaskbar startPressed
    SaveCursorBackBuffer mx, my
    DrawCursor mx, my
    SCREENUNLOCK
END SUB

SUB DrawActiveLayoutWindowOnly(BYVAL mx AS INTEGER, BYVAL my AS INTEGER)
    IF activeLayoutWindow < LBOUND(layoutWindows) OR activeLayoutWindow > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(activeLayoutWindow).used = 0 THEN EXIT SUB
    IF layoutWindows(activeLayoutWindow).minimized <> 0 THEN EXIT SUB

    SCREENLOCK
    RestoreCursorBackBuffer
    DrawLayoutWindowCached activeLayoutWindow
    DrawSoundVolumePopup
    SaveCursorBackBuffer mx, my
    DrawCursor mx, my
    SCREENUNLOCK
END SUB

SUB DrawActiveLayoutWindowChangedOnly(BYVAL mx AS INTEGER, BYVAL my AS INTEGER)
    IF activeLayoutWindow < LBOUND(layoutWindows) OR activeLayoutWindow > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(activeLayoutWindow).used = 0 THEN EXIT SUB
    IF layoutWindows(activeLayoutWindow).minimized <> 0 THEN EXIT SUB

    ' This redraw consumes live active-window state directly.
    ' Do not let a later full redraw reuse a stale whole-window image.
    layoutDrawCacheValid(activeLayoutWindow) = 0

    SCREENLOCK
    RestoreCursorBackBuffer

    ' Typing and direct control scrolling immediately change again.
    ' Redraw the active window, but do not waste time GET-capturing a full-window cache
    ' that the next keypress or scroll tick will invalidate.
    layoutSkipFullWindowCacheCapture = -1
    DrawLayoutWindowCached activeLayoutWindow
    layoutSkipFullWindowCacheCapture = 0
    DrawSoundVolumePopup

    SaveCursorBackBuffer mx, my
    DrawCursor mx, my
    SCREENUNLOCK
END SUB


FUNCTION DrawFastTextboxLineOnly(BYVAL elemIdx AS INTEGER, BYVAL lineNum AS INTEGER) AS INTEGER
    DIM ex AS INTEGER
    DIM ey AS INTEGER
    DIM ew AS INTEGER
    DIM eh AS INTEGER
    DIM contentW AS INTEGER
    DIM contentH AS INTEGER
    DIM showHScroll AS INTEGER
    DIM showVScroll AS INTEGER
    DIM clientW AS INTEGER
    DIM clientH AS INTEGER
    DIM maxScrollX AS INTEGER
    DIM maxScrollY AS INTEGER
    DIM clipL AS INTEGER
    DIM clipT AS INTEGER
    DIM clipR AS INTEGER
    DIM clipB AS INTEGER
    DIM contentRight AS INTEGER
    DIM tbRows AS INTEGER
    DIM tbCols AS INTEGER
    DIM tbFirstLine AS INTEGER
    DIM tbRow AS INTEGER
    DIM tbStartPos AS INTEGER
    DIM tbLineEnd AS INTEGER
    DIM tbLineCount AS INTEGER
    DIM tbShowScroll AS INTEGER
    DIM tbScrollLeft AS INTEGER
    DIM tbTextClipR AS INTEGER
    DIM tbWrap AS INTEGER
    DIM tbCaret AS INTEGER
    DIM tbCol AS INTEGER
    DIM tbFocus AS INTEGER
    DIM tbLocked AS INTEGER
    DIM tbFillCol AS UINTEGER
    DIM tbTextCol AS UINTEGER
    DIM tx AS INTEGER
    DIM rowY AS INTEGER

    DrawFastTextboxLineOnly = 0

    IF elemIdx < 1 OR elemIdx > uiCount THEN EXIT FUNCTION
    IF uiElems(elemIdx).kindKey <> "TEXTBOX" THEN EXIT FUNCTION
    IF TextboxIsMultiline(elemIdx) = 0 THEN EXIT FUNCTION
    IF Ed_SelHas(uiEdit(elemIdx)) <> 0 THEN EXIT FUNCTION

    ex = uiWinX + uiElems(elemIdx).x - uiScrollX
    ey = uiWinY + 22 + uiElems(elemIdx).y - uiScrollY
    ew = uiElems(elemIdx).w
    eh = uiElems(elemIdx).h
    IF ew <= 0 THEN ew = 120
    IF eh <= 0 THEN eh = 22

    GetLayoutContentExtents contentW, contentH
    GetLayoutScrollMetricsFromContent contentW, contentH, showHScroll, showVScroll, clientW, clientH, maxScrollX, maxScrollY

    contentRight = LayoutVisibleClientRight(showVScroll)
    clipL = uiWinX + 2
    clipT = uiWinY + 19
    clipR = contentRight
    clipB = LayoutVisibleClientBottom(showHScroll)

    IF RectIntersectsClip(ex, ey, ex + ew, ey + eh, clipL, clipT, clipR, clipB) = 0 THEN
        DrawFastTextboxLineOnly = -1
        EXIT FUNCTION
    END IF

    tbWrap = TextboxWordWrap(elemIdx)
    tbRows = TextboxRows(elemIdx)
    tbCols = TextboxCols(elemIdx)
    tbLineCount = TextboxDisplayLineCount(elemIdx, uiElems(elemIdx).text)

    tbShowScroll = 0
    tbTextClipR = ex + ew - 2
    IF tbTextClipR > clipR THEN tbTextClipR = clipR
    IF tbTextClipR < clipL THEN tbTextClipR = clipL
    IF tbLineCount > tbRows THEN
        tbShowScroll = -1
        tbScrollLeft = ex + ew - 14
        tbTextClipR = tbScrollLeft - 1
        IF tbTextClipR > clipR THEN tbTextClipR = clipR
        IF tbTextClipR < clipL THEN tbTextClipR = clipL
    END IF

    tbFirstLine = 0
    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN tbFirstLine = comboScrollTop(activeLayoutWindow, elemIdx)
    END IF

    tbRow = lineNum - tbFirstLine
    IF tbRow < 0 OR tbRow >= tbRows THEN EXIT FUNCTION

    tbStartPos = TextboxMetricLineStart(elemIdx, uiElems(elemIdx).text, lineNum, tbCols)
    IF tbStartPos < 0 THEN tbStartPos = 0

    IF tbWrap <> 0 THEN
        tbLineEnd = TbWrappedLineEndPos(uiElems(elemIdx).text, tbStartPos, tbCols)
    ELSE
        tbLineEnd = TbLineEndPos(uiElems(elemIdx).text, tbStartPos)
    END IF

    tbLocked = 0
    IF uiElems(elemIdx).noEdit <> 0 AND uiElems(elemIdx).state < 0 THEN tbLocked = -1
    tbFillCol = COL_CONTROL_BG
    tbTextCol = COL_TEXT
    IF tbLocked <> 0 THEN
        tbFillCol = COL_BEVEL_HI
        tbTextCol = COL_BEVEL_LO
    END IF

    rowY = ey + 4 + tbRow * 8
    FillRectClipped ex + 3, rowY, tbTextClipR, rowY + 7, clipL, clipT, tbTextClipR, clipB, tbFillCol
    DrawStringSliceClipped ex + 4, rowY, uiElems(elemIdx).text, tbStartPos + 1, tbLineEnd - tbStartPos, tbCols, tbTextCol, clipL, clipT, tbTextClipR, clipB

    tbFocus = 0
    tbCaret = uiCaretPos
    IF uiWindowActive <> 0 AND uiFocusIndex = elemIdx THEN tbFocus = -1
    IF tbFocus <> 0 AND uiCaretVisible <> 0 THEN
        tbCol = tbCaret - tbStartPos
        IF tbCol < 0 THEN tbCol = 0
        IF tbCol > tbCols THEN tbCol = tbCols
        tx = ex + 4 + tbCol * 8
        IF tx > ex + ew - 5 THEN tx = ex + ew - 5
        LineVClipped tx, rowY, rowY + 7, clipL, clipT, tbTextClipR, clipB, tbTextCol
    END IF

    DrawFastTextboxLineOnly = -1
END FUNCTION

SUB DrawActiveDirtyElementsOnly(BYVAL mx AS INTEGER, BYVAL my AS INTEGER)
    DIM dirtyIdx AS INTEGER
    DIM elemIdx AS INTEGER
    DIM fastLineDrawn AS INTEGER

    IF activeLayoutWindow < LBOUND(layoutWindows) OR activeLayoutWindow > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(activeLayoutWindow).used = 0 THEN EXIT SUB
    IF layoutWindows(activeLayoutWindow).minimized <> 0 THEN EXIT SUB

    ' Dirty-control redraw changes what is on screen without recapturing
    ' the full window image, so that cache must be considered stale afterward.
    layoutDrawCacheValid(activeLayoutWindow) = 0

    IF layoutDirtyElemCount(activeLayoutWindow) <= 0 THEN
        IF layoutFastTextboxPending = 0 OR layoutFastTextboxWin <> activeLayoutWindow THEN
            DrawActiveLayoutWindowChangedOnly mx, my
            EXIT SUB
        END IF
    END IF

    SCREENLOCK
    RestoreCursorBackBuffer
    drawLayoutWindow = activeLayoutWindow

    ' Typing/list dirty redraws are raised while this active window already owns
    ' the live globals. Reloading the saved slot here copied every control and
    ' every textbox undo buffer back out on each keystroke for no benefit.
    ' These are true control-only changes. Paint just the controls that changed
    ' instead of redrawing the entire active app window for every key or list step.
    fastLineDrawn = 0
    IF layoutFastTextboxPending <> 0 AND layoutFastTextboxWin = activeLayoutWindow THEN
        IF layoutFastTextboxLine >= 0 THEN
            fastLineDrawn = DrawFastTextboxLineOnly(layoutFastTextboxElem, layoutFastTextboxLine)
        ELSE
            fastLineDrawn = DrawFastTextboxViewportOnly(layoutFastTextboxElem)
        END IF
        IF fastLineDrawn = 0 THEN MarkLayoutDirtyElement activeLayoutWindow, layoutFastTextboxElem
    END IF

    IF layoutDirtyElemCount(activeLayoutWindow) > 0 THEN
        layoutDrawPass = 4
        layoutDrawOnlyElement = 0
        DrawAppLayout
    END IF

    layoutDrawPass = 0
    layoutDrawOnlyElement = 0
    drawLayoutWindow = 0
    ClearLayoutDirtyElements activeLayoutWindow
    DrawSoundVolumePopup
    SaveCursorBackBuffer mx, my
    DrawCursor mx, my
    SCREENUNLOCK
END SUB

SUB DrawActiveFocusedTextboxOnly(BYVAL mx AS INTEGER, BYVAL my AS INTEGER)
    DIM focusElem AS INTEGER
    DIM caretLine AS INTEGER
    DIM fastLineDrawn AS INTEGER

    IF activeLayoutWindow < LBOUND(layoutWindows) OR activeLayoutWindow > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(activeLayoutWindow).used = 0 THEN EXIT SUB
    IF layoutWindows(activeLayoutWindow).minimized <> 0 THEN EXIT SUB

    ' Caret-only textbox redraws also bypass full-window recapture.
    ' Keep the full window cache from surviving with an old caret state.
    layoutDrawCacheValid(activeLayoutWindow) = 0

    focusElem = layoutWindows(activeLayoutWindow).focusIndex
    IF focusElem < 1 OR focusElem > layoutUiCount(activeLayoutWindow) THEN
        DrawActiveLayoutWindowOnly mx, my
        EXIT SUB
    END IF
    IF layoutUiElems(activeLayoutWindow, focusElem).kindId <> UI_KIND_TEXTBOX THEN
        DrawActiveLayoutWindowOnly mx, my
        EXIT SUB
    END IF

    SCREENLOCK
    RestoreCursorBackBuffer

    fastLineDrawn = 0
    IF TextboxIsMultiline(focusElem) <> 0 THEN
        IF Ed_SelHas(uiEdit(focusElem)) = 0 THEN
            caretLine = TextboxMetricCaretLine(focusElem, uiElems(focusElem).text, uiCaretPos, TextboxCols(focusElem))
            fastLineDrawn = DrawFastTextboxLineOnly(focusElem, caretLine)
        END IF
    END IF

    IF fastLineDrawn = 0 THEN
        drawLayoutWindow = activeLayoutWindow
        layoutDrawOnlyElement = focusElem
        layoutDrawPass = 3
        DrawAppLayout
        layoutDrawPass = 0
        layoutDrawOnlyElement = 0
        drawLayoutWindow = 0
    END IF

    DrawSoundVolumePopup
    SaveCursorBackBuffer mx, my
    DrawCursor mx, my
    SCREENUNLOCK
END SUB

' ---------------------------
' Message boxes, confirm boxes, and text-entry popups
' ---------------------------

SUB GuiMessageBounds(BYREF boxX1 AS INTEGER, BYREF boxY1 AS INTEGER, BYREF boxX2 AS INTEGER, BYREF boxY2 AS INTEGER)
    DIM boxW AS INTEGER
    DIM boxH AS INTEGER

    boxW = 360
    boxH = 116

    IF SCR_W < boxW + 24 THEN boxW = SCR_W - 24
    IF boxW < 240 THEN boxW = 240
    IF WORK_H < boxH + 24 THEN boxH = WORK_H - 24
    IF boxH < 96 THEN boxH = 96

    boxX1 = (SCR_W - boxW) \ 2
    boxY1 = WORK_Y + ((WORK_H - boxH) \ 2)
    IF boxX1 < 4 THEN boxX1 = 4
    IF boxY1 < WORK_Y + 4 THEN boxY1 = WORK_Y + 4

    boxX2 = boxX1 + boxW
    boxY2 = boxY1 + boxH
END SUB

FUNCTION GuiMessageOkHit(BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER) AS INTEGER
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER
    DIM okX1 AS INTEGER
    DIM okY1 AS INTEGER
    DIM okX2 AS INTEGER
    DIM okY2 AS INTEGER

    GuiMessageBounds x1, y1, x2, y2
    okX1 = x1 + ((x2 - x1) - 70) \ 2
    okY1 = y2 - 34
    okX2 = okX1 + 70
    okY2 = okY1 + 22

    RETURN InRect(mouseX, mouseY, okX1, okY1, okX2, okY2)
END FUNCTION

FUNCTION GuiMessageCloseHit(BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER) AS INTEGER
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER

    GuiMessageBounds x1, y1, x2, y2
    RETURN InRect(mouseX, mouseY, x2 - 18, y1 + 3, x2 - 4, y1 + 17)
END FUNCTION

SUB DrawGuiMessageBox(BYVAL titleText AS STRING, BYVAL msgText AS STRING, BYVAL boxX1 AS INTEGER, BYVAL boxY1 AS INTEGER, BYVAL boxX2 AS INTEGER, BYVAL boxY2 AS INTEGER, BYVAL okPressed AS INTEGER, BYVAL closePressed AS INTEGER)
    DIM okX1 AS INTEGER
    DIM okY1 AS INTEGER
    DIM okX2 AS INTEGER
    DIM okY2 AS INTEGER
    DIM lineOne AS STRING
    DIM lineTwo AS STRING
    DIM msgWork AS STRING

    DrawBevelBox boxX1, boxY1, boxX2, boxY2, 0
    LINE (boxX1 + 2, boxY1 + 20)-(boxX2 - 2, boxY2 - 2), COL_CONTROL_BG, BF
    DrawThemedTitleBar boxX1 + 1, boxY1 + 1, boxX2 - 1, boxY1 + 18, -1

    IF TRIM$(titleText) <> "" THEN
        DRAW STRING (boxX1 + 8, boxY1 + 6), LEFT$(TRIM$(titleText), 36), COL_TEXT_INV
    ELSE
        DRAW STRING (boxX1 + 8, boxY1 + 6), "Message", COL_TEXT_INV
    END IF

    DrawBevelBox boxX2 - 18, boxY1 + 3, boxX2 - 4, boxY1 + 17, closePressed
    DrawCloseGlyph boxX2 - 18, boxY1 + 3, boxX2 - 4, boxY1 + 17

    msgWork = TRIM$(msgText)
    IF LEN(msgWork) <= 38 THEN
        lineOne = msgWork
        lineTwo = ""
    ELSE
        lineOne = LEFT$(msgWork, 38)
        lineTwo = MID$(msgWork, 39, 38)
    END IF

    IF lineOne <> "" THEN DRAW STRING (boxX1 + 18, boxY1 + 40), lineOne, COL_TEXT
    IF lineTwo <> "" THEN DRAW STRING (boxX1 + 18, boxY1 + 54), lineTwo, COL_TEXT

    okX1 = boxX1 + ((boxX2 - boxX1) - 70) \ 2
    okY1 = boxY2 - 34
    okX2 = okX1 + 70
    okY2 = okY1 + 22

    DrawButtonBevelBox okX1, okY1, okX2, okY2, okPressed
    DRAW STRING (okX1 + 27, okY1 + 7), "OK", COL_TEXT
END SUB

SUB RedrawGuiForMessage(BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER, BYVAL titleText AS STRING, BYVAL msgText AS STRING, BYVAL okPressed AS INTEGER, BYVAL closePressed AS INTEGER, BYVAL showBox AS INTEGER)
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER

    SCREENLOCK
    cursorBackValid = 0
    DrawDesktop
    IF layoutWindowCount > 0 THEN
        DrawAllLayoutWindows
    ELSE
        DrawWindows
    END IF
    DrawTaskbar 0
    IF showBox <> 0 THEN
        GuiMessageBounds x1, y1, x2, y2
        DrawGuiMessageBox titleText, msgText, x1, y1, x2, y2, okPressed, closePressed
    END IF
    SaveCursorBackBuffer mouseX, mouseY
    DrawCursor mouseX, mouseY
    SCREENUNLOCK
END SUB

SUB ShowGuiMessageBox(BYVAL titleText AS STRING, BYVAL msgText AS STRING)
    DIM mx AS INTEGER
    DIM my AS INTEGER
    DIM mw AS INTEGER
    DIM mb AS INTEGER
    DIM primaryNow AS INTEGER
    DIM prevPrimary AS INTEGER
    DIM okPressed AS INTEGER
    DIM closePressed AS INTEGER
    DIM mouseOk AS INTEGER
    DIM oldMx AS INTEGER
    DIM oldMy AS INTEGER
    DIM k AS STRING
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER

    startMenuOpen = 0
    launchCtxOpen = 0
    FOR mw = 0 TO 8
        menuOpenItem(mw) = 0
    NEXT

    IF guiMessageSuppressErrorSound = 0 THEN SoundUiEvent "ERROR"

    GuiMessageBounds x1, y1, x2, y2

    mouseOk = (GETMOUSE(mx, my, mw, mb) = 0)
    IF mouseOk THEN
        mx = ClampI(mx, 0, SCR_W - 1)
        my = ClampI(my, 0, SCR_H - 1)
    ELSE
        mx = SCR_W \ 2
        my = WORK_Y + (WORK_H \ 2)
        mb = 0
    END IF

    prevPrimary = IsPrimaryButtonPressed(mb)
    okPressed = 0
    closePressed = 0
    oldMx = -1
    oldMy = -1

    RedrawGuiForMessage mx, my, titleText, msgText, okPressed, closePressed, -1

    DO
        mouseOk = (GETMOUSE(mx, my, mw, mb) = 0)
        IF mouseOk THEN
            mx = ClampI(mx, 0, SCR_W - 1)
            my = ClampI(my, 0, SCR_H - 1)
        ELSE
            mx = oldMx
            my = oldMy
            mb = 0
        END IF

        primaryNow = IsPrimaryButtonPressed(mb)

        IF primaryNow <> 0 AND prevPrimary = 0 THEN
            okPressed = GuiMessageOkHit(mx, my)
            closePressed = GuiMessageCloseHit(mx, my)
            SCREENLOCK
            RestoreCursorBackBuffer
            DrawGuiMessageBox titleText, msgText, x1, y1, x2, y2, okPressed, closePressed
            SaveCursorBackBuffer mx, my
            DrawCursor mx, my
            SCREENUNLOCK
        END IF

        IF primaryNow = 0 AND prevPrimary <> 0 THEN
            IF okPressed <> 0 OR closePressed <> 0 THEN EXIT DO
            okPressed = 0
            closePressed = 0
            SCREENLOCK
            RestoreCursorBackBuffer
            DrawGuiMessageBox titleText, msgText, x1, y1, x2, y2, okPressed, closePressed
            SaveCursorBackBuffer mx, my
            DrawCursor mx, my
            SCREENUNLOCK
        END IF

        k = INKEY$
        IF k <> "" THEN
            IF k = CHR$(13) OR k = CHR$(27) THEN EXIT DO
        END IF

        IF mx <> oldMx OR my <> oldMy THEN
            DrawCursorOnly mx, my
            oldMx = mx
            oldMy = my
        END IF

        prevPrimary = primaryNow
        SoundServiceAt TIMER
        SLEEP 10
    LOOP

    DO
        mouseOk = (GETMOUSE(mx, my, mw, mb) = 0)
        IF mouseOk = 0 THEN EXIT DO
        IF IsPrimaryButtonPressed(mb) = 0 THEN EXIT DO
        SoundServiceAt TIMER
        SLEEP 10
    LOOP

    RedrawGuiForMessage mx, my, titleText, msgText, 0, 0, 0
END SUB

SUB DrawGuiConfirmBox(BYVAL titleText AS STRING, BYVAL msgText AS STRING, BYVAL boxX1 AS INTEGER, BYVAL boxY1 AS INTEGER, BYVAL boxX2 AS INTEGER, BYVAL boxY2 AS INTEGER, BYVAL okPressed AS INTEGER, BYVAL cancelPressed AS INTEGER, BYVAL closePressed AS INTEGER)
