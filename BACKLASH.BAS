                                    END IF
                                END IF
                            END IF
                        END IF
                    NEXT

                    IF rightHitIndex > 0 THEN
                        listItemCount = ComboFastItemCount(rightHitIndex, listCacheSlot)
                        rightItemH = 16
                        rightRows = (eh - 4) \ rightItemH
                        IF rightRows < 1 THEN rightRows = 1
                        comboScrollTop(activeLayoutWindow, rightHitIndex) = ClampScrollPos(comboScrollTop(activeLayoutWindow, rightHitIndex), listItemCount - rightRows)
                        rightTextRight = ex + ew - 2
                        IF listItemCount > rightRows THEN rightTextRight = ex + ew - 16
                        IF smx >= ex + 2 AND smx <= rightTextRight AND smy >= ey + 2 AND smy <= ey + eh - 2 THEN
                            rightSelIdx = comboScrollTop(activeLayoutWindow, rightHitIndex) + ((smy - (ey + 2)) \ rightItemH) + 1
                            IF rightSelIdx >= 1 AND rightSelIdx <= listItemCount THEN
                                ctxFileValue = ComboFastItemValue(listCacheSlot, rightSelIdx)
                                IF LEFT$(UCASE$(ctxFileValue), 2) = "F:" OR LEFT$(UCASE$(ctxFileValue), 2) = "D:" THEN
                                    ctxMenuIsDir = 0
                                    ctxMenuEditEnabled = 0
                                    ctxMenuHasCopy = 0
                                    ctxMenuPasteOnly = 0
                                    IF LEFT$(UCASE$(ctxFileValue), 2) = "D:" THEN
                                        ctxMenuIsDir = -1
                                    ELSE
                                        IF FileSupportsEditAssociation(MID$(ctxFileValue, 3)) <> 0 THEN
                                            IF LookupFileEditAssociation(MID$(ctxFileValue, 3)) <> "" THEN ctxMenuEditEnabled = -1
                                        END IF
                                    END IF
                                    ctxMenuH = ContextMenuHeight(activeLayoutWindow, ctxMenuIsDir, ctxMenuPasteOnly)
                                    uiElems(rightHitIndex).text = ComboFastItemText(listCacheSlot, rightSelIdx)
                                    IF uiElems(rightHitIndex).multiSelect <> 0 THEN
