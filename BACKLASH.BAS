                                            ListSelectionClear activeLayoutWindow, rightHitIndex
                                            ListSelectionAdd activeLayoutWindow, rightHitIndex, ctxFileValue
                                            layoutListAnchorIdx(activeLayoutWindow, rightHitIndex) = rightSelIdx
                                        END IF
                                    END IF
                                    uiFocusIndex = rightHitIndex
                                    layoutWindows(activeLayoutWindow).focusIndex = rightHitIndex
                                    SyncLayoutWindowElementOnly activeLayoutWindow, rightHitIndex
                                    IF ctxMenuIsDir = 0 THEN
