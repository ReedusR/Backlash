    f = FREEFILE
    IF OPEN(DesktopIconEditTempPath() FOR OUTPUT AS #f) <> 0 THEN EXIT SUB
    PRINT #f, "[ICON]"
    PRINT #f, "DISPLAY=" + desktopIcons(iconIdx).caption
    PRINT #f, "TARGET=" + desktopIcons(iconIdx).action
    PRINT #f, "ICON=" + desktopIcons(iconIdx).bmpFile
    PRINT #f, "X=" + LTRIM$(STR$(desktopIcons(iconIdx).x))
    PRINT #f, "Y=" + LTRIM$(STR$(desktopIcons(iconIdx).y))
    CLOSE #f
END SUB

