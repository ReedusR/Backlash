FUNCTION LayoutParserSectionIsElement(BYREF sectionName AS STRING) AS INTEGER
    SELECT CASE sectionName
    CASE "TAB", "LABEL", "PREVIEW", "APPVIEW", "CANVAS", "OVERLAY", "RADIO", "CHECKBOX", "BUTTON", "COMBO", "LISTBOX", "TEXTBOX", "SPLITTER"
        RETURN -1
    END SELECT

    RETURN 0
END FUNCTION

SUB ResetLayoutPageParseElement(BYREF cur AS UIElement)
    cur.kind = ""
    cur.text = ""
    cur.x = 0
    cur.y = 0
    cur.w = 0
    cur.h = 0
    cur.page = ""
    cur.state = 0
    cur.name = ""
    cur.action = ""
    cur.enterAction = ""
    cur.escAction = ""
    cur.keyAction = ""
    cur.keyCapture = 0
    cur.groupName = ""
    cur.bindFile = ""
    cur.bindSection = ""
    cur.bindKey = ""
    cur.bindValue = ""
    cur.sourceDir = ""
    cur.sourceMask = ""
    cur.sourceKind = ""
    cur.sourceIndex = ""
    cur.valuePrefix = ""
    cur.sourceControl = ""
    cur.modeGroup = ""
    cur.dropRows = 0
    cur.dropW = 0
    cur.sourceItems = ""
    cur.defaultValue = ""
    cur.maxLen = 0
    cur.noEdit = 0
    cur.multiSelect = 0
    cur.drawStyle = ""
    cur.baseX = 0
    cur.baseY = 0
    cur.baseW = 0
    cur.baseH = 0
    cur.growW = 0
    cur.growH = 0
    cur.moveX = 0
    cur.moveY = 0
    cur.wordWrap = 0
    NormalizeUiElementKeys cur
END SUB

SUB AppendParsedLayoutPageElement(BYREF cur AS UIElement, BYVAL elemKind AS STRING)
    IF uiCount >= 192 THEN EXIT SUB
    IF cur.text = "" AND cur.w = 0 AND cur.h = 0 AND cur.x = 0 AND cur.y = 0 THEN EXIT SUB

    uiCount = uiCount + 1
    cur.baseX = cur.x
    cur.baseY = cur.y
    cur.baseW = cur.w
    cur.baseH = cur.h
    uiElems(uiCount) = cur
    uiElems(uiCount).kind = elemKind
    NormalizeUiElementKeys uiElems(uiCount)
END SUB

FUNCTION LayoutSelectedPageFile() AS STRING
    DIM keyName AS STRING
    DIM pageFile AS STRING
    DIM activePage AS STRING
    DIM pageKey AS STRING
    DIM i AS INTEGER
    DIM ch AS STRING

    LayoutSelectedPageFile = ""
    IF TRIM$(uiLayoutAppPath) = "" THEN EXIT FUNCTION

    keyName = "PAGE_FILE_" + LTRIM$(STR$(uiSelectedTab))
    pageFile = AppCfgValue(uiLayoutAppPath, keyName, "")

    IF TRIM$(pageFile) = "" THEN
        GetLayoutActivePage activePage
        pageKey = ""
        FOR i = 1 TO LEN(activePage)
            ch = MID$(activePage, i, 1)
            IF (ch >= "A" AND ch <= "Z") OR (ch >= "0" AND ch <= "9") THEN
                pageKey = pageKey + ch
            ELSEIF ch = " " OR ch = "-" THEN
                pageKey = pageKey + "_"
            END IF
        NEXT
        IF pageKey <> "" THEN pageFile = AppCfgValue(uiLayoutAppPath, "PAGE_FILE_" + pageKey, "")
    END IF

    pageFile = NormalizePath(pageFile)
    IF pageFile = "" THEN EXIT FUNCTION
    LayoutSelectedPageFile = LayoutFilePath(pageFile)
END FUNCTION

SUB RemoveLoadedLayoutPageControls()
    DIM i AS INTEGER
    DIM j AS INTEGER
    DIM elemKind AS STRING

    i = 1
    DO WHILE i <= uiCount
        elemKind = uiElems(i).kindKey
        IF TRIM$(uiElems(i).page) <> "" AND elemKind <> "TAB" THEN
            FOR j = i TO uiCount - 1
                uiElems(j) = uiElems(j + 1)
                uiEdit(j) = uiEdit(j + 1)
                uiSelAnchor(j) = uiSelAnchor(j + 1)
                uiPrefCol(j) = uiPrefCol(j + 1)
                uiWordSelMode(j) = uiWordSelMode(j + 1)
                uiWordSelA(j) = uiWordSelA(j + 1)
                uiWordSelB(j) = uiWordSelB(j + 1)
                uiLineSelMode(j) = uiLineSelMode(j + 1)
                uiLineSelA(j) = uiLineSelA(j + 1)
                uiLineSelB(j) = uiLineSelB(j + 1)
            NEXT
            uiCount = uiCount - 1
        ELSE
            i = i + 1
        END IF
    LOOP

    FOR j = uiCount + 1 TO 192
        ResetLayoutPageParseElement uiElems(j)
        ResetEditorControlRuntimeState j, ""
        uiSelAnchor(j) = 0
        uiPrefCol(j) = 0
        uiWordSelMode(j) = 0
        uiWordSelA(j) = 0
        uiWordSelB(j) = 0
        uiLineSelMode(j) = 0
        uiLineSelA(j) = 0
        uiLineSelB(j) = 0
    NEXT
END SUB

FUNCTION LayoutPageParseCacheFind(BYREF pageFile AS STRING, BYVAL pageStamp AS DOUBLE) AS INTEGER
    DIM slotIdx AS INTEGER
    DIM cachePath AS STRING

    FOR slotIdx = 1 TO LAYOUT_PAGE_PARSE_CACHE_SLOTS
        cachePath = RTRIM$(layoutPageParseCachePath(slotIdx))
        IF cachePath <> "" THEN
            IF cachePath = pageFile AND layoutPageParseCacheStamp(slotIdx) = pageStamp THEN
                layoutPageParseCacheTick = layoutPageParseCacheTick + 1
                layoutPageParseCacheUse(slotIdx) = layoutPageParseCacheTick
                RETURN slotIdx
            END IF
        END IF
    NEXT

    RETURN 0
END FUNCTION

SUB AppendLayoutPageControlsFromCache(BYVAL cacheSlot AS INTEGER)
    DIM i AS INTEGER
    DIM itemCount AS INTEGER

    IF cacheSlot < 1 OR cacheSlot > LAYOUT_PAGE_PARSE_CACHE_SLOTS THEN EXIT SUB
    itemCount = layoutPageParseCacheCount(cacheSlot)
    IF itemCount < 1 THEN EXIT SUB
    IF itemCount > 192 THEN itemCount = 192

    FOR i = 1 TO itemCount
        IF uiCount >= 192 THEN EXIT FOR
        uiCount = uiCount + 1
        uiElems(uiCount) = layoutPageParseCacheElem(cacheSlot, i)
    NEXT
END SUB

SUB StoreLayoutPageParseCache(BYREF pageFile AS STRING, BYVAL pageStamp AS DOUBLE, BYVAL firstElem AS INTEGER, BYVAL elemCount AS INTEGER)
    DIM slotIdx AS INTEGER
    DIM i AS INTEGER
    DIM oldestSlot AS INTEGER
    DIM oldestUse AS LONG
    DIM existingPath AS STRING

    IF pageFile = "" THEN EXIT SUB
    IF elemCount < 1 THEN EXIT SUB
    IF firstElem < 1 OR firstElem > 192 THEN EXIT SUB
    IF elemCount > 192 THEN elemCount = 192

    slotIdx = 0
    FOR i = 1 TO LAYOUT_PAGE_PARSE_CACHE_SLOTS
        existingPath = RTRIM$(layoutPageParseCachePath(i))
        IF existingPath = pageFile THEN
            slotIdx = i
            EXIT FOR
        END IF
        IF slotIdx = 0 AND existingPath = "" THEN slotIdx = i
    NEXT

    IF slotIdx = 0 THEN
        oldestSlot = 1
        oldestUse = layoutPageParseCacheUse(1)
        FOR i = 2 TO LAYOUT_PAGE_PARSE_CACHE_SLOTS
            IF layoutPageParseCacheUse(i) < oldestUse THEN
                oldestUse = layoutPageParseCacheUse(i)
                oldestSlot = i
            END IF
        NEXT
        slotIdx = oldestSlot
    END IF

    FOR i = 1 TO layoutPageParseCacheCount(slotIdx)
        IF i > 192 THEN EXIT FOR
        ResetLayoutPageParseElement layoutPageParseCacheElem(slotIdx, i)
    NEXT

    layoutPageParseCachePath(slotIdx) = pageFile
    layoutPageParseCacheStamp(slotIdx) = pageStamp
    layoutPageParseCacheCount(slotIdx) = elemCount
    layoutPageParseCacheTick = layoutPageParseCacheTick + 1
    layoutPageParseCacheUse(slotIdx) = layoutPageParseCacheTick

    FOR i = 1 TO elemCount
        layoutPageParseCacheElem(slotIdx, i) = uiElems(firstElem + i - 1)
    NEXT
END SUB

SUB AppendLayoutPageFileControls(BYVAL pageFile AS STRING)
    DIM f AS INTEGER
    DIM lineIn AS STRING
    DIM section AS STRING
    DIM rawSection AS STRING
    DIM cur AS UIElement
    DIM p AS INTEGER
    DIM k AS STRING
    DIM v AS STRING
    DIM pageStamp AS DOUBLE
    DIM cacheSlot AS INTEGER
    DIM firstParsedElem AS INTEGER
    DIM parsedCount AS INTEGER
    DIM sectionIsElement AS INTEGER

    pageFile = LayoutFilePath(NormalizePath(pageFile))
    IF pageFile = "" THEN EXIT SUB
    IF DIR(pageFile) = "" THEN EXIT SUB

    pageStamp = FileDateTime(pageFile)
    cacheSlot = LayoutPageParseCacheFind(pageFile, pageStamp)
    IF cacheSlot > 0 THEN
        AppendLayoutPageControlsFromCache cacheSlot
        EXIT SUB
    END IF

    firstParsedElem = uiCount + 1
    ResetLayoutPageParseElement cur
    section = ""
    sectionIsElement = 0

    f = FREEFILE
    IF OPEN(pageFile FOR INPUT AS #f) <> 0 THEN EXIT SUB

    DO WHILE NOT EOF(f)
        LINE INPUT #f, lineIn
        lineIn = TRIM$(lineIn)

        IF lineIn = "" THEN
        ELSEIF LEFT$(lineIn, 1) = "#" OR LEFT$(lineIn, 1) = ";" THEN
        ELSEIF LEFT$(lineIn, 1) = "[" AND RIGHT$(lineIn, 1) = "]" THEN
            IF sectionIsElement <> 0 THEN AppendParsedLayoutPageElement cur, section

            rawSection = UCASE$(MID$(lineIn, 2, LEN(lineIn) - 2))
            section = rawSection
            sectionIsElement = LayoutParserSectionIsElement(section)
            ResetLayoutPageParseElement cur
        ELSE
            p = INSTR(lineIn, "=")
            IF p > 0 THEN
                k = UCASE$(TRIM$(LEFT$(lineIn, p - 1)))
                v = TRIM$(MID$(lineIn, p + 1))

                IF sectionIsElement <> 0 THEN
                    IF k = "TEXT" THEN cur.text = v
                    IF k = "X" THEN cur.x = VAL(v)
                    IF k = "Y" THEN cur.y = VAL(v)
                    IF k = "W" THEN cur.w = VAL(v)
                    IF k = "H" THEN cur.h = VAL(v)
                    IF k = "PAGE" THEN cur.page = v
                    IF k = "STATE" THEN cur.state = VAL(v)
                    IF k = "NAME" THEN cur.name = v
                    IF k = "ACTION" THEN cur.action = v
                    IF k = "ENTER_ACTION" OR k = "ON_ENTER" OR k = "SUBMIT_ACTION" THEN cur.enterAction = v
                    IF k = "ESC_ACTION" OR k = "ON_ESC" THEN cur.escAction = v
                    IF k = "KEY_ACTION" OR k = "ON_KEY" THEN cur.keyAction = v
                    IF k = "KEY_CAPTURE" OR k = "CAPTURE_KEYS" THEN cur.keyCapture = VAL(v)
                    IF k = "GROUP" THEN cur.groupName = v
                    IF k = "BIND_FILE" THEN cur.bindFile = ResolveAppBindFilePathFromFile(pageFile, v)
                    IF k = "BIND_SECTION" THEN cur.bindSection = v
                    IF k = "BIND_KEY" THEN cur.bindKey = v
                    IF k = "BIND_VALUE" THEN cur.bindValue = v
                    IF k = "SOURCE_DIR" THEN cur.sourceDir = v
                    IF k = "SOURCE_MASK" THEN cur.sourceMask = v
                    IF k = "SOURCE_KIND" OR k = "SOURCE_TYPE" THEN cur.sourceKind = UCASE$(TRIM$(v))
                    IF k = "SOURCE_INDEX" OR k = "INDEX_FILE" THEN cur.sourceIndex = v
                    IF k = "VALUE_PREFIX" THEN cur.valuePrefix = v
                    IF k = "SOURCE_CONTROL" THEN cur.sourceControl = v
                    IF k = "MODE_GROUP" THEN cur.modeGroup = v
                    IF k = "DROP_ROWS" THEN cur.dropRows = VAL(v)
                    IF k = "DROP_W" OR k = "POPUP_W" THEN cur.dropW = VAL(v)
                    IF k = "SOURCE_ITEMS" THEN cur.sourceItems = v
                    IF k = "DEFAULT_VALUE" THEN cur.defaultValue = v
                    IF k = "MAXLEN" THEN cur.maxLen = VAL(v)
                    IF k = "READONLY" THEN cur.noEdit = VAL(v)
                    IF k = "NOEDIT" THEN cur.noEdit = VAL(v)
                    IF k = "MULTISELECT" THEN cur.multiSelect = VAL(v)
                    IF k = "DRAW_STYLE" THEN cur.drawStyle = UCASE$(v)
                    IF k = "STYLE" THEN cur.drawStyle = UCASE$(v)
                    IF k = "GROW_W" THEN cur.growW = VAL(v)
                    IF k = "GROW_H" THEN cur.growH = VAL(v)
                    IF k = "MOVE_X" THEN cur.moveX = VAL(v)
                    IF k = "ANCHOR_RIGHT" THEN cur.moveX = VAL(v)
                    IF k = "MOVE_Y" THEN cur.moveY = VAL(v)
                    IF k = "ANCHOR_BOTTOM" THEN cur.moveY = VAL(v)
                    IF k = "WORD_WRAP" THEN cur.wordWrap = VAL(v)
                END IF
            END IF
        END IF
    LOOP

    IF sectionIsElement <> 0 THEN AppendParsedLayoutPageElement cur, section

    CLOSE #f

    parsedCount = uiCount - firstParsedElem + 1
    IF parsedCount > 0 THEN StoreLayoutPageParseCache pageFile, pageStamp, firstParsedElem, parsedCount
END SUB

SUB LoadSelectedLayoutPageControls()
    DIM pageFile AS STRING
    DIM winIdx AS INTEGER

    pageFile = LayoutSelectedPageFile()
    IF pageFile = "" THEN EXIT SUB

    RemoveLoadedLayoutPageControls
    AppendLayoutPageFileControls pageFile
    ClearScriptPreviewBindCache
    FreeScriptPreviewCache

    winIdx = activeLayoutWindow
    IF winIdx >= LBOUND(layoutWindows) AND winIdx <= UBOUND(layoutWindows) THEN
        IF layoutWindows(winIdx).used <> 0 THEN
            IF UCASE$(NormalizePath(RTRIM$(layoutWindows(winIdx).appPath))) = UCASE$(NormalizePath(uiLayoutAppPath)) THEN
                FreeLayoutWindowElementCaches winIdx
                FreeLayoutWindowStaticCache winIdx
                FreeLayoutWindowDrawCache winIdx
                MarkLayoutWindowDirty winIdx
            END IF
        END IF
    END IF
END SUB



SUB OpenLayoutAppWindowCore(BYVAL appPath AS STRING, BYVAL activeStateAlreadySaved AS INTEGER)
    DIM i AS INTEGER
    DIM newLayoutSlot AS INTEGER
    DIM singleInstVal AS STRING
    DIM si AS INTEGER
    DIM siWin AS INTEGER
    DIM busyStarted AS INTEGER

    busyStarted = 0
    appPath = NormalizePath(appPath)
    IF appPath = "" THEN EXIT SUB
    IF DIR(LayoutFilePath(appPath)) = "" THEN EXIT SUB

    IF bdbgEnabled <> 0 THEN BDbgWindowEvent "OPEN_REQUEST path=" + appPath, 0

    singleInstVal = UCASE$(TRIM$(AppCfgValue(appPath, "single_instance", "0")))

    IF singleInstVal = "1" OR singleInstVal = "YES" OR singleInstVal = "TRUE" THEN
        siWin = 0
        FOR si = LBOUND(layoutWindows) TO UBOUND(layoutWindows)
            IF layoutWindows(si).used <> 0 THEN
                IF UCASE$(NormalizePath(RTRIM$(layoutWindows(si).appPath))) = UCASE$(NormalizePath(appPath)) THEN
                    siWin = si
                    EXIT FOR
                END IF
            END IF
        NEXT

        IF siWin <> 0 THEN
            IF bdbgEnabled <> 0 THEN BDbgWindowEvent "OPEN_SINGLE_INSTANCE_ACTIVATE path=" + appPath, siWin
            ActivateLayoutWindow siWin
            ApplyLayoutWindowDialogFocus siWin
            EXIT SUB
        END IF
    END IF

    IF activeStateAlreadySaved = 0 THEN
        IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
            IF layoutWindows(activeLayoutWindow).used <> 0 THEN
                SyncLayoutWindowFromGlobals activeLayoutWindow
            END IF
        END IF
    END IF

    uiSelectedTab = 1
    uiPressedIndex = 0
    uiFocusIndex = 0
    uiCaretPos = 0
    uiScrollY = 0
    uiScrollX = 0
    uiResizable = -1
    uiNoScrollbars = 0
    uiWindowActive = -1
    uiTitle = "Application"

    SetCursorBusy -1
    busyStarted = -1
    IF bdbgEnabled <> 0 THEN BDbgWindowEvent "OPEN_BEFORE_LOAD path=" + appPath, 0
    LoadAppLayout appPath
    IF bdbgEnabled <> 0 THEN BDbgWindowEvent "OPEN_AFTER_LOAD path=" + appPath + " uiCount=" + BDbgNum(uiCount), 0
    IF uiLoadedLayoutHasPageFiles <> 0 THEN
        IF bdbgEnabled <> 0 THEN BDbgWindowEvent "OPEN_BEFORE_PAGE_REFRESH path=" + appPath, 0
        RefreshLayoutPageControls
        IF bdbgEnabled <> 0 THEN BDbgWindowEvent "OPEN_AFTER_PAGE_REFRESH path=" + appPath + " uiCount=" + BDbgNum(uiCount), 0
    END IF
    IF uiTitle = "" THEN uiTitle = "Application"
    ClampLayoutWindowToWorkArea -1

    newLayoutSlot = 0
    FOR i = LBOUND(layoutWindows) TO UBOUND(layoutWindows)
        IF layoutWindows(i).used = 0 THEN
            newLayoutSlot = i
            EXIT FOR
        END IF
    NEXT

    IF newLayoutSlot = 0 THEN
        IF bdbgEnabled <> 0 THEN BDbgWindowEvent "OPEN_NO_FREE_SLOT path=" + appPath, 0
        IF busyStarted <> 0 THEN SetCursorBusy 0
        EXIT SUB
    END IF

    FOR i = LBOUND(layoutWindows) TO UBOUND(layoutWindows)
        IF layoutWindows(i).used <> 0 THEN layoutWindows(i).active = 0
    NEXT

    activeLayoutWindow = newLayoutSlot
    IF bdbgEnabled <> 0 THEN BDbgWindowEvent "OPEN_BEFORE_INIT_SLOT path=" + appPath, activeLayoutWindow
    InitLayoutWindowSlot activeLayoutWindow, appPath, uiTitle
    IF bdbgEnabled <> 0 THEN BDbgWindowEvent "OPEN_AFTER_INIT_SLOT path=" + appPath, activeLayoutWindow
    MoveLayoutWindowToFront activeLayoutWindow
    layoutWindows(activeLayoutWindow).active = -1
    FreeInactiveLayoutWindowCaches activeLayoutWindow
    IF bdbgEnabled <> 0 THEN BDbgWindowEvent "OPEN_AFTER_ZORDER path=" + appPath, activeLayoutWindow

    layoutWindowCount = 0
    FOR i = LBOUND(layoutWindows) TO UBOUND(layoutWindows)
        IF layoutWindows(i).used <> 0 THEN layoutWindowCount = layoutWindowCount + 1
    NEXT

    SyncGlobalsFromLayoutWindow activeLayoutWindow
    ApplyLayoutWindowDialogFocus activeLayoutWindow
    IF bdbgEnabled <> 0 THEN BDbgWindowEvent "OPEN_BEFORE_RUNTIME_INIT path=" + appPath, activeLayoutWindow
    AppRuntime_InitLoadedEvents activeLayoutWindow, LayoutFilePath(appPath)
    IF bdbgEnabled <> 0 THEN BDbgWindowEvent "OPEN_AFTER_RUNTIME_INIT path=" + appPath, activeLayoutWindow
    IF busyStarted <> 0 THEN SetCursorBusy 0
    IF bdbgEnabled <> 0 THEN BDbgWindowEvent "OPEN_DONE path=" + appPath, activeLayoutWindow
END SUB

SUB OpenLayoutAppWindow(BYVAL appPath AS STRING)
    OpenLayoutAppWindowCore appPath, 0
END SUB

SUB OpenLayoutAppWindowFromSavedState(BYVAL appPath AS STRING)
    ' Use this only when the caller already stored the active window state.
    ' It avoids a second deep window copy before opening a dialog or helper window.
    OpenLayoutAppWindowCore appPath, -1
END SUB



' ---------------------------
' Pipe-list parsing used by menu editors and list-backed tools
' ---------------------------

FUNCTION PipeEncodeValue(BYVAL s AS STRING) AS STRING
    DIM i AS INTEGER
    DIM ch AS STRING
    DIM outText AS STRING

    outText = ""
    FOR i = 1 TO LEN(s)
        ch = MID$(s, i, 1)
        IF ch = "|" THEN
            outText = outText + CHR$(2)
        ELSEIF ch = CHR$(1) THEN
            outText = outText + " "
        ELSE
            outText = outText + ch
        END IF
    NEXT

    RETURN outText
END FUNCTION

FUNCTION PipeDecodeValue(BYVAL s AS STRING) AS STRING
    DIM i AS INTEGER
    DIM ch AS STRING
    DIM outText AS STRING

    outText = ""
    FOR i = 1 TO LEN(s)
        ch = MID$(s, i, 1)
        IF ch = CHR$(2) THEN
            outText = outText + "|"
        ELSE
            outText = outText + ch
        END IF
    NEXT

    RETURN outText
END FUNCTION

FUNCTION PipePart(BYVAL s AS STRING, BYVAL partNum AS INTEGER) AS STRING
    DIM curPart AS INTEGER
    DIM scanPos AS INTEGER
    DIM startPos AS INTEGER

    IF partNum < 1 THEN RETURN ""

    curPart = 1
    startPos = 1

    FOR scanPos = 1 TO LEN(s)
        IF MID$(s, scanPos, 1) = "|" THEN
            IF curPart = partNum THEN RETURN MID$(s, startPos, scanPos - startPos)
            curPart = curPart + 1
            startPos = scanPos + 1
        END IF
    NEXT

    IF curPart = partNum THEN RETURN MID$(s, startPos)
    RETURN ""
END FUNCTION

FUNCTION PipeRawIsMenu(BYVAL rawLine AS STRING) AS INTEGER
    DIM firstPart AS STRING

    firstPart = RTRIM$(LTRIM$(PipePart(rawLine, 1)))
    IF LEN(firstPart) > 0 THEN
        IF RIGHT$(firstPart, 1) = ">" THEN RETURN -1
    END IF

    RETURN 0
END FUNCTION

FUNCTION PipeMenuNameFromRaw(BYVAL rawLine AS STRING) AS STRING
    DIM firstPart AS STRING

    firstPart = RTRIM$(LTRIM$(PipePart(rawLine, 1)))
    IF LEN(firstPart) > 0 THEN
        IF RIGHT$(firstPart, 1) = ">" THEN firstPart = LEFT$(firstPart, LEN(firstPart) - 1)
    END IF

    RETURN firstPart
END FUNCTION

FUNCTION PipeLineDisplayFromRaw(BYVAL rawLine AS STRING) AS STRING
    DIM workLine AS STRING
    DIM leadText AS STRING
    DIM firstPart AS STRING
    DIM i AS INTEGER

    rawLine = RTRIM$(rawLine)
    workLine = LTRIM$(rawLine)
    IF workLine = "" THEN RETURN ""

    IF workLine = "-" THEN RETURN "-"

    leadText = ""
    FOR i = 1 TO LEN(rawLine)
        IF MID$(rawLine, i, 1) <> " " AND MID$(rawLine, i, 1) <> CHR$(9) THEN EXIT FOR
        leadText = leadText + MID$(rawLine, i, 1)
    NEXT

    firstPart = RTRIM$(LTRIM$(PipePart(workLine, 1)))
    IF firstPart = "" THEN RETURN ""
    IF RIGHT$(firstPart, 1) = ">" THEN firstPart = LEFT$(firstPart, LEN(firstPart) - 1) + " >"

    RETURN leadText + firstPart
END FUNCTION


FUNCTION PipeListSourceAppendRawWithId(BYVAL sourceText AS STRING, BYVAL rawLine AS STRING, _
    BYVAL itemId AS INTEGER, BYREF added AS INTEGER) AS STRING
    DIM dispText AS STRING
    DIM itemText AS STRING

    added = 0
    rawLine = RTRIM$(rawLine)
    dispText = PipeLineDisplayFromRaw(rawLine)
    IF dispText = "" THEN RETURN sourceText

    IF itemId < 1 THEN itemId = 1
    itemText = dispText + CHR$(1) + PipeEncodeValue("P:" + LTRIM$(STR$(itemId)) + CHR$(3) + rawLine)
    IF sourceText <> "" THEN sourceText = sourceText + "|"
    sourceText = sourceText + itemText
    added = -1

    RETURN sourceText
END FUNCTION

FUNCTION PipeListRawFromItemSpec(BYVAL itemSpec AS STRING) AS STRING
    DIM sepPos AS INTEGER
    DIM decodedText AS STRING
    DIM idSep AS INTEGER

    sepPos = INSTR(itemSpec, CHR$(1))
    IF sepPos > 0 THEN
        decodedText = PipeDecodeValue(MID$(itemSpec, sepPos + 1))
        IF LEFT$(decodedText, 2) = "P:" THEN
            idSep = INSTR(decodedText, CHR$(3))
            IF idSep > 0 THEN RETURN MID$(decodedText, idSep + 1)
        END IF
        RETURN decodedText
    END IF

    RETURN PipeDecodeValue(itemSpec)
END FUNCTION

FUNCTION PipeListSourceAddRaw(BYVAL sourceText AS STRING, BYVAL rawLine AS STRING) AS STRING
    DIM sourceWork AS STRING
    DIM itemSpec AS STRING
    DIM sepPos AS INTEGER
    DIM itemId AS INTEGER
    DIM added AS INTEGER

    itemId = 1
    sourceWork = sourceText
    DO WHILE sourceWork <> ""
        sepPos = INSTR(sourceWork, "|")
        IF sepPos > 0 THEN
            itemSpec = LEFT$(sourceWork, sepPos - 1)
            sourceWork = MID$(sourceWork, sepPos + 1)
        ELSE
            itemSpec = sourceWork
            sourceWork = ""
        END IF
        IF itemSpec <> "" THEN itemId = itemId + 1
    LOOP

    RETURN PipeListSourceAppendRawWithId(sourceText, rawLine, itemId, added)
END FUNCTION

FUNCTION PipeListSourceItemAt(BYVAL sourceText AS STRING, BYVAL itemIdx AS INTEGER) AS STRING
    DIM curIdx AS INTEGER
    DIM sepPos AS INTEGER
    DIM itemSpec AS STRING

    IF itemIdx < 1 THEN RETURN ""

    curIdx = 0
    DO WHILE sourceText <> ""
        sepPos = INSTR(sourceText, "|")
        IF sepPos > 0 THEN
            itemSpec = LEFT$(sourceText, sepPos - 1)
            sourceText = MID$(sourceText, sepPos + 1)
        ELSE
            itemSpec = sourceText
            sourceText = ""
        END IF

        IF itemSpec <> "" THEN
            curIdx = curIdx + 1
            IF curIdx = itemIdx THEN RETURN itemSpec
        END IF
    LOOP

    RETURN ""
END FUNCTION

FUNCTION PipeListCountSource(BYVAL sourceText AS STRING) AS INTEGER
    DIM cnt AS INTEGER
    DIM sepPos AS INTEGER
    DIM itemSpec AS STRING

    cnt = 0
    DO WHILE sourceText <> ""
        sepPos = INSTR(sourceText, "|")
        IF sepPos > 0 THEN
            itemSpec = LEFT$(sourceText, sepPos - 1)
            sourceText = MID$(sourceText, sepPos + 1)
        ELSE
            itemSpec = sourceText
            sourceText = ""
        END IF

        IF itemSpec <> "" THEN cnt = cnt + 1
    LOOP

    RETURN cnt
END FUNCTION

FUNCTION PipeListRawAt(BYVAL sourceText AS STRING, BYVAL itemIdx AS INTEGER) AS STRING
    DIM itemSpec AS STRING

    itemSpec = PipeListSourceItemAt(sourceText, itemIdx)
    RETURN PipeListRawFromItemSpec(itemSpec)
END FUNCTION


FUNCTION PipeListValueAt(BYVAL sourceText AS STRING, BYVAL itemIdx AS INTEGER) AS STRING
    DIM itemSpec AS STRING
    DIM sepPos AS INTEGER

    itemSpec = PipeListSourceItemAt(sourceText, itemIdx)
    sepPos = INSTR(itemSpec, CHR$(1))
    IF sepPos > 0 THEN RETURN MID$(itemSpec, sepPos + 1)

    RETURN itemSpec
END FUNCTION

FUNCTION PipeListSourceFromRawText(BYVAL rawText AS STRING) AS STRING
    DIM outText AS STRING
    DIM scanPos AS INTEGER
    DIM lineEnd AS INTEGER
    DIM nextPos AS INTEGER
    DIM crPos AS INTEGER
    DIM lfPos AS INTEGER
    DIM lineText AS STRING
    DIM itemId AS INTEGER
    DIM added AS INTEGER

    outText = ""
    scanPos = 1
    itemId = 0

    DO WHILE scanPos <= LEN(rawText)
        crPos = INSTR(scanPos, rawText, CHR$(13))
        lfPos = INSTR(scanPos, rawText, CHR$(10))

        IF crPos = 0 AND lfPos = 0 THEN
            lineEnd = LEN(rawText) + 1
            nextPos = LEN(rawText) + 1
        ELSEIF crPos <> 0 AND (lfPos = 0 OR crPos < lfPos) THEN
            lineEnd = crPos
            nextPos = crPos + 1
            IF nextPos <= LEN(rawText) THEN
                IF MID$(rawText, nextPos, 1) = CHR$(10) THEN nextPos = nextPos + 1
            END IF
        ELSE
            lineEnd = lfPos
            nextPos = lfPos + 1
        END IF

        lineText = MID$(rawText, scanPos, lineEnd - scanPos)
        outText = PipeListSourceAppendRawWithId(outText, lineText, itemId + 1, added)
        IF added <> 0 THEN itemId = itemId + 1
        scanPos = nextPos
    LOOP

    RETURN outText
END FUNCTION

FUNCTION PipeListRawTextFromSource(BYVAL sourceText AS STRING) AS STRING
    DIM outText AS STRING
    DIM sourceWork AS STRING
    DIM itemSpec AS STRING
    DIM rawLine AS STRING
    DIM sepPos AS INTEGER

    outText = ""
    sourceWork = sourceText

    DO WHILE sourceWork <> ""
        sepPos = INSTR(sourceWork, "|")
        IF sepPos > 0 THEN
            itemSpec = LEFT$(sourceWork, sepPos - 1)
            sourceWork = MID$(sourceWork, sepPos + 1)
        ELSE
            itemSpec = sourceWork
            sourceWork = ""
        END IF

        IF itemSpec <> "" THEN
            rawLine = PipeListRawFromItemSpec(itemSpec)
            IF outText <> "" THEN outText = outText + CHR$(13) + CHR$(10)
            outText = outText + rawLine
        END IF
    LOOP

    IF outText <> "" THEN outText = outText + CHR$(13) + CHR$(10)
    RETURN outText
END FUNCTION

FUNCTION PipeListRemoveAt(BYVAL sourceText AS STRING, BYVAL removeIdx AS INTEGER) AS STRING
    DIM outText AS STRING
    DIM sourceWork AS STRING
    DIM itemSpec AS STRING
    DIM rawLine AS STRING
    DIM sepPos AS INTEGER
    DIM curIdx AS INTEGER
    DIM itemId AS INTEGER
    DIM added AS INTEGER

    outText = ""
    sourceWork = sourceText
    curIdx = 0
    itemId = 0

    DO WHILE sourceWork <> ""
        sepPos = INSTR(sourceWork, "|")
        IF sepPos > 0 THEN
            itemSpec = LEFT$(sourceWork, sepPos - 1)
            sourceWork = MID$(sourceWork, sepPos + 1)
        ELSE
            itemSpec = sourceWork
            sourceWork = ""
        END IF

        IF itemSpec <> "" THEN
            curIdx = curIdx + 1
            IF curIdx <> removeIdx THEN
                rawLine = PipeListRawFromItemSpec(itemSpec)
                outText = PipeListSourceAppendRawWithId(outText, rawLine, itemId + 1, added)
                IF added <> 0 THEN itemId = itemId + 1
            END IF
        END IF
    LOOP

    RETURN outText
END FUNCTION

FUNCTION PipeListMoveAt(BYVAL sourceText AS STRING, BYVAL moveIdx AS INTEGER, BYVAL moveDir AS STRING) AS STRING
    DIM rawItems(1 TO 256) AS STRING
    DIM cnt AS INTEGER
    DIM i AS INTEGER
    DIM swapText AS STRING
    DIM outText AS STRING
    DIM sourceWork AS STRING
    DIM itemSpec AS STRING
    DIM sepPos AS INTEGER
    DIM itemId AS INTEGER
    DIM added AS INTEGER

    cnt = PipeListCountSource(sourceText)
    IF cnt < 1 THEN RETURN sourceText
    IF cnt > 256 THEN cnt = 256
    IF moveIdx < 1 OR moveIdx > cnt THEN RETURN sourceText

    sourceWork = sourceText
    i = 0
    DO WHILE sourceWork <> "" AND i < cnt
        sepPos = INSTR(sourceWork, "|")
        IF sepPos > 0 THEN
            itemSpec = LEFT$(sourceWork, sepPos - 1)
            sourceWork = MID$(sourceWork, sepPos + 1)
        ELSE
            itemSpec = sourceWork
            sourceWork = ""
        END IF

        IF itemSpec <> "" THEN
            i = i + 1
            rawItems(i) = PipeListRawFromItemSpec(itemSpec)
        END IF
    LOOP

    moveDir = UCASE$(TRIM$(moveDir))
    IF moveDir = "UP" THEN
        IF moveIdx <= 1 THEN RETURN sourceText
        swapText = rawItems(moveIdx - 1)
        rawItems(moveIdx - 1) = rawItems(moveIdx)
        rawItems(moveIdx) = swapText
    ELSEIF moveDir = "DOWN" THEN
        IF moveIdx >= cnt THEN RETURN sourceText
        swapText = rawItems(moveIdx + 1)
        rawItems(moveIdx + 1) = rawItems(moveIdx)
        rawItems(moveIdx) = swapText
    ELSE
        RETURN sourceText
    END IF

    outText = ""
    itemId = 0
    FOR i = 1 TO cnt
        outText = PipeListSourceAppendRawWithId(outText, rawItems(i), itemId + 1, added)
        IF added <> 0 THEN itemId = itemId + 1
    NEXT

    RETURN outText
END FUNCTION

FUNCTION PipeListSetAt(BYVAL sourceText AS STRING, BYVAL setIdx AS INTEGER, BYVAL rawLine AS STRING) AS STRING
    DIM outText AS STRING
    DIM cnt AS INTEGER
    DIM sourceWork AS STRING
    DIM itemSpec AS STRING
    DIM sourceRawLine AS STRING
    DIM sepPos AS INTEGER
    DIM curIdx AS INTEGER
    DIM itemId AS INTEGER
    DIM added AS INTEGER

    outText = ""
    cnt = PipeListCountSource(sourceText)

    IF setIdx < 1 OR setIdx > cnt THEN RETURN sourceText

    sourceWork = sourceText
    curIdx = 0
    itemId = 0

    DO WHILE sourceWork <> ""
        sepPos = INSTR(sourceWork, "|")
        IF sepPos > 0 THEN
            itemSpec = LEFT$(sourceWork, sepPos - 1)
            sourceWork = MID$(sourceWork, sepPos + 1)
        ELSE
            itemSpec = sourceWork
            sourceWork = ""
        END IF

        IF itemSpec <> "" THEN
            curIdx = curIdx + 1
            IF curIdx = setIdx THEN
                outText = PipeListSourceAppendRawWithId(outText, rawLine, itemId + 1, added)
            ELSE
                sourceRawLine = PipeListRawFromItemSpec(itemSpec)
                outText = PipeListSourceAppendRawWithId(outText, sourceRawLine, itemId + 1, added)
            END IF
            IF added <> 0 THEN itemId = itemId + 1
        END IF
    LOOP

    RETURN outText
END FUNCTION

FUNCTION PipeRawLevel(BYVAL rawLine AS STRING) AS INTEGER
    DIM workLine AS STRING
    DIM level AS INTEGER

    workLine = rawLine
    level = 0

    DO WHILE LEN(workLine) > 0 AND (LEFT$(workLine, 1) = " " OR LEFT$(workLine, 1) = CHR$(9))
        IF LEFT$(workLine, 1) = CHR$(9) THEN
            level = level + 1
            workLine = MID$(workLine, 2)
        ELSEIF LEN(workLine) >= 2 AND LEFT$(workLine, 2) = "  " THEN
            level = level + 1
            workLine = MID$(workLine, 3)
        ELSE
            workLine = MID$(workLine, 2)
        END IF
    LOOP

    RETURN level
END FUNCTION

FUNCTION PipeParentLevel(BYVAL parentText AS STRING) AS INTEGER
    DIM i AS INTEGER
    DIM level AS INTEGER

    parentText = TRIM$(parentText)
    IF parentText = "" OR UCASE$(parentText) = "(ROOT)" THEN RETURN 0

    level = 1
    FOR i = 1 TO LEN(parentText)
        IF MID$(parentText, i, 1) = CHR$(92) THEN level = level + 1
    NEXT

    RETURN level
END FUNCTION

FUNCTION PipePrefixForParent(BYVAL parentText AS STRING) AS STRING
    DIM level AS INTEGER

    level = PipeParentLevel(parentText)
    IF level <= 0 THEN RETURN ""

    RETURN STRING$(level * 2, " ")
END FUNCTION

FUNCTION PipeListMenuPathAt(BYVAL sourceText AS STRING, BYVAL itemIdx AS INTEGER) AS STRING
    DIM j AS INTEGER
    DIM level AS INTEGER
    DIM rawLine AS STRING
    DIM menuName AS STRING
    DIM stackPath(0 TO 8) AS STRING
    DIM sourceWork AS STRING
    DIM itemSpec AS STRING
    DIM sepPos AS INTEGER
    DIM curIdx AS INTEGER

    IF itemIdx < 1 THEN RETURN ""

    FOR j = 0 TO 8
        stackPath(j) = ""
    NEXT

    sourceWork = sourceText
    curIdx = 0

    DO WHILE sourceWork <> "" AND curIdx < itemIdx
        sepPos = INSTR(sourceWork, "|")
        IF sepPos > 0 THEN
            itemSpec = LEFT$(sourceWork, sepPos - 1)
            sourceWork = MID$(sourceWork, sepPos + 1)
        ELSE
            itemSpec = sourceWork
            sourceWork = ""
        END IF

        IF itemSpec <> "" THEN
            curIdx = curIdx + 1
            rawLine = PipeListRawFromItemSpec(itemSpec)
            IF PipeRawIsMenu(rawLine) <> 0 THEN
                level = PipeRawLevel(rawLine)
                IF level < 0 THEN level = 0
                IF level > 8 THEN level = 8

                menuName = PipeMenuNameFromRaw(rawLine)
                IF level = 0 OR stackPath(level - 1) = "" THEN
                    stackPath(level) = menuName
                ELSE
                    stackPath(level) = stackPath(level - 1) + CHR$(92) + menuName
                END IF

                FOR j = level + 1 TO 8
                    stackPath(j) = ""
                NEXT

                IF curIdx = itemIdx THEN RETURN stackPath(level)
            END IF
        END IF
    LOOP

    RETURN ""
END FUNCTION

FUNCTION PipeListSetAtForParent(BYVAL sourceText AS STRING, BYVAL setIdx AS INTEGER, _
    BYVAL rawLine AS STRING, BYVAL parentText AS STRING) AS STRING
    DIM rawItems(1 TO 256) AS STRING
    DIM stackPath(0 TO 8) AS STRING
    DIM cnt AS INTEGER
    DIM sourceCnt AS INTEGER
    DIM i AS INTEGER
    DIM j AS INTEGER
    DIM outText AS STRING
    DIM insertPos AS INTEGER
    DIM parentLevel AS INTEGER
    DIM rawLevel AS INTEGER
    DIM level AS INTEGER
    DIM menuName AS STRING
    DIM menuPath AS STRING
    DIM sourceWork AS STRING
    DIM itemSpec AS STRING
    DIM sepPos AS INTEGER
    DIM sourceIdx AS INTEGER
    DIM itemId AS INTEGER
    DIM added AS INTEGER

    parentText = TRIM$(parentText)
    IF parentText = "" THEN parentText = "(root)"

    sourceCnt = PipeListCountSource(sourceText)
    IF sourceCnt > 256 THEN sourceCnt = 256

    cnt = 0
    sourceIdx = 0
    sourceWork = sourceText
    DO WHILE sourceWork <> "" AND sourceIdx < sourceCnt
        sepPos = INSTR(sourceWork, "|")
        IF sepPos > 0 THEN
            itemSpec = LEFT$(sourceWork, sepPos - 1)
            sourceWork = MID$(sourceWork, sepPos + 1)
        ELSE
            itemSpec = sourceWork
            sourceWork = ""
        END IF

        IF itemSpec <> "" THEN
            sourceIdx = sourceIdx + 1
            IF sourceIdx <> setIdx THEN
                cnt = cnt + 1
                rawItems(cnt) = PipeListRawFromItemSpec(itemSpec)
            END IF
        END IF
    LOOP

    insertPos = cnt + 1
    IF UCASE$(parentText) <> "(ROOT)" THEN
        FOR j = 0 TO 8
            stackPath(j) = ""
        NEXT

        FOR i = 1 TO cnt
            IF PipeRawIsMenu(rawItems(i)) <> 0 THEN
                rawLevel = PipeRawLevel(rawItems(i))
                level = rawLevel
                IF level < 0 THEN level = 0
                IF level > 8 THEN level = 8

                menuName = PipeMenuNameFromRaw(rawItems(i))
                IF level = 0 OR stackPath(level - 1) = "" THEN
                    stackPath(level) = menuName
                ELSE
                    stackPath(level) = stackPath(level - 1) + CHR$(92) + menuName
                END IF

                FOR j = level + 1 TO 8
                    stackPath(j) = ""
                NEXT

                menuPath = stackPath(level)
                IF UCASE$(menuPath) = UCASE$(parentText) THEN
                    parentLevel = rawLevel
                    insertPos = i + 1
                    DO WHILE insertPos <= cnt
                        level = PipeRawLevel(rawItems(insertPos))
                        IF level <= parentLevel THEN EXIT DO
                        insertPos = insertPos + 1
                    LOOP
                    EXIT FOR
                END IF
            END IF
        NEXT
    END IF

    outText = ""
    itemId = 0
    FOR i = 1 TO cnt + 1
        IF i = insertPos THEN
            outText = PipeListSourceAppendRawWithId(outText, rawLine, itemId + 1, added)
            IF added <> 0 THEN itemId = itemId + 1
        END IF
        IF i <= cnt THEN
            outText = PipeListSourceAppendRawWithId(outText, rawItems(i), itemId + 1, added)
            IF added <> 0 THEN itemId = itemId + 1
        END IF
    NEXT

    RETURN outText
END FUNCTION

FUNCTION PipeExternalModeFromAction(BYVAL actionText AS STRING) AS STRING
    DIM workText AS STRING
    DIM workUp AS STRING

    workText = TRIM$(actionText)
    workUp = UCASE$(workText)

    IF LEFT$(workUp, 4) = "DOS:" THEN
        workText = TRIM$(MID$(workText, 5))
        workUp = UCASE$(workText)
        IF LEFT$(workUp, 7) = "UNLOAD:" THEN RETURN "UNLOAD"
        IF LEFT$(workUp, 9) = "RESIDENT:" THEN RETURN "RESIDENT"
    END IF

    RETURN ""
END FUNCTION

FUNCTION PipeExternalCommandFromAction(BYVAL actionText AS STRING) AS STRING
    DIM workText AS STRING
    DIM workUp AS STRING

    workText = TRIM$(actionText)
    workUp = UCASE$(workText)

    IF LEFT$(workUp, 4) = "DOS:" THEN
        workText = TRIM$(MID$(workText, 5))
        workUp = UCASE$(workText)
        IF LEFT$(workUp, 7) = "UNLOAD:" THEN RETURN TRIM$(MID$(workText, 8))
        IF LEFT$(workUp, 9) = "RESIDENT:" THEN RETURN TRIM$(MID$(workText, 10))
    END IF

    RETURN workText
END FUNCTION

FUNCTION PipeValidateExternalProgram(BYVAL commandText AS STRING, BYVAL modeText AS STRING, BYREF statusText AS STRING) AS INTEGER
    DIM cmdText AS STRING
    DIM cmdUp AS STRING
    DIM modeValue AS STRING
    DIM programText AS STRING
    DIM extPos AS INTEGER
    DIM scanPos AS INTEGER
    DIM candidateText AS STRING

    cmdText = TRIM$(commandText)
    cmdUp = UCASE$(cmdText)
    modeValue = UCASE$(TRIM$(modeText))
    statusText = ""

    IF modeValue <> "UNLOAD" AND modeValue <> "RESIDENT" THEN
        statusText = "Launch type must be UNLOAD or RESIDENT"
        RETURN 0
    END IF

    IF cmdText = "" THEN
        statusText = "Program path is blank"
        RETURN 0
    END IF

    IF INSTR(cmdText, CHR$(34)) > 0 THEN
        statusText = "Quotes are not allowed in DOS paths"
        RETURN 0
    END IF

    IF INSTR(cmdText, CHR$(9)) > 0 THEN
        statusText = "Tabs are not allowed in DOS paths"
        RETURN 0
    END IF

    programText = DosCommandProgram(cmdText)
    IF programText = "" THEN
        statusText = "Program path is blank"
        RETURN 0
    END IF

    IF DosCommandPathHasSpaces(programText) <> 0 THEN
        statusText = "Spaces are not allowed in DOS paths"
        RETURN 0
    END IF

    IF DosCommandPathIs83(programText) = 0 THEN
        statusText = "Invalid 8.3 DOS path"
        RETURN 0
    END IF

    IF DosCommandTargetIsDirectory(programText) <> 0 THEN
        statusText = "Target is a directory, not a program"
        RETURN 0
    END IF

    IF DosCommandExtensionAllowed(programText) = 0 THEN
        statusText = "Unsupported DOS program extension"
        RETURN 0
    END IF

    IF DosCommandTargetExists(programText) = 0 THEN
        extPos = 0
        scanPos = INSTR(cmdUp, ".EXE")
        IF scanPos > 0 THEN extPos = scanPos
        scanPos = INSTR(cmdUp, ".COM")
        IF scanPos > 0 THEN
            IF extPos = 0 OR scanPos < extPos THEN extPos = scanPos
        END IF
        scanPos = INSTR(cmdUp, ".BAT")
        IF scanPos > 0 THEN
            IF extPos = 0 OR scanPos < extPos THEN extPos = scanPos
        END IF

        IF extPos > 0 THEN
            candidateText = LEFT$(cmdText, extPos + 3)
            IF INSTR(candidateText, " ") > 0 THEN
                statusText = "Spaces are not allowed in DOS paths"
                RETURN 0
            END IF
        END IF

        statusText = "Program file not found"
        RETURN 0
    END IF

    RETURN -1
END FUNCTION

FUNCTION PipeBuildRawLineFromValues(BYVAL entryType AS STRING, BYVAL entryName AS STRING, _
    BYVAL actionText AS STRING, BYVAL iconText AS STRING, BYVAL parentText AS STRING, _
    BYVAL launchModeText AS STRING, BYREF statusText AS STRING) AS STRING
    DIM typeValue AS STRING
    DIM nameValue AS STRING
    DIM actionValue AS STRING
    DIM iconValue AS STRING
    DIM parentValue AS STRING
    DIM modeValue AS STRING
    DIM prefixText AS STRING

    typeValue = UCASE$(TRIM$(entryType))
    nameValue = TRIM$(entryName)
    actionValue = TRIM$(actionText)
    iconValue = TRIM$(iconText)
    parentValue = TRIM$(parentText)
    prefixText = ""
    statusText = ""

    prefixText = PipePrefixForParent(parentValue)
    IF typeValue = "" THEN typeValue = "ITEM"

    SELECT CASE typeValue
    CASE "SEPARATOR", "DASH", "LINE", "-"
        RETURN prefixText + "-"
    CASE "MENU", "FOLDER", "HEADER"
        IF nameValue = "" THEN
            statusText = "Menu name is blank"
            RETURN ""
        ELSEIF iconValue = "" THEN
            statusText = "Icon file is blank"
            RETURN ""
        ELSEIF actionValue <> "" THEN
            RETURN prefixText + nameValue + ">|" + actionValue + "|" + iconValue
        ELSE
            RETURN prefixText + nameValue + ">|" + iconValue
        END IF
    CASE "EXTERNAL PROGRAM", "EXTERNAL", "DOS PROGRAM", "PROGRAM"
        modeValue = UCASE$(TRIM$(launchModeText))
        IF modeValue = "" THEN modeValue = PipeExternalModeFromAction(actionValue)
        IF modeValue = "" THEN modeValue = "UNLOAD"
        actionValue = PipeExternalCommandFromAction(actionValue)
        IF nameValue = "" THEN
            statusText = "Name is blank"
            RETURN ""
        ELSEIF actionValue = "" THEN
            statusText = "Program path is blank"
            RETURN ""
        ELSEIF PipeValidateExternalProgram(actionValue, modeValue, statusText) = 0 THEN
            ShowGuiMessageBox "INVALID EXTERNAL PROGRAM:", statusText
            RETURN ""
        ELSEIF iconValue = "" THEN
            statusText = "Icon file is blank"
            RETURN ""
        ELSE
            RETURN prefixText + nameValue + "|DOS:" + modeValue + ":" + actionValue + "|" + iconValue
        END IF
    CASE ELSE
        IF nameValue = "" THEN
            statusText = "Name is blank"
            RETURN ""
        ELSEIF actionValue = "" THEN
            statusText = "Launch file is blank"
            RETURN ""
        ELSEIF iconValue = "" THEN
            statusText = "Icon file is blank"
            RETURN ""
        ELSE
            RETURN prefixText + nameValue + "|" + actionValue + "|" + iconValue
        END IF
    END SELECT

    RETURN ""
END FUNCTION

FUNCTION PipeListParentMenusFromSource(BYVAL sourceText AS STRING) AS STRING
    DIM outText AS STRING
    DIM rawLine AS STRING
    DIM menuPath AS STRING
    DIM menuName AS STRING
    DIM stackPath(0 TO 8) AS STRING
    DIM sourceWork AS STRING
    DIM itemSpec AS STRING
    DIM sepPos AS INTEGER
    DIM level AS INTEGER
    DIM j AS INTEGER

    outText = "(root)"
    sourceWork = sourceText

    FOR j = 0 TO 8
        stackPath(j) = ""
    NEXT

    DO WHILE sourceWork <> ""
        sepPos = INSTR(sourceWork, "|")
        IF sepPos > 0 THEN
            itemSpec = LEFT$(sourceWork, sepPos - 1)
            sourceWork = MID$(sourceWork, sepPos + 1)
        ELSE
            itemSpec = sourceWork
            sourceWork = ""
        END IF

        IF itemSpec <> "" THEN
            rawLine = PipeListRawFromItemSpec(itemSpec)
            IF PipeRawIsMenu(rawLine) <> 0 THEN
                level = PipeRawLevel(rawLine)
                IF level < 0 THEN level = 0
                IF level > 8 THEN level = 8

                menuName = PipeMenuNameFromRaw(rawLine)
                IF level = 0 OR stackPath(level - 1) = "" THEN
                    stackPath(level) = menuName
                ELSE
                    stackPath(level) = stackPath(level - 1) + CHR$(92) + menuName
                END IF

                FOR j = level + 1 TO 8
                    stackPath(j) = ""
                NEXT

                menuPath = stackPath(level)
                IF menuPath <> "" THEN outText = outText + "|" + menuPath
            END IF
        END IF
    LOOP

    RETURN outText
END FUNCTION

FUNCTION PipeListParentForIndex(BYVAL sourceText AS STRING, BYVAL itemIdx AS INTEGER) AS STRING
    DIM j AS INTEGER
    DIM level AS INTEGER
    DIM itemLevel AS INTEGER
    DIM rawLine AS STRING
    DIM menuName AS STRING
    DIM stackPath(0 TO 8) AS STRING
    DIM sourceWork AS STRING
    DIM itemSpec AS STRING
    DIM sepPos AS INTEGER
    DIM curIdx AS INTEGER
    DIM targetFound AS INTEGER

    IF itemIdx < 1 THEN RETURN "(root)"

    FOR j = 0 TO 8
        stackPath(j) = ""
    NEXT

    sourceWork = sourceText
    curIdx = 0
    itemLevel = 0
    targetFound = 0

    DO WHILE sourceWork <> "" AND targetFound = 0
        sepPos = INSTR(sourceWork, "|")
        IF sepPos > 0 THEN
            itemSpec = LEFT$(sourceWork, sepPos - 1)
            sourceWork = MID$(sourceWork, sepPos + 1)
        ELSE
            itemSpec = sourceWork
            sourceWork = ""
        END IF

        IF itemSpec <> "" THEN
            curIdx = curIdx + 1
            rawLine = PipeListRawFromItemSpec(itemSpec)

            IF curIdx = itemIdx THEN
                itemLevel = PipeRawLevel(rawLine)
                IF itemLevel < 0 THEN itemLevel = 0
                IF itemLevel > 8 THEN itemLevel = 8
                targetFound = -1
            ELSEIF curIdx < itemIdx THEN
                IF PipeRawIsMenu(rawLine) <> 0 THEN
                    level = PipeRawLevel(rawLine)
                    IF level < 0 THEN level = 0
                    IF level > 8 THEN level = 8

                    menuName = PipeMenuNameFromRaw(rawLine)
                    IF level = 0 OR stackPath(level - 1) = "" THEN
                        stackPath(level) = menuName
                    ELSE
                        stackPath(level) = stackPath(level - 1) + CHR$(92) + menuName
                    END IF

                    FOR j = level + 1 TO 8
                        stackPath(j) = ""
                    NEXT
                END IF
            END IF
        END IF
    LOOP

    IF itemLevel = 0 THEN RETURN "(root)"
    IF stackPath(itemLevel - 1) <> "" THEN RETURN stackPath(itemLevel - 1)

    RETURN "(root)"
END FUNCTION

FUNCTION PipeListSelectedIndexByName(BYVAL controlName AS STRING) AS INTEGER
    DIM listIdx AS INTEGER
    DIM selectedText AS STRING
    DIM i AS INTEGER

    listIdx = GetControlIndexByName(controlName)
    IF listIdx < 1 OR listIdx > uiCount THEN RETURN 0

    selectedText = RTRIM$(uiElems(listIdx).text)
    IF selectedText = "" THEN RETURN 0

    BuildComboItems listIdx
    FOR i = 1 TO tempComboItemCount
        IF UCASE$(RTRIM$(tempComboValues(i))) = UCASE$(selectedText) THEN RETURN i
    NEXT
    FOR i = 1 TO tempComboItemCount
        IF UCASE$(RTRIM$(tempComboItems(i))) = UCASE$(selectedText) THEN RETURN i
    NEXT

    RETURN 0
END FUNCTION


SUB SetControlTextByNameAny(BYVAL controlName AS STRING, BYVAL dataText AS STRING)
    DIM idx AS INTEGER

    idx = GetControlIndexByName(controlName)
    IF idx < 1 OR idx > uiCount THEN EXIT SUB

    uiElems(idx).text = dataText
    IF uiElems(idx).kindId = UI_KIND_TEXTBOX THEN
        Ed_SetTextGlue uiEdit(idx), dataText, uiElems(idx).text, uiCaretPos
        IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
            IF layoutWindows(activeLayoutWindow).used <> 0 THEN comboScrollTop(activeLayoutWindow, idx) = 0
        END IF
    END IF

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
            layoutUiElems(activeLayoutWindow, idx) = uiElems(idx)
            layoutUiEdit(activeLayoutWindow, idx) = uiEdit(idx)
            IF uiElems(idx).kindId = UI_KIND_LABEL THEN
                IF UCASE$(TRIM$(uiElems(idx).modeGroup)) = "TEXT_STATS" THEN
                    layoutTextStatsCacheValid(activeLayoutWindow, idx) = 0
                    layoutTextStatsCacheText(activeLayoutWindow, idx) = ""
                END IF
            END IF
            MarkLayoutDirtyElement activeLayoutWindow, idx
            MarkLayoutWindowVisualDirty activeLayoutWindow
        END IF
    END IF
END SUB

SUB ClearActiveTextSaveStatusForEdit(BYVAL sourceElemIdx AS INTEGER)
    DIM statusControlName AS STRING
    DIM statusIdx AS INTEGER

    IF activeLayoutWindow < LBOUND(layoutWindows) OR activeLayoutWindow > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(activeLayoutWindow).used = 0 THEN EXIT SUB

    statusControlName = TRIM$(layoutTextSaveStatusControl(activeLayoutWindow))
    IF statusControlName = "" THEN EXIT SUB

    statusIdx = GetControlIndexByName(statusControlName)
    IF statusIdx < 1 OR statusIdx > uiCount THEN EXIT SUB
    IF statusIdx = sourceElemIdx THEN EXIT SUB
    IF TRIM$(uiElems(statusIdx).text) = "" THEN EXIT SUB

    SetControlTextByNameAny statusControlName, ""
END SUB

SUB SetControlLockedByNameAny(BYVAL controlName AS STRING, BYVAL lockFlag AS INTEGER)
    DIM idx AS INTEGER

    idx = GetControlIndexByName(controlName)
    IF idx < 1 OR idx > uiCount THEN EXIT SUB

    IF lockFlag <> 0 THEN
        uiElems(idx).noEdit = -1
        uiElems(idx).state = -1
        IF uiFocusIndex = idx THEN uiFocusIndex = 0
    ELSE
        uiElems(idx).noEdit = 0
        uiElems(idx).state = 0
    END IF

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
            layoutUiElems(activeLayoutWindow, idx) = uiElems(idx)
            IF layoutWindows(activeLayoutWindow).focusIndex = idx AND lockFlag <> 0 THEN layoutWindows(activeLayoutWindow).focusIndex = 0
            MarkLayoutDirtyElement activeLayoutWindow, idx
            MarkLayoutWindowVisualDirty activeLayoutWindow
        END IF
    END IF
END SUB


SUB SetControlSourceItemsByName(BYVAL controlName AS STRING, BYVAL sourceText AS STRING, BYVAL selectedText AS STRING)
    DIM idx AS INTEGER

    idx = GetControlIndexByName(controlName)
    IF idx < 1 OR idx > uiCount THEN EXIT SUB

    uiElems(idx).sourceItems = sourceText
    uiElems(idx).text = selectedText

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
            layoutUiElems(activeLayoutWindow, idx) = uiElems(idx)
            MarkLayoutDirtyElement activeLayoutWindow, idx
            MarkLayoutWindowVisualDirty activeLayoutWindow
        END IF
    END IF
END SUB

' ---------------------------
' Config-backed file lists and per-program setting panels
' ---------------------------

FUNCTION ReadNthCfgValueInSection(BYVAL fileName AS STRING, BYVAL sectionName AS STRING, BYVAL keyName AS STRING, BYVAL nthItem AS INTEGER, BYVAL defaultValue AS STRING) AS STRING
    DIM f AS INTEGER
    DIM lineIn AS STRING
    DIM p AS INTEGER
    DIM k AS STRING
    DIM v AS STRING
    DIM activeSection AS STRING
    DIM targetSection AS STRING
    DIM hitCount AS INTEGER

    IF nthItem < 1 THEN nthItem = 1
    fileName = LayoutFilePath(fileName)
    targetSection = UCASE$(TRIM$(sectionName))
    activeSection = ""
    hitCount = 0

    f = FREEFILE
    IF OPEN(fileName FOR INPUT AS #f) <> 0 THEN RETURN defaultValue

    DO WHILE NOT EOF(f)
        LINE INPUT #f, lineIn
        lineIn = TRIM$(lineIn)

        IF lineIn = "" OR LEFT$(lineIn, 1) = "#" OR LEFT$(lineIn, 1) = ";" THEN
        ELSEIF LEFT$(lineIn, 1) = "[" AND RIGHT$(lineIn, 1) = "]" THEN
            activeSection = UCASE$(TRIM$(MID$(lineIn, 2, LEN(lineIn) - 2)))
        ELSE
            IF targetSection = "" OR activeSection = targetSection THEN
                p = INSTR(lineIn, "=")
                IF p > 0 THEN
                    k = UCASE$(TRIM$(LEFT$(lineIn, p - 1)))
                    v = StripOuterQuotes(TRIM$(MID$(lineIn, p + 1)))
                    IF k = UCASE$(keyName) THEN
                        hitCount = hitCount + 1
                        IF hitCount = nthItem THEN
                            CLOSE #f
                            RETURN v
                        END IF
                    END IF
                END IF
            END IF
        END IF
    LOOP

    CLOSE #f
    RETURN defaultValue
END FUNCTION

SUB LoadRepeatedCfgValuesInSection(BYVAL fileName AS STRING, BYVAL sectionName AS STRING, BYVAL keyName AS STRING, BYVAL maxItems AS INTEGER)
    DIM f AS INTEGER
    DIM lineIn AS STRING
    DIM p AS INTEGER
    DIM k AS STRING
    DIM v AS STRING
    DIM activeSection AS STRING
    DIM targetSection AS STRING
    DIM targetKey AS STRING

    fileCfgRepeatValueCount = 0
    IF maxItems < 1 THEN EXIT SUB
    IF maxItems > 256 THEN maxItems = 256

    fileName = LayoutFilePath(fileName)
    targetSection = UCASE$(TRIM$(sectionName))
    targetKey = UCASE$(TRIM$(keyName))
    activeSection = ""

    f = FREEFILE
    IF OPEN(fileName FOR INPUT AS #f) <> 0 THEN EXIT SUB

    DO WHILE NOT EOF(f)
        LINE INPUT #f, lineIn
        lineIn = TRIM$(lineIn)

        IF lineIn = "" OR LEFT$(lineIn, 1) = "#" OR LEFT$(lineIn, 1) = ";" THEN
        ELSEIF LEFT$(lineIn, 1) = "[" AND RIGHT$(lineIn, 1) = "]" THEN
            activeSection = UCASE$(TRIM$(MID$(lineIn, 2, LEN(lineIn) - 2)))
        ELSE
            IF targetSection = "" OR activeSection = targetSection THEN
                p = INSTR(lineIn, "=")
                IF p > 0 THEN
                    k = UCASE$(TRIM$(LEFT$(lineIn, p - 1)))
                    v = StripOuterQuotes(TRIM$(MID$(lineIn, p + 1)))
                    IF k = targetKey THEN
                        fileCfgRepeatValueCount = fileCfgRepeatValueCount + 1
                        fileCfgRepeatValues(fileCfgRepeatValueCount) = v
                        IF fileCfgRepeatValueCount >= maxItems THEN EXIT DO
                    END IF
                END IF
            END IF
        END IF
    LOOP

    CLOSE #f
END SUB

FUNCTION PipeSpecValue(BYVAL specText AS STRING, BYVAL keyName AS STRING, BYVAL defaultValue AS STRING) AS STRING
    DIM remaining AS STRING
    DIM tokenText AS STRING
    DIM p AS INTEGER
    DIM eqPos AS INTEGER
    DIM k AS STRING
    DIM v AS STRING

    remaining = specText
    keyName = UCASE$(TRIM$(keyName))

    DO WHILE remaining <> ""
        p = INSTR(remaining, "|")
        IF p > 0 THEN
            tokenText = LEFT$(remaining, p - 1)
            remaining = MID$(remaining, p + 1)
        ELSE
            tokenText = remaining
            remaining = ""
        END IF

        eqPos = INSTR(tokenText, "=")
        IF eqPos > 0 THEN
            k = UCASE$(TRIM$(LEFT$(tokenText, eqPos - 1)))
            v = StripOuterQuotes(TRIM$(MID$(tokenText, eqPos + 1)))
            IF k = keyName THEN RETURN v
        END IF
    LOOP

    RETURN defaultValue
END FUNCTION

FUNCTION FileBaseNameNoExt(BYVAL fileName AS STRING) AS STRING
    DIM n AS STRING
    DIM i AS INTEGER
    DIM dotPos AS INTEGER

    n = FileNameOnly(fileName)
    dotPos = 0
    FOR i = LEN(n) TO 1 STEP -1
        IF MID$(n, i, 1) = "." THEN
            dotPos = i
            EXIT FOR
        END IF
    NEXT

    IF dotPos > 1 THEN RETURN LEFT$(n, dotPos - 1)
    RETURN n
END FUNCTION

FUNCTION FileCfgMatchingConfig(BYVAL dirName AS STRING, BYVAL programName AS STRING) AS STRING
    DIM cfgName AS STRING
    DIM cfgPath AS STRING

    dirName = NormalizePath(TRIM$(dirName))
    programName = FileNameOnly(TRIM$(programName))
    IF programName = "" THEN RETURN ""

    cfgName = FileBaseNameNoExt(programName) + ".CFG"
    cfgPath = JoinPath(dirName, cfgName)
    IF DIR(cfgPath) <> "" THEN RETURN cfgName
    RETURN ""
END FUNCTION

FUNCTION FileCfgDisplayName(BYVAL dirName AS STRING, BYVAL programName AS STRING) AS STRING
    DIM cfgName AS STRING
    DIM cfgPath AS STRING
    DIM nameText AS STRING

    programName = FileNameOnly(TRIM$(programName))
    cfgName = FileCfgMatchingConfig(dirName, programName)
    IF cfgName <> "" THEN
        cfgPath = JoinPath(NormalizePath(TRIM$(dirName)), cfgName)
        nameText = TRIM$(ReadCfgValueNoCache(cfgPath, "NAME", ""))
        IF nameText <> "" THEN RETURN nameText
    END IF

    RETURN programName
END FUNCTION

FUNCTION FileCfgControlValue(BYVAL controlName AS STRING) AS STRING
    DIM idx AS INTEGER

    idx = GetControlIndexByName(controlName)
    IF idx < 1 OR idx > uiCount THEN RETURN ""

    SELECT CASE uiElems(idx).kindId
    CASE UI_KIND_COMBO
        RETURN ControlValueFromCombo(idx)
    CASE UI_KIND_LISTBOX
        RETURN ControlValueFromListControl(idx)
    CASE ELSE
        RETURN RTRIM$(uiElems(idx).text)
    END SELECT
END FUNCTION

FUNCTION FileCfgSelectedProgram(BYVAL listControlName AS STRING, BYVAL programControlName AS STRING) AS STRING
    DIM programName AS STRING

    programName = TRIM$(FileCfgControlValue(listControlName))
    IF LEFT$(UCASE$(programName), 2) = "F:" THEN programName = MID$(programName, 3)
    programName = FileNameOnly(programName)
    IF UCASE$(FileExtensionOf(programName)) = "CFG" THEN programName = FileBaseNameNoExt(programName) + ".EXE"

    IF programName = "" AND programControlName <> "" THEN
        programName = TRIM$(GetTextboxTextByName(programControlName))
        IF LEFT$(UCASE$(programName), 2) = "F:" THEN programName = MID$(programName, 3)
        programName = FileNameOnly(programName)
        IF UCASE$(FileExtensionOf(programName)) = "CFG" THEN programName = FileBaseNameNoExt(programName) + ".EXE"
    END IF

    RETURN programName
END FUNCTION

SUB FileCfgClearSettingControls(BYVAL settingPrefix AS STRING, BYVAL maxSettings AS INTEGER)
    DIM i AS INTEGER
    DIM n AS STRING

    IF maxSettings < 1 THEN maxSettings = 4

    FOR i = 1 TO maxSettings
        n = LTRIM$(STR$(i))
        SetControlTextByNameAny settingPrefix + n + "_LABEL", ""
        SetControlTextByNameAny settingPrefix + n + "_VALUE", ""
        SetControlTextByNameAny settingPrefix + n + "_RANGE", ""
        SetControlLockedByNameAny settingPrefix + n + "_VALUE", -1
    NEXT
END SUB

SUB FileCfgSetStatus(BYVAL statusControlName AS STRING, BYVAL statusText AS STRING)
    IF statusControlName <> "" THEN SetTextboxTextByName statusControlName, statusText
END SUB

SUB FileCfgBuildList(BYVAL sysFileName AS STRING, BYVAL sectionName AS STRING)
    DIM dirName AS STRING
    DIM maskText AS STRING
    DIM listControlName AS STRING
    DIM globalConfig AS STRING
    DIM programText AS STRING
    DIM selectedValue AS STRING
    DIM selectedDisplay AS STRING
    DIM pattern AS STRING
    DIM fname AS STRING
    DIM programs(1 TO 256) AS STRING
    DIM programCount AS INTEGER
    DIM i AS INTEGER
    DIM gapSize AS INTEGER
    DIM itemIdx AS INTEGER
    DIM moveIdx AS INTEGER
    DIM sortProgram AS STRING
    DIM sortKey AS STRING
    DIM compareKey AS STRING
    DIM itemSpec AS STRING
    DIM itemText AS STRING
    DIM firstDisplay AS STRING

    dirName = NormalizePath(TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "DIR", "")))
    maskText = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "MASK", "*.EXE"))
    listControlName = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "LIST_CONTROL", ""))
    globalConfig = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "GLOBAL_CONFIG", ""))

    IF dirName = "" OR listControlName = "" THEN EXIT SUB
    IF maskText = "" THEN maskText = "*.EXE"

    selectedValue = ""
    IF globalConfig <> "" THEN
        selectedValue = TRIM$(ReadCfgValue(globalConfig, "PROGRAM", ""))
        IF selectedValue = "" THEN selectedValue = TRIM$(ReadCfgValue(globalConfig, "SELECTED", ""))
    END IF
    IF LEFT$(UCASE$(selectedValue), 2) = "F:" THEN selectedValue = MID$(selectedValue, 3)
    selectedValue = FileNameOnly(selectedValue)
    IF UCASE$(FileExtensionOf(selectedValue)) = "CFG" THEN selectedValue = FileBaseNameNoExt(selectedValue) + ".EXE"

    pattern = dirName
    IF RIGHT$(pattern, 1) <> CHR$(92) THEN pattern = pattern + CHR$(92)
    pattern = pattern + maskText

    programCount = 0
    fname = DIR(pattern)
    DO WHILE fname <> "" AND programCount < 256
        IF fname <> "." AND fname <> ".." THEN
            programCount = programCount + 1
            programs(programCount) = fname
        END IF
        fname = DIR()
    LOOP

    gapSize = programCount \ 2
    DO WHILE gapSize > 0
        FOR itemIdx = 1 + gapSize TO programCount
            sortProgram = RTRIM$(programs(itemIdx))
            sortKey = UCASE$(sortProgram)
            moveIdx = itemIdx

            DO WHILE moveIdx - gapSize >= 1
                compareKey = UCASE$(RTRIM$(programs(moveIdx - gapSize)))
                IF compareKey <= sortKey THEN EXIT DO
                programs(moveIdx) = programs(moveIdx - gapSize)
                moveIdx = moveIdx - gapSize
            LOOP

            programs(moveIdx) = sortProgram
        NEXT
        gapSize = gapSize \ 2
    LOOP

    itemSpec = ""
    selectedDisplay = ""
    firstDisplay = ""
    FOR i = 1 TO programCount
        programText = RTRIM$(programs(i))
        itemText = FileCfgDisplayName(dirName, programText)
        IF i = 1 THEN firstDisplay = itemText
        IF itemSpec <> "" THEN itemSpec = itemSpec + "|"
        itemSpec = itemSpec + itemText + CHR$(1) + programText
        IF selectedValue <> "" THEN
            IF UCASE$(programText) = UCASE$(selectedValue) THEN selectedDisplay = itemText
        END IF
    NEXT

    IF selectedDisplay = "" AND programCount > 0 THEN
        IF selectedValue = "" THEN selectedDisplay = firstDisplay
    END IF

    SetControlSourceItemsByName listControlName, itemSpec, selectedDisplay
END SUB

SUB FileCfgPopulateSelected(BYVAL sysFileName AS STRING, BYVAL sectionName AS STRING)
    DIM dirName AS STRING
    DIM listControlName AS STRING
    DIM programControlName AS STRING
    DIM configControlName AS STRING
    DIM statusControlName AS STRING
    DIM settingPrefix AS STRING
    DIM maxSettings AS INTEGER
    DIM programName AS STRING
    DIM cfgName AS STRING
    DIM cfgPath AS STRING
    DIM uiLine AS STRING
    DIM labelText AS STRING
    DIM keyText AS STRING
    DIM minText AS STRING
    DIM maxText AS STRING
    DIM stepText AS STRING
    DIM rangeText AS STRING
    DIM valueText AS STRING
    DIM i AS INTEGER
    DIM n AS STRING

    dirName = NormalizePath(TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "DIR", "")))
    listControlName = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "LIST_CONTROL", ""))
    programControlName = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "PROGRAM_CONTROL", ""))
    configControlName = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "CONFIG_CONTROL", ""))
    statusControlName = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "STATUS", ""))
    settingPrefix = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "SETTING_PREFIX", ""))
    maxSettings = VAL(ReadCfgValueInSection(sysFileName, sectionName, "MAX_SETTINGS", "4"))
    IF maxSettings < 1 THEN maxSettings = 4

    programName = FileCfgSelectedProgram(listControlName, programControlName)
    cfgName = FileCfgMatchingConfig(dirName, programName)

    IF programControlName <> "" THEN SetControlTextByNameAny programControlName, programName
    IF configControlName <> "" THEN SetControlTextByNameAny configControlName, cfgName

    FileCfgClearSettingControls settingPrefix, maxSettings

    IF cfgName <> "" THEN
        cfgPath = JoinPath(dirName, cfgName)
        LoadRepeatedCfgValuesInSection cfgPath, "", "UI", maxSettings
        FOR i = 1 TO maxSettings
            uiLine = ""
            IF i <= fileCfgRepeatValueCount THEN uiLine = fileCfgRepeatValues(i)
            IF uiLine <> "" THEN
                n = LTRIM$(STR$(i))
                labelText = PipeSpecValue(uiLine, "LABEL", "")
                keyText = PipeSpecValue(uiLine, "KEY", "")
                minText = PipeSpecValue(uiLine, "MIN", "")
                maxText = PipeSpecValue(uiLine, "MAX", "")
                stepText = PipeSpecValue(uiLine, "STEP", "")

                rangeText = ""
                IF minText <> "" OR maxText <> "" THEN rangeText = minText + "-" + maxText
                IF stepText <> "" THEN
                    IF rangeText <> "" THEN rangeText = rangeText + " "
                    rangeText = rangeText + "step " + stepText
                END IF

                valueText = ""
                IF keyText <> "" THEN valueText = ReadCfgValue(cfgPath, keyText, "")

                SetControlTextByNameAny settingPrefix + n + "_LABEL", labelText
                SetControlTextByNameAny settingPrefix + n + "_VALUE", valueText
                SetControlTextByNameAny settingPrefix + n + "_RANGE", rangeText
                IF keyText <> "" THEN SetControlLockedByNameAny settingPrefix + n + "_VALUE", 0
            END IF
        NEXT
        FileCfgSetStatus statusControlName, "Loaded " + programName
    ELSE
        FileCfgSetStatus statusControlName, "Loaded " + programName
    END IF

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN SyncLayoutWindowFromGlobals activeLayoutWindow
    END IF
END SUB

SUB FileCfgInit(BYVAL sysFileName AS STRING, BYVAL sectionName AS STRING)
    FileCfgBuildList sysFileName, sectionName
    FileCfgPopulateSelected sysFileName, sectionName
    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN SaveBindingSnapshotFromGlobals activeLayoutWindow
    END IF
END SUB

SUB FileCfgSaveSelected(BYVAL sysFileName AS STRING, BYVAL sectionName AS STRING)
    DIM dirName AS STRING
    DIM listControlName AS STRING
    DIM programControlName AS STRING
    DIM configControlName AS STRING
    DIM statusControlName AS STRING
    DIM settingPrefix AS STRING
    DIM maxSettings AS INTEGER
    DIM globalConfig AS STRING
    DIM enabledControlName AS STRING
    DIM timeoutControlName AS STRING
    DIM programName AS STRING
    DIM cfgName AS STRING
    DIM cfgPath AS STRING
    DIM uiLine AS STRING
    DIM keyText AS STRING
    DIM valueText AS STRING
    DIM postSaveActionText AS STRING
    DIM postSaveActionKey AS STRING
    DIM postSaveActionIndex AS INTEGER
    DIM i AS INTEGER

    dirName = NormalizePath(TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "DIR", "")))
    listControlName = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "LIST_CONTROL", ""))
    programControlName = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "PROGRAM_CONTROL", ""))
    configControlName = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "CONFIG_CONTROL", ""))
    statusControlName = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "STATUS", ""))
    settingPrefix = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "SETTING_PREFIX", ""))
    maxSettings = VAL(ReadCfgValueInSection(sysFileName, sectionName, "MAX_SETTINGS", "4"))
    globalConfig = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "GLOBAL_CONFIG", ""))
    enabledControlName = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "ENABLED_CONTROL", ""))
    timeoutControlName = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "TIMEOUT_CONTROL", ""))
    IF maxSettings < 1 THEN maxSettings = 4

    programName = FileCfgSelectedProgram(listControlName, programControlName)
    cfgName = FileCfgMatchingConfig(dirName, programName)

    IF programControlName <> "" THEN SetControlTextByNameAny programControlName, programName
    IF configControlName <> "" THEN SetControlTextByNameAny configControlName, cfgName

    BeginCfgWriteBatch

    IF globalConfig <> "" THEN
        IF enabledControlName <> "" THEN SetCfgValueInSection globalConfig, "", "ENABLED", FileCfgControlValue(enabledControlName)
        IF timeoutControlName <> "" THEN SetCfgValueInSection globalConfig, "", "TIMEOUT", GetTextboxTextByName(timeoutControlName)
        SetCfgValueInSection globalConfig, "", "SAVER_DIR", dirName
        SetCfgValueInSection globalConfig, "", "PROGRAM", programName
        SetCfgValueInSection globalConfig, "", "CONFIG", cfgName
        SetCfgValueInSection globalConfig, "", "SELECTED", programName
    END IF

    IF cfgName <> "" THEN
        cfgPath = JoinPath(dirName, cfgName)
        LoadRepeatedCfgValuesInSection cfgPath, "", "UI", maxSettings
        FOR i = 1 TO maxSettings
            uiLine = ""
            IF i <= fileCfgRepeatValueCount THEN uiLine = fileCfgRepeatValues(i)
            IF uiLine <> "" THEN
                keyText = PipeSpecValue(uiLine, "KEY", "")
                IF keyText <> "" THEN
                    valueText = GetTextboxTextByName(settingPrefix + LTRIM$(STR$(i)) + "_VALUE")
                    SetCfgValueInSection cfgPath, "", keyText, valueText
                END IF
            END IF
        NEXT
    END IF

    FlushCfgWriteBatch

    FileCfgSetStatus statusControlName, "Saved " + programName

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
            SyncLayoutWindowFromGlobals activeLayoutWindow
            SaveBindingSnapshotFromGlobals activeLayoutWindow
        END IF
    END IF

    ' Optional app-owned post-save actions let a FILECFG workflow notify shell services once.
    postSaveActionIndex = 1
    DO WHILE postSaveActionIndex <= 16
        IF postSaveActionIndex = 1 THEN
            postSaveActionKey = "POST_SAVE_ACTION"
        ELSE
            postSaveActionKey = "POST_SAVE_ACTION" + LTRIM$(STR$(postSaveActionIndex))
        END IF

        postSaveActionText = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, postSaveActionKey, ""))
        IF postSaveActionText = "" THEN EXIT DO

        HostAppAction activeLayoutWindow, postSaveActionText
        postSaveActionIndex = postSaveActionIndex + 1
    LOOP
END SUB

SUB FileCfgCancel(BYVAL sysFileName AS STRING, BYVAL sectionName AS STRING)
    FileCfgInit sysFileName, sectionName
    FileCfgSetStatus TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "STATUS", "")), "Canceled"
    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN SyncLayoutWindowFromGlobals activeLayoutWindow
    END IF
END SUB

SUB FileCfgRunSelected(BYVAL sysFileName AS STRING, BYVAL sectionName AS STRING)
    DIM dirName AS STRING
    DIM listControlName AS STRING
    DIM programControlName AS STRING
    DIM statusControlName AS STRING
    DIM programName AS STRING
    DIM programPath AS STRING
    DIM runDir AS STRING
    DIM runFile AS STRING
    DIM oldDir AS STRING

    dirName = NormalizePath(TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "DIR", "")))
    listControlName = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "LIST_CONTROL", ""))
    programControlName = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "PROGRAM_CONTROL", ""))
    statusControlName = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "STATUS", ""))

    programName = FileCfgSelectedProgram(listControlName, programControlName)
    IF programName = "" THEN
        FileCfgSetStatus statusControlName, "No program selected"
        IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
            IF layoutWindows(activeLayoutWindow).used <> 0 THEN SyncLayoutWindowFromGlobals activeLayoutWindow
        END IF
        EXIT SUB
    END IF

    programPath = JoinPath(dirName, programName)
    IF DIR(programPath) = "" THEN
        FileCfgSetStatus statusControlName, "Missing " + programName
        IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
            IF layoutWindows(activeLayoutWindow).used <> 0 THEN SyncLayoutWindowFromGlobals activeLayoutWindow
        END IF
        ShowGuiMessageBox "FILE NOT FOUND:", programPath
        EXIT SUB
    END IF

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN SyncLayoutWindowFromGlobals activeLayoutWindow
    END IF

    startMenuOpen = 0
    launchCtxOpen = 0
    SoundStop

    SCREEN 0
    WIDTH 80, 25
    COLOR 7, 0
    CLS

    oldDir = CURDIR
    runDir = ParentPath(programPath)
    runFile = FileNameOnly(programPath)

    IF runDir <> "" AND DIR(runDir, &H10) <> "" THEN
        CHDIR runDir
        SHELL runFile
        CHDIR oldDir
    ELSE
        SHELL programPath
    END IF

    ResumeGuiAfterShell

    ResetScreensaverIdle
    FileCfgSetStatus statusControlName, "Test completed"
    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN SyncLayoutWindowFromGlobals activeLayoutWindow
    END IF
END SUB

SUB PipePopulateEntryFields(BYVAL listControlName AS STRING, BYVAL itemIdx AS INTEGER, _
    BYVAL typeControlName AS STRING, BYVAL nameControlName AS STRING, _
    BYVAL actionControlName AS STRING, BYVAL iconControlName AS STRING, _
    BYVAL parentControlName AS STRING, BYVAL launchTypeControlName AS STRING, _
    BYVAL statusControlName AS STRING)
    DIM listIdx AS INTEGER
    DIM sourceText AS STRING
    DIM rawLine AS STRING
    DIM trimLine AS STRING
    DIM partOne AS STRING
    DIM partTwo AS STRING
    DIM partThree AS STRING
    DIM itemName AS STRING
    DIM entryType AS STRING
    DIM launchTypeText AS STRING

    listIdx = GetControlIndexByName(listControlName)
    IF listIdx < 1 OR listIdx > uiCount THEN EXIT SUB

    sourceText = uiElems(listIdx).sourceItems
    rawLine = PipeListRawAt(sourceText, itemIdx)
    trimLine = RTRIM$(LTRIM$(rawLine))

    partOne = PipePart(rawLine, 1)
    partTwo = PipePart(rawLine, 2)
    partThree = PipePart(rawLine, 3)

    entryType = "Item"
    launchTypeText = ""
    itemName = RTRIM$(LTRIM$(partOne))

    IF PipeExternalModeFromAction(partTwo) <> "" THEN
        entryType = "External Program"
        launchTypeText = PipeExternalModeFromAction(partTwo)
        partTwo = PipeExternalCommandFromAction(partTwo)
    END IF

    IF trimLine = "-" THEN
        entryType = "Separator"
        launchTypeText = ""
        itemName = ""
        partTwo = ""
        partThree = ""
    ELSEIF PipeRawIsMenu(rawLine) <> 0 THEN
        entryType = "Menu"
        launchTypeText = ""
        itemName = PipeMenuNameFromRaw(rawLine)
        IF RTRIM$(LTRIM$(partThree)) = "" THEN
            partThree = PipePart(rawLine, 2)
            partTwo = ""
        END IF
    END IF

    SetControlTextByNameAny typeControlName, entryType
    SetControlTextByNameAny nameControlName, itemName
    SetControlTextByNameAny actionControlName, RTRIM$(LTRIM$(partTwo))
    SetControlTextByNameAny iconControlName, RTRIM$(LTRIM$(partThree))
    SetControlTextByNameAny parentControlName, PipeListParentForIndex(sourceText, itemIdx)
    SetControlTextByNameAny launchTypeControlName, launchTypeText

    IF statusControlName <> "" THEN SetTextboxTextByName statusControlName, "Selected: " + PipeLineDisplayFromRaw(rawLine)
END SUB


' ---------------------------
' Preset tracking, preset load/save, and preset apply
' ---------------------------

SUB ClearWindowPresetTracking(BYVAL winIdx AS INTEGER)
    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB
    layoutPresetTrackValid(winIdx) = 0
    layoutPresetTrackDirty(winIdx) = 0
    layoutPresetTrackPath(winIdx) = ""
    layoutPresetTrackTargetFile(winIdx) = ""
    layoutPresetTrackDepth(winIdx) = 0
END SUB

SUB TrackPresetLoadedForWindow(BYVAL winIdx AS INTEGER, BYVAL presetPath AS STRING, BYVAL targetFile AS STRING, BYVAL depthVal AS INTEGER)
    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(winIdx).used = 0 THEN EXIT SUB
    layoutPresetTrackValid(winIdx) = -1
    layoutPresetTrackDirty(winIdx) = 0
    layoutPresetTrackPath(winIdx) = NormalizePath(presetPath)
    layoutPresetTrackTargetFile(winIdx) = NormalizePath(targetFile)
    layoutPresetTrackDepth(winIdx) = depthVal
END SUB

SUB MarkWindowPresetDirty(BYVAL winIdx AS INTEGER)
    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(winIdx).used = 0 THEN EXIT SUB
    IF layoutPresetTrackValid(winIdx) <> 0 THEN layoutPresetTrackDirty(winIdx) = -1
END SUB

FUNCTION WindowPresetIsClean(BYVAL winIdx AS INTEGER, BYVAL presetPath AS STRING, BYVAL targetFile AS STRING, BYVAL depthVal AS INTEGER) AS INTEGER
    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN RETURN 0
    IF layoutWindows(winIdx).used = 0 THEN RETURN 0
    IF layoutPresetTrackValid(winIdx) = 0 THEN RETURN 0
    IF layoutPresetTrackDirty(winIdx) <> 0 THEN RETURN 0
    IF UCASE$(NormalizePath(presetPath)) <> UCASE$(NormalizePath(RTRIM$(layoutPresetTrackPath(winIdx)))) THEN RETURN 0
    IF NormalizePath(targetFile) <> "" THEN
        IF UCASE$(NormalizePath(targetFile)) <> UCASE$(NormalizePath(RTRIM$(layoutPresetTrackTargetFile(winIdx)))) THEN RETURN 0
    END IF
    IF depthVal <> 0 THEN
        IF layoutPresetTrackDepth(winIdx) <> 0 AND layoutPresetTrackDepth(winIdx) <> depthVal THEN RETURN 0
    END IF
    RETURN -1
END FUNCTION

SUB SysCfgSetConfirm(BYVAL sysFileName AS STRING, BYVAL sectionName AS STRING)
    DIM targetFileName AS STRING
    DIM targetSection AS STRING
    DIM targetKey AS STRING
    DIM targetValue AS STRING
    DIM currentValue AS STRING
    DIM confirmTitle AS STRING
    DIM confirmMessage AS STRING
    DIM reloadDisplay AS INTEGER
    DIM refreshPage AS INTEGER

    LoadCfgReadCacheFile sysFileName

    targetFileName = NormalizePath(ReadCfgValueInSection(sysFileName, sectionName, "TARGET_FILE", ""))
    targetSection = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "TARGET_SECTION", ""))
    targetKey = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "TARGET_KEY", ""))
    targetValue = ExpandLayoutDynamicText(ReadCfgValueInSection(sysFileName, sectionName, "TARGET_VALUE", ""))
    confirmTitle = ReadCfgValueInSection(sysFileName, sectionName, "CONFIRM_TITLE", "Confirm")
    confirmMessage = ReadCfgValueInSection(sysFileName, sectionName, "CONFIRM_MESSAGE", "Apply this change?")
    reloadDisplay = VALINT(ReadCfgValueInSection(sysFileName, sectionName, "RELOAD_DISPLAY", "0"))
    refreshPage = VALINT(ReadCfgValueInSection(sysFileName, sectionName, "REFRESH_PAGE", "0"))

    IF targetFileName = "" OR targetKey = "" THEN EXIT SUB

    currentValue = ReadCfgValueInSection(targetFileName, targetSection, targetKey, "")
    IF UCASE$(TRIM$(currentValue)) = UCASE$(TRIM$(targetValue)) THEN
        IF refreshPage <> 0 THEN
            SelectTabFromBoundConfig
            RefreshLayoutPageControls
        END IF
        IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
            IF layoutWindows(activeLayoutWindow).used <> 0 THEN SyncLayoutWindowFromGlobals activeLayoutWindow
        END IF
        EXIT SUB
    END IF

    IF TRIM$(confirmMessage) <> "" THEN
        IF ShowGuiConfirmBox(confirmTitle, confirmMessage) = 0 THEN
            IF refreshPage <> 0 THEN
                SelectTabFromBoundConfig
                RefreshLayoutPageControls
            END IF
            IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
                IF layoutWindows(activeLayoutWindow).used <> 0 THEN
                    SyncLayoutWindowFromGlobals activeLayoutWindow
                    SaveBindingSnapshotFromGlobals activeLayoutWindow
                END IF
            END IF
            EXIT SUB
        END IF
    END IF

    SetCfgValueInSection targetFileName, targetSection, targetKey, targetValue

    IF reloadDisplay <> 0 THEN
        RefreshDisplayFromCurrentConfig
    ELSE
        RefreshVisualConfigFast
    END IF

    IF refreshPage <> 0 THEN
        SelectTabFromBoundConfig
        RefreshLayoutPageControls
    END IF

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
            SyncLayoutWindowFromGlobals activeLayoutWindow
            SaveBindingSnapshotFromGlobals activeLayoutWindow
        END IF
    END IF
END SUB

FUNCTION CfgPresetFileMatchesAction(BYVAL sysFileName AS STRING, BYVAL sectionName AS STRING, BYVAL presetPath AS STRING) AS INTEGER
    DIM matchKey AS STRING
    DIM matchValue AS STRING
    DIM matchSource AS STRING
    DIM actualValue AS STRING
    DIM marker AS STRING
    DIM allowMissing AS INTEGER

    CfgPresetFileMatchesAction = -1
    sysFileName = NormalizePath(sysFileName)
    presetPath = NormalizePath(presetPath)
    IF presetPath = "" THEN EXIT FUNCTION

    LoadCfgReadCacheFile sysFileName
    matchKey = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "MATCH_KEY", ""))
    IF matchKey = "" THEN EXIT FUNCTION

    matchSource = UCASE$(TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "MATCH_VALUE_SOURCE", ReadCfgValueInSection(sysFileName, sectionName, "MATCH_SOURCE", ""))))
    SELECT CASE matchSource
    CASE "SELECTED_TAB", "SELECTED_DEPTH", "SELECTED_PAGE"
        matchValue = LTRIM$(STR$(LayoutSelectedDepthValue()))
    CASE "CURRENT_DISPLAY", "CURRENT_DEPTH", "CURRENT_COLOR_DEPTH"
        matchValue = LTRIM$(STR$(LayoutCurrentColorDepth()))
    CASE ELSE
        matchValue = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "MATCH_VALUE", ""))
    END SELECT

    IF matchValue = "" THEN EXIT FUNCTION

    marker = CHR$(1)
    allowMissing = VALINT(ReadCfgValueInSection(sysFileName, sectionName, "MATCH_ALLOW_MISSING", "0"))
    LoadCfgReadCacheFile presetPath
    actualValue = ReadCfgValue(presetPath, matchKey, marker)

    IF actualValue = marker THEN
        IF allowMissing <> 0 THEN
            CfgPresetFileMatchesAction = -1
        ELSE
            CfgPresetFileMatchesAction = 0
        END IF
        EXIT FUNCTION
    END IF

    IF UCASE$(TRIM$(actualValue)) = UCASE$(TRIM$(matchValue)) THEN
        CfgPresetFileMatchesAction = -1
    ELSE
        CfgPresetFileMatchesAction = 0
    END IF
END FUNCTION

SUB CfgPresetLoadControls(BYVAL sysFileName AS STRING, BYVAL sectionName AS STRING)
    DIM presetControlName AS STRING
    DIM statusControlName AS STRING
    DIM targetFileName AS STRING
    DIM presetPath AS STRING
    DIM cfgValue AS STRING
    DIM i AS INTEGER
    DIM loadedCount AS INTEGER
    DIM presetIdx AS INTEGER
    DIM trackDepth AS INTEGER

    LoadCfgReadCacheFile sysFileName

    presetControlName = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "PRESET_CONTROL", ""))
    statusControlName = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "STATUS", ""))
    targetFileName = NormalizePath(ReadCfgValueInSection(sysFileName, sectionName, "TARGET_FILE", ""))

    presetPath = GetControlTextValue(presetControlName)
    IF LEFT$(UCASE$(presetPath), 2) = "F:" THEN presetPath = MID$(presetPath, 3)
    presetPath = NormalizePath(presetPath)
    presetIdx = GetControlIndexByName(presetControlName)
    IF presetPath <> "" AND DIR(presetPath) = "" THEN
        IF presetIdx >= 1 AND presetIdx <= uiCount THEN
            IF TRIM$(uiElems(presetIdx).sourceDir) <> "" THEN
                presetPath = JoinPath(ExpandLayoutDynamicText(uiElems(presetIdx).sourceDir), FileNameOnly(presetPath))
            END IF
        END IF
    END IF

    IF presetPath = "" THEN
        IF statusControlName <> "" THEN SetTextboxTextByName statusControlName, "No preset selected"
        SyncLayoutWindowFromGlobals activeLayoutWindow
        EXIT SUB
    END IF

    LoadCfgReadCacheFile presetPath
    IF CfgPresetFileMatchesAction(sysFileName, sectionName, presetPath) = 0 THEN
        IF statusControlName <> "" THEN SetTextboxTextByName statusControlName, "Preset does not match selected page"
        SyncLayoutWindowFromGlobals activeLayoutWindow
        EXIT SUB
    END IF

    loadedCount = 0
    FOR i = 1 TO uiCount
        IF TRIM$(uiElems(i).bindKey) <> "" THEN
            IF targetFileName = "" OR UCASE$(NormalizePath(uiElems(i).bindFile)) = UCASE$(targetFileName) THEN
                cfgValue = ReadCfgValue(presetPath, uiElems(i).bindKey, CHR$(1))
                IF cfgValue <> CHR$(1) THEN
                    SELECT CASE uiElems(i).kindKey
                    CASE "TEXTBOX"
                        SetTextboxTextByName uiElems(i).name, cfgValue
                    CASE "COMBO"
                        SetComboSelectionFromBoundValue i, cfgValue
                    CASE "RADIO"
                        IF UCASE$(TRIM$(uiElems(i).bindValue)) = UCASE$(TRIM$(cfgValue)) THEN
                            uiElems(i).state = -1
                        ELSEIF TRIM$(uiElems(i).groupName) <> "" THEN
                            uiElems(i).state = 0
                        END IF
                    CASE ELSE
                        uiElems(i).text = cfgValue
                    END SELECT
                    loadedCount = loadedCount + 1
                END IF
            END IF
        END IF
    NEXT

    IF statusControlName <> "" THEN
        IF loadedCount > 0 THEN
            SetTextboxTextByName statusControlName, "Loaded preset values"
        ELSE
            SetTextboxTextByName statusControlName, "Selected file had no matching values"
        END IF
    END IF

    IF loadedCount > 0 THEN
        InvalidateLivePreviewCachesForWindow activeLayoutWindow
        MarkLayoutWindowDirty activeLayoutWindow
        trackDepth = CfgPresetDepthForAction(sysFileName, sectionName)
        TrackPresetLoadedForWindow activeLayoutWindow, presetPath, targetFileName, trackDepth
    END IF
    SyncLayoutWindowFromGlobals activeLayoutWindow
END SUB

FUNCTION CfgPresetDepthForAction(BYVAL sysFileName AS STRING, BYVAL sectionName AS STRING) AS INTEGER
    DIM depthSource AS STRING
    DIM depthVal AS INTEGER

    LoadCfgReadCacheFile sysFileName

    depthSource = UCASE$(TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "DEPTH_SOURCE", "")))
    SELECT CASE depthSource
    CASE "SELECTED_TAB", "SELECTED_DEPTH", "SELECTED_PAGE"
        depthVal = LayoutSelectedDepthValue()
    CASE "CURRENT_DISPLAY", "CURRENT_DEPTH", "CURRENT_COLOR_DEPTH"
        depthVal = LayoutCurrentColorDepth()
    CASE ELSE
        depthVal = VALINT(ReadCfgValueInSection(sysFileName, sectionName, "DEPTH_VALUE", "0"))
    END SELECT

    CfgPresetDepthForAction = depthVal
END FUNCTION

FUNCTION CfgPresetTargetDirForAction(BYVAL sysFileName AS STRING, BYVAL sectionName AS STRING, BYVAL depthVal AS INTEGER) AS STRING
    DIM targetDir AS STRING
    DIM depthDir AS STRING
    DIM useDepthFolders AS INTEGER

    LoadCfgReadCacheFile sysFileName

    targetDir = NormalizePath(ReadCfgValueInSection(sysFileName, sectionName, "TARGET_DIR", "."))
    IF targetDir = "" THEN targetDir = "."

    targetDir = ExpandLayoutDynamicText(targetDir)
    useDepthFolders = VALINT(ReadCfgValueInSection(sysFileName, sectionName, "USE_DEPTH_FOLDERS", "0"))
    IF useDepthFolders <> 0 THEN
        depthDir = ReadCfgValueInSection(sysFileName, sectionName, "TARGET_DIR_" + LTRIM$(STR$(depthVal)), "")
        depthDir = ExpandLayoutDynamicText(depthDir)
        IF depthDir <> "" THEN targetDir = depthDir
    END IF

    CfgPresetTargetDirForAction = targetDir
END FUNCTION

FUNCTION CfgPresetSkipKey(BYVAL keyName AS STRING, BYVAL skipKeys AS STRING) AS INTEGER
    DIM checkKey AS STRING
    DIM workList AS STRING
    DIM itemText AS STRING
    DIM sepPos AS INTEGER

    checkKey = UCASE$(TRIM$(keyName))
    IF checkKey = "" THEN RETURN -1

    workList = skipKeys
    DO WHILE workList <> ""
        sepPos = INSTR(workList, "|")
        IF sepPos > 0 THEN
            itemText = LEFT$(workList, sepPos - 1)
            workList = MID$(workList, sepPos + 1)
        ELSE
            itemText = workList
            workList = ""
        END IF

        IF UCASE$(TRIM$(itemText)) = checkKey THEN RETURN -1
    LOOP

    RETURN 0
END FUNCTION

FUNCTION CfgPresetCopyFileToTarget(BYVAL presetPath AS STRING, BYVAL targetFileName AS STRING, BYVAL skipKeys AS STRING) AS INTEGER
    DIM f AS INTEGER
    DIM rawLine AS STRING
    DIM lineText AS STRING
    DIM p AS INTEGER
    DIM keyText AS STRING
    DIM valueText AS STRING
    DIM copiedCount AS INTEGER

    CfgPresetCopyFileToTarget = 0
    presetPath = NormalizePath(presetPath)
    targetFileName = NormalizePath(targetFileName)
    IF presetPath = "" OR targetFileName = "" THEN EXIT FUNCTION
    IF DIR(presetPath) = "" THEN EXIT FUNCTION

    copiedCount = 0
    f = FREEFILE
    IF OPEN(presetPath FOR INPUT AS #f) <> 0 THEN EXIT FUNCTION

    DO WHILE EOF(f) = 0
        LINE INPUT #f, rawLine
        lineText = TRIM$(rawLine)
        IF lineText <> "" THEN
            IF LEFT$(lineText, 1) <> "#" AND LEFT$(lineText, 1) <> ";" THEN
                IF NOT (LEFT$(lineText, 1) = "[" AND RIGHT$(lineText, 1) = "]") THEN
                    p = INSTR(lineText, "=")
                    IF p > 0 THEN
                        keyText = TRIM$(LEFT$(lineText, p - 1))
                        valueText = StripOuterQuotes(TRIM$(MID$(lineText, p + 1)))
                        IF CfgPresetSkipKey(keyText, skipKeys) = 0 THEN
                            SetCfgValueInSection targetFileName, "", keyText, valueText
                            copiedCount = copiedCount + 1
                        END IF
                    END IF
                END IF
            END IF
        END IF
    LOOP

    CLOSE #f
    CfgPresetCopyFileToTarget = copiedCount
END FUNCTION

SUB CfgPresetApplyToTarget(BYVAL sysFileName AS STRING, BYVAL sectionName AS STRING)
    DIM presetControlName AS STRING
    DIM statusControlName AS STRING
    DIM targetFileName AS STRING
    DIM presetPath AS STRING
    DIM presetIdx AS INTEGER
    DIM sourceDir AS STRING
    DIM sourceDirByDepth AS STRING
    DIM depthVal AS INTEGER
    DIM activePageOnly AS INTEGER
    DIM reloadDisplay AS INTEGER
    DIM activePage AS STRING
    DIM elemPage AS STRING
    DIM fallbackToControls AS INTEGER
    DIM requireDepthMatch AS INTEGER
    DIM i AS INTEGER
    DIM includeElem AS INTEGER
    DIM marker AS STRING
    DIM presetVal AS STRING
    DIM controlVal AS STRING
    DIM dirtyControls AS INTEGER
    DIM copiedCount AS INTEGER
    DIM presetTargetFile AS STRING
    DIM presetKey AS STRING
    DIM presetKeyTemplate AS STRING
    DIM presetCleanFast AS INTEGER
    DIM directPresetCopy AS INTEGER
    DIM skipKeys AS STRING

    LoadCfgReadCacheFile sysFileName

    presetControlName = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "PRESET_CONTROL", ""))
    statusControlName = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "STATUS", ""))
    targetFileName = NormalizePath(ReadCfgValueInSection(sysFileName, sectionName, "TARGET_FILE", ""))
    activePageOnly = VALINT(ReadCfgValueInSection(sysFileName, sectionName, "ACTIVE_PAGE_ONLY", "0"))
    reloadDisplay = VALINT(ReadCfgValueInSection(sysFileName, sectionName, "RELOAD_DISPLAY", "0"))
    fallbackToControls = VALINT(ReadCfgValueInSection(sysFileName, sectionName, "FALLBACK_TO_CONTROLS_ON_DIRTY", "1"))
    requireDepthMatch = VALINT(ReadCfgValueInSection(sysFileName, sectionName, "MATCH_DEPTH", "0"))
    presetTargetFile = NormalizePath(ReadCfgValueInSection(sysFileName, sectionName, "STORE_PRESET_FILE", targetFileName))
    presetKeyTemplate = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "STORE_PRESET_KEY", ""))
    directPresetCopy = VALINT(ReadCfgValueInSection(sysFileName, sectionName, "DIRECT_PRESET_COPY", "0"))
    skipKeys = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "SKIP_KEYS", ""))

    depthVal = CfgPresetDepthForAction(sysFileName, sectionName)
    activePage = ""
    IF activePageOnly <> 0 THEN GetLayoutActivePage activePage
    activePage = UCASE$(TRIM$(activePage))

    presetPath = GetControlTextValue(presetControlName)
    IF LEFT$(UCASE$(presetPath), 2) = "F:" THEN presetPath = MID$(presetPath, 3)
    presetPath = NormalizePath(presetPath)

    presetIdx = GetControlIndexByName(presetControlName)
    IF presetPath <> "" AND DIR(presetPath) = "" THEN
        sourceDir = ExpandLayoutDynamicText(ReadCfgValueInSection(sysFileName, sectionName, "SOURCE_DIR", ""))
        IF sourceDir <> "" THEN sourceDir = ResolveAppLocalFilePathFromFile(sysFileName, sourceDir)
        IF sourceDir = "" THEN
            IF presetIdx >= 1 AND presetIdx <= uiCount THEN sourceDir = NormalizePath(uiElems(presetIdx).sourceDir)
        END IF

        sourceDirByDepth = ""
        IF VALINT(ReadCfgValueInSection(sysFileName, sectionName, "USE_DEPTH_FOLDERS", "0")) <> 0 THEN
            sourceDirByDepth = ExpandLayoutDynamicText(ReadCfgValueInSection(sysFileName, sectionName, "SOURCE_DIR_" + LTRIM$(STR$(depthVal)), ""))
            IF sourceDirByDepth <> "" THEN sourceDirByDepth = ResolveAppLocalFilePathFromFile(sysFileName, sourceDirByDepth)
        END IF
        IF sourceDirByDepth <> "" THEN sourceDir = sourceDirByDepth
        IF sourceDir <> "" THEN presetPath = JoinPath(sourceDir, FileNameOnly(presetPath))
    END IF

    IF presetPath = "" OR DIR(presetPath) = "" THEN
        IF fallbackToControls <> 0 THEN
            ApplyBindingsFromControlsUsingSys sysFileName, sectionName
            EXIT SUB
        END IF
        IF statusControlName <> "" THEN SetTextboxTextByName statusControlName, "No preset selected"
        SyncLayoutWindowFromGlobals activeLayoutWindow
        EXIT SUB
    END IF

    LoadCfgReadCacheFile presetPath
    IF requireDepthMatch <> 0 OR TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "MATCH_KEY", "")) <> "" THEN
        IF CfgPresetFileMatchesAction(sysFileName, sectionName, presetPath) = 0 THEN
            IF statusControlName <> "" THEN SetTextboxTextByName statusControlName, "Preset does not match selected page"
            SyncLayoutWindowFromGlobals activeLayoutWindow
            EXIT SUB
        END IF
    END IF

    marker = CHR$(1)
    dirtyControls = 0
    copiedCount = 0
    presetCleanFast = WindowPresetIsClean(activeLayoutWindow, presetPath, targetFileName, depthVal)

    IF presetCleanFast <> 0 AND directPresetCopy <> 0 THEN
        BeginCfgWriteBatch
        copiedCount = CfgPresetCopyFileToTarget(presetPath, targetFileName, skipKeys)
        IF copiedCount > 0 THEN
            presetKey = ExpandLayoutDynamicText(presetKeyTemplate)
            IF presetKey <> "" AND presetTargetFile <> "" THEN SetCfgValueInSection presetTargetFile, "", presetKey, presetPath
            FlushCfgWriteBatch
            IF reloadDisplay <> 0 THEN RefreshVisualConfigFast
            IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
                IF layoutWindows(activeLayoutWindow).used <> 0 THEN
                    SyncLayoutWindowFromGlobals activeLayoutWindow
                    SaveBindingSnapshotFromGlobals activeLayoutWindow
                    TrackPresetLoadedForWindow activeLayoutWindow, presetPath, targetFileName, depthVal
                END IF
            END IF
            IF statusControlName <> "" THEN SetTextboxTextByName statusControlName, "Applied preset"
            EXIT SUB
        END IF
        FlushCfgWriteBatch
    END IF

    IF presetCleanFast <> 0 THEN GOTO CfgPresetApplySkipDirtyCompare

    FOR i = 1 TO uiCount
        IF TRIM$(uiElems(i).bindFile) <> "" AND TRIM$(uiElems(i).bindKey) <> "" THEN
            includeElem = -1
            IF targetFileName <> "" THEN
                IF UCASE$(NormalizePath(uiElems(i).bindFile)) <> UCASE$(targetFileName) THEN includeElem = 0
            END IF
            IF includeElem <> 0 AND activePageOnly <> 0 THEN
                elemPage = uiElems(i).pageKey
                IF elemPage <> "" THEN
                    IF elemPage <> activePage THEN includeElem = 0
                END IF
            END IF
            IF includeElem <> 0 THEN
                presetVal = ReadCfgValue(presetPath, uiElems(i).bindKey, marker)

                IF presetVal <> marker THEN
                    SELECT CASE uiElems(i).kindKey
                    CASE "TEXTBOX"
                        controlVal = uiElems(i).text
                        IF TRIM$(uiElems(i).name) <> "" THEN controlVal = GetTextboxTextByName(uiElems(i).name)
                    CASE "COMBO"
                        controlVal = ControlValueFromCombo(i)
                    CASE "CHECKBOX"
                        controlVal = TRIM$(uiElems(i).bindValue)
                        IF controlVal = "" THEN controlVal = "1"
                        IF uiElems(i).state = 0 THEN controlVal = "0"
                    CASE "RADIO"
                        controlVal = ""
                        IF uiElems(i).state <> 0 THEN controlVal = uiElems(i).bindValue
                    CASE ELSE
                        controlVal = uiElems(i).text
                    END SELECT

                    IF UCASE$(TRIM$(controlVal)) <> UCASE$(TRIM$(presetVal)) THEN dirtyControls = -1
                    copiedCount = copiedCount + 1
                END IF
            END IF
        END IF
    NEXT

CfgPresetApplySkipDirtyCompare:

    IF dirtyControls <> 0 AND fallbackToControls <> 0 THEN
        ApplyBindingsFromControlsUsingSys sysFileName, sectionName
        EXIT SUB
    END IF

    IF copiedCount = 0 AND presetCleanFast = 0 THEN
        IF fallbackToControls <> 0 THEN
            ApplyBindingsFromControlsUsingSys sysFileName, sectionName
            EXIT SUB
        END IF
        IF statusControlName <> "" THEN SetTextboxTextByName statusControlName, "Preset had no matching values"
        SyncLayoutWindowFromGlobals activeLayoutWindow
        EXIT SUB
    END IF

    BeginCfgWriteBatch

    FOR i = 1 TO uiCount
        IF TRIM$(uiElems(i).bindFile) <> "" AND TRIM$(uiElems(i).bindKey) <> "" THEN
            includeElem = -1
            IF targetFileName <> "" THEN
                IF UCASE$(NormalizePath(uiElems(i).bindFile)) <> UCASE$(targetFileName) THEN includeElem = 0
            END IF
            IF includeElem <> 0 AND activePageOnly <> 0 THEN
                elemPage = uiElems(i).pageKey
                IF elemPage <> "" THEN
                    IF elemPage <> activePage THEN includeElem = 0
                END IF
            END IF
            IF includeElem <> 0 THEN
                presetVal = ReadCfgValue(presetPath, uiElems(i).bindKey, marker)
                IF presetVal <> marker THEN
                    SetCfgValueInSection uiElems(i).bindFile, uiElems(i).bindSection, uiElems(i).bindKey, presetVal
                    IF presetCleanFast <> 0 THEN copiedCount = copiedCount + 1
                END IF
            END IF
        END IF
    NEXT

    presetKey = ExpandLayoutDynamicText(presetKeyTemplate)
    IF presetKey <> "" AND presetTargetFile <> "" THEN SetCfgValueInSection presetTargetFile, "", presetKey, presetPath

    FlushCfgWriteBatch

    IF reloadDisplay <> 0 THEN RefreshVisualConfigFast

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
            SyncLayoutWindowFromGlobals activeLayoutWindow
            SaveBindingSnapshotFromGlobals activeLayoutWindow
            TrackPresetLoadedForWindow activeLayoutWindow, presetPath, targetFileName, depthVal
        END IF
    END IF

    IF statusControlName <> "" THEN SetTextboxTextByName statusControlName, "Applied preset"
END SUB

SUB CfgPresetSaveControls(BYVAL sysFileName AS STRING, BYVAL sectionName AS STRING)
    DIM presetControlName AS STRING
    DIM nameControlName AS STRING
    DIM statusControlName AS STRING
    DIM targetDir AS STRING
    DIM targetFileName AS STRING
    DIM presetName AS STRING
    DIM baseName AS STRING
    DIM savePath AS STRING
    DIM fileExt AS STRING
    DIM depthVal AS INTEGER
    DIM promptedName AS STRING
    DIM defaultName AS STRING
    DIM promptTitle AS STRING
    DIM promptText AS STRING
    DIM overwriteTitle AS STRING
    DIM writeNameKey AS STRING
    DIM writeDepthKey AS STRING
    DIM f AS INTEGER
    DIM i AS INTEGER
    DIM valueText AS STRING
    DIM savedCount AS INTEGER
    DIM presetIdx AS INTEGER
    DIM saveThisKey AS INTEGER
    DIM indexPath AS STRING

    LoadCfgReadCacheFile sysFileName

    presetControlName = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "PRESET_CONTROL", ""))
    nameControlName = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "NAME_CONTROL", ""))
    statusControlName = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "STATUS", ""))
    targetFileName = NormalizePath(ReadCfgValueInSection(sysFileName, sectionName, "TARGET_FILE", ""))
    fileExt = UCASE$(TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "FILE_EXT", ".CFG")))
    promptTitle = ReadCfgValueInSection(sysFileName, sectionName, "PROMPT_TITLE", "Save Preset")
    promptText = ReadCfgValueInSection(sysFileName, sectionName, "PROMPT_TEXT", ReadCfgValueInSection(sysFileName, sectionName, "PROMPT_MESSAGE", "Enter file name:"))
    overwriteTitle = ReadCfgValueInSection(sysFileName, sectionName, "OVERWRITE_TITLE", promptTitle)
    writeNameKey = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "WRITE_NAME_KEY", ""))
    writeDepthKey = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "WRITE_DEPTH_KEY", ""))

    IF fileExt = "" THEN fileExt = ".CFG"
    IF LEFT$(fileExt, 1) <> "." THEN fileExt = "." + fileExt

    presetName = TRIM$(GetTextboxTextByName(nameControlName))
    IF presetName = "" THEN
        IF VALINT(ReadCfgValueInSection(sysFileName, sectionName, "PROMPT_IF_EMPTY", "0")) <> 0 THEN
            defaultName = ""

            promptedName = ShowGuiTextInputBox(promptTitle, promptText, defaultName)
            IF promptedName = CHR$(1) THEN
                IF statusControlName <> "" THEN SetTextboxTextByName statusControlName, "Save canceled"
                SyncLayoutWindowFromGlobals activeLayoutWindow
                EXIT SUB
            END IF
            presetName = TRIM$(promptedName)
            IF presetName <> "" THEN SetTextboxTextByName nameControlName, presetName
        END IF
    END IF

    IF LEFT$(UCASE$(presetName), 2) = "F:" THEN presetName = FileNameOnly(MID$(presetName, 3))
    IF UCASE$(RIGHT$(presetName, LEN(fileExt))) = fileExt THEN presetName = LEFT$(presetName, LEN(presetName) - LEN(fileExt))
    presetName = TRIM$(presetName)
    IF presetName = "" THEN
        IF statusControlName <> "" THEN SetTextboxTextByName statusControlName, "No filename entered"
        SyncLayoutWindowFromGlobals activeLayoutWindow
        EXIT SUB
    END IF

    depthVal = CfgPresetDepthForAction(sysFileName, sectionName)
    targetDir = CfgPresetTargetDirForAction(sysFileName, sectionName, depthVal)
    EnsureDirectoryExists targetDir

    baseName = CleanDosBaseName(presetName, CHR$(1))
    IF baseName = CHR$(1) OR baseName = "" THEN
        IF statusControlName <> "" THEN SetTextboxTextByName statusControlName, "Invalid filename"
        SyncLayoutWindowFromGlobals activeLayoutWindow
        EXIT SUB
    END IF

    savePath = JoinPath(targetDir, baseName + fileExt)
    IF DIR(savePath) <> "" THEN
        IF VALINT(ReadCfgValueInSection(sysFileName, sectionName, "CONFIRM_OVERWRITE", "1")) <> 0 THEN
            IF ShowGuiConfirmBox(overwriteTitle, "Overwrite " + FileNameOnly(savePath) + "?") = 0 THEN
                IF statusControlName <> "" THEN SetTextboxTextByName statusControlName, "Save canceled"
                SyncLayoutWindowFromGlobals activeLayoutWindow
                EXIT SUB
            END IF
        END IF
    END IF

    f = FREEFILE
    IF OPEN(savePath FOR OUTPUT AS #f) <> 0 THEN
        IF statusControlName <> "" THEN SetTextboxTextByName statusControlName, "Could not write file"
        SyncLayoutWindowFromGlobals activeLayoutWindow
        EXIT SUB
    END IF

    IF writeNameKey <> "" THEN PRINT #f, writeNameKey + "=" + presetName
    IF writeDepthKey <> "" THEN PRINT #f, writeDepthKey + "=" + LTRIM$(STR$(depthVal))

    savedCount = 0
    FOR i = 1 TO uiCount
        IF TRIM$(uiElems(i).bindKey) <> "" THEN
            saveThisKey = -1
            IF targetFileName <> "" THEN
                IF UCASE$(NormalizePath(uiElems(i).bindFile)) <> UCASE$(targetFileName) THEN saveThisKey = 0
            END IF
            IF saveThisKey <> 0 THEN
                SELECT CASE uiElems(i).kindKey
                CASE "TEXTBOX"
                    valueText = uiElems(i).text
                    IF TRIM$(uiElems(i).name) <> "" THEN valueText = GetTextboxTextByName(uiElems(i).name)
                    PRINT #f, uiElems(i).bindKey + "=" + valueText
                    savedCount = savedCount + 1
                CASE "COMBO"
                    valueText = ControlValueFromCombo(i)
                    PRINT #f, uiElems(i).bindKey + "=" + valueText
                    savedCount = savedCount + 1
                CASE "RADIO"
                    IF uiElems(i).state <> 0 THEN
                        PRINT #f, uiElems(i).bindKey + "=" + uiElems(i).bindValue
                        savedCount = savedCount + 1
                    END IF
                END SELECT
            END IF
        END IF
    NEXT

    CLOSE #f
    InvalidateCfgReadCacheForFile savePath

    presetIdx = GetControlIndexByName(presetControlName)
    IF presetIdx >= 1 AND presetIdx <= uiCount THEN
        uiElems(presetIdx).text = FileNameOnly(savePath)
        indexPath = ExpandSourceIndexPath(uiElems(presetIdx).sourceIndex, depthVal)
        IF indexPath <> "" THEN
            IF DIR(indexPath) <> "" THEN KILL indexPath
        END IF
    END IF
    ClearComboItemCache

    IF statusControlName <> "" THEN SetTextboxTextByName statusControlName, "Saved " + FileNameOnly(savePath)
    SyncLayoutWindowFromGlobals activeLayoutWindow
END SUB

FUNCTION FileBrowserPathIsDirectory(BYVAL itemPath AS STRING) AS INTEGER
    itemPath = AbsoluteDirPath(TRIM$(itemPath))
    IF itemPath = "" THEN RETURN 0
    IF DirectoryExistsForSize(itemPath) <> 0 THEN RETURN -1
    RETURN 0
END FUNCTION

FUNCTION FileBrowserDirDropUnsafe(BYVAL sourceDir AS STRING, BYVAL targetDir AS STRING) AS INTEGER
    DIM srcKey AS STRING
    DIM dstKey AS STRING

    sourceDir = AbsoluteDirPath(TRIM$(sourceDir))
    targetDir = AbsoluteDirPath(TRIM$(targetDir))
    IF sourceDir = "" OR targetDir = "" THEN RETURN -1

    srcKey = UCASE$(sourceDir)
    dstKey = UCASE$(targetDir)
    IF RIGHT$(srcKey, 1) <> CHR$(92) THEN srcKey = srcKey + CHR$(92)
    IF RIGHT$(dstKey, 1) <> CHR$(92) THEN dstKey = dstKey + CHR$(92)

    ' A directory cannot be dropped on itself or inside its own tree.
    IF dstKey = srcKey THEN RETURN -1
    IF LEFT$(dstKey, LEN(srcKey)) = srcKey THEN RETURN -1

    RETURN 0
END FUNCTION

FUNCTION FileBrowserConfirmOverwrite(BYVAL targetPath AS STRING, BYVAL targetIsDir AS INTEGER, BYVAL moveMode AS INTEGER) AS INTEGER
    DIM msgText AS STRING

    targetPath = NormalizePath(TRIM$(targetPath))
    IF targetPath = "" THEN RETURN 0

    IF targetIsDir <> 0 THEN
        msgText = "Target folder exists. Merge " + FileNameOnly(targetPath) + "?"
    ELSE
        msgText = "Overwrite existing file " + FileNameOnly(targetPath) + "?"
    END IF

    ' Drag/drop never overwrites or merges without user confirmation.
    IF ShowGuiConfirmBox("Confirm Overwrite", msgText) <> 0 THEN RETURN -1
    RETURN 0
END FUNCTION

SUB FileBrowserCopyMoveListToDir(BYVAL sourceList AS STRING, BYVAL targetDir AS STRING, BYVAL moveMode AS INTEGER, BYVAL sourceWin AS INTEGER, BYVAL statusControlName AS STRING)
    DIM itemList AS STRING
    DIM itemPath AS STRING
    DIM selectedPath AS STRING
    DIM newPath AS STRING
    DIM sepPos AS INTEGER
    DIM itemCount AS INTEGER
    DIM successCount AS INTEGER
    DIM failCount AS INTEGER
    DIM statusText AS STRING
    DIM refreshDir AS STRING
    DIM restoreWin AS INTEGER
    DIM isDir AS INTEGER
    DIM destExists AS INTEGER
    DIM opFiles AS INTEGER
    DIM opDirs AS INTEGER
    DIM opFails AS INTEGER
    DIM beforeFails AS INTEGER
    DIM overwriteOk AS INTEGER

    sourceList = TRIM$(sourceList)
    targetDir = AbsoluteDirPath(TRIM$(targetDir))
    itemCount = DelimitedListCount(sourceList)
    successCount = 0
    failCount = 0

    IF itemCount < 1 THEN
        statusText = "Drag-drop unavailable"
    ELSEIF targetDir = "" THEN
        statusText = "Drop directory unavailable"
    ELSE
        itemList = sourceList
        DO WHILE itemList <> ""
            sepPos = INSTR(itemList, CHR$(1))
            IF sepPos > 0 THEN
                itemPath = LEFT$(itemList, sepPos - 1)
                itemList = MID$(itemList, sepPos + 1)
            ELSE
                itemPath = itemList
                itemList = ""
            END IF

            selectedPath = NormalizePath(TRIM$(itemPath))
            isDir = FileBrowserPathIsDirectory(selectedPath)
            IF isDir <> 0 THEN selectedPath = AbsoluteDirPath(selectedPath)
            overwriteOk = 0

            IF selectedPath = "" THEN
                failCount = failCount + 1
            ELSEIF PathExistsAny(selectedPath) = 0 THEN
                failCount = failCount + 1
            ELSE
                newPath = JoinPath(targetDir, FileNameOnly(selectedPath))
                IF UCASE$(NormalizePath(selectedPath)) = UCASE$(NormalizePath(newPath)) THEN
                    failCount = failCount + 1
                ELSEIF isDir <> 0 AND FileBrowserDirDropUnsafe(selectedPath, targetDir) <> 0 THEN
                    failCount = failCount + 1
                ELSE
                    destExists = PathExistsAny(newPath)
                    IF destExists <> 0 THEN overwriteOk = FileBrowserConfirmOverwrite(newPath, isDir, moveMode)

                    IF destExists <> 0 AND overwriteOk = 0 THEN
                        failCount = failCount + 1
                    ELSEIF isDir <> 0 THEN
                        beforeFails = failCount
                        opFiles = 0
                        opDirs = 0
                        opFails = 0

                        IF moveMode <> 0 AND destExists = 0 THEN
                            IF RenameFileSafe(selectedPath, newPath) <> 0 THEN
                                successCount = successCount + 1
                            ELSE
                                failCount = failCount + 1
                            END IF
                        ELSE
                            CopyDirectoryTree selectedPath, newPath, -1, -1, -1, -1, -1, opFiles, opDirs, opFails
                            failCount = failCount + opFails
                            IF opFails = 0 AND PathExistsAny(newPath) <> 0 THEN
                                IF moveMode <> 0 THEN
                                    opFiles = 0
                                    opDirs = 0
                                    opFails = 0
                                    IF DeleteDirectoryTree(selectedPath, opFiles, opDirs, opFails) <> 0 AND opFails = 0 THEN
                                        successCount = successCount + 1
                                    ELSE
                                        failCount = failCount + 1
                                    END IF
                                ELSE
                                    successCount = successCount + 1
                                END IF
                            ELSEIF failCount = beforeFails THEN
                                failCount = failCount + 1
                            END IF
                        END IF
                    ELSEIF moveMode <> 0 THEN
                        IF destExists <> 0 THEN
                            IF CopyFileSafeOverwrite(selectedPath, newPath, -1) <> 0 THEN
                                IF DeleteFileSafe(selectedPath) <> 0 THEN
                                    successCount = successCount + 1
                                ELSE
                                    failCount = failCount + 1
                                END IF
                            ELSE
                                failCount = failCount + 1
                            END IF
                        ELSEIF RenameFileSafe(selectedPath, newPath) <> 0 THEN
                            successCount = successCount + 1
                        ELSE
                            failCount = failCount + 1
                        END IF
                    ELSEIF CopyFileSafeOverwrite(selectedPath, newPath, destExists) <> 0 THEN
                        successCount = successCount + 1
                    ELSE
                        failCount = failCount + 1
                    END IF
                END IF
            END IF
        LOOP

        IF successCount > 0 THEN
            ClearComboItemCache
            IF sourceWin >= LBOUND(layoutWindows) AND sourceWin <= UBOUND(layoutWindows) THEN
                IF layoutWindows(sourceWin).used <> 0 THEN
                    refreshDir = FileBrowserWindowCurrentDir(sourceWin)
                    IF refreshDir <> "" THEN
                        restoreWin = activeLayoutWindow
                        ConfigureFileBrowserWindow sourceWin, refreshDir
                        activeLayoutWindow = restoreWin
                        IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
                            IF layoutWindows(activeLayoutWindow).used <> 0 THEN SyncGlobalsFromLayoutWindow activeLayoutWindow
                        END IF
                    END IF
                END IF
            END IF
        END IF

        IF successCount = 0 THEN
            IF moveMode <> 0 THEN
                statusText = "Move failed"
            ELSE
                statusText = "Copy failed"
            END IF
        ELSEIF itemCount = 1 THEN
            IF moveMode <> 0 THEN
                statusText = "Moved " + FileNameOnly(newPath)
            ELSE
                statusText = "Copied " + FileNameOnly(newPath)
            END IF
        ELSEIF failCount > 0 THEN
            IF moveMode <> 0 THEN
                statusText = "Moved " + LTRIM$(STR$(successCount)) + ", failed " + LTRIM$(STR$(failCount))
            ELSE
                statusText = "Copied " + LTRIM$(STR$(successCount)) + ", failed " + LTRIM$(STR$(failCount))
            END IF
        ELSE
            IF moveMode <> 0 THEN
                statusText = "Moved " + LTRIM$(STR$(successCount)) + " items"
            ELSE
                statusText = "Copied " + LTRIM$(STR$(successCount)) + " items"
            END IF
        END IF
    END IF

    IF statusControlName <> "" THEN
        IF sourceWin >= LBOUND(layoutWindows) AND sourceWin <= UBOUND(layoutWindows) THEN
            IF layoutWindows(sourceWin).used <> 0 THEN
                restoreWin = activeLayoutWindow
                activeLayoutWindow = sourceWin
                SyncGlobalsFromLayoutWindow sourceWin
                SetTextboxTextByName statusControlName, statusText
                SyncLayoutWindowFromGlobals sourceWin
                activeLayoutWindow = restoreWin
                IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
                    IF layoutWindows(activeLayoutWindow).used <> 0 THEN SyncGlobalsFromLayoutWindow activeLayoutWindow
                END IF
            END IF
        END IF
    END IF
END SUB

