FUNCTION SoundDriverIdFromText(BYVAL driverText AS STRING) AS INTEGER
    driverText = UCASE$(TRIM$(driverText))
    SELECT CASE driverText
        CASE "NONE", "OFF", "DISABLED"
            RETURN SOUND_DRIVER_NONE
        CASE "PCSPKR", "PC", "SPEAKER", "PCSPEAKER"
            RETURN SOUND_DRIVER_PCSPKR
        CASE "AUTO"
            RETURN SOUND_DRIVER_AUTO
        CASE "ADLIB", "OPL", "OPL2", "OPL3"
            RETURN SOUND_DRIVER_ADLIB
        CASE "SBLASTER", "SB", "SOUNDBLASTER", "SOUND BLASTER"
            RETURN SOUND_DRIVER_SBLASTER
    END SELECT
    RETURN SOUND_DRIVER_PCSPKR
END FUNCTION

FUNCTION SoundDriverName(BYVAL driverId AS INTEGER) AS STRING
    SELECT CASE driverId
        CASE SOUND_DRIVER_NONE
            RETURN "NONE"
        CASE SOUND_DRIVER_PCSPKR
            RETURN "PCSPKR"
        CASE SOUND_DRIVER_AUTO
            RETURN "AUTO"
        CASE SOUND_DRIVER_ADLIB
            RETURN "ADLIB"
        CASE SOUND_DRIVER_SBLASTER
            RETURN "SBLASTER"
    END SELECT
    RETURN "UNKNOWN"
END FUNCTION

FUNCTION SoundBoolText(BYVAL flagValue AS INTEGER) AS STRING
    IF flagValue <> 0 THEN RETURN "YES"
    RETURN "NO"
END FUNCTION

FUNCTION SoundHexWord(BYVAL valueNum AS INTEGER) AS STRING
    DIM hexChars AS STRING
    DIM workValue AS INTEGER
    DIM i AS INTEGER
    DIM digitValue AS INTEGER
    DIM resultText AS STRING

    hexChars = "0123456789ABCDEF"
    workValue = valueNum AND &HFFFF
    resultText = ""
    FOR i = 12 TO 0 STEP -4
        digitValue = (workValue SHR i) AND &HF
        resultText = resultText + MID$(hexChars, digitValue + 1, 1)
    NEXT
    RETURN resultText
END FUNCTION

