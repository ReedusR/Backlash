FUNCTION StartupSplashModeFromText(BYVAL modeText AS STRING) AS INTEGER
    modeText = UCASE$(TRIM$(modeText))
    IF modeText = "CENTER" THEN RETURN 1
    IF modeText = "FIT" THEN RETURN 2
    IF modeText = "FILL" THEN RETURN 3
    IF modeText = "STRETCH" THEN RETURN 4
    IF VALINT(modeText) >= 1 AND VALINT(modeText) <= 4 THEN RETURN VALINT(modeText)
    RETURN 2
END FUNCTION

SUB FreeStartupSplashWallpaper()
    IF startupSplashWallPix <> 0 THEN
        DEALLOCATE startupSplashWallPix
        startupSplashWallPix = 0
    END IF
    IF startupSplashBackImage <> 0 THEN
        ImageDestroy startupSplashBackImage
        startupSplashBackImage = 0
    END IF
    startupSplashWallW = 0
    startupSplashWallH = 0
END SUB

SUB StartupSplashSourceFileInfo(BYVAL fileName AS STRING, BYREF sizeBytes AS LONGINT, BYREF stampValue AS DOUBLE)
    DIM f AS INTEGER

    sizeBytes = 0
    stampValue = 0
    fileName = NormalizePath(TRIM$(fileName))
    IF fileName = "" THEN EXIT SUB

    f = FREEFILE
    IF OPEN(fileName FOR BINARY ACCESS READ AS #f) <> 0 THEN EXIT SUB
    sizeBytes = LOF(f)
    CLOSE #f

    stampValue = FileDateTime(fileName)
END SUB

FUNCTION BuildStartupSplashRenderedPixels(BYVAL srcPix AS UINTEGER PTR, BYVAL srcW AS INTEGER, BYVAL srcH AS INTEGER, BYVAL mode AS INTEGER) AS UINTEGER PTR
    DIM renderPix AS UINTEGER PTR
    DIM pixelCount AS LONG
    DIM i AS LONG
    DIM dstX AS INTEGER
    DIM dstY AS INTEGER
    DIM srcX AS INTEGER
    DIM srcY AS INTEGER
    DIM offX AS INTEGER
    DIM offY AS INTEGER
    DIM destW AS INTEGER
    DIM destH AS INTEGER
    DIM relX AS INTEGER
    DIM relY AS INTEGER
    DIM scaleX AS DOUBLE
    DIM scaleY AS DOUBLE
    DIM scaleUse AS DOUBLE

    BuildStartupSplashRenderedPixels = 0
    IF srcPix = 0 OR srcW <= 0 OR srcH <= 0 THEN EXIT FUNCTION
    IF SCR_W <= 0 OR SCR_H <= 0 THEN EXIT FUNCTION

    pixelCount = CLNG(SCR_W) * SCR_H
    IF pixelCount <= 0 THEN EXIT FUNCTION

    renderPix = CAST(UINTEGER PTR, ALLOCATE(pixelCount * SIZEOF(UINTEGER)))
    IF renderPix = 0 THEN EXIT FUNCTION

    FOR i = 0 TO pixelCount - 1
        renderPix[i] = COL_DESKTOP
    NEXT

    SELECT CASE mode
        CASE 1
            offX = (SCR_W - srcW) \ 2
            offY = (SCR_H - srcH) \ 2
            FOR srcY = 0 TO srcH - 1
                dstY = offY + srcY
                IF dstY >= 0 AND dstY < SCR_H THEN
                    FOR srcX = 0 TO srcW - 1
                        dstX = offX + srcX
                        IF dstX >= 0 AND dstX < SCR_W THEN
                            renderPix[CLNG(dstY) * SCR_W + dstX] = srcPix[CLNG(srcY) * srcW + srcX]
                        END IF
                    NEXT
                END IF
            NEXT

        CASE 4
            FOR dstY = 0 TO SCR_H - 1
                srcY = (CLNG(dstY) * srcH) \ SCR_H
                FOR dstX = 0 TO SCR_W - 1
                    srcX = (CLNG(dstX) * srcW) \ SCR_W
                    renderPix[CLNG(dstY) * SCR_W + dstX] = srcPix[CLNG(srcY) * srcW + srcX]
                NEXT
            NEXT

        CASE ELSE
            scaleX = CDbl(SCR_W) / CDbl(srcW)
            scaleY = CDbl(SCR_H) / CDbl(srcH)
            IF mode = 3 THEN
                IF scaleX > scaleY THEN scaleUse = scaleX ELSE scaleUse = scaleY
            ELSE
                IF scaleX < scaleY THEN scaleUse = scaleX ELSE scaleUse = scaleY
            END IF
            IF scaleUse <= 0 THEN scaleUse = 1
            destW = CINT(CDbl(srcW) * scaleUse)
            destH = CINT(CDbl(srcH) * scaleUse)
            IF destW < 1 THEN destW = 1
            IF destH < 1 THEN destH = 1
            offX = (SCR_W - destW) \ 2
            offY = (SCR_H - destH) \ 2
            FOR dstY = 0 TO SCR_H - 1
                relY = dstY - offY
                IF relY >= 0 AND relY < destH THEN
                    srcY = (CLNG(relY) * srcH) \ destH
                    FOR dstX = 0 TO SCR_W - 1
                        relX = dstX - offX
                        IF relX >= 0 AND relX < destW THEN
                            srcX = (CLNG(relX) * srcW) \ destW
                            renderPix[CLNG(dstY) * SCR_W + dstX] = srcPix[CLNG(srcY) * srcW + srcX]
                        END IF
                    NEXT
                END IF
            NEXT
    END SELECT

    BuildStartupSplashRenderedPixels = renderPix
END FUNCTION

FUNCTION LoadStartupSplashWallpaperCache(BYVAL sourcePath AS STRING, BYVAL sourceMode AS INTEGER, BYVAL sourceStamp AS DOUBLE, BYVAL sourceSize AS LONGINT) AS INTEGER
    DIM f AS INTEGER
    DIM sig AS STRING * 4
    DIM cacheSourcePath AS STRING * 260
    DIM cacheMode AS INTEGER
    DIM cacheScrW AS INTEGER
    DIM cacheScrH AS INTEGER
    DIM cacheDepth AS INTEGER
    DIM cacheSourceSize AS LONGINT
    DIM cacheSourceStamp AS DOUBLE
    DIM pixelCount AS LONG
    DIM cachePix() AS UINTEGER

    LoadStartupSplashWallpaperCache = 0
    sourcePath = LEFT$(NormalizePath(TRIM$(sourcePath)), 260)
    IF sourcePath = "" THEN EXIT FUNCTION

    f = FREEFILE
    IF OPEN(PATH_SPLASHCACHE FOR BINARY ACCESS READ AS #f) <> 0 THEN EXIT FUNCTION
    IF LOF(f) < 284 THEN
        CLOSE #f
        EXIT FUNCTION
    END IF

    GET #f, , sig
    GET #f, , cacheSourcePath
    GET #f, , cacheMode
    GET #f, , cacheScrW
    GET #f, , cacheScrH
    GET #f, , cacheDepth
    GET #f, , cacheSourceSize
    GET #f, , cacheSourceStamp

    IF sig <> "BSC1" THEN
        CLOSE #f
        EXIT FUNCTION
    END IF
    IF UCASE$(RTRIM$(cacheSourcePath)) <> UCASE$(RTRIM$(sourcePath)) THEN
        CLOSE #f
        EXIT FUNCTION
    END IF
    IF cacheMode <> sourceMode OR cacheScrW <> SCR_W OR cacheScrH <> SCR_H OR cacheDepth <> cfg.colorDepth THEN
        CLOSE #f
        EXIT FUNCTION
    END IF
    IF cacheSourceSize <> sourceSize OR cacheSourceStamp <> sourceStamp THEN
        CLOSE #f
        EXIT FUNCTION
    END IF

    pixelCount = CLNG(SCR_W) * SCR_H
    IF pixelCount <= 0 THEN
        CLOSE #f
        EXIT FUNCTION
    END IF

    REDIM cachePix(0 TO pixelCount - 1)
    GET #f, , cachePix()
    CLOSE #f

    startupSplashBackImage = BuildImageBufferFromPixels(@cachePix(0), SCR_W, SCR_H)
    IF startupSplashBackImage = 0 THEN EXIT FUNCTION
    LoadStartupSplashWallpaperCache = -1
END FUNCTION

SUB SaveStartupSplashWallpaperCache(BYVAL sourcePath AS STRING, BYVAL sourceMode AS INTEGER, BYVAL sourceStamp AS DOUBLE, BYVAL sourceSize AS LONGINT, BYVAL pix AS UINTEGER PTR, BYVAL w AS INTEGER, BYVAL h AS INTEGER)
    DIM f AS INTEGER
    DIM sig AS STRING * 4
    DIM cacheSourcePath AS STRING * 260
    DIM pixelCount AS LONG
    DIM i AS LONG
    DIM cachePix() AS UINTEGER

    IF pix = 0 OR w <= 0 OR h <= 0 THEN EXIT SUB
    IF w <> SCR_W OR h <> SCR_H THEN EXIT SUB

    pixelCount = CLNG(w) * h
    IF pixelCount <= 0 THEN EXIT SUB

    REDIM cachePix(0 TO pixelCount - 1)
    FOR i = 0 TO pixelCount - 1
        cachePix(i) = pix[i]
    NEXT

    sig = "BSC1"
    cacheSourcePath = LEFT$(NormalizePath(TRIM$(sourcePath)), 260)

    f = FREEFILE
    IF OPEN(PATH_SPLASHCACHE FOR BINARY ACCESS WRITE AS #f) <> 0 THEN EXIT SUB
    PUT #f, , sig
    PUT #f, , cacheSourcePath
    PUT #f, , sourceMode
    PUT #f, , SCR_W
    PUT #f, , SCR_H
    PUT #f, , cfg.colorDepth
    PUT #f, , sourceSize
    PUT #f, , sourceStamp
    PUT #f, , cachePix()
    CLOSE #f
END SUB

SUB LoadStartupSplashWallpaper()
    DIM modeText AS STRING
    DIM sourceSize AS LONGINT
    DIM sourceStamp AS DOUBLE
    DIM renderedPix AS UINTEGER PTR

    FreeStartupSplashWallpaper

    startupSplashWallpaperPath = NormalizePath(ReadCfgValue(PATH_SPLASHCFG, "wallpaper", "SYSTEM\SPLASH.BMP"))
    modeText = ReadCfgValue(PATH_SPLASHCFG, "mode", "fit")
    startupSplashWallpaperMode = StartupSplashModeFromText(modeText)

    IF startupSplashWallpaperPath = "" THEN EXIT SUB

    StartupSplashSourceFileInfo startupSplashWallpaperPath, sourceSize, sourceStamp
    IF sourceSize > 0 AND sourceStamp > 0 THEN
        IF LoadStartupSplashWallpaperCache(startupSplashWallpaperPath, startupSplashWallpaperMode, sourceStamp, sourceSize) <> 0 THEN EXIT SUB
    END IF

    IF LoadBmpColor(startupSplashWallpaperPath, startupSplashWallPix, startupSplashWallW, startupSplashWallH) = 0 THEN
        startupSplashWallPix = 0
        startupSplashWallW = 0
        startupSplashWallH = 0
        EXIT SUB
    END IF
    IF startupSplashWallPix = 0 OR startupSplashWallW <= 0 OR startupSplashWallH <= 0 THEN
        FreeStartupSplashWallpaper
        EXIT SUB
    END IF

    renderedPix = BuildStartupSplashRenderedPixels(startupSplashWallPix, startupSplashWallW, startupSplashWallH, startupSplashWallpaperMode)
    DEALLOCATE startupSplashWallPix
    startupSplashWallPix = 0
    startupSplashWallW = 0
    startupSplashWallH = 0
    IF renderedPix = 0 THEN EXIT SUB

    startupSplashBackImage = BuildImageBufferFromPixels(renderedPix, SCR_W, SCR_H)
    IF startupSplashBackImage <> 0 AND sourceSize > 0 AND sourceStamp > 0 THEN
        SaveStartupSplashWallpaperCache startupSplashWallpaperPath, startupSplashWallpaperMode, sourceStamp, sourceSize, renderedPix, SCR_W, SCR_H
    END IF

    DEALLOCATE renderedPix
END SUB

SUB StartupSplashStatus(BYVAL statusText AS STRING, BYVAL stepNum AS INTEGER, BYVAL stepMax AS INTEGER)
    DIM boxW AS INTEGER
    DIM boxH AS INTEGER
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER
    DIM barX1 AS INTEGER
    DIM barY1 AS INTEGER
    DIM barX2 AS INTEGER
    DIM barY2 AS INTEGER
    DIM fillX AS INTEGER
    DIM maxChars AS INTEGER
    DIM shownText AS STRING

    IF startupSplashEnabled = 0 THEN EXIT SUB
    IF SCR_W < 160 OR SCR_H < 120 THEN EXIT SUB

    IF stepMax < 1 THEN stepMax = 1
    IF stepNum < 0 THEN stepNum = 0
    IF stepNum > stepMax THEN stepNum = stepMax

    boxW = 360
    IF boxW > SCR_W - 40 THEN boxW = SCR_W - 40
    boxH = 128
    x1 = (SCR_W - boxW) \ 2
    IF SCR_H >= boxH + 64 THEN
        y1 = SCR_H - boxH - 44
    ELSE
        y1 = (SCR_H - boxH) \ 2
    END IF
    x2 = x1 + boxW
    y2 = y1 + boxH

    maxChars = (boxW - 40) \ 8
    IF maxChars < 1 THEN maxChars = 1
    shownText = LEFT$(statusText, maxChars)

    SoundServiceAt TIMER

    barX1 = x1 + 20
    barX2 = x2 - 20
    barY1 = y2 - 34
    barY2 = y2 - 22
    fillX = barX1 + ((barX2 - barX1 - 1) * stepNum) \ stepMax

    SCREENLOCK
    IF startupSplashBackImage <> 0 THEN
        PUT (0, 0), startupSplashBackImage, PSET
    ELSE
        LINE (0, 0)-(SCR_W - 1, SCR_H - 1), COL_DESKTOP, BF
    END IF
    LINE (x1, y1)-(x2, y2), COL_BUTTON, BF
    LINE (x1, y1)-(x2, y1), COL_BEVEL_HI
    LINE (x1, y1)-(x1, y2), COL_BEVEL_HI
    LINE (x1, y2)-(x2, y2), COL_BEVEL_LO
    LINE (x2, y1)-(x2, y2), COL_BEVEL_LO
    LINE (x1 + 2, y1 + 2)-(x2 - 2, y1 + 24), COL_TITLE, BF
    DRAW STRING (x1 + 12, y1 + 9), "Backlash", COL_TEXT_INV
    DRAW STRING (x1 + 20, y1 + 48), shownText, COL_TEXT
    LINE (barX1, barY1)-(barX2, barY2), COL_BEVEL_LO, B
    IF fillX > barX1 THEN LINE (barX1 + 1, barY1 + 1)-(fillX, barY2 - 1), COL_SELECT, BF
    SCREENUNLOCK
END SUB


FUNCTION StripOuterQuotes(BYVAL s AS STRING) AS STRING
    s = TRIM$(s)
    IF LEN(s) >= 2 THEN
        IF (LEFT$(s, 1) = CHR$(34) AND RIGHT$(s, 1) = CHR$(34)) OR _
           (LEFT$(s, 1) = "'" AND RIGHT$(s, 1) = "'") THEN
            s = MID$(s, 2, LEN(s) - 2)
        END IF
    END IF
    RETURN s
END FUNCTION

' ---------------------------
' App config reads and batched config writes
' ---------------------------

FUNCTION AppCfgValue(BYVAL fileName AS STRING, BYVAL keyName AS STRING, BYVAL defaultValue AS STRING) AS STRING
    DIM profileName AS STRING
    DIM profileValue AS STRING

    fileName = NormalizePath(fileName)
    profileName = LayoutProfile(fileName)
    fileName = LayoutFilePath(fileName)

    ' App/SYS launch paths usually ask for a whole group of keys at once.
    ' Load the file once here so missing profile keys do not keep reopening it.
    LoadCfgReadCacheFile fileName

    IF profileName <> "" THEN
        profileValue = ReadCfgValueInSection(fileName, profileName, keyName, CHR$(2))
        IF profileValue <> CHR$(2) THEN RETURN profileValue
    END IF

    RETURN ReadCfgValue(fileName, keyName, defaultValue)
END FUNCTION


FUNCTION ReadCfgValueInSection(BYVAL fileName AS STRING, BYVAL sectionName AS STRING, BYVAL keyName AS STRING, BYVAL defaultValue AS STRING) AS STRING
    DIM f AS INTEGER
    DIM lineIn AS STRING
    DIM p AS INTEGER
    DIM k AS STRING
    DIM v AS STRING
    DIM activeSection AS STRING
    DIM targetSection AS STRING
    DIM i AS INTEGER
    DIM cacheFile AS STRING
    DIM cacheKey AS STRING
    DIM resultValue AS STRING

    fileName = LayoutFilePath(ExpandLayoutDynamicText(fileName))
    sectionName = ExpandLayoutDynamicText(sectionName)
    keyName = ExpandLayoutDynamicText(keyName)
    cacheFile = UCASE$(NormalizePath(fileName))
    targetSection = UCASE$(TRIM$(sectionName))
    cacheKey = UCASE$(TRIM$(keyName))
    activeSection = ""

    IF cfgWriteBatchCount > 0 THEN
        FOR i = cfgWriteBatchCount TO 1 STEP -1
            IF RTRIM$(cfgWriteBatchCmpFile(i)) = cacheFile AND _
               RTRIM$(cfgWriteBatchCmpSection(i)) = targetSection AND _
               RTRIM$(cfgWriteBatchCmpKey(i)) = cacheKey THEN
                RETURN cfgWriteBatchValue(i)
            END IF
        NEXT
    END IF

    i = FindCfgReadCacheEntry(cacheFile, targetSection, cacheKey)
    IF i > 0 THEN RETURN cfgReadCacheValue(i)

    ' Patch 9: sectioned reads share the same full-file cache used by
    ' ordinary key reads. This avoids reopening APP/SYS/CFG files for each key.
    LoadCfgReadCacheFile fileName
    i = FindCfgReadCacheEntry(cacheFile, targetSection, cacheKey)
    IF i > 0 THEN RETURN cfgReadCacheValue(i)

    IF CfgReadFileAlreadyLoaded(fileName) <> 0 THEN
        AddCfgReadCacheEntry cacheFile, targetSection, cacheKey, defaultValue
        RETURN defaultValue
    END IF

    ' If the preload could not complete, keep the old one-key scan fallback.
    f = FREEFILE
    IF OPEN(fileName FOR INPUT AS #f) <> 0 THEN RETURN defaultValue

    resultValue = defaultValue

    DO WHILE NOT EOF(f)
        LINE INPUT #f, lineIn
        lineIn = TRIM$(lineIn)

        IF lineIn = "" OR LEFT$(lineIn, 1) = "#" OR LEFT$(lineIn, 1) = ";" THEN
        ELSEIF LEFT$(lineIn, 1) = "[" AND RIGHT$(lineIn, 1) = "]" THEN
            activeSection = UCASE$(TRIM$(MID$(lineIn, 2, LEN(lineIn) - 2)))
        ELSE
            IF targetSection = "" OR activeSection = targetSection THEN
                p = INSTR(lineIn, "=")
                IF p > 0 THEN
                    k = UCASE$(TRIM$(LEFT$(lineIn, p - 1)))
                    v = StripOuterQuotes(TRIM$(MID$(lineIn, p + 1)))
                    IF k = cacheKey THEN
                        resultValue = v
                        EXIT DO
                    END IF
                END IF
            END IF
        END IF
    LOOP

    CLOSE #f

    AddCfgReadCacheEntry cacheFile, targetSection, cacheKey, resultValue

    RETURN resultValue
END FUNCTION

SUB BeginCfgWriteBatch()
    cfgWriteBatchDepth = cfgWriteBatchDepth + 1
    cfgWriteBatchActive = -1
END SUB

SUB QueueCfgValueInSection(BYVAL fileName AS STRING, BYVAL sectionName AS STRING, BYVAL keyName AS STRING, BYVAL newValue AS STRING)
    DIM i AS INTEGER
    DIM normFile AS STRING
    DIM cmpFile AS STRING
    DIM cmpSection AS STRING
    DIM cmpKey AS STRING

    IF cfgWriteBatchActive = 0 THEN
        SetCfgValueInSectionDirect fileName, sectionName, keyName, newValue
        EXIT SUB
    END IF

    normFile = NormalizePath(fileName)
    cmpFile = UCASE$(NormalizePath(LayoutFilePath(normFile)))
    cmpSection = UCASE$(TRIM$(sectionName))
    cmpKey = UCASE$(TRIM$(keyName))
    IF cmpFile = "" OR cmpKey = "" THEN EXIT SUB

    FOR i = 1 TO cfgWriteBatchCount
        IF RTRIM$(cfgWriteBatchCmpFile(i)) = cmpFile AND _
           RTRIM$(cfgWriteBatchCmpSection(i)) = cmpSection AND _
           RTRIM$(cfgWriteBatchCmpKey(i)) = cmpKey THEN
            cfgWriteBatchValue(i) = newValue
            EXIT SUB
        END IF
    NEXT

    IF cfgWriteBatchCount >= 256 THEN
        SetCfgValueInSectionDirect fileName, sectionName, keyName, newValue
        EXIT SUB
    END IF

    cfgWriteBatchCount = cfgWriteBatchCount + 1
    cfgWriteBatchFile(cfgWriteBatchCount) = normFile
    cfgWriteBatchSection(cfgWriteBatchCount) = TRIM$(sectionName)
    cfgWriteBatchKey(cfgWriteBatchCount) = TRIM$(keyName)
    cfgWriteBatchValue(cfgWriteBatchCount) = newValue
    cfgWriteBatchCmpFile(cfgWriteBatchCount) = cmpFile
    cfgWriteBatchCmpSection(cfgWriteBatchCount) = cmpSection
    cfgWriteBatchCmpKey(cfgWriteBatchCount) = cmpKey
END SUB
SUB FlushCfgWriteBatch()
    DIM batchIdx AS INTEGER
    DIM entryIdx AS INTEGER
    DIM prevIdx AS INTEGER
    DIM alreadyDone AS INTEGER
    DIM sameFile AS INTEGER
    DIM fileName AS STRING
    DIM fileLines(1 TO 2048) AS STRING
    DIM lineCount AS INTEGER
    DIM f AS INTEGER
    DIM lineIn AS STRING
    DIM i AS INTEGER
    DIM secStart AS INTEGER
    DIM secEnd AS INTEGER
    DIM keyLine AS INTEGER
    DIM curSection AS STRING
    DIM s AS STRING
    DIM p AS INTEGER
    DIM k AS STRING
    DIM targetSection AS STRING
    DIM targetKey AS STRING
    DIM insertPos AS INTEGER
    DIM uniqueFileCount AS INTEGER
    DIM uniqueFileFirstIdx(1 TO 256) AS INTEGER
    DIM uniqueIdx AS INTEGER

    IF cfgWriteBatchDepth > 0 THEN
        cfgWriteBatchDepth = cfgWriteBatchDepth - 1
        IF cfgWriteBatchDepth > 0 THEN EXIT SUB
    END IF

    IF cfgWriteBatchCount <= 0 THEN
        cfgWriteBatchActive = 0
        EXIT SUB
    END IF

    cfgWriteBatchActive = 0

    uniqueFileCount = 0
    FOR batchIdx = 1 TO cfgWriteBatchCount
        fileName = RTRIM$(cfgWriteBatchFile(batchIdx))
        IF fileName <> "" THEN
            alreadyDone = 0
            FOR prevIdx = 1 TO uniqueFileCount
                IF RTRIM$(cfgWriteBatchCmpFile(uniqueFileFirstIdx(prevIdx))) = RTRIM$(cfgWriteBatchCmpFile(batchIdx)) THEN
                    alreadyDone = -1
                    EXIT FOR
                END IF
            NEXT

            IF alreadyDone = 0 THEN
                IF uniqueFileCount < 256 THEN
                    uniqueFileCount = uniqueFileCount + 1
                    uniqueFileFirstIdx(uniqueFileCount) = batchIdx
                END IF
            END IF
        END IF
    NEXT

    FOR uniqueIdx = 1 TO uniqueFileCount
        batchIdx = uniqueFileFirstIdx(uniqueIdx)
        fileName = RTRIM$(cfgWriteBatchFile(batchIdx))
        IF fileName <> "" THEN
            lineCount = 0
            f = FREEFILE
            IF OPEN(fileName FOR INPUT AS #f) = 0 THEN
                DO WHILE NOT EOF(f)
                    LINE INPUT #f, lineIn
                    IF lineCount < 2048 THEN
                        lineCount = lineCount + 1
                        fileLines(lineCount) = lineIn
                    END IF
                LOOP
                CLOSE #f
            END IF

            FOR entryIdx = 1 TO cfgWriteBatchCount
                sameFile = 0
                IF RTRIM$(cfgWriteBatchCmpFile(entryIdx)) = RTRIM$(cfgWriteBatchCmpFile(batchIdx)) THEN sameFile = -1
                IF sameFile <> 0 THEN
                    targetSection = RTRIM$(cfgWriteBatchCmpSection(entryIdx))
                    targetKey = RTRIM$(cfgWriteBatchCmpKey(entryIdx))

                    IF targetSection = "" THEN
                        keyLine = 0
                        FOR i = 1 TO lineCount
                            s = TRIM$(fileLines(i))
                            IF s <> "" AND LEFT$(s, 1) <> "#" AND LEFT$(s, 1) <> ";" THEN
                                p = INSTR(s, "=")
                                IF p > 0 THEN
                                    k = UCASE$(TRIM$(LEFT$(s, p - 1)))
                                    IF k = targetKey THEN
                                        keyLine = i
                                        EXIT FOR
                                    END IF
                                END IF
                            END IF
                        NEXT

                        IF keyLine <> 0 THEN
                            fileLines(keyLine) = TRIM$(RTRIM$(cfgWriteBatchKey(entryIdx))) + "=" + cfgWriteBatchValue(entryIdx)
                        ELSE
                            IF lineCount > 0 THEN
                                IF TRIM$(fileLines(lineCount)) <> "" THEN
                                    IF lineCount < 2048 THEN
                                        lineCount = lineCount + 1
                                        fileLines(lineCount) = ""
                                    END IF
                                END IF
                            END IF
                            IF lineCount < 2048 THEN
                                lineCount = lineCount + 1
                                fileLines(lineCount) = TRIM$(RTRIM$(cfgWriteBatchKey(entryIdx))) + "=" + cfgWriteBatchValue(entryIdx)
                            END IF
                        END IF
                    ELSE
                        secStart = 0
                        secEnd = lineCount + 1
                        keyLine = 0
                        curSection = ""

                        FOR i = 1 TO lineCount
                            s = TRIM$(fileLines(i))
                            IF LEFT$(s, 1) = "[" AND RIGHT$(s, 1) = "]" THEN
                                curSection = UCASE$(TRIM$(MID$(s, 2, LEN(s) - 2)))
                                IF secStart <> 0 AND secEnd = lineCount + 1 AND curSection <> targetSection THEN
                                    secEnd = i
                                END IF
                                IF curSection = targetSection AND secStart = 0 THEN
                                    secStart = i
                                END IF
                            ELSEIF secStart <> 0 AND secEnd = lineCount + 1 THEN
                                p = INSTR(s, "=")
                                IF p > 0 THEN
                                    k = UCASE$(TRIM$(LEFT$(s, p - 1)))
                                    IF k = targetKey THEN
                                        keyLine = i
                                    END IF
                                END IF
                            END IF
                        NEXT

                        IF secStart = 0 THEN
                            IF lineCount > 0 THEN
                                IF TRIM$(fileLines(lineCount)) <> "" THEN
                                    IF lineCount < 2048 THEN
                                        lineCount = lineCount + 1
                                        fileLines(lineCount) = ""
                                    END IF
                                END IF
                            END IF
                            IF lineCount < 2047 THEN
                                lineCount = lineCount + 1
                                fileLines(lineCount) = "[" + TRIM$(RTRIM$(cfgWriteBatchSection(entryIdx))) + "]"
                                lineCount = lineCount + 1
                                fileLines(lineCount) = TRIM$(RTRIM$(cfgWriteBatchKey(entryIdx))) + "=" + cfgWriteBatchValue(entryIdx)
                            END IF
                        ELSEIF keyLine <> 0 THEN
                            fileLines(keyLine) = TRIM$(RTRIM$(cfgWriteBatchKey(entryIdx))) + "=" + cfgWriteBatchValue(entryIdx)
                        ELSE
                            insertPos = secEnd
                            IF insertPos < 1 THEN insertPos = lineCount + 1
                            IF insertPos > lineCount + 1 THEN insertPos = lineCount + 1

                            IF lineCount < 2048 THEN
                                FOR i = lineCount TO insertPos STEP -1
                                    fileLines(i + 1) = fileLines(i)
                                NEXT
                                fileLines(insertPos) = TRIM$(RTRIM$(cfgWriteBatchKey(entryIdx))) + "=" + cfgWriteBatchValue(entryIdx)
                                lineCount = lineCount + 1
                            END IF
                        END IF
                    END IF
                END IF
            NEXT

            f = FREEFILE
            IF OPEN(fileName FOR OUTPUT AS #f) = 0 THEN
                FOR i = 1 TO lineCount
                    PRINT #f, fileLines(i)
                NEXT
                CLOSE #f
                InvalidateCfgReadCacheForFile fileName
            END IF
        END IF
    NEXT

    FOR i = 1 TO cfgWriteBatchCount
        cfgWriteBatchFile(i) = ""
        cfgWriteBatchSection(i) = ""
        cfgWriteBatchKey(i) = ""
        cfgWriteBatchValue(i) = ""
        cfgWriteBatchCmpFile(i) = ""
        cfgWriteBatchCmpSection(i) = ""
        cfgWriteBatchCmpKey(i) = ""
    NEXT
    cfgWriteBatchCount = 0
END SUB

SUB SetCfgValueInSection(BYVAL fileName AS STRING, BYVAL sectionName AS STRING, BYVAL keyName AS STRING, BYVAL newValue AS STRING)
    fileName = ExpandLayoutDynamicText(fileName)
    sectionName = ExpandLayoutDynamicText(sectionName)
    keyName = ExpandLayoutDynamicText(keyName)
    IF cfgWriteBatchActive <> 0 THEN
        QueueCfgValueInSection fileName, sectionName, keyName, newValue
    ELSE
        SetCfgValueInSectionDirect fileName, sectionName, keyName, newValue
    END IF
END SUB

SUB SetCfgValueInSectionDirect(BYVAL fileName AS STRING, BYVAL sectionName AS STRING, BYVAL keyName AS STRING, BYVAL newValue AS STRING)
    DIM fileLines(1 TO 2048) AS STRING
    DIM lineCount AS INTEGER
    DIM f AS INTEGER
    DIM lineIn AS STRING
    DIM i AS INTEGER
    DIM secStart AS INTEGER
    DIM secEnd AS INTEGER
    DIM keyLine AS INTEGER
    DIM curSection AS STRING
    DIM s AS STRING
    DIM p AS INTEGER
    DIM k AS STRING
    DIM targetSection AS STRING
    DIM insertPos AS INTEGER

    fileName = NormalizePath(fileName)
    InvalidateCfgReadCacheForFile fileName
    targetSection = UCASE$(TRIM$(sectionName))
    lineCount = 0

    f = FREEFILE
    IF OPEN(fileName FOR INPUT AS #f) = 0 THEN
        DO WHILE NOT EOF(f)
            LINE INPUT #f, lineIn
            IF lineCount < 2048 THEN
                lineCount = lineCount + 1
                fileLines(lineCount) = lineIn
            END IF
        LOOP
        CLOSE #f
    END IF

    IF targetSection = "" THEN
        keyLine = 0
        FOR i = 1 TO lineCount
            s = TRIM$(fileLines(i))
            IF s <> "" AND LEFT$(s, 1) <> "#" AND LEFT$(s, 1) <> ";" THEN
                p = INSTR(s, "=")
                IF p > 0 THEN
                    k = UCASE$(TRIM$(LEFT$(s, p - 1)))
                    IF k = UCASE$(keyName) THEN
                        keyLine = i
                        EXIT FOR
                    END IF
                END IF
            END IF
        NEXT

        IF keyLine <> 0 THEN
            fileLines(keyLine) = keyName + "=" + newValue
        ELSE
            IF lineCount > 0 THEN
                IF TRIM$(fileLines(lineCount)) <> "" THEN
                    IF lineCount < 2048 THEN
                        lineCount = lineCount + 1
                        fileLines(lineCount) = ""
                    END IF
                END IF
            END IF
            IF lineCount < 2048 THEN
                lineCount = lineCount + 1
                fileLines(lineCount) = keyName + "=" + newValue
            END IF
        END IF

        f = FREEFILE
        IF OPEN(fileName FOR OUTPUT AS #f) <> 0 THEN EXIT SUB
        FOR i = 1 TO lineCount
            PRINT #f, fileLines(i)
        NEXT
        CLOSE #f
        EXIT SUB
    END IF

    secStart = 0
    secEnd = lineCount + 1
    keyLine = 0
    curSection = ""

    FOR i = 1 TO lineCount
        s = TRIM$(fileLines(i))
        IF LEFT$(s, 1) = "[" AND RIGHT$(s, 1) = "]" THEN
            curSection = UCASE$(TRIM$(MID$(s, 2, LEN(s) - 2)))
            IF secStart <> 0 AND secEnd = lineCount + 1 AND curSection <> targetSection THEN
                secEnd = i
            END IF
            IF curSection = targetSection AND secStart = 0 THEN
                secStart = i
            END IF
        ELSEIF secStart <> 0 AND secEnd = lineCount + 1 THEN
            p = INSTR(s, "=")
            IF p > 0 THEN
                k = UCASE$(TRIM$(LEFT$(s, p - 1)))
                IF k = UCASE$(keyName) THEN
                    keyLine = i
                END IF
            END IF
        END IF
    NEXT

    IF secStart = 0 THEN
        IF lineCount > 0 THEN
            IF TRIM$(fileLines(lineCount)) <> "" THEN
                IF lineCount < 2048 THEN
                    lineCount = lineCount + 1
                    fileLines(lineCount) = ""
                END IF
            END IF
        END IF
        IF lineCount < 2047 THEN
            lineCount = lineCount + 1
            fileLines(lineCount) = "[" + sectionName + "]"
            lineCount = lineCount + 1
            fileLines(lineCount) = keyName + "=" + newValue
        END IF
    ELSEIF keyLine <> 0 THEN
        fileLines(keyLine) = keyName + "=" + newValue
    ELSE
        insertPos = secEnd
        IF insertPos < 1 THEN insertPos = lineCount + 1
        IF insertPos > lineCount + 1 THEN insertPos = lineCount + 1

        IF lineCount < 2048 THEN
            FOR i = lineCount TO insertPos STEP -1
                fileLines(i + 1) = fileLines(i)
            NEXT
            fileLines(insertPos) = keyName + "=" + newValue
            lineCount = lineCount + 1
        END IF
    END IF

    f = FREEFILE
    IF OPEN(fileName FOR OUTPUT AS #f) <> 0 THEN EXIT SUB
    FOR i = 1 TO lineCount
        PRINT #f, fileLines(i)
    NEXT
    CLOSE #f
END SUB

' ---------------------------
' Preview bitmap cache and combo/list item cache
' ---------------------------

SUB ClearPreviewDimensionCache()
    previewDimCachePath = ""
    previewDimCacheW = 0
    previewDimCacheH = 0
    previewDimCacheValid = 0
END SUB

SUB FreePreviewBitmap()
    IF previewImg <> 0 THEN
        ImageDestroy previewImg
        previewImg = 0
    END IF
    IF previewPix <> 0 THEN
        DEALLOCATE previewPix
        previewPix = 0
    END IF
    previewW = 0
    previewH = 0
    previewImgW = 0
    previewImgH = 0
    previewLoaded = 0
    previewPath = ""
END SUB

SUB EnsurePreviewBitmap(BYVAL bmpPath AS STRING, BYVAL maxW AS INTEGER, BYVAL maxH AS INTEGER)
    DIM normPath AS STRING
    DIM cacheKey AS STRING

    normPath = NormalizePath(bmpPath)
    IF normPath = "" THEN
        FreePreviewBitmap
        ClearPreviewDimensionCache
        EXIT SUB
    END IF

    IF maxW < 1 THEN maxW = 1
    IF maxH < 1 THEN maxH = 1

    cacheKey = normPath + "|" + LTRIM$(STR$(maxW)) + "x" + LTRIM$(STR$(maxH))

    IF previewLoaded <> 0 AND previewPix <> 0 THEN
        IF previewPath = cacheKey THEN EXIT SUB
    END IF

    FreePreviewBitmap

    IF LoadBmpColorSampled(normPath, previewPix, previewW, previewH, maxW, maxH) = 0 THEN
        IF previewPix <> 0 THEN
            DEALLOCATE previewPix
            previewPix = 0
        END IF
        previewW = 0
        previewH = 0
        IF LoadBmpColor(normPath, previewPix, previewW, previewH) = 0 THEN EXIT SUB
    END IF
    IF previewPix = 0 OR previewW < 1 OR previewH < 1 THEN
        FreePreviewBitmap
        EXIT SUB
    END IF

    previewImg = BuildScaledImageBufferFromPixels(previewPix, previewW, previewH, maxW, maxH)
    IF previewImg = 0 THEN
        FreePreviewBitmap
        EXIT SUB
    END IF
    previewImgW = maxW
    previewImgH = maxH

    previewLoaded = -1
    previewPath = cacheKey
END SUB


FUNCTION BuildSourceItemsFromTemp() AS STRING
    DIM i AS INTEGER
    DIM spec AS STRING
    DIM itemText AS STRING
    DIM itemValue AS STRING

    spec = ""
    FOR i = 1 TO tempComboItemCount
        itemText = RTRIM$(tempComboItems(i))
        itemValue = RTRIM$(tempComboValues(i))
        IF itemText <> "" THEN
            IF spec <> "" THEN spec = spec + "|"
            spec = spec + itemText + CHR$(1) + itemValue
            IF LEN(spec) > 30000 THEN EXIT FOR
        END IF
    NEXT

    RETURN spec
END FUNCTION


SUB ClearTempComboItems()
    DIM itemIdx AS INTEGER
    DIM oldCount AS INTEGER

    ' Temporary combo/list buffers now use dynamic strings. Clear the active
    ' scratch entries before rebuilding so old item/value text releases heap
    ' storage instead of staying resident after the next control is built.
    oldCount = tempComboItemCount
    IF oldCount < 0 THEN oldCount = 0
    IF oldCount > 256 THEN oldCount = 256
    FOR itemIdx = 1 TO oldCount
        tempComboItems(itemIdx) = ""
        tempComboValues(itemIdx) = ""
    NEXT
    tempComboItemCount = 0
    tempComboCacheKey = ""
END SUB


' Clears cached combo/list contents so file-backed controls reload current data.
SUB ClearComboItemCache()
    DIM slotIdx AS INTEGER
    DIM itemIdx AS INTEGER
    DIM oldCount AS INTEGER

    ' Combo/list cache entries now use dynamic strings instead of fixed 260-byte
    ' cells. Clear only active cached item/value strings so invalidation also
    ' releases their heap storage without sweeping unused empty slots.
    FOR slotIdx = 1 TO 16
        oldCount = comboItemCacheCount(slotIdx)
        IF oldCount < 0 THEN oldCount = 0
        IF oldCount > 256 THEN oldCount = 256
        FOR itemIdx = 1 TO oldCount
            comboItemCacheItems(slotIdx, itemIdx) = ""
            comboItemCacheValues(slotIdx, itemIdx) = ""
            comboItemCacheDivider(slotIdx, itemIdx) = 0
        NEXT
        comboItemCacheValid(slotIdx) = 0
        comboItemCacheKeyText(slotIdx) = ""
        comboItemCacheCount(slotIdx) = 0
        comboItemCacheAge(slotIdx) = 0
    NEXT
    comboItemCacheClock = 0
    ClearTempComboItems
    ClearFilePaneMetadataCache
    ClearDirectoryStatsCache
END SUB

' Builds the cache key used to decide whether a combo or list source must be rebuilt.
FUNCTION ComboItemCacheKey(BYVAL elemIdx AS INTEGER) AS STRING
    DIM winIdx AS INTEGER
    DIM effDir AS STRING
    DIM effMask AS STRING
    DIM effMaskKey AS STRING
    DIM effSourceKind AS STRING
    DIM keyText AS STRING

    IF elemIdx < 1 OR elemIdx > uiCount THEN RETURN ""

    winIdx = drawLayoutWindow
    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN winIdx = activeLayoutWindow
    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN winIdx = 0

    effDir = TRIM$(uiElems(elemIdx).sourceDir)
    effMask = TRIM$(uiElems(elemIdx).sourceMask)
    effMaskKey = UCASE$(effMask)
    effSourceKind = uiElems(elemIdx).sourceKindKey

    IF effSourceKind <> "" THEN
        IF effDir = "" THEN effDir = TRIM$(fileDlgDir)
        IF effDir = "" THEN effDir = "."
    END IF

    keyText = "W=" + STR$(winIdx)
    keyText = keyText + ";APP="
    IF winIdx >= LBOUND(layoutWindows) AND winIdx <= UBOUND(layoutWindows) THEN
        IF layoutWindows(winIdx).used <> 0 THEN keyText = keyText + UCASE$(NormalizePath(RTRIM$(layoutWindows(winIdx).appPath)))
    END IF
    keyText = keyText + ";E=" + STR$(elemIdx)
    keyText = keyText + ";K=" + uiElems(elemIdx).kindKey
    keyText = keyText + ";WID=" + STR$(uiElems(elemIdx).w)
    keyText = keyText + ";DIR=" + UCASE$(NormalizePath(effDir))
    keyText = keyText + ";MASK=" + effMaskKey
    keyText = keyText + ";SK=" + effSourceKind
    keyText = keyText + ";INDEX=" + UCASE$(ExpandSourceIndexPath(uiElems(elemIdx).sourceIndex, LayoutSelectedDepthValue()))
    keyText = keyText + ";ITEMS=" + uiElems(elemIdx).sourceItems
    keyText = keyText + ";DEPTH=" + STR$(LayoutSelectedDepthValue())
    keyText = keyText + ";CD=" + STR$(cfg.colorDepth)

    RETURN keyText
END FUNCTION

FUNCTION LoadComboItemsFromCache(BYVAL elemIdx AS INTEGER, BYVAL cacheKey AS STRING) AS INTEGER
    DIM slotIdx AS INTEGER
    DIM itemIdx AS INTEGER

    IF cacheKey = "" THEN RETURN 0

    FOR slotIdx = 1 TO 16
        IF comboItemCacheValid(slotIdx) <> 0 THEN
            IF comboItemCacheKeyText(slotIdx) = cacheKey THEN
                tempComboItemCount = comboItemCacheCount(slotIdx)
                IF tempComboItemCount < 0 THEN tempComboItemCount = 0
                IF tempComboItemCount > 256 THEN tempComboItemCount = 256
                FOR itemIdx = 1 TO tempComboItemCount
                    tempComboItems(itemIdx) = comboItemCacheItems(slotIdx, itemIdx)
                    tempComboValues(itemIdx) = comboItemCacheValues(slotIdx, itemIdx)
                NEXT
                comboItemCacheClock = comboItemCacheClock + 1
                comboItemCacheAge(slotIdx) = comboItemCacheClock
                tempComboCacheKey = cacheKey
                RETURN -1
            END IF
        END IF
    NEXT

    RETURN 0
END FUNCTION

FUNCTION FindComboItemCacheSlot(BYVAL cacheKey AS STRING) AS INTEGER
    DIM slotIdx AS INTEGER

    IF cacheKey = "" THEN RETURN 0

    FOR slotIdx = 1 TO 16
        IF comboItemCacheValid(slotIdx) <> 0 THEN
            IF comboItemCacheKeyText(slotIdx) = cacheKey THEN
                comboItemCacheClock = comboItemCacheClock + 1
                comboItemCacheAge(slotIdx) = comboItemCacheClock
                RETURN slotIdx
            END IF
        END IF
    NEXT

    RETURN 0
END FUNCTION

FUNCTION EnsureComboItemCacheSlot(BYVAL elemIdx AS INTEGER) AS INTEGER
    DIM cacheKey AS STRING
    DIM slotIdx AS INTEGER

    IF elemIdx < 1 OR elemIdx > uiCount THEN RETURN 0

    cacheKey = ComboItemCacheKey(elemIdx)
    IF cacheKey = "" THEN RETURN 0

    slotIdx = FindComboItemCacheSlot(cacheKey)
    IF slotIdx <> 0 THEN RETURN slotIdx

    BuildComboItems elemIdx
    RETURN FindComboItemCacheSlot(cacheKey)
END FUNCTION

FUNCTION ComboFastItemCount(BYVAL elemIdx AS INTEGER, BYREF cacheSlotOut AS INTEGER) AS INTEGER
    cacheSlotOut = EnsureComboItemCacheSlot(elemIdx)
    IF cacheSlotOut > 0 THEN RETURN comboItemCacheCount(cacheSlotOut)

    BuildComboItems elemIdx
    cacheSlotOut = 0
    RETURN tempComboItemCount
END FUNCTION

FUNCTION ComboFastItemText(BYVAL cacheSlot AS INTEGER, BYVAL itemIdx AS INTEGER) AS STRING
    IF cacheSlot > 0 THEN
        IF itemIdx >= 1 AND itemIdx <= comboItemCacheCount(cacheSlot) THEN RETURN RTRIM$(comboItemCacheItems(cacheSlot, itemIdx))
        RETURN ""
    END IF
    IF itemIdx >= 1 AND itemIdx <= tempComboItemCount THEN RETURN RTRIM$(tempComboItems(itemIdx))
    RETURN ""
END FUNCTION

FUNCTION ComboFastItemValue(BYVAL cacheSlot AS INTEGER, BYVAL itemIdx AS INTEGER) AS STRING
    IF cacheSlot > 0 THEN
        IF itemIdx >= 1 AND itemIdx <= comboItemCacheCount(cacheSlot) THEN RETURN RTRIM$(comboItemCacheValues(cacheSlot, itemIdx))
        RETURN ""
    END IF
    IF itemIdx >= 1 AND itemIdx <= tempComboItemCount THEN RETURN RTRIM$(tempComboValues(itemIdx))
    RETURN ""
END FUNCTION

SUB StoreComboItemsInCache(BYVAL elemIdx AS INTEGER, BYVAL cacheKey AS STRING)
    DIM slotIdx AS INTEGER
    DIM itemIdx AS INTEGER
    DIM bestSlot AS INTEGER
    DIM bestAge AS LONG
    DIM oldCount AS INTEGER

    IF cacheKey = "" THEN EXIT SUB
    IF tempComboItemCount < 0 THEN tempComboItemCount = 0
    IF tempComboItemCount > 256 THEN tempComboItemCount = 256

    bestSlot = 0
    FOR slotIdx = 1 TO 16
        IF comboItemCacheValid(slotIdx) <> 0 THEN
            IF comboItemCacheKeyText(slotIdx) = cacheKey THEN
                bestSlot = slotIdx
                EXIT FOR
            END IF
        ELSEIF bestSlot = 0 THEN
            bestSlot = slotIdx
        END IF
    NEXT

    IF bestSlot = 0 THEN
        bestSlot = 1
        bestAge = comboItemCacheAge(1)
        FOR slotIdx = 2 TO 16
            IF comboItemCacheAge(slotIdx) < bestAge THEN
                bestAge = comboItemCacheAge(slotIdx)
                bestSlot = slotIdx
            END IF
        NEXT
    END IF

    oldCount = comboItemCacheCount(bestSlot)
    IF oldCount < 0 THEN oldCount = 0
    IF oldCount > 256 THEN oldCount = 256

    comboItemCacheClock = comboItemCacheClock + 1
    comboItemCacheValid(bestSlot) = -1
    comboItemCacheKeyText(bestSlot) = cacheKey
    comboItemCacheCount(bestSlot) = tempComboItemCount
    comboItemCacheAge(bestSlot) = comboItemCacheClock

    FOR itemIdx = 1 TO tempComboItemCount
        comboItemCacheItems(bestSlot, itemIdx) = tempComboItems(itemIdx)
        comboItemCacheValues(bestSlot, itemIdx) = tempComboValues(itemIdx)
        comboItemCacheDivider(bestSlot, itemIdx) = ComboDividerFlagFromText(tempComboItems(itemIdx), tempComboValues(itemIdx))
    NEXT
    FOR itemIdx = tempComboItemCount + 1 TO oldCount
        comboItemCacheItems(bestSlot, itemIdx) = ""
        comboItemCacheValues(bestSlot, itemIdx) = ""
        comboItemCacheDivider(bestSlot, itemIdx) = 0
    NEXT
    tempComboCacheKey = cacheKey
END SUB


FUNCTION ExpandSourceIndexPath(BYVAL indexPath AS STRING, BYVAL depthVal AS INTEGER) AS STRING
    DIM resultText AS STRING
    DIM depthText AS STRING
    DIM p AS INTEGER

    resultText = NormalizePath(TRIM$(indexPath))
    IF resultText = "" THEN RETURN ""

    depthText = LTRIM$(STR$(depthVal))
    DIM folderText AS STRING
    folderText = LayoutDepthFolderName(depthVal)

    p = INSTR(UCASE$(resultText), "%COLORDEPTH%")
    DO WHILE p > 0
        resultText = LEFT$(resultText, p - 1) + depthText + MID$(resultText, p + 12)
        p = INSTR(UCASE$(resultText), "%COLORDEPTH%")
    LOOP

    p = INSTR(UCASE$(resultText), "%DEPTH%")
    DO WHILE p > 0
        resultText = LEFT$(resultText, p - 1) + depthText + MID$(resultText, p + 7)
        p = INSTR(UCASE$(resultText), "%DEPTH%")
    LOOP

    p = INSTR(UCASE$(resultText), "$COLORDEPTH")
    DO WHILE p > 0
        resultText = LEFT$(resultText, p - 1) + depthText + MID$(resultText, p + 11)
        p = INSTR(UCASE$(resultText), "$COLORDEPTH")
    LOOP

    p = INSTR(UCASE$(resultText), "$DEPTH")
    DO WHILE p > 0
        resultText = LEFT$(resultText, p - 1) + depthText + MID$(resultText, p + 6)
        p = INSTR(UCASE$(resultText), "$DEPTH")
    LOOP

    RETURN NormalizePath(resultText)
END FUNCTION

FUNCTION LoadComboItemsFromIndex(BYVAL elemIdx AS INTEGER, BYVAL indexPath AS STRING) AS INTEGER
    DIM f AS INTEGER
    DIM rawLine AS STRING
    DIM lineText AS STRING
    DIM itemText AS STRING
    DIM itemValue AS STRING
    DIM sepPos AS INTEGER
    DIM eqPos AS INTEGER

    IF elemIdx < 1 OR elemIdx > uiCount THEN RETURN 0
    indexPath = NormalizePath(TRIM$(indexPath))
    IF indexPath = "" THEN RETURN 0
    IF DIR(indexPath) = "" THEN RETURN 0

    ClearTempComboItems
    f = FREEFILE
    IF OPEN(indexPath FOR INPUT AS #f) <> 0 THEN RETURN 0

    DO WHILE EOF(f) = 0 AND tempComboItemCount < 256
        LINE INPUT #f, rawLine
        lineText = TRIM$(rawLine)
        IF lineText <> "" THEN
            IF LEFT$(lineText, 1) <> ";" AND LEFT$(lineText, 1) <> "#" THEN
                itemText = lineText
                itemValue = lineText
                sepPos = INSTR(lineText, "|")
                eqPos = INSTR(lineText, "=")
                IF sepPos > 0 THEN
                    itemText = TRIM$(LEFT$(lineText, sepPos - 1))
                    itemValue = TRIM$(MID$(lineText, sepPos + 1))
                ELSEIF eqPos > 0 THEN
                    itemText = TRIM$(LEFT$(lineText, eqPos - 1))
                    itemValue = TRIM$(MID$(lineText, eqPos + 1))
                END IF

                IF itemText <> "" THEN
                    tempComboItemCount = tempComboItemCount + 1
                    tempComboItems(tempComboItemCount) = itemText
                    tempComboValues(tempComboItemCount) = itemValue
                END IF
            END IF
        END IF
    LOOP

    CLOSE #f

    IF tempComboItemCount > 0 THEN RETURN -1
    RETURN 0
END FUNCTION

SUB StoreComboItemsToIndex(BYVAL indexPath AS STRING)
    DIM f AS INTEGER
    DIM i AS INTEGER
    DIM parentDir AS STRING

    indexPath = NormalizePath(TRIM$(indexPath))
    IF indexPath = "" THEN EXIT SUB

    parentDir = ParentPath(indexPath)
    IF parentDir <> "" THEN EnsureDirectoryExists parentDir

    f = FREEFILE
    IF OPEN(indexPath FOR OUTPUT AS #f) <> 0 THEN EXIT SUB
    FOR i = 1 TO tempComboItemCount
        IF RTRIM$(tempComboItems(i)) <> "" THEN
            PRINT #f, RTRIM$(tempComboItems(i)) + "|" + RTRIM$(tempComboValues(i))
        END IF
    NEXT
    CLOSE #f
END SUB


' Sorts temporary combo/list items before the control displays them.
SUB SortTempComboItems(BYVAL firstIdx AS INTEGER, BYVAL lastIdx AS INTEGER)
    DIM gapSize AS INTEGER
    DIM itemIdx AS INTEGER
    DIM moveIdx AS INTEGER
    DIM sortItem AS STRING
    DIM sortValue AS STRING
    DIM sortKey AS STRING
    DIM sortKeys(1 TO 256) AS STRING

    IF firstIdx < 1 THEN firstIdx = 1
    IF lastIdx > tempComboItemCount THEN lastIdx = tempComboItemCount
    IF lastIdx <= firstIdx THEN EXIT SUB

    FOR itemIdx = firstIdx TO lastIdx
        sortKeys(itemIdx) = UCASE$(RTRIM$(tempComboItems(itemIdx)))
    NEXT

    gapSize = (lastIdx - firstIdx + 1) \ 2
    DO WHILE gapSize > 0
        FOR itemIdx = firstIdx + gapSize TO lastIdx
            sortItem = tempComboItems(itemIdx)
            sortValue = tempComboValues(itemIdx)
            sortKey = sortKeys(itemIdx)
            moveIdx = itemIdx

            DO WHILE moveIdx - gapSize >= firstIdx
                IF sortKeys(moveIdx - gapSize) <= sortKey THEN EXIT DO

                tempComboItems(moveIdx) = tempComboItems(moveIdx - gapSize)
                tempComboValues(moveIdx) = tempComboValues(moveIdx - gapSize)
                sortKeys(moveIdx) = sortKeys(moveIdx - gapSize)
                moveIdx = moveIdx - gapSize
            LOOP

            tempComboItems(moveIdx) = sortItem
            tempComboValues(moveIdx) = sortValue
            sortKeys(moveIdx) = sortKey
        NEXT
        gapSize = gapSize \ 2
    LOOP
END SUB

' Builds the item list for a combo box from inline entries, folders, or index files.
SUB BuildComboItems(BYVAL elemIdx AS INTEGER)
    DIM pattern AS STRING
    DIM fname AS STRING
    DIM i AS INTEGER
    DIM itemsSpec AS STRING
    DIM itemSpec AS STRING
    DIM sepPos AS INTEGER
    DIM eqPos AS INTEGER
    DIM sepChrPos AS INTEGER
    DIM sourceKind AS STRING
    DIM sourceMaskText AS STRING
    DIM sourceMaskKey AS STRING
    DIM explorerSourceFlag AS INTEGER
    DIM dirName AS STRING
    DIM parentName AS STRING
    DIM pathCaption AS STRING
    DIM dirFull AS STRING
    DIM fileFull AS STRING
    DIM sortStart AS INTEGER
    DIM dirCandidates(1 TO 256) AS STRING
    DIM dirCandidateCount AS INTEGER
    DIM dirAttr AS INTEGER
    DIM navFileAttr AS INTEGER
    DIM navFileSize AS LONGINT
    DIM navFileDateText AS STRING
    DIM includeFile AS INTEGER
    DIM comboCacheKeyText AS STRING
    DIM sourceIndexPath AS STRING
    DIM usedSourceIndex AS INTEGER

    IF elemIdx < 1 OR elemIdx > uiCount THEN EXIT SUB
    IF uiElems(elemIdx).kindKey <> "COMBO" AND uiElems(elemIdx).kindKey <> "LISTBOX" THEN EXIT SUB

    comboCacheKeyText = ComboItemCacheKey(elemIdx)
    IF comboCacheKeyText <> "" THEN
        IF tempComboCacheKey = comboCacheKeyText AND tempComboItemCount > 0 THEN EXIT SUB
    END IF

    ClearTempComboItems
    IF LoadComboItemsFromCache(elemIdx, comboCacheKeyText) <> 0 THEN EXIT SUB

    sourceIndexPath = ExpandSourceIndexPath(uiElems(elemIdx).sourceIndex, LayoutSelectedDepthValue())
    usedSourceIndex = 0
    IF sourceIndexPath <> "" THEN
        IF LoadComboItemsFromIndex(elemIdx, sourceIndexPath) <> 0 THEN
            usedSourceIndex = -1
            GOTO BuildComboItemsStore
        END IF
    END IF

    itemsSpec = uiElems(elemIdx).sourceItems
    IF TRIM$(itemsSpec) <> "" THEN
        DO WHILE itemsSpec <> ""
            sepPos = INSTR(itemsSpec, "|")
            IF sepPos > 0 THEN
                itemSpec = LEFT$(itemsSpec, sepPos - 1)
                itemsSpec = MID$(itemsSpec, sepPos + 1)
            ELSE
                itemSpec = itemsSpec
                itemsSpec = ""
            END IF

            IF itemSpec <> "" THEN
                IF tempComboItemCount < 256 THEN
                    tempComboItemCount = tempComboItemCount + 1
                    sepChrPos = INSTR(itemSpec, CHR$(1))
                    eqPos = INSTR(itemSpec, "=")
                    IF sepChrPos > 0 THEN
                        tempComboItems(tempComboItemCount) = LEFT$(itemSpec, sepChrPos - 1)
                        tempComboValues(tempComboItemCount) = MID$(itemSpec, sepChrPos + 1)
                    ELSEIF eqPos > 0 THEN
                        tempComboItems(tempComboItemCount) = TRIM$(LEFT$(itemSpec, eqPos - 1))
                        tempComboValues(tempComboItemCount) = TRIM$(MID$(itemSpec, eqPos + 1))
                    ELSE
                        tempComboItems(tempComboItemCount) = itemSpec
                        tempComboValues(tempComboItemCount) = itemSpec
                    END IF
                END IF
            END IF
        LOOP
        GOTO BuildComboItemsStore
    END IF

    sourceKind = uiElems(elemIdx).sourceKindKey
    sourceMaskText = TRIM$(uiElems(elemIdx).sourceMask)
    sourceMaskKey = UCASE$(sourceMaskText)
    explorerSourceFlag = 0

    IF sourceKind <> "" THEN explorerSourceFlag = -1

    IF sourceKind = "DIRS" OR sourceKind = "FILES" THEN
        dirName = TRIM$(uiElems(elemIdx).sourceDir)
        IF dirName = "" THEN dirName = TRIM$(fileDlgDir)
        IF dirName = "" THEN dirName = "."
        IF explorerSourceFlag <> 0 THEN
            dirName = AbsoluteDirPath(dirName)
        ELSE
            dirName = NormalizePath(dirName)
        END IF

        IF sourceKind = "DIRS" THEN
            FOR i = 67 TO 90
                    dirFull = CHR$(i) + ":" + CHR$(92)
                    pattern = dirFull + "*.*"
                    IF DirectoryHasAnyEntry(dirFull) <> 0 OR UCASE$(LEFT$(AbsoluteDirPath(dirName), 3)) = UCASE$(dirFull) THEN
                        IF tempComboItemCount < 256 THEN
                            tempComboItemCount = tempComboItemCount + 1
                            tempComboItems(tempComboItemCount) = "[" + CHR$(i) + ":] " + dirFull
                            tempComboValues(tempComboItemCount) = "D:" + dirFull
                        END IF
                    END IF
                NEXT

            IF tempComboItemCount < 256 THEN
                tempComboItemCount = tempComboItemCount + 1
                pathCaption = dirName
                tempComboItems(tempComboItemCount) = pathCaption
                tempComboValues(tempComboItemCount) = "D:" + dirName
            END IF

            parentName = ParentPath(dirName)
            IF parentName = "" THEN
                IF dirName = "." THEN
                    parentName = ParentPath(AbsoluteDirPath(dirName))
                ELSEIF dirName <> "" AND INSTR(dirName, CHR$(92)) = 0 AND INSTR(dirName, ":") = 0 THEN
                    parentName = "."
                END IF
            END IF

            IF parentName <> "" THEN
                IF tempComboItemCount < 256 THEN
                    tempComboItemCount = tempComboItemCount + 1
                    IF explorerSourceFlag <> 0 THEN
                        tempComboItems(tempComboItemCount) = CHR$(24) + " UP"
                    ELSE
                        tempComboItems(tempComboItemCount) = "[..] " + parentName
                    END IF
                    tempComboValues(tempComboItemCount) = "D:" + parentName
                END IF
            END IF

            sortStart = tempComboItemCount + 1
            pattern = dirName
            IF RIGHT$(pattern, 1) <> CHR$(92) THEN pattern = pattern + CHR$(92)
            pattern = pattern + "*.*"

            dirAttr = 0
            fname = DIR(pattern, &H37, dirAttr)
            DO WHILE fname <> "" AND tempComboItemCount < 256
                IF fname <> "." AND fname <> ".." THEN
                    dirFull = JoinPath(dirName, fname)
                    IF (dirAttr AND &H10) <> 0 THEN
                        tempComboItemCount = tempComboItemCount + 1
                        tempComboItems(tempComboItemCount) = "[DIR] " + fname
                        tempComboValues(tempComboItemCount) = "D:" + dirFull
                    END IF
                END IF
                fname = DIR(dirAttr)
            LOOP

            SortTempComboItems sortStart, tempComboItemCount

            GOTO BuildComboItemsStore
        END IF

        pattern = dirName
        IF RIGHT$(pattern, 1) <> CHR$(92) THEN pattern = pattern + CHR$(92)
        IF sourceMaskKey = "EDIT_ASSOC" OR _
           sourceMaskKey = "$EDIT_ASSOC" OR _
           INSTR(sourceMaskText, ";") > 0 THEN
            pattern = pattern + "*.*"
        ELSEIF sourceMaskText <> "" THEN
            pattern = pattern + sourceMaskText
        ELSE
            pattern = pattern + "*.TXT"
        END IF

        navFileAttr = 0
        fname = DIR(pattern, &H37, navFileAttr)
        DO WHILE fname <> "" AND tempComboItemCount < 256
            IF fname <> "." AND fname <> ".." THEN
                fileFull = JoinPath(dirName, fname)
                IF (navFileAttr AND &H10) = 0 THEN
                    IF FileMatchesDialogMask(fileFull, uiElems(elemIdx).sourceMask) <> 0 THEN
                        tempComboItemCount = tempComboItemCount + 1
                        tempComboItems(tempComboItemCount) = FileNameOnly(fileFull)
                        tempComboValues(tempComboItemCount) = "F:" + fileFull
                    END IF
                END IF
            END IF
            fname = DIR(navFileAttr)
        LOOP

        SortTempComboItems 1, tempComboItemCount

        GOTO BuildComboItemsStore
    END IF

    pattern = ExpandLayoutDynamicText(uiElems(elemIdx).sourceDir)
    IF pattern = "" THEN GOTO BuildComboItemsStore

    IF RIGHT$(pattern, 1) <> CHR$(92) THEN pattern = pattern + CHR$(92)
    IF INSTR(sourceMaskText, ";") > 0 THEN
        pattern = pattern + "*.*"
    ELSEIF sourceMaskText <> "" THEN
        pattern = pattern + sourceMaskText
    ELSE
        pattern = pattern + "*.BMP"
    END IF

    fname = DIR(pattern)
    DO WHILE fname <> ""
        includeFile = -1
        IF includeFile <> 0 THEN
            IF FileMatchesDialogMask(fname, uiElems(elemIdx).sourceMask) = 0 THEN includeFile = 0
        END IF

        IF includeFile <> 0 THEN
            IF tempComboItemCount < 256 THEN
                tempComboItemCount = tempComboItemCount + 1
                tempComboItems(tempComboItemCount) = fname
                tempComboValues(tempComboItemCount) = fname
            END IF
        END IF
        fname = DIR()
    LOOP

    SortTempComboItems 1, tempComboItemCount

BuildComboItemsStore:
    IF sourceIndexPath <> "" AND usedSourceIndex = 0 AND tempComboItemCount > 0 THEN StoreComboItemsToIndex sourceIndexPath
    StoreComboItemsInCache elemIdx, comboCacheKeyText
END SUB

' ---------------------------
' Combo popups, list controls, scroll math, and wheel scrolling
' ---------------------------

FUNCTION ComboDividerFlagFromText(BYREF itemTextIn AS STRING, BYREF itemValueIn AS STRING) AS INTEGER
    DIM itemText AS STRING
    DIM itemValue AS STRING

    itemText = UCASE$(TRIM$(RTRIM$(itemTextIn)))
    itemValue = UCASE$(TRIM$(RTRIM$(itemValueIn)))

    IF itemValue = "DIVIDER" THEN RETURN -1
    IF itemText = "-" OR itemText = "--" OR itemText = "---" THEN RETURN -1
    IF itemText = "DIVIDER" THEN RETURN -1

    RETURN 0
END FUNCTION

FUNCTION ComboItemIsDivider(BYVAL itemIdx AS INTEGER) AS INTEGER
    IF itemIdx < 1 OR itemIdx > tempComboItemCount THEN RETURN 0
    RETURN ComboDividerFlagFromText(tempComboItems(itemIdx), tempComboValues(itemIdx))
END FUNCTION

FUNCTION ComboItemPixelHeight(BYVAL itemIdx AS INTEGER) AS INTEGER
    IF ComboItemIsDivider(itemIdx) <> 0 THEN RETURN 8
    RETURN 16
END FUNCTION

FUNCTION ComboPopupVisibleHeight(BYVAL topIdx AS INTEGER, BYVAL rows AS INTEGER) AS INTEGER
    DIM visibleRow AS INTEGER
    DIM itemIdx AS INTEGER
    DIM totalH AS INTEGER

    IF rows < 1 THEN rows = 1
    IF topIdx < 0 THEN topIdx = 0

    totalH = 0
    FOR visibleRow = 0 TO rows - 1
        itemIdx = topIdx + visibleRow + 1
        IF itemIdx >= 1 AND itemIdx <= tempComboItemCount THEN
            totalH = totalH + ComboItemPixelHeight(itemIdx)
        END IF
    NEXT

    IF totalH < 1 THEN totalH = 16
    RETURN totalH
END FUNCTION


FUNCTION ComboCachedItemIsDivider(BYVAL cacheSlot AS INTEGER, BYVAL itemIdx AS INTEGER) AS INTEGER
    IF cacheSlot < 1 OR cacheSlot > 16 THEN RETURN 0
    IF comboItemCacheValid(cacheSlot) = 0 THEN RETURN 0
    IF itemIdx < 1 OR itemIdx > comboItemCacheCount(cacheSlot) THEN RETURN 0

    RETURN comboItemCacheDivider(cacheSlot, itemIdx)
END FUNCTION

FUNCTION ComboCachedItemPixelHeight(BYVAL cacheSlot AS INTEGER, BYVAL itemIdx AS INTEGER) AS INTEGER
    IF cacheSlot < 1 OR cacheSlot > 16 THEN RETURN 16
    IF comboItemCacheValid(cacheSlot) = 0 THEN RETURN 16
    IF itemIdx < 1 OR itemIdx > comboItemCacheCount(cacheSlot) THEN RETURN 16
    IF comboItemCacheDivider(cacheSlot, itemIdx) <> 0 THEN RETURN 8
    RETURN 16
END FUNCTION

FUNCTION ComboCachedPopupVisibleHeight(BYVAL cacheSlot AS INTEGER, BYVAL topIdx AS INTEGER, BYVAL rows AS INTEGER) AS INTEGER
    DIM visibleRow AS INTEGER
    DIM itemIdx AS INTEGER
    DIM totalH AS INTEGER

    IF cacheSlot < 1 OR cacheSlot > 16 THEN RETURN 16
    IF comboItemCacheValid(cacheSlot) = 0 THEN RETURN 16
    IF rows < 1 THEN rows = 1
    IF topIdx < 0 THEN topIdx = 0

    totalH = 0
    FOR visibleRow = 0 TO rows - 1
        itemIdx = topIdx + visibleRow + 1
        IF itemIdx >= 1 AND itemIdx <= comboItemCacheCount(cacheSlot) THEN
            totalH = totalH + ComboCachedItemPixelHeight(cacheSlot, itemIdx)
        END IF
    NEXT

    IF totalH < 1 THEN totalH = 16
    RETURN totalH
END FUNCTION

FUNCTION ComboPopupHitItem(BYVAL mouseY AS INTEGER, BYVAL popupTop AS INTEGER, BYVAL topIdx AS INTEGER, BYVAL rows AS INTEGER) AS INTEGER
    DIM visibleRow AS INTEGER
    DIM itemIdx AS INTEGER
    DIM rowTop AS INTEGER
    DIM rowH AS INTEGER

    IF rows < 1 THEN rows = 1
    IF topIdx < 0 THEN topIdx = 0

    rowTop = popupTop
    FOR visibleRow = 0 TO rows - 1
        itemIdx = topIdx + visibleRow + 1
        IF itemIdx >= 1 AND itemIdx <= tempComboItemCount THEN
            rowH = ComboItemPixelHeight(itemIdx)
            IF mouseY >= rowTop AND mouseY <= rowTop + rowH - 1 THEN
                RETURN itemIdx
            END IF
            rowTop = rowTop + rowH
        END IF
    NEXT

    RETURN 0
END FUNCTION

FUNCTION ComboCachedPopupHitItem(BYVAL cacheSlot AS INTEGER, BYVAL mouseY AS INTEGER, BYVAL popupTop AS INTEGER, BYVAL topIdx AS INTEGER, BYVAL rows AS INTEGER) AS INTEGER
    DIM visibleRow AS INTEGER
    DIM itemIdx AS INTEGER
    DIM rowTop AS INTEGER
    DIM rowH AS INTEGER

    IF cacheSlot < 1 OR cacheSlot > 16 THEN RETURN 0
    IF comboItemCacheValid(cacheSlot) = 0 THEN RETURN 0
    IF rows < 1 THEN rows = 1
    IF topIdx < 0 THEN topIdx = 0

    rowTop = popupTop
    FOR visibleRow = 0 TO rows - 1
        itemIdx = topIdx + visibleRow + 1
        IF itemIdx >= 1 AND itemIdx <= comboItemCacheCount(cacheSlot) THEN
            rowH = ComboCachedItemPixelHeight(cacheSlot, itemIdx)
            IF mouseY >= rowTop AND mouseY <= rowTop + rowH - 1 THEN
                RETURN itemIdx
            END IF
            rowTop = rowTop + rowH
        END IF
    NEXT

    RETURN 0
END FUNCTION

FUNCTION ComboDropRows(BYVAL elemIdx AS INTEGER) AS INTEGER
    IF elemIdx < 1 OR elemIdx > uiCount THEN RETURN 6
    IF uiElems(elemIdx).dropRows > 0 THEN RETURN uiElems(elemIdx).dropRows
    RETURN 6
END FUNCTION

FUNCTION ComboPopupWidth(BYVAL elemIdx AS INTEGER, BYVAL controlW AS INTEGER) AS INTEGER
    DIM popupW AS INTEGER

    popupW = controlW
    IF popupW < 1 THEN popupW = 120
    IF elemIdx >= 1 AND elemIdx <= uiCount THEN
        IF uiElems(elemIdx).dropW > popupW THEN popupW = uiElems(elemIdx).dropW
    END IF
    RETURN popupW
END FUNCTION

FUNCTION EffectiveComboRows(BYVAL elemIdx AS INTEGER, BYVAL ex AS INTEGER, BYVAL ey AS INTEGER, BYVAL ew AS INTEGER, BYVAL eh AS INTEGER) AS INTEGER
    DIM rows AS INTEGER
    DIM itemH AS INTEGER
    DIM availPx AS INTEGER
    DIM maxRowsBySpace AS INTEGER
    DIM comboBottomLimit AS INTEGER

    rows = ComboDropRows(elemIdx)
    IF rows < 1 THEN rows = 1

    itemH = 16
    comboBottomLimit = uiWinY + uiWinH - 2
    availPx = comboBottomLimit - (ey + eh) - 2

    maxRowsBySpace = availPx \ itemH
    IF maxRowsBySpace < 1 THEN maxRowsBySpace = 1

    IF rows > maxRowsBySpace THEN rows = maxRowsBySpace
    IF rows < 1 THEN rows = 1
    RETURN rows
END FUNCTION

FUNCTION ClampScrollPos(BYVAL scrollPos AS INTEGER, BYVAL maxScroll AS INTEGER) AS INTEGER
    IF maxScroll < 0 THEN maxScroll = 0
    IF scrollPos < 0 THEN scrollPos = 0
    IF scrollPos > maxScroll THEN scrollPos = maxScroll
    RETURN scrollPos
END FUNCTION

FUNCTION CalcScrollThumbSize(BYVAL viewSize AS INTEGER, BYVAL totalSize AS INTEGER, BYVAL trackSize AS INTEGER, BYVAL minThumb AS INTEGER) AS INTEGER
    DIM thumbSize AS INTEGER

    IF trackSize < 1 THEN RETURN 0
    IF totalSize < 1 THEN totalSize = 1
    IF viewSize < 1 THEN viewSize = 1

    thumbSize = (CLNG(viewSize) * trackSize) \ totalSize
    IF thumbSize < minThumb THEN thumbSize = minThumb
    IF thumbSize > trackSize THEN thumbSize = trackSize
    RETURN thumbSize
END FUNCTION

FUNCTION CalcScrollThumbTop(BYVAL scrollPos AS INTEGER, BYVAL maxScroll AS INTEGER, BYVAL trackTop AS INTEGER, BYVAL trackSize AS INTEGER, BYVAL thumbSize AS INTEGER) AS INTEGER
    scrollPos = ClampScrollPos(scrollPos, maxScroll)
    IF trackSize < 1 THEN RETURN trackTop
    IF thumbSize < 0 THEN thumbSize = 0
    IF thumbSize > trackSize THEN thumbSize = trackSize

    IF maxScroll > 0 AND (trackSize - thumbSize) > 0 THEN
        RETURN trackTop + (CLNG(trackSize - thumbSize) * scrollPos) \ maxScroll
    END IF

    RETURN trackTop
END FUNCTION

FUNCTION CalcScrollPosFromThumbTop(BYVAL thumbTop AS INTEGER, BYVAL trackTop AS INTEGER, BYVAL trackSize AS INTEGER, BYVAL thumbSize AS INTEGER, BYVAL maxScroll AS INTEGER) AS INTEGER
    IF maxScroll <= 0 THEN RETURN 0
    IF trackSize < 1 THEN RETURN 0
    IF thumbSize < 0 THEN thumbSize = 0
    IF thumbSize > trackSize THEN thumbSize = trackSize

    IF thumbTop < trackTop THEN thumbTop = trackTop
    IF thumbTop > trackTop + trackSize - thumbSize THEN thumbTop = trackTop + trackSize - thumbSize

    IF (trackSize - thumbSize) > 0 THEN
        RETURN ClampScrollPos((CLNG(thumbTop - trackTop) * maxScroll) \ (trackSize - thumbSize), maxScroll)
    END IF

    RETURN 0
END FUNCTION

FUNCTION ApplyWheelToScroll(BYVAL scrollPos AS INTEGER, BYVAL wheelDelta AS INTEGER, BYVAL maxScroll AS INTEGER, BYVAL stepSize AS INTEGER) AS INTEGER
    DIM steps AS INTEGER

    steps = AbsI(wheelDelta)
    IF steps < 1 THEN steps = 1
    IF steps > 8 THEN steps = 8
    IF stepSize < 1 THEN stepSize = 1

    RETURN ClampScrollPos(scrollPos - SGN(wheelDelta) * steps * stepSize, maxScroll)
END FUNCTION

SUB GetLayoutActivePage(BYREF activePage AS STRING)
    DIM i AS INTEGER
    DIM tabNumber AS INTEGER

    activePage = ""
    tabNumber = 0
    FOR i = 1 TO uiCount
        IF uiElems(i).kindId = UI_KIND_TAB THEN
            tabNumber = tabNumber + 1
            IF tabNumber = uiSelectedTab THEN
                activePage = UCASE$(uiElems(i).text)
                EXIT SUB
            END IF
        END IF
    NEXT

    FOR i = 1 TO uiCount
        IF uiElems(i).kindId = UI_KIND_TAB THEN
            activePage = UCASE$(uiElems(i).text)
            EXIT SUB
        END IF
    NEXT
END SUB

SUB GetLayoutContentExtents(BYREF contentW AS INTEGER, BYREF contentH AS INTEGER)
    DIM i AS INTEGER
    DIM activePage AS STRING
    DIM visible AS INTEGER
    DIM elemW AS INTEGER
    DIM elemH AS INTEGER
    DIM elemRight AS INTEGER
    DIM elemBottom AS INTEGER
    DIM kindUpper AS STRING
    DIM cacheWin AS INTEGER

    GetLayoutActivePage activePage

    cacheWin = 0
    IF drawLayoutWindow >= LBOUND(layoutWindows) AND drawLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(drawLayoutWindow).used <> 0 THEN cacheWin = drawLayoutWindow
    END IF
    IF cacheWin = 0 THEN
        IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
            IF layoutWindows(activeLayoutWindow).used <> 0 THEN cacheWin = activeLayoutWindow
        END IF
    END IF

    IF cacheWin <> 0 THEN
        IF layoutContentCacheValid(cacheWin) <> 0 AND _
           layoutContentCacheVersion(cacheWin) = layoutDirtyVersion(cacheWin) AND _
           layoutContentCacheTab(cacheWin) = uiSelectedTab AND _
           layoutContentCacheCount(cacheWin) = uiCount AND _
           layoutContentCachePage(cacheWin) = activePage THEN
            contentW = layoutContentCacheW(cacheWin)
            contentH = layoutContentCacheH(cacheWin)
            EXIT SUB
        END IF
    END IF

    contentW = 0
    contentH = 22

    FOR i = 1 TO uiCount
        visible = 0
        kindUpper = uiElems(i).kindKey
        IF kindUpper = "TAB" THEN
            visible = -1
        ELSEIF uiElems(i).page = "" THEN
            visible = -1
        ELSEIF uiElems(i).pageKey = activePage THEN
            visible = -1
        END IF

        IF visible <> 0 THEN
            IF kindUpper = "LABEL" AND uiElems(i).modeId = UI_MODE_TEXT_STATS THEN
                IF uiElems(i).moveY <> 0 THEN CONTINUE FOR
            END IF

            elemW = uiElems(i).w
            elemH = uiElems(i).h

            SELECT CASE kindUpper
            CASE "LABEL"
                elemW = LEN(uiElems(i).text) * 8
                elemH = 8
            CASE "RADIO", "CHECKBOX"
                elemW = 22 + LEN(uiElems(i).text) * 8
                elemH = 16
            CASE "BUTTON"
                IF elemW <= 0 THEN elemW = LEN(uiElems(i).text) * 8 + 20
                IF elemH <= 0 THEN elemH = 22
            CASE "COMBO", "TEXTBOX"
                IF elemW <= 0 THEN elemW = 120
                IF elemH <= 0 THEN elemH = 22
            CASE "LISTBOX"
                IF elemW <= 0 THEN elemW = 120
                IF elemH <= 0 THEN elemH = 100
            CASE "APPVIEW", "CANVAS"
                IF elemW <= 0 THEN elemW = 120
                IF elemH <= 0 THEN elemH = 100
            CASE "OVERLAY"
                IF elemW <= 0 THEN elemW = 1
                IF elemH <= 0 THEN elemH = 1
            CASE "SPLITTER"
                IF elemW <= 0 THEN elemW = 6
                IF elemH <= 0 THEN elemH = 100
            END SELECT

            IF elemW < 0 THEN elemW = 0
            IF elemH < 0 THEN elemH = 0

            elemRight = uiElems(i).x + elemW
            elemBottom = 22 + uiElems(i).y + elemH

            IF elemRight > contentW THEN contentW = elemRight
            IF elemBottom > contentH THEN contentH = elemBottom
        END IF
    NEXT

    IF contentW < 1 THEN contentW = 1
    IF contentH < 1 THEN contentH = 1

    IF cacheWin <> 0 THEN
        layoutContentCacheW(cacheWin) = contentW
        layoutContentCacheH(cacheWin) = contentH
        layoutContentCacheVersion(cacheWin) = layoutDirtyVersion(cacheWin)
        layoutContentCacheTab(cacheWin) = uiSelectedTab
        layoutContentCacheCount(cacheWin) = uiCount
        layoutContentCachePage(cacheWin) = activePage
        layoutContentCacheValid(cacheWin) = -1
    END IF
END SUB

SUB ClampLayoutWindowToWorkArea(BYVAL fitSize AS INTEGER)
    IF WORK_W < 1 OR WORK_H < 1 THEN EXIT SUB

    IF uiWinW < 180 THEN uiWinW = 180
    IF uiWinH < 120 THEN uiWinH = 120

    IF fitSize <> 0 THEN
        IF uiWinW > WORK_W THEN uiWinW = WORK_W
        IF uiWinH > WORK_H THEN uiWinH = WORK_H
    END IF

    IF uiWinX < WORK_X THEN uiWinX = WORK_X
    IF uiWinY < WORK_Y THEN uiWinY = WORK_Y

    IF uiWinX + uiWinW - 1 > WORK_RIGHT THEN uiWinX = WORK_RIGHT - uiWinW + 1
    IF uiWinY + uiWinH - 1 > WORK_BOTTOM THEN uiWinY = WORK_BOTTOM - uiWinH + 1

    IF uiWinX < WORK_X THEN uiWinX = WORK_X
    IF uiWinY < WORK_Y THEN uiWinY = WORK_Y
END SUB

SUB ClampLayoutWindowResizeToWorkArea()
    IF WORK_W < 1 OR WORK_H < 1 THEN EXIT SUB

    IF uiWinW < 180 THEN uiWinW = 180
    IF uiWinH < 120 THEN uiWinH = 120

    IF uiWinX + uiWinW - 1 > WORK_RIGHT THEN uiWinW = WORK_RIGHT - uiWinX + 1
    IF uiWinY + uiWinH - 1 > WORK_BOTTOM THEN uiWinH = WORK_BOTTOM - uiWinY + 1

    IF uiWinW < 180 THEN uiWinW = 180
    IF uiWinH < 120 THEN uiWinH = 120
END SUB

SUB GetLayoutScrollMetricsFromContent(BYVAL contentW AS INTEGER, BYVAL contentH AS INTEGER, _
                                      BYREF showHScroll AS INTEGER, BYREF showVScroll AS INTEGER, _
                                      BYREF clientW AS INTEGER, BYREF clientH AS INTEGER, _
                                      BYREF maxScrollX AS INTEGER, BYREF maxScrollY AS INTEGER)
    DIM baseClientW AS INTEGER
    DIM baseClientH AS INTEGER
    DIM passNum AS INTEGER
    DIM newShowH AS INTEGER
    DIM newShowV AS INTEGER

    ' Use this when the caller already walked the controls and has the content size.
    ' It keeps the scrollbar math in one place without doing the same scan again.
    baseClientW = uiWinW - 4
    baseClientH = uiWinH - 21
    IF baseClientW < 1 THEN baseClientW = 1
    IF baseClientH < 1 THEN baseClientH = 1

    showHScroll = 0
    showVScroll = 0

    IF uiNoScrollbars <> 0 THEN
        clientW = baseClientW
        clientH = baseClientH
        maxScrollX = 0
        maxScrollY = 0
        uiScrollX = 0
        uiScrollY = 0
        EXIT SUB
    END IF

    FOR passNum = 1 TO 3
        clientW = baseClientW
        clientH = baseClientH
        IF showVScroll <> 0 THEN clientW = clientW - 14
        IF showHScroll <> 0 THEN clientH = clientH - 14
        IF clientW < 1 THEN clientW = 1
        IF clientH < 1 THEN clientH = 1

        newShowH = 0
        newShowV = 0
        IF uiResizable <> 0 AND contentW > clientW THEN newShowH = -1
        IF uiResizable <> 0 AND contentH > clientH THEN newShowV = -1

        IF newShowH = showHScroll AND newShowV = showVScroll THEN EXIT FOR
        showHScroll = newShowH
        showVScroll = newShowV
    NEXT

    clientW = baseClientW
    clientH = baseClientH
    IF showVScroll <> 0 THEN clientW = clientW - 14
    IF showHScroll <> 0 THEN clientH = clientH - 14
    IF clientW < 1 THEN clientW = 1
    IF clientH < 1 THEN clientH = 1

    maxScrollX = contentW - clientW
    maxScrollY = contentH - clientH
    IF maxScrollX < 0 THEN maxScrollX = 0
    IF maxScrollY < 0 THEN maxScrollY = 0
END SUB

SUB GetLayoutScrollMetrics(BYREF showHScroll AS INTEGER, BYREF showVScroll AS INTEGER, BYREF clientW AS INTEGER, BYREF clientH AS INTEGER, BYREF maxScrollX AS INTEGER, BYREF maxScrollY AS INTEGER)
    DIM contentW AS INTEGER
    DIM contentH AS INTEGER

    GetLayoutContentExtents contentW, contentH
    GetLayoutScrollMetricsFromContent contentW, contentH, showHScroll, showVScroll, clientW, clientH, maxScrollX, maxScrollY
END SUB

FUNCTION LayoutVisibleClientRight(BYVAL showVScroll AS INTEGER) AS INTEGER
    IF showVScroll <> 0 THEN
        RETURN uiWinX + uiWinW - 16
    END IF
    RETURN uiWinX + uiWinW - 2
END FUNCTION

FUNCTION LayoutVisibleClientBottom(BYVAL showHScroll AS INTEGER) AS INTEGER
    IF showHScroll <> 0 THEN
        RETURN uiWinY + uiWinH - 16
    END IF
    RETURN uiWinY + uiWinH - 2
END FUNCTION


FUNCTION ScrollHoveredScrollableAtMouse(BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER, BYVAL wheelDelta AS INTEGER) AS INTEGER
    DIM scrollMode AS INTEGER
    DIM activePage AS STRING

    IF cfg.showTaskbar <> 0 THEN
        IF mouseY < WORK_Y OR mouseY > WORK_BOTTOM THEN RETURN 0
    END IF
    IF activeLayoutWindow < 1 OR activeLayoutWindow > 12 THEN RETURN 0
    IF layoutWindows(activeLayoutWindow).used = 0 THEN RETURN 0

    scrollMode = ScrollOpenComboAtMouse(mouseX, mouseY, wheelDelta)
    IF scrollMode <> 0 THEN RETURN scrollMode

    GetLayoutActivePage activePage

    scrollMode = ScrollTextBoxAtMouse(mouseX, mouseY, wheelDelta, activePage)
    IF scrollMode <> 0 THEN RETURN scrollMode

    scrollMode = ScrollListBoxAtMouse(mouseX, mouseY, wheelDelta, activePage)
    IF scrollMode <> 0 THEN RETURN scrollMode

    scrollMode = ScrollLayoutWindowAtMouse(mouseX, mouseY, wheelDelta)
    IF scrollMode <> 0 THEN RETURN scrollMode
    RETURN 0
END FUNCTION

FUNCTION ScrollOpenComboAtMouse(BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER, BYVAL wheelDelta AS INTEGER) AS INTEGER
    DIM elemIdx AS INTEGER
    DIM ex AS INTEGER
    DIM ey AS INTEGER
    DIM ew AS INTEGER
    DIM eh AS INTEGER
    DIM comboRows AS INTEGER
    DIM itemCount AS INTEGER
    DIM comboCacheSlot AS INTEGER
    DIM topIdx AS INTEGER
    DIM newTopIdx AS INTEGER
    DIM hitTop AS INTEGER
    DIM hitBottom AS INTEGER
    DIM activePage AS STRING
    DIM i AS INTEGER
    DIM itemIdx AS INTEGER
    DIM currentIdx AS INTEGER
    DIM selectedIdx AS INTEGER
    DIM scanIdx AS INTEGER
    DIM stepDir AS INTEGER
    DIM stepCount AS INTEGER
    DIM stepLoop AS INTEGER
    DIM selectedText AS STRING
    DIM itemText AS STRING
    DIM dividerFlag AS INTEGER

    IF activeLayoutWindow < 1 OR activeLayoutWindow > 12 THEN RETURN 0
    IF layoutWindows(activeLayoutWindow).used = 0 THEN RETURN 0

    elemIdx = comboOpenIndex(activeLayoutWindow)
    IF elemIdx >= 1 AND elemIdx <= uiCount THEN
        IF uiElems(elemIdx).kindId = UI_KIND_COMBO THEN
            ex = uiWinX + uiElems(elemIdx).x - uiScrollX
            ey = uiWinY + 22 + uiElems(elemIdx).y - uiScrollY
            ew = uiElems(elemIdx).w
            eh = uiElems(elemIdx).h
            IF ew <= 0 THEN ew = 120
            IF eh <= 0 THEN eh = 22

            itemCount = ComboFastItemCount(elemIdx, comboCacheSlot)
            comboRows = EffectiveComboRows(elemIdx, ex, ey, ew, eh)
            IF comboRows < 1 THEN comboRows = 1
            IF itemCount > 0 AND itemCount < comboRows THEN comboRows = itemCount
            IF comboRows < 1 THEN comboRows = 1

            hitTop = ey
            hitBottom = ey + eh + comboRows * 16

            IF mouseX < ex OR mouseX > ex + ew OR mouseY < hitTop OR mouseY > hitBottom THEN RETURN 0
            IF itemCount <= comboRows THEN RETURN 4

            topIdx = ClampScrollPos(comboScrollTop(activeLayoutWindow, elemIdx), itemCount - comboRows)
            newTopIdx = ApplyWheelToScroll(topIdx, wheelDelta, itemCount - comboRows, 1)

            IF newTopIdx <> topIdx THEN
                comboScrollTop(activeLayoutWindow, elemIdx) = newTopIdx
                RETURN 3
            END IF

            RETURN 4
        END IF
    END IF

    GetLayoutActivePage activePage

    FOR i = 1 TO uiCount
        IF uiElems(i).kindId = UI_KIND_COMBO THEN
            IF uiElems(i).page = "" OR uiElems(i).pageKey = activePage THEN
                ex = uiWinX + uiElems(i).x - uiScrollX
                ey = uiWinY + 22 + uiElems(i).y - uiScrollY
                ew = uiElems(i).w
                eh = uiElems(i).h
                IF ew <= 0 THEN ew = 120
                IF eh <= 0 THEN eh = 22

                IF mouseX >= ex AND mouseX <= ex + ew AND mouseY >= ey AND mouseY <= ey + eh THEN
                    itemCount = ComboFastItemCount(i, comboCacheSlot)
                    IF itemCount < 1 THEN RETURN 4

                    selectedText = UCASE$(RTRIM$(uiElems(i).text))
                    currentIdx = 0
                    FOR itemIdx = 1 TO itemCount
                        itemText = UCASE$(ComboFastItemText(comboCacheSlot, itemIdx))
                        IF itemText = selectedText THEN
                            currentIdx = itemIdx
                            EXIT FOR
                        END IF
                    NEXT

                    stepDir = -SGN(wheelDelta)
                    IF stepDir = 0 THEN RETURN 4

                    IF currentIdx < 1 THEN
                        IF stepDir > 0 THEN
                            selectedIdx = 0
                        ELSE
                            selectedIdx = itemCount + 1
                        END IF
                    ELSE
                        selectedIdx = currentIdx
                    END IF

                    stepCount = AbsI(wheelDelta)
                    IF stepCount < 1 THEN stepCount = 1
                    IF stepCount > 8 THEN stepCount = 8

                    FOR stepLoop = 1 TO stepCount
                        scanIdx = selectedIdx + stepDir
                        DO WHILE scanIdx >= 1 AND scanIdx <= itemCount
                            IF comboCacheSlot > 0 THEN
                                dividerFlag = ComboCachedItemIsDivider(comboCacheSlot, scanIdx)
                            ELSE
                                dividerFlag = ComboItemIsDivider(scanIdx)
                            END IF

                            IF dividerFlag = 0 THEN
                                selectedIdx = scanIdx
                                EXIT DO
                            END IF

                            scanIdx = scanIdx + stepDir
                        LOOP
                    NEXT

                    IF selectedIdx < 1 OR selectedIdx > itemCount THEN RETURN 4
                    IF currentIdx = selectedIdx THEN RETURN 4

                    uiElems(i).text = ComboFastItemText(comboCacheSlot, selectedIdx)
                    InvalidateLivePreviewCachesForControl activeLayoutWindow, i
                    IF TRIM$(uiElems(i).bindFile) <> "" AND TRIM$(uiElems(i).bindKey) <> "" THEN MarkWindowPresetDirty activeLayoutWindow
                    AppRuntime_HandleEvent activeLayoutWindow, "CHANGE", uiElems(i).name, uiElems(i).text, uiElems(i).action
                    IF activeLayoutWindow >= 1 AND activeLayoutWindow <= 12 THEN
                        IF layoutWindows(activeLayoutWindow).used <> 0 THEN SyncLayoutWindowElementOnly activeLayoutWindow, i
                    END IF
                    RETURN 1
                END IF
            END IF
        END IF
    NEXT

    RETURN 0
END FUNCTION

FUNCTION ScrollTextBoxAtMouse(BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER, BYVAL wheelDelta AS INTEGER, BYREF activePage AS STRING) AS INTEGER
    DIM i AS INTEGER
    DIM ex AS INTEGER
    DIM ey AS INTEGER
    DIM ew AS INTEGER
    DIM eh AS INTEGER
    DIM rows AS INTEGER
    DIM lineCount AS INTEGER
    DIM maxTop AS INTEGER
    DIM topIdx AS INTEGER
    DIM newTopIdx AS INTEGER

    IF activeLayoutWindow < 1 OR activeLayoutWindow > 12 THEN RETURN 0
    IF layoutWindows(activeLayoutWindow).used = 0 THEN RETURN 0


    FOR i = 1 TO uiCount
        IF uiElems(i).kindId = UI_KIND_TEXTBOX THEN
            IF TextboxIsMultiline(i) <> 0 THEN
                IF uiElems(i).page = "" OR uiElems(i).pageKey = activePage THEN
                    ex = uiWinX + uiElems(i).x - uiScrollX
                    ey = uiWinY + 22 + uiElems(i).y - uiScrollY
                    ew = uiElems(i).w
                    eh = uiElems(i).h
                    IF ew <= 0 THEN ew = 120
                    IF eh <= 0 THEN eh = 22

                    IF mouseX >= ex AND mouseX <= ex + ew AND mouseY >= ey AND mouseY <= ey + eh THEN
                        rows = TextboxRows(i)
                        lineCount = TextboxDisplayLineCount(i, uiElems(i).text)
                        maxTop = lineCount - rows
                        IF maxTop < 0 THEN maxTop = 0
                        IF maxTop <= 0 THEN RETURN 4

                        topIdx = ClampScrollPos(comboScrollTop(activeLayoutWindow, i), maxTop)
                        newTopIdx = ApplyWheelToScroll(topIdx, wheelDelta, maxTop, 3)

                        IF newTopIdx <> topIdx THEN
                            comboScrollTop(activeLayoutWindow, i) = newTopIdx
                            layoutFastTextboxPending = -1
                            layoutFastTextboxWin = activeLayoutWindow
                            layoutFastTextboxElem = i
                            layoutFastTextboxLine = -1
                            RETURN 2
                        END IF

                        RETURN 4
                    END IF
                END IF
            END IF
        END IF
    NEXT

    RETURN 0
END FUNCTION

FUNCTION ScrollListBoxAtMouse(BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER, BYVAL wheelDelta AS INTEGER, BYREF activePage AS STRING) AS INTEGER
    DIM i AS INTEGER
    DIM ex AS INTEGER
    DIM ey AS INTEGER
    DIM ew AS INTEGER
    DIM eh AS INTEGER
    DIM listRows AS INTEGER
    DIM itemCount AS INTEGER
    DIM topIdx AS INTEGER
    DIM newTopIdx AS INTEGER
    DIM listCacheSlot AS INTEGER

    IF activeLayoutWindow < 1 OR activeLayoutWindow > 12 THEN RETURN 0
    IF layoutWindows(activeLayoutWindow).used = 0 THEN RETURN 0


    FOR i = 1 TO uiCount
        IF uiElems(i).kindId = UI_KIND_LISTBOX THEN
            IF uiElems(i).page = "" OR uiElems(i).pageKey = activePage THEN
                ex = uiWinX + uiElems(i).x - uiScrollX
                ey = uiWinY + 22 + uiElems(i).y - uiScrollY
                ew = uiElems(i).w
                eh = uiElems(i).h
                IF ew <= 0 THEN ew = 120
                IF eh <= 0 THEN eh = 100

                IF mouseX >= ex AND mouseX <= ex + ew AND mouseY >= ey AND mouseY <= ey + eh THEN
                    itemCount = ComboFastItemCount(i, listCacheSlot)
                    listRows = (eh - 4) \ 16
                    IF listRows < 1 THEN listRows = 1
                    IF itemCount <= listRows THEN RETURN 4

                    topIdx = ClampScrollPos(comboScrollTop(activeLayoutWindow, i), itemCount - listRows)
                    newTopIdx = ApplyWheelToScroll(topIdx, wheelDelta, itemCount - listRows, 1)

                    IF newTopIdx <> topIdx THEN
                        comboScrollTop(activeLayoutWindow, i) = newTopIdx
                        MarkLayoutDirtyElement activeLayoutWindow, i
                        RETURN 2
                    END IF

                    RETURN 4
                END IF
            END IF
        END IF
    NEXT

    i = uiFocusIndex
    IF i >= 1 AND i <= uiCount THEN
        IF uiElems(i).kindId = UI_KIND_LISTBOX THEN
            IF UCASE$(TRIM$(uiElems(i).sourceKind)) = "DIRS" OR UCASE$(TRIM$(uiElems(i).sourceKind)) = "FILES" THEN
                itemCount = ComboFastItemCount(i, listCacheSlot)
                listRows = (uiElems(i).h - 4) \ 16
                IF listRows < 1 THEN listRows = 1
                IF itemCount <= listRows THEN RETURN 4

                topIdx = ClampScrollPos(comboScrollTop(activeLayoutWindow, i), itemCount - listRows)
                newTopIdx = ApplyWheelToScroll(topIdx, wheelDelta, itemCount - listRows, 1)

                IF newTopIdx <> topIdx THEN
                    comboScrollTop(activeLayoutWindow, i) = newTopIdx
                    MarkLayoutDirtyElement activeLayoutWindow, i
                    RETURN 2
                END IF

                RETURN 4
            END IF
        END IF
    END IF

    RETURN 0
END FUNCTION


FUNCTION ScrollLayoutWindowAtMouse(BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER, BYVAL wheelDelta AS INTEGER) AS INTEGER
    DIM showHScroll AS INTEGER
    DIM showVScroll AS INTEGER
    DIM clientW AS INTEGER
    DIM clientH AS INTEGER
    DIM maxScrollX AS INTEGER
    DIM listItemSelected AS INTEGER
    DIM listItemValue AS STRING
    DIM listHighlightAllowed AS INTEGER
    DIM maxScrollY AS INTEGER
    DIM newScrollY AS INTEGER

    IF activeLayoutWindow < 1 OR activeLayoutWindow > 12 THEN RETURN 0
    IF layoutWindows(activeLayoutWindow).used = 0 THEN RETURN 0
    IF uiResizable = 0 THEN RETURN 0
    IF uiNoScrollbars <> 0 THEN RETURN 0
    IF mouseX < uiWinX OR mouseX > uiWinX + uiWinW OR mouseY < uiWinY + 19 OR mouseY > uiWinY + uiWinH THEN RETURN 0

    GetLayoutScrollMetrics showHScroll, showVScroll, clientW, clientH, maxScrollX, maxScrollY

    newScrollY = ApplyWheelToScroll(uiScrollY, wheelDelta, maxScrollY, 16)

    IF newScrollY <> uiScrollY THEN
        uiScrollY = newScrollY
        SyncLayoutWindowScrollOnly activeLayoutWindow
        RETURN 3
    END IF

    IF maxScrollY > 0 THEN RETURN 4
    RETURN 0
END FUNCTION


' ---------------------------
' Action token parsing, raw text I/O, and control value helpers
' ---------------------------

' Reads the next space-delimited token from an app action command.
FUNCTION NextActionToken(BYREF src AS STRING) AS STRING
    DIM srcLen AS INTEGER
    DIM startPos AS INTEGER
    DIM spacePos AS INTEGER
    DIM restPos AS INTEGER

    srcLen = LEN(src)
    IF srcLen <= 0 THEN RETURN ""

    startPos = 1
    WHILE startPos <= srcLen AND MID$(src, startPos, 1) = " "
        startPos = startPos + 1
    WEND

    IF startPos > srcLen THEN
        src = ""
        RETURN ""
    END IF

    spacePos = INSTR(startPos, src, " ")
    IF spacePos <= 0 THEN
        IF startPos = 1 THEN
            NextActionToken = src
        ELSE
            NextActionToken = MID$(src, startPos)
        END IF
        src = ""
        EXIT FUNCTION
    END IF

    NextActionToken = MID$(src, startPos, spacePos - startPos)

    restPos = spacePos + 1
    WHILE restPos <= srcLen AND MID$(src, restPos, 1) = " "
        restPos = restPos + 1
    WEND

    IF restPos > srcLen THEN
        src = ""
    ELSE
        src = MID$(src, restPos)
    END IF
END FUNCTION

' Runtime action helper cache.  These helpers keep hot action dispatch paths from
' rebuilding the same trimmed / uppercase command headers on repeated events.
FUNCTION UpperCachedText(BYVAL textIn AS STRING) AS STRING
    STATIC cacheReady AS INTEGER
    STATIC cacheText AS STRING
    STATIC cacheUpper AS STRING

    IF cacheReady <> 0 THEN
        IF textIn = cacheText THEN RETURN cacheUpper
    END IF

    cacheText = textIn
    cacheUpper = UCASE$(textIn)
    cacheReady = -1
    RETURN cacheUpper
END FUNCTION

FUNCTION NormalizeActionRawUpperCached(BYVAL textIn AS STRING, BYREF rawOut AS STRING, BYREF upperOut AS STRING) AS INTEGER
    STATIC cacheReady AS INTEGER
    STATIC cacheTextIn AS STRING
    STATIC cacheRaw AS STRING
    STATIC cacheUpper AS STRING

    IF cacheReady <> 0 THEN
        IF textIn = cacheTextIn THEN
            rawOut = cacheRaw
            upperOut = cacheUpper
            RETURN (upperOut <> "")
        END IF
    END IF

    cacheTextIn = textIn
    cacheRaw = TRIM$(textIn)
    cacheUpper = UpperCachedText(cacheRaw)
    cacheReady = -1

    rawOut = cacheRaw
    upperOut = cacheUpper
    RETURN (upperOut <> "")
END FUNCTION

FUNCTION ParseActionHeaderCached(BYVAL actIn AS STRING, BYREF rawOut AS STRING, BYREF tokenOut AS STRING, BYREF argsOut AS STRING) AS INTEGER
    STATIC cacheReady AS INTEGER
    STATIC cacheActIn AS STRING
    STATIC cacheRaw AS STRING
    STATIC cacheToken AS STRING
    STATIC cacheArgs AS STRING

    IF cacheReady <> 0 THEN
        IF actIn = cacheActIn THEN
            rawOut = cacheRaw
            tokenOut = cacheToken
            argsOut = cacheArgs
            RETURN (tokenOut <> "")
        END IF
    END IF

    cacheActIn = actIn
    cacheRaw = TRIM$(actIn)
    cacheArgs = cacheRaw
    cacheToken = UpperCachedText(NextActionToken(cacheArgs))
    cacheReady = -1

    rawOut = cacheRaw
    tokenOut = cacheToken
    argsOut = cacheArgs
    RETURN (tokenOut <> "")
END FUNCTION

' Identifies direct app actions that only update state or controls inside the
' active layout window. Button/key callers can use this to avoid a whole-screen
' redraw after small control changes while leaving complex actions on the safe path.
FUNCTION HostActionDirectActiveWindowRedrawOnly(BYVAL actIn AS STRING) AS INTEGER
    DIM rawText AS STRING
    DIM act AS STRING
    DIM args AS STRING

    IF ParseActionHeaderCached(actIn, rawText, act, args) = 0 THEN RETURN 0

    SELECT CASE act
    CASE "TEXTBOX_CARET_END", "TEXT_CARET_END", "CONTROL_CARET_END"
        RETURN -1
    CASE "APPVIEW_TOOL", "APPVIEW_UNDO"
        RETURN -1
    CASE "APPVAR_SET", "APPVAR_SET_ML", "APPVAR_CLEAR", "APPVAR_CLEAR_ALL", "APPVAR_CLEAR_PREFIX"
        RETURN -1
    CASE "APPVAR_COPY", "APPVAR_FROM_CONTROL", "APPVAR_FROM_CONTROL_STATE"
        RETURN -1
    CASE "APPVAR_ADD", "APPVAR_SUB", "APPVAR_MUL", "APPVAR_DIV", "APPVAR_MOD"
        RETURN -1
    CASE "APPVAR_MIN", "APPVAR_MAX", "APPVAR_CLAMP", "APPVAR_TOGGLE", "APPVAR_RANDOM"
        RETURN -1
    CASE "APPVAR_APPEND", "APPVAR_PREPEND", "APPVAR_EXPAND", "APPVAR_EXPAND_ML", "APPVAR_APPEND_LINE", "APPVAR_LEN"
        RETURN -1
    CASE "SET_CONTROL_TEXT", "CLEAR_CONTROL", "CONTROL_TEXT_FROM_APPVAR", "CONTROL_TEXT_FROM_APPVAR_ML"
        RETURN -1
    CASE "CONTROL_STATE_FROM_APPVAR", "CONTROL_TEXT_EXPAND", "CONTROL_TEXT_EXPAND_ML"
        RETURN -1
    CASE "CONTROL_APPEND_TEXT", "CONTROL_APPEND_EXPAND", "CONTROL_APPEND_EXPAND_ML", "CONTROL_CLEAR"
        RETURN -1
    CASE ELSE
        RETURN 0
    END SELECT
END FUNCTION

FUNCTION LayoutKeyActionToken(BYVAL keyIn AS STRING) AS STRING
    DIM ascCode AS INTEGER
    DIM keyChar AS STRING

    IF keyIn = "" THEN RETURN ""

    IF LEN(keyIn) = 1 THEN
        ascCode = ASC(keyIn)
        IF ascCode = 32 THEN
            IF MULTIKEY(29) OR MULTIKEY(157) THEN RETURN "CTRL_SPACE"
            RETURN "SPACE"
        END IF
        IF ascCode >= 48 AND ascCode <= 57 THEN RETURN CHR$(ascCode)
        IF ascCode = 13 THEN RETURN "EQUALS"
        IF ascCode = 8 THEN RETURN "BACK"
        IF ascCode = 27 THEN RETURN "CLEAR"
        IF ascCode = 46 THEN RETURN "DOT"
        IF ascCode = 43 THEN RETURN "PLUS"
        IF ascCode = 45 THEN RETURN "MINUS"
        IF ascCode = 42 THEN RETURN "STAR"
        IF ascCode = 47 THEN RETURN "SLASH"
        IF ascCode = 61 THEN RETURN "EQUALS"
        IF ascCode = 40 THEN RETURN "LPAREN"
        IF ascCode = 41 THEN RETURN "RPAREN"
        keyChar = UCASE$(CHR$(ascCode))
        IF keyChar = "C" THEN RETURN "CLEAR"
        IF keyChar = "S" THEN RETURN "SIN"
        IF keyChar = "T" THEN RETURN "TAN"
        IF keyChar = "L" THEN RETURN "LOG"
        IF keyChar = "Q" THEN RETURN "SQRT"
    ELSEIF LEN(keyIn) = 2 THEN
        ascCode = ASC(RIGHT$(keyIn, 1))
        IF ascCode = 83 THEN RETURN "CLEAR"
    END IF

    RETURN ""
END FUNCTION

FUNCTION LayoutInteractiveKeyToken(BYVAL keyIn AS STRING) AS STRING
    DIM ascCode AS INTEGER
    DIM tokenText AS STRING

    IF keyIn = "" THEN RETURN ""

    IF LEN(keyIn) = 1 THEN
        ascCode = ASC(keyIn)
        SELECT CASE ascCode
        CASE 8
            RETURN "BACKSPACE"
        CASE 9
            RETURN "TAB"
        CASE 13
            RETURN "ENTER"
        CASE 27
            RETURN "ESC"
        CASE 32
            RETURN "SPACE"
        CASE 127
            RETURN "DELETE"
        CASE ELSE
            tokenText = "ASCII_" + LTRIM$(STR$(ascCode))
            RETURN tokenText
        END SELECT
    ELSEIF LEN(keyIn) = 2 THEN
        ascCode = ASC(RIGHT$(keyIn, 1))
        SELECT CASE ascCode
        CASE 59 TO 68
            RETURN "F" + LTRIM$(STR$(ascCode - 58))
        CASE 71
            RETURN "HOME"
        CASE 72
            RETURN "UP"
        CASE 73
            RETURN "PGUP"
        CASE 75
            RETURN "LEFT"
        CASE 77
            RETURN "RIGHT"
        CASE 79
            RETURN "END"
        CASE 80
            RETURN "DOWN"
        CASE 81
            RETURN "PGDN"
        CASE 82
            RETURN "INSERT"
        CASE 83
            RETURN "DELETE"
        CASE 133
            RETURN "F11"
        CASE 134
            RETURN "F12"
        CASE ELSE
            RETURN "EXT_" + LTRIM$(STR$(ascCode))
        END SELECT
    END IF

    RETURN ""
END FUNCTION

FUNCTION KeyTokenFromInkey(BYVAL keyIn AS STRING) AS STRING
    DIM ascCode AS INTEGER
    DIM keyChar AS STRING

    IF keyIn = "" THEN RETURN ""

    IF LEN(keyIn) = 1 THEN
        ascCode = ASC(keyIn)
        SELECT CASE ascCode
        CASE 8
            RETURN "BACKSPACE"
        CASE 9
            RETURN "TAB"
        CASE 13
            RETURN "ENTER"
        CASE 1 TO 26
            RETURN "CTRL_" + CHR$(ascCode + 64)
        CASE 27
            RETURN "ESC"
        CASE 32
            RETURN "SPACE"
        CASE 39
            RETURN "QUOTE"
        CASE 44
            RETURN "COMMA"
        CASE 45
            RETURN "MINUS"
        CASE 46
            RETURN "DOT"
        CASE 47
            RETURN "SLASH"
        CASE 48 TO 57
            RETURN CHR$(ascCode)
        CASE 59
            RETURN "SEMICOLON"
        CASE 61
            RETURN "EQUALS"
        CASE 91
            RETURN "LBRACKET"
        CASE 92
            RETURN "BACKSLASH"
        CASE 93
            RETURN "RBRACKET"
        CASE 96
            RETURN "GRAVE"
        CASE 127
            RETURN "DELETE"
        END SELECT

        keyChar = UCASE$(CHR$(ascCode))
        IF keyChar >= "A" AND keyChar <= "Z" THEN RETURN keyChar
        RETURN "ASCII_" + LTRIM$(STR$(ascCode))
    ELSEIF LEN(keyIn) = 2 THEN
        ascCode = ASC(RIGHT$(keyIn, 1))
        SELECT CASE ascCode
        CASE 59 TO 68
            RETURN "F" + LTRIM$(STR$(ascCode - 58))
        CASE 71
            RETURN "HOME"
        CASE 72
            RETURN "UP"
        CASE 73
            RETURN "PGUP"
        CASE 75
            RETURN "LEFT"
        CASE 77
            RETURN "RIGHT"
        CASE 79
            RETURN "END"
        CASE 80
            RETURN "DOWN"
        CASE 81
            RETURN "PGDN"
        CASE 82
            RETURN "INSERT"
        CASE 83
            RETURN "DELETE"
        CASE 133
            RETURN "F11"
        CASE 134
            RETURN "F12"
        CASE ELSE
            RETURN "EXT_" + LTRIM$(STR$(ascCode))
        END SELECT
    END IF

    RETURN ""
END FUNCTION

FUNCTION KeyScanFromInkey(BYVAL keyIn AS STRING) AS INTEGER
    IF keyIn = "" THEN RETURN 0
    IF LEN(keyIn) = 2 THEN RETURN ASC(RIGHT$(keyIn, 1))
    RETURN KeyScanFromName(KeyTokenFromInkey(keyIn))
END FUNCTION

FUNCTION KeyAsciiFromInkey(BYVAL keyIn AS STRING) AS INTEGER
    IF keyIn = "" THEN RETURN 0
    IF LEN(keyIn) = 1 THEN RETURN ASC(keyIn)
    RETURN 0
END FUNCTION

