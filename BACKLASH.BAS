FUNCTION KeyFlagsNow() AS INTEGER
    DIM flagsValue AS INTEGER

    flagsValue = 0
    IF MULTIKEY(42) OR MULTIKEY(54) THEN flagsValue = flagsValue OR KEY_FLAG_SHIFT
    IF MULTIKEY(29) OR MULTIKEY(157) THEN flagsValue = flagsValue OR KEY_FLAG_CTRL
    IF MULTIKEY(56) OR MULTIKEY(184) THEN flagsValue = flagsValue OR KEY_FLAG_ALT
    RETURN flagsValue
END FUNCTION

FUNCTION KeyDownGeneric(BYVAL keyName AS STRING) AS INTEGER
    DIM scanCode AS INTEGER

    keyName = UCASE$(TRIM$(keyName))
    SELECT CASE keyName
    CASE "CTRL", "CONTROL"
        IF MULTIKEY(29) OR MULTIKEY(157) THEN RETURN -1
        RETURN 0
    CASE "SHIFT"
        IF MULTIKEY(42) OR MULTIKEY(54) THEN RETURN -1
        RETURN 0
    CASE "ALT"
        IF MULTIKEY(56) OR MULTIKEY(184) THEN RETURN -1
        RETURN 0
    END SELECT

    scanCode = KeyScanFromName(keyName)
    IF scanCode > 0 THEN
        IF MULTIKEY(scanCode) THEN RETURN -1
    END IF
    RETURN 0
END FUNCTION

SUB KeyQueueClear(BYVAL winIdx AS INTEGER)
    DIM i AS INTEGER

    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB
    keyQueueHead(winIdx) = 1
    keyQueueTail(winIdx) = 1
    keyQueueCount(winIdx) = 0
    FOR i = 1 TO KEY_QUEUE_MAX
        keyQueueText(winIdx, i) = ""
        keyQueueScan(winIdx, i) = 0
        keyQueueAscii(winIdx, i) = 0
        keyQueueFlags(winIdx, i) = 0
    NEXT
END SUB

SUB KeyQueuePush(BYVAL winIdx AS INTEGER, BYVAL keyText AS STRING, BYVAL scanCode AS INTEGER, BYVAL asciiCode AS INTEGER, BYVAL flagsValue AS INTEGER)
    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(winIdx).used = 0 THEN EXIT SUB
    keyText = UCASE$(TRIM$(keyText))
    IF keyText = "" THEN EXIT SUB

    IF keyQueueHead(winIdx) < 1 OR keyQueueHead(winIdx) > KEY_QUEUE_MAX THEN keyQueueHead(winIdx) = 1
    IF keyQueueTail(winIdx) < 1 OR keyQueueTail(winIdx) > KEY_QUEUE_MAX THEN keyQueueTail(winIdx) = 1

    IF keyQueueCount(winIdx) >= KEY_QUEUE_MAX THEN
        keyQueueHead(winIdx) = keyQueueHead(winIdx) + 1
        IF keyQueueHead(winIdx) > KEY_QUEUE_MAX THEN keyQueueHead(winIdx) = 1
        keyQueueCount(winIdx) = KEY_QUEUE_MAX - 1
    END IF

    keyQueueText(winIdx, keyQueueTail(winIdx)) = keyText
    keyQueueScan(winIdx, keyQueueTail(winIdx)) = scanCode
    keyQueueAscii(winIdx, keyQueueTail(winIdx)) = asciiCode
    keyQueueFlags(winIdx, keyQueueTail(winIdx)) = flagsValue
    keyQueueTail(winIdx) = keyQueueTail(winIdx) + 1
    IF keyQueueTail(winIdx) > KEY_QUEUE_MAX THEN keyQueueTail(winIdx) = 1
    keyQueueCount(winIdx) = keyQueueCount(winIdx) + 1
END SUB

FUNCTION KeyQueuePeek(BYVAL winIdx AS INTEGER, BYREF keyText AS STRING, BYREF scanCode AS INTEGER, BYREF asciiCode AS INTEGER, BYREF flagsValue AS INTEGER) AS INTEGER
    keyText = ""
    scanCode = 0
    asciiCode = 0
    flagsValue = 0
    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN RETURN 0
    IF layoutWindows(winIdx).used = 0 THEN RETURN 0
    IF keyQueueCount(winIdx) <= 0 THEN RETURN 0
    IF keyQueueHead(winIdx) < 1 OR keyQueueHead(winIdx) > KEY_QUEUE_MAX THEN keyQueueHead(winIdx) = 1

    keyText = keyQueueText(winIdx, keyQueueHead(winIdx))
    scanCode = keyQueueScan(winIdx, keyQueueHead(winIdx))
    asciiCode = keyQueueAscii(winIdx, keyQueueHead(winIdx))
    flagsValue = keyQueueFlags(winIdx, keyQueueHead(winIdx))
    RETURN -1
END FUNCTION

FUNCTION KeyQueueRead(BYVAL winIdx AS INTEGER, BYREF keyText AS STRING, BYREF scanCode AS INTEGER, BYREF asciiCode AS INTEGER, BYREF flagsValue AS INTEGER) AS INTEGER
    IF KeyQueuePeek(winIdx, keyText, scanCode, asciiCode, flagsValue) = 0 THEN RETURN 0

    keyQueueText(winIdx, keyQueueHead(winIdx)) = ""
    keyQueueScan(winIdx, keyQueueHead(winIdx)) = 0
    keyQueueAscii(winIdx, keyQueueHead(winIdx)) = 0
    keyQueueFlags(winIdx, keyQueueHead(winIdx)) = 0
    keyQueueHead(winIdx) = keyQueueHead(winIdx) + 1
    IF keyQueueHead(winIdx) > KEY_QUEUE_MAX THEN keyQueueHead(winIdx) = 1
    keyQueueCount(winIdx) = keyQueueCount(winIdx) - 1
    IF keyQueueCount(winIdx) < 0 THEN keyQueueCount(winIdx) = 0
    RETURN -1
END FUNCTION

SUB KeyQueuePushInkey(BYVAL winIdx AS INTEGER, BYVAL keyIn AS STRING)
    DIM keyText AS STRING

    keyText = KeyTokenFromInkey(keyIn)
    IF keyText = "" THEN EXIT SUB
    KeyQueuePush winIdx, keyText, KeyScanFromInkey(keyIn), KeyAsciiFromInkey(keyIn), KeyFlagsNow()
END SUB

FUNCTION DispatchFocusedControlKeyAction(BYVAL keyIn AS STRING) AS INTEGER
    DIM elemIdx AS INTEGER
    DIM actionText AS STRING
    DIM tokenText AS STRING
    DIM actionActiveOnlyRedraw AS INTEGER
    DIM actionStartWin AS INTEGER
    DIM actionStartWindowCount AS INTEGER

    DispatchFocusedControlKeyAction = 0
    IF keyIn = "" THEN EXIT FUNCTION
    IF activeLayoutWindow < LBOUND(layoutWindows) OR activeLayoutWindow > UBOUND(layoutWindows) THEN EXIT FUNCTION
    IF layoutWindows(activeLayoutWindow).used = 0 THEN EXIT FUNCTION
    elemIdx = uiFocusIndex
    IF elemIdx < 1 OR elemIdx > uiCount THEN EXIT FUNCTION

    actionText = ""
    IF LEN(keyIn) = 1 THEN
        SELECT CASE ASC(keyIn)
        CASE 13
            actionText = TRIM$(uiElems(elemIdx).enterAction)
        CASE 27
            actionText = TRIM$(uiElems(elemIdx).escAction)
        END SELECT
    END IF

    IF actionText = "" THEN
        IF uiElems(elemIdx).keyCapture <> 0 THEN
            actionText = TRIM$(uiElems(elemIdx).keyAction)
            IF actionText <> "" THEN
                tokenText = LayoutInteractiveKeyToken(keyIn)
                IF tokenText <> "" THEN actionText = actionText + " " + tokenText
            END IF
        END IF
    END IF

    IF actionText = "" THEN EXIT FUNCTION

    IF uiElems(elemIdx).kindId = UI_KIND_TEXTBOX THEN
        IF uiEdit(elemIdx).txtLen = 0 AND uiEdit(elemIdx).txt = "" THEN Ed_LoadTxt uiEdit(elemIdx), uiElems(elemIdx).text, uiCaretPos
        Ed_SyncGlue uiEdit(elemIdx), uiElems(elemIdx).text, uiCaretPos
        SaveActiveTextboxDrawStateToWindow activeLayoutWindow, elemIdx
    ELSE
        layoutUiElems(activeLayoutWindow, elemIdx) = uiElems(elemIdx)
        layoutWindows(activeLayoutWindow).focusIndex = elemIdx
    END IF

    actionActiveOnlyRedraw = HostActionDirectActiveWindowRedrawOnly(actionText)
    actionStartWin = activeLayoutWindow
    actionStartWindowCount = layoutWindowCount

    HostAppAction activeLayoutWindow, actionText

    ' Return 2 when the key action only dirtied the active window.
    ' Complex key actions keep the caller on the full-redraw path.
    DispatchFocusedControlKeyAction = 1
    IF actionActiveOnlyRedraw <> 0 THEN
        IF activeLayoutWindow = actionStartWin AND layoutWindowCount = actionStartWindowCount THEN
            ' Context-menu state is local to the main loop, so this helper only
            ' checks the global overlay states it can safely see.
            IF startMenuOpen = 0 AND launchCtxOpen = 0 AND desktopCtxOpen = 0 THEN
                DispatchFocusedControlKeyAction = 2
            END IF
        END IF
    END IF
END FUNCTION


FUNCTION SysTextWithArg(BYVAL srcText AS STRING, BYVAL argText AS STRING) AS STRING
    DIM replacePos AS INTEGER

    DO
        replacePos = INSTR(srcText, "$1")
        IF replacePos <= 0 THEN EXIT DO
        srcText = LEFT$(srcText, replacePos - 1) + argText + MID$(srcText, replacePos + 2)
    LOOP

    RETURN srcText
END FUNCTION


' ---------------------------
' Generic per-window APP/SYS variables
' ---------------------------

FUNCTION AppVarNormalizeName(BYVAL nameText AS STRING) AS STRING
    nameText = UCASE$(TRIM$(nameText))
    IF LEN(nameText) > APPVAR_NAME_LIMIT THEN nameText = LEFT$(nameText, APPVAR_NAME_LIMIT)
    RETURN nameText
END FUNCTION

FUNCTION AppVarSlot(BYVAL winIdx AS INTEGER, BYVAL nameText AS STRING, BYVAL createFlag AS INTEGER) AS INTEGER
    DIM n AS STRING
    DIM i AS INTEGER
    DIM firstFree AS INTEGER

    AppVarSlot = 0
    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT FUNCTION
    IF layoutWindows(winIdx).used = 0 THEN EXIT FUNCTION

    n = AppVarNormalizeName(nameText)
    IF n = "" THEN EXIT FUNCTION

    firstFree = 0
    FOR i = 1 TO APPVAR_MAX_SLOTS
        IF appVarWin(i) = winIdx THEN
            IF appVarName(i) = n THEN RETURN i
        ELSEIF appVarWin(i) = 0 THEN
            IF firstFree = 0 THEN firstFree = i
        END IF
    NEXT

    IF createFlag <> 0 AND firstFree <> 0 THEN
        appVarWin(firstFree) = winIdx
        appVarName(firstFree) = n
        appVarValue(firstFree) = ""
        RETURN firstFree
    END IF
END FUNCTION

FUNCTION AppVarGet(BYVAL winIdx AS INTEGER, BYVAL nameText AS STRING) AS STRING
    DIM slotIdx AS INTEGER
    slotIdx = AppVarSlot(winIdx, nameText, 0)
    IF slotIdx = 0 THEN RETURN ""
    RETURN appVarValue(slotIdx)
END FUNCTION

SUB AppVarSet(BYVAL winIdx AS INTEGER, BYVAL nameText AS STRING, BYVAL valueText AS STRING)
    DIM slotIdx AS INTEGER

    slotIdx = AppVarSlot(winIdx, nameText, -1)
    IF slotIdx = 0 THEN EXIT SUB
    IF LEN(valueText) > APPVAR_VALUE_LIMIT THEN valueText = LEFT$(valueText, APPVAR_VALUE_LIMIT)
    appVarValue(slotIdx) = valueText
END SUB

SUB AppVarClearOne(BYVAL winIdx AS INTEGER, BYVAL nameText AS STRING)
    DIM slotIdx AS INTEGER
    slotIdx = AppVarSlot(winIdx, nameText, 0)
    IF slotIdx = 0 THEN EXIT SUB
    appVarWin(slotIdx) = 0
    appVarName(slotIdx) = ""
    appVarValue(slotIdx) = ""
END SUB

SUB AppVarClearWindow(BYVAL winIdx AS INTEGER)
    DIM i AS INTEGER
    FOR i = 1 TO APPVAR_MAX_SLOTS
        IF appVarWin(i) = winIdx THEN
            appVarWin(i) = 0
            appVarName(i) = ""
            appVarValue(i) = ""
        END IF
    NEXT
END SUB

SUB AppVarClearPrefix(BYVAL winIdx AS INTEGER, BYVAL prefixText AS STRING)
    DIM i AS INTEGER
    DIM p AS STRING

    p = AppVarNormalizeName(prefixText)
    IF p = "" THEN EXIT SUB
    FOR i = 1 TO APPVAR_MAX_SLOTS
        IF appVarWin(i) = winIdx THEN
            IF LEFT$(appVarName(i), LEN(p)) = p THEN
                appVarWin(i) = 0
                appVarName(i) = ""
                appVarValue(i) = ""
            END IF
        END IF
    NEXT
END SUB

FUNCTION AppVarInt(BYVAL winIdx AS INTEGER, BYVAL nameText AS STRING) AS LONG
    RETURN VAL(AppVarGet(winIdx, nameText))
END FUNCTION

FUNCTION AppVarExpandText(BYVAL winIdx AS INTEGER, BYVAL srcText AS STRING) AS STRING
    DIM outText AS STRING
    DIM pctPos AS INTEGER
    DIM pctEnd AS INTEGER
    DIM tokenName AS STRING

    outText = ""
    DO WHILE srcText <> ""
        pctPos = INSTR(srcText, "%")
        IF pctPos <= 0 THEN
            outText = outText + srcText
            EXIT DO
        END IF

        outText = outText + LEFT$(srcText, pctPos - 1)
        srcText = MID$(srcText, pctPos + 1)
        pctEnd = INSTR(srcText, "%")
        IF pctEnd <= 0 THEN
            outText = outText + "%" + srcText
            EXIT DO
        END IF

        tokenName = LEFT$(srcText, pctEnd - 1)
        outText = outText + AppVarGet(winIdx, tokenName)
        srcText = MID$(srcText, pctEnd + 1)
    LOOP

    RETURN outText
END FUNCTION

FUNCTION AppVarDecodeEscapes(BYVAL srcText AS STRING) AS STRING
    DIM outText AS STRING
    DIM scanIdx AS INTEGER
    DIM chText AS STRING
    DIM escText AS STRING

    outText = ""
    scanIdx = 1
    DO WHILE scanIdx <= LEN(srcText)
        chText = MID$(srcText, scanIdx, 1)
        IF chText = "\" AND scanIdx < LEN(srcText) THEN
            escText = MID$(srcText, scanIdx + 1, 1)
            SELECT CASE escText
            CASE "n", "N"
                outText = outText + CHR$(13) + CHR$(10)
                scanIdx = scanIdx + 2
            CASE "r", "R"
                outText = outText + CHR$(13)
                scanIdx = scanIdx + 2
            CASE "t", "T"
                outText = outText + CHR$(9)
                scanIdx = scanIdx + 2
            CASE "\"
                outText = outText + "\"
                scanIdx = scanIdx + 2
            CASE ELSE
                outText = outText + chText
                scanIdx = scanIdx + 1
            END SELECT
        ELSE
            outText = outText + chText
            scanIdx = scanIdx + 1
        END IF
    LOOP

    RETURN outText
END FUNCTION

FUNCTION AppVarCompare(BYVAL winIdx AS INTEGER, BYVAL opText AS STRING, BYVAL nameText AS STRING, BYVAL valueText AS STRING) AS INTEGER
    DIM leftText AS STRING
    DIM rightText AS STRING
    DIM leftVal AS LONG
    DIM rightVal AS LONG

    opText = UCASE$(TRIM$(opText))
    leftText = AppVarGet(winIdx, nameText)
    rightText = AppVarExpandText(winIdx, valueText)

    SELECT CASE opText
    CASE "EQ"
        RETURN (leftText = rightText)
    CASE "NE"
        RETURN (leftText <> rightText)
    CASE "EMPTY"
        RETURN (TRIM$(leftText) = "")
    CASE "NOT_EMPTY"
        RETURN (TRIM$(leftText) <> "")
    CASE ELSE
        leftVal = VAL(leftText)
        rightVal = VAL(rightText)
        SELECT CASE opText
        CASE "GT"
            RETURN (leftVal > rightVal)
        CASE "GE"
            RETURN (leftVal >= rightVal)
        CASE "LT"
            RETURN (leftVal < rightVal)
        CASE "LE"
            RETURN (leftVal <= rightVal)
        END SELECT
    END SELECT

    RETURN 0
END FUNCTION

FUNCTION AppVarControlState(BYVAL winIdx AS INTEGER, BYVAL controlName AS STRING) AS INTEGER
    DIM i AS INTEGER
    DIM targetName AS STRING

    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN RETURN 0
    IF layoutWindows(winIdx).used = 0 THEN RETURN 0
    targetName = UCASE$(TRIM$(controlName))
    IF targetName = "" THEN RETURN 0

    FOR i = 1 TO layoutUiCount(winIdx)
        IF UCASE$(TRIM$(layoutUiElems(winIdx, i).name)) = targetName THEN
            IF layoutUiElems(winIdx, i).state <> 0 THEN RETURN 1
            RETURN 0
        END IF
    NEXT
    RETURN 0
END FUNCTION

SUB AppVarSetControlState(BYVAL winIdx AS INTEGER, BYVAL controlName AS STRING, BYVAL stateValue AS INTEGER)
    DIM i AS INTEGER
    DIM targetName AS STRING

    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(winIdx).used = 0 THEN EXIT SUB
    targetName = UCASE$(TRIM$(controlName))
    IF targetName = "" THEN EXIT SUB

    FOR i = 1 TO layoutUiCount(winIdx)
        IF UCASE$(TRIM$(layoutUiElems(winIdx, i).name)) = targetName THEN
            IF stateValue <> 0 THEN
                layoutUiElems(winIdx, i).state = -1
            ELSE
                layoutUiElems(winIdx, i).state = 0
            END IF
            IF activeLayoutWindow = winIdx THEN uiElems(i) = layoutUiElems(winIdx, i)
            MarkLayoutDirtyElement winIdx, i
            MarkLayoutWindowVisualDirty winIdx
            EXIT SUB
        END IF
    NEXT
END SUB

SUB AppVarSaveToFile(BYVAL winIdx AS INTEGER, BYVAL fileName AS STRING)
    DIM f AS INTEGER
    DIM i AS INTEGER
    DIM savePath AS STRING

    savePath = ResolveAppLocalFilePath(winIdx, fileName)
    IF savePath = "" THEN EXIT SUB
    f = FREEFILE
    IF OPEN(savePath FOR OUTPUT AS #f) <> 0 THEN EXIT SUB
    PRINT #f, "# BACKLASH_APPVAR_V1"
    FOR i = 1 TO APPVAR_MAX_SLOTS
        IF appVarWin(i) = winIdx THEN
            PRINT #f, appVarName(i) + "=" + SessionHexEncode(appVarValue(i))
        END IF
    NEXT
    CLOSE #f
    InvalidateCfgReadCacheForFile savePath
END SUB

SUB AppVarLoadFromFile(BYVAL winIdx AS INTEGER, BYVAL fileName AS STRING)
    DIM f AS INTEGER
    DIM loadPath AS STRING
    DIM lineText AS STRING
    DIM p AS INTEGER
    DIM n AS STRING
    DIM v AS STRING

    loadPath = ResolveAppLocalFilePath(winIdx, fileName)
    IF loadPath = "" THEN EXIT SUB
    IF DIR(LayoutFilePath(loadPath)) = "" THEN EXIT SUB

    f = FREEFILE
    IF OPEN(loadPath FOR INPUT AS #f) <> 0 THEN EXIT SUB
    DO WHILE EOF(f) = 0
        LINE INPUT #f, lineText
        lineText = TRIM$(lineText)
        IF lineText <> "" THEN
            IF LEFT$(lineText, 1) <> "#" THEN
                p = INSTR(lineText, "=")
                IF p > 1 THEN
                    n = LEFT$(lineText, p - 1)
                    v = MID$(lineText, p + 1)
                    AppVarSet winIdx, n, SessionHexDecode(v)
                END IF
            END IF
        END IF
    LOOP
    CLOSE #f
END SUB

FUNCTION ActiveFocusedTextbox() AS INTEGER
    IF ActiveFocusedTextboxIndex() <> 0 THEN RETURN -1
    RETURN 0
END FUNCTION

FUNCTION ActiveFocusedTextboxIndex() AS INTEGER
    DIM f AS INTEGER

    IF activeLayoutWindow < LBOUND(layoutWindows) OR activeLayoutWindow > UBOUND(layoutWindows) THEN RETURN 0
    IF layoutWindows(activeLayoutWindow).used = 0 THEN RETURN 0

    f = layoutWindows(activeLayoutWindow).focusIndex
    IF f < 1 OR f > layoutUiCount(activeLayoutWindow) THEN RETURN 0

    IF layoutUiElems(activeLayoutWindow, f).kindId = UI_KIND_TEXTBOX THEN RETURN f
    RETURN 0
END FUNCTION


FUNCTION ReadTextFileRaw(BYVAL fileName AS STRING) AS STRING
    DIM f AS INTEGER
    DIM n AS INTEGER
    DIM dataText AS STRING

    IF fileName = "" THEN RETURN ""
    f = FREEFILE
    IF OPEN(fileName FOR BINARY ACCESS READ AS #f) <> 0 THEN RETURN ""
    n = LOF(f)
    IF n > 0 THEN
        dataText = SPACE$(n)
        GET #f, , dataText
    ELSE
        dataText = ""
    END IF
    CLOSE #f
    RETURN dataText
END FUNCTION

FUNCTION WriteTextFileRaw(BYVAL fileName AS STRING, BYVAL dataText AS STRING) AS INTEGER
    DIM f AS INTEGER

    IF fileName = "" THEN RETURN 0
    f = FREEFILE
    IF OPEN(fileName FOR BINARY ACCESS WRITE AS #f) <> 0 THEN RETURN 0
    IF LEN(dataText) > 0 THEN PUT #f, , dataText
    CLOSE #f
    RETURN -1
END FUNCTION

SUB SetTextboxTextByName(BYVAL controlName AS STRING, BYVAL dataText AS STRING)
    DIM idx AS INTEGER

    idx = GetControlIndexByName(controlName)
    IF idx < 1 OR idx > uiCount THEN EXIT SUB
    IF uiElems(idx).kindId <> UI_KIND_TEXTBOX THEN EXIT SUB

    Ed_SetTextGlue uiEdit(idx), dataText, uiElems(idx).text, uiCaretPos
    InvalidateTextboxMetrics idx

    IF activeLayoutWindow >= 1 AND activeLayoutWindow <= 12 THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN comboScrollTop(activeLayoutWindow, idx) = 0
    END IF

    IF activeLayoutWindow >= 1 AND activeLayoutWindow <= 12 THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
            layoutUiElems(activeLayoutWindow, idx) = uiElems(idx)
            layoutUiEdit(activeLayoutWindow, idx) = uiEdit(idx)
        END IF
    END IF

    IF uiElems(idx).noEdit = 0 THEN
        uiFocusIndex = idx
        uiScrollY = 0
        uiScrollX = 0
        uiCaretVisible = -1
        uiLastCaretBlink = TIMER

        IF activeLayoutWindow >= 1 AND activeLayoutWindow <= 12 THEN
            IF layoutWindows(activeLayoutWindow).used <> 0 THEN
                layoutWindows(activeLayoutWindow).focusIndex = idx
                layoutWindows(activeLayoutWindow).caretPos = uiCaretPos
                layoutWindows(activeLayoutWindow).scrollY = 0
                layoutWindows(activeLayoutWindow).scrollX = 0
            END IF
        END IF
    ELSE
        IF uiFocusIndex = idx THEN uiFocusIndex = 0
        IF activeLayoutWindow >= 1 AND activeLayoutWindow <= 12 THEN
            IF layoutWindows(activeLayoutWindow).used <> 0 THEN
                IF layoutWindows(activeLayoutWindow).focusIndex = idx THEN layoutWindows(activeLayoutWindow).focusIndex = 0
            END IF
        END IF
    END IF

    ' This setter already writes the changed textbox back into the window slot.
    ' Mark only the visual cache dirty instead of forcing callers to deep-sync the whole window.
    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
            MarkLayoutDirtyElement activeLayoutWindow, idx
            MarkLayoutWindowVisualDirty activeLayoutWindow
        END IF
    END IF
END SUB

SUB SetTextboxCaretEndByName(BYVAL controlName AS STRING)
    DIM idx AS INTEGER

    idx = GetControlIndexByName(controlName)
    IF idx < 1 OR idx > uiCount THEN EXIT SUB
    IF uiElems(idx).kindId <> UI_KIND_TEXTBOX THEN EXIT SUB

    IF uiEdit(idx).txtLen = 0 AND uiEdit(idx).txt = "" THEN Ed_LoadTxt uiEdit(idx), uiElems(idx).text, LEN(uiElems(idx).text)
    uiEdit(idx).curPos = uiEdit(idx).txtLen
    Ed_SelClr uiEdit(idx)
    Ed_SyncGlue uiEdit(idx), uiElems(idx).text, uiCaretPos
    SyncTextboxScrollToCaret idx

    IF uiElems(idx).noEdit = 0 THEN
        uiFocusIndex = idx
        uiCaretVisible = -1
        uiLastCaretBlink = TIMER
    END IF

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
            layoutUiElems(activeLayoutWindow, idx) = uiElems(idx)
            layoutUiEdit(activeLayoutWindow, idx) = uiEdit(idx)
            layoutWindows(activeLayoutWindow).focusIndex = uiFocusIndex
            layoutWindows(activeLayoutWindow).caretPos = uiCaretPos
            MarkLayoutDirtyElement activeLayoutWindow, idx
            MarkLayoutWindowVisualDirty activeLayoutWindow
        END IF
    END IF
END SUB

SUB SetDialogTargetControlText(BYVAL targetWin AS INTEGER, BYVAL controlName AS STRING, BYVAL dataText AS STRING)
    DIM idx AS INTEGER
    DIM i AS INTEGER
    DIM targetName AS STRING
    DIM elemName AS STRING
    DIM caretPos AS INTEGER

    IF targetWin < LBOUND(layoutWindows) OR targetWin > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(targetWin).used = 0 THEN EXIT SUB

    targetName = UCASE$(TRIM$(controlName))
    IF targetName = "" THEN EXIT SUB

    idx = 0
    FOR i = 1 TO layoutUiCount(targetWin)
        elemName = UCASE$(TRIM$(layoutUiElems(targetWin, i).name))
        IF elemName = targetName THEN
            idx = i
            EXIT FOR
        END IF
    NEXT

    IF idx < 1 OR idx > layoutUiCount(targetWin) THEN EXIT SUB

    SELECT CASE layoutUiElems(targetWin, idx).kindKey
    CASE "TEXTBOX"
        caretPos = LEN(dataText)
        Ed_SetTextGlue layoutUiEdit(targetWin, idx), dataText, layoutUiElems(targetWin, idx).text, caretPos
        InvalidateTextboxMetrics idx
        comboScrollTop(targetWin, idx) = 0
        IF layoutWindows(targetWin).focusIndex = idx THEN layoutWindows(targetWin).caretPos = caretPos

    CASE ELSE
        layoutUiElems(targetWin, idx).text = dataText
    END SELECT

    IF layoutUiElems(targetWin, idx).bindFile <> "" AND layoutUiElems(targetWin, idx).bindKey <> "" THEN
        SetCfgValueInSection layoutUiElems(targetWin, idx).bindFile, _
                             layoutUiElems(targetWin, idx).bindSection, _
                             layoutUiElems(targetWin, idx).bindKey, dataText
    END IF

    MarkLayoutDirtyElement targetWin, idx
    MarkLayoutWindowVisualDirty targetWin
    IF activeLayoutWindow = targetWin THEN SyncGlobalsFromLayoutWindow targetWin
END SUB

SUB SetDialogTargetControlTextNoBind(BYVAL targetWin AS INTEGER, BYVAL controlName AS STRING, BYVAL dataText AS STRING)
    DIM idx AS INTEGER
    DIM i AS INTEGER
    DIM targetName AS STRING
    DIM elemName AS STRING
    DIM caretPos AS INTEGER
    DIM bindWasChanged AS INTEGER

    IF targetWin < LBOUND(layoutWindows) OR targetWin > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(targetWin).used = 0 THEN EXIT SUB

    targetName = UCASE$(TRIM$(controlName))
    IF targetName = "" THEN EXIT SUB

    idx = 0
    FOR i = 1 TO layoutUiCount(targetWin)
        elemName = UCASE$(TRIM$(layoutUiElems(targetWin, i).name))
        IF elemName = targetName THEN
            idx = i
            EXIT FOR
        END IF
    NEXT

    IF idx < 1 OR idx > layoutUiCount(targetWin) THEN EXIT SUB

    SELECT CASE layoutUiElems(targetWin, idx).kindKey
    CASE "TEXTBOX"
        caretPos = LEN(dataText)
        Ed_SetTextGlue layoutUiEdit(targetWin, idx), dataText, layoutUiElems(targetWin, idx).text, caretPos
        InvalidateTextboxMetrics idx
        comboScrollTop(targetWin, idx) = 0
        IF layoutWindows(targetWin).focusIndex = idx THEN layoutWindows(targetWin).caretPos = caretPos

    CASE ELSE
        layoutUiElems(targetWin, idx).text = dataText
    END SELECT

    bindWasChanged = 0
    IF TRIM$(layoutUiElems(targetWin, idx).bindFile) <> "" AND TRIM$(layoutUiElems(targetWin, idx).bindKey) <> "" THEN bindWasChanged = -1

    IF bindWasChanged <> 0 THEN
        MarkWindowPresetDirty targetWin
        InvalidateLivePreviewCachesForWindow targetWin
    END IF

    MarkLayoutDirtyElement targetWin, idx
    MarkLayoutWindowVisualDirty targetWin
    IF activeLayoutWindow = targetWin THEN SyncGlobalsFromLayoutWindow targetWin
END SUB

SUB ControlEditClearTransfer()
    DIM i AS INTEGER

    controlEditSourceWin = 0
    controlEditDialogWin = 0
    controlEditMapCount = 0
    FOR i = 1 TO 16
        controlEditSourceName(i) = ""
        controlEditDialogName(i) = ""
    NEXT
END SUB

SUB ControlEditOpenFromSys(BYVAL sourceWin AS INTEGER, BYVAL sysFileName AS STRING, BYVAL sysSectionName AS STRING, BYVAL sysArg1 AS STRING)
    DIM dialogPath AS STRING
    DIM profileMode AS STRING
    DIM mapText AS STRING
    DIM srcControl AS STRING
    DIM dlgControl AS STRING
    DIM sepPos AS INTEGER
    DIM mapIdx AS INTEGER
    DIM dialogWin AS INTEGER
    DIM copiedValue AS STRING

    IF sourceWin < LBOUND(layoutWindows) OR sourceWin > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(sourceWin).used = 0 THEN EXIT SUB

    dialogPath = TRIM$(SysTextWithArg(ReadCfgValueInSection(sysFileName, sysSectionName, "DIALOG", ""), sysArg1))
    IF dialogPath = "" THEN dialogPath = TRIM$(SysTextWithArg(ReadCfgValueInSection(sysFileName, sysSectionName, "VALUE", ""), sysArg1))
    IF dialogPath = "" THEN EXIT SUB
    dialogPath = ResolvePathFromAppWindow(sourceWin, dialogPath)
    IF DIR(LayoutFilePath(dialogPath)) = "" THEN EXIT SUB

    profileMode = TRIM$(SysTextWithArg(ReadCfgValueInSection(sysFileName, sysSectionName, "PROFILE", ""), sysArg1))
    IF profileMode = "" THEN profileMode = TRIM$(SysTextWithArg(ReadCfgValueInSection(sysFileName, sysSectionName, "MODE", ""), sysArg1))

    ControlEditClearTransfer
    controlEditSourceWin = sourceWin

    FOR mapIdx = 1 TO 16
        mapText = TRIM$(SysTextWithArg(ReadCfgValueInSection(sysFileName, sysSectionName, "COPY_" + LTRIM$(STR$(mapIdx)), ""), sysArg1))
        IF mapText = "" THEN mapText = TRIM$(SysTextWithArg(ReadCfgValueInSection(sysFileName, sysSectionName, "MAP_" + LTRIM$(STR$(mapIdx)), ""), sysArg1))
        IF mapText <> "" THEN
            sepPos = INSTR(mapText, "|")
            IF sepPos > 0 THEN
                srcControl = TRIM$(LEFT$(mapText, sepPos - 1))
                dlgControl = TRIM$(MID$(mapText, sepPos + 1))
                IF srcControl <> "" AND dlgControl <> "" THEN
                    controlEditMapCount = controlEditMapCount + 1
                    controlEditSourceName(controlEditMapCount) = srcControl
                    controlEditDialogName(controlEditMapCount) = dlgControl
                END IF
            END IF
        END IF
    NEXT

    IF controlEditMapCount < 1 THEN
        ControlEditClearTransfer
        EXIT SUB
    END IF

    SyncLayoutWindowFromGlobals sourceWin
    IF profileMode <> "" THEN
        OpenDialogLayoutAndApplyProfile dialogPath, "", profileMode, 0
    ELSE
        OpenLayoutAppWindow dialogPath
    END IF

    dialogWin = activeLayoutWindow
    IF dialogWin < LBOUND(layoutWindows) OR dialogWin > UBOUND(layoutWindows) THEN
        ControlEditClearTransfer
        EXIT SUB
    END IF
    IF layoutWindows(dialogWin).used = 0 THEN
        ControlEditClearTransfer
        EXIT SUB
    END IF

    controlEditDialogWin = dialogWin
    FOR mapIdx = 1 TO controlEditMapCount
        copiedValue = GetDialogControlTextValue(sourceWin, controlEditSourceName(mapIdx))
        SetDialogTargetControlTextNoBind dialogWin, controlEditDialogName(mapIdx), copiedValue
    NEXT
    MarkLayoutWindowVisualDirty dialogWin
END SUB

SUB ControlEditApplyClose(BYVAL dialogWin AS INTEGER)
    DIM sourceWin AS INTEGER
    DIM mapIdx AS INTEGER
    DIM copiedValue AS STRING

    IF dialogWin < LBOUND(layoutWindows) OR dialogWin > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(dialogWin).used = 0 THEN EXIT SUB
    IF controlEditDialogWin <> dialogWin THEN
        CloseLayoutWindow dialogWin
        EXIT SUB
    END IF

    sourceWin = controlEditSourceWin
    IF sourceWin < LBOUND(layoutWindows) OR sourceWin > UBOUND(layoutWindows) THEN
        CloseLayoutWindow dialogWin
        ControlEditClearTransfer
        EXIT SUB
    END IF
    IF layoutWindows(sourceWin).used = 0 THEN
        CloseLayoutWindow dialogWin
        ControlEditClearTransfer
        EXIT SUB
    END IF

    FOR mapIdx = 1 TO controlEditMapCount
        copiedValue = GetDialogControlTextValue(dialogWin, controlEditDialogName(mapIdx))
        SetDialogTargetControlTextNoBind sourceWin, controlEditSourceName(mapIdx), copiedValue
    NEXT

    MarkLayoutWindowVisualDirty sourceWin
    CloseLayoutWindow dialogWin
    ControlEditClearTransfer
END SUB

FUNCTION GetDialogControlTextValue(BYVAL targetWin AS INTEGER, BYVAL controlName AS STRING) AS STRING
    DIM idx AS INTEGER
    DIM i AS INTEGER
    DIM targetName AS STRING
    DIM elemName AS STRING

    IF targetWin < LBOUND(layoutWindows) OR targetWin > UBOUND(layoutWindows) THEN RETURN ""
    IF layoutWindows(targetWin).used = 0 THEN RETURN ""

    targetName = UCASE$(TRIM$(controlName))
    IF targetName = "" THEN RETURN ""

    idx = 0
    FOR i = 1 TO layoutUiCount(targetWin)
        elemName = UCASE$(TRIM$(layoutUiElems(targetWin, i).name))
        IF elemName = targetName THEN
            idx = i
            EXIT FOR
        END IF
    NEXT

    IF idx < 1 OR idx > layoutUiCount(targetWin) THEN RETURN ""

    SELECT CASE layoutUiElems(targetWin, idx).kindKey
    CASE "TEXTBOX"
        RETURN Ed_GetTextGlue(layoutUiEdit(targetWin, idx), layoutUiElems(targetWin, idx).text)
    CASE ELSE
        RETURN RTRIM$(layoutUiElems(targetWin, idx).text)
    END SELECT
END FUNCTION

FUNCTION GetDialogBoundControlTextValue(BYVAL targetWin AS INTEGER, BYVAL bindFileName AS STRING, BYVAL bindSectionName AS STRING, BYVAL bindKeyName AS STRING) AS STRING
    DIM i AS INTEGER
    DIM targetFile AS STRING
    DIM elemFile AS STRING
    DIM targetSection AS STRING
    DIM targetKey AS STRING

    IF targetWin < LBOUND(layoutWindows) OR targetWin > UBOUND(layoutWindows) THEN RETURN ""
    IF layoutWindows(targetWin).used = 0 THEN RETURN ""

    targetFile = UCASE$(NormalizePath(LayoutFilePath(bindFileName)))
    targetSection = UCASE$(TRIM$(bindSectionName))
    targetKey = UCASE$(TRIM$(bindKeyName))
    IF targetFile = "" OR targetKey = "" THEN RETURN ""

    FOR i = 1 TO layoutUiCount(targetWin)
        elemFile = UCASE$(NormalizePath(LayoutFilePath(layoutUiElems(targetWin, i).bindFile)))
        IF elemFile = targetFile THEN
            IF UCASE$(TRIM$(layoutUiElems(targetWin, i).bindSection)) = targetSection THEN
                IF UCASE$(TRIM$(layoutUiElems(targetWin, i).bindKey)) = targetKey THEN
                    SELECT CASE layoutUiElems(targetWin, i).kindKey
                    CASE "TEXTBOX"
                        RETURN Ed_GetTextGlue(layoutUiEdit(targetWin, i), layoutUiElems(targetWin, i).text)
                    CASE ELSE
                        RETURN RTRIM$(layoutUiElems(targetWin, i).text)
                    END SELECT
                END IF
            END IF
        END IF
    NEXT

    RETURN ""
END FUNCTION

FUNCTION SessionHexEncode(BYVAL sourceText AS STRING) AS STRING
    DIM i AS INTEGER
    DIM b AS INTEGER
    DIM hx AS STRING
    DIM outText AS STRING

    outText = ""
    FOR i = 1 TO LEN(sourceText)
        b = ASC(MID$(sourceText, i, 1)) AND &HFF
        hx = HEX$(b)
        IF LEN(hx) < 2 THEN hx = "0" + hx
        outText = outText + RIGHT$(hx, 2)
    NEXT

    RETURN outText
END FUNCTION

FUNCTION SessionHexNibble(BYVAL ch AS STRING) AS INTEGER
    ch = UCASE$(LEFT$(ch, 1))
    IF ch >= "0" AND ch <= "9" THEN RETURN ASC(ch) - ASC("0")
    IF ch >= "A" AND ch <= "F" THEN RETURN ASC(ch) - ASC("A") + 10
    RETURN 0
END FUNCTION

FUNCTION SessionHexDecode(BYVAL hexText AS STRING) AS STRING
    DIM i AS INTEGER
    DIM hiNib AS INTEGER
    DIM loNib AS INTEGER
    DIM outText AS STRING

    outText = ""
    IF LEN(hexText) < 2 THEN RETURN outText

    FOR i = 1 TO LEN(hexText) - 1 STEP 2
        hiNib = SessionHexNibble(MID$(hexText, i, 1))
        loNib = SessionHexNibble(MID$(hexText, i + 1, 1))
        outText = outText + CHR$((hiNib * 16) + loNib)
    NEXT

    RETURN outText
END FUNCTION

SUB ClearSessionRestoreControlBuffer()
    DIM i AS INTEGER
    FOR i = 1 TO sessionRestoreCtrlCount
        sessionRestoreCtrlSlot(i) = 0
        sessionRestoreCtrlName(i) = ""
        sessionRestoreCtrlKind(i) = ""
        sessionRestoreCtrlText(i) = ""
        sessionRestoreCtrlMulti(i) = ""
        sessionRestoreCtrlSourceDir(i) = ""
        sessionRestoreCtrlSourceMask(i) = ""
        sessionRestoreCtrlSourceItems(i) = ""
        sessionRestoreCtrlState(i) = 0
        sessionRestoreCtrlScroll(i) = 0
        sessionRestoreCtrlAnchor(i) = 0
        sessionRestoreCtrlCur(i) = 0
        sessionRestoreCtrlSelA(i) = 0
        sessionRestoreCtrlSelB(i) = 0
    NEXT
    sessionRestoreCtrlCount = 0
END SUB

FUNCTION SessionSaveableControlKind(BYVAL kindText AS STRING) AS INTEGER
    kindText = UCASE$(TRIM$(kindText))
    SELECT CASE kindText
    CASE "TEXTBOX", "COMBO", "LISTBOX", "RADIO", "CHECKBOX", "APPVIEW"
        RETURN -1
    END SELECT
    RETURN 0
END FUNCTION

FUNCTION SessionLayoutControlIndex(BYVAL winIdx AS INTEGER, BYVAL controlName AS STRING) AS INTEGER
    SessionLayoutControlIndex = LayoutControlIndexByName(winIdx, controlName)
END FUNCTION

FUNCTION SessionLayoutControlText(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER) AS STRING
    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN RETURN ""
    IF elemIdx < 1 OR elemIdx > layoutUiCount(winIdx) THEN RETURN ""

    SELECT CASE layoutUiElems(winIdx, elemIdx).kindKey
    CASE "TEXTBOX"
        RETURN Ed_GetTextGlue(layoutUiEdit(winIdx, elemIdx), layoutUiElems(winIdx, elemIdx).text)
    CASE ELSE
        RETURN RTRIM$(layoutUiElems(winIdx, elemIdx).text)
    END SELECT
END FUNCTION

SUB AppendWindowControlSession(BYREF sessionText AS STRING, BYVAL winIdx AS INTEGER, BYVAL eol AS STRING)
    DIM elemIdx AS INTEGER
    DIM ctrlName AS STRING
    DIM ctrlKind AS STRING
    DIM ctrlText AS STRING
    DIM multiText AS STRING
    DIM ctrlCur AS INTEGER
    DIM ctrlSelA AS INTEGER
    DIM ctrlSelB AS INTEGER

    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(winIdx).used = 0 THEN EXIT SUB

    FOR elemIdx = 1 TO layoutUiCount(winIdx)
        ctrlName = TRIM$(layoutUiElems(winIdx, elemIdx).name)
        ctrlKind = layoutUiElems(winIdx, elemIdx).kindKey
        IF ctrlName <> "" AND SessionSaveableControlKind(ctrlKind) <> 0 THEN
            ctrlText = SessionLayoutControlText(winIdx, elemIdx)
            multiText = layoutListMultiSel(winIdx, elemIdx)
            ctrlCur = 0
            ctrlSelA = 0
            ctrlSelB = 0
            IF ctrlKind = "TEXTBOX" THEN
                ctrlCur = layoutUiEdit(winIdx, elemIdx).curPos
                ctrlSelA = layoutUiEdit(winIdx, elemIdx).selA
                ctrlSelB = layoutUiEdit(winIdx, elemIdx).selB
            END IF

            sessionText = sessionText + "CTRL|" + _
                LTRIM$(STR$(winIdx)) + "|" + _
                SessionHexEncode(ctrlName) + "|" + _
                ctrlKind + "|" + _
                LTRIM$(STR$(layoutUiElems(winIdx, elemIdx).state)) + "|" + _
                LTRIM$(STR$(comboScrollTop(winIdx, elemIdx))) + "|" + _
                LTRIM$(STR$(layoutListAnchorIdx(winIdx, elemIdx))) + "|" + _
                LTRIM$(STR$(ctrlCur)) + "|" + _
                LTRIM$(STR$(ctrlSelA)) + "|" + _
                LTRIM$(STR$(ctrlSelB)) + "|" + _
                SessionHexEncode(ctrlText) + "|" + _
                SessionHexEncode(multiText) + "|" + _
                SessionHexEncode(layoutUiElems(winIdx, elemIdx).sourceDir) + "|" + _
                SessionHexEncode(layoutUiElems(winIdx, elemIdx).sourceMask) + "|" + _
                SessionHexEncode(layoutUiElems(winIdx, elemIdx).sourceItems) + eol
        END IF
    NEXT
END SUB

SUB RestoreWindowControlStates(BYVAL winIdx AS INTEGER, BYVAL oldSlot AS INTEGER, BYVAL selectionOnly AS INTEGER)
    DIM ctrlIdx AS INTEGER
    DIM elemIdx AS INTEGER
    DIM ctrlKind AS STRING
    DIM dataText AS STRING
    DIM caretPos AS INTEGER
    DIM textLen AS INTEGER

    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(winIdx).used = 0 THEN EXIT SUB

    FOR ctrlIdx = 1 TO sessionRestoreCtrlCount
        IF sessionRestoreCtrlSlot(ctrlIdx) = oldSlot THEN
            elemIdx = SessionLayoutControlIndex(winIdx, sessionRestoreCtrlName(ctrlIdx))
            IF elemIdx >= 1 AND elemIdx <= layoutUiCount(winIdx) THEN
                ctrlKind = layoutUiElems(winIdx, elemIdx).kindKey
                IF selectionOnly = 0 OR ctrlKind = "COMBO" OR ctrlKind = "LISTBOX" THEN
                    layoutUiElems(winIdx, elemIdx).state = sessionRestoreCtrlState(ctrlIdx)
                    comboScrollTop(winIdx, elemIdx) = sessionRestoreCtrlScroll(ctrlIdx)
                    layoutListAnchorIdx(winIdx, elemIdx) = sessionRestoreCtrlAnchor(ctrlIdx)
                    layoutListMultiSel(winIdx, elemIdx) = sessionRestoreCtrlMulti(ctrlIdx)
                    IF selectionOnly = 0 THEN
                        layoutUiElems(winIdx, elemIdx).sourceDir = sessionRestoreCtrlSourceDir(ctrlIdx)
                        layoutUiElems(winIdx, elemIdx).sourceMask = sessionRestoreCtrlSourceMask(ctrlIdx)
                        layoutUiElems(winIdx, elemIdx).sourceItems = sessionRestoreCtrlSourceItems(ctrlIdx)
                    ELSEIF ctrlKind = "COMBO" OR ctrlKind = "LISTBOX" THEN
                        IF sessionRestoreCtrlSourceItems(ctrlIdx) <> "" THEN layoutUiElems(winIdx, elemIdx).sourceItems = sessionRestoreCtrlSourceItems(ctrlIdx)
                    END IF

                    IF selectionOnly = 0 OR ctrlKind = "COMBO" OR ctrlKind = "LISTBOX" THEN
                        dataText = sessionRestoreCtrlText(ctrlIdx)
                        SELECT CASE ctrlKind
                        CASE "TEXTBOX"
                            caretPos = sessionRestoreCtrlCur(ctrlIdx)
                            Ed_SetTextGlue layoutUiEdit(winIdx, elemIdx), dataText, layoutUiElems(winIdx, elemIdx).text, caretPos
                            textLen = LEN(dataText)
                            IF layoutUiEdit(winIdx, elemIdx).curPos < 0 THEN layoutUiEdit(winIdx, elemIdx).curPos = 0
                            IF layoutUiEdit(winIdx, elemIdx).curPos > textLen THEN layoutUiEdit(winIdx, elemIdx).curPos = textLen
                            layoutUiEdit(winIdx, elemIdx).selA = sessionRestoreCtrlSelA(ctrlIdx)
                            layoutUiEdit(winIdx, elemIdx).selB = sessionRestoreCtrlSelB(ctrlIdx)
                            IF layoutUiEdit(winIdx, elemIdx).selA < 0 THEN layoutUiEdit(winIdx, elemIdx).selA = 0
                            IF layoutUiEdit(winIdx, elemIdx).selB < 0 THEN layoutUiEdit(winIdx, elemIdx).selB = 0
                            IF layoutUiEdit(winIdx, elemIdx).selA > textLen THEN layoutUiEdit(winIdx, elemIdx).selA = textLen
                            IF layoutUiEdit(winIdx, elemIdx).selB > textLen THEN layoutUiEdit(winIdx, elemIdx).selB = textLen
                            InvalidateTextboxMetrics elemIdx
                        CASE ELSE
                            layoutUiElems(winIdx, elemIdx).text = dataText
                        END SELECT
                    END IF
                END IF
            END IF
        END IF
    NEXT

    MarkLayoutWindowVisualDirty winIdx
    IF activeLayoutWindow = winIdx THEN SyncGlobalsFromLayoutWindow winIdx
END SUB

SUB RunWindowSessionRestoreAction(BYVAL winIdx AS INTEGER)
    DIM appPath AS STRING
    DIM restoreAction AS STRING

    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(winIdx).used = 0 THEN EXIT SUB

    appPath = RTRIM$(layoutWindows(winIdx).appPath)
    IF TRIM$(appPath) = "" THEN EXIT SUB

    restoreAction = TRIM$(AppCfgValue(appPath, "SESSION_RESTORE_ACTION", ""))
    IF restoreAction = "" THEN EXIT SUB

    activeLayoutWindow = winIdx
    SyncGlobalsFromLayoutWindow winIdx
    HostAppAction winIdx, restoreAction
    SyncLayoutWindowFromGlobals winIdx
END SUB

FUNCTION SessionAppViewPixelHex(BYVAL winIdx AS INTEGER) AS STRING
    DIM totalPix AS LONG
    DIM i AS LONG
    DIM rawText AS STRING

    IF winIdx < 1 OR winIdx > 12 THEN RETURN ""
    IF appViewLoaded(winIdx) = 0 OR appViewPix(winIdx) = 0 THEN RETURN ""
    totalPix = CLNG(appViewW(winIdx)) * CLNG(appViewH(winIdx))
    IF totalPix <= 0 OR totalPix > 16384 THEN RETURN ""

    rawText = ""
    FOR i = 0 TO totalPix - 1
        rawText = rawText + CHR$(appViewPix(winIdx)[i])
    NEXT

    RETURN SessionHexEncode(rawText)
END FUNCTION

SUB AppendWindowAppViewSession(BYREF sessionText AS STRING, BYVAL winIdx AS INTEGER, BYVAL eol AS STRING)
    IF winIdx < 1 OR winIdx > 12 THEN EXIT SUB
    IF appViewLoaded(winIdx) = 0 OR appViewPix(winIdx) = 0 THEN EXIT SUB

    sessionText = sessionText + "APPVIEW|" + _
        LTRIM$(STR$(winIdx)) + "|" + _
        LTRIM$(STR$(appViewW(winIdx))) + "|" + _
        LTRIM$(STR$(appViewH(winIdx))) + "|" + _
        LTRIM$(STR$(appViewColors(winIdx))) + "|" + _
        LTRIM$(STR$(appViewClearIndex(winIdx))) + "|" + _
        LTRIM$(STR$(appViewLeftColor(winIdx))) + "|" + _
        LTRIM$(STR$(appViewRightColor(winIdx))) + "|" + _
        LTRIM$(STR$(appViewTool(winIdx))) + "|" + _
        LTRIM$(STR$(appViewDirty(winIdx))) + "|" + _
        SessionHexEncode(appViewFileName(winIdx)) + "|" + _
        SessionHexEncode(appViewPalettePath(winIdx)) + "|" + _
        SessionAppViewPixelHex(winIdx) + eol
END SUB

SUB ClearSessionRestoreAppViewBuffer()
    DIM i AS INTEGER
    FOR i = 1 TO 12
        sessionRestoreAppViewLoaded(i) = 0
        sessionRestoreAppViewW(i) = 0
        sessionRestoreAppViewH(i) = 0
        sessionRestoreAppViewColors(i) = 0
        sessionRestoreAppViewClear(i) = 0
        sessionRestoreAppViewLeft(i) = 0
        sessionRestoreAppViewRight(i) = 0
        sessionRestoreAppViewTool(i) = 0
        sessionRestoreAppViewDirty(i) = 0
        sessionRestoreAppViewFile(i) = ""
        sessionRestoreAppViewPalette(i) = ""
        sessionRestoreAppViewPixels(i) = ""
    NEXT
END SUB

SUB RestoreWindowAppViewState(BYVAL winIdx AS INTEGER, BYVAL oldSlot AS INTEGER)
    DIM totalPix AS LONG
    DIM rawText AS STRING
    DIM i AS LONG

    IF winIdx < 1 OR winIdx > 12 THEN EXIT SUB
    IF oldSlot < 1 OR oldSlot > 12 THEN EXIT SUB
    IF sessionRestoreAppViewLoaded(oldSlot) = 0 THEN EXIT SUB
    IF sessionRestoreAppViewW(oldSlot) < 1 OR sessionRestoreAppViewH(oldSlot) < 1 THEN EXIT SUB

    IF AppViewEnsureSurface(winIdx, sessionRestoreAppViewW(oldSlot), sessionRestoreAppViewH(oldSlot), sessionRestoreAppViewColors(oldSlot), sessionRestoreAppViewClear(oldSlot), sessionRestoreAppViewPalette(oldSlot)) = 0 THEN EXIT SUB

    rawText = SessionHexDecode(sessionRestoreAppViewPixels(oldSlot))
    totalPix = CLNG(appViewW(winIdx)) * CLNG(appViewH(winIdx))
    IF LEN(rawText) >= totalPix THEN
        FOR i = 0 TO totalPix - 1
            appViewPix(winIdx)[i] = CUBYTE(ASC(MID$(rawText, i + 1, 1)) AND &HFF)
        NEXT
    END IF

    appViewLeftColor(winIdx) = sessionRestoreAppViewLeft(oldSlot)
    appViewRightColor(winIdx) = sessionRestoreAppViewRight(oldSlot)
    appViewTool(winIdx) = sessionRestoreAppViewTool(oldSlot)
    appViewDirty(winIdx) = sessionRestoreAppViewDirty(oldSlot)
    appViewFileName(winIdx) = sessionRestoreAppViewFile(oldSlot)
    appViewPalettePath(winIdx) = sessionRestoreAppViewPalette(oldSlot)
    appViewDragActive(winIdx) = 0
    appViewDragLastX(winIdx) = -1
    appViewDragLastY(winIdx) = -1
    appViewVersion(winIdx) = appViewVersion(winIdx) + 1
    AppViewMarkRelated winIdx
END SUB


FUNCTION ExpandHelperCommandControls(BYVAL winIdx AS INTEGER, BYVAL cmdText AS STRING) AS STRING
    DIM workText AS STRING
    DIM resultText AS STRING
    DIM upperText AS STRING
    DIM tokenStart AS INTEGER
    DIM tokenEnd AS INTEGER
    DIM controlName AS STRING
    DIM controlValue AS STRING

    workText = cmdText
    resultText = ""

    DO
        tokenStart = INSTR(UCASE$(workText), "%WINID%")
        IF tokenStart <= 0 THEN EXIT DO
        workText = LEFT$(workText, tokenStart - 1) + LTRIM$(STR$(winIdx)) + MID$(workText, tokenStart + 7)
    LOOP

    DO
        tokenStart = INSTR(UCASE$(workText), "%INSTANCE%")
        IF tokenStart <= 0 THEN EXIT DO
        workText = LEFT$(workText, tokenStart - 1) + LTRIM$(STR$(winIdx)) + MID$(workText, tokenStart + 10)
    LOOP

    DO
        upperText = UCASE$(workText)
        tokenStart = INSTR(upperText, "%CONTROL:")
        IF tokenStart <= 0 THEN
            resultText = resultText + workText
            EXIT DO
        END IF

        resultText = resultText + LEFT$(workText, tokenStart - 1)
        tokenEnd = INSTR(tokenStart + 9, workText, "%")
        IF tokenEnd <= 0 THEN
            resultText = resultText + MID$(workText, tokenStart)
            EXIT DO
        END IF

        controlName = MID$(workText, tokenStart + 9, tokenEnd - tokenStart - 9)
        controlValue = GetDialogControlTextValue(winIdx, controlName)
        resultText = resultText + controlValue
        workText = MID$(workText, tokenEnd + 1)
    LOOP

    RETURN resultText
END FUNCTION

FUNCTION GetTextboxTextByName(BYVAL controlName AS STRING) AS STRING

    DIM idx AS INTEGER

    idx = GetControlIndexByName(controlName)
    IF idx < 1 OR idx > uiCount THEN RETURN ""
    IF uiElems(idx).kindId <> UI_KIND_TEXTBOX THEN RETURN ""

    RETURN Ed_GetTextGlue(uiEdit(idx), uiElems(idx).text)
END FUNCTION

FUNCTION GetControlTextValue(BYVAL controlName AS STRING) AS STRING
    DIM idx AS INTEGER

    idx = GetControlIndexByName(controlName)
    IF idx < 1 OR idx > uiCount THEN RETURN ""

    SELECT CASE uiElems(idx).kindId
    CASE UI_KIND_TEXTBOX
        RETURN GetTextboxTextByName(controlName)
    CASE UI_KIND_COMBO
        RETURN ControlValueFromCombo(idx)
    CASE UI_KIND_LISTBOX
        RETURN ControlValueFromListControl(idx)
    CASE ELSE
        RETURN RTRIM$(uiElems(idx).text)
    END SELECT
END FUNCTION

FUNCTION IsFileDialogDirectoryList(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER) AS INTEGER
    DIM dirControlName AS STRING
    DIM appPath AS STRING

    IF elemIdx < 1 OR elemIdx > uiCount THEN RETURN 0

    IF UCASE$(TRIM$(uiElems(elemIdx).sourceKind)) = "DIRS" THEN RETURN -1

    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN RETURN 0
    IF layoutWindows(winIdx).used = 0 THEN RETURN 0

    appPath = RTRIM$(layoutWindows(winIdx).appPath)
    dirControlName = TRIM$(AppCfgValue(appPath, "FILE_DIR_CONTROL", ""))

    IF dirControlName <> "" THEN
        IF uiElems(elemIdx).nameKey = UCASE$(dirControlName) THEN RETURN -1
    END IF

    RETURN 0
END FUNCTION

SUB ResetEditorControlRuntimeState(BYVAL elemIdx AS INTEGER, BYVAL seedText AS STRING)
    DIM sinkText AS STRING
    DIM sinkCaret AS INTEGER

    IF elemIdx < LBOUND(uiEdit) OR elemIdx > UBOUND(uiEdit) THEN EXIT SUB

    sinkText = seedText
    sinkCaret = 0
    Ed_SetTextGlue uiEdit(elemIdx), seedText, sinkText, sinkCaret
    InvalidateTextboxMetrics elemIdx

    uiSelAnchor(elemIdx) = 0
    uiPrefCol(elemIdx) = 0
    uiWordSelMode(elemIdx) = 0
    uiWordSelA(elemIdx) = 0
    uiWordSelB(elemIdx) = 0
    uiLineSelMode(elemIdx) = 0
    uiLineSelA(elemIdx) = 0
    uiLineSelB(elemIdx) = 0
END SUB

FUNCTION ControlNameHash(BYREF keyName AS STRING) AS INTEGER
    DIM i AS INTEGER
    DIM textLen AS INTEGER
    DIM h AS LONG
    DIM c AS INTEGER
    DIM textPtr AS UBYTE PTR

    h = 0
    textLen = LEN(keyName)
    IF textLen > 0 THEN
        textPtr = CAST(UBYTE PTR, STRPTR(keyName))
        IF textPtr <> 0 THEN
            FOR i = 0 TO textLen - 1
                c = textPtr[i]
                h = (h * 33 + c) MOD CONTROL_NAME_HASH_SIZE
            NEXT
        END IF
    END IF

    RETURN CINT(h)
END FUNCTION

SUB RebuildGlobalControlNameCache()
    DIM slotIdx AS INTEGER
    DIM probeCount AS INTEGER
    DIM elemIdx AS INTEGER
    DIM keyName AS STRING
    DIM i AS INTEGER

    FOR i = 0 TO CONTROL_NAME_HASH_SIZE - 1
        uiNameCacheKey(i) = ""
        uiNameCacheIdx(i) = 0
    NEXT

    FOR elemIdx = 1 TO uiCount
        keyName = uiElems(elemIdx).nameKey
        IF keyName <> "" THEN
            slotIdx = ControlNameHash(keyName)
            probeCount = 0
            DO WHILE probeCount < CONTROL_NAME_HASH_SIZE
                IF uiNameCacheKey(slotIdx) = "" THEN
                    uiNameCacheKey(slotIdx) = keyName
                    uiNameCacheIdx(slotIdx) = elemIdx
                    EXIT DO
                ELSEIF uiNameCacheKey(slotIdx) = keyName THEN
                    ' Preserve the original first-match behavior for duplicate names.
                    EXIT DO
                END IF
                slotIdx = slotIdx + 1
                IF slotIdx >= CONTROL_NAME_HASH_SIZE THEN slotIdx = 0
                probeCount = probeCount + 1
            LOOP
        END IF
    NEXT

    uiNameCacheValid = -1
END SUB

SUB RebuildLayoutControlNameCache(BYVAL winIdx AS INTEGER)
    DIM slotIdx AS INTEGER
    DIM probeCount AS INTEGER
    DIM elemIdx AS INTEGER
    DIM keyName AS STRING
    DIM i AS INTEGER

    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB

    FOR i = 0 TO CONTROL_NAME_HASH_SIZE - 1
        layoutNameCacheKey(winIdx, i) = ""
        layoutNameCacheIdx(winIdx, i) = 0
    NEXT

    IF layoutWindows(winIdx).used <> 0 THEN
        FOR elemIdx = 1 TO layoutUiCount(winIdx)
            keyName = layoutUiElems(winIdx, elemIdx).nameKey
            IF keyName <> "" THEN
                slotIdx = ControlNameHash(keyName)
                probeCount = 0
                DO WHILE probeCount < CONTROL_NAME_HASH_SIZE
                    IF layoutNameCacheKey(winIdx, slotIdx) = "" THEN
                        layoutNameCacheKey(winIdx, slotIdx) = keyName
                        layoutNameCacheIdx(winIdx, slotIdx) = elemIdx
                        EXIT DO
                    ELSEIF layoutNameCacheKey(winIdx, slotIdx) = keyName THEN
                        ' Preserve the original first-match behavior for duplicate names.
                        EXIT DO
                    END IF
                    slotIdx = slotIdx + 1
                    IF slotIdx >= CONTROL_NAME_HASH_SIZE THEN slotIdx = 0
                    probeCount = probeCount + 1
                LOOP
            END IF
        NEXT
    END IF

    layoutNameCacheValid(winIdx) = -1
END SUB

FUNCTION GetControlIndexByNameKey(BYREF controlNameKey AS STRING) AS INTEGER
    DIM slotIdx AS INTEGER
    DIM probeCount AS INTEGER

    IF controlNameKey = "" THEN RETURN 0

    IF uiNameCacheValid = 0 THEN RebuildGlobalControlNameCache

    slotIdx = ControlNameHash(controlNameKey)
    probeCount = 0
    DO WHILE probeCount < CONTROL_NAME_HASH_SIZE
        IF uiNameCacheKey(slotIdx) = "" THEN RETURN 0
        IF uiNameCacheKey(slotIdx) = controlNameKey THEN RETURN uiNameCacheIdx(slotIdx)
        slotIdx = slotIdx + 1
        IF slotIdx >= CONTROL_NAME_HASH_SIZE THEN slotIdx = 0
        probeCount = probeCount + 1
    LOOP

    RETURN 0
END FUNCTION

FUNCTION LayoutControlIndexByNameKey(BYVAL winIdx AS INTEGER, BYREF controlNameKey AS STRING) AS INTEGER
    DIM slotIdx AS INTEGER
    DIM probeCount AS INTEGER

    IF controlNameKey = "" THEN RETURN 0
    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN RETURN 0
    IF layoutWindows(winIdx).used = 0 THEN RETURN 0

    IF layoutNameCacheValid(winIdx) = 0 THEN RebuildLayoutControlNameCache winIdx

    slotIdx = ControlNameHash(controlNameKey)
    probeCount = 0
    DO WHILE probeCount < CONTROL_NAME_HASH_SIZE
        IF layoutNameCacheKey(winIdx, slotIdx) = "" THEN RETURN 0
        IF layoutNameCacheKey(winIdx, slotIdx) = controlNameKey THEN RETURN layoutNameCacheIdx(winIdx, slotIdx)
        slotIdx = slotIdx + 1
        IF slotIdx >= CONTROL_NAME_HASH_SIZE THEN slotIdx = 0
        probeCount = probeCount + 1
    LOOP

    RETURN 0
END FUNCTION

FUNCTION GetControlIndexByName(BYVAL controlName AS STRING) AS INTEGER
    DIM target AS STRING

    target = UCASE$(TRIM$(controlName))
    RETURN GetControlIndexByNameKey(target)
END FUNCTION

FUNCTION LayoutControlIndexByName(BYVAL winIdx AS INTEGER, BYVAL controlName AS STRING) AS INTEGER
    DIM target AS STRING

    target = UCASE$(TRIM$(controlName))
    RETURN LayoutControlIndexByNameKey(winIdx, target)
END FUNCTION

FUNCTION GetControlStateByName(BYVAL controlName AS STRING) AS INTEGER
    DIM idx AS INTEGER

    idx = GetControlIndexByName(controlName)
    IF idx < 1 OR idx > uiCount THEN RETURN 0

    RETURN uiElems(idx).state
END FUNCTION

SUB ApplyVerticalSplitterPosition(BYVAL splitterIdx AS INTEGER, BYVAL newSplitX AS INTEGER)
    DIM act AS STRING
    DIM verb AS STRING
    DIM leftName AS STRING
    DIM rightName AS STRING
    DIM labelName AS STRING
    DIM minLeftText AS STRING
    DIM minRightText AS STRING
    DIM leftIdx AS INTEGER
    DIM rightIdx AS INTEGER
    DIM labelIdx AS INTEGER
    DIM splitW AS INTEGER
    DIM paneLeft AS INTEGER
    DIM paneRight AS INTEGER
    DIM minLeftPx AS INTEGER
    DIM minRightPx AS INTEGER
    DIM minX AS INTEGER
    DIM maxX AS INTEGER

    IF splitterIdx < 1 OR splitterIdx > uiCount THEN EXIT SUB
    IF uiElems(splitterIdx).kindId <> UI_KIND_SPLITTER THEN EXIT SUB

    act = uiElems(splitterIdx).action
    verb = UCASE$(NextActionToken(act))
    IF verb <> "SPLIT" THEN EXIT SUB

    leftName = NextActionToken(act)
    rightName = NextActionToken(act)
    labelName = NextActionToken(act)
    minLeftText = NextActionToken(act)
    minRightText = NextActionToken(act)

    leftIdx = GetControlIndexByName(leftName)
    rightIdx = GetControlIndexByName(rightName)

    IF leftIdx < 1 OR leftIdx > uiCount THEN EXIT SUB
    IF rightIdx < 1 OR rightIdx > uiCount THEN EXIT SUB

    splitW = uiElems(splitterIdx).w
    IF splitW < 3 THEN splitW = 6

    paneLeft = uiElems(leftIdx).x
    paneRight = uiElems(rightIdx).x + uiElems(rightIdx).w

    minLeftPx = VAL(minLeftText) * 8
    minRightPx = VAL(minRightText) * 8
    IF minLeftPx < 8 THEN minLeftPx = 112
    IF minRightPx < 8 THEN minRightPx = 96

    minX = paneLeft + minLeftPx
    maxX = paneRight - splitW - minRightPx
    IF maxX < minX THEN maxX = minX

    IF newSplitX < minX THEN newSplitX = minX
    IF newSplitX > maxX THEN newSplitX = maxX

    uiElems(splitterIdx).x = newSplitX
    uiElems(splitterIdx).w = splitW
    uiElems(leftIdx).w = newSplitX - paneLeft
    uiElems(rightIdx).x = newSplitX + splitW
    uiElems(rightIdx).w = paneRight - uiElems(rightIdx).x

    IF labelName <> "" THEN
        labelIdx = GetControlIndexByName(labelName)
        IF labelIdx >= 1 AND labelIdx <= uiCount THEN
            uiElems(labelIdx).x = uiElems(rightIdx).x
        END IF
    END IF

    ' Splitter drags already know exactly which controls changed.
    ' Save only those controls instead of syncing the entire active window.
    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
            layoutUiElems(activeLayoutWindow, splitterIdx) = uiElems(splitterIdx)
            layoutUiElems(activeLayoutWindow, leftIdx) = uiElems(leftIdx)
            layoutUiElems(activeLayoutWindow, rightIdx) = uiElems(rightIdx)
            IF labelIdx >= 1 AND labelIdx <= uiCount THEN
                layoutUiElems(activeLayoutWindow, labelIdx) = uiElems(labelIdx)
            END IF
            MarkLayoutWindowDirty activeLayoutWindow
        END IF
    END IF
END SUB


' ---------------------------
' File dialogs, generic file browser windows, and file operation dialogs
' ---------------------------

FUNCTION JoinPath(BYVAL dirName AS STRING, BYVAL fileName AS STRING) AS STRING
    dirName = TRIM$(dirName)
    fileName = TRIM$(fileName)

    IF fileName = "" THEN RETURN ""
    IF INSTR(fileName, ":") > 0 THEN RETURN NormalizePath(fileName)
    IF LEFT$(fileName, 1) = CHR$(92) THEN RETURN NormalizePath(fileName)
    IF dirName = "" THEN RETURN NormalizePath(fileName)
    IF RIGHT$(dirName, 1) <> CHR$(92) THEN dirName = dirName + CHR$(92)

    RETURN NormalizePath(dirName + fileName)
END FUNCTION

FUNCTION ParentPath(BYVAL filePath AS STRING) AS STRING
    DIM i AS INTEGER

    filePath = NormalizePath(filePath)
    IF LEN(filePath) = 3 THEN
        IF MID$(filePath, 2, 1) = ":" AND RIGHT$(filePath, 1) = CHR$(92) THEN RETURN ""
    END IF

    FOR i = LEN(filePath) TO 1 STEP -1
        IF MID$(filePath, i, 1) = CHR$(92) THEN
            IF i = 3 AND MID$(filePath, 2, 1) = ":" THEN
                RETURN LEFT$(filePath, 3)
            END IF
            RETURN LEFT$(filePath, i - 1)
        END IF
    NEXT

    RETURN ""
END FUNCTION

FUNCTION CurrentDrivePrefix() AS STRING
    DIM curPath AS STRING
    DIM colonPos AS INTEGER

    curPath = NormalizePath(CURDIR)
    colonPos = INSTR(curPath, ":")
    IF colonPos > 0 THEN RETURN LEFT$(curPath, colonPos)

    RETURN "C:"
END FUNCTION

FUNCTION AbsoluteDirPath(BYVAL dirName AS STRING) AS STRING
    DIM curPath AS STRING
    DIM curDrive AS STRING

    dirName = NormalizePath(TRIM$(dirName))
    IF dirName = "" OR dirName = "." THEN
        curPath = NormalizePath(CURDIR)
        IF curPath <> "" THEN RETURN curPath
        RETURN CurrentDrivePrefix() + CHR$(92)
    END IF

    IF LEN(dirName) = 2 AND MID$(dirName, 2, 1) = ":" THEN
        RETURN dirName + CHR$(92)
    END IF

    IF INSTR(dirName, ":") > 0 THEN RETURN dirName

    curDrive = CurrentDrivePrefix()
    IF LEFT$(dirName, 1) = CHR$(92) THEN RETURN curDrive + dirName

    curPath = NormalizePath(CURDIR)
    IF curPath = "" THEN curPath = curDrive + CHR$(92)
    RETURN JoinPath(curPath, dirName)
END FUNCTION

FUNCTION DirectoryHasAnyEntry(BYVAL dirPath AS STRING) AS INTEGER
    DIM pattern AS STRING

    dirPath = NormalizePath(TRIM$(dirPath))
    IF dirPath = "" THEN RETURN 0

    pattern = dirPath
    IF RIGHT$(pattern, 1) <> CHR$(92) THEN pattern = pattern + CHR$(92)
    pattern = pattern + "*.*"

    IF DIR(pattern, &H17) <> "" THEN RETURN -1
    IF DIR(pattern) <> "" THEN RETURN -1

    RETURN 0
END FUNCTION


FUNCTION ResolvePathFromAppWindow(BYVAL winIdx AS INTEGER, BYVAL relPath AS STRING) AS STRING
    DIM baseDir AS STRING
    DIM candidate AS STRING

    relPath = NormalizePath(TRIM$(relPath))
    IF relPath = "" THEN RETURN ""

    IF DIR(LayoutFilePath(relPath)) <> "" THEN RETURN relPath
    IF INSTR(LayoutFilePath(relPath), ":") > 0 THEN RETURN relPath
    IF LEFT$(LayoutFilePath(relPath), 1) = CHR$(92) THEN RETURN relPath

    IF winIdx >= LBOUND(layoutWindows) AND winIdx <= UBOUND(layoutWindows) THEN
        IF layoutWindows(winIdx).used <> 0 THEN
            baseDir = ParentPath(LayoutFilePath(RTRIM$(layoutWindows(winIdx).appPath)))
            IF baseDir <> "" THEN
                candidate = JoinPath(baseDir, relPath)
                IF DIR(LayoutFilePath(candidate)) <> "" THEN RETURN candidate
            END IF
        END IF
    END IF

    RETURN relPath
END FUNCTION

' Resolve app-owned files relative to the running APP file.
' This is used only by action/file helper paths, not hot redraw/input paths.
FUNCTION ResolveAppLocalPath(BYVAL winIdx AS INTEGER, BYVAL rawPath AS STRING) AS STRING
    DIM baseDir AS STRING
    DIM cleanPath AS STRING

    cleanPath = NormalizePath(TRIM$(rawPath))
    IF cleanPath = "" THEN RETURN ""

    IF INSTR(LayoutFilePath(cleanPath), ":") > 0 THEN RETURN cleanPath
    IF LEFT$(LayoutFilePath(cleanPath), 1) = CHR$(92) THEN RETURN cleanPath

    IF winIdx >= LBOUND(layoutWindows) AND winIdx <= UBOUND(layoutWindows) THEN
        IF layoutWindows(winIdx).used <> 0 THEN
            baseDir = ParentPath(LayoutFilePath(RTRIM$(layoutWindows(winIdx).appPath)))
            IF baseDir <> "" THEN RETURN JoinPath(baseDir, cleanPath)
        END IF
    END IF

    RETURN cleanPath
END FUNCTION

' Resolve existing app-side files before falling back to the old current-directory behavior.
' This keeps generic dialogs/system paths working while allowing same-folder APP/SYS/EXE packages.
FUNCTION ResolveAppLocalFilePath(BYVAL winIdx AS INTEGER, BYVAL rawPath AS STRING) AS STRING
    DIM appPath AS STRING
    DIM cleanPath AS STRING

    cleanPath = NormalizePath(TRIM$(rawPath))
    IF cleanPath = "" THEN RETURN ""
    IF INSTR(LayoutFilePath(cleanPath), ":") > 0 THEN RETURN cleanPath
    IF LEFT$(LayoutFilePath(cleanPath), 1) = CHR$(92) THEN RETURN cleanPath

    appPath = ResolveAppLocalPath(winIdx, cleanPath)
    IF appPath <> cleanPath THEN
        IF DIR(LayoutFilePath(appPath)) <> "" THEN RETURN appPath
    END IF

    IF DIR(LayoutFilePath(cleanPath)) <> "" THEN RETURN cleanPath
    IF appPath <> "" THEN RETURN appPath
    RETURN cleanPath
END FUNCTION

' Resolve app-owned paths relative to a known APP/SYS file path.
' This is used while a layout is still loading and does not yet have a window slot.
FUNCTION ResolveAppLocalPathFromFile(BYVAL appPath AS STRING, BYVAL rawPath AS STRING) AS STRING
    DIM baseDir AS STRING
    DIM cleanPath AS STRING

    cleanPath = NormalizePath(TRIM$(rawPath))
    IF cleanPath = "" THEN RETURN ""

    IF INSTR(LayoutFilePath(cleanPath), ":") > 0 THEN RETURN cleanPath
    IF LEFT$(LayoutFilePath(cleanPath), 1) = CHR$(92) THEN RETURN cleanPath

    baseDir = ParentPath(LayoutFilePath(NormalizePath(TRIM$(appPath))))
    IF baseDir <> "" THEN RETURN JoinPath(baseDir, cleanPath)

    RETURN cleanPath
END FUNCTION

' Resolve existing app-local files first, then preserve old root/current-directory behavior.
' Missing relative files are treated as app-owned so TMP/status files stay beside the APP.
FUNCTION ResolveAppLocalFilePathFromFile(BYVAL appPath AS STRING, BYVAL rawPath AS STRING) AS STRING
    DIM appLocalPath AS STRING
    DIM cleanPath AS STRING

    cleanPath = NormalizePath(TRIM$(rawPath))
    IF cleanPath = "" THEN RETURN ""
    IF INSTR(LayoutFilePath(cleanPath), ":") > 0 THEN RETURN cleanPath
    IF LEFT$(LayoutFilePath(cleanPath), 1) = CHR$(92) THEN RETURN cleanPath

    appLocalPath = ResolveAppLocalPathFromFile(appPath, cleanPath)
    IF appLocalPath <> cleanPath THEN
        IF DIR(LayoutFilePath(appLocalPath)) <> "" THEN RETURN appLocalPath
    END IF

    IF DIR(LayoutFilePath(cleanPath)) <> "" THEN RETURN cleanPath
    IF appLocalPath <> "" THEN RETURN appLocalPath
    RETURN cleanPath
END FUNCTION

' Resolve APP control binding files without turning shell-owned folder paths into app-local files.
' Bare names and explicit .\ paths remain app-owned; existing app-local files still win.
FUNCTION ResolveAppBindFilePathFromFile(BYVAL appPath AS STRING, BYVAL rawPath AS STRING) AS STRING
    DIM appLocalPath AS STRING
    DIM cleanPath AS STRING
    DIM markedLocal AS INTEGER

    cleanPath = NormalizePath(TRIM$(rawPath))
    IF cleanPath = "" THEN RETURN ""
    IF INSTR(LayoutFilePath(cleanPath), ":") > 0 THEN RETURN cleanPath
    IF LEFT$(LayoutFilePath(cleanPath), 1) = CHR$(92) THEN RETURN cleanPath

    markedLocal = 0
    IF LEFT$(cleanPath, 2) = "." + CHR$(92) THEN
        markedLocal = -1
        cleanPath = MID$(cleanPath, 3)
    END IF

    ' Shell-owned bind files must stay rooted at the Backlash install root.
    ' Otherwise an old APPS\SYSTEM copy can shadow SYSTEM\DISPLAY.CFG and
    ' make Display/desktop settings save into the wrong file.
    IF markedLocal = 0 THEN
        IF LEFT$(UCASE$(cleanPath), 7) = "SYSTEM" + CHR$(92) THEN RETURN cleanPath
    END IF

    appLocalPath = ResolveAppLocalPathFromFile(appPath, cleanPath)
    IF appLocalPath <> cleanPath THEN
        IF markedLocal <> 0 THEN RETURN appLocalPath
        IF DIR(LayoutFilePath(appLocalPath)) <> "" THEN RETURN appLocalPath
    END IF

    ' A missing path with its own folder component is shell/current-root relative.
    ' This keeps SYSTEM\TEMP and other shell-owned bind targets aligned with helper output.
    IF INSTR(cleanPath, CHR$(92)) > 0 THEN RETURN cleanPath

    IF appLocalPath <> "" THEN RETURN appLocalPath
    RETURN cleanPath
END FUNCTION

' Resolve only the executable portion of a helper command relative to the running APP.
FUNCTION ResolveAppLocalCommand(BYVAL winIdx AS INTEGER, BYVAL rawCmd AS STRING) AS STRING
    DIM cmdText AS STRING
    DIM exeText AS STRING
    DIM restText AS STRING
    DIM p AS INTEGER

    cmdText = TRIM$(rawCmd)
    IF cmdText = "" THEN RETURN ""

    IF LEFT$(cmdText, 1) = CHR$(34) THEN
        p = INSTR(2, cmdText, CHR$(34))
        IF p > 0 THEN
            exeText = MID$(cmdText, 2, p - 2)
            restText = MID$(cmdText, p + 1)
            RETURN CHR$(34) + ResolveAppLocalFilePath(winIdx, exeText) + CHR$(34) + restText
        END IF
    END IF

    p = INSTR(cmdText, " ")
    IF p > 0 THEN
        exeText = LEFT$(cmdText, p - 1)
        restText = MID$(cmdText, p)
    ELSE
        exeText = cmdText
        restText = ""
    END IF

    RETURN ResolveAppLocalFilePath(winIdx, exeText) + restText
END FUNCTION

FUNCTION AppDialogPath(BYVAL winIdx AS INTEGER, BYVAL keyName AS STRING, BYVAL defaultValue AS STRING) AS STRING
    DIM dlgPath AS STRING

    dlgPath = TRIM$(defaultValue)

    IF winIdx >= LBOUND(layoutWindows) AND winIdx <= UBOUND(layoutWindows) THEN
        IF layoutWindows(winIdx).used <> 0 THEN
            dlgPath = TRIM$(AppCfgValue(RTRIM$(layoutWindows(winIdx).appPath), keyName, dlgPath))
            dlgPath = ResolvePathFromAppWindow(winIdx, dlgPath)
        END IF
    END IF

    RETURN dlgPath
END FUNCTION

FUNCTION FileDialogPersistCfgValue(BYVAL targetWin AS INTEGER, BYVAL keyName AS STRING, BYVAL defaultValue AS STRING) AS STRING
    DIM cfgValue AS STRING

    cfgValue = TRIM$(defaultValue)

    IF targetWin >= LBOUND(layoutWindows) AND targetWin <= UBOUND(layoutWindows) THEN
        IF layoutWindows(targetWin).used <> 0 THEN
            cfgValue = TRIM$(AppCfgValue(RTRIM$(layoutWindows(targetWin).appPath), keyName, cfgValue))
        END IF
    END IF

    RETURN cfgValue
END FUNCTION

FUNCTION FileDialogPersistentDir(BYVAL targetWin AS INTEGER, BYVAL defaultDir AS STRING) AS STRING
    DIM cfgFileName AS STRING
    DIM cfgSectionName AS STRING
    DIM cfgKeyName AS STRING
    DIM savedDir AS STRING
    DIM resolvedDir AS STRING

    defaultDir = NormalizePath(TRIM$(defaultDir))

    cfgFileName = FileDialogPersistCfgValue(targetWin, "FILE_DIALOG_LAST_DIR_FILE", "")
    cfgSectionName = FileDialogPersistCfgValue(targetWin, "FILE_DIALOG_LAST_DIR_SECTION", "")
    cfgKeyName = FileDialogPersistCfgValue(targetWin, "FILE_DIALOG_LAST_DIR_KEY", "")

    IF cfgFileName = "" OR cfgKeyName = "" THEN RETURN defaultDir

    savedDir = TRIM$(ReadCfgValueInSection(cfgFileName, cfgSectionName, cfgKeyName, ""))
    IF savedDir = "" THEN RETURN defaultDir

    resolvedDir = ResolveExistingDosPath(AbsoluteDirPath(savedDir))
    IF resolvedDir <> "" THEN RETURN resolvedDir

    RETURN defaultDir
END FUNCTION

SUB SaveFileDialogPersistentDir(BYVAL targetWin AS INTEGER, BYVAL dirName AS STRING)
    DIM cfgFileName AS STRING
    DIM cfgSectionName AS STRING
    DIM cfgKeyName AS STRING
    DIM resolvedDir AS STRING

    cfgFileName = FileDialogPersistCfgValue(targetWin, "FILE_DIALOG_LAST_DIR_FILE", "")
    cfgSectionName = FileDialogPersistCfgValue(targetWin, "FILE_DIALOG_LAST_DIR_SECTION", "")
    cfgKeyName = FileDialogPersistCfgValue(targetWin, "FILE_DIALOG_LAST_DIR_KEY", "")

    IF cfgFileName = "" OR cfgKeyName = "" THEN EXIT SUB

    resolvedDir = ResolveExistingDosPath(AbsoluteDirPath(dirName))
    IF resolvedDir = "" THEN EXIT SUB

    SetCfgValueInSection cfgFileName, cfgSectionName, cfgKeyName, resolvedDir
END SUB

FUNCTION AppControlNameValue(BYVAL winIdx AS INTEGER, BYVAL keyName AS STRING, BYVAL defaultValue AS STRING) AS STRING
    DIM controlName AS STRING

    controlName = TRIM$(defaultValue)

    IF winIdx >= LBOUND(layoutWindows) AND winIdx <= UBOUND(layoutWindows) THEN
        IF layoutWindows(winIdx).used <> 0 THEN
            controlName = TRIM$(AppCfgValue(RTRIM$(layoutWindows(winIdx).appPath), keyName, controlName))
        END IF
    END IF

    RETURN controlName
END FUNCTION

FUNCTION FileBrowserWindowCurrentDir(BYVAL winIdx AS INTEGER) AS STRING
    DIM pathControlName AS STRING
    DIM fileControlName AS STRING
    DIM elemIdx AS INTEGER
    DIM dirName AS STRING

    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN RETURN ""
    IF layoutWindows(winIdx).used = 0 THEN RETURN ""

    pathControlName = AppControlNameValue(winIdx, "FILE_BROWSER_PATH_CONTROL", "")
    IF pathControlName <> "" THEN
        elemIdx = LayoutControlIndexByName(winIdx, pathControlName)
        IF elemIdx >= 1 AND elemIdx <= layoutUiCount(winIdx) THEN
            IF layoutUiElems(winIdx, elemIdx).kindId = UI_KIND_TEXTBOX THEN
                dirName = Ed_GetTextGlue(layoutUiEdit(winIdx, elemIdx), layoutUiElems(winIdx, elemIdx).text)
            ELSE
                dirName = RTRIM$(layoutUiElems(winIdx, elemIdx).text)
            END IF
        END IF
    END IF

    IF TRIM$(dirName) = "" THEN
        fileControlName = AppControlNameValue(winIdx, "FILE_BROWSER_FILE_CONTROL", "")
        IF fileControlName <> "" THEN
            elemIdx = LayoutControlIndexByName(winIdx, fileControlName)
            IF elemIdx >= 1 AND elemIdx <= layoutUiCount(winIdx) THEN
                dirName = RTRIM$(layoutUiElems(winIdx, elemIdx).sourceDir)
            END IF
        END IF
    END IF

    dirName = AbsoluteDirPath(dirName)
    IF dirName = "" THEN dirName = AbsoluteDirPath(".")
    RETURN dirName
END FUNCTION

FUNCTION ResolveDeletePathForApply(BYVAL rawPath AS STRING, BYVAL isDir AS INTEGER) AS STRING
    DIM p AS STRING

    p = TRIM$(rawPath)
    IF p = "" THEN RETURN ""

    IF LEFT$(UCASE$(p), 2) = "F:" AND INSTR(MID$(p, 3), ":") > 0 THEN
        p = MID$(p, 3)
        isDir = 0
    ELSEIF LEFT$(UCASE$(p), 2) = "D:" AND INSTR(MID$(p, 3), ":") > 0 THEN
        p = MID$(p, 3)
        isDir = -1
    END IF

    IF INSTR(p, ":") = 0 THEN
        IF LEFT$(p, 1) = CHR$(92) THEN
            p = CurrentDrivePrefix() + p
        ELSEIF TRIM$(deleteSourceDir) <> "" THEN
            p = JoinPath(deleteSourceDir, p)
        END IF
    END IF

    IF isDir <> 0 THEN
        p = ResolveExistingDosPath(AbsoluteDirPath(p))
        IF p <> "" THEN RETURN p
        RETURN AbsoluteDirPath(p)
    END IF

    p = ResolveExistingDosPath(NormalizePath(p))
    IF p <> "" THEN RETURN p
    RETURN NormalizePath(p)
END FUNCTION

SUB ConfigureFileDialogWindow(BYVAL dlgWin AS INTEGER)
    DIM dirIdx AS INTEGER
    DIM fileIdx AS INTEGER
    DIM pathIdx AS INTEGER
    DIM defaultFocusIdx AS INTEGER
    DIM dirControlName AS STRING
    DIM fileControlName AS STRING
    DIM pathControlName AS STRING
    DIM dlgAppPath AS STRING

    IF dlgWin < LBOUND(layoutWindows) OR dlgWin > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(dlgWin).used = 0 THEN EXIT SUB

    dlgAppPath = RTRIM$(layoutWindows(dlgWin).appPath)
    dirControlName = TRIM$(AppCfgValue(dlgAppPath, "FILE_DIR_CONTROL", ""))
    fileControlName = TRIM$(AppCfgValue(dlgAppPath, "FILE_LIST_CONTROL", ""))
    pathControlName = TRIM$(AppCfgValue(dlgAppPath, "FILE_PATH_CONTROL", ""))

    SyncGlobalsFromLayoutWindow dlgWin

    IF TRIM$(fileDlgDir) = "" THEN fileDlgDir = "."
    fileDlgDir = NormalizePath(fileDlgDir)

    IF dirControlName <> "" THEN
        dirIdx = GetControlIndexByName(dirControlName)
        IF dirIdx >= 1 AND dirIdx <= uiCount THEN
            IF uiElems(dirIdx).kindId = UI_KIND_COMBO THEN
                uiElems(dirIdx).sourceDir = fileDlgDir
                uiElems(dirIdx).sourceMask = "*.*"
                uiElems(dirIdx).sourceKind = "DIRS"
                uiElems(dirIdx).sourceKindKey = "DIRS"
                uiElems(dirIdx).sourceKindId = UI_SOURCE_DIRS
                uiElems(dirIdx).text = fileDlgDir
                comboScrollTop(dlgWin, dirIdx) = 0
                layoutUiElems(dlgWin, dirIdx) = uiElems(dirIdx)
                MarkLayoutDirtyElement dlgWin, dirIdx
            ELSEIF uiElems(dirIdx).kindId = UI_KIND_LISTBOX THEN
                uiElems(dirIdx).sourceDir = fileDlgDir
                uiElems(dirIdx).sourceMask = "*.*"
                uiElems(dirIdx).sourceKind = "DIRS"
                uiElems(dirIdx).sourceKindKey = "DIRS"
                uiElems(dirIdx).sourceKindId = UI_SOURCE_DIRS
                uiElems(dirIdx).sourceItems = ""
                uiElems(dirIdx).text = ""
                comboScrollTop(dlgWin, dirIdx) = 0
                BuildComboItems dirIdx
                uiElems(dirIdx).sourceItems = BuildSourceItemsFromTemp()
                layoutUiElems(dlgWin, dirIdx) = uiElems(dirIdx)
                MarkLayoutDirtyElement dlgWin, dirIdx
            END IF
        END IF
    END IF

    IF fileControlName <> "" THEN
        fileIdx = GetControlIndexByName(fileControlName)
        IF fileIdx >= 1 AND fileIdx <= uiCount THEN
            IF uiElems(fileIdx).kindId = UI_KIND_COMBO THEN
                uiElems(fileIdx).sourceDir = fileDlgDir
                uiElems(fileIdx).sourceMask = fileDlgMask
                uiElems(fileIdx).sourceKind = "FILES"
                uiElems(fileIdx).sourceKindKey = "FILES"
                uiElems(fileIdx).sourceKindId = UI_SOURCE_FILES
                uiElems(fileIdx).text = ""

                BuildComboItems fileIdx
                IF tempComboItemCount > 0 THEN
                    uiElems(fileIdx).text = RTRIM$(tempComboItems(1))
                END IF

                comboScrollTop(dlgWin, fileIdx) = 0
                layoutUiElems(dlgWin, fileIdx) = uiElems(fileIdx)
                MarkLayoutDirtyElement dlgWin, fileIdx
            ELSEIF uiElems(fileIdx).kindId = UI_KIND_LISTBOX THEN
                uiElems(fileIdx).sourceDir = fileDlgDir
                uiElems(fileIdx).sourceMask = fileDlgMask
                uiElems(fileIdx).sourceKind = "FILES"
                uiElems(fileIdx).sourceKindKey = "FILES"
                uiElems(fileIdx).sourceKindId = UI_SOURCE_FILES
                uiElems(fileIdx).sourceItems = ""
                uiElems(fileIdx).text = ""

                comboScrollTop(dlgWin, fileIdx) = 0
                BuildComboItems fileIdx
                uiElems(fileIdx).sourceItems = BuildSourceItemsFromTemp()
                layoutUiElems(dlgWin, fileIdx) = uiElems(fileIdx)
                MarkLayoutDirtyElement dlgWin, fileIdx
            END IF
        END IF
    END IF

    IF pathControlName <> "" THEN
        pathIdx = GetControlIndexByName(pathControlName)
        IF pathIdx >= 1 AND pathIdx <= uiCount THEN
            IF uiElems(pathIdx).kindId = UI_KIND_TEXTBOX THEN
                SetTextboxTextByName pathControlName, AbsoluteDirPath(fileDlgDir)
                layoutUiElems(dlgWin, pathIdx) = uiElems(pathIdx)
                layoutUiEdit(dlgWin, pathIdx) = uiEdit(pathIdx)
                MarkLayoutDirtyElement dlgWin, pathIdx
            END IF
        END IF
    END IF

    defaultFocusIdx = 0
    IF uiFocusIndex = dirIdx OR uiFocusIndex = fileIdx THEN
        defaultFocusIdx = uiFocusIndex
    ELSEIF fileDlgDirectoryMode <> 0 THEN
        IF dirIdx >= 1 AND dirIdx <= uiCount THEN defaultFocusIdx = dirIdx
        IF defaultFocusIdx = 0 AND fileIdx >= 1 AND fileIdx <= uiCount THEN defaultFocusIdx = fileIdx
    ELSE
        IF fileIdx >= 1 AND fileIdx <= uiCount THEN defaultFocusIdx = fileIdx
        IF defaultFocusIdx = 0 AND dirIdx >= 1 AND dirIdx <= uiCount THEN defaultFocusIdx = dirIdx
    END IF

    comboOpenIndex(dlgWin) = 0
    uiFocusIndex = defaultFocusIdx
    uiPressedIndex = 0
    layoutWindows(dlgWin).focusIndex = defaultFocusIdx
    layoutWindows(dlgWin).pressedIndex = 0
    MarkLayoutWindowVisualDirty dlgWin
    SyncLayoutWindowFromGlobals dlgWin
END SUB

