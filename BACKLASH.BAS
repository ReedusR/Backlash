    ClearDosRequestFile PATH_DOSRUNBAT
    ClearDosRequestFile PATH_DOSRESBAT
END SUB

FUNCTION AppLaunchTargetExists(BYVAL appPath AS STRING) AS INTEGER
    appPath = NormalizePath(TRIM$(appPath))
    IF appPath = "" THEN RETURN 0
    IF DIR(LayoutFilePath(appPath)) <> "" THEN RETURN -1
    RETURN 0
END FUNCTION

SUB ShowDosLaunchError(BYVAL messageKey AS STRING, BYVAL detailText AS STRING)
    DIM keyText AS STRING
    DIM titleText AS STRING
    DIM msgText AS STRING

    keyText = UCASE$(TRIM$(messageKey))
    IF keyText = "" THEN keyText = "DOS_ERROR"

    titleText = TRIM$(ReadCfgValueInSection(PATH_DOSERRCFG, keyText, "TITLE", ""))
    msgText = TRIM$(ReadCfgValueInSection(PATH_DOSERRCFG, keyText, "TEXT", ""))

    IF titleText = "" THEN titleText = keyText
    IF msgText = "" THEN msgText = detailText

    ShowGuiMessageBox titleText, msgText
END SUB

FUNCTION DosBatchChdirLines(BYVAL dirName AS STRING) AS STRING
    DIM driveText AS STRING
    DIM cdText AS STRING
    DIM eol AS STRING

    eol = CHR$(13) + CHR$(10)
    dirName = NormalizePath(TRIM$(dirName))
    IF dirName = "" THEN RETURN ""

    driveText = ""
    cdText = dirName

    IF LEN(dirName) >= 2 THEN
        IF MID$(dirName, 2, 1) = ":" THEN
            driveText = LEFT$(dirName, 2)
            cdText = MID$(dirName, 3)
            IF cdText = "" THEN cdText = CHR$(92)
        END IF
    END IF

    IF driveText <> "" THEN
        RETURN driveText + eol + "CD " + cdText + eol
    END IF

    RETURN "CD " + cdText + eol
END FUNCTION

FUNCTION BuildDosRunBatch(BYVAL cmdLine AS STRING) AS STRING
    DIM eol AS STRING
    DIM rootDir AS STRING
    DIM programText AS STRING
    DIM resolvedProgram AS STRING
    DIM argsText AS STRING
    DIM programDir AS STRING
    DIM runText AS STRING
    DIM batchText AS STRING
    DIM extName AS STRING

    eol = CHR$(13) + CHR$(10)
    cmdLine = TRIM$(cmdLine)
    rootDir = AbsoluteDirPath(".")
    programText = DosCommandProgram(cmdLine)
    argsText = DosCommandArgs(cmdLine)

    IF programText = "" THEN RETURN ""

    resolvedProgram = DosCommandExistingTarget(programText)
    IF resolvedProgram = "" THEN resolvedProgram = programText

    programDir = ParentPath(resolvedProgram)
    extName = UCASE$(FileExtensionOf(resolvedProgram))

    IF programDir <> "" THEN
        runText = FileNameOnly(resolvedProgram)
        IF extName = "BAT" THEN runText = "CALL " + runText
        IF argsText <> "" THEN runText = runText + " " + argsText
    ELSE
        runText = resolvedProgram
        IF extName = "BAT" THEN runText = "CALL " + runText
        IF argsText <> "" THEN runText = runText + " " + argsText
    END IF

    batchText = "@ECHO OFF" + eol
    batchText = batchText + "REM Backlash DOS launch request" + eol
    batchText = batchText + DosBatchChdirLines(rootDir)
    IF programDir <> "" THEN batchText = batchText + DosBatchChdirLines(programDir)
    batchText = batchText + runText + eol
    batchText = batchText + DosBatchChdirLines(rootDir)

    RETURN batchText
END FUNCTION

FUNCTION WriteDosRunRequest(BYVAL cmdLine AS STRING) AS INTEGER
    DIM batchText AS STRING

    batchText = BuildDosRunBatch(cmdLine)
    IF batchText = "" THEN RETURN 0

    ClearDosRequestFile PATH_DOSRUNBAT
    RETURN WriteTextFileRaw(PATH_DOSRUNBAT, batchText)
END FUNCTION

FUNCTION WriteDosResidentRequest(BYVAL cmdLine AS STRING) AS INTEGER
    DIM batchText AS STRING

    batchText = BuildDosRunBatch(cmdLine)
    IF batchText = "" THEN RETURN 0

    ClearDosRequestFile PATH_DOSRESBAT
    RETURN WriteTextFileRaw(PATH_DOSRESBAT, batchText)
END FUNCTION

SUB ClearSessionFile(BYVAL fileName AS STRING)
    fileName = NormalizePath(TRIM$(fileName))
    IF fileName = "" THEN EXIT SUB
    IF DIR(fileName) <> "" THEN KILL fileName
END SUB

SUB ClearSessionTempFile()
    ClearSessionFile PATH_SESSIONTMP
END SUB

FUNCTION SessionWindowFilePath(BYVAL winIdx AS INTEGER) AS STRING
    DIM appPath AS STRING
    DIM controlName AS STRING
    DIM filePath AS STRING

    SessionWindowFilePath = ""

    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT FUNCTION
    IF layoutWindows(winIdx).used = 0 THEN EXIT FUNCTION

    appPath = RTRIM$(layoutWindows(winIdx).appPath)
    IF TRIM$(appPath) = "" THEN EXIT FUNCTION

    controlName = TRIM$(AppCfgValue(appPath, "SESSION_FILE_CONTROL", ""))
    IF controlName = "" THEN controlName = TRIM$(AppCfgValue(appPath, "OPEN_FILE_PATH_CONTROL", ""))
    IF controlName = "" THEN EXIT FUNCTION

    filePath = TRIM$(GetDialogControlTextValue(winIdx, controlName))
    IF filePath = "" THEN EXIT FUNCTION

    SessionWindowFilePath = NormalizePath(filePath)
END FUNCTION

SUB RestoreWindowSessionFile(BYVAL winIdx AS INTEGER, BYVAL filePath AS STRING)
    DIM appPath AS STRING
    DIM controlName AS STRING
    DIM contentControl AS STRING
    DIM reloadAction AS STRING
    DIM dataText AS STRING

    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(winIdx).used = 0 THEN EXIT SUB

    appPath = RTRIM$(layoutWindows(winIdx).appPath)
    filePath = NormalizePath(TRIM$(filePath))
    IF TRIM$(appPath) = "" OR filePath = "" THEN EXIT SUB

    controlName = TRIM$(AppCfgValue(appPath, "SESSION_FILE_CONTROL", ""))
    IF controlName = "" THEN controlName = TRIM$(AppCfgValue(appPath, "OPEN_FILE_PATH_CONTROL", ""))
    IF controlName = "" THEN EXIT SUB

    activeLayoutWindow = winIdx
    SyncGlobalsFromLayoutWindow winIdx

    SetDialogTargetControlText winIdx, controlName, filePath

    contentControl = TRIM$(AppCfgValue(appPath, "SESSION_CONTENT_CONTROL", ""))
    IF contentControl = "" THEN contentControl = TRIM$(AppCfgValue(appPath, "OPEN_FILE_CONTENT_CONTROL", ""))
    IF contentControl <> "" THEN
        IF DIR(filePath) <> "" THEN
            dataText = ReadTextFileRaw(filePath)
            SetDialogTargetControlText winIdx, contentControl, dataText
        END IF
    END IF

    reloadAction = TRIM$(AppCfgValue(appPath, "SESSION_RELOAD_ACTION", ""))
    IF reloadAction = "" THEN reloadAction = TRIM$(AppCfgValue(appPath, "OPEN_FILE_ACTION", ""))
    IF reloadAction <> "" THEN HostAppAction winIdx, reloadAction

    SyncLayoutWindowFromGlobals winIdx
END SUB

FUNCTION BuildShellSessionText() AS STRING
    DIM i AS INTEGER
    DIM z AS INTEGER
    DIM slotIdx AS INTEGER
    DIM sessionText AS STRING
    DIM eol AS STRING
    DIM saveMin AS INTEGER
    DIM saveMax AS INTEGER
    DIM sessionFile AS STRING

    eol = CHR$(13) + CHR$(10)

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN SyncLayoutWindowFromGlobals activeLayoutWindow
    END IF

    sessionText = "BACKLASH_SESSION_V1" + eol
    sessionText = sessionText + "ACTIVE|" + LTRIM$(STR$(activeLayoutWindow)) + eol
    sessionText = sessionText + "TASKSCROLL|" + LTRIM$(STR$(taskbarFirstButton)) + eol

    FOR z = LBOUND(layoutZOrder) TO UBOUND(layoutZOrder)
        slotIdx = layoutZOrder(z)
        IF slotIdx >= LBOUND(layoutWindows) AND slotIdx <= UBOUND(layoutWindows) THEN
            IF layoutWindows(slotIdx).used <> 0 THEN
                saveMin = 0
                saveMax = 0
                IF layoutWindows(slotIdx).minimized <> 0 THEN saveMin = 1
                IF layoutWindows(slotIdx).maximized <> 0 THEN saveMax = 1
                sessionFile = SessionWindowFilePath(slotIdx)
                sessionText = sessionText + "WIN|" + _
                    LTRIM$(STR$(slotIdx)) + "|" + _
                    PipeEncodeValue(RTRIM$(layoutWindows(slotIdx).appPath)) + "|" + _
                    LTRIM$(STR$(layoutWindows(slotIdx).x)) + "|" + _
                    LTRIM$(STR$(layoutWindows(slotIdx).y)) + "|" + _
                    LTRIM$(STR$(layoutWindows(slotIdx).w)) + "|" + _
                    LTRIM$(STR$(layoutWindows(slotIdx).h)) + "|" + _
                    LTRIM$(STR$(saveMin)) + "|" + _
                    LTRIM$(STR$(saveMax)) + "|" + _
                    LTRIM$(STR$(layoutWindows(slotIdx).restoreX)) + "|" + _
                    LTRIM$(STR$(layoutWindows(slotIdx).restoreY)) + "|" + _
                    LTRIM$(STR$(layoutWindows(slotIdx).restoreW)) + "|" + _
                    LTRIM$(STR$(layoutWindows(slotIdx).restoreH)) + "|" + _
                    LTRIM$(STR$(layoutWindows(slotIdx).selectedTab)) + "|" + _
                    LTRIM$(STR$(layoutWindows(slotIdx).focusIndex)) + "|" + _
                    LTRIM$(STR$(layoutWindows(slotIdx).caretPos)) + "|" + _
                    LTRIM$(STR$(layoutWindows(slotIdx).scrollY)) + "|" + _
                    LTRIM$(STR$(layoutWindows(slotIdx).scrollX)) + "|" + _
                    PipeEncodeValue(sessionFile) + eol
                AppendWindowControlSession sessionText, slotIdx, eol
                AppendWindowAppViewSession sessionText, slotIdx, eol
            END IF
        END IF
    NEXT

    FOR i = LBOUND(layoutWindows) TO UBOUND(layoutWindows)
        IF layoutWindows(i).used <> 0 THEN
            DIM alreadySaved AS INTEGER
            alreadySaved = 0
            FOR z = LBOUND(layoutZOrder) TO UBOUND(layoutZOrder)
                IF layoutZOrder(z) = i THEN alreadySaved = -1
            NEXT
            IF alreadySaved = 0 THEN
                saveMin = 0
                saveMax = 0
                IF layoutWindows(i).minimized <> 0 THEN saveMin = 1
                IF layoutWindows(i).maximized <> 0 THEN saveMax = 1
                sessionFile = SessionWindowFilePath(i)
                sessionText = sessionText + "WIN|" + _
                    LTRIM$(STR$(i)) + "|" + _
                    PipeEncodeValue(RTRIM$(layoutWindows(i).appPath)) + "|" + _
                    LTRIM$(STR$(layoutWindows(i).x)) + "|" + _
                    LTRIM$(STR$(layoutWindows(i).y)) + "|" + _
                    LTRIM$(STR$(layoutWindows(i).w)) + "|" + _
                    LTRIM$(STR$(layoutWindows(i).h)) + "|" + _
                    LTRIM$(STR$(saveMin)) + "|" + _
                    LTRIM$(STR$(saveMax)) + "|" + _
                    LTRIM$(STR$(layoutWindows(i).restoreX)) + "|" + _
                    LTRIM$(STR$(layoutWindows(i).restoreY)) + "|" + _
                    LTRIM$(STR$(layoutWindows(i).restoreW)) + "|" + _
                    LTRIM$(STR$(layoutWindows(i).restoreH)) + "|" + _
                    LTRIM$(STR$(layoutWindows(i).selectedTab)) + "|" + _
                    LTRIM$(STR$(layoutWindows(i).focusIndex)) + "|" + _
                    LTRIM$(STR$(layoutWindows(i).caretPos)) + "|" + _
                    LTRIM$(STR$(layoutWindows(i).scrollY)) + "|" + _
                    LTRIM$(STR$(layoutWindows(i).scrollX)) + "|" + _
                    PipeEncodeValue(sessionFile) + eol
                AppendWindowControlSession sessionText, i, eol
                AppendWindowAppViewSession sessionText, i, eol
            END IF
        END IF
    NEXT

    RETURN sessionText
END FUNCTION

SUB SaveShellSessionToFile(BYVAL fileName AS STRING)
    DIM sessionText AS STRING

    fileName = NormalizePath(TRIM$(fileName))
    IF fileName = "" THEN EXIT SUB

    sessionText = BuildShellSessionText()
    ClearSessionFile fileName
    IF WriteTextFileRaw(fileName, sessionText) = 0 THEN ClearSessionFile fileName
END SUB

SUB SaveSessionBeforeDosUnload()
    SaveShellSessionToFile PATH_SESSIONTMP
END SUB

SUB SaveSessionBeforeShutdown()
    SaveShellSessionToFile PATH_SESSIONCFG
END SUB

FUNCTION RestoreShellSessionFromFile(BYVAL fileName AS STRING, BYVAL clearAfterRestore AS INTEGER) AS INTEGER
    DIM f AS INTEGER
    DIM lineText AS STRING
    DIM firstLine AS STRING
    DIM oldActive AS INTEGER
    DIM savedTaskScroll AS INTEGER
    DIM savedCount AS INTEGER
    DIM oldSlot(1 TO 12) AS INTEGER
    DIM newSlot(1 TO 12) AS INTEGER
    DIM winApp(1 TO 12) AS STRING
    DIM winX(1 TO 12) AS INTEGER
    DIM winY(1 TO 12) AS INTEGER
    DIM winW(1 TO 12) AS INTEGER
    DIM winH(1 TO 12) AS INTEGER
    DIM winMin(1 TO 12) AS INTEGER
    DIM winMax(1 TO 12) AS INTEGER
    DIM winRX(1 TO 12) AS INTEGER
    DIM winRY(1 TO 12) AS INTEGER
    DIM winRW(1 TO 12) AS INTEGER
    DIM winRH(1 TO 12) AS INTEGER
    DIM winTab(1 TO 12) AS INTEGER
    DIM winFocus(1 TO 12) AS INTEGER
    DIM winCaret(1 TO 12) AS INTEGER
    DIM winScrollY(1 TO 12) AS INTEGER
    DIM winScrollX(1 TO 12) AS INTEGER
    DIM winFile(1 TO 12) AS STRING
    DIM i AS INTEGER
    DIM z AS INTEGER
    DIM slotIdx AS INTEGER
    DIM targetNewSlot AS INTEGER
    DIM topVisibleSlot AS INTEGER
    DIM beforeActive AS INTEGER
    DIM restoredCount AS INTEGER
    DIM appOldSlot AS INTEGER

    RestoreShellSessionFromFile = 0

    fileName = NormalizePath(TRIM$(fileName))
    IF fileName = "" THEN EXIT FUNCTION
    IF DIR(fileName) = "" THEN EXIT FUNCTION

    f = FREEFILE
    IF OPEN(fileName FOR INPUT AS #f) <> 0 THEN EXIT FUNCTION
    IF EOF(f) THEN
        CLOSE #f
        IF clearAfterRestore <> 0 THEN ClearSessionFile fileName
        EXIT FUNCTION
    END IF

    LINE INPUT #f, firstLine
    IF TRIM$(firstLine) <> "BACKLASH_SESSION_V1" THEN
        CLOSE #f
        IF clearAfterRestore <> 0 THEN ClearSessionFile fileName
        EXIT FUNCTION
    END IF

    oldActive = 0
    savedTaskScroll = 0
    savedCount = 0
    ClearSessionRestoreControlBuffer
    ClearSessionRestoreAppViewBuffer

    DO WHILE NOT EOF(f)
        LINE INPUT #f, lineText
        IF PipePart(lineText, 1) = "ACTIVE" THEN
            oldActive = CINT(VAL(PipePart(lineText, 2)))
        ELSEIF PipePart(lineText, 1) = "TASKSCROLL" THEN
            savedTaskScroll = CINT(VAL(PipePart(lineText, 2)))
        ELSEIF PipePart(lineText, 1) = "WIN" THEN
            IF savedCount < 12 THEN
                savedCount = savedCount + 1
                oldSlot(savedCount) = CINT(VAL(PipePart(lineText, 2)))
                winApp(savedCount) = PipeDecodeValue(PipePart(lineText, 3))
                winX(savedCount) = CINT(VAL(PipePart(lineText, 4)))
                winY(savedCount) = CINT(VAL(PipePart(lineText, 5)))
                winW(savedCount) = CINT(VAL(PipePart(lineText, 6)))
                winH(savedCount) = CINT(VAL(PipePart(lineText, 7)))
                winMin(savedCount) = CINT(VAL(PipePart(lineText, 8)))
                winMax(savedCount) = CINT(VAL(PipePart(lineText, 9)))
                winRX(savedCount) = CINT(VAL(PipePart(lineText, 10)))
                winRY(savedCount) = CINT(VAL(PipePart(lineText, 11)))
                winRW(savedCount) = CINT(VAL(PipePart(lineText, 12)))
                winRH(savedCount) = CINT(VAL(PipePart(lineText, 13)))
                winTab(savedCount) = CINT(VAL(PipePart(lineText, 14)))
                winFocus(savedCount) = CINT(VAL(PipePart(lineText, 15)))
                winCaret(savedCount) = CINT(VAL(PipePart(lineText, 16)))
                winScrollY(savedCount) = CINT(VAL(PipePart(lineText, 17)))
                winScrollX(savedCount) = CINT(VAL(PipePart(lineText, 18)))
                winFile(savedCount) = PipeDecodeValue(PipePart(lineText, 19))
                IF winMin(savedCount) <> 0 THEN winMin(savedCount) = -1
                IF winMax(savedCount) <> 0 THEN winMax(savedCount) = -1
            END IF
        ELSEIF PipePart(lineText, 1) = "CTRL" THEN
            IF sessionRestoreCtrlCount < 2304 THEN
                sessionRestoreCtrlCount = sessionRestoreCtrlCount + 1
                sessionRestoreCtrlSlot(sessionRestoreCtrlCount) = CINT(VAL(PipePart(lineText, 2)))
                sessionRestoreCtrlName(sessionRestoreCtrlCount) = SessionHexDecode(PipePart(lineText, 3))
                sessionRestoreCtrlKind(sessionRestoreCtrlCount) = PipePart(lineText, 4)
                sessionRestoreCtrlState(sessionRestoreCtrlCount) = CINT(VAL(PipePart(lineText, 5)))
                sessionRestoreCtrlScroll(sessionRestoreCtrlCount) = CINT(VAL(PipePart(lineText, 6)))
                sessionRestoreCtrlAnchor(sessionRestoreCtrlCount) = CINT(VAL(PipePart(lineText, 7)))
                sessionRestoreCtrlCur(sessionRestoreCtrlCount) = CINT(VAL(PipePart(lineText, 8)))
                sessionRestoreCtrlSelA(sessionRestoreCtrlCount) = CINT(VAL(PipePart(lineText, 9)))
                sessionRestoreCtrlSelB(sessionRestoreCtrlCount) = CINT(VAL(PipePart(lineText, 10)))
                sessionRestoreCtrlText(sessionRestoreCtrlCount) = SessionHexDecode(PipePart(lineText, 11))
                sessionRestoreCtrlMulti(sessionRestoreCtrlCount) = SessionHexDecode(PipePart(lineText, 12))
                sessionRestoreCtrlSourceDir(sessionRestoreCtrlCount) = SessionHexDecode(PipePart(lineText, 13))
                sessionRestoreCtrlSourceMask(sessionRestoreCtrlCount) = SessionHexDecode(PipePart(lineText, 14))
                sessionRestoreCtrlSourceItems(sessionRestoreCtrlCount) = SessionHexDecode(PipePart(lineText, 15))
            END IF
        ELSEIF PipePart(lineText, 1) = "APPVIEW" THEN
            appOldSlot = CINT(VAL(PipePart(lineText, 2)))
            IF appOldSlot >= 1 AND appOldSlot <= 12 THEN
                sessionRestoreAppViewLoaded(appOldSlot) = -1
                sessionRestoreAppViewW(appOldSlot) = CINT(VAL(PipePart(lineText, 3)))
                sessionRestoreAppViewH(appOldSlot) = CINT(VAL(PipePart(lineText, 4)))
                sessionRestoreAppViewColors(appOldSlot) = CINT(VAL(PipePart(lineText, 5)))
                sessionRestoreAppViewClear(appOldSlot) = CINT(VAL(PipePart(lineText, 6)))
                sessionRestoreAppViewLeft(appOldSlot) = CINT(VAL(PipePart(lineText, 7)))
                sessionRestoreAppViewRight(appOldSlot) = CINT(VAL(PipePart(lineText, 8)))
                sessionRestoreAppViewTool(appOldSlot) = CINT(VAL(PipePart(lineText, 9)))
                sessionRestoreAppViewDirty(appOldSlot) = CINT(VAL(PipePart(lineText, 10)))
                sessionRestoreAppViewFile(appOldSlot) = SessionHexDecode(PipePart(lineText, 11))
                sessionRestoreAppViewPalette(appOldSlot) = SessionHexDecode(PipePart(lineText, 12))
                sessionRestoreAppViewPixels(appOldSlot) = PipePart(lineText, 13)
            END IF
        END IF
    LOOP
    CLOSE #f

    IF savedCount <= 0 THEN
        ClearSessionRestoreControlBuffer
        ClearSessionRestoreAppViewBuffer
        IF clearAfterRestore <> 0 THEN
            ClearSessionFile fileName
            RestoreShellSessionFromFile = -1
        END IF
        EXIT FUNCTION
    END IF

    activeLayoutWindow = 0
    uiWindowActive = 0
    uiPressedIndex = 0
    uiFocusIndex = 0
    uiCaretPos = 0
    uiScrollY = 0
    uiScrollX = 0
    uiSelectedTab = 0
    uiCount = 0
    uiTitle = ""
    uiWinX = 0
    uiWinY = 0
    uiWinW = 0
    uiWinH = 0
    uiResizable = 0

    restoredCount = 0
    FOR i = 1 TO savedCount
        newSlot(i) = 0
        IF TRIM$(winApp(i)) <> "" THEN
            IF AppLaunchTargetExists(winApp(i)) <> 0 THEN
                beforeActive = activeLayoutWindow
                OpenLayoutAppWindow winApp(i)
                slotIdx = activeLayoutWindow
                IF slotIdx >= LBOUND(layoutWindows) AND slotIdx <= UBOUND(layoutWindows) THEN
                    IF layoutWindows(slotIdx).used <> 0 THEN
                        IF UCASE$(NormalizePath(RTRIM$(layoutWindows(slotIdx).appPath))) = UCASE$(NormalizePath(winApp(i))) THEN
                            newSlot(i) = slotIdx
                            restoredCount = restoredCount + 1

                            layoutWindows(slotIdx).x = winX(i)
                            layoutWindows(slotIdx).y = winY(i)
                            layoutWindows(slotIdx).w = winW(i)
                            layoutWindows(slotIdx).h = winH(i)
                            layoutWindows(slotIdx).minimized = winMin(i)
                            layoutWindows(slotIdx).maximized = winMax(i)
                            layoutWindows(slotIdx).restoreX = winRX(i)
                            layoutWindows(slotIdx).restoreY = winRY(i)
                            layoutWindows(slotIdx).restoreW = winRW(i)
                            layoutWindows(slotIdx).restoreH = winRH(i)

                            IF layoutWindows(slotIdx).resizable = 0 THEN layoutWindows(slotIdx).maximized = 0
                            IF layoutWindows(slotIdx).maximized <> 0 THEN
                                layoutWindows(slotIdx).x = WORK_X
                                layoutWindows(slotIdx).y = WORK_Y
                                layoutWindows(slotIdx).w = WORK_W
                                layoutWindows(slotIdx).h = WORK_H
                            END IF

                            IF layoutWindows(slotIdx).w < 80 THEN layoutWindows(slotIdx).w = 80
                            IF layoutWindows(slotIdx).h < 60 THEN layoutWindows(slotIdx).h = 60
                            IF layoutWindows(slotIdx).w > WORK_W THEN layoutWindows(slotIdx).w = WORK_W
                            IF layoutWindows(slotIdx).h > SCR_H THEN layoutWindows(slotIdx).h = SCR_H

                            IF layoutWindows(slotIdx).restoreW < 80 THEN layoutWindows(slotIdx).restoreW = layoutWindows(slotIdx).w
                            IF layoutWindows(slotIdx).restoreH < 60 THEN layoutWindows(slotIdx).restoreH = layoutWindows(slotIdx).h
                            IF layoutWindows(slotIdx).restoreW > WORK_W THEN layoutWindows(slotIdx).restoreW = WORK_W
                            IF layoutWindows(slotIdx).restoreH > SCR_H THEN layoutWindows(slotIdx).restoreH = SCR_H

                            RestoreWindowSessionFile slotIdx, winFile(i)
                            RestoreWindowControlStates slotIdx, oldSlot(i), 0
                            RunWindowSessionRestoreAction slotIdx
                            RestoreWindowControlStates slotIdx, oldSlot(i), -1
                            RestoreWindowAppViewState slotIdx, oldSlot(i)

                            layoutWindows(slotIdx).active = 0
                            layoutWindows(slotIdx).selectedTab = winTab(i)
                            layoutWindows(slotIdx).pressedIndex = 0
                            layoutWindows(slotIdx).focusIndex = winFocus(i)
                            IF layoutWindows(slotIdx).focusIndex < 0 OR layoutWindows(slotIdx).focusIndex > layoutUiCount(slotIdx) THEN layoutWindows(slotIdx).focusIndex = 0
                            layoutWindows(slotIdx).caretPos = winCaret(i)
                            IF layoutWindows(slotIdx).caretPos < 0 THEN layoutWindows(slotIdx).caretPos = 0
                            layoutWindows(slotIdx).scrollY = winScrollY(i)
                            layoutWindows(slotIdx).scrollX = winScrollX(i)
                            IF layoutWindows(slotIdx).scrollY < 0 THEN layoutWindows(slotIdx).scrollY = 0
                            IF layoutWindows(slotIdx).scrollX < 0 THEN layoutWindows(slotIdx).scrollX = 0
                            IF layoutWindows(slotIdx).focusIndex >= 1 AND layoutWindows(slotIdx).focusIndex <= layoutUiCount(slotIdx) THEN
                                IF layoutUiElems(slotIdx, layoutWindows(slotIdx).focusIndex).kindId = UI_KIND_TEXTBOX THEN
                                    layoutUiEdit(slotIdx, layoutWindows(slotIdx).focusIndex).curPos = layoutWindows(slotIdx).caretPos
                                END IF
                            END IF
                            comboOpenIndex(slotIdx) = 0

                            SyncGlobalsFromLayoutWindow slotIdx
                        ELSE
                            activeLayoutWindow = beforeActive
                        END IF
                    END IF
                END IF
            END IF
        END IF
    NEXT

    FOR z = LBOUND(layoutZOrder) TO UBOUND(layoutZOrder)
        layoutZOrder(z) = 0
    NEXT

    z = LBOUND(layoutZOrder)
    FOR i = 1 TO savedCount
        IF newSlot(i) >= LBOUND(layoutWindows) AND newSlot(i) <= UBOUND(layoutWindows) THEN
            IF layoutWindows(newSlot(i)).used <> 0 AND z <= UBOUND(layoutZOrder) THEN
                layoutZOrder(z) = newSlot(i)
                z = z + 1
            END IF
        END IF
    NEXT

    layoutWindowCount = 0
    FOR i = LBOUND(layoutWindows) TO UBOUND(layoutWindows)
        IF layoutWindows(i).used <> 0 THEN layoutWindowCount = layoutWindowCount + 1
    NEXT

    activeLayoutWindow = 0
    uiWindowActive = 0
    uiPressedIndex = 0
    uiFocusIndex = 0
    uiCaretPos = 0
    uiScrollY = 0
    uiScrollX = 0
    uiSelectedTab = 0
    uiCount = 0
    uiTitle = ""
    uiWinX = 0
    uiWinY = 0
    uiWinW = 0
    uiWinH = 0
    uiResizable = 0

    targetNewSlot = 0
    IF oldActive <> 0 THEN
        FOR i = 1 TO savedCount
            IF oldSlot(i) = oldActive THEN
                targetNewSlot = newSlot(i)
                EXIT FOR
            END IF
        NEXT
    END IF

    topVisibleSlot = 0
    FOR z = UBOUND(layoutZOrder) TO LBOUND(layoutZOrder) STEP -1
        slotIdx = layoutZOrder(z)
        IF slotIdx >= LBOUND(layoutWindows) AND slotIdx <= UBOUND(layoutWindows) THEN
            IF layoutWindows(slotIdx).used <> 0 AND layoutWindows(slotIdx).minimized = 0 THEN
                topVisibleSlot = slotIdx
                EXIT FOR
            END IF
        END IF
    NEXT

    IF targetNewSlot >= LBOUND(layoutWindows) AND targetNewSlot <= UBOUND(layoutWindows) THEN
        IF layoutWindows(targetNewSlot).used <> 0 AND layoutWindows(targetNewSlot).minimized = 0 THEN
            ActivateLayoutWindow targetNewSlot
        ELSEIF topVisibleSlot <> 0 THEN
            ActivateLayoutWindow topVisibleSlot
        END IF
    ELSEIF topVisibleSlot <> 0 THEN
        ActivateLayoutWindow topVisibleSlot
    END IF

    taskbarFirstButton = savedTaskScroll
    NormalizeTaskbarScroll
    InvalidateTaskbarCache
    drawLayoutWindow = 0

    IF restoredCount > 0 THEN RestoreShellSessionFromFile = -1
    ClearSessionRestoreControlBuffer
    ClearSessionRestoreAppViewBuffer
    IF clearAfterRestore <> 0 THEN ClearSessionFile fileName
END FUNCTION

FUNCTION RestoreSessionAfterDosUnload() AS INTEGER
    RETURN RestoreShellSessionFromFile(PATH_SESSIONTMP, -1)
END FUNCTION

FUNCTION RestoreSessionAfterShutdown() AS INTEGER
    RETURN RestoreShellSessionFromFile(PATH_SESSIONCFG, 0)
END FUNCTION

SUB DrawShutdownScreen()
    DIM boxW AS INTEGER
    DIM boxH AS INTEGER
    DIM boxX1 AS INTEGER
    DIM boxY1 AS INTEGER
    DIM boxX2 AS INTEGER
    DIM boxY2 AS INTEGER
    DIM titleText AS STRING
    DIM bodyText AS STRING
    DIM titleX AS INTEGER
    DIM bodyX AS INTEGER

    titleText = "Backlash"
    bodyText = "Saving state and shutting down..."
    boxW = 320
    boxH = 96
    IF boxW > SCR_W - 32 THEN boxW = SCR_W - 32
    IF boxH > SCR_H - 32 THEN boxH = SCR_H - 32

    boxX1 = (SCR_W - boxW) \ 2
    boxY1 = (SCR_H - boxH) \ 2
    boxX2 = boxX1 + boxW
    boxY2 = boxY1 + boxH

    titleX = boxX1 + ((boxW - (LEN(titleText) * 8)) \ 2)
    bodyX = boxX1 + ((boxW - (LEN(bodyText) * 8)) \ 2)
    IF titleX < boxX1 + 8 THEN titleX = boxX1 + 8
    IF bodyX < boxX1 + 8 THEN bodyX = boxX1 + 8

    SCREENLOCK
    LINE (0, 0)-(SCR_W - 1, SCR_H - 1), COL_DESKTOP, BF
    DrawBevelBox boxX1, boxY1, boxX2, boxY2, 0
    LINE (boxX1 + 4, boxY1 + 4)-(boxX2 - 4, boxY1 + 24), COL_SELECT, BF
    DRAW STRING (titleX, boxY1 + 10), titleText, COL_SELECTED_TEXT
    DRAW STRING (bodyX, boxY1 + 48), bodyText, COL_TEXT
    DRAW STRING (boxX1 + 16, boxY2 - 24), "Please wait.", COL_TEXT
    SCREENUNLOCK
END SUB

SUB BeginGuiShutdown()
    BDbgTrace "SHUTDOWN_BEGIN"
    startMenuOpen = 0
    launchCtxOpen = 0
    desktopCtxOpen = 0
    soundVolumePopupOpen = 0

    BDbgTrace "SHUTDOWN_BEFORE_SAVE_SESSION"
    SaveSessionBeforeShutdown
    BDbgTrace "SHUTDOWN_AFTER_SAVE_SESSION"
    BDbgTrace "SHUTDOWN_BEFORE_DRAW_SCREEN"
    DrawShutdownScreen
    BDbgTrace "SHUTDOWN_AFTER_DRAW_SCREEN"
    BDbgTrace "SHUTDOWN_BEFORE_SOUND"
    SoundShutdownEventAndWait
    BDbgTrace "SHUTDOWN_AFTER_SOUND"
    running = 0
END SUB

SUB LaunchDosProgram(BYVAL cmdLine AS STRING, BYVAL runMode AS STRING)
    DIM modeVal AS STRING
    DIM programText AS STRING

    BDbgTrace "DOS_LAUNCH_BEGIN cmd=" + cmdLine + " mode=" + runMode
    cmdLine = TRIM$(cmdLine)
    IF cmdLine = "" THEN
        ShowDosLaunchError "EMPTY_TARGET", ""
        EXIT SUB
    END IF

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN SyncLayoutWindowFromGlobals activeLayoutWindow
    END IF

    startMenuOpen = 0
    launchCtxOpen = 0

    modeVal = DosRunModeValue(runMode)
    IF modeVal = "" THEN modeVal = cfg.dosRunMode
    IF modeVal = "" THEN modeVal = "RESIDENT"
    BDbgTrace "DOS_LAUNCH_MODE cmd=" + cmdLine + " resolved=" + modeVal

    programText = DosCommandProgram(cmdLine)
    IF programText <> "" THEN
        IF DosCommandPathHasSpaces(programText) <> 0 THEN
            ShowDosLaunchError "INVALID_PATH_SPACE", ""
            EXIT SUB
        END IF
        IF DosCommandPathIs83(programText) = 0 THEN
            ShowDosLaunchError "INVALID_PATH_83", programText
            EXIT SUB
        END IF
        IF DosCommandTargetIsDirectory(programText) <> 0 THEN
            ShowDosLaunchError "NOT_DOS_PROGRAM", programText
            EXIT SUB
        END IF
        IF DosCommandExtensionAllowed(programText) = 0 THEN
            ShowDosLaunchError "UNSUPPORTED_PROGRAM", programText
            EXIT SUB
        END IF
        IF DosCommandTargetExists(programText) = 0 THEN
            ShowDosLaunchError "FILE_NOT_FOUND", programText
            EXIT SUB
        END IF
    END IF

    SetCursorBusy -1

    IF modeVal = "UNLOAD" THEN
        BDbgTrace "DOS_LAUNCH_UNLOAD_BEFORE_WRITE cmd=" + cmdLine
        IF WriteDosRunRequest(cmdLine) <> 0 THEN
            BDbgTrace "DOS_LAUNCH_UNLOAD_AFTER_WRITE cmd=" + cmdLine
            BDbgTrace "DOS_LAUNCH_UNLOAD_BEFORE_SAVE_SESSION"
            SaveSessionBeforeDosUnload
            BDbgTrace "DOS_LAUNCH_UNLOAD_AFTER_SAVE_SESSION"
            running = 0
            EXIT SUB
        END IF

        SetCursorBusy 0
        ShowDosLaunchError "DOSRUN_CREATE_FAILED", PATH_DOSRUNBAT
        EXIT SUB
    END IF

    BDbgTrace "DOS_LAUNCH_RESIDENT_BEFORE_WRITE cmd=" + cmdLine
    IF WriteDosResidentRequest(cmdLine) = 0 THEN
        SetCursorBusy 0
        BDbgTrace "DOS_LAUNCH_RESIDENT_WRITE_FAILED"
        ShowDosLaunchError "DOSRES_CREATE_FAILED", PATH_DOSRESBAT
        EXIT SUB
    END IF
    BDbgTrace "DOS_LAUNCH_RESIDENT_AFTER_WRITE cmd=" + cmdLine

    SoundStop

    SCREEN 0
    WIDTH 80, 25
    COLOR 7, 0
    CLS

    PRINT "Running: "; cmdLine
    PRINT
    BDbgTrace "DOS_LAUNCH_RESIDENT_BEFORE_SHELL"
    SHELL PATH_DOSRESBAT
    BDbgTrace "DOS_LAUNCH_RESIDENT_AFTER_SHELL"
    ClearDosRequestFile PATH_DOSRESBAT
    PRINT
    PRINT "Program finished. Press any key."
    SLEEP

    BDbgTrace "DOS_LAUNCH_RESIDENT_BEFORE_RESUME_GUI"
    ResumeGuiAfterShell
    BDbgTrace "DOS_LAUNCH_RESIDENT_AFTER_RESUME_GUI"
END SUB

SUB RunAssociatedProgram(BYVAL fileName AS STRING)
    fileName = NormalizePath(TRIM$(fileName))
    IF fileName = "" THEN EXIT SUB

    ExecuteLaunchTarget fileName
END SUB

