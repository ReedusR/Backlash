        uiWinY = 0
        uiWinW = 0
        uiWinH = 0
        uiDesignW = 0
        uiDesignH = 0
        uiResizable = 0
        comboOpenIndex(idx) = 0
    ELSE
        FOR i = LBOUND(layoutWindows) TO UBOUND(layoutWindows)
            IF layoutWindows(i).used <> 0 THEN
                layoutWindows(i).active = 0
            END IF
        NEXT
        layoutWindows(activeLayoutWindow).active = -1
        FreeInactiveLayoutWindowCaches activeLayoutWindow
        SyncGlobalsFromLayoutWindow activeLayoutWindow
    END IF
    InvalidateTaskbarCache
    IF bdbgEnabled <> 0 THEN BDbgWindowEvent "CLOSE_BEFORE_APPVIEW_FREE", idx
    AppViewFreeSlot idx
    CanvasFreeSlot idx
    IF bdbgEnabled <> 0 THEN BDbgWindowEvent "CLOSE_AFTER_APPVIEW_FREE", idx
    IF bdbgEnabled <> 0 THEN BDbgWindowEvent "CLOSE_BEFORE_RT_CLEAR", idx
    RtClearWin idx
    IF bdbgEnabled <> 0 THEN BDbgWindowEvent "CLOSE_DONE", idx
