FUNCTION AddLaunchMenuItem(BYVAL cap AS STRING, BYVAL act AS STRING, BYVAL bmp AS STRING, BYVAL parentIdx AS INTEGER, BYVAL isSubmenu AS INTEGER) AS INTEGER
    cap = TRIM$(cap)
    act = TRIM$(act)
    bmp = NormalizePath(TRIM$(bmp))

    IF cap = "" THEN RETURN 0
    IF menuCount >= MAX_MENU_ITEMS THEN RETURN 0

    menuCount = menuCount + 1
    menuItems(menuCount).caption = cap
    menuItems(menuCount).action = act
    menuItems(menuCount).bmpFile = bmp
    menuItems(menuCount).pixels = 0
    menuItems(menuCount).imageBuf = 0
    menuItems(menuCount).runY = 0
    menuItems(menuCount).runX1 = 0
    menuItems(menuCount).runX2 = 0
    menuItems(menuCount).runCol = 0
    menuItems(menuCount).runCount = 0
    menuItems(menuCount).hasTrans = 0
    menuItems(menuCount).w = 0
    menuItems(menuCount).h = 0
    menuItems(menuCount).loaded = 0
    menuItems(menuCount).parentIdx = parentIdx
    menuItems(menuCount).isSubmenu = isSubmenu
    menuChildCacheValid = 0
    ClearMenuMetricsCache

    RETURN menuCount
END FUNCTION

SUB AddDefaultMenu()
    DIM ignoreIdx AS INTEGER

    menuCount = 0

    ignoreIdx = AddLaunchMenuItem("DOS Shell", "SHELL", "", 0, 0)
    ignoreIdx = AddLaunchMenuItem("Shut Down", "EXIT", "", 0, 0)
    launchMenuStaticCount = menuCount
    BuildLaunchMenuCaches
END SUB

SUB ExpandLaunchFolderMenu(BYVAL parentIdx AS INTEGER, BYVAL folderPath AS STRING)
    DIM pattern AS STRING
    DIM fname AS STRING
    DIM fullName AS STRING
    DIM attrBits AS INTEGER
    DIM ignoreIdx AS INTEGER

    folderPath = NormalizePath(TRIM$(folderPath))
    IF parentIdx < 1 OR parentIdx > menuCount THEN EXIT SUB
    IF folderPath = "" THEN EXIT SUB

    EnsureDirectoryExists folderPath
    IF PathExistsAny(folderPath) = 0 THEN EXIT SUB

    pattern = folderPath
    IF RIGHT$(pattern, 1) <> CHR$(92) THEN pattern = pattern + CHR$(92)
    pattern = pattern + "*.*"

    attrBits = 0
    fname = DIR(pattern, &H37, attrBits)
    DO WHILE fname <> ""
        IF fname <> "." AND fname <> ".." THEN
            IF (attrBits AND &H10) = 0 THEN
                fullName = JoinPath(folderPath, fname)
                ignoreIdx = AddLaunchMenuItem(fname, "FILE:" + fullName, "", parentIdx, 0)
            END IF
        END IF
        fname = DIR(attrBits)
    LOOP
END SUB

SUB ExpandLaunchRecentMenu(BYVAL parentIdx AS INTEGER, BYVAL recentFilePath AS STRING)
    DIM f AS INTEGER
    DIM lineIn AS STRING
    DIM filePath AS STRING
    DIM ignoreIdx AS INTEGER

    recentFilePath = NormalizePath(TRIM$(recentFilePath))
    IF parentIdx < 1 OR parentIdx > menuCount THEN EXIT SUB
    IF recentFilePath = "" THEN EXIT SUB

    f = FREEFILE
    IF OPEN(recentFilePath FOR INPUT AS #f) <> 0 THEN EXIT SUB

    DO WHILE NOT EOF(f)
        LINE INPUT #f, lineIn
        filePath = NormalizePath(TRIM$(lineIn))
        IF filePath <> "" THEN
            IF DIR(filePath) <> "" THEN
                ignoreIdx = AddLaunchMenuItem(FileNameOnly(filePath), "FILE:" + filePath, "", parentIdx, 0)
            END IF
        END IF
    LOOP

    CLOSE #f
END SUB

SUB ExpandDynamicLaunchMenuItems()
    DIM i AS INTEGER
    DIM baseCount AS INTEGER
    DIM actionUpper AS STRING
    DIM actionText AS STRING

    baseCount = menuCount
    FOR i = 1 TO baseCount
        IF menuItems(i).isSubmenu <> 0 THEN
            actionText = TRIM$(menuItems(i).action)
            actionUpper = UCASE$(actionText)

            IF LEFT$(actionUpper, 8) = "LISTDIR:" THEN
                ExpandLaunchFolderMenu i, MID$(actionText, 9)
            ELSEIF LEFT$(actionUpper, 7) = "RECENT:" THEN
                ExpandLaunchRecentMenu i, MID$(actionText, 8)
            END IF
        END IF
    NEXT
END SUB

' Rebuilds the Launch menu recent-file entries from the current history file.
SUB RefreshLaunchRecentMenuItems()
    DIM staticIdx AS INTEGER
    DIM readIdx AS INTEGER
    DIM writeIdx AS INTEGER
    DIM oldMenuCount AS INTEGER
    DIM actionText AS STRING
    DIM actionUpper AS STRING
    DIM recentFilePath AS STRING

    IF launchMenuStaticCount < 0 THEN launchMenuStaticCount = 0
    IF launchMenuStaticCount > menuCount THEN launchMenuStaticCount = menuCount
    IF launchMenuStaticCount <= 0 THEN EXIT SUB

    FOR staticIdx = 1 TO launchMenuStaticCount
        actionText = TRIM$(menuItems(staticIdx).action)
        actionUpper = UCASE$(actionText)
        IF LEFT$(actionUpper, 7) = "RECENT:" THEN
            oldMenuCount = menuCount
            writeIdx = 1

            FOR readIdx = 1 TO oldMenuCount
                IF readIdx > launchMenuStaticCount AND menuItems(readIdx).parentIdx = staticIdx THEN
                    IF menuItems(readIdx).pixels <> 0 THEN
                        DEALLOCATE menuItems(readIdx).pixels
                        menuItems(readIdx).pixels = 0
                    END IF
                    IF menuItems(readIdx).imageBuf <> 0 THEN
                        ImageDestroy menuItems(readIdx).imageBuf
                        menuItems(readIdx).imageBuf = 0
                    END IF
                    FreeTransparentRunCache menuItems(readIdx).runY, menuItems(readIdx).runX1, menuItems(readIdx).runX2, menuItems(readIdx).runCol, menuItems(readIdx).runCount
                    menuItems(readIdx).hasTrans = 0
                    menuItems(readIdx).loaded = 0
                    menuItems(readIdx).w = 0
                    menuItems(readIdx).h = 0
                ELSE
                    IF writeIdx <> readIdx THEN menuItems(writeIdx) = menuItems(readIdx)
                    writeIdx = writeIdx + 1
                END IF
            NEXT

            menuCount = writeIdx - 1
            recentFilePath = MID$(actionText, 8)
            ExpandLaunchRecentMenu staticIdx, recentFilePath
        END IF
    NEXT

    BuildLaunchMenuCaches
    InvalidateStartMenuBackBuffer
END SUB

FUNCTION LaunchRecentFileStorePath() AS STRING
    DIM i AS INTEGER
    DIM actionText AS STRING
    DIM actionUpper AS STRING

    FOR i = 1 TO menuCount
        actionText = TRIM$(menuItems(i).action)
        actionUpper = UCASE$(actionText)
        IF LEFT$(actionUpper, 7) = "RECENT:" THEN
            RETURN NormalizePath(TRIM$(MID$(actionText, 8)))
        END IF
    NEXT

    RETURN ""
END FUNCTION

SUB RecentFilesAdd(BYVAL filePath AS STRING)
    DIM recentFilePath AS STRING
    DIM oldItems(1 TO MAX_RECENT_ITEMS) AS STRING
    DIM oldCount AS INTEGER
    DIM outItems(1 TO MAX_RECENT_ITEMS) AS STRING
    DIM outCount AS INTEGER
    DIM f AS INTEGER
    DIM lineIn AS STRING
    DIM i AS INTEGER
    DIM alreadyAdded AS INTEGER

    filePath = NormalizePath(TRIM$(filePath))
    IF filePath = "" THEN EXIT SUB
    IF DIR(filePath) = "" THEN EXIT SUB

    recentFilePath = LaunchRecentFileStorePath()
    IF recentFilePath = "" THEN EXIT SUB

    f = FREEFILE
    IF OPEN(recentFilePath FOR INPUT AS #f) = 0 THEN
        DO WHILE NOT EOF(f) AND oldCount < MAX_RECENT_ITEMS
            LINE INPUT #f, lineIn
            lineIn = NormalizePath(TRIM$(lineIn))
            IF lineIn <> "" THEN
                oldCount = oldCount + 1
                oldItems(oldCount) = lineIn
            END IF
        LOOP
        CLOSE #f
    END IF

    outCount = 1
    outItems(outCount) = filePath

    FOR i = 1 TO oldCount
        IF UCASE$(NormalizePath(TRIM$(oldItems(i)))) <> UCASE$(filePath) THEN
            IF outCount < MAX_RECENT_ITEMS THEN
                outCount = outCount + 1
                outItems(outCount) = NormalizePath(TRIM$(oldItems(i)))
            END IF
        END IF
    NEXT

    f = FREEFILE
    IF OPEN(recentFilePath FOR OUTPUT AS #f) <> 0 THEN EXIT SUB
    FOR i = 1 TO outCount
        PRINT #f, RTRIM$(outItems(i))
    NEXT
    CLOSE #f

    IF startMenuOpen = 0 THEN RefreshLaunchRecentMenuItems
END SUB

SUB LoadStartMenu(BYVAL filename AS STRING)
    DIM rawLine AS STRING
    DIM lineIn AS STRING
    DIM p AS INTEGER
    DIM p2 AS INTEGER
    DIM cap AS STRING
    DIM act AS STRING
    DIM bmp AS STRING
    DIM f AS INTEGER
    DIM mp AS UINTEGER PTR
    DIM mw AS INTEGER
    DIM mh AS INTEGER
    DIM i AS INTEGER
    DIM level AS INTEGER
    DIM tmp AS STRING
    DIM stackParent(0 TO 8) AS INTEGER
    DIM addedIdx AS INTEGER
    DIM capRaw AS STRING
    DIM tmpUpper AS STRING

    FreeMenuIcons
    ClearResolvedIconPathCache
    menuCount = 0
    menuChildCacheValid = 0
    ClearMenuMetricsCache
    filename = NormalizePath(filename)
    f = FREEFILE

    FOR i = 0 TO 8
        stackParent(i) = 0
    NEXT

    IF OPEN(filename FOR INPUT AS #f) <> 0 THEN
        AddDefaultMenu
        EXIT SUB
    END IF

    DO WHILE NOT EOF(f)
        LINE INPUT #f, rawLine
        lineIn = RTRIM$(rawLine)
        level = 0

        DO WHILE LEN(lineIn) > 0 AND (LEFT$(lineIn, 1) = " " OR LEFT$(lineIn, 1) = CHR$(9))
            IF LEFT$(lineIn, 1) = CHR$(9) THEN
                level = level + 1
                lineIn = MID$(lineIn, 2)
            ELSEIF LEN(lineIn) >= 2 AND LEFT$(lineIn, 2) = "  " THEN
                level = level + 1
                lineIn = MID$(lineIn, 3)
            ELSE
                lineIn = MID$(lineIn, 2)
            END IF
        LOOP

        IF level < 0 THEN level = 0
        IF level > 8 THEN level = 8

        lineIn = TRIM$(lineIn)

        IF lineIn <> "" AND LEFT$(lineIn, 1) <> "#" THEN
            IF lineIn = "-" OR lineIn = "---" THEN
                addedIdx = AddLaunchMenuItem("-", "", "", stackParent(level), 0)
            ELSE
                p = INSTR(lineIn, "|")
                bmp = ""
                cap = lineIn
                act = ""

                IF p > 0 THEN
                    capRaw = TRIM$(LEFT$(lineIn, p - 1))
                    cap = capRaw
                    tmp = TRIM$(MID$(lineIn, p + 1))
                    p2 = INSTR(tmp, "|")
                    IF RIGHT$(cap, 1) = ">" THEN
                        cap = RTRIM$(LEFT$(cap, LEN(cap) - 1))
                        IF p2 > 0 THEN
                            act = TRIM$(LEFT$(tmp, p2 - 1))
                            bmp = TRIM$(MID$(tmp, p2 + 1))
                        ELSE
                            tmpUpper = UCASE$(tmp)
                            IF LEFT$(tmpUpper, 8) = "LISTDIR:" OR LEFT$(tmpUpper, 7) = "RECENT:" THEN
                                act = tmp
                                bmp = ""
                            ELSE
                                act = ""
                                bmp = tmp
                            END IF
                        END IF
                    ELSE
                        IF p2 > 0 THEN
                            act = TRIM$(LEFT$(tmp, p2 - 1))
                            bmp = TRIM$(MID$(tmp, p2 + 1))
                        ELSE
                            act = tmp
                        END IF
                    END IF
                END IF

                IF cap <> "" THEN
                    IF p > 0 AND RIGHT$(TRIM$(LEFT$(lineIn, p - 1)), 1) = ">" THEN
                        addedIdx = AddLaunchMenuItem(cap, act, bmp, stackParent(level), -1)
                        IF addedIdx <> 0 THEN stackParent(level + 1) = addedIdx
                    ELSE
                        addedIdx = AddLaunchMenuItem(cap, act, bmp, stackParent(level), 0)
                        IF level < 8 THEN stackParent(level + 1) = 0
                    END IF
                END IF
            END IF
        END IF
    LOOP

    CLOSE #f

    IF menuCount = 0 THEN
        AddDefaultMenu
        EXIT SUB
    END IF

    launchMenuStaticCount = menuCount
    ExpandDynamicLaunchMenuItems
    BuildLaunchMenuCaches

    FOR i = 1 TO menuCount
        IF menuItems(i).caption <> "-" AND menuItems(i).bmpFile <> "" THEN
            mp = 0
            mw = 0
            mh = 0
            IF LoadIconBmpCached(ResolveIconBmpPath(menuItems(i).bmpFile), mp, mw, mh) THEN
                menuItems(i).pixels = mp
                menuItems(i).w = mw
                menuItems(i).h = mh
                menuItems(i).hasTrans = PixelBufferHasTransparency(mp, mw, mh)
                IF menuItems(i).hasTrans = 0 THEN
                    menuItems(i).imageBuf = BuildImageBufferFromPixels(mp, mw, mh)
                ELSE
                    BuildTransparentRunCache mp, mw, mh, menuItems(i).runY, menuItems(i).runX1, menuItems(i).runX2, menuItems(i).runCol, menuItems(i).runCount
                END IF
                menuItems(i).loaded = -1
            END IF
        END IF
    NEXT
END SUB

FUNCTION LoadDesktopIconsFile(BYVAL fileName AS STRING) AS INTEGER
    DIM f AS INTEGER
    DIM lineIn AS STRING
    DIM p1 AS INTEGER
    DIM p2 AS INTEGER
    DIM p3 AS INTEGER
    DIM p4 AS INTEGER
    DIM validLines AS INTEGER

    iconCount = 0
    fileName = NormalizePath(fileName)

    f = FREEFILE
    IF OPEN(fileName FOR INPUT AS #f) <> 0 THEN RETURN 0

    DO WHILE NOT EOF(f)
        LINE INPUT #f, lineIn
        lineIn = TRIM$(lineIn)

        IF lineIn <> "" AND LEFT$(lineIn, 1) <> "#" THEN
            p1 = INSTR(lineIn, "|")
            p2 = INSTR(p1 + 1, lineIn, "|")
            p3 = INSTR(p2 + 1, lineIn, "|")
            p4 = INSTR(p3 + 1, lineIn, "|")

            IF p1 > 0 AND p2 > 0 AND p3 > 0 AND p4 > 0 THEN
                validLines = validLines + 1
                iconCount = iconCount + 1
                IF iconCount <= 128 THEN
                    desktopIcons(iconCount).caption = TRIM$(LEFT$(lineIn, p1 - 1))
                    desktopIcons(iconCount).action = TRIM$(MID$(lineIn, p1 + 1, p2 - p1 - 1))
                    desktopIcons(iconCount).bmpFile = NormalizePath(TRIM$(MID$(lineIn, p2 + 1, p3 - p2 - 1)))
                    desktopIcons(iconCount).x = VALINT(TRIM$(MID$(lineIn, p3 + 1, p4 - p3 - 1)))
                    desktopIcons(iconCount).y = VALINT(TRIM$(MID$(lineIn, p4 + 1)))
                    desktopIcons(iconCount).pixels = 0
                    desktopIcons(iconCount).imageBuf = 0
                    desktopIcons(iconCount).runY = 0
                    desktopIcons(iconCount).runX1 = 0
                    desktopIcons(iconCount).runX2 = 0
                    desktopIcons(iconCount).runCol = 0
                    desktopIcons(iconCount).runCount = 0
                    desktopIcons(iconCount).hasTrans = 0
                    desktopIcons(iconCount).w = 0
                    desktopIcons(iconCount).h = 0
                    desktopIcons(iconCount).loaded = 0
                END IF
            END IF
        END IF
    LOOP

    CLOSE #f

    IF validLines = 0 THEN RETURN 0
    RETURN -1
END FUNCTION

SUB LoadDesktopIcons(BYVAL fileName AS STRING)
    DIM loadedOk AS INTEGER

    fileName = NormalizePath(fileName)
    loadedOk = LoadDesktopIconsFile(fileName)

    IF loadedOk = 0 THEN
        IF UCASE$(fileName) = UCASE$(NormalizePath(PATH_DESKTOPTXT)) THEN
            loadedOk = LoadDesktopIconsFile(PATH_DESKTOPBAK)
        END IF
    END IF

    IF loadedOk <> 0 THEN ResolveDesktopIconCollisions
END SUB

SUB SaveDesktopIcons()
    DIM f AS INTEGER
    DIM i AS INTEGER
    DIM tmpFile AS STRING

    tmpFile = "SYSTEM\DESKTOP.$$$"

    IF DIR(tmpFile) <> "" THEN KILL tmpFile

    f = FREEFILE
    IF OPEN(tmpFile FOR OUTPUT AS #f) <> 0 THEN EXIT SUB

    FOR i = 1 TO iconCount
        PRINT #f, desktopIcons(i).caption + "|" + _
                  desktopIcons(i).action + "|" + _
                  desktopIcons(i).bmpFile + "|" + _
                  LTRIM$(STR$(desktopIcons(i).x)) + "|" + _
                  LTRIM$(STR$(desktopIcons(i).y))
    NEXT

    CLOSE #f

    IF DIR(tmpFile) = "" THEN EXIT SUB

    IF DIR(PATH_DESKTOPTXT) <> "" THEN
        IF DIR(PATH_DESKTOPBAK) <> "" THEN KILL PATH_DESKTOPBAK
        IF CopyFileSafe(PATH_DESKTOPTXT, PATH_DESKTOPBAK) = 0 THEN EXIT SUB
    END IF

    IF DIR(PATH_DESKTOPTXT) <> "" THEN KILL PATH_DESKTOPTXT
    NAME tmpFile AS PATH_DESKTOPTXT
END SUB


SUB ClearDesktopIconSlot(BYVAL iconIdx AS INTEGER)
    IF iconIdx < LBOUND(desktopIcons) OR iconIdx > UBOUND(desktopIcons) THEN EXIT SUB

    desktopIcons(iconIdx).caption = ""
    desktopIcons(iconIdx).action = ""
    desktopIcons(iconIdx).bmpFile = ""
    desktopIcons(iconIdx).x = 0
    desktopIcons(iconIdx).y = 0
    desktopIcons(iconIdx).w = 0
    desktopIcons(iconIdx).h = 0
    desktopIcons(iconIdx).pixels = 0
    desktopIcons(iconIdx).imageBuf = 0
    desktopIcons(iconIdx).runY = 0
    desktopIcons(iconIdx).runX1 = 0
    desktopIcons(iconIdx).runX2 = 0
    desktopIcons(iconIdx).runCol = 0
    desktopIcons(iconIdx).runCount = 0
    desktopIcons(iconIdx).hasTrans = 0
    desktopIcons(iconIdx).loaded = 0
END SUB

SUB MoveDesktopIconSlot(BYVAL dstIdx AS INTEGER, BYVAL srcIdx AS INTEGER)
    IF dstIdx < LBOUND(desktopIcons) OR dstIdx > UBOUND(desktopIcons) THEN EXIT SUB
    IF srcIdx < LBOUND(desktopIcons) OR srcIdx > UBOUND(desktopIcons) THEN EXIT SUB

    desktopIcons(dstIdx).caption = desktopIcons(srcIdx).caption
    desktopIcons(dstIdx).action = desktopIcons(srcIdx).action
    desktopIcons(dstIdx).bmpFile = desktopIcons(srcIdx).bmpFile
    desktopIcons(dstIdx).x = desktopIcons(srcIdx).x
    desktopIcons(dstIdx).y = desktopIcons(srcIdx).y
    desktopIcons(dstIdx).w = desktopIcons(srcIdx).w
    desktopIcons(dstIdx).h = desktopIcons(srcIdx).h
    desktopIcons(dstIdx).pixels = desktopIcons(srcIdx).pixels
    desktopIcons(dstIdx).imageBuf = desktopIcons(srcIdx).imageBuf
    desktopIcons(dstIdx).runY = desktopIcons(srcIdx).runY
    desktopIcons(dstIdx).runX1 = desktopIcons(srcIdx).runX1
    desktopIcons(dstIdx).runX2 = desktopIcons(srcIdx).runX2
    desktopIcons(dstIdx).runCol = desktopIcons(srcIdx).runCol
    desktopIcons(dstIdx).runCount = desktopIcons(srcIdx).runCount
    desktopIcons(dstIdx).hasTrans = desktopIcons(srcIdx).hasTrans
    desktopIcons(dstIdx).loaded = desktopIcons(srcIdx).loaded
END SUB

SUB SnapIconToGrid(BYVAL idx AS INTEGER)
    IF idx < 1 OR idx > iconCount THEN EXIT SUB
    IF cfg.snapIcons = 0 THEN EXIT SUB
    IF ICON_CELL_W <= 0 OR ICON_CELL_H <= 0 THEN EXIT SUB

    desktopIcons(idx).x = (desktopIcons(idx).x \ ICON_CELL_W) * ICON_CELL_W + ICON_PAD_X
    desktopIcons(idx).y = (desktopIcons(idx).y \ ICON_CELL_H) * ICON_CELL_H + ICON_PAD_Y
END SUB

SUB ClampIconToDesktop(BYVAL idx AS INTEGER)
    DIM maxX AS INTEGER
    DIM maxY AS INTEGER

    IF idx < 1 OR idx > iconCount THEN EXIT SUB

    maxX = WORK_W - ICON_CELL_W
    maxY = WORK_H - ICON_CELL_H

    IF maxX < 0 THEN maxX = 0
    IF maxY < 0 THEN maxY = 0

    desktopIcons(idx).x = ClampI(desktopIcons(idx).x, 0, maxX)
    desktopIcons(idx).y = ClampI(desktopIcons(idx).y, 0, maxY)
END SUB

FUNCTION DesktopIconPositionCollides(BYVAL iconIdx AS INTEGER, BYVAL testX AS INTEGER, BYVAL testY AS INTEGER) AS INTEGER
    DIM i AS INTEGER
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER
    DIM ix1 AS INTEGER
    DIM iy1 AS INTEGER
    DIM ix2 AS INTEGER
    DIM iy2 AS INTEGER

    IF iconIdx < 1 OR iconIdx > iconCount THEN RETURN 0
    IF ICON_CELL_W <= 0 OR ICON_CELL_H <= 0 THEN RETURN 0

    x1 = testX
    y1 = testY
    x2 = testX + ICON_CELL_W - 1
    y2 = testY + ICON_CELL_H - 1

    FOR i = 1 TO iconCount
        IF i <> iconIdx THEN
            ix1 = desktopIcons(i).x
            iy1 = desktopIcons(i).y
            ix2 = ix1 + ICON_CELL_W - 1
            iy2 = iy1 + ICON_CELL_H - 1

            IF x1 <= ix2 AND x2 >= ix1 AND y1 <= iy2 AND y2 >= iy1 THEN RETURN -1
        END IF
    NEXT

    RETURN 0
END FUNCTION

SUB PlaceDesktopIconNoCollision(BYVAL iconIdx AS INTEGER)
    DIM maxX AS INTEGER
    DIM maxY AS INTEGER
    DIM firstX AS INTEGER
    DIM firstY AS INTEGER
    DIM testX AS INTEGER
    DIM testY AS INTEGER
    DIM bestX AS INTEGER
    DIM bestY AS INTEGER
    DIM wantX AS INTEGER
    DIM wantY AS INTEGER
    DIM dx AS LONGINT
    DIM dy AS LONGINT
    DIM dist AS LONGINT
    DIM bestDist AS LONGINT
    DIM gridCols AS INTEGER
    DIM gridRows AS INTEGER
    DIM totalCells AS INTEGER
    DIM i AS INTEGER
    DIM cellIdx AS INTEGER
    DIM cellCol AS INTEGER
    DIM cellRow AS INTEGER
    DIM occCol AS INTEGER
    DIM occRow AS INTEGER
    DIM occupied(0 TO 4095) AS INTEGER

    IF iconIdx < 1 OR iconIdx > iconCount THEN EXIT SUB
    IF ICON_CELL_W <= 0 OR ICON_CELL_H <= 0 THEN EXIT SUB

    ClampIconToDesktop iconIdx
    IF cfg.snapIcons <> 0 THEN
        SnapIconToGrid iconIdx
        ClampIconToDesktop iconIdx
    END IF

    IF DesktopIconPositionCollides(iconIdx, desktopIcons(iconIdx).x, desktopIcons(iconIdx).y) = 0 THEN EXIT SUB

    wantX = desktopIcons(iconIdx).x
    wantY = desktopIcons(iconIdx).y

    maxX = WORK_W - ICON_CELL_W
    maxY = WORK_H - ICON_CELL_H
    IF maxX < 0 THEN maxX = 0
    IF maxY < 0 THEN maxY = 0

    firstX = ICON_PAD_X
    firstY = ICON_PAD_Y
    IF firstX < 0 THEN firstX = 0
    IF firstY < 0 THEN firstY = 0
    IF firstX > maxX THEN firstX = 0
    IF firstY > maxY THEN firstY = 0

    gridCols = ((maxX - firstX) \ ICON_CELL_W) + 1
    gridRows = ((maxY - firstY) \ ICON_CELL_H) + 1
    IF gridCols <= 0 OR gridRows <= 0 THEN EXIT SUB

    totalCells = gridCols * gridRows
    IF totalCells > 4096 THEN totalCells = 4096

    FOR i = 1 TO iconCount
        IF i <> iconIdx THEN
            occCol = (desktopIcons(i).x - firstX + (ICON_CELL_W \ 2)) \ ICON_CELL_W
            occRow = (desktopIcons(i).y - firstY + (ICON_CELL_H \ 2)) \ ICON_CELL_H
            IF occCol >= 0 AND occCol < gridCols AND occRow >= 0 AND occRow < gridRows THEN
                cellIdx = occRow * gridCols + occCol
                IF cellIdx >= 0 AND cellIdx < totalCells THEN occupied(cellIdx) = -1
            END IF
        END IF
    NEXT

    bestX = desktopIcons(iconIdx).x
    bestY = desktopIcons(iconIdx).y
    bestDist = -1

    FOR cellRow = 0 TO gridRows - 1
        testY = firstY + cellRow * ICON_CELL_H
        FOR cellCol = 0 TO gridCols - 1
            cellIdx = cellRow * gridCols + cellCol
            IF cellIdx < totalCells THEN
                IF occupied(cellIdx) = 0 THEN
                    testX = firstX + cellCol * ICON_CELL_W
                    IF DesktopIconPositionCollides(iconIdx, testX, testY) = 0 THEN
                        dx = CLNG(testX - wantX)
                        dy = CLNG(testY - wantY)
                        dist = dx * dx + dy * dy
                        IF bestDist < 0 OR dist < bestDist THEN
                            bestDist = dist
                            bestX = testX
                            bestY = testY
                        END IF
                    END IF
                END IF
            END IF
        NEXT
    NEXT

    IF bestDist >= 0 THEN
        desktopIcons(iconIdx).x = bestX
        desktopIcons(iconIdx).y = bestY
    END IF
END SUB

SUB ResolveDesktopIconCollisions()
    DIM i AS INTEGER

    IF iconCount <= 0 THEN EXIT SUB

    FOR i = 1 TO iconCount
        PlaceDesktopIconNoCollision i
    NEXT
END SUB

SUB SnapAllIcons()
    DIM i AS INTEGER

    IF cfg.snapIcons = 0 THEN EXIT SUB
    IF ICON_CELL_W <= 0 OR ICON_CELL_H <= 0 THEN EXIT SUB

    FOR i = 1 TO iconCount
        PlaceDesktopIconNoCollision i
    NEXT
END SUB


FUNCTION DesktopIconBmpIsTrashAware(BYVAL bmpSpec AS STRING) AS INTEGER
    bmpSpec = UCASE$(TRIM$(bmpSpec))
    IF LEFT$(bmpSpec, 10) = "TRASHICON:" THEN RETURN -1
    RETURN 0
END FUNCTION

FUNCTION DesktopIconTrashEmptyBmp(BYVAL bmpSpec AS STRING) AS STRING
    DIM specText AS STRING
    DIM sepPos AS INTEGER

    specText = TRIM$(bmpSpec)
    IF DesktopIconBmpIsTrashAware(specText) = 0 THEN RETURN specText

    specText = TRIM$(MID$(specText, 11))
    sepPos = INSTR(specText, ",")
    IF sepPos > 0 THEN specText = LEFT$(specText, sepPos - 1)
    specText = TRIM$(specText)
    IF specText = "" THEN specText = "ICONS\48\TRSHEMTY.BMP"
    RETURN specText
END FUNCTION

FUNCTION DesktopIconTrashFullBmp(BYVAL bmpSpec AS STRING) AS STRING
    DIM specText AS STRING
    DIM sepPos AS INTEGER

    specText = TRIM$(bmpSpec)
    IF DesktopIconBmpIsTrashAware(specText) = 0 THEN RETURN specText

    specText = TRIM$(MID$(specText, 11))
    sepPos = INSTR(specText, ",")
    IF sepPos > 0 THEN
        specText = MID$(specText, sepPos + 1)
    ELSE
        specText = ""
    END IF
    specText = TRIM$(specText)
    IF specText = "" THEN specText = "ICONS\48\TRASHFUL.BMP"
    RETURN specText
END FUNCTION

FUNCTION DesktopIconResolvedBmpFile(BYVAL iconIdx AS INTEGER) AS STRING
    IF iconIdx < 1 OR iconIdx > iconCount THEN RETURN ""
    IF DesktopIconBmpIsTrashAware(desktopIcons(iconIdx).bmpFile) = 0 THEN RETURN desktopIcons(iconIdx).bmpFile
    IF TrashHasItems() <> 0 THEN RETURN DesktopIconTrashFullBmp(desktopIcons(iconIdx).bmpFile)
    RETURN DesktopIconTrashEmptyBmp(desktopIcons(iconIdx).bmpFile)
END FUNCTION

SUB FreeDesktopIconImage(BYVAL iconIdx AS INTEGER)
    IF iconIdx < 1 OR iconIdx > iconCount THEN EXIT SUB

    IF desktopIcons(iconIdx).pixels <> 0 THEN
        DEALLOCATE desktopIcons(iconIdx).pixels
        desktopIcons(iconIdx).pixels = 0
    END IF
    IF desktopIcons(iconIdx).imageBuf <> 0 THEN
        ImageDestroy desktopIcons(iconIdx).imageBuf
        desktopIcons(iconIdx).imageBuf = 0
    END IF
    FreeTransparentRunCache desktopIcons(iconIdx).runY, desktopIcons(iconIdx).runX1, desktopIcons(iconIdx).runX2, desktopIcons(iconIdx).runCol, desktopIcons(iconIdx).runCount
    desktopIcons(iconIdx).loaded = 0
    desktopIcons(iconIdx).hasTrans = 0
    desktopIcons(iconIdx).w = 0
    desktopIcons(iconIdx).h = 0
END SUB

SUB LoadSingleDesktopIcon(BYVAL iconIdx AS INTEGER)
    DIM p AS UINTEGER PTR
    DIM w AS INTEGER
    DIM h AS INTEGER

    IF iconIdx < 1 OR iconIdx > iconCount THEN EXIT SUB

    FreeDesktopIconImage iconIdx

    IF LoadIconBmpCached(ResolveIconBmpPath(DesktopIconResolvedBmpFile(iconIdx)), p, w, h) THEN
        desktopIcons(iconIdx).pixels = p
        desktopIcons(iconIdx).w = w
        desktopIcons(iconIdx).h = h
        desktopIcons(iconIdx).hasTrans = PixelBufferHasTransparency(p, w, h)
        IF desktopIcons(iconIdx).hasTrans = 0 THEN
            desktopIcons(iconIdx).imageBuf = BuildImageBufferFromPixels(p, w, h)
        ELSE
            BuildTransparentRunCache p, w, h, desktopIcons(iconIdx).runY, desktopIcons(iconIdx).runX1, desktopIcons(iconIdx).runX2, desktopIcons(iconIdx).runCol, desktopIcons(iconIdx).runCount
        END IF
        desktopIcons(iconIdx).loaded = -1
    END IF
END SUB

' Updates desktop icons that change when the Waste Basket becomes empty or full.
SUB RefreshTrashAwareDesktopIcons()
    DIM i AS INTEGER
    DIM changed AS INTEGER
    DIM hasItems AS INTEGER

    hasItems = TrashHasItems()
    IF trashAwareIconStateKnown <> 0 THEN
        IF trashAwareIconHasItems = hasItems THEN EXIT SUB
    END IF

    trashAwareIconStateKnown = -1
    trashAwareIconHasItems = hasItems

    changed = 0
    FOR i = 1 TO iconCount
        IF DesktopIconBmpIsTrashAware(desktopIcons(i).bmpFile) <> 0 THEN
            LoadSingleDesktopIcon i
            changed = -1
        END IF
    NEXT

    IF changed <> 0 THEN InvalidateDesktopCache
END SUB

SUB LoadAllIcons()
    DIM i AS INTEGER

    ClearResolvedIconPathCache

    FOR i = 1 TO iconCount
        LoadSingleDesktopIcon i
    NEXT

    trashAwareIconHasItems = TrashHasItems()
    trashAwareIconStateKnown = -1
END SUB

' ---------------------------
' Background cache
' ---------------------------

SUB BuildBackgroundCache()
    DIM x AS INTEGER
    DIM y AS INTEGER
    DIM sx AS INTEGER
    DIM sy AS INTEGER
    DIM ox AS INTEGER
    DIM oy AS INTEGER
    DIM tx AS INTEGER
    DIM ty AS INTEGER
    DIM maxTx AS INTEGER
    DIM maxTy AS INTEGER
    DIM scaledImg AS ANY PTR

    FreeBackgroundCache

    bgCache = ImageCreate(SCR_W, SCR_H, COL_DESKTOP)
    IF bgCache = 0 THEN EXIT SUB

    IF wallLoaded = 0 OR wallPix = 0 OR wallW <= 0 OR wallH <= 0 THEN
        LINE bgCache, (0, 0)-(SCR_W - 1, SCR_H - 1), COL_DESKTOP, BF
        EXIT SUB
    END IF

    SELECT CASE theme.wallpaperMode
        CASE 1
            LINE bgCache, (0, 0)-(SCR_W - 1, SCR_H - 1), COL_DESKTOP, BF
            ox = (SCR_W - wallW) \ 2
            oy = (SCR_H - wallH) \ 2

            IF wallImage <> 0 AND ox >= 0 AND oy >= 0 AND ox + wallW <= SCR_W AND oy + wallH <= SCR_H THEN
                PUT bgCache, (ox, oy), wallImage, PSET
            ELSE
                FOR y = 0 TO wallH - 1
                    sy = oy + y
                    IF sy >= 0 AND sy < SCR_H THEN
                        FOR x = 0 TO wallW - 1
                            sx = ox + x
                            IF sx >= 0 AND sx < SCR_W THEN
                                PSET bgCache, (sx, sy), wallPix[CLNG(y) * wallW + x]
                            END IF
                        NEXT
                    END IF
                NEXT
            END IF

        CASE 2
            LINE bgCache, (0, 0)-(SCR_W - 1, SCR_H - 1), COL_DESKTOP, BF
            IF wallImage <> 0 THEN
                maxTy = SCR_H - 1
                maxTx = SCR_W - 1
                FOR ty = 0 TO maxTy STEP wallH
                    FOR tx = 0 TO maxTx STEP wallW
                        IF tx + wallW <= SCR_W AND ty + wallH <= SCR_H THEN
                            PUT bgCache, (tx, ty), wallImage, PSET
                        ELSE
                            FOR y = 0 TO wallH - 1
                                sy = ty + y
                                IF sy >= 0 AND sy < SCR_H THEN
                                    FOR x = 0 TO wallW - 1
                                        sx = tx + x
                                        IF sx >= 0 AND sx < SCR_W THEN
                                            PSET bgCache, (sx, sy), wallPix[CLNG(y) * wallW + x]
                                        END IF
                                    NEXT
                                END IF
                            NEXT
                        END IF
                    NEXT
                NEXT
            ELSE
                FOR ty = 0 TO SCR_H - 1 STEP wallH
                    FOR tx = 0 TO SCR_W - 1 STEP wallW
                        FOR y = 0 TO wallH - 1
                            sy = ty + y
                            IF sy >= 0 AND sy < SCR_H THEN
                                FOR x = 0 TO wallW - 1
                                    sx = tx + x
                                    IF sx >= 0 AND sx < SCR_W THEN
                                        PSET bgCache, (sx, sy), wallPix[CLNG(y) * wallW + x]
                                    END IF
                                NEXT
                            END IF
                        NEXT
                    NEXT
                NEXT
            END IF

        CASE 3
            IF wallImage <> 0 AND wallW = SCR_W AND wallH = SCR_H THEN
                PUT bgCache, (0, 0), wallImage, PSET
            ELSE
                scaledImg = BuildScaledImageBufferFromPixels(wallPix, wallW, wallH, SCR_W, SCR_H)
                IF scaledImg <> 0 THEN
                    PUT bgCache, (0, 0), scaledImg, PSET
                    ImageDestroy scaledImg
                ELSE
                    FOR y = 0 TO SCR_H - 1
                        sy = (CLNG(y) * wallH) \ SCR_H
                        FOR x = 0 TO SCR_W - 1
                            sx = (CLNG(x) * wallW) \ SCR_W
                            PSET bgCache, (x, y), wallPix[CLNG(sy) * wallW + sx]
                        NEXT
                    NEXT
                END IF
            END IF

        CASE ELSE
            LINE bgCache, (0, 0)-(SCR_W - 1, SCR_H - 1), COL_DESKTOP, BF
    END SELECT
END SUB

' ---------------------------
' Hit testing
' ---------------------------

FUNCTION DesktopIconScreenX(BYVAL idx AS INTEGER) AS INTEGER
    RETURN desktopIcons(idx).x + WORK_X
END FUNCTION

FUNCTION DesktopIconScreenY(BYVAL idx AS INTEGER) AS INTEGER
    RETURN desktopIcons(idx).y + WORK_Y
END FUNCTION

FUNCTION DesktopScreenXToIconX(BYVAL screenX AS INTEGER) AS INTEGER
    RETURN screenX - WORK_X
END FUNCTION

FUNCTION DesktopScreenYToIconY(BYVAL screenY AS INTEGER) AS INTEGER
    RETURN screenY - WORK_Y
END FUNCTION

FUNCTION IconRectX1(BYVAL idx AS INTEGER) AS INTEGER
    RETURN DesktopIconScreenX(idx)
END FUNCTION

FUNCTION IconRectY1(BYVAL idx AS INTEGER) AS INTEGER
    RETURN DesktopIconScreenY(idx)
END FUNCTION

FUNCTION IconRectX2(BYVAL idx AS INTEGER) AS INTEGER
    RETURN DesktopIconScreenX(idx) + ICON_CELL_W - 1
END FUNCTION

FUNCTION IconRectY2(BYVAL idx AS INTEGER) AS INTEGER
    RETURN DesktopIconScreenY(idx) + ICON_CELL_H - 1
END FUNCTION



FUNCTION IconFromPoint(BYVAL mx AS INTEGER, BYVAL my AS INTEGER) AS INTEGER
    DIM i AS INTEGER

    IF cfg.showIcons = 0 THEN RETURN 0

    FOR i = iconCount TO 1 STEP -1
        IF InRect(mx, my, IconRectX1(i), IconRectY1(i), IconRectX2(i), IconRectY2(i)) THEN RETURN i
    NEXT

    RETURN 0
END FUNCTION

SUB ClearMenuMetricsCache()
    DIM i AS INTEGER

    InvalidateStartMenuHitCache

    FOR i = 0 TO MAX_MENU_ITEMS
        menuPanelMetricValid(i) = 0
        menuPanelWidthCache(i) = 0
        menuPanelHeightCache(i) = 0
        menuPanelChildCountCache(i) = 0
        menuPanelHasIconsCache(i) = 0
        menuPanelHasSubmenusCache(i) = 0
    NEXT

    FreeStartMenuPanelCache
END SUB

SUB FreeStartMenuPanelCache()
    DIM slotIdx AS INTEGER

    FOR slotIdx = 1 TO START_MENU_PANEL_CACHE_SLOTS
        IF startMenuPanelCacheImg(slotIdx) <> 0 THEN
            ImageDestroy startMenuPanelCacheImg(slotIdx)
            startMenuPanelCacheImg(slotIdx) = 0
        END IF
        startMenuPanelCacheValid(slotIdx) = 0
        startMenuPanelCacheParent(slotIdx) = 0
        startMenuPanelCacheW(slotIdx) = 0
        startMenuPanelCacheH(slotIdx) = 0
        startMenuPanelCacheUse(slotIdx) = 0
    NEXT

    startMenuPanelCacheTick = 0
END SUB

FUNCTION FindStartMenuPanelCacheSlot(BYVAL parentIdx AS INTEGER, BYVAL imgW AS INTEGER, BYVAL imgH AS INTEGER) AS INTEGER
    DIM slotIdx AS INTEGER

    FOR slotIdx = 1 TO START_MENU_PANEL_CACHE_SLOTS
        IF startMenuPanelCacheValid(slotIdx) <> 0 THEN
            IF startMenuPanelCacheParent(slotIdx) = parentIdx AND _
               startMenuPanelCacheW(slotIdx) = imgW AND _
               startMenuPanelCacheH(slotIdx) = imgH THEN
                RETURN slotIdx
            END IF
        END IF
    NEXT

    RETURN 0
END FUNCTION

FUNCTION AcquireStartMenuPanelCacheSlot(BYVAL parentIdx AS INTEGER, BYVAL imgW AS INTEGER, BYVAL imgH AS INTEGER) AS INTEGER
    DIM slotIdx AS INTEGER
    DIM bestSlot AS INTEGER
    DIM bestUse AS LONG

    slotIdx = FindStartMenuPanelCacheSlot(parentIdx, imgW, imgH)
    IF slotIdx <> 0 THEN RETURN slotIdx

    FOR slotIdx = 1 TO START_MENU_PANEL_CACHE_SLOTS
        IF startMenuPanelCacheValid(slotIdx) = 0 THEN RETURN slotIdx
    NEXT

    bestSlot = 1
    bestUse = startMenuPanelCacheUse(1)
    FOR slotIdx = 2 TO START_MENU_PANEL_CACHE_SLOTS
        IF startMenuPanelCacheUse(slotIdx) < bestUse THEN
            bestUse = startMenuPanelCacheUse(slotIdx)
            bestSlot = slotIdx
        END IF
    NEXT

    IF startMenuPanelCacheImg(bestSlot) <> 0 THEN
        ImageDestroy startMenuPanelCacheImg(bestSlot)
        startMenuPanelCacheImg(bestSlot) = 0
    END IF
    startMenuPanelCacheValid(bestSlot) = 0
    startMenuPanelCacheParent(bestSlot) = 0
    startMenuPanelCacheW(bestSlot) = 0
    startMenuPanelCacheH(bestSlot) = 0
    startMenuPanelCacheUse(bestSlot) = 0

    RETURN bestSlot
END FUNCTION

FUNCTION PutStartMenuPanelBaseFromCache(BYVAL parentIdx AS INTEGER, BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL imgW AS INTEGER, BYVAL imgH AS INTEGER) AS INTEGER
    DIM slotIdx AS INTEGER

    slotIdx = FindStartMenuPanelCacheSlot(parentIdx, imgW, imgH)
    IF slotIdx = 0 THEN RETURN 0
    IF startMenuPanelCacheImg(slotIdx) = 0 THEN RETURN 0

    PUT (x1, y1), startMenuPanelCacheImg(slotIdx), PSET

    startMenuPanelCacheTick = startMenuPanelCacheTick + 1
    IF startMenuPanelCacheTick > 1000000000 THEN startMenuPanelCacheTick = 1
    startMenuPanelCacheUse(slotIdx) = startMenuPanelCacheTick

    RETURN -1
END FUNCTION

SUB CaptureStartMenuPanelBaseCache(BYVAL parentIdx AS INTEGER, BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER)
    DIM imgW AS INTEGER
    DIM imgH AS INTEGER
    DIM slotIdx AS INTEGER

    IF x2 < x1 OR y2 < y1 THEN EXIT SUB

    imgW = x2 - x1 + 1
    imgH = y2 - y1 + 1
    IF imgW <= 0 OR imgH <= 0 THEN EXIT SUB

    slotIdx = AcquireStartMenuPanelCacheSlot(parentIdx, imgW, imgH)
    IF slotIdx = 0 THEN EXIT SUB

    IF startMenuPanelCacheImg(slotIdx) = 0 OR _
       startMenuPanelCacheW(slotIdx) <> imgW OR _
       startMenuPanelCacheH(slotIdx) <> imgH THEN
        IF startMenuPanelCacheImg(slotIdx) <> 0 THEN
            ImageDestroy startMenuPanelCacheImg(slotIdx)
            startMenuPanelCacheImg(slotIdx) = 0
        END IF
        startMenuPanelCacheImg(slotIdx) = ImageCreate(imgW, imgH, 0)
    END IF

    IF startMenuPanelCacheImg(slotIdx) = 0 THEN
        startMenuPanelCacheValid(slotIdx) = 0
        EXIT SUB
    END IF

    GET (x1, y1)-(x2, y2), startMenuPanelCacheImg(slotIdx)

    startMenuPanelCacheTick = startMenuPanelCacheTick + 1
    IF startMenuPanelCacheTick > 1000000000 THEN startMenuPanelCacheTick = 1

    startMenuPanelCacheValid(slotIdx) = -1
    startMenuPanelCacheParent(slotIdx) = parentIdx
    startMenuPanelCacheW(slotIdx) = imgW
    startMenuPanelCacheH(slotIdx) = imgH
    startMenuPanelCacheUse(slotIdx) = startMenuPanelCacheTick
END SUB

SUB InvalidateStartMenuHitCache()
    startMenuHitCacheValid = 0
    startMenuHitCacheItem = 0
    startMenuHitCacheX1 = 0
    startMenuHitCacheY1 = 0
    startMenuHitCacheX2 = 0
    startMenuHitCacheY2 = 0
    startMenuHitCacheVisibleRows = 0
    startMenuHitCachePanelCount = 0

    startMenuNearPanelCacheValid = 0
    startMenuNearPanelCacheX1 = 0
    startMenuNearPanelCacheY1 = 0
    startMenuNearPanelCacheX2 = 0
    startMenuNearPanelCacheY2 = 0
    startMenuNearPanelCachePanelCount = 0
END SUB

SUB BuildLaunchMenuCaches()
    DIM i AS INTEGER
    DIM parentIdx AS INTEGER
    DIM tailChild(0 TO MAX_MENU_ITEMS) AS INTEGER
    DIM lvl AS INTEGER
    DIM cur AS INTEGER
    DIM guardCount AS INTEGER

    FOR i = 0 TO MAX_MENU_ITEMS
        menuFirstChild(i) = 0
        tailChild(i) = 0
    NEXT

    InvalidateStartMenuHitCache

    FOR i = 1 TO MAX_MENU_ITEMS
        menuNextSibling(i) = 0
        menuItemIsDivider(i) = 0
        menuItemCaptionLen(i) = 0
        menuItemHasIcon(i) = 0
        menuItemHasSubmenu(i) = 0
        menuItemLevelCache(i) = 0
    NEXT

    FOR i = 1 TO menuCount
        parentIdx = menuItems(i).parentIdx
        IF parentIdx < 0 OR parentIdx > MAX_MENU_ITEMS THEN parentIdx = 0

        IF menuItems(i).caption = "-" THEN
            menuItemIsDivider(i) = -1
            menuItemCaptionLen(i) = 1
        ELSE
            menuItemIsDivider(i) = 0
            menuItemCaptionLen(i) = LEN(menuItems(i).caption)
        END IF

        IF menuItems(i).bmpFile <> "" THEN
            menuItemHasIcon(i) = -1
        ELSE
            menuItemHasIcon(i) = 0
        END IF
        IF menuItems(i).isSubmenu <> 0 THEN
            menuItemHasSubmenu(i) = -1
        ELSE
            menuItemHasSubmenu(i) = 0
        END IF

        IF menuFirstChild(parentIdx) = 0 THEN
            menuFirstChild(parentIdx) = i
        ELSE
            menuNextSibling(tailChild(parentIdx)) = i
        END IF
        tailChild(parentIdx) = i
    NEXT

    FOR i = 1 TO menuCount
        lvl = 0
        guardCount = 0
        cur = menuItems(i).parentIdx
        DO WHILE cur > 0 AND cur <= menuCount AND guardCount < 8
            lvl = lvl + 1
            guardCount = guardCount + 1
            cur = menuItems(cur).parentIdx
        LOOP
        menuItemLevelCache(i) = lvl
    NEXT

    menuChildCacheValid = -1
    ClearMenuMetricsCache
    InvalidateStartMenuHitCache
END SUB

SUB BuildMenuPanelMetrics(BYVAL parentIdx AS INTEGER)
    DIM i AS INTEGER
    DIM n AS INTEGER
    DIM h AS INTEGER
    DIM maxChars AS INTEGER
    DIM curChars AS INTEGER
    DIM w AS INTEGER
    DIM hasIcons AS INTEGER
    DIM hasSubmenus AS INTEGER

    IF parentIdx < 0 OR parentIdx > MAX_MENU_ITEMS THEN EXIT SUB
    IF menuChildCacheValid = 0 THEN BuildLaunchMenuCaches
    IF menuPanelMetricValid(parentIdx) <> 0 THEN EXIT SUB

    n = 0
    h = MENU_PANEL_PAD_Y * 2
    maxChars = 0
    hasIcons = 0
    hasSubmenus = 0

    i = menuFirstChild(parentIdx)
    DO WHILE i <> 0
        n = n + 1
        h = h + MenuItemPixelHeight(i)

        curChars = menuItemCaptionLen(i)
        IF menuItemHasIcon(i) <> 0 THEN hasIcons = -1
        IF menuItemHasSubmenu(i) <> 0 THEN hasSubmenus = -1
        IF curChars > maxChars THEN maxChars = curChars

        i = menuNextSibling(i)
    LOOP

    w = MENU_PAD_X + (maxChars * 8) + MENU_PAD_X

    IF hasIcons <> 0 THEN w = w + MENU_ICON_GUTTER
    IF hasSubmenus <> 0 THEN w = w + MENU_ARROW_PAD

    IF parentIdx = 0 THEN
        w = w + StartStripSpace()
        IF w < MENU_MIN_W_TOP + StartStripSpace() THEN w = MENU_MIN_W_TOP + StartStripSpace()
    ELSE
        IF w < MENU_MIN_W_SUB THEN w = MENU_MIN_W_SUB
    END IF

    IF w > 260 THEN w = 260

    menuPanelChildCountCache(parentIdx) = n
    menuPanelHeightCache(parentIdx) = h
    menuPanelWidthCache(parentIdx) = w
    menuPanelHasIconsCache(parentIdx) = hasIcons
    menuPanelHasSubmenusCache(parentIdx) = hasSubmenus
    menuPanelMetricValid(parentIdx) = -1
END SUB


FUNCTION MenuItemPixelHeight(BYVAL itemIdx AS INTEGER) AS INTEGER
    IF itemIdx >= 1 AND itemIdx <= menuCount THEN
        IF menuItemIsDivider(itemIdx) <> 0 THEN
            IF ITEM_H > 1 THEN RETURN ITEM_H \ 2
            RETURN 1
        END IF
    END IF

    RETURN ITEM_H
END FUNCTION

FUNCTION MenuPanelHeight(BYVAL parentIdx AS INTEGER) AS INTEGER
    IF parentIdx < 0 OR parentIdx > MAX_MENU_ITEMS THEN RETURN MENU_PANEL_PAD_Y * 2
    BuildMenuPanelMetrics parentIdx
    RETURN menuPanelHeightCache(parentIdx)
END FUNCTION

FUNCTION MenuPanelWidth(BYVAL parentIdx AS INTEGER) AS INTEGER
    IF parentIdx < 0 OR parentIdx > MAX_MENU_ITEMS THEN RETURN MENU_MIN_W_SUB
    BuildMenuPanelMetrics parentIdx
    RETURN menuPanelWidthCache(parentIdx)
END FUNCTION

FUNCTION MenuHeight() AS INTEGER
    RETURN MenuPanelHeight(0)
END FUNCTION


FUNCTION MenuY1() AS INTEGER
    IF lay.taskbarEdge = TASKBAR_EDGE_TOP THEN RETURN WORK_Y + 1
    RETURN WORK_BOTTOM - MenuHeight() - 1
END FUNCTION

FUNCTION MenuPanelItemFromPoint(BYVAL parentIdx AS INTEGER, BYVAL mx AS INTEGER, BYVAL my AS INTEGER) AS INTEGER
    DIM p AS INTEGER
    DIM row AS INTEGER
    DIM i AS INTEGER
    DIM y1 AS INTEGER
    DIM y2 AS INTEGER

    FOR p = 0 TO menuPanelCount
        IF menuPanels(p).parentIdx = parentIdx THEN
            IF InRect(mx, my, menuPanels(p).x1, menuPanels(p).y1, menuPanels(p).x2, menuPanels(p).y2) = 0 THEN RETURN 0
            row = 0
            DIM hitX1 AS INTEGER
            DIM hitH AS INTEGER
            hitX1 = menuPanels(p).x1 + 2
            IF parentIdx = 0 THEN hitX1 = hitX1 + StartStripSpace()
            y1 = menuPanels(p).y1 + 4
            IF menuChildCacheValid = 0 THEN BuildLaunchMenuCaches
            i = menuFirstChild(parentIdx)
            DO WHILE i <> 0
                hitH = MenuItemPixelHeight(i)
                y2 = y1 + hitH - 1
                IF InRect(mx, my, hitX1, y1, menuPanels(p).x2 - 2, y2) THEN
                    IF menuItemIsDivider(i) = 0 THEN RETURN i
                    RETURN 0
                END IF
                y1 = y1 + hitH
                row = row + 1
                i = menuNextSibling(i)
            LOOP
            RETURN 0
        END IF
    NEXT
    RETURN 0
END FUNCTION

FUNCTION MenuItemLevel(BYVAL idx AS INTEGER) AS INTEGER
    IF idx < 1 OR idx > menuCount THEN RETURN 0
    IF menuChildCacheValid = 0 THEN BuildLaunchMenuCaches
    RETURN menuItemLevelCache(idx)
END FUNCTION

FUNCTION MenuItemFromPoint(BYVAL mx AS INTEGER, BYVAL my AS INTEGER) AS INTEGER
    DIM rowPos AS INTEGER
    DIM itemIdx AS INTEGER

    IF startMenuOpen = 0 THEN
        InvalidateStartMenuHitCache
        RETURN 0
    END IF

    IF startMenuHitCacheValid <> 0 THEN
        itemIdx = startMenuHitCacheItem
        IF itemIdx >= 1 AND itemIdx <= menuCount THEN
            IF startMenuHitCacheVisibleRows = menuVisibleRowCount AND startMenuHitCachePanelCount = menuPanelCount THEN
                IF menuItemRowVisible(itemIdx) <> 0 THEN
                    IF menuItemRowX1(itemIdx) = startMenuHitCacheX1 AND menuItemRowY1(itemIdx) = startMenuHitCacheY1 AND _
                       menuItemRowX2(itemIdx) = startMenuHitCacheX2 AND menuItemRowY2(itemIdx) = startMenuHitCacheY2 THEN
                        IF InRect(mx, my, startMenuHitCacheX1, startMenuHitCacheY1, startMenuHitCacheX2, startMenuHitCacheY2) THEN RETURN itemIdx
                    END IF
                END IF
            END IF
        END IF
    END IF

    ' Visible launch-menu rows are recorded in draw order.
    ' Walk that compact list backward so open child panels win before parents.
    FOR rowPos = menuVisibleRowCount TO 1 STEP -1
        itemIdx = menuVisibleRowItems(rowPos)
        IF itemIdx >= 1 AND itemIdx <= menuCount THEN
            IF menuItemRowVisible(itemIdx) <> 0 THEN
                IF InRect(mx, my, menuItemRowX1(itemIdx), menuItemRowY1(itemIdx), menuItemRowX2(itemIdx), menuItemRowY2(itemIdx)) THEN
                    IF menuItemIsDivider(itemIdx) = 0 THEN
                        startMenuHitCacheValid = -1
                        startMenuHitCacheItem = itemIdx
                        startMenuHitCacheX1 = menuItemRowX1(itemIdx)
                        startMenuHitCacheY1 = menuItemRowY1(itemIdx)
                        startMenuHitCacheX2 = menuItemRowX2(itemIdx)
                        startMenuHitCacheY2 = menuItemRowY2(itemIdx)
                        startMenuHitCacheVisibleRows = menuVisibleRowCount
                        startMenuHitCachePanelCount = menuPanelCount
                        RETURN itemIdx
                    END IF
                    InvalidateStartMenuHitCache
                    RETURN 0
                END IF
            END IF
        END IF
    NEXT

    startMenuHitCacheValid = 0
    startMenuHitCacheItem = 0
    RETURN 0
END FUNCTION

FUNCTION PointInAnyMenuPanel(BYVAL mx AS INTEGER, BYVAL my AS INTEGER) AS INTEGER
    DIM p AS INTEGER
    FOR p = 0 TO menuPanelCount
        IF InRect(mx, my, menuPanels(p).x1, menuPanels(p).y1, menuPanels(p).x2, menuPanels(p).y2) THEN RETURN -1
    NEXT
    RETURN 0
END FUNCTION

FUNCTION PointNearAnyMenuPanel(BYVAL mx AS INTEGER, BYVAL my AS INTEGER) AS INTEGER
    DIM p AS INTEGER

    IF startMenuNearPanelCacheValid <> 0 THEN
        IF startMenuNearPanelCachePanelCount = menuPanelCount THEN
            IF InRect(mx, my, startMenuNearPanelCacheX1, startMenuNearPanelCacheY1, startMenuNearPanelCacheX2, startMenuNearPanelCacheY2) THEN RETURN -1
        END IF
    END IF

    FOR p = 0 TO menuPanelCount
        IF InRect(mx, my, menuPanels(p).x1 - 4, menuPanels(p).y1 - 2, menuPanels(p).x2 + 4, menuPanels(p).y2 + 2) THEN
            startMenuNearPanelCacheValid = -1
            startMenuNearPanelCacheX1 = menuPanels(p).x1 - 4
            startMenuNearPanelCacheY1 = menuPanels(p).y1 - 2
            startMenuNearPanelCacheX2 = menuPanels(p).x2 + 4
            startMenuNearPanelCacheY2 = menuPanels(p).y2 + 2
            startMenuNearPanelCachePanelCount = menuPanelCount
            RETURN -1
        END IF
    NEXT

    startMenuNearPanelCacheValid = 0
    RETURN 0
END FUNCTION

SUB NoteStartMenuBranchChange(BYVAL level AS INTEGER, BYVAL oldItem AS INTEGER, BYVAL newItem AS INTEGER)
    IF level < 0 THEN level = 0
    IF level > 8 THEN level = 8

    IF startMenuBranchChangeLevel < 0 OR startMenuBranchChangeLevel > 8 OR level < startMenuBranchChangeLevel THEN
        startMenuBranchChangeLevel = level
        startMenuBranchOldItem = oldItem
        startMenuBranchNewItem = newItem
    END IF
END SUB

SUB UpdateStartMenuHoverState(BYVAL hoverIdx AS INTEGER, BYVAL mx AS INTEGER, BYVAL my AS INTEGER, BYREF menuStateChanged AS INTEGER)
    DIM lvl AS INTEGER
    DIM clearLvl AS INTEGER

    startMenuBranchChangeLevel = 9
    startMenuBranchOldItem = 0
    startMenuBranchNewItem = 0

    IF startMenuOpen = 0 THEN EXIT SUB

    IF hoverIdx > 0 THEN
        IF menuItemHasSubmenu(hoverIdx) <> 0 THEN
            lvl = MenuItemLevel(hoverIdx)
            IF lvl < 0 THEN lvl = 0
            IF lvl > 8 THEN lvl = 8

            IF menuOpenItem(lvl) <> hoverIdx THEN
                NoteStartMenuBranchChange lvl, menuOpenItem(lvl), hoverIdx
                menuOpenItem(lvl) = hoverIdx
                menuStateChanged = -1
            END IF

            clearLvl = lvl + 1
            DO WHILE clearLvl <= 8
                IF menuOpenItem(clearLvl) <> 0 THEN
                    NoteStartMenuBranchChange clearLvl, menuOpenItem(clearLvl), 0
                    menuOpenItem(clearLvl) = 0
                    menuStateChanged = -1
                END IF
                clearLvl = clearLvl + 1
            LOOP
        ELSE
            clearLvl = MenuItemLevel(hoverIdx)
            IF clearLvl < 0 THEN clearLvl = 0
            IF clearLvl > 8 THEN clearLvl = 8
            DO WHILE clearLvl <= 8
                IF menuOpenItem(clearLvl) <> 0 THEN
                    NoteStartMenuBranchChange clearLvl, menuOpenItem(clearLvl), 0
                    menuOpenItem(clearLvl) = 0
                    menuStateChanged = -1
                END IF
                clearLvl = clearLvl + 1
            LOOP
        END IF
    ELSEIF PointNearAnyMenuPanel(mx, my) = 0 THEN
        FOR clearLvl = 0 TO 8
            IF menuOpenItem(clearLvl) <> 0 THEN
                NoteStartMenuBranchChange clearLvl, menuOpenItem(clearLvl), 0
                menuOpenItem(clearLvl) = 0
                menuStateChanged = -1
            END IF
        NEXT
    END IF
END SUB

' ---------------------------
' Icon label / selection drawing
' ---------------------------

FUNCTION FitLabelLine(BYVAL s AS STRING, BYVAL maxChars AS INTEGER, BYREF restOut AS STRING) AS STRING
    DIM txt AS STRING
    DIM p AS INTEGER
    DIM lastSpace AS INTEGER
    DIM testPart AS STRING

    txt = TRIM$(s)
    restOut = ""

    IF txt = "" THEN RETURN ""
    IF LEN(txt) <= maxChars THEN RETURN txt

    testPart = LEFT$(txt, maxChars)
    lastSpace = 0

    FOR p = LEN(testPart) TO 1 STEP -1
        IF ASC(testPart, p) = 32 THEN
            lastSpace = p
            EXIT FOR
        END IF
    NEXT

    IF lastSpace > 0 THEN
        FitLabelLine = RTRIM$(LEFT$(txt, lastSpace - 1))
        restOut = LTRIM$(MID$(txt, lastSpace + 1))
    ELSE
        FitLabelLine = LEFT$(txt, maxChars)
        restOut = LTRIM$(MID$(txt, maxChars + 1))
    END IF
END FUNCTION

SUB DrawWrappedCenteredLabel(BYVAL idx AS INTEGER, BYVAL isSelected AS INTEGER)
    DIM text1 AS STRING
    DIM text2 AS STRING
    DIM remain AS STRING
    DIM maxChars AS INTEGER
    DIM charW AS INTEGER
    DIM labelW AS INTEGER
    DIM labelX1 AS INTEGER
    DIM labelX2 AS INTEGER
    DIM tx1 AS INTEGER
    DIM tx2 AS INTEGER
    DIM ty1 AS INTEGER
    DIM ty2 AS INTEGER
    DIM w1 AS INTEGER
    DIM w2 AS INTEGER
    DIM bgX1 AS INTEGER
    DIM bgX2 AS INTEGER
    DIM bgY1 AS INTEGER
    DIM bgY2 AS INTEGER
    DIM widest AS INTEGER
    DIM drawCol AS UINTEGER

    charW = 8

    labelX1 = DesktopIconScreenX(idx)
    labelX2 = DesktopIconScreenX(idx) + ICON_CELL_W - 1
    labelW = labelX2 - labelX1 + 1

    ty1 = DesktopIconScreenY(idx) + 46
    ty2 = ty1 + 10

    maxChars = (labelW - 8) \ charW
    IF maxChars < 4 THEN maxChars = 4

    IF idx >= 1 AND idx <= 128 AND desktopLabelCacheValid(idx) <> 0 AND _
       desktopLabelCacheCaption(idx) = desktopIcons(idx).caption AND _
       desktopLabelCacheMaxChars(idx) = maxChars THEN
        text1 = desktopLabelCacheText1(idx)
        text2 = desktopLabelCacheText2(idx)
        w1 = desktopLabelCacheW1(idx)
        w2 = desktopLabelCacheW2(idx)
    ELSE
        text1 = FitLabelLine(desktopIcons(idx).caption, maxChars, remain)

        IF remain <> "" THEN
            text2 = FitLabelLine(remain, maxChars, remain)
            IF remain <> "" THEN
                IF LEN(text2) > maxChars - 3 THEN
                    text2 = LEFT$(text2, maxChars - 3) + "..."
                ELSE
                    text2 = text2 + "..."
                END IF
            END IF
        ELSE
            text2 = ""
        END IF

        w1 = LEN(text1) * charW
        w2 = LEN(text2) * charW

        IF idx >= 1 AND idx <= 128 THEN
            desktopLabelCacheValid(idx) = -1
            desktopLabelCacheCaption(idx) = desktopIcons(idx).caption
            desktopLabelCacheMaxChars(idx) = maxChars
            desktopLabelCacheText1(idx) = text1
            desktopLabelCacheText2(idx) = text2
            desktopLabelCacheW1(idx) = w1
            desktopLabelCacheW2(idx) = w2
        END IF
    END IF

    tx1 = labelX1 + ((labelW - w1) \ 2)
    tx2 = labelX1 + ((labelW - w2) \ 2)

    IF tx1 < labelX1 + 2 THEN tx1 = labelX1 + 2
    IF tx2 < labelX1 + 2 THEN tx2 = labelX1 + 2

    IF isSelected THEN
        widest = w1
        IF w2 > widest THEN widest = w2
        IF widest < 16 THEN widest = 16

        bgX1 = labelX1 + ((labelW - widest) \ 2) - 4
        bgX2 = bgX1 + widest + 7
        bgY1 = ty1 - 2
        bgY2 = ty1 + 11
        IF text2 <> "" THEN bgY2 = ty2 + 11

        LINE (bgX1, bgY1)-(bgX2, bgY2), COL_SELECT, BF
        drawCol = COL_SELECTED_TEXT
    ELSE
        drawCol = COL_TEXT_INV
    END IF

    DRAW STRING (tx1, ty1), text1, drawCol
    IF text2 <> "" THEN
        DRAW STRING (tx2, ty2), text2, drawCol
    END IF
END SUB

SUB DrawIconSelection(BYVAL idx AS INTEGER)
    DIM ix AS INTEGER
    DIM iy AS INTEGER
    DIM selX1 AS INTEGER
    DIM selY1 AS INTEGER
    DIM selX2 AS INTEGER
    DIM selY2 AS INTEGER

    ix = DesktopIconScreenX(idx)
    iy = DesktopIconScreenY(idx)

    selX1 = ix + 6
    selY1 = iy + 4
    selX2 = ix + ICON_CELL_W - 7
    selY2 = iy + ICON_TEXT_Y_OFFSET - 6

    LINE (selX1, selY1)-(selX2, selY2), COL_SELECT, B
    LINE (selX1 + 1, selY1 + 1)-(selX2 - 1, selY2 - 1), COL_BEVEL_HI, B
END SUB

' ---------------------------
' Drawing
' ---------------------------

SUB DrawBevelBox(BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER, BYVAL pressed AS INTEGER)
    LINE (x1, y1)-(x2, y2), uiStyle.panelFaceCol, BF

    IF uiStyle.windowModern <> 0 THEN
        LINE (x1, y1)-(x2, y2), uiStyle.bevelLoCol, B
        IF pressed THEN
            IF x2 - x1 > 2 AND y2 - y1 > 2 THEN
                LINE (x1 + 1, y1 + 1)-(x2 - 1, y1 + 1), uiStyle.bevelLoCol
                LINE (x1 + 1, y1 + 1)-(x1 + 1, y2 - 1), uiStyle.bevelLoCol
            END IF
        ELSE
            IF x2 - x1 > 2 AND y2 - y1 > 2 THEN
                LINE (x1 + 1, y1 + 1)-(x2 - 1, y1 + 1), uiStyle.bevelHiCol
                LINE (x1 + 1, y1 + 1)-(x1 + 1, y2 - 1), uiStyle.bevelHiCol
            END IF
        END IF
        EXIT SUB
    END IF

    IF pressed THEN
        LINE (x1, y1)-(x2, y1), uiStyle.bevelLoCol
        LINE (x1, y1)-(x1, y2), uiStyle.bevelLoCol
        LINE (x1, y2)-(x2, y2), uiStyle.bevelHiCol
        LINE (x2, y1)-(x2, y2), uiStyle.bevelHiCol
    ELSE
        LINE (x1, y1)-(x2, y1), uiStyle.bevelHiCol
        LINE (x1, y1)-(x1, y2), uiStyle.bevelHiCol
        LINE (x1, y2)-(x2, y2), uiStyle.bevelLoCol
        LINE (x2, y1)-(x2, y2), uiStyle.bevelLoCol
    END IF
END SUB

SUB DrawButtonBevelBox(BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER, BYVAL pressed AS INTEGER)
    LINE (x1, y1)-(x2, y2), uiStyle.buttonFaceCol, BF

    SELECT CASE uiStyle.buttonStyleId
    CASE 5
        IF x2 - x1 > 6 AND y2 - y1 > 6 THEN
            IF pressed THEN
                LINE (x1 + 2, y1)-(x2 - 2, y1), uiStyle.bevelLoCol
                LINE (x1, y1 + 2)-(x1, y2 - 2), uiStyle.bevelLoCol
                LINE (x1 + 2, y2)-(x2 - 2, y2), uiStyle.bevelHiCol
                LINE (x2, y1 + 2)-(x2, y2 - 2), uiStyle.bevelHiCol
            ELSE
                LINE (x1 + 2, y1)-(x2 - 2, y1), uiStyle.bevelHiCol
                LINE (x1, y1 + 2)-(x1, y2 - 2), uiStyle.bevelHiCol
                LINE (x1 + 2, y2)-(x2 - 2, y2), uiStyle.bevelLoCol
                LINE (x2, y1 + 2)-(x2, y2 - 2), uiStyle.bevelLoCol
            END IF
            EXIT SUB
        END IF
        ' Very small buttons use the classic fallback path.
    CASE 4
        LINE (x1, y1)-(x2, y2), uiStyle.bevelLoCol, B
        IF pressed THEN
            IF x2 - x1 > 3 AND y2 - y1 > 3 THEN LINE (x1 + 1, y1 + 1)-(x2 - 1, y2 - 1), uiStyle.bevelLoCol, B
        END IF
        EXIT SUB
    CASE 3
        LINE (x1, y1)-(x2, y2), uiStyle.bevelLoCol, B
        IF x2 - x1 > 2 AND y2 - y1 > 2 THEN
            IF pressed THEN
                LINE (x1 + 1, y1 + 1)-(x2 - 1, y1 + 1), uiStyle.bevelLoCol
                LINE (x1 + 1, y1 + 1)-(x1 + 1, y2 - 1), uiStyle.bevelLoCol
                LINE (x1 + 1, y2 - 1)-(x2 - 1, y2 - 1), uiStyle.bevelHiCol
            ELSE
                LINE (x1 + 1, y1 + 1)-(x2 - 1, y1 + 1), uiStyle.bevelHiCol
                LINE (x1 + 1, y1 + 1)-(x1 + 1, y2 - 1), uiStyle.bevelHiCol
            END IF
        END IF
        EXIT SUB
    CASE 2
        LINE (x1, y1)-(x2, y2), uiStyle.bevelLoCol, B
        IF pressed THEN
            IF x2 - x1 > 2 AND y2 - y1 > 2 THEN
                LINE (x1 + 1, y1 + 1)-(x2 - 1, y1 + 1), uiStyle.bevelLoCol
                LINE (x1 + 1, y1 + 1)-(x1 + 1, y2 - 1), uiStyle.bevelLoCol
            END IF
        ELSE
            IF x2 - x1 > 2 AND y2 - y1 > 2 THEN
                LINE (x1 + 1, y1 + 1)-(x2 - 1, y1 + 1), uiStyle.bevelHiCol
                LINE (x1 + 1, y1 + 1)-(x1 + 1, y2 - 1), uiStyle.bevelHiCol
            END IF
        END IF
        EXIT SUB
    END SELECT

    IF pressed THEN
        LINE (x1, y1)-(x2, y1), uiStyle.bevelLoCol
        LINE (x1, y1)-(x1, y2), uiStyle.bevelLoCol
        LINE (x1, y2)-(x2, y2), uiStyle.bevelHiCol
        LINE (x2, y1)-(x2, y2), uiStyle.bevelHiCol
    ELSE
        LINE (x1, y1)-(x2, y1), uiStyle.bevelHiCol
        LINE (x1, y1)-(x1, y2), uiStyle.bevelHiCol
        LINE (x1, y2)-(x2, y2), uiStyle.bevelLoCol
        LINE (x2, y1)-(x2, y2), uiStyle.bevelLoCol
    END IF
END SUB

SUB DrawTitleButtonBevelBox(BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER, BYVAL pressed AS INTEGER)
    LINE (x1, y1)-(x2, y2), uiStyle.titleButtonFaceCol, BF

    SELECT CASE uiStyle.titleButtonStyleId
    CASE 5
        IF x2 - x1 > 6 AND y2 - y1 > 6 THEN
            IF pressed THEN
                LINE (x1 + 2, y1)-(x2 - 2, y1), uiStyle.bevelLoCol
                LINE (x1, y1 + 2)-(x1, y2 - 2), uiStyle.bevelLoCol
                LINE (x1 + 2, y2)-(x2 - 2, y2), uiStyle.bevelHiCol
                LINE (x2, y1 + 2)-(x2, y2 - 2), uiStyle.bevelHiCol
            ELSE
                LINE (x1 + 2, y1)-(x2 - 2, y1), uiStyle.bevelHiCol
                LINE (x1, y1 + 2)-(x1, y2 - 2), uiStyle.bevelHiCol
                LINE (x1 + 2, y2)-(x2 - 2, y2), uiStyle.bevelLoCol
                LINE (x2, y1 + 2)-(x2, y2 - 2), uiStyle.bevelLoCol
            END IF
            EXIT SUB
        END IF
        ' Very small title buttons use the classic fallback path.
    CASE 4
        LINE (x1, y1)-(x2, y2), uiStyle.bevelLoCol, B
        EXIT SUB
    CASE 3
        LINE (x1, y1)-(x2, y2), uiStyle.bevelLoCol, B
        IF x2 - x1 > 2 AND y2 - y1 > 2 THEN
            IF pressed THEN
                LINE (x1 + 1, y1 + 1)-(x2 - 1, y1 + 1), uiStyle.bevelLoCol
            ELSE
                LINE (x1 + 1, y1 + 1)-(x2 - 1, y1 + 1), uiStyle.bevelHiCol
            END IF
        END IF
        EXIT SUB
    CASE 2
        LINE (x1, y1)-(x2, y2), uiStyle.bevelLoCol, B
        IF pressed THEN
            IF x2 - x1 > 2 AND y2 - y1 > 2 THEN LINE (x1 + 1, y1 + 1)-(x2 - 1, y1 + 1), uiStyle.bevelLoCol
        ELSE
            IF x2 - x1 > 2 AND y2 - y1 > 2 THEN LINE (x1 + 1, y1 + 1)-(x2 - 1, y1 + 1), uiStyle.bevelHiCol
        END IF
        EXIT SUB
    END SELECT

    IF pressed THEN
        LINE (x1, y1)-(x2, y1), uiStyle.bevelLoCol
        LINE (x1, y1)-(x1, y2), uiStyle.bevelLoCol
        LINE (x1, y2)-(x2, y2), uiStyle.bevelHiCol
        LINE (x2, y1)-(x2, y2), uiStyle.bevelHiCol
    ELSE
        LINE (x1, y1)-(x2, y1), uiStyle.bevelHiCol
        LINE (x1, y1)-(x1, y2), uiStyle.bevelHiCol
        LINE (x1, y2)-(x2, y2), uiStyle.bevelLoCol
        LINE (x2, y1)-(x2, y2), uiStyle.bevelLoCol
    END IF
END SUB

SUB DrawCloseGlyph(BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER)
    DIM gx1 AS INTEGER
    DIM gy1 AS INTEGER
