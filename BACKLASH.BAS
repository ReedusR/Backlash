FUNCTION HelperArgsForRunDir(BYVAL argsText AS STRING, BYVAL oldDir AS STRING) AS STRING
    DIM resultText AS STRING
    DIM rawToken AS STRING
    DIM adjustedToken AS STRING
    DIM i AS INTEGER
    DIM ch AS STRING
    DIM inQuote AS INTEGER
    DIM hadQuote AS INTEGER
    DIM pathLike AS INTEGER

    argsText = TRIM$(argsText)
    oldDir = NormalizePath(TRIM$(oldDir))
    IF argsText = "" THEN RETURN ""

    i = 1
    DO WHILE i <= LEN(argsText)
        DO WHILE i <= LEN(argsText)
            ch = MID$(argsText, i, 1)
            IF ch <> " " AND ch <> CHR$(9) THEN EXIT DO
            i = i + 1
        LOOP
        IF i > LEN(argsText) THEN EXIT DO

        rawToken = ""
        inQuote = 0
        hadQuote = 0

        DO WHILE i <= LEN(argsText)
            ch = MID$(argsText, i, 1)
            IF ch = CHR$(34) THEN
                hadQuote = -1
                IF inQuote = 0 THEN
                    inQuote = -1
                ELSE
                    inQuote = 0
                END IF
                i = i + 1
            ELSEIF inQuote = 0 AND (ch = " " OR ch = CHR$(9)) THEN
                EXIT DO
            ELSE
                rawToken = rawToken + ch
                i = i + 1
            END IF
        LOOP

        adjustedToken = NormalizePath(rawToken)
        pathLike = 0
        IF INSTR(adjustedToken, CHR$(92)) > 0 THEN pathLike = -1

        IF pathLike <> 0 THEN
            IF INSTR(LayoutFilePath(adjustedToken), ":") = 0 AND LEFT$(LayoutFilePath(adjustedToken), 1) <> CHR$(92) THEN
                IF LEFT$(adjustedToken, 2) <> "." + CHR$(92) THEN
                    IF oldDir <> "" THEN adjustedToken = JoinPath(oldDir, adjustedToken)
                END IF
            END IF
        ELSE
            adjustedToken = rawToken
        END IF

        IF resultText <> "" THEN resultText = resultText + " "
        IF hadQuote <> 0 OR INSTR(adjustedToken, " ") > 0 THEN
            resultText = resultText + CHR$(34) + adjustedToken + CHR$(34)
        ELSE
            resultText = resultText + adjustedToken
        END IF
    LOOP

    RETURN resultText
END FUNCTION

SUB RunSilentHelper(BYVAL cmdLine AS STRING)
    DIM helperCmd AS STRING
    DIM helperExe AS STRING
    DIM helperArgs AS STRING
    DIM helperDir AS STRING
    DIM helperFile AS STRING
    DIM helperRun AS STRING
    DIM oldDir AS STRING
    DIM p AS INTEGER

    helperCmd = TRIM$(cmdLine)
    IF helperCmd = "" THEN
        ShowGuiMessageBox "EMPTY HELPER COMMAND:", "No helper command was supplied."
        EXIT SUB
    END IF

    IF LEFT$(helperCmd, 1) = CHR$(34) THEN
        p = INSTR(2, helperCmd, CHR$(34))
        IF p > 0 THEN
            helperExe = MID$(helperCmd, 2, p - 2)
            helperArgs = LTRIM$(MID$(helperCmd, p + 1))
        ELSE
            helperExe = helperCmd
            helperArgs = ""
        END IF
    ELSE
        p = INSTR(helperCmd, " ")
        IF p > 0 THEN
            helperExe = LEFT$(helperCmd, p - 1)
            helperArgs = LTRIM$(MID$(helperCmd, p + 1))
        ELSE
            helperExe = helperCmd
            helperArgs = ""
        END IF
    END IF

    helperDir = ParentPath(helperExe)
    helperFile = FileNameOnly(helperExe)

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN SyncLayoutWindowFromGlobals activeLayoutWindow
    END IF

    startMenuOpen = 0
    launchCtxOpen = 0
    SoundStop

    oldDir = CURDIR
    IF helperDir <> "" AND helperFile <> "" AND DIR(helperDir, &H10) <> "" THEN
        helperArgs = HelperArgsForRunDir(helperArgs, oldDir)
        CHDIR helperDir
        helperRun = helperFile
        IF helperArgs <> "" THEN helperRun = helperRun + " " + helperArgs
        SHELL helperRun
        IF oldDir <> "" THEN CHDIR oldDir
    ELSE
        SHELL helperCmd
    END IF

    ResumeGuiAfterShell
END SUB

