FUNCTION InRect(BYVAL px AS INTEGER, BYVAL py AS INTEGER, _
                BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, _
                BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER) AS INTEGER
    IF px >= x1 AND px <= x2 AND py >= y1 AND py <= y2 THEN RETURN -1
    RETURN 0
END FUNCTION

FUNCTION BkInlineControlModeToken(BYVAL tokenText AS STRING) AS INTEGER
    DIM modeText AS STRING

    modeText = UCASE$(TRIM$(tokenText))
    IF modeText = "CONTROL_IO" THEN RETURN -1
    IF modeText = "CONTROL_STATE" THEN RETURN -1
    IF modeText = "STATE" THEN RETURN -1
    IF modeText = "/CONTROL_IO" THEN RETURN -1
    IF modeText = "/CONTROL_STATE" THEN RETURN -1
    IF modeText = "/STATE" THEN RETURN -1

    RETURN 0
END FUNCTION

SUB WriteBkInlineControlFile(BYVAL winIdx AS INTEGER, BYVAL fileName AS STRING)
    DIM outText AS STRING
    DIM eol AS STRING
    DIM i AS INTEGER
    DIM controlName AS STRING
    DIM controlValue AS STRING

    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(winIdx).used = 0 THEN EXIT SUB
    IF TRIM$(fileName) = "" THEN EXIT SUB

    eol = CHR$(13) + CHR$(10)
    outText = "[controls]" + eol

    FOR i = 1 TO layoutUiCount(winIdx)
        controlName = TRIM$(layoutUiElems(winIdx, i).name)
        IF controlName <> "" THEN
            controlValue = GetDialogControlTextValue(winIdx, controlName)
            outText = outText + controlName + "=" + SessionHexEncode(controlValue) + eol
        END IF
    NEXT

    WriteTextFileRaw fileName, outText
END SUB

SUB ApplyLayoutWindowDialogFocus(BYVAL targetWin AS INTEGER)
    DIM dialogAppPath AS STRING
    DIM focusControlName AS STRING
    DIM selectAllControlName AS STRING
    DIM focusIdx AS INTEGER
    DIM selectAllIdx AS INTEGER
    DIM selectedText AS STRING

    IF targetWin < LBOUND(layoutWindows) OR targetWin > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(targetWin).used = 0 THEN EXIT SUB
    IF activeLayoutWindow <> targetWin THEN EXIT SUB

    dialogAppPath = RTRIM$(layoutWindows(targetWin).appPath)
    IF dialogAppPath = "" THEN EXIT SUB

    focusControlName = TRIM$(AppCfgValue(dialogAppPath, "DIALOG_FOCUS_CONTROL", ""))
    selectAllControlName = TRIM$(AppCfgValue(dialogAppPath, "DIALOG_SELECT_ALL_CONTROL", ""))

    ' Dialogs can request a starting textbox so typing works immediately after open.
    IF focusControlName <> "" THEN
        focusIdx = GetControlIndexByName(focusControlName)
        IF focusIdx >= 1 AND focusIdx <= uiCount THEN
            uiFocusIndex = focusIdx
            IF uiElems(focusIdx).kindId = UI_KIND_TEXTBOX THEN
                Ed_LoadTxt uiEdit(focusIdx), uiElems(focusIdx).text, LEN(uiElems(focusIdx).text)
                uiCaretPos = uiEdit(focusIdx).curPos
                layoutUiEdit(targetWin, focusIdx) = uiEdit(focusIdx)
            ELSE
                uiCaretPos = 0
            END IF
            layoutWindows(targetWin).focusIndex = focusIdx
            layoutWindows(targetWin).caretPos = uiCaretPos
            layoutUiElems(targetWin, focusIdx) = uiElems(focusIdx)
            MarkLayoutDirtyElement targetWin, focusIdx
        END IF
    END IF

    selectAllIdx = GetControlIndexByName(selectAllControlName)
    IF selectAllIdx >= 1 AND selectAllIdx <= uiCount THEN
        IF uiElems(selectAllIdx).kindId = UI_KIND_TEXTBOX AND uiElems(selectAllIdx).noEdit = 0 THEN
            selectedText = uiElems(selectAllIdx).text
            Ed_LoadTxt uiEdit(selectAllIdx), selectedText, LEN(selectedText)
            uiEdit(selectAllIdx).selA = 0
            uiEdit(selectAllIdx).selB = uiEdit(selectAllIdx).txtLen
            uiEdit(selectAllIdx).curPos = uiEdit(selectAllIdx).txtLen
            uiFocusIndex = selectAllIdx
            uiCaretPos = uiEdit(selectAllIdx).curPos
            uiSelAnchor(selectAllIdx) = 0
            uiPrefCol(selectAllIdx) = -1
            comboScrollTop(targetWin, selectAllIdx) = 0
            InvalidateTextboxMetrics selectAllIdx
            layoutWindows(targetWin).focusIndex = selectAllIdx
            layoutWindows(targetWin).caretPos = uiCaretPos
            layoutUiElems(targetWin, selectAllIdx) = uiElems(selectAllIdx)
            layoutUiEdit(targetWin, selectAllIdx) = uiEdit(selectAllIdx)
            layoutUiSelAnchor(targetWin, selectAllIdx) = uiSelAnchor(selectAllIdx)
            layoutUiPrefCol(targetWin, selectAllIdx) = uiPrefCol(selectAllIdx)
            MarkLayoutDirtyElement targetWin, selectAllIdx
        END IF
    END IF

    SyncLayoutWindowFromGlobals targetWin
END SUB


SUB ApplyBkInlineControlFile(BYVAL winIdx AS INTEGER, BYVAL fileName AS STRING)
    DIM rawText AS STRING
    DIM lineText AS STRING
    DIM scanIdx AS INTEGER
    DIM startPos AS INTEGER
    DIM ch AS STRING
    DIM eqPos AS INTEGER
    DIM controlName AS STRING
    DIM encodedValue AS STRING
    DIM decodedValue AS STRING
    DIM sectionName AS STRING
    DIM inControls AS INTEGER

    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(winIdx).used = 0 THEN EXIT SUB
    IF TRIM$(fileName) = "" THEN EXIT SUB
    IF DIR(fileName) = "" THEN EXIT SUB

    rawText = ReadTextFileRaw(fileName)
    IF rawText = "" THEN EXIT SUB

    inControls = 0
    startPos = 1
    scanIdx = 1

    DO WHILE scanIdx <= LEN(rawText) + 1
        IF scanIdx <= LEN(rawText) THEN
            ch = MID$(rawText, scanIdx, 1)
        ELSE
            ch = CHR$(10)
        END IF

        IF ch = CHR$(13) OR ch = CHR$(10) THEN
            lineText = MID$(rawText, startPos, scanIdx - startPos)
            lineText = TRIM$(lineText)

            IF lineText <> "" THEN
                IF LEFT$(lineText, 1) = "[" AND RIGHT$(lineText, 1) = "]" THEN
                    sectionName = UCASE$(TRIM$(MID$(lineText, 2, LEN(lineText) - 2)))
                    IF sectionName = "CONTROLS" OR sectionName = "SET_CONTROLS" THEN
                        inControls = -1
                    ELSE
                        inControls = 0
                    END IF
                ELSEIF inControls <> 0 THEN
                    eqPos = INSTR(lineText, "=")
                    IF eqPos > 1 THEN
                        controlName = TRIM$(LEFT$(lineText, eqPos - 1))
                        encodedValue = TRIM$(MID$(lineText, eqPos + 1))
                        IF controlName <> "" THEN
                            decodedValue = SessionHexDecode(encodedValue)
                            SetDialogTargetControlTextNoBind winIdx, controlName, decodedValue
                        END IF
                    END IF
                END IF
            END IF

            IF ch = CHR$(13) AND scanIdx < LEN(rawText) THEN
                IF MID$(rawText, scanIdx + 1, 1) = CHR$(10) THEN scanIdx = scanIdx + 1
            END IF
            startPos = scanIdx + 1
        END IF

        scanIdx = scanIdx + 1
    LOOP

    MarkLayoutWindowVisualDirty winIdx
END SUB

SUB RunInlineControlHelper(BYVAL helperExe AS STRING, BYVAL helperArgs AS STRING, BYVAL helperDir AS STRING, BYVAL helperFile AS STRING)
    DIM oldDir AS STRING
    DIM runArgs AS STRING
    DIM helperRun AS STRING
    DIM targetWin AS INTEGER
    DIM inputFile AS STRING
    DIM outputFile AS STRING
    DIM canUseHelperDir AS INTEGER

    targetWin = activeLayoutWindow
    IF targetWin < LBOUND(layoutWindows) OR targetWin > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(targetWin).used = 0 THEN EXIT SUB

    SyncLayoutWindowFromGlobals targetWin

    inputFile = "BKHLPIN.CFG"
    outputFile = "BKHLPOT.CFG"
    oldDir = CURDIR
    canUseHelperDir = 0

    IF helperDir <> "" AND helperFile <> "" THEN
        IF DIR(helperDir, &H10) <> "" THEN canUseHelperDir = -1
    END IF

    IF canUseHelperDir <> 0 THEN
        runArgs = HelperArgsForRunDir(helperArgs, oldDir)
        CHDIR helperDir
        IF DIR(inputFile) <> "" THEN KILL inputFile
        IF DIR(outputFile) <> "" THEN KILL outputFile
        WriteBkInlineControlFile targetWin, inputFile
        helperRun = helperFile
        IF runArgs <> "" THEN helperRun = helperRun + " " + runArgs
        helperRun = helperRun + " " + inputFile + " " + outputFile
        SHELL helperRun
        ApplyBkInlineControlFile targetWin, outputFile
        IF DIR(inputFile) <> "" THEN KILL inputFile
        IF DIR(outputFile) <> "" THEN KILL outputFile
        IF oldDir <> "" THEN CHDIR oldDir
    ELSE
        IF DIR(inputFile) <> "" THEN KILL inputFile
        IF DIR(outputFile) <> "" THEN KILL outputFile
        WriteBkInlineControlFile targetWin, inputFile
        helperRun = helperExe
        IF helperArgs <> "" THEN helperRun = helperRun + " " + helperArgs
        helperRun = helperRun + " " + inputFile + " " + outputFile
        SHELL helperRun
        ApplyBkInlineControlFile targetWin, outputFile
        IF DIR(inputFile) <> "" THEN KILL inputFile
        IF DIR(outputFile) <> "" THEN KILL outputFile
    END IF

    SyncGlobalsFromLayoutWindow targetWin
    cursorBackValid = 0
    InvalidateTaskbarCache
END SUB


' Clears cached file details used by Navigator-style file panes.
SUB ClearFilePaneMetadataCache()
    DIM slotIdx AS INTEGER

    FOR slotIdx = 1 TO 64
        filePaneMetaValid(slotIdx) = 0
        filePaneMetaPath(slotIdx) = ""
        filePaneMetaSize(slotIdx) = 0
        filePaneMetaDate(slotIdx) = ""
        filePaneMetaAttr(slotIdx) = 0
        filePaneMetaAge(slotIdx) = 0
    NEXT
    filePaneMetaClock = 0
END SUB

FUNCTION CachedFilePaneCaption(BYVAL itemValue AS STRING, BYVAL fallbackText AS STRING, BYVAL paneW AS INTEGER) AS STRING
    DIM fileName AS STRING
    DIM fileKey AS STRING
    DIM slotIdx AS INTEGER
    DIM bestSlot AS INTEGER
    DIM bestAge AS LONG
    DIM sizeBytes AS LONGINT
    DIM dateText AS STRING
    DIM attrBits AS INTEGER

    fileName = RTRIM$(itemValue)
    IF LEFT$(fileName, 2) = "F:" THEN fileName = MID$(fileName, 3)
    fileName = NormalizePath(TRIM$(fileName))
    IF fileName = "" THEN RETURN fallbackText

    fileKey = UCASE$(fileName)
    FOR slotIdx = 1 TO 64
        IF filePaneMetaValid(slotIdx) <> 0 THEN
            IF filePaneMetaPath(slotIdx) = fileKey THEN
                filePaneMetaClock = filePaneMetaClock + 1
                filePaneMetaAge(slotIdx) = filePaneMetaClock
                RETURN FilePaneCaption(fileName, filePaneMetaAttr(slotIdx), paneW, filePaneMetaSize(slotIdx), filePaneMetaDate(slotIdx))
            END IF
        END IF
    NEXT

    bestSlot = 0
    FOR slotIdx = 1 TO 64
        IF filePaneMetaValid(slotIdx) = 0 THEN
            bestSlot = slotIdx
            EXIT FOR
        END IF
    NEXT

    IF bestSlot = 0 THEN
        bestSlot = 1
        bestAge = filePaneMetaAge(1)
        FOR slotIdx = 2 TO 64
            IF filePaneMetaAge(slotIdx) < bestAge THEN
                bestAge = filePaneMetaAge(slotIdx)
                bestSlot = slotIdx
            END IF
        NEXT
    END IF

    attrBits = FileAttributeBits(fileName)
    ReadFilePaneMetadata fileName, sizeBytes, dateText

    filePaneMetaClock = filePaneMetaClock + 1
    filePaneMetaValid(bestSlot) = -1
    filePaneMetaPath(bestSlot) = fileKey
    filePaneMetaSize(bestSlot) = sizeBytes
    filePaneMetaDate(bestSlot) = dateText
    filePaneMetaAttr(bestSlot) = attrBits
    filePaneMetaAge(bestSlot) = filePaneMetaClock

    RETURN FilePaneCaption(fileName, attrBits, paneW, sizeBytes, dateText)
END FUNCTION



FUNCTION AbsI(BYVAL n AS INTEGER) AS INTEGER
    IF n < 0 THEN RETURN -n
    RETURN n
END FUNCTION

FUNCTION ClampI(BYVAL n AS INTEGER, BYVAL lo AS INTEGER, BYVAL hi AS INTEGER) AS INTEGER
    IF n < lo THEN RETURN lo
    IF n > hi THEN RETURN hi
    RETURN n
END FUNCTION

' Central GUI loop throttle: stay responsive while work/input is pending,
' but keep the normal idle delay when the shell is quiet.
SUB GuiAdaptiveSleep(BYVAL activeNow AS INTEGER)
    IF activeNow <> 0 THEN
        SLEEP 1
    ELSE
        SLEEP 10
    END IF
END SUB

SUB Backlash16PaletteRgb(BYVAL colorIdx AS INTEGER, BYREF r AS INTEGER, BYREF g AS INTEGER, BYREF b AS INTEGER)
    SELECT CASE (colorIdx AND 15)
        CASE 0
            r = 0: g = 0: b = 0
        CASE 1
            r = 0: g = 0: b = 170
        CASE 2
            r = 0: g = 170: b = 0
        CASE 3
            r = 0: g = 170: b = 170
        CASE 4
            r = 170: g = 0: b = 0
        CASE 5
            r = 170: g = 0: b = 170
        CASE 6
            r = 170: g = 85: b = 0
        CASE 7
            r = 170: g = 170: b = 170
        CASE 8
            r = 85: g = 85: b = 85
        CASE 9
            r = 85: g = 85: b = 255
        CASE 10
            r = 85: g = 255: b = 85
        CASE 11
            r = 85: g = 255: b = 255
        CASE 12
            r = 255: g = 85: b = 85
        CASE 13
            r = 255: g = 0: b = 255
        CASE 14
            r = 255: g = 255: b = 85
        CASE ELSE
            r = 255: g = 255: b = 255
    END SELECT
END SUB

FUNCTION Backlash16ColorIndex(BYVAL r AS INTEGER, BYVAL g AS INTEGER, BYVAL b AS INTEGER) AS UINTEGER
    DIM maxc AS INTEGER
    DIM minc AS INTEGER
    DIM avg AS INTEGER
    DIM diff AS INTEGER
    DIM threshold AS INTEGER
    DIM idx AS INTEGER

    r = ClampI(r, 0, 255)
    g = ClampI(g, 0, 255)
    b = ClampI(b, 0, 255)

    IF r = 0 AND g = 0 AND b = 0 THEN RETURN 0
    IF r = 0 AND g = 0 AND b = 170 THEN RETURN 1
    IF r = 0 AND g = 170 AND b = 0 THEN RETURN 2
    IF r = 0 AND g = 170 AND b = 170 THEN RETURN 3
    IF r = 170 AND g = 0 AND b = 0 THEN RETURN 4
    IF r = 170 AND g = 0 AND b = 170 THEN RETURN 5
    IF r = 170 AND g = 85 AND b = 0 THEN RETURN 6
    IF r = 170 AND g = 170 AND b = 170 THEN RETURN 7
    IF r = 85 AND g = 85 AND b = 85 THEN RETURN 8
    IF r = 85 AND g = 85 AND b = 255 THEN RETURN 9
    IF r = 85 AND g = 255 AND b = 85 THEN RETURN 10
    IF r = 85 AND g = 255 AND b = 255 THEN RETURN 11
    IF r = 255 AND g = 85 AND b = 85 THEN RETURN 12
    IF r = 255 AND g = 0 AND b = 255 THEN RETURN 13
    IF r = 255 AND g = 255 AND b = 85 THEN RETURN 14
    IF r = 255 AND g = 255 AND b = 255 THEN RETURN 15

    maxc = r
    IF g > maxc THEN maxc = g
    IF b > maxc THEN maxc = b
    minc = r
    IF g < minc THEN minc = g
    IF b < minc THEN minc = b
    avg = (r + g + b) \ 3
    diff = maxc - minc

    IF diff < 32 THEN
        IF avg < 43 THEN RETURN 0
        IF avg < 128 THEN RETURN 8
        IF avg < 213 THEN RETURN 7
        RETURN 15
    END IF

    threshold = 96
    IF avg < 96 AND maxc < 192 THEN threshold = 85

    idx = 0
    IF b >= threshold THEN idx = idx OR 1
    IF g >= threshold THEN idx = idx OR 2
    IF r >= threshold THEN idx = idx OR 4

    IF idx = 0 THEN
        IF avg >= 85 THEN RETURN 8
        RETURN 0
    END IF

    IF maxc >= 192 OR avg >= 144 THEN RETURN idx + 8
    RETURN idx
END FUNCTION

FUNCTION Backlash256ColorIndex(BYVAL r AS INTEGER, BYVAL g AS INTEGER, BYVAL b AS INTEGER) AS UINTEGER
    DIM ri AS INTEGER
    DIM gi AS INTEGER
    DIM bi AS INTEGER
    DIM cubeR AS INTEGER
    DIM cubeG AS INTEGER
    DIM cubeB AS INTEGER
    DIM cubeIndex AS INTEGER
    DIM shade AS INTEGER
    DIM grayIndex AS INTEGER
    DIM grayVal AS INTEGER
    DIM cubeDist AS LONG
    DIM grayDist AS LONG
    DIM dr AS LONG
    DIM dg AS LONG
    DIM db AS LONG

    r = ClampI(r, 0, 255)
    g = ClampI(g, 0, 255)
    b = ClampI(b, 0, 255)

    IF r = 0 AND g = 0 AND b = 0 THEN RETURN 0
    IF r = 0 AND g = 0 AND b = 170 THEN RETURN 1
    IF r = 0 AND g = 170 AND b = 0 THEN RETURN 2
    IF r = 0 AND g = 170 AND b = 170 THEN RETURN 3
    IF r = 170 AND g = 0 AND b = 0 THEN RETURN 4
    IF r = 170 AND g = 0 AND b = 170 THEN RETURN 5
    IF r = 170 AND g = 85 AND b = 0 THEN RETURN 6
    IF r = 170 AND g = 170 AND b = 170 THEN RETURN 7
    IF r = 85 AND g = 85 AND b = 85 THEN RETURN 8
    IF r = 85 AND g = 85 AND b = 255 THEN RETURN 9
    IF r = 85 AND g = 255 AND b = 85 THEN RETURN 10
    IF r = 85 AND g = 255 AND b = 255 THEN RETURN 11
    IF r = 255 AND g = 85 AND b = 85 THEN RETURN 12
    IF r = 255 AND g = 0 AND b = 255 THEN RETURN 13
    IF r = 255 AND g = 255 AND b = 85 THEN RETURN 14
    IF r = 255 AND g = 255 AND b = 255 THEN RETURN 15

    ri = (r + 25) \ 51
    gi = (g + 25) \ 51
    bi = (b + 25) \ 51
    ri = ClampI(ri, 0, 5)
    gi = ClampI(gi, 0, 5)
    bi = ClampI(bi, 0, 5)

    cubeR = ri * 51
    cubeG = gi * 51
    cubeB = bi * 51
    cubeIndex = 16 + ri * 36 + gi * 6 + bi

    shade = (r + g + b) \ 3
    grayIndex = 232 + ((shade - 8 + 5) \ 10)
    grayIndex = ClampI(grayIndex, 232, 255)
    grayVal = 8 + (grayIndex - 232) * 10

    dr = CLNG(r - cubeR)
    dg = CLNG(g - cubeG)
    db = CLNG(b - cubeB)
    cubeDist = dr * dr + dg * dg + db * db

    dr = CLNG(r - grayVal)
    dg = CLNG(g - grayVal)
    db = CLNG(b - grayVal)
    grayDist = dr * dr + dg * dg + db * db

    IF grayDist < cubeDist THEN RETURN grayIndex
    RETURN cubeIndex
END FUNCTION

FUNCTION MakeCol(BYVAL r AS INTEGER, BYVAL g AS INTEGER, BYVAL b AS INTEGER) AS UINTEGER
    IF cfg.colorDepth = 8 THEN RETURN Backlash256ColorIndex(r, g, b)
    RETURN RGB(ClampI(r, 0, 255), ClampI(g, 0, 255), ClampI(b, 0, 255))
END FUNCTION


SUB ApplyLayoutAutoFit(BYVAL winIdx AS INTEGER)
    DIM i AS INTEGER
    DIM deltaW AS INTEGER
    DIM deltaH AS INTEGER
    DIM minW AS INTEGER
    DIM minH AS INTEGER

    IF uiDesignW < 1 THEN uiDesignW = uiWinW
    IF uiDesignH < 1 THEN uiDesignH = uiWinH

    deltaW = uiWinW - uiDesignW
    deltaH = uiWinH - uiDesignH

    FOR i = 1 TO uiCount
        IF uiElems(i).growW <> 0 THEN
            IF uiElems(i).baseW = 0 AND uiElems(i).w <> 0 THEN uiElems(i).baseW = uiElems(i).w
            minW = 16
            IF uiElems(i).kindId = UI_KIND_TEXTBOX THEN minW = 48
            IF uiElems(i).kindId = UI_KIND_LISTBOX THEN minW = 48
            uiElems(i).w = uiElems(i).baseW + deltaW
            IF uiElems(i).w < minW THEN uiElems(i).w = minW
        END IF

        IF uiElems(i).growH <> 0 THEN
            IF uiElems(i).baseH = 0 AND uiElems(i).h <> 0 THEN uiElems(i).baseH = uiElems(i).h
            minH = 16
            IF uiElems(i).kindId = UI_KIND_TEXTBOX THEN minH = 22
            IF uiElems(i).kindId = UI_KIND_LISTBOX THEN minH = 32
            uiElems(i).h = uiElems(i).baseH + deltaH
            IF uiElems(i).h < minH THEN uiElems(i).h = minH
        END IF

        IF uiElems(i).moveX <> 0 THEN
            uiElems(i).x = uiElems(i).baseX + deltaW
        END IF

        IF uiElems(i).moveY <> 0 THEN
            uiElems(i).y = uiElems(i).baseY + deltaH
        END IF
    NEXT

    IF winIdx >= LBOUND(layoutWindows) AND winIdx <= UBOUND(layoutWindows) THEN
        IF layoutWindows(winIdx).used <> 0 THEN
            FOR i = 1 TO uiCount
                layoutUiElems(winIdx, i) = uiElems(i)
            NEXT
            MarkLayoutWindowDirty winIdx
        END IF
    END IF
END SUB

' ---------------------------
' Taskbar clock popups
' ---------------------------
' Clock UI uses fixed taskbar rectangles. Left-click opens the calendar;
' right-click opens a direct DOS system-time adjustment popup.

FUNCTION ClockPad2(BYVAL valueNum AS INTEGER) AS STRING
    DIM outText AS STRING
    outText = LTRIM$(STR$(valueNum))
    IF LEN(outText) < 2 THEN outText = "0" + outText
    RETURN outText
END FUNCTION

SUB ClockReadSystemDate(BYREF yearVal AS INTEGER, BYREF monthVal AS INTEGER, BYREF dayVal AS INTEGER)
    DIM d AS STRING
    d = DATE$
    monthVal = VAL(LEFT$(d, 2))
    dayVal = VAL(MID$(d, 4, 2))
    yearVal = VAL(MID$(d, 7, 4))
    IF yearVal < 1980 THEN yearVal = 1980
    IF monthVal < 1 OR monthVal > 12 THEN monthVal = 1
    IF dayVal < 1 OR dayVal > 31 THEN dayVal = 1
END SUB

SUB ClockReadSystemTime(BYREF hourVal AS INTEGER, BYREF minuteVal AS INTEGER, BYREF secondVal AS INTEGER)
    DIM t AS STRING
    t = TIME$
    hourVal = VAL(LEFT$(t, 2))
    minuteVal = VAL(MID$(t, 4, 2))
    secondVal = VAL(MID$(t, 7, 2))
    IF hourVal < 0 OR hourVal > 23 THEN hourVal = 0
    IF minuteVal < 0 OR minuteVal > 59 THEN minuteVal = 0
    IF secondVal < 0 OR secondVal > 59 THEN secondVal = 0
END SUB

FUNCTION ClockMonthDays(BYVAL yearVal AS INTEGER, BYVAL monthVal AS INTEGER) AS INTEGER
    SELECT CASE monthVal
    CASE 1, 3, 5, 7, 8, 10, 12
        RETURN 31
    CASE 4, 6, 9, 11
        RETURN 30
    CASE 2
        IF (yearVal MOD 400) = 0 THEN RETURN 29
        IF (yearVal MOD 100) = 0 THEN RETURN 28
        IF (yearVal MOD 4) = 0 THEN RETURN 29
        RETURN 28
    END SELECT
    RETURN 30
END FUNCTION

FUNCTION ClockMonthName(BYVAL monthVal AS INTEGER) AS STRING
    SELECT CASE monthVal
    CASE 1: RETURN "January"
    CASE 2: RETURN "February"
    CASE 3: RETURN "March"
    CASE 4: RETURN "April"
    CASE 5: RETURN "May"
    CASE 6: RETURN "June"
    CASE 7: RETURN "July"
    CASE 8: RETURN "August"
    CASE 9: RETURN "September"
    CASE 10: RETURN "October"
    CASE 11: RETURN "November"
    CASE 12: RETURN "December"
    END SELECT
    RETURN "Month"
END FUNCTION

FUNCTION ClockDayOfWeek(BYVAL yearVal AS INTEGER, BYVAL monthVal AS INTEGER, BYVAL dayVal AS INTEGER) AS INTEGER
    DIM y AS INTEGER
    DIM m AS INTEGER
    DIM k AS INTEGER
    DIM j AS INTEGER
    DIM h AS INTEGER
    y = yearVal
    m = monthVal
    IF m < 3 THEN
        m = m + 12
        y = y - 1
    END IF
    k = y MOD 100
    j = y \ 100
    h = (dayVal + ((13 * (m + 1)) \ 5) + k + (k \ 4) + (j \ 4) + (5 * j)) MOD 7
    RETURN (h + 6) MOD 7
END FUNCTION

SUB LoadClockConfig()
    clockCalendarOpen = 0
    clockTimeOpen = 0
END SUB

FUNCTION TaskbarClockHitFromPoint(BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER) AS INTEGER
    TaskbarClockHitFromPoint = 0
    IF cfg.showTaskbar = 0 THEN EXIT FUNCTION
    IF cfg.showClock = 0 THEN EXIT FUNCTION
    IF TaskbarHitFromPoint(mouseX, mouseY) = 0 THEN EXIT FUNCTION
    IF InRect(mouseX, mouseY, TASKBAR_CLOCK_X1, TASKBAR_CLOCK_Y1, TASKBAR_CLOCK_X2, TASKBAR_CLOCK_Y2) THEN TaskbarClockHitFromPoint = -1
END FUNCTION

SUB ClockPopupRect(BYVAL popupW AS INTEGER, BYVAL popupH AS INTEGER, BYREF x1 AS INTEGER, BYREF y1 AS INTEGER, BYREF x2 AS INTEGER, BYREF y2 AS INTEGER)
    x2 = TASKBAR_CLOCK_X2
    x1 = x2 - popupW + 1
    IF x1 < 4 THEN x1 = 4
    x2 = x1 + popupW - 1
    IF x2 > SCR_W - 5 THEN
        x2 = SCR_W - 5
        x1 = x2 - popupW + 1
    END IF
    IF lay.taskbarEdge = TASKBAR_EDGE_TOP THEN
        y1 = TASKBAR_Y2 + 5
        y2 = y1 + popupH - 1
        IF y2 > SCR_H - 5 THEN
            y2 = SCR_H - 5
            y1 = y2 - popupH + 1
        END IF
    ELSE
        y2 = TASKBAR_Y1 - 5
        y1 = y2 - popupH + 1
        IF y1 < 4 THEN y1 = 4
    END IF
END SUB

SUB ClockClosePopups()
    IF clockCalendarOpen = 0 AND clockTimeOpen = 0 THEN EXIT SUB
    clockCalendarOpen = 0
    clockTimeOpen = 0
    InvalidateTaskbarCache
END SUB

SUB ClockSetPreviewFromSystem()
    DIM yearVal AS INTEGER
    DIM monthVal AS INTEGER
    DIM dayVal AS INTEGER
    DIM secondVal AS INTEGER
    ClockReadSystemDate yearVal, monthVal, dayVal
    ClockReadSystemTime clockSetHour, clockSetMinute, secondVal
    IF clockCalMonth < 1 OR clockCalMonth > 12 THEN clockCalMonth = monthVal
    IF clockCalYear < 1980 THEN clockCalYear = yearVal
END SUB

SUB ClockToggleCalendarPopup()
    DIM yearVal AS INTEGER
    DIM monthVal AS INTEGER
    DIM dayVal AS INTEGER
    IF clockCalendarOpen = 0 THEN
        ClockReadSystemDate yearVal, monthVal, dayVal
        clockCalMonth = monthVal
        clockCalYear = yearVal
        clockCalendarOpen = -1
        clockTimeOpen = 0
    ELSE
        clockCalendarOpen = 0
    END IF
    InvalidateTaskbarCache
END SUB

SUB ClockToggleTimePopup()
    IF clockTimeOpen = 0 THEN
        ClockSetPreviewFromSystem
        clockTimeOpen = -1
        clockCalendarOpen = 0
    ELSE
        clockTimeOpen = 0
    END IF
    InvalidateTaskbarCache
END SUB

FUNCTION ClockCalendarHitFromPoint(BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER) AS INTEGER
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER
    ClockCalendarHitFromPoint = 0
    IF clockCalendarOpen = 0 THEN EXIT FUNCTION
    ClockPopupRect CLOCK_CAL_POPUP_W, CLOCK_CAL_POPUP_H, x1, y1, x2, y2
    IF InRect(mouseX, mouseY, x1, y1, x2, y2) THEN ClockCalendarHitFromPoint = -1
END FUNCTION

FUNCTION ClockTimePopupHitFromPoint(BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER) AS INTEGER
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER
    ClockTimePopupHitFromPoint = 0
    IF clockTimeOpen = 0 THEN EXIT FUNCTION
    ClockPopupRect CLOCK_TIME_POPUP_W, CLOCK_TIME_POPUP_H, x1, y1, x2, y2
    IF InRect(mouseX, mouseY, x1, y1, x2, y2) THEN ClockTimePopupHitFromPoint = -1
END FUNCTION

FUNCTION ClockCalendarActionFromPoint(BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER) AS INTEGER
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER
    ClockCalendarActionFromPoint = 0
    IF ClockCalendarHitFromPoint(mouseX, mouseY) = 0 THEN EXIT FUNCTION
    ClockPopupRect CLOCK_CAL_POPUP_W, CLOCK_CAL_POPUP_H, x1, y1, x2, y2
    IF InRect(mouseX, mouseY, x1 + 10, y1 + 9, x1 + 32, y1 + 29) THEN RETURN 1
    IF InRect(mouseX, mouseY, x2 - 32, y1 + 9, x2 - 10, y1 + 29) THEN RETURN 2
    IF InRect(mouseX, mouseY, x2 - 57, y2 - 28, x2 - 10, y2 - 9) THEN RETURN 3
END FUNCTION

FUNCTION ClockTimePopupActionFromPoint(BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER) AS INTEGER
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER
    ClockTimePopupActionFromPoint = 0
    IF ClockTimePopupHitFromPoint(mouseX, mouseY) = 0 THEN EXIT FUNCTION
    ClockPopupRect CLOCK_TIME_POPUP_W, CLOCK_TIME_POPUP_H, x1, y1, x2, y2
    IF InRect(mouseX, mouseY, x1 + 28, y1 + 74, x1 + 59, y1 + 94) THEN RETURN 1
    IF InRect(mouseX, mouseY, x1 + 66, y1 + 74, x1 + 97, y1 + 94) THEN RETURN 2
    IF InRect(mouseX, mouseY, x1 + 126, y1 + 74, x1 + 157, y1 + 94) THEN RETURN 3
    IF InRect(mouseX, mouseY, x1 + 164, y1 + 74, x1 + 195, y1 + 94) THEN RETURN 4
    IF InRect(mouseX, mouseY, x1 + 48, y2 - 30, x1 + 107, y2 - 10) THEN RETURN 5
    IF InRect(mouseX, mouseY, x2 - 70, y2 - 30, x2 - 12, y2 - 10) THEN RETURN 6
END FUNCTION

SUB ClockApplyPreviewTime()
    DIM cmdText AS STRING
    DIM secondVal AS INTEGER
    IF clockSetHour < 0 THEN clockSetHour = 0
    IF clockSetHour > 23 THEN clockSetHour = 23
    IF clockSetMinute < 0 THEN clockSetMinute = 0
    IF clockSetMinute > 59 THEN clockSetMinute = 59
    cmdText = "TIME " + ClockPad2(clockSetHour) + ":" + ClockPad2(clockSetMinute) + ":00"
    SHELL cmdText
    ResumeGuiAfterShell
    ResetScreensaverIdle
    ClockReadSystemTime clockSetHour, clockSetMinute, secondVal
    taskbarClockLastText = ""
    taskbarClockLastCheck = 0
    InvalidateTaskbarCache
    InvalidateDesktopCache
    InvalidateStartMenuBackBuffer
    InvalidateContextOverlayBackBuffer
END SUB

SUB ClockHandleCalendarAction(BYVAL actionNum AS INTEGER)
    SELECT CASE actionNum
    CASE 1
        clockCalMonth = clockCalMonth - 1
        IF clockCalMonth < 1 THEN
            clockCalMonth = 12
            clockCalYear = clockCalYear - 1
            IF clockCalYear < 1980 THEN clockCalYear = 1980
        END IF
    CASE 2
        clockCalMonth = clockCalMonth + 1
        IF clockCalMonth > 12 THEN
            clockCalMonth = 1
            clockCalYear = clockCalYear + 1
        END IF
    CASE 3
        clockCalendarOpen = 0
    END SELECT
    InvalidateTaskbarCache
END SUB

SUB ClockHandleTimeAction(BYVAL actionNum AS INTEGER)
    SELECT CASE actionNum
    CASE 1
        clockSetHour = clockSetHour - 1
        IF clockSetHour < 0 THEN clockSetHour = 23
    CASE 2
        clockSetHour = clockSetHour + 1
        IF clockSetHour > 23 THEN clockSetHour = 0
    CASE 3
        clockSetMinute = clockSetMinute - 1
        IF clockSetMinute < 0 THEN clockSetMinute = 59
    CASE 4
        clockSetMinute = clockSetMinute + 1
        IF clockSetMinute > 59 THEN clockSetMinute = 0
    CASE 5
        ClockApplyPreviewTime
    CASE 6
        clockTimeOpen = 0
    END SELECT
    InvalidateTaskbarCache
END SUB

FUNCTION ClockMousePrimaryAction(BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER) AS INTEGER
    ClockMousePrimaryAction = 0
    IF TaskbarClockHitFromPoint(mouseX, mouseY) <> 0 THEN
        SoundCloseVolumePopup
        ClockToggleCalendarPopup
        ClockMousePrimaryAction = -1
        EXIT FUNCTION
    END IF
    IF ClockCalendarHitFromPoint(mouseX, mouseY) <> 0 THEN
        ClockHandleCalendarAction ClockCalendarActionFromPoint(mouseX, mouseY)
        ClockMousePrimaryAction = -1
        EXIT FUNCTION
    END IF
    IF ClockTimePopupHitFromPoint(mouseX, mouseY) <> 0 THEN
        ClockHandleTimeAction ClockTimePopupActionFromPoint(mouseX, mouseY)
        ClockMousePrimaryAction = -1
        EXIT FUNCTION
    END IF
    IF clockCalendarOpen <> 0 OR clockTimeOpen <> 0 THEN
        ClockClosePopups
        ClockMousePrimaryAction = -1
    END IF
END FUNCTION

FUNCTION ClockMouseRightAction(BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER) AS INTEGER
    ClockMouseRightAction = 0
    IF TaskbarClockHitFromPoint(mouseX, mouseY) <> 0 THEN
        SoundCloseVolumePopup
        ClockToggleTimePopup
        ClockMouseRightAction = -1
        EXIT FUNCTION
    END IF
    IF ClockCalendarHitFromPoint(mouseX, mouseY) <> 0 OR ClockTimePopupHitFromPoint(mouseX, mouseY) <> 0 THEN
        ClockMouseRightAction = -1
        EXIT FUNCTION
    END IF
    IF clockCalendarOpen <> 0 OR clockTimeOpen <> 0 THEN
        ClockClosePopups
        ClockMouseRightAction = -1
    END IF
END FUNCTION

SUB DrawClockCalendarPopup()
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER
    DIM titleText AS STRING
    DIM yearVal AS INTEGER
    DIM monthVal AS INTEGER
    DIM dayVal AS INTEGER
    DIM firstDow AS INTEGER
    DIM daysInMonth AS INTEGER
    DIM dayNum AS INTEGER
    DIM rowNum AS INTEGER
    DIM colNum AS INTEGER
    DIM cellX AS INTEGER
    DIM cellY AS INTEGER
    DIM drawToday AS INTEGER
    DIM titleX AS INTEGER
    DIM dowText AS STRING
    DIM dayText AS STRING
    IF clockCalendarOpen = 0 THEN EXIT SUB
    ClockPopupRect CLOCK_CAL_POPUP_W, CLOCK_CAL_POPUP_H, x1, y1, x2, y2
    DrawBevelBox x1, y1, x2, y2, 0
    LINE (x1 + 3, y1 + 3)-(x2 - 3, y1 + 34), COL_BUTTON, BF
    DrawButtonBevelBox x1 + 10, y1 + 9, x1 + 32, y1 + 29, 0
    DRAW STRING (x1 + 18, y1 + 15), "<", COL_TEXT
    DrawButtonBevelBox x2 - 32, y1 + 9, x2 - 10, y1 + 29, 0
    DRAW STRING (x2 - 24, y1 + 15), ">", COL_TEXT
    titleText = ClockMonthName(clockCalMonth) + " " + LTRIM$(STR$(clockCalYear))
    titleX = x1 + ((CLOCK_CAL_POPUP_W - LEN(titleText) * 8) \ 2)
    IF titleX < x1 + 40 THEN titleX = x1 + 40
    DRAW STRING (titleX, y1 + 16), titleText, COL_TEXT
    dowText = "Sun Mon Tue Wed Thu Fri Sat"
    DRAW STRING (x1 + 17, y1 + 44), dowText, COL_TEXT
    LINE (x1 + 12, y1 + 56)-(x2 - 12, y1 + 56), COL_BEVEL_LO
    ClockReadSystemDate yearVal, monthVal, dayVal
    firstDow = ClockDayOfWeek(clockCalYear, clockCalMonth, 1)
    daysInMonth = ClockMonthDays(clockCalYear, clockCalMonth)
    FOR dayNum = 1 TO daysInMonth
        rowNum = (firstDow + dayNum - 1) \ 7
        colNum = (firstDow + dayNum - 1) MOD 7
        cellX = x1 + 18 + (colNum * 31)
        cellY = y1 + 65 + (rowNum * 20)
        drawToday = 0
        IF yearVal = clockCalYear AND monthVal = clockCalMonth AND dayVal = dayNum THEN drawToday = -1
        dayText = LTRIM$(STR$(dayNum))
        IF drawToday <> 0 THEN
            LINE (cellX - 3, cellY - 3)-(cellX + 20, cellY + 12), COL_SELECT, BF
            DRAW STRING (cellX + (16 - LEN(dayText) * 8), cellY), dayText, COL_TEXT_INV
        ELSE
            DRAW STRING (cellX + (16 - LEN(dayText) * 8), cellY), dayText, COL_TEXT
        END IF
    NEXT
    DrawButtonBevelBox x2 - 57, y2 - 28, x2 - 10, y2 - 9, 0
    DRAW STRING (x2 - 49, y2 - 22), "Close", COL_TEXT
END SUB

SUB DrawClockTimePopup()
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER
    DIM timeText AS STRING
    DIM tx AS INTEGER
    IF clockTimeOpen = 0 THEN EXIT SUB
    ClockPopupRect CLOCK_TIME_POPUP_W, CLOCK_TIME_POPUP_H, x1, y1, x2, y2
