FUNCTION ShowGuiTextInputBox(BYVAL titleText AS STRING, BYVAL msgText AS STRING, BYVAL defaultText AS STRING) AS STRING
    DIM mx AS INTEGER
    DIM my AS INTEGER
    DIM mw AS INTEGER
    DIM mb AS INTEGER
    DIM primaryNow AS INTEGER
    DIM prevPrimary AS INTEGER
    DIM okPressed AS INTEGER
    DIM cancelPressed AS INTEGER
    DIM closePressed AS INTEGER
    DIM mouseOk AS INTEGER
    DIM oldMx AS INTEGER
    DIM oldMy AS INTEGER
    DIM k AS STRING
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER
    DIM okX1 AS INTEGER
    DIM okY1 AS INTEGER
    DIM okX2 AS INTEGER
    DIM okY2 AS INTEGER
    DIM cancelX1 AS INTEGER
    DIM cancelY1 AS INTEGER
    DIM cancelX2 AS INTEGER
    DIM cancelY2 AS INTEGER
    DIM inputText AS STRING
    DIM asciiVal AS INTEGER
    DIM redrawBox AS INTEGER

    ShowGuiTextInputBox = CHR$(1)
    inputText = LEFT$(TRIM$(defaultText), 12)

    DO
        k = INKEY$
    LOOP WHILE k <> ""

    startMenuOpen = 0
    launchCtxOpen = 0
    FOR mw = 0 TO 8
        menuOpenItem(mw) = 0
    NEXT

    GuiMessageBounds x1, y1, x2, y2
    IF WORK_H >= 160 THEN
        y1 = WORK_Y + ((WORK_H - 136) \ 2)
        IF y1 < WORK_Y + 4 THEN y1 = WORK_Y + 4
        y2 = y1 + 136
    END IF

    okX1 = x1 + ((x2 - x1) \ 2) - 78
    okY1 = y2 - 34
    okX2 = okX1 + 70
    okY2 = okY1 + 22
    cancelX1 = x1 + ((x2 - x1) \ 2) + 8
    cancelY1 = okY1
    cancelX2 = cancelX1 + 70
    cancelY2 = cancelY1 + 22

    mouseOk = (GETMOUSE(mx, my, mw, mb) = 0)
    IF mouseOk THEN
        mx = ClampI(mx, 0, SCR_W - 1)
        my = ClampI(my, 0, SCR_H - 1)
    ELSE
        mx = SCR_W \ 2
        my = WORK_Y + (WORK_H \ 2)
        mb = 0
    END IF

    okPressed = 0
    cancelPressed = 0
    closePressed = 0
    oldMx = mx
    oldMy = my

    SCREENLOCK
    cursorBackValid = 0
    DrawDesktop
    IF layoutWindowCount > 0 THEN
        DrawAllLayoutWindows
    ELSE
        DrawWindows
    END IF
    DrawTaskbar 0
    DrawGuiTextInputBox titleText, msgText, inputText, x1, y1, x2, y2, okPressed, cancelPressed, closePressed
    SaveCursorBackBuffer mx, my
    DrawCursor mx, my
    SCREENUNLOCK

    DO WHILE IsPrimaryButtonPressed(mb) <> 0
        mouseOk = (GETMOUSE(mx, my, mw, mb) = 0)
        IF mouseOk THEN
            mx = ClampI(mx, 0, SCR_W - 1)
            my = ClampI(my, 0, SCR_H - 1)
        ELSE
            mb = 0
        END IF
        IF mx <> oldMx OR my <> oldMy THEN
            DrawCursorOnly mx, my
            oldMx = mx
            oldMy = my
        END IF
        SLEEP 10
    LOOP

    DO
        k = INKEY$
    LOOP WHILE k <> ""

    prevPrimary = 0

    DO
        mouseOk = (GETMOUSE(mx, my, mw, mb) = 0)
        IF mouseOk THEN
            mx = ClampI(mx, 0, SCR_W - 1)
            my = ClampI(my, 0, SCR_H - 1)
        ELSE
            mx = oldMx
            my = oldMy
            mb = 0
        END IF

        primaryNow = IsPrimaryButtonPressed(mb)
        redrawBox = 0

        IF primaryNow <> 0 AND prevPrimary = 0 THEN
            okPressed = InRect(mx, my, okX1, okY1, okX2, okY2)
            cancelPressed = InRect(mx, my, cancelX1, cancelY1, cancelX2, cancelY2)
            closePressed = InRect(mx, my, x2 - 18, y1 + 3, x2 - 4, y1 + 17)
            redrawBox = -1
        END IF

        IF primaryNow = 0 AND prevPrimary <> 0 THEN
            IF okPressed <> 0 THEN
                ShowGuiTextInputBox = inputText
                EXIT DO
            END IF
            IF cancelPressed <> 0 OR closePressed <> 0 THEN
                ShowGuiTextInputBox = CHR$(1)
                EXIT DO
            END IF
            IF okPressed <> 0 OR cancelPressed <> 0 OR closePressed <> 0 THEN redrawBox = -1
            okPressed = 0
            cancelPressed = 0
            closePressed = 0
        END IF

        k = INKEY$
        IF k <> "" THEN
            IF LEN(k) = 1 THEN
                asciiVal = ASC(k)
                SELECT CASE asciiVal
                CASE 13
                    ShowGuiTextInputBox = inputText
                    EXIT DO
                CASE 27
                    ShowGuiTextInputBox = CHR$(1)
                    EXIT DO
                CASE 8
                    IF LEN(inputText) > 0 THEN
                        inputText = LEFT$(inputText, LEN(inputText) - 1)
                        redrawBox = -1
                    END IF
                CASE 32 TO 126
                    IF LEN(inputText) < 12 THEN
                        inputText = inputText + k
                        redrawBox = -1
                    END IF
                END SELECT
            END IF
        END IF

        IF redrawBox <> 0 THEN
            SCREENLOCK
            RestoreCursorBackBuffer
            DrawGuiTextInputBox titleText, msgText, inputText, x1, y1, x2, y2, okPressed, cancelPressed, closePressed
            SaveCursorBackBuffer mx, my
            DrawCursor mx, my
            SCREENUNLOCK
        ELSEIF mx <> oldMx OR my <> oldMy THEN
            DrawCursorOnly mx, my
        END IF

        oldMx = mx
        oldMy = my
        prevPrimary = primaryNow
        SLEEP 10
    LOOP

    DO
        mouseOk = (GETMOUSE(mx, my, mw, mb) = 0)
        IF mouseOk = 0 THEN EXIT DO
        IF IsPrimaryButtonPressed(mb) = 0 THEN EXIT DO
        SLEEP 10
    LOOP

    SCREENLOCK
    cursorBackValid = 0
    DrawDesktop
    IF layoutWindowCount > 0 THEN
        DrawAllLayoutWindows
    ELSE
        DrawWindows
    END IF
    DrawTaskbar 0
    SaveCursorBackBuffer mx, my
    DrawCursor mx, my
    SCREENUNLOCK
END FUNCTION

' ---------------------------
' Layout page switching, tab state, and textbox focus helpers
' ---------------------------

FUNCTION LayoutCurrentColorDepth() AS INTEGER
    IF cfg.colorDepth = 4 THEN RETURN 4
    IF cfg.colorDepth = 8 THEN RETURN 8
    RETURN 16
END FUNCTION

FUNCTION LayoutSelectedDepthValue() AS INTEGER
    DIM i AS INTEGER
    DIM tabNumber AS INTEGER

    tabNumber = 0
    FOR i = 1 TO uiCount
        IF uiElems(i).kindId = UI_KIND_TAB THEN
            tabNumber = tabNumber + 1
            IF tabNumber = uiSelectedTab THEN
                IF VALINT(uiElems(i).bindValue) <> 0 THEN RETURN VALINT(uiElems(i).bindValue)
            END IF
        END IF
    NEXT

    RETURN LayoutCurrentColorDepth()
END FUNCTION

FUNCTION LayoutDepthFolderName(BYVAL depthVal AS INTEGER) AS STRING
    SELECT CASE depthVal
    CASE 4
        RETURN "16"
    CASE 8
        RETURN "256"
    CASE ELSE
        RETURN "HIGH"
    END SELECT
END FUNCTION

' Expands layout tokens such as color-depth folders before a control uses a path or value.
FUNCTION ExpandLayoutDynamicText(BYVAL srcText AS STRING) AS STRING
    DIM resultText AS STRING
    DIM depthText AS STRING
    DIM folderText AS STRING
    DIM iconDepthFolderText AS STRING
    DIM assetDepthFolderText AS STRING
    DIM p AS INTEGER

    resultText = NormalizePath(TRIM$(srcText))
    IF resultText = "" THEN RETURN ""
    IF INSTR(resultText, "%") = 0 THEN RETURN resultText

    depthText = LTRIM$(STR$(LayoutSelectedDepthValue()))
    folderText = LayoutDepthFolderName(LayoutSelectedDepthValue())
    IF LayoutSelectedDepthValue() = 4 THEN
        iconDepthFolderText = "16COLOR\"
    ELSEIF LayoutSelectedDepthValue() = 8 THEN
        iconDepthFolderText = "256COLOR\"
    ELSE
        iconDepthFolderText = ""
    END IF
    assetDepthFolderText = iconDepthFolderText

    p = INSTR(UCASE$(resultText), "%COLORDEPTH%")
    DO WHILE p > 0
        resultText = LEFT$(resultText, p - 1) + depthText + MID$(resultText, p + 12)
        p = INSTR(UCASE$(resultText), "%COLORDEPTH%")
    LOOP

    p = INSTR(UCASE$(resultText), "%DEPTHFOLDER%")
    DO WHILE p > 0
        resultText = LEFT$(resultText, p - 1) + folderText + MID$(resultText, p + 13)
        p = INSTR(UCASE$(resultText), "%DEPTHFOLDER%")
    LOOP

    p = INSTR(UCASE$(resultText), "%ICONDEPTHFOLDER%")
    DO WHILE p > 0
        resultText = LEFT$(resultText, p - 1) + iconDepthFolderText + MID$(resultText, p + LEN("%ICONDEPTHFOLDER%"))
        p = INSTR(UCASE$(resultText), "%ICONDEPTHFOLDER%")
    LOOP

    p = INSTR(UCASE$(resultText), "%ASSETDEPTHFOLDER%")
    DO WHILE p > 0
        resultText = LEFT$(resultText, p - 1) + assetDepthFolderText + MID$(resultText, p + LEN("%ASSETDEPTHFOLDER%"))
        p = INSTR(UCASE$(resultText), "%ASSETDEPTHFOLDER%")
    LOOP

    p = INSTR(UCASE$(resultText), "%DEPTH%")
    DO WHILE p > 0
        resultText = LEFT$(resultText, p - 1) + depthText + MID$(resultText, p + 7)
        p = INSTR(UCASE$(resultText), "%DEPTH%")
    LOOP

    RETURN resultText
END FUNCTION

FUNCTION LayoutHasPageFiles() AS INTEGER
    DIM i AS INTEGER
    DIM keyName AS STRING

    IF TRIM$(uiLayoutAppPath) = "" THEN RETURN 0
    FOR i = 1 TO 12
        keyName = "PAGE_FILE_" + LTRIM$(STR$(i))
        IF TRIM$(AppCfgValue(uiLayoutAppPath, keyName, "")) <> "" THEN RETURN -1
    NEXT
    RETURN 0
END FUNCTION

SUB SelectTabFromBoundConfig()
    DIM i AS INTEGER
    DIM tabNumber AS INTEGER
    DIM bindFile AS STRING
    DIM bindSection AS STRING
    DIM bindKey AS STRING
    DIM bindValue AS STRING
    DIM curValue AS STRING

    tabNumber = 0
    FOR i = 1 TO uiCount
        IF uiElems(i).kindId = UI_KIND_TAB THEN
            tabNumber = tabNumber + 1
            bindFile = ExpandLayoutDynamicText(uiElems(i).bindFile)
            bindSection = ExpandLayoutDynamicText(uiElems(i).bindSection)
            bindKey = ExpandLayoutDynamicText(uiElems(i).bindKey)
            bindValue = TRIM$(uiElems(i).bindValue)
            IF bindFile <> "" AND bindKey <> "" AND bindValue <> "" THEN
                curValue = ReadCfgValueInSection(bindFile, bindSection, bindKey, "")
                IF UCASE$(TRIM$(curValue)) = UCASE$(bindValue) THEN
                    uiSelectedTab = tabNumber
                    EXIT SUB
                END IF
            END IF
        END IF
    NEXT
END SUB

SUB RefreshLayoutPageControls()
    DIM i AS INTEGER

    LoadSelectedLayoutPageControls
    InitBoundControlsFromConfig

    ' RemoveLoadedLayoutPageControls already clears slots that were dropped.
    ' Reset only the controls that exist after the selected page has been appended.
    FOR i = 1 TO uiCount
        IF uiElems(i).kindId = UI_KIND_TEXTBOX THEN
            ResetEditorControlRuntimeState i, uiElems(i).text
            uiElems(i).text = uiEdit(i).txt
        ELSE
            ResetEditorControlRuntimeState i, ""
        END IF
    NEXT

    uiFocusIndex = 0
    uiCaretPos = 0
    uiScrollY = 0
    uiScrollX = 0
END SUB

FUNCTION LayoutTabHasConfigBinding(BYVAL elemIdx AS INTEGER, BYVAL winIdx AS INTEGER) AS INTEGER
    LayoutTabHasConfigBinding = 0
    IF elemIdx < 1 OR elemIdx > uiCount THEN EXIT FUNCTION
    IF uiElems(elemIdx).kindKey <> "TAB" THEN EXIT FUNCTION
    IF TRIM$(uiElems(elemIdx).bindFile) = "" THEN EXIT FUNCTION
    IF TRIM$(uiElems(elemIdx).bindKey) = "" THEN EXIT FUNCTION
    IF TRIM$(uiElems(elemIdx).bindValue) = "" THEN EXIT FUNCTION
    LayoutTabHasConfigBinding = -1
END FUNCTION

FUNCTION FocusNextTextboxInActivePage(BYVAL direction AS INTEGER) AS INTEGER
    DIM i AS INTEGER
    DIM currentIdx AS INTEGER
    DIM firstIdx AS INTEGER
    DIM lastIdx AS INTEGER
    DIM nextIdx AS INTEGER
    DIM activePage AS STRING
    DIM elemPage AS STRING

    FocusNextTextboxInActivePage = 0
    IF direction < 0 THEN direction = -1 ELSE direction = 1

    currentIdx = uiFocusIndex
    IF currentIdx < 1 OR currentIdx > uiCount THEN EXIT FUNCTION
    IF uiElems(currentIdx).kindId <> UI_KIND_TEXTBOX THEN EXIT FUNCTION
    IF uiElems(currentIdx).noEdit <> 0 THEN EXIT FUNCTION

    GetLayoutActivePage activePage
    activePage = UCASE$(TRIM$(activePage))

    firstIdx = 0
    lastIdx = 0
    nextIdx = 0

    FOR i = 1 TO uiCount
        IF uiElems(i).kindId = UI_KIND_TEXTBOX THEN
            IF uiElems(i).noEdit = 0 THEN
                elemPage = uiElems(i).pageKey
                IF activePage = "" OR elemPage = "" OR elemPage = activePage THEN
                    IF firstIdx = 0 THEN firstIdx = i
                    lastIdx = i
                    IF direction > 0 THEN
                        IF i > currentIdx AND nextIdx = 0 THEN nextIdx = i
                    ELSE
                        IF i < currentIdx THEN nextIdx = i
                    END IF
                END IF
            END IF
        END IF
    NEXT

    IF nextIdx = 0 THEN
        IF direction > 0 THEN nextIdx = firstIdx ELSE nextIdx = lastIdx
    END IF
    IF nextIdx < 1 OR nextIdx > uiCount THEN EXIT FUNCTION

    uiFocusIndex = nextIdx
    uiCaretPos = LEN(uiElems(nextIdx).text)
    uiCaretVisible = -1
    uiLastCaretBlink = TIMER

    Ed_LoadTxt uiEdit(nextIdx), uiElems(nextIdx).text, uiCaretPos
    uiEdit(nextIdx).curPos = uiCaretPos
    Ed_SelClr uiEdit(nextIdx)

    uiSelAnchor(nextIdx) = uiCaretPos
    uiWordSelMode(nextIdx) = 0
    uiWordSelA(nextIdx) = 0
    uiWordSelB(nextIdx) = 0
    uiLineSelMode(nextIdx) = 0
    uiLineSelA(nextIdx) = 0
    uiLineSelB(nextIdx) = 0

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
            SyncLayoutWindowElementOnly activeLayoutWindow, nextIdx
        END IF
    END IF

    FocusNextTextboxInActivePage = -1
END FUNCTION

FUNCTION ActiveEditableTextboxFocused() AS INTEGER
    ActiveEditableTextboxFocused = 0

    IF activeLayoutWindow < LBOUND(layoutWindows) OR activeLayoutWindow > UBOUND(layoutWindows) THEN EXIT FUNCTION
    IF layoutWindows(activeLayoutWindow).used = 0 THEN EXIT FUNCTION
    IF uiFocusIndex < 1 OR uiFocusIndex > uiCount THEN EXIT FUNCTION
    IF uiElems(uiFocusIndex).kindId <> UI_KIND_TEXTBOX THEN EXIT FUNCTION
    IF uiElems(uiFocusIndex).noEdit <> 0 THEN EXIT FUNCTION

    ActiveEditableTextboxFocused = -1
END FUNCTION

