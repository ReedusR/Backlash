    RETURN outText
END FUNCTION

SUB SoundWriteStatus()
    DIM f AS INTEGER

    IF TRIM$(soundStatusFile) = "" THEN EXIT SUB
    f = FREEFILE
    IF OPEN(soundStatusFile FOR OUTPUT AS #f) <> 0 THEN EXIT SUB
    PRINT #f, SoundStatusText();
    CLOSE #f
END SUB

FUNCTION SoundCfgEnabled(BYVAL keyName AS STRING, BYVAL defaultEnabled AS INTEGER) AS INTEGER
    DIM defaultText AS STRING
    DIM valueText AS STRING

    IF defaultEnabled <> 0 THEN
        defaultText = "1"
    ELSE
        defaultText = "0"
    END IF

    valueText = UCASE$(TRIM$(ReadCfgValue(PATH_SOUNDCFG, keyName, defaultText)))
    IF valueText = "0" OR valueText = "NO" OR valueText = "FALSE" OR valueText = "OFF" THEN RETURN 0
    RETURN -1
END FUNCTION

FUNCTION SoundCfgInt(BYVAL keyName AS STRING, BYVAL defaultValue AS INTEGER, BYVAL minValue AS INTEGER, BYVAL maxValue AS INTEGER) AS INTEGER
    DIM valueNum AS INTEGER

    valueNum = VALINT(ReadCfgValue(PATH_SOUNDCFG, keyName, LTRIM$(STR$(defaultValue))))
    IF valueNum < minValue THEN valueNum = minValue
    IF valueNum > maxValue THEN valueNum = maxValue
    RETURN valueNum
END FUNCTION

FUNCTION SoundScaleSampleValue(BYVAL sampleValue AS INTEGER) AS INTEGER
    IF sampleValue < 0 THEN sampleValue = 0
    IF sampleValue > 255 THEN sampleValue = 255

    IF soundVolumePercent <= 0 THEN RETURN 128
    IF soundVolumePercent >= 100 THEN RETURN sampleValue

    sampleValue = 128 + (((sampleValue - 128) * soundVolumePercent) \ 100)
    IF sampleValue < 0 THEN sampleValue = 0
    IF sampleValue > 255 THEN sampleValue = 255
    RETURN sampleValue
END FUNCTION

FUNCTION SoundApplyVolumeToSampleText(BYREF sampleText AS STRING) AS STRING
    DIM sampleLen AS INTEGER
    DIM i AS INTEGER
    DIM outText AS STRING

    sampleLen = LEN(sampleText)
    IF sampleLen < 1 THEN RETURN ""
    IF soundVolumePercent >= 100 THEN RETURN sampleText
    IF soundVolumePercent <= 0 THEN RETURN STRING$(sampleLen, CHR$(128))

    outText = SPACE$(sampleLen)
    FOR i = 1 TO sampleLen
        MID$(outText, i, 1) = CHR$(SoundScaleSampleValue(ASC(MID$(sampleText, i, 1))))
    NEXT
    RETURN outText
END FUNCTION

SUB SoundSetVolumePercent(BYVAL newVolumePercent AS INTEGER)
    IF newVolumePercent < 0 THEN newVolumePercent = 0
    IF newVolumePercent > 100 THEN newVolumePercent = 100
    IF newVolumePercent = soundVolumePercent THEN EXIT SUB

    soundVolumePercent = newVolumePercent
    SetCfgValueInSection PATH_SOUNDCFG, "", "volume", LTRIM$(STR$(soundVolumePercent))
    InvalidateTaskbarCache
END SUB

SUB SoundOpenTaskbarSettings()
    IF TRIM$(soundSettingsApp) = "" THEN EXIT SUB
    ExecuteLaunchTarget soundSettingsApp
END SUB

FUNCTION SoundPortFromHexText(BYVAL portText AS STRING, BYVAL defaultPort AS INTEGER) AS INTEGER
    DIM i AS INTEGER
    DIM ch AS INTEGER
    DIM digit AS INTEGER
    DIM valueNum AS INTEGER

    portText = UCASE$(TRIM$(portText))
    IF LEFT$(portText, 2) = "&H" THEN portText = MID$(portText, 3)
    IF LEFT$(portText, 2) = "0X" THEN portText = MID$(portText, 3)
    IF RIGHT$(portText, 1) = "H" THEN portText = LEFT$(portText, LEN(portText) - 1)
    IF portText = "" THEN RETURN defaultPort

    valueNum = 0
    FOR i = 1 TO LEN(portText)
        ch = ASC(MID$(portText, i, 1))
        IF ch >= ASC("0") AND ch <= ASC("9") THEN
            digit = ch - ASC("0")
        ELSEIF ch >= ASC("A") AND ch <= ASC("F") THEN
            digit = ch - ASC("A") + 10
        ELSE
            RETURN defaultPort
        END IF
        valueNum = valueNum * 16 + digit
        IF valueNum < 0 OR valueNum > &HFFFF THEN RETURN defaultPort
    NEXT

    RETURN valueNum
END FUNCTION

SUB SoundIoWait(BYVAL waitLoops AS INTEGER)
    DIM i AS INTEGER
    DIM dummyValue AS INTEGER

    IF waitLoops < 1 THEN EXIT SUB
    IF soundAdlibBase <= 0 THEN EXIT SUB
    FOR i = 1 TO waitLoops
        dummyValue = INP(soundAdlibBase)
    NEXT
END SUB

SUB SoundAdlibWriteReg(BYVAL regNum AS INTEGER, BYVAL valueNum AS INTEGER)
    IF soundAdlibBase <= 0 THEN EXIT SUB
    OUT soundAdlibBase, (regNum AND &HFF)
    SoundIoWait 6
    OUT soundAdlibBase + 1, (valueNum AND &HFF)
    SoundIoWait 35
END SUB

FUNCTION SoundAdlibDetect() AS INTEGER
    DIM statusBefore AS INTEGER
    DIM statusAfter AS INTEGER

    SoundAdlibDetect = 0
    IF soundAdlibDetectEnabled = 0 THEN EXIT FUNCTION
    IF soundAdlibBase <= 0 THEN EXIT FUNCTION

    SoundAdlibWriteReg &H04, &H60
    SoundAdlibWriteReg &H04, &H80
    statusBefore = INP(soundAdlibBase)

    SoundAdlibWriteReg &H02, &HFF
    SoundAdlibWriteReg &H04, &H21
    SLEEP 1
    statusAfter = INP(soundAdlibBase)

    SoundAdlibWriteReg &H04, &H60
    SoundAdlibWriteReg &H04, &H80

    IF (statusBefore AND &HE0) = 0 AND (statusAfter AND &HE0) = &HC0 THEN SoundAdlibDetect = -1
END FUNCTION

FUNCTION SoundAdlibCalcTone(BYVAL freqHz AS INTEGER, BYREF blockNum AS INTEGER, BYREF fnum AS INTEGER) AS INTEGER
    DIM testBlock AS INTEGER
    DIM calcFnum AS INTEGER
    DIM calcValue AS DOUBLE

    SoundAdlibCalcTone = 0
    blockNum = 0
    fnum = 0

    IF freqHz < 37 THEN freqHz = 37
    IF freqHz > 6200 THEN freqHz = 6200

    FOR testBlock = 1 TO 7
        calcValue = (CDbl(freqHz) * (2.0 ^ (20 - testBlock))) / 49716.0
        calcFnum = CINT(calcValue)
        IF calcFnum >= 1 AND calcFnum <= 1023 THEN
            blockNum = testBlock
            fnum = calcFnum
            SoundAdlibCalcTone = -1
            EXIT FUNCTION
        END IF
    NEXT

    blockNum = 7
    fnum = 1023
    SoundAdlibCalcTone = -1
END FUNCTION

SUB SoundAdlibStop()
    IF soundAdlibBase <= 0 THEN EXIT SUB
    IF soundAdlibDetected = 0 THEN EXIT SUB

    SoundAdlibWriteReg &HB0, &H00
    SoundAdlibWriteReg &HA0, &H00
END SUB

FUNCTION SoundAdlibStartTone(BYVAL freqHz AS INTEGER, BYVAL durationMs AS INTEGER) AS INTEGER
    DIM blockNum AS INTEGER
    DIM fnum AS INTEGER
    DIM keyByte AS INTEGER

    SoundAdlibStartTone = 0
    IF soundAdlibDetected = 0 THEN EXIT FUNCTION
    IF soundAdlibBase <= 0 THEN EXIT FUNCTION
    IF SoundAdlibCalcTone(freqHz, blockNum, fnum) = 0 THEN EXIT FUNCTION

    SoundAdlibStop

    ' Channel 0, two-operator tone. Operator offsets are 0 and 3.
    SoundAdlibWriteReg &H01, &H20
    SoundAdlibWriteReg &H20, &H01
    SoundAdlibWriteReg &H23, &H01
    SoundAdlibWriteReg &H40, &H3F
    SoundAdlibWriteReg &H43, &H00
    SoundAdlibWriteReg &H60, &HF0
    SoundAdlibWriteReg &H63, &HF0
    SoundAdlibWriteReg &H80, &H77
    SoundAdlibWriteReg &H83, &H77
    SoundAdlibWriteReg &HC0, &H00
    SoundAdlibWriteReg &HA0, (fnum AND &HFF)

    keyByte = &H20 OR ((blockNum AND 7) SHL 2) OR ((fnum SHR 8) AND 3)
    SoundAdlibWriteReg &HB0, keyByte

    soundActive = -1
    soundStartTime = TIMER
    soundDurationSeconds = CDbl(durationMs) / 1000.0
    SoundAdlibStartTone = -1
END FUNCTION

FUNCTION SoundBlasterEnvTokenValue(BYVAL envText AS STRING, BYVAL tokenName AS STRING) AS STRING
    DIM posNum AS INTEGER
    DIM tokenText AS STRING
    DIM tokenChar AS STRING
    DIM tokenValue AS STRING
    DIM ch AS STRING

    SoundBlasterEnvTokenValue = ""
    envText = UCASE$(TRIM$(envText))
    tokenName = UCASE$(LEFT$(TRIM$(tokenName), 1))
    IF envText = "" OR tokenName = "" THEN EXIT FUNCTION

    posNum = 1
    DO WHILE posNum <= LEN(envText)
        DO WHILE posNum <= LEN(envText) AND MID$(envText, posNum, 1) = " "
            posNum = posNum + 1
        LOOP
        tokenText = ""
        DO WHILE posNum <= LEN(envText)
            ch = MID$(envText, posNum, 1)
            IF ch = " " THEN EXIT DO
            tokenText = tokenText + ch
            posNum = posNum + 1
        LOOP
        IF tokenText <> "" THEN
            tokenChar = LEFT$(tokenText, 1)
            tokenValue = MID$(tokenText, 2)
            IF tokenChar = tokenName THEN
                SoundBlasterEnvTokenValue = tokenValue
                EXIT FUNCTION
            END IF
        END IF
        posNum = posNum + 1
    LOOP
END FUNCTION

SUB SoundBlasterLoadConfig()
    DIM blasterEnv AS STRING
    DIM cfgText AS STRING
    DIM tokenValue AS STRING

    soundSbDetected = 0
    soundSbDetectEnabled = SoundCfgEnabled("sb_detect", -1)
    soundSbBase = 0
    soundSbIrq = 0
    soundSbDma8 = -1
    soundSbDma16 = -1
    soundSbType = 0
    soundSbDspVersionMajor = -1
    soundSbDspVersionMinor = -1

    blasterEnv = ENVIRON$("BLASTER")

    cfgText = UCASE$(TRIM$(ReadCfgValue(PATH_SOUNDCFG, "sb_base", "AUTO")))
    IF cfgText = "" OR cfgText = "AUTO" THEN
        tokenValue = SoundBlasterEnvTokenValue(blasterEnv, "A")
        IF tokenValue <> "" THEN soundSbBase = SoundPortFromHexText(tokenValue, 0)
    ELSE
        soundSbBase = SoundPortFromHexText(cfgText, 0)
    END IF

    cfgText = UCASE$(TRIM$(ReadCfgValue(PATH_SOUNDCFG, "sb_irq", "AUTO")))
    IF cfgText = "" OR cfgText = "AUTO" THEN
        tokenValue = SoundBlasterEnvTokenValue(blasterEnv, "I")
        IF tokenValue <> "" THEN soundSbIrq = VALINT(tokenValue)
    ELSE
        soundSbIrq = VALINT(cfgText)
    END IF

    cfgText = UCASE$(TRIM$(ReadCfgValue(PATH_SOUNDCFG, "sb_dma8", "AUTO")))
    IF cfgText = "" OR cfgText = "AUTO" THEN
        tokenValue = SoundBlasterEnvTokenValue(blasterEnv, "D")
        IF tokenValue <> "" THEN soundSbDma8 = VALINT(tokenValue)
    ELSE
        soundSbDma8 = VALINT(cfgText)
    END IF

    cfgText = UCASE$(TRIM$(ReadCfgValue(PATH_SOUNDCFG, "sb_dma16", "AUTO")))
    IF cfgText = "" OR cfgText = "AUTO" THEN
        tokenValue = SoundBlasterEnvTokenValue(blasterEnv, "H")
        IF tokenValue <> "" THEN soundSbDma16 = VALINT(tokenValue)
    ELSE
        soundSbDma16 = VALINT(cfgText)
    END IF

    cfgText = UCASE$(TRIM$(ReadCfgValue(PATH_SOUNDCFG, "sb_type", "AUTO")))
    IF cfgText = "" OR cfgText = "AUTO" THEN
        tokenValue = SoundBlasterEnvTokenValue(blasterEnv, "T")
        IF tokenValue <> "" THEN soundSbType = VALINT(tokenValue)
    ELSE
        soundSbType = VALINT(cfgText)
    END IF

    IF soundSbBase < &H200 OR soundSbBase > &H280 THEN soundSbBase = 0
END SUB

FUNCTION SoundBlasterDetect() AS INTEGER
    DIM i AS INTEGER
    DIM statusValue AS INTEGER
    DIM ackValue AS INTEGER

    SoundBlasterDetect = 0
    IF soundSbDetectEnabled = 0 THEN EXIT FUNCTION
    IF soundSbBase <= 0 THEN EXIT FUNCTION

    OUT soundSbBase + &H6, 1
    FOR i = 1 TO 64
        statusValue = INP(soundSbBase + &HE)
    NEXT
    OUT soundSbBase + &H6, 0

    FOR i = 1 TO 2048
        statusValue = INP(soundSbBase + &HE)
        IF (statusValue AND &H80) <> 0 THEN
            ackValue = INP(soundSbBase + &HA)
            IF ackValue = &HAA THEN SoundBlasterDetect = -1
            EXIT FUNCTION
        END IF
    NEXT
END FUNCTION

FUNCTION SoundBlasterWriteByte(BYVAL byteValue AS INTEGER) AS INTEGER
    DIM i AS INTEGER

    SoundBlasterWriteByte = 0
    IF soundSbBase <= 0 THEN EXIT FUNCTION

    FOR i = 1 TO 4096
        IF (INP(soundSbBase + &HC) AND &H80) = 0 THEN
            OUT soundSbBase + &HC, (byteValue AND &HFF)
            SoundBlasterWriteByte = -1
            EXIT FUNCTION
        END IF
    NEXT
END FUNCTION

FUNCTION SoundBlasterReadByte(BYREF byteValue AS INTEGER) AS INTEGER
    DIM i AS INTEGER

    SoundBlasterReadByte = 0
    byteValue = -1
    IF soundSbBase <= 0 THEN EXIT FUNCTION

    FOR i = 1 TO 4096
        IF (INP(soundSbBase + &HE) AND &H80) <> 0 THEN
            byteValue = INP(soundSbBase + &HA) AND &HFF
            SoundBlasterReadByte = -1
            EXIT FUNCTION
        END IF
    NEXT
END FUNCTION

FUNCTION SoundBlasterQueryVersion() AS INTEGER
    DIM majorValue AS INTEGER
    DIM minorValue AS INTEGER

    SoundBlasterQueryVersion = 0
    soundSbDspVersionMajor = -1
    soundSbDspVersionMinor = -1

    IF soundSbDetected = 0 THEN EXIT FUNCTION
    IF soundSbBase <= 0 THEN EXIT FUNCTION
    IF SoundBlasterWriteByte(&HE1) = 0 THEN EXIT FUNCTION
    IF SoundBlasterReadByte(majorValue) = 0 THEN EXIT FUNCTION
    IF SoundBlasterReadByte(minorValue) = 0 THEN EXIT FUNCTION

    soundSbDspVersionMajor = majorValue
    soundSbDspVersionMinor = minorValue
    SoundBlasterQueryVersion = -1
END FUNCTION

FUNCTION SoundBlasterDirectDacWrite(BYVAL sampleValue AS INTEGER) AS INTEGER
    SoundBlasterDirectDacWrite = 0
    IF soundSbDetected = 0 THEN EXIT FUNCTION
    IF soundSbBase <= 0 THEN EXIT FUNCTION
    IF SoundBlasterWriteByte(&H10) = 0 THEN EXIT FUNCTION
    IF SoundBlasterWriteByte(sampleValue AND &HFF) = 0 THEN EXIT FUNCTION
    SoundBlasterDirectDacWrite = -1
END FUNCTION

FUNCTION SoundBlasterSpeakerOn() AS INTEGER
    SoundBlasterSpeakerOn = 0
    IF soundSbDetected = 0 THEN EXIT FUNCTION
    IF soundSbBase <= 0 THEN EXIT FUNCTION
    IF SoundBlasterWriteByte(&HD1) = 0 THEN EXIT FUNCTION
    SoundBlasterSpeakerOn = -1
END FUNCTION

FUNCTION SoundBlasterDirectClick() AS INTEGER
    DIM stopResult AS INTEGER

    SoundBlasterDirectClick = 0
    IF soundEnabled = 0 THEN EXIT FUNCTION
    IF soundSbDetected = 0 THEN EXIT FUNCTION
    IF soundSbBase <= 0 THEN EXIT FUNCTION
    IF soundSbDspVersionMajor < 0 THEN EXIT FUNCTION

    SoundStop

    IF SoundBlasterWriteByte(&HD1) = 0 THEN EXIT FUNCTION
    IF SoundBlasterDirectDacWrite(128) = 0 THEN GOTO SbDirectClickStop
    SLEEP 1
    IF SoundBlasterDirectDacWrite(255) = 0 THEN GOTO SbDirectClickStop
    SLEEP 10
    IF SoundBlasterDirectDacWrite(0) = 0 THEN GOTO SbDirectClickStop
    SLEEP 10
    IF SoundBlasterDirectDacWrite(128) = 0 THEN GOTO SbDirectClickStop
    SoundBlasterDirectClick = -1

SbDirectClickStop:
    stopResult = SoundBlasterWriteByte(&HD3)
END FUNCTION

FUNCTION SoundBlasterDma8ChannelValid(BYVAL dmaChan AS INTEGER) AS INTEGER
    SELECT CASE dmaChan
        CASE 0, 1, 3
            RETURN -1
    END SELECT
    RETURN 0
END FUNCTION

FUNCTION SoundBlasterDma8TestReady() AS INTEGER
    IF soundEnabled = 0 THEN RETURN 0
    IF soundSbDetected = 0 THEN RETURN 0
    IF soundSbBase <= 0 THEN RETURN 0
    IF soundSbDspVersionMajor < 0 THEN RETURN 0
    IF SoundBlasterDma8ChannelValid(soundSbDma8) = 0 THEN RETURN 0
    RETURN -1
END FUNCTION

SUB SoundBlasterDma8Mask(BYVAL dmaChan AS INTEGER, BYVAL masked AS INTEGER)
    IF SoundBlasterDma8ChannelValid(dmaChan) = 0 THEN EXIT SUB
    IF masked <> 0 THEN
        OUT &H0A, ((dmaChan AND 3) OR 4)
    ELSE
        OUT &H0A, (dmaChan AND 3)
    END IF
END SUB

FUNCTION SoundBlasterDma8Program(BYVAL dmaChan AS INTEGER, BYVAL dmaAddr AS LONG, BYVAL sampleLen AS INTEGER) AS INTEGER
    DIM addrPort AS INTEGER
    DIM countPort AS INTEGER
    DIM pagePort AS INTEGER
    DIM countValue AS INTEGER
    DIM pageValue AS INTEGER
    DIM addrOffset AS INTEGER

    SoundBlasterDma8Program = 0
    IF sampleLen < 1 THEN EXIT FUNCTION
    IF SoundBlasterDma8ChannelValid(dmaChan) = 0 THEN EXIT FUNCTION
    IF ((dmaAddr AND &HFFFF) + sampleLen - 1) > &HFFFF THEN EXIT FUNCTION

    SELECT CASE dmaChan
        CASE 0
            addrPort = &H00
            countPort = &H01
            pagePort = &H87
        CASE 1
            addrPort = &H02
            countPort = &H03
            pagePort = &H83
        CASE 3
            addrPort = &H06
            countPort = &H07
            pagePort = &H82
        CASE ELSE
            EXIT FUNCTION
    END SELECT

    countValue = sampleLen - 1
    addrOffset = dmaAddr AND &HFFFF
    pageValue = (dmaAddr \ 65536) AND &HFF

    SoundBlasterDma8Mask dmaChan, -1
    OUT &H0C, 0
    OUT &H0B, (&H48 OR (dmaChan AND 3))
    OUT addrPort, (addrOffset AND &HFF)
    OUT addrPort, ((addrOffset \ 256) AND &HFF)
    OUT pagePort, pageValue
    OUT countPort, (countValue AND &HFF)
    OUT countPort, ((countValue \ 256) AND &HFF)
    SoundBlasterDma8Mask dmaChan, 0

    SoundBlasterDma8Program = -1
END FUNCTION

FUNCTION SoundBlasterDma8StartPlayback(BYVAL sampleRate AS INTEGER, BYVAL sampleLen AS INTEGER) AS INTEGER
    DIM countValue AS INTEGER
    DIM timeConst AS INTEGER

    SoundBlasterDma8StartPlayback = 0
    IF sampleRate < 4000 THEN EXIT FUNCTION
    IF sampleLen < 1 THEN EXIT FUNCTION

    countValue = sampleLen - 1

    IF soundSbDspVersionMajor >= 4 THEN
        ' Native DSP 4.xx 8-bit single-cycle output. This avoids legacy 14h
        ' startup behavior on SB16-compatible cards while keeping unsigned mono.
        IF SoundBlasterWriteByte(&H41) = 0 THEN EXIT FUNCTION
        IF SoundBlasterWriteByte((sampleRate \ 256) AND &HFF) = 0 THEN EXIT FUNCTION
        IF SoundBlasterWriteByte(sampleRate AND &HFF) = 0 THEN EXIT FUNCTION
        IF SoundBlasterWriteByte(&HC0) = 0 THEN EXIT FUNCTION
        IF SoundBlasterWriteByte(&H00) = 0 THEN EXIT FUNCTION
        IF SoundBlasterWriteByte(countValue AND &HFF) = 0 THEN EXIT FUNCTION
        IF SoundBlasterWriteByte((countValue \ 256) AND &HFF) = 0 THEN EXIT FUNCTION
    ELSE
        timeConst = 256 - (1000000 \ sampleRate)
        IF timeConst < 0 THEN timeConst = 0
        IF timeConst > 255 THEN timeConst = 255
        IF SoundBlasterWriteByte(&H40) = 0 THEN EXIT FUNCTION
        IF SoundBlasterWriteByte(timeConst) = 0 THEN EXIT FUNCTION
        IF SoundBlasterWriteByte(&H14) = 0 THEN EXIT FUNCTION
        IF SoundBlasterWriteByte(countValue AND &HFF) = 0 THEN EXIT FUNCTION
        IF SoundBlasterWriteByte((countValue \ 256) AND &HFF) = 0 THEN EXIT FUNCTION
    END IF

    SoundBlasterDma8StartPlayback = -1
END FUNCTION

SUB SoundSbDmaBufferRelease()
    DIM freeResult AS INTEGER

    IF soundSbDmaBufferSelector <> 0 THEN
        freeResult = __dpmi_free_dos_memory(soundSbDmaBufferSelector)
    END IF
    soundSbDmaBufferSelector = 0
    soundSbDmaBufferSegment = 0
    soundSbDmaBufferLinear = 0
    soundSbDmaBufferBytes = 0
END SUB

FUNCTION SoundSbDmaBufferEnsure(BYVAL needBytes AS INTEGER) AS INTEGER
    DIM paras AS INTEGER
    DIM selectorValue AS INTEGER
    DIM segmentValue AS INTEGER

    SoundSbDmaBufferEnsure = 0
    IF needBytes < 1 THEN EXIT FUNCTION
    IF needBytes > SOUND_SB_WAV_MAX_SAMPLE_BYTES THEN EXIT FUNCTION

    IF soundSbDmaBufferLinear <> 0 AND soundSbDmaBufferBytes >= needBytes THEN
        IF ((soundSbDmaBufferLinear AND &HFFFF) + needBytes - 1) <= &HFFFF THEN
            SoundSbDmaBufferEnsure = -1
            EXIT FUNCTION
        END IF
    END IF

    SoundSbDmaBufferRelease

    paras = (needBytes + 15) \ 16
    selectorValue = 0
    segmentValue = __dpmi_allocate_dos_memory(paras, @selectorValue)
    IF segmentValue < 0 OR selectorValue = 0 THEN EXIT FUNCTION

    soundSbDmaBufferSelector = selectorValue
    soundSbDmaBufferSegment = segmentValue
    soundSbDmaBufferLinear = CLNG(segmentValue) * 16
    soundSbDmaBufferBytes = paras * 16

    IF ((soundSbDmaBufferLinear AND &HFFFF) + needBytes - 1) > &HFFFF THEN
        SoundSbDmaBufferRelease
        EXIT FUNCTION
    END IF

    SoundSbDmaBufferEnsure = -1
END FUNCTION

FUNCTION SoundSbDmaBufferPut(BYREF dataText AS STRING, BYVAL byteCount AS INTEGER) AS INTEGER
    SoundSbDmaBufferPut = 0
    IF byteCount < 1 THEN EXIT FUNCTION
    IF byteCount > LEN(dataText) THEN EXIT FUNCTION
    IF SoundSbDmaBufferEnsure(byteCount) = 0 THEN EXIT FUNCTION

    DOSMEMPUT STRPTR(dataText), byteCount, soundSbDmaBufferLinear
    SoundSbDmaBufferPut = -1
END FUNCTION

FUNCTION SoundBlasterDmaTest() AS INTEGER
    DIM sampleText AS STRING
    DIM sampleLen AS INTEGER
    DIM i AS INTEGER
    DIM phaseLen AS INTEGER
    DIM sampleVal AS INTEGER
    DIM timeConst AS INTEGER
    DIM countValue AS INTEGER
    DIM playMs AS INTEGER
    DIM stopResult AS INTEGER

    SoundBlasterDmaTest = 0
    IF SoundBlasterDma8TestReady() = 0 THEN EXIT FUNCTION

    sampleLen = SOUND_SB_DMA_TEST_LEN
    sampleText = SPACE$(sampleLen)
    phaseLen = SOUND_SB_DMA_TEST_RATE \ 880
    IF phaseLen < 2 THEN phaseLen = 2

    FOR i = 1 TO sampleLen
        IF (((i - 1) \ (phaseLen \ 2)) AND 1) = 0 THEN
            sampleVal = 196
        ELSE
            sampleVal = 60
        END IF
        MID$(sampleText, i, 1) = CHR$(sampleVal AND &HFF)
    NEXT

    SoundPrepareForPlayback
    IF SoundSbDmaBufferPut(sampleText, sampleLen) = 0 THEN EXIT FUNCTION

    IF SoundBlasterSpeakerOn() = 0 THEN GOTO SbDmaTestStop
    IF SoundBlasterDma8Program(soundSbDma8, soundSbDmaBufferLinear, sampleLen) = 0 THEN GOTO SbDmaTestStop

    IF SoundBlasterDma8StartPlayback(SOUND_SB_DMA_TEST_RATE, sampleLen) = 0 THEN GOTO SbDmaTestStop

    playMs = (sampleLen * 1000) \ SOUND_SB_DMA_TEST_RATE
    IF playMs < 50 THEN playMs = 50
    SLEEP playMs + 50
    SoundBlasterDmaTest = -1

SbDmaTestStop:
    SoundBlasterDma8Mask soundSbDma8, -1
    stopResult = SoundBlasterWriteByte(&HD3)
END FUNCTION

FUNCTION SoundBlasterDma8OutputReady() AS INTEGER
    SoundBlasterDma8OutputReady = 0
    IF soundEnabled = 0 THEN EXIT FUNCTION
    IF soundSbDetected = 0 THEN EXIT FUNCTION
    IF soundSbBase <= 0 THEN EXIT FUNCTION
    IF soundSbDspVersionMajor < 0 THEN EXIT FUNCTION
    IF SoundBlasterDma8ChannelValid(soundSbDma8) = 0 THEN EXIT FUNCTION
    SoundBlasterDma8OutputReady = -1
END FUNCTION

FUNCTION SoundBlasterDmaStartTone(BYVAL freqHz AS INTEGER, BYVAL durationMs AS INTEGER) AS INTEGER
    DIM sampleText AS STRING
    DIM sampleLen AS INTEGER
    DIM i AS INTEGER
    DIM phaseLen AS INTEGER
    DIM halfPhase AS INTEGER
    DIM sampleVal AS INTEGER
    DIM timeConst AS INTEGER
    DIM countValue AS INTEGER

    SoundBlasterDmaStartTone = 0
    IF SoundBlasterDma8OutputReady() = 0 THEN EXIT FUNCTION

    IF freqHz < 37 THEN freqHz = soundDefaultFreq
    IF freqHz < 37 THEN freqHz = 880
    IF freqHz > 4000 THEN freqHz = 4000

    IF durationMs < 10 THEN durationMs = 10
    IF durationMs > 1000 THEN durationMs = 1000

    sampleLen = (SOUND_SB_DMA_TONE_RATE * durationMs) \ 1000
    IF sampleLen < 32 THEN sampleLen = 32
    IF sampleLen > SOUND_SB_DMA_TONE_MAX_LEN THEN sampleLen = SOUND_SB_DMA_TONE_MAX_LEN

    sampleText = SPACE$(sampleLen)
    phaseLen = SOUND_SB_DMA_TONE_RATE \ freqHz
    IF phaseLen < 2 THEN phaseLen = 2
    halfPhase = phaseLen \ 2
    IF halfPhase < 1 THEN halfPhase = 1

    FOR i = 1 TO sampleLen
        IF (((i - 1) \ halfPhase) AND 1) = 0 THEN
            sampleVal = 192
        ELSE
            sampleVal = 64
        END IF
        sampleVal = SoundScaleSampleValue(sampleVal)
        MID$(sampleText, i, 1) = CHR$(sampleVal AND &HFF)
    NEXT

    SoundPrepareForPlayback
    IF SoundSbDmaBufferPut(sampleText, sampleLen) = 0 THEN EXIT FUNCTION

    IF SoundBlasterSpeakerOn() = 0 THEN GOTO SbDmaToneStop
    IF SoundBlasterDma8Program(soundSbDma8, soundSbDmaBufferLinear, sampleLen) = 0 THEN GOTO SbDmaToneStop

    IF SoundBlasterDma8StartPlayback(SOUND_SB_DMA_TONE_RATE, sampleLen) = 0 THEN GOTO SbDmaToneStop

    soundActive = -1
    soundStartTime = TIMER
    soundDurationSeconds = CDbl(sampleLen) / CDbl(SOUND_SB_DMA_TONE_RATE)
    SoundBlasterDmaStartTone = -1
    EXIT FUNCTION

SbDmaToneStop:
    SoundBlasterDma8Mask soundSbDma8, -1
    IF soundSbDetected <> 0 AND soundSbBase > 0 THEN countValue = SoundBlasterWriteByte(&HD3)
END FUNCTION

FUNCTION SoundDataByteAt(BYREF dataText AS STRING, BYVAL byteOffset AS LONG) AS INTEGER
    IF byteOffset < 0 OR byteOffset >= LEN(dataText) THEN RETURN 0
    RETURN ASC(MID$(dataText, byteOffset + 1, 1))
END FUNCTION

FUNCTION SoundDataU16At(BYREF dataText AS STRING, BYVAL byteOffset AS LONG) AS INTEGER
    RETURN SoundDataByteAt(dataText, byteOffset) + SoundDataByteAt(dataText, byteOffset + 1) * 256
END FUNCTION

FUNCTION SoundDataS16At(BYREF dataText AS STRING, BYVAL byteOffset AS LONG) AS INTEGER
    DIM valueNum AS INTEGER

    valueNum = SoundDataU16At(dataText, byteOffset)
    IF valueNum >= 32768 THEN valueNum = valueNum - 65536
    RETURN valueNum
END FUNCTION

FUNCTION SoundDataU32At(BYREF dataText AS STRING, BYVAL byteOffset AS LONG) AS LONG
    DIM v AS LONG
    v = CLNG(SoundDataByteAt(dataText, byteOffset)) + CLNG(SoundDataByteAt(dataText, byteOffset + 1)) * 256
    v = v + CLNG(SoundDataByteAt(dataText, byteOffset + 2)) * 65536
    v = v + CLNG(SoundDataByteAt(dataText, byteOffset + 3)) * 16777216
    RETURN v
END FUNCTION

FUNCTION SoundBlasterDmaPlaySampleText(BYREF sampleText AS STRING, BYVAL sampleRate AS INTEGER) AS INTEGER
    DIM sampleLen AS INTEGER
    DIM dmaLen AS INTEGER
    DIM timeConst AS INTEGER
    DIM countValue AS INTEGER
    DIM dmaText AS STRING
    DIM volumeSampleText AS STRING

    SoundBlasterDmaPlaySampleText = 0
    IF SoundBlasterDma8OutputReady() = 0 THEN EXIT FUNCTION

    sampleLen = LEN(sampleText)
    IF sampleLen < 1 THEN EXIT FUNCTION
    IF sampleLen + SOUND_SB_WAV_PAD_BYTES * 2 > SOUND_SB_WAV_MAX_SAMPLE_BYTES THEN EXIT FUNCTION
    IF sampleRate < SOUND_SB_WAV_MIN_RATE OR sampleRate > SOUND_SB_WAV_MAX_RATE THEN EXIT FUNCTION

    volumeSampleText = SoundApplyVolumeToSampleText(sampleText)
    IF LEN(volumeSampleText) <> sampleLen THEN EXIT FUNCTION

    ' Unsigned 8-bit PCM silence is 128. Pad both edges so the DAC does not
    ' jump directly from an old level into the first WAV byte or leave at the
    ' final WAV byte when playback ends.
    dmaText = STRING$(SOUND_SB_WAV_PAD_BYTES, CHR$(128)) + volumeSampleText + STRING$(SOUND_SB_WAV_PAD_BYTES, CHR$(128))
    dmaLen = LEN(dmaText)
    IF dmaLen < 1 OR dmaLen > SOUND_SB_WAV_MAX_SAMPLE_BYTES THEN EXIT FUNCTION

    SoundPrepareForPlayback
    SoundBlasterDma8Mask soundSbDma8, -1
    IF SoundBlasterSpeakerOn() = 0 THEN GOTO SbDmaSampleStop

    IF SoundSbDmaBufferPut(dmaText, dmaLen) = 0 THEN GOTO SbDmaSampleStop

    IF SoundBlasterDma8Program(soundSbDma8, soundSbDmaBufferLinear, dmaLen) = 0 THEN GOTO SbDmaSampleStop

    IF SoundBlasterDma8StartPlayback(sampleRate, dmaLen) = 0 THEN GOTO SbDmaSampleStop

    soundActive = -1
    soundStartTime = TIMER
    soundDurationSeconds = CDbl(dmaLen) / CDbl(sampleRate)
    SoundBlasterDmaPlaySampleText = -1
    EXIT FUNCTION

SbDmaSampleStop:
    SoundBlasterDma8Mask soundSbDma8, -1
    IF soundSbDetected <> 0 AND soundSbBase > 0 THEN countValue = SoundBlasterWriteByte(&HD3)
END FUNCTION

FUNCTION SoundBlasterLoadWav8Mono(BYVAL fileName AS STRING, BYREF sampleTextOut AS STRING, BYREF sampleRateOut AS INTEGER) AS INTEGER
    DIM f AS INTEGER
    DIM dataText AS STRING
    DIM dataLen AS LONG
    DIM wavScanPos AS LONG
    DIM chunkId AS STRING
    DIM chunkSize AS LONG
    DIM chunkNext AS LONG
    DIM fmtPos AS LONG
    DIM fmtSize AS LONG
    DIM wavDataPos AS LONG
    DIM wavDataSize AS LONG
    DIM audioFormat AS INTEGER
    DIM channels AS INTEGER
    DIM sampleRate AS LONG
    DIM bitsPerSample AS INTEGER

    SoundBlasterLoadWav8Mono = 0
    sampleTextOut = ""
    sampleRateOut = 0

    fileName = NormalizePath(TRIM$(fileName))
    IF fileName = "" THEN EXIT FUNCTION

    f = FREEFILE
    IF OPEN(fileName FOR BINARY ACCESS READ AS #f) <> 0 THEN EXIT FUNCTION
    dataLen = LOF(f)
    IF dataLen < 44 OR dataLen > SOUND_SB_WAV_MAX_FILE_BYTES THEN
        CLOSE #f
        EXIT FUNCTION
    END IF
    dataText = SPACE$(dataLen)
    GET #f, 1, dataText
    CLOSE #f

    IF MID$(dataText, 1, 4) <> "RIFF" THEN EXIT FUNCTION
    IF MID$(dataText, 9, 4) <> "WAVE" THEN EXIT FUNCTION

    fmtPos = -1
    fmtSize = 0
    wavDataPos = -1
    wavDataSize = 0
    wavScanPos = 12

    DO WHILE wavScanPos + 8 <= dataLen
        chunkId = MID$(dataText, wavScanPos + 1, 4)
        chunkSize = SoundDataU32At(dataText, wavScanPos + 4)
        IF chunkSize < 0 THEN EXIT DO
        IF wavScanPos + 8 + chunkSize > dataLen THEN EXIT DO

        IF chunkId = "fmt " THEN
            fmtPos = wavScanPos + 8
            fmtSize = chunkSize
        ELSEIF chunkId = "data" THEN
            wavDataPos = wavScanPos + 8
            wavDataSize = chunkSize
            EXIT DO
        END IF

        chunkNext = wavScanPos + 8 + chunkSize
        IF (chunkSize AND 1) <> 0 THEN chunkNext = chunkNext + 1
        IF chunkNext <= wavScanPos THEN EXIT DO
        wavScanPos = chunkNext
    LOOP

    IF fmtPos < 0 OR wavDataPos < 0 THEN EXIT FUNCTION
    IF fmtSize < 16 THEN EXIT FUNCTION
    IF wavDataSize < 1 OR wavDataSize + SOUND_SB_WAV_PAD_BYTES * 2 > SOUND_SB_WAV_MAX_SAMPLE_BYTES THEN EXIT FUNCTION

    audioFormat = SoundDataU16At(dataText, fmtPos)
    channels = SoundDataU16At(dataText, fmtPos + 2)
    sampleRate = SoundDataU32At(dataText, fmtPos + 4)
    bitsPerSample = SoundDataU16At(dataText, fmtPos + 14)

    IF audioFormat <> 1 THEN EXIT FUNCTION
    IF channels <> 1 THEN EXIT FUNCTION
    IF bitsPerSample <> 8 THEN EXIT FUNCTION
    IF sampleRate < SOUND_SB_WAV_MIN_RATE OR sampleRate > SOUND_SB_WAV_MAX_RATE THEN EXIT FUNCTION

    sampleTextOut = MID$(dataText, wavDataPos + 1, wavDataSize)
    sampleRateOut = CINT(sampleRate)
    SoundBlasterLoadWav8Mono = -1
END FUNCTION

FUNCTION SoundBlasterPlayCachedWav8Mono(BYVAL fileName AS STRING, BYREF cachePath AS STRING, BYREF cacheSample AS STRING, BYREF cacheRate AS INTEGER) AS INTEGER
    DIM normalizedPath AS STRING

    SoundBlasterPlayCachedWav8Mono = 0
    IF SoundBlasterDma8OutputReady() = 0 THEN EXIT FUNCTION

    normalizedPath = NormalizePath(TRIM$(fileName))
    IF normalizedPath = "" THEN EXIT FUNCTION

    IF UCASE$(cachePath) <> UCASE$(normalizedPath) OR cacheSample = "" OR cacheRate < 1 THEN
        cachePath = ""
        cacheSample = ""
        cacheRate = 0
        IF SoundBlasterLoadWav8Mono(normalizedPath, cacheSample, cacheRate) = 0 THEN EXIT FUNCTION
        cachePath = normalizedPath
    END IF

    SoundBlasterPlayCachedWav8Mono = SoundBlasterDmaPlaySampleText(cacheSample, cacheRate)
END FUNCTION

FUNCTION SoundBlasterPlayWav8Mono(BYVAL fileName AS STRING) AS INTEGER
    DIM sampleText AS STRING
    DIM sampleRate AS INTEGER

    SoundBlasterPlayWav8Mono = 0
    IF SoundBlasterDma8OutputReady() = 0 THEN EXIT FUNCTION
    IF SoundBlasterLoadWav8Mono(fileName, sampleText, sampleRate) = 0 THEN EXIT FUNCTION
    SoundBlasterPlayWav8Mono = SoundBlasterDmaPlaySampleText(sampleText, sampleRate)
END FUNCTION

SUB SoundPcmClose()
    IF soundPcmFileOpen <> 0 THEN
        CLOSE #soundPcmFile
    END IF
    soundPcmFileOpen = 0
    soundPcmFile = 0
    soundPcmActive = 0
    soundPcmPaused = 0
    soundPcmChunkStartByte = 0
END SUB

FUNCTION SoundPcmSpecField(BYVAL specText AS STRING, BYVAL fieldIndex AS INTEGER) AS STRING
    DIM scanPos AS INTEGER
    DIM nextComma AS INTEGER
    DIM fieldNum AS INTEGER
    DIM fieldText AS STRING

    SoundPcmSpecField = ""
    specText = TRIM$(specText)
    IF fieldIndex < 1 OR specText = "" THEN EXIT FUNCTION

    scanPos = 1
    fieldNum = 1
    DO
        nextComma = INSTR(scanPos, specText, ",")
        IF nextComma > 0 THEN
            fieldText = MID$(specText, scanPos, nextComma - scanPos)
        ELSE
            fieldText = MID$(specText, scanPos)
        END IF

        IF fieldNum = fieldIndex THEN
            SoundPcmSpecField = TRIM$(fieldText)
            EXIT FUNCTION
        END IF

        IF nextComma <= 0 THEN EXIT DO
        scanPos = nextComma + 1
        fieldNum = fieldNum + 1
    LOOP
END FUNCTION

SUB SoundPcmWriteStatus(BYVAL stateText AS STRING)
    DIM f AS INTEGER
    DIM percentDone AS INTEGER

    stateText = UCASE$(TRIM$(stateText))
    IF stateText = "" THEN stateText = soundPcmLastStatus
    IF stateText = "" THEN stateText = "STOPPED"

    soundPcmLastStatus = stateText
    percentDone = 0
    IF soundPcmTotalBytes > 0 THEN
        percentDone = CINT((soundPcmBytesRead * 100) \ soundPcmTotalBytes)
        IF percentDone < 0 THEN percentDone = 0
        IF percentDone > 100 THEN percentDone = 100
    END IF

    f = FREEFILE
    IF OPEN(PATH_PCMSTAT FOR OUTPUT AS #f) <> 0 THEN EXIT SUB
    PRINT #f, "PCM STREAM TRACE"
    PRINT #f, "STATUS=" + stateText
    PRINT #f, "PATH=" + soundPcmPath
    PRINT #f, "TOTAL_BYTES=" + LTRIM$(STR$(soundPcmTotalBytes))
    PRINT #f, "BYTES_READ=" + LTRIM$(STR$(soundPcmBytesRead))
    PRINT #f, "PERCENT=" + LTRIM$(STR$(percentDone))
    PRINT #f, "CHUNK_START=" + LTRIM$(STR$(soundPcmChunkStartByte))
    PRINT #f, "CHUNKS=" + LTRIM$(STR$(soundPcmChunks))
    PRINT #f, "PAUSED=" + SoundBoolText(soundPcmPaused)
    PRINT #f, "SRC_RATE=" + LTRIM$(STR$(soundPcmSrcRate))
    PRINT #f, "SRC_CHANNELS=" + LTRIM$(STR$(soundPcmSrcChannels))
    PRINT #f, "SRC_BITS=" + LTRIM$(STR$(soundPcmSrcBits))
    PRINT #f, "SRC_SIGNED=" + SoundBoolText(soundPcmSrcSigned)
    PRINT #f, "OUT_RATE=" + LTRIM$(STR$(soundPcmOutRate))
    PRINT #f, "OUT_FORMAT=UNSIGNED_8BIT_MONO"
    PRINT #f, "ERROR=" + soundPcmLastError
    CLOSE #f
END SUB

FUNCTION SoundPcmStartFile(BYVAL fileName AS STRING, BYVAL sampleRate AS INTEGER, BYVAL channels AS INTEGER, BYVAL bitsPerSample AS INTEGER) AS INTEGER
    DIM requestPath AS STRING

    SoundPcmStartFile = 0
    requestPath = NormalizePath(TRIM$(fileName))

    IF soundPcmPaused <> 0 AND soundPcmFileOpen <> 0 THEN
        IF UCASE$(requestPath) = UCASE$(soundPcmPath) THEN
            SoundPcmStartFile = SoundPcmResume()
            EXIT FUNCTION
        END IF
    END IF

    IF sampleRate <= 0 THEN sampleRate = SOUND_PCM_DEFAULT_SRC_RATE
    IF channels <= 0 THEN channels = 2
    IF bitsPerSample <= 0 THEN bitsPerSample = 16

    soundPcmPath = requestPath
    soundPcmTotalBytes = 0
    soundPcmBytesRead = 0
    soundPcmChunkStartByte = 0
    soundPcmChunks = 0
    soundPcmPaused = 0
    soundPcmLastError = ""
    soundPcmSrcRate = sampleRate
    soundPcmSrcChannels = channels
    soundPcmSrcBits = bitsPerSample
    soundPcmSrcSigned = 0
    soundPcmSrcFrameBytes = 0
    soundPcmStepFrames = 0
    soundPcmInputBytesPerOut = 0
    soundPcmOutRate = SOUND_PCM_DEFAULT_OUT_RATE
    SoundPcmWriteStatus "START"

    IF soundPcmPath = "" THEN
        soundPcmLastError = "EMPTY_PATH"
        SoundPcmWriteStatus "ERROR"
        EXIT FUNCTION
    END IF

    IF SoundBlasterDma8OutputReady() = 0 THEN
        soundPcmLastError = "SOUNDBLASTER_DMA_NOT_READY"
        SoundPcmWriteStatus "ERROR"
        EXIT FUNCTION
    END IF

    IF sampleRate <> 44100 AND sampleRate <> 22050 THEN
        soundPcmLastError = "UNSUPPORTED_RATE"
        SoundPcmWriteStatus "ERROR"
        EXIT FUNCTION
    END IF
    IF channels <> 1 AND channels <> 2 THEN
        soundPcmLastError = "UNSUPPORTED_CHANNELS"
        SoundPcmWriteStatus "ERROR"
        EXIT FUNCTION
    END IF
    IF bitsPerSample <> 8 AND bitsPerSample <> 16 THEN
        soundPcmLastError = "UNSUPPORTED_BITS"
        SoundPcmWriteStatus "ERROR"
        EXIT FUNCTION
    END IF
    IF bitsPerSample = 8 AND channels <> 1 THEN
        soundPcmLastError = "UNSUPPORTED_8BIT_CHANNELS"
        SoundPcmWriteStatus "ERROR"
        EXIT FUNCTION
    END IF
    IF bitsPerSample = 8 AND sampleRate <> 22050 THEN
        soundPcmLastError = "UNSUPPORTED_8BIT_RATE"
        SoundPcmWriteStatus "ERROR"
        EXIT FUNCTION
    END IF

    IF bitsPerSample = 16 THEN
        soundPcmSrcSigned = -1
    ELSE
        soundPcmSrcSigned = 0
    END IF
    soundPcmSrcFrameBytes = channels * (bitsPerSample \ 8)
    IF sampleRate = 44100 THEN
        soundPcmStepFrames = 2
    ELSE
        soundPcmStepFrames = 1
    END IF
    soundPcmInputBytesPerOut = soundPcmSrcFrameBytes * soundPcmStepFrames
    IF soundPcmInputBytesPerOut < 1 THEN
        soundPcmLastError = "BAD_FORMAT"
        SoundPcmWriteStatus "ERROR"
        EXIT FUNCTION
    END IF

    SoundStop

    soundPcmFile = FREEFILE
    IF OPEN(soundPcmPath FOR BINARY ACCESS READ AS #soundPcmFile) <> 0 THEN
        soundPcmLastError = "OPEN_FAILED"
        SoundPcmWriteStatus "ERROR"
        EXIT FUNCTION
    END IF

    soundPcmFileOpen = -1
    soundPcmTotalBytes = LOF(soundPcmFile)
    IF soundPcmTotalBytes < soundPcmInputBytesPerOut THEN
        soundPcmLastError = "FILE_TOO_SMALL"
        SoundPcmClose
        SoundPcmWriteStatus "ERROR"
        EXIT FUNCTION
    END IF

    soundPcmActive = -1
    SoundPcmWriteStatus "OPEN_OK"

    IF SoundPcmStartNextChunk() = 0 THEN
        IF soundPcmLastError = "" THEN soundPcmLastError = "FIRST_CHUNK_FAILED"
        SoundPcmClose
        SoundPcmWriteStatus "ERROR"
        EXIT FUNCTION
    END IF

    SoundPcmStartFile = -1
END FUNCTION

FUNCTION SoundPcmStartRaw16Stereo44100(BYVAL fileName AS STRING) AS INTEGER
    SoundPcmStartRaw16Stereo44100 = SoundPcmStartFile(fileName, 44100, 2, 16)
END FUNCTION

FUNCTION SoundPcmPause() AS INTEGER
    DIM portVal AS INTEGER
    DIM sbStopResult AS INTEGER

    SoundPcmPause = 0

    IF soundPcmFileOpen = 0 THEN
        soundPcmLastError = "NOT_PLAYING"
        SoundPcmWriteStatus "ERROR"
        EXIT FUNCTION
    END IF

    IF soundPcmPaused <> 0 THEN
        SoundPcmWriteStatus "PAUSED"
        SoundPcmPause = -1
        EXIT FUNCTION
    END IF

    IF soundPcmChunkStartByte >= 0 AND soundPcmChunkStartByte < soundPcmBytesRead THEN
        soundPcmBytesRead = soundPcmChunkStartByte
        SEEK #soundPcmFile, soundPcmBytesRead + 1
    END IF

    portVal = INP(&H61)
    OUT &H61, (portVal AND &HFC)
    SoundAdlibStop
    IF soundSbDetected <> 0 AND soundSbBase > 0 THEN
        IF SoundBlasterDma8ChannelValid(soundSbDma8) <> 0 THEN SoundBlasterDma8Mask soundSbDma8, -1
        sbStopResult = SoundBlasterWriteByte(&HD3)
    END IF

    soundActive = 0
    soundDurationSeconds = 0
    soundPcmActive = 0
    soundPcmPaused = -1
    soundPcmLastError = ""
    SoundPcmWriteStatus "PAUSED"
    SoundPcmPause = -1
END FUNCTION

FUNCTION SoundPcmResume() AS INTEGER
    SoundPcmResume = 0

    IF soundPcmFileOpen = 0 THEN
        soundPcmLastError = "NOT_PAUSED"
        SoundPcmWriteStatus "ERROR"
        EXIT FUNCTION
    END IF

    IF soundPcmPaused = 0 THEN
        IF soundPcmActive <> 0 THEN
            SoundPcmWriteStatus "PLAYING"
            SoundPcmResume = -1
        ELSE
            soundPcmLastError = "NOT_PAUSED"
            SoundPcmWriteStatus "ERROR"
        END IF
        EXIT FUNCTION
    END IF

    soundPcmPaused = 0
    soundPcmActive = -1
    soundPcmLastError = ""
    SoundPcmWriteStatus "RESUME"

    IF SoundPcmStartNextChunk() = 0 THEN
        IF soundPcmLastError = "" THEN soundPcmLastError = "RESUME_CHUNK_FAILED"
        SoundPcmClose
        SoundPcmWriteStatus "ERROR"
        EXIT FUNCTION
    END IF

    SoundPcmResume = -1
END FUNCTION

FUNCTION SoundPcmStartNextChunk() AS INTEGER
    DIM remainBytes AS LONG
    DIM readBytes AS INTEGER
    DIM outBytes AS INTEGER
    DIM inputText AS STRING
    DIM sampleText AS STRING
    DIM inputPtr AS UBYTE PTR
    DIM samplePtr AS UBYTE PTR
    DIM outIdx AS INTEGER
    DIM srcOff AS LONG
    DIM leftSample AS INTEGER
    DIM rightSample AS INTEGER
    DIM monoSample AS INTEGER
    DIM outSample AS INTEGER
    DIM byteLo AS INTEGER
    DIM byteHi AS INTEGER

    SoundPcmStartNextChunk = 0

    IF soundPcmActive = 0 THEN EXIT FUNCTION
    IF soundPcmPaused <> 0 THEN
        SoundPcmWriteStatus "PAUSED"
        EXIT FUNCTION
    END IF
    IF soundPcmFileOpen = 0 THEN
        soundPcmLastError = "PCM_FILE_NOT_OPEN"
        SoundPcmWriteStatus "ERROR"
        EXIT FUNCTION
    END IF
    IF soundPcmInputBytesPerOut < 1 THEN
        soundPcmLastError = "BAD_FORMAT"
        SoundPcmWriteStatus "ERROR"
        EXIT FUNCTION
    END IF

    remainBytes = soundPcmTotalBytes - soundPcmBytesRead
    IF remainBytes < soundPcmInputBytesPerOut THEN
        SoundPcmClose
        SoundFinishPlayback
        SoundPcmWriteStatus "DONE"
        EXIT FUNCTION
    END IF

    IF remainBytes > CLNG(SOUND_PCM_CHUNK_OUT_BYTES) * CLNG(soundPcmInputBytesPerOut) THEN
        readBytes = SOUND_PCM_CHUNK_OUT_BYTES * soundPcmInputBytesPerOut
    ELSE
        readBytes = CINT(remainBytes)
    END IF

    readBytes = (readBytes \ soundPcmInputBytesPerOut) * soundPcmInputBytesPerOut
    IF readBytes < soundPcmInputBytesPerOut THEN
        SoundPcmClose
        SoundFinishPlayback
        SoundPcmWriteStatus "DONE"
        EXIT FUNCTION
    END IF

    soundPcmChunkStartByte = soundPcmBytesRead
    inputText = SPACE$(readBytes)
    GET #soundPcmFile, , inputText
    soundPcmBytesRead = soundPcmBytesRead + readBytes

    outBytes = readBytes \ soundPcmInputBytesPerOut
    sampleText = SPACE$(outBytes)
    inputPtr = CAST(UBYTE PTR, STRPTR(inputText))
    samplePtr = CAST(UBYTE PTR, STRPTR(sampleText))

    FOR outIdx = 0 TO outBytes - 1
        srcOff = CLNG(outIdx) * CLNG(soundPcmInputBytesPerOut)
        IF soundPcmSrcBits = 8 THEN
            outSample = inputPtr[srcOff]
        ELSE
            byteLo = inputPtr[srcOff]
            byteHi = inputPtr[srcOff + 1]
            leftSample = byteLo OR (byteHi SHL 8)
            IF leftSample > 32767 THEN leftSample = leftSample - 65536
            IF soundPcmSrcChannels = 2 THEN
                byteLo = inputPtr[srcOff + 2]
                byteHi = inputPtr[srcOff + 3]
                rightSample = byteLo OR (byteHi SHL 8)
                IF rightSample > 32767 THEN rightSample = rightSample - 65536
                monoSample = (leftSample + rightSample) \ 2
            ELSE
                monoSample = leftSample
            END IF
            outSample = 128 + (monoSample \ 256)
        END IF

        IF outSample < 0 THEN outSample = 0
        IF outSample > 255 THEN outSample = 255
        samplePtr[outIdx] = outSample AND &HFF
    NEXT

    IF SoundBlasterDmaPlaySampleText(sampleText, soundPcmOutRate) = 0 THEN
        soundPcmLastError = "DMA_PLAY_FAILED"
        SoundPcmClose
        SoundPcmWriteStatus "ERROR"
        EXIT FUNCTION
    END IF

    soundPcmChunks = soundPcmChunks + 1
    IF soundPcmChunks = 1 OR (soundPcmChunks MOD SOUND_PCM_STATUS_CHUNK_INTERVAL) = 0 THEN
        SoundPcmWriteStatus "PLAYING"
    ELSE
        soundPcmLastStatus = "PLAYING"
    END IF
    SoundPcmStartNextChunk = -1
END FUNCTION

SUB SoundClearEventWavCaches()
    soundClickWavCachePath = ""
    soundClickWavCacheData = ""
    soundClickWavCacheRate = 0
    soundMenuWavCachePath = ""
    soundMenuWavCacheData = ""
    soundMenuWavCacheRate = 0
    soundErrorWavCachePath = ""
    soundErrorWavCacheData = ""
    soundErrorWavCacheRate = 0
    soundStartupWavCachePath = ""
    soundStartupWavCacheData = ""
    soundStartupWavCacheRate = 0
    soundShutdownWavCachePath = ""
    soundShutdownWavCacheData = ""
    soundShutdownWavCacheRate = 0
END SUB

FUNCTION SoundButtonActionOwnsSound(BYVAL actionText AS STRING) AS INTEGER
    DIM workText AS STRING
    DIM firstToken AS STRING
    DIM p AS INTEGER

    workText = UCASE$(TRIM$(actionText))
    IF workText = "" THEN RETURN 0

    p = INSTR(workText, " ")
    IF p > 0 THEN
        firstToken = LEFT$(workText, p - 1)
    ELSE
        firstToken = workText
    END IF

    IF LEFT$(firstToken, 6) = "SOUND_" THEN RETURN -1
    IF firstToken = "BEEP" OR firstToken = "SBTEST" OR firstToken = "SBDMA" THEN RETURN -1
    IF firstToken = "PLAY_TONE" OR firstToken = "PLAY_WAV" THEN RETURN -1

    RETURN 0
END FUNCTION

SUB SoundUiEvent(BYVAL eventName AS STRING)
    eventName = UCASE$(TRIM$(eventName))
    IF soundEnabled = 0 THEN EXIT SUB

    SELECT CASE eventName
        CASE "CLICK"
            IF soundClickEnabled <> 0 THEN
                IF soundDriverId = SOUND_DRIVER_SBLASTER AND soundClickWav <> "" THEN
                    IF SoundBlasterPlayCachedWav8Mono(soundClickWav, soundClickWavCachePath, soundClickWavCacheData, soundClickWavCacheRate) <> 0 THEN EXIT SUB
                    IF soundFallbackToTone = 0 THEN EXIT SUB
                END IF
                SoundStartTone soundClickFreq, soundClickMs
            END IF
        CASE "MENU"
            IF soundMenuEnabled <> 0 THEN
                IF soundDriverId = SOUND_DRIVER_SBLASTER AND soundMenuWav <> "" THEN
                    IF SoundBlasterPlayCachedWav8Mono(soundMenuWav, soundMenuWavCachePath, soundMenuWavCacheData, soundMenuWavCacheRate) <> 0 THEN EXIT SUB
                    IF soundFallbackToTone = 0 THEN EXIT SUB
                END IF
                SoundStartTone soundMenuFreq, soundMenuMs
            END IF
        CASE "ERROR"
            IF soundErrorEnabled <> 0 THEN
                IF soundDriverId = SOUND_DRIVER_SBLASTER AND soundErrorWav <> "" THEN
                    IF SoundBlasterPlayCachedWav8Mono(soundErrorWav, soundErrorWavCachePath, soundErrorWavCacheData, soundErrorWavCacheRate) <> 0 THEN EXIT SUB
                    IF soundFallbackToTone = 0 THEN EXIT SUB
                END IF
                SoundStartTone soundErrorFreq, soundErrorMs
            END IF
        CASE "STARTUP"
            IF soundStartupEnabled <> 0 THEN
                IF soundDriverId = SOUND_DRIVER_SBLASTER AND soundStartupWav <> "" THEN
                    IF SoundBlasterPlayCachedWav8Mono(soundStartupWav, soundStartupWavCachePath, soundStartupWavCacheData, soundStartupWavCacheRate) <> 0 THEN EXIT SUB
                    IF soundFallbackToTone = 0 THEN EXIT SUB
                END IF
                SoundStartTone soundStartupFreq, soundStartupMs
            END IF
        CASE "SHUTDOWN"
            IF soundShutdownEnabled <> 0 THEN
                IF soundDriverId = SOUND_DRIVER_SBLASTER AND soundShutdownWav <> "" THEN
                    IF SoundBlasterPlayCachedWav8Mono(soundShutdownWav, soundShutdownWavCachePath, soundShutdownWavCacheData, soundShutdownWavCacheRate) <> 0 THEN EXIT SUB
                    IF soundFallbackToTone = 0 THEN EXIT SUB
                END IF
                SoundStartTone soundShutdownFreq, soundShutdownMs
            END IF
    END SELECT
END SUB

SUB SoundShutdownEventAndWait()
    DIM shutdownWaitStart AS DOUBLE

    IF soundEnabled = 0 THEN EXIT SUB
    IF soundDriverId = SOUND_DRIVER_NONE THEN EXIT SUB

    SoundUiEvent "SHUTDOWN"
    IF soundActive = 0 THEN EXIT SUB

    shutdownWaitStart = TIMER
    DO WHILE soundActive <> 0
        SoundServiceAt TIMER
        IF TimerElapsedSeconds(shutdownWaitStart) >= 10.0 THEN EXIT DO
        SLEEP 10
    LOOP

    SoundStop
END SUB

SUB RefreshSoundConfig()
    DIM enabledText AS STRING
    DIM sbWarmResult AS INTEGER

    SoundClearEventWavCaches
    LoadCfgReadCacheFile PATH_SOUNDCFG
    enabledText = UCASE$(TRIM$(ReadCfgValue(PATH_SOUNDCFG, "enabled", "1")))
    IF enabledText = "0" OR enabledText = "NO" OR enabledText = "FALSE" OR enabledText = "OFF" THEN
        soundEnabled = 0
    ELSE
        soundEnabled = -1
    END IF

    soundDriver = UCASE$(TRIM$(ReadCfgValue(PATH_SOUNDCFG, "driver", "PCSPKR")))
    IF soundDriver = "" THEN soundDriver = "PCSPKR"
    soundRequestedDriverId = SoundDriverIdFromText(soundDriver)
    soundDriverId = soundRequestedDriverId
    soundStatusFile = NormalizePath(TRIM$(ReadCfgValue(PATH_SOUNDCFG, "status_file", "SYSTEM\SNDSTAT.TXT")))
    soundVolumePercent = SoundCfgInt("volume", 100, 0, 100)
    soundTaskbarVolumeEnabled = SoundCfgEnabled("taskbar_volume", -1)
    soundSettingsApp = NormalizePath(TRIM$(ReadCfgValue(PATH_SOUNDCFG, "settings_app", "")))

    soundAdlibDetectEnabled = SoundCfgEnabled("adlib_detect", -1)
    soundAdlibBase = SoundPortFromHexText(ReadCfgValue(PATH_SOUNDCFG, "adlib_base", "388"), SOUND_ADLIB_DEFAULT_BASE)
    soundAdlibDetected = 0
    SoundBlasterLoadConfig
    IF soundEnabled <> 0 THEN
        IF soundRequestedDriverId = SOUND_DRIVER_AUTO OR soundRequestedDriverId = SOUND_DRIVER_ADLIB THEN
            soundAdlibDetected = SoundAdlibDetect()
        END IF
        IF soundRequestedDriverId = SOUND_DRIVER_AUTO OR soundRequestedDriverId = SOUND_DRIVER_SBLASTER THEN
            soundSbDetected = SoundBlasterDetect()
            IF soundSbDetected <> 0 THEN SoundBlasterQueryVersion
        END IF
    END IF

    IF soundRequestedDriverId = SOUND_DRIVER_AUTO THEN
        IF soundAdlibDetected <> 0 THEN
            soundDriverId = SOUND_DRIVER_ADLIB
        ELSEIF SoundBlasterDma8OutputReady() <> 0 THEN
            soundDriverId = SOUND_DRIVER_SBLASTER
        ELSE
            soundDriverId = SOUND_DRIVER_PCSPKR
        END IF
    ELSEIF soundRequestedDriverId = SOUND_DRIVER_ADLIB THEN
        IF soundAdlibDetected <> 0 THEN
            soundDriverId = SOUND_DRIVER_ADLIB
        ELSE
            soundDriverId = SOUND_DRIVER_PCSPKR
        END IF
    ELSEIF soundRequestedDriverId = SOUND_DRIVER_SBLASTER THEN
        IF SoundBlasterDma8OutputReady() <> 0 THEN
            soundDriverId = SOUND_DRIVER_SBLASTER
        ELSE
            soundDriverId = SOUND_DRIVER_PCSPKR
        END IF
    END IF

    soundDefaultFreq = VALINT(ReadCfgValue(PATH_SOUNDCFG, "default_freq", "880"))
    IF soundDefaultFreq < 37 THEN soundDefaultFreq = 37
    IF soundDefaultFreq > 20000 THEN soundDefaultFreq = 20000

    soundDefaultMs = VALINT(ReadCfgValue(PATH_SOUNDCFG, "default_ms", "80"))
    IF soundDefaultMs < 10 THEN soundDefaultMs = 10
    IF soundDefaultMs > 5000 THEN soundDefaultMs = 5000

    soundFallbackToTone = SoundCfgEnabled("fallback_to_tone", -1)

    soundClickEnabled = SoundCfgEnabled("click", -1)
    soundClickFreq = SoundCfgInt("click_freq", 1200, 37, 20000)
    soundClickMs = SoundCfgInt("click_ms", 25, 10, 5000)
    soundClickWav = NormalizePath(TRIM$(ReadCfgValue(PATH_SOUNDCFG, "click_wav", "")))

    soundMenuEnabled = SoundCfgEnabled("menu", -1)
    soundMenuFreq = SoundCfgInt("menu_freq", 900, 37, 20000)
    soundMenuMs = SoundCfgInt("menu_ms", 35, 10, 5000)
    soundMenuWav = NormalizePath(TRIM$(ReadCfgValue(PATH_SOUNDCFG, "menu_wav", "")))

    soundErrorEnabled = SoundCfgEnabled("error", -1)
    soundErrorFreq = SoundCfgInt("error_freq", 220, 37, 20000)
    soundErrorMs = SoundCfgInt("error_ms", 140, 10, 5000)
    soundErrorWav = NormalizePath(TRIM$(ReadCfgValue(PATH_SOUNDCFG, "error_wav", "")))

    soundStartupEnabled = SoundCfgEnabled("startup", 0)
    soundStartupFreq = SoundCfgInt("startup_freq", 660, 37, 20000)
    soundStartupMs = SoundCfgInt("startup_ms", 80, 10, 5000)
    soundStartupWav = NormalizePath(TRIM$(ReadCfgValue(PATH_SOUNDCFG, "startup_wav", "")))

    soundShutdownEnabled = SoundCfgEnabled("shutdown", 0)
    soundShutdownFreq = SoundCfgInt("shutdown_freq", 440, 37, 20000)
    soundShutdownMs = SoundCfgInt("shutdown_ms", 120, 10, 5000)
    soundShutdownWav = NormalizePath(TRIM$(ReadCfgValue(PATH_SOUNDCFG, "shutdown_wav", "")))

    IF soundEnabled <> 0 AND soundDriverId = SOUND_DRIVER_SBLASTER THEN
        sbWarmResult = SoundBlasterSpeakerOn()
    ELSE
        SoundStop
        SoundSbDmaBufferRelease
    END IF
    IF soundEnabled = 0 OR soundDriverId = SOUND_DRIVER_NONE THEN SoundStop
    InvalidateTaskbarCache
    SoundWriteStatus
END SUB

SUB SoundStop()
    DIM portVal AS INTEGER
    DIM sbStopResult AS INTEGER

    SoundPcmClose

    ' Always silence hardware gates, even if the software flag was already clear.
    ' A blocking SHELL target such as a screensaver cannot service the timed stop.
    portVal = INP(&H61)
    OUT &H61, (portVal AND &HFC)
    SoundAdlibStop
    IF soundSbDetected <> 0 AND soundSbBase > 0 THEN
        IF SoundBlasterDma8ChannelValid(soundSbDma8) <> 0 THEN SoundBlasterDma8Mask soundSbDma8, -1
        sbStopResult = SoundBlasterWriteByte(&HD3)
    END IF
    soundActive = 0
    soundDurationSeconds = 0
END SUB

SUB SoundPrepareForPlayback()
    DIM portVal AS INTEGER

    ' Prepare for a new GUI sound without powering down the Sound Blaster
    ' output gate. Turning the DSP speaker off/on for every WAV can mute the
    ' first part of the next sample on some cards.
    portVal = INP(&H61)
    OUT &H61, (portVal AND &HFC)
    SoundAdlibStop
    IF soundSbDetected <> 0 AND soundSbBase > 0 THEN
        IF SoundBlasterDma8ChannelValid(soundSbDma8) <> 0 THEN SoundBlasterDma8Mask soundSbDma8, -1
    END IF
    soundActive = 0
    soundDurationSeconds = 0
END SUB

SUB SoundFinishPlayback()
    DIM portVal AS INTEGER

    ' Natural end of a timed GUI sound. Keep the Sound Blaster speaker gate on
    ' so the next WAV starts at byte zero instead of losing its leading edge.
    portVal = INP(&H61)
    OUT &H61, (portVal AND &HFC)
    SoundAdlibStop
    IF soundSbDetected <> 0 AND soundSbBase > 0 THEN
        IF SoundBlasterDma8ChannelValid(soundSbDma8) <> 0 THEN SoundBlasterDma8Mask soundSbDma8, -1
    END IF
    soundActive = 0
    soundDurationSeconds = 0
END SUB

SUB SoundPcSpeakerStartTone(BYVAL freqHz AS INTEGER, BYVAL durationMs AS INTEGER)
    DIM divisor AS UINTEGER
    DIM portVal AS INTEGER

    divisor = 1193180 \ freqHz
    IF divisor < 1 THEN divisor = 1

    OUT &H43, &HB6
    OUT &H42, (divisor AND &HFF)
    OUT &H42, ((divisor SHR 8) AND &HFF)

    portVal = INP(&H61)
    OUT &H61, (portVal OR 3)

    ' Short PC speaker feedback tones must not depend on how quickly the GUI loop
    ' returns to SoundServiceAt. Use the DOS timer-backed sleep for fixed length.
    IF durationMs <= SOUND_PCSPKR_SYNC_MAX_MS THEN
        soundActive = 0
        soundDurationSeconds = 0
        SLEEP durationMs
        SoundStop
        EXIT SUB
    END IF

    soundActive = -1
    soundStartTime = TIMER
    soundDurationSeconds = CDbl(durationMs) / 1000.0
END SUB

SUB SoundStartTone(BYVAL freqHz AS INTEGER, BYVAL durationMs AS INTEGER)
    IF soundEnabled = 0 THEN EXIT SUB
    IF soundDriverId = SOUND_DRIVER_NONE THEN EXIT SUB

    IF freqHz < 37 THEN freqHz = soundDefaultFreq
    IF freqHz < 37 THEN freqHz = 880
    IF freqHz > 20000 THEN freqHz = 20000

    IF durationMs < 1 THEN durationMs = soundDefaultMs
    IF durationMs < 10 THEN durationMs = 10
    IF durationMs > 5000 THEN durationMs = 5000

    IF soundDriverId = SOUND_DRIVER_ADLIB THEN
        IF SoundAdlibStartTone(freqHz, durationMs) <> 0 THEN EXIT SUB
    ELSEIF soundDriverId = SOUND_DRIVER_SBLASTER THEN
        IF SoundBlasterDmaStartTone(freqHz, durationMs) <> 0 THEN EXIT SUB
    END IF

    SoundPcSpeakerStartTone freqHz, durationMs
END SUB

SUB SoundServiceAt(BYVAL nowTime AS DOUBLE)
    IF soundPcmActive <> 0 AND soundPcmPaused = 0 THEN
        IF soundActive = 0 THEN
            IF SoundPcmStartNextChunk() <> 0 THEN EXIT SUB
        ELSEIF soundDurationSeconds <= 0 THEN
            IF SoundPcmStartNextChunk() <> 0 THEN EXIT SUB
        ELSEIF TimerElapsedSecondsAt(soundStartTime, nowTime) >= soundDurationSeconds THEN
            IF SoundPcmStartNextChunk() <> 0 THEN EXIT SUB
        ELSE
            EXIT SUB
        END IF
    END IF

    IF soundActive = 0 THEN EXIT SUB
    IF soundDurationSeconds <= 0 THEN
        SoundFinishPlayback
        EXIT SUB
    END IF
    IF TimerElapsedSecondsAt(soundStartTime, nowTime) >= soundDurationSeconds THEN SoundFinishPlayback
END SUB

' ---------------------------
' Screensaver idle tracking and saver launching
' ---------------------------

FUNCTION TimerElapsedSecondsAt(BYVAL startTime AS DOUBLE, BYVAL nowTime AS DOUBLE) AS DOUBLE
    DIM elapsedTime AS DOUBLE
    DIM backwardDelta AS DOUBLE

    elapsedTime = nowTime - startTime
    IF elapsedTime < 0 THEN
        backwardDelta = startTime - nowTime

        ' A cached event-loop timestamp can be older than an activity timestamp
        ' captured later in the same input pass. That is not midnight rollover
        ' and must not become almost 24 hours of false idle time.
        IF backwardDelta < 60 THEN RETURN 0

        elapsedTime = elapsedTime + 86400
    END IF
    RETURN elapsedTime
END FUNCTION

FUNCTION TimerElapsedSeconds(BYVAL startTime AS DOUBLE) AS DOUBLE
    RETURN TimerElapsedSecondsAt(startTime, TIMER)
END FUNCTION

SUB ResetScreensaverIdleAt(BYVAL nowTime AS DOUBLE)
    screenSaverLastInputTime = nowTime
    screenSaverLastIdleCheck = 0

    ' A reset can happen inside a nested app/screensaver loop while the outer
    ' event-loop timestamp is stale. Skip the next idle probe so that stale
    ' timestamp cannot relaunch the saver immediately after returning.
    screenSaverSkipNextIdleCheck = -1
END SUB

SUB ResetScreensaverIdle()
    ResetScreensaverIdleAt TIMER
END SUB

SUB RefreshScreensaverLaunchConfig(BYVAL forceRefresh AS INTEGER)
    DIM enabledText AS STRING
    DIM timeoutMinutes AS DOUBLE

    ' Refresh only when explicitly requested by startup, launch fallback, or a service notification.
    enabledText = UCASE$(TRIM$(ReadCfgValue(PATH_SCRNSAVRCFG, "ENABLED", "NO")))
    IF enabledText = "YES" OR enabledText = "ON" OR enabledText = "TRUE" OR enabledText = "1" THEN
        screenSaverConfigEnabled = -1
    ELSE
        screenSaverConfigEnabled = 0
    END IF

    timeoutMinutes = VAL(ReadCfgValue(PATH_SCRNSAVRCFG, "TIMEOUT", "0"))
    IF timeoutMinutes > 0 THEN
        screenSaverConfigTimeoutSeconds = timeoutMinutes * 60
    ELSE
        screenSaverConfigTimeoutSeconds = 0
    END IF

    screenSaverConfigProgram = TRIM$(ReadCfgValue(PATH_SCRNSAVRCFG, "PROGRAM", ""))
END SUB

FUNCTION ResolveScreensaverProgramPath(BYVAL programText AS STRING) AS STRING
    DIM saverDir AS STRING
    DIM programPath AS STRING

    programPath = NormalizePath(TRIM$(programText))
    IF programPath = "" THEN RETURN ""

    IF INSTR(programPath, "\") > 0 OR INSTR(programPath, ":") > 0 THEN RETURN programPath

    saverDir = NormalizePath(TRIM$(ReadCfgValue(PATH_SCRNSAVRCFG, "SAVER_DIR", "")))
    IF saverDir = "" THEN RETURN ""
    RETURN JoinPath(saverDir, programPath)
END FUNCTION

FUNCTION LaunchConfiguredScreensaver() AS INTEGER
    DIM programText AS STRING
    DIM programPath AS STRING
    DIM runDir AS STRING
    DIM runFile AS STRING
    DIM oldDir AS STRING

    IF screenSaverLaunching <> 0 THEN RETURN 0

    programText = TRIM$(screenSaverConfigProgram)
    IF programText = "" THEN
        RefreshScreensaverLaunchConfig -1
        programText = TRIM$(screenSaverConfigProgram)
    END IF
    programPath = ResolveScreensaverProgramPath(programText)
    IF programPath = "" THEN RETURN 0
    IF DIR(programPath) = "" THEN RETURN 0

    screenSaverLaunching = -1

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN SyncLayoutWindowFromGlobals activeLayoutWindow
    END IF

    startMenuOpen = 0
    launchCtxOpen = 0
    SoundStop

    SCREEN 0
    WIDTH 80, 25
    COLOR 7, 0
    CLS

    oldDir = CURDIR
    runDir = ParentPath(programPath)
    runFile = FileNameOnly(programPath)

    IF runDir <> "" AND DIR(runDir, &H10) <> "" THEN
        CHDIR runDir
        SHELL runFile
        CHDIR oldDir
    ELSE
        SHELL programPath
    END IF

    ResumeGuiAfterScreensaver
    ResetScreensaverIdle
    screenSaverLaunching = 0
    RETURN -1
END FUNCTION

FUNCTION CheckScreensaverIdleAt(BYVAL nowTime AS DOUBLE) AS INTEGER
    IF screenSaverConfigEnabled = 0 THEN RETURN 0
    IF screenSaverConfigTimeoutSeconds <= 0 THEN RETURN 0

    IF screenSaverSkipNextIdleCheck <> 0 THEN
        screenSaverSkipNextIdleCheck = 0
        screenSaverLastIdleCheck = nowTime
        RETURN 0
    END IF

    IF screenSaverLastIdleCheck <> 0 THEN
        IF TimerElapsedSecondsAt(screenSaverLastIdleCheck, nowTime) < .25 THEN RETURN 0
    END IF
    screenSaverLastIdleCheck = nowTime

    IF TimerElapsedSecondsAt(screenSaverLastInputTime, nowTime) < screenSaverConfigTimeoutSeconds THEN RETURN 0

    IF LaunchConfiguredScreensaver() <> 0 THEN RETURN -1
    ResetScreensaverIdle
    RETURN 0
END FUNCTION

FUNCTION CheckScreensaverIdle() AS INTEGER
    RETURN CheckScreensaverIdleAt(TIMER)
END FUNCTION


' ---------------------------
' APP layout parser
' ---------------------------

SUB LoadAppLayout(BYVAL appPath AS STRING)
    DIM f AS INTEGER
    DIM lineIn AS STRING
    DIM section AS STRING
    DIM rawSection AS STRING
    DIM profileName AS STRING
    DIM cur AS UIElement
    DIM p AS INTEGER
    DIM k AS STRING
    DIM v AS STRING
    DIM i AS INTEGER
    DIM eventsCapture AS INTEGER
    DIM sectionIsElement AS INTEGER

    ClearComboItemCache
    RtClearPendingAppEvents
    uiLoadedLayoutHasPageFiles = 0
    eventsCapture = 0
    uiCount = 0
    uiNameCacheValid = 0
    section = ""
    sectionIsElement = 0
    uiWinX = 20
    uiWinY = 20
    uiWinW = 300
    uiWinH = 180
    uiDesignW = 300
    uiDesignH = 180
    uiTitle = ""

    cur.kind = ""
    cur.text = ""
    cur.x = 0
    cur.y = 0
    cur.w = 0
    cur.h = 0
    cur.page = ""
    cur.state = 0
    cur.name = ""
    cur.action = ""
    cur.enterAction = ""
    cur.escAction = ""
    cur.keyAction = ""
    cur.keyCapture = 0
    cur.groupName = ""
    cur.bindFile = ""
    cur.bindSection = ""
    cur.bindKey = ""
    cur.bindValue = ""
    cur.sourceDir = ""
    cur.sourceMask = ""
    cur.sourceKind = ""
    cur.sourceIndex = ""
    cur.valuePrefix = ""
    cur.sourceControl = ""
    cur.modeGroup = ""
    cur.dropRows = 0
    cur.dropW = 0
    cur.sourceItems = ""
    cur.defaultValue = ""
    cur.maxLen = 0
    cur.noEdit = 0
    cur.multiSelect = 0
    cur.drawStyle = ""
    cur.baseX = 0
    cur.baseY = 0
    cur.baseW = 0
    cur.baseH = 0
    cur.growW = 0
    cur.growH = 0
    cur.moveX = 0
    cur.moveY = 0
    cur.wordWrap = 0
    NormalizeUiElementKeys cur

    f = FREEFILE
    appPath = NormalizePath(appPath)
    profileName = LayoutProfile(appPath)
    appPath = LayoutFilePath(appPath)
    uiLayoutAppPath = appPath
    IF OPEN(appPath FOR INPUT AS #f) <> 0 THEN EXIT SUB

    DO WHILE NOT EOF(f)
        LINE INPUT #f, lineIn
        lineIn = TRIM$(lineIn)

        ' Runtime event rows live in the same APP/SYS file this parser already reads.
        ' Collect them during this pass so app open does not reopen and rescan the file.
        IF LEFT$(lineIn, 1) = "[" AND RIGHT$(lineIn, 1) = "]" THEN
            IF UCASE$(lineIn) = "[EVENTS]" THEN
                eventsCapture = -1
            ELSEIF eventsCapture <> 0 THEN
                eventsCapture = 0
            END IF
        ELSEIF eventsCapture <> 0 THEN
            RtAppendPendingAppEventLine lineIn
        END IF

        IF lineIn = "" THEN
        ELSEIF LEFT$(lineIn, 1) = "#" OR LEFT$(lineIn, 1) = ";" THEN
        ELSEIF LEFT$(lineIn, 1) = "[" AND RIGHT$(lineIn, 1) = "]" THEN
            IF sectionIsElement <> 0 THEN
                IF uiCount < 192 THEN
                    IF cur.text <> "" OR cur.w <> 0 OR cur.h <> 0 OR cur.x <> 0 OR cur.y <> 0 THEN
                        uiCount = uiCount + 1
                        cur.baseX = cur.x
                        cur.baseY = cur.y
                        cur.baseW = cur.w
                        cur.baseH = cur.h
                        uiElems(uiCount) = cur
                        uiElems(uiCount).kind = section
                        NormalizeUiElementKeys uiElems(uiCount)
                    END IF
                END IF
            END IF

            rawSection = UCASE$(MID$(lineIn, 2, LEN(lineIn) - 2))
            section = rawSection
            IF profileName <> "" THEN
                IF rawSection = profileName THEN
                    section = ""
                ELSEIF LEFT$(rawSection, LEN(profileName) + 1) = profileName + "." THEN
                    section = MID$(rawSection, LEN(profileName) + 2)
                ELSE
                    section = "__SKIP__"
                END IF
            END IF
            sectionIsElement = LayoutParserSectionIsElement(section)

            cur.kind = ""
            cur.text = ""
            cur.x = 0
            cur.y = 0
            cur.w = 0
            cur.h = 0
            cur.page = ""
            cur.state = 0
            cur.name = ""
            cur.action = ""
            cur.groupName = ""
            cur.bindFile = ""
            cur.bindSection = ""
            cur.bindKey = ""
            cur.bindValue = ""
            cur.sourceDir = ""
            cur.sourceMask = ""
            cur.sourceIndex = ""
            cur.valuePrefix = ""
            cur.sourceControl = ""
            cur.modeGroup = ""
            cur.dropRows = 0
            cur.dropW = 0
            cur.sourceItems = ""
            cur.defaultValue = ""
            cur.maxLen = 0
            cur.noEdit = 0
            cur.multiSelect = 0
            cur.drawStyle = ""
            cur.baseX = 0
            cur.baseY = 0
            cur.baseW = 0
            cur.baseH = 0
            cur.growW = 0
            cur.growH = 0
            cur.moveX = 0
            cur.moveY = 0
            cur.wordWrap = 0
            NormalizeUiElementKeys cur
        ELSEIF section <> "__SKIP__" THEN
            ' Profiled SYS layouts skip every unrelated section.
            ' Do not spend time splitting keys and values that cannot be used here.
            p = INSTR(lineIn, "=")
            IF p > 0 THEN
                k = UCASE$(TRIM$(LEFT$(lineIn, p - 1)))
                v = TRIM$(MID$(lineIn, p + 1))

                IF section = "" THEN
                    IF k = "TITLE" THEN uiTitle = v
                    IF k = "RESIZABLE" THEN
                        IF UCASE$(TRIM$(v)) = "0" THEN
                            uiResizable = 0
                        ELSE
                            uiResizable = -1
                        END IF
                    END IF
                    IF k = "NO_SCROLLBARS" THEN
                        IF UCASE$(TRIM$(v)) = "1" OR UCASE$(TRIM$(v)) = "YES" OR UCASE$(TRIM$(v)) = "TRUE" THEN uiNoScrollbars = -1
                    END IF
                    IF LEFT$(k, 10) = "PAGE_FILE_" THEN
                        IF TRIM$(v) <> "" THEN uiLoadedLayoutHasPageFiles = -1
                    END IF
                    IF k = "SCROLLBARS" THEN
                        IF UCASE$(TRIM$(v)) = "0" OR UCASE$(TRIM$(v)) = "NO" OR UCASE$(TRIM$(v)) = "FALSE" THEN uiNoScrollbars = -1
                    END IF
                ELSEIF section = "WINDOW" THEN
                    IF k = "X" THEN uiWinX = VAL(v)
                    IF k = "Y" THEN uiWinY = VAL(v)
                    IF k = "W" THEN uiWinW = VAL(v)
                    IF k = "H" THEN uiWinH = VAL(v)
                ELSEIF sectionIsElement <> 0 THEN
                    IF k = "TEXT" THEN cur.text = v
                    IF k = "X" THEN cur.x = VAL(v)
                    IF k = "Y" THEN cur.y = VAL(v)
                    IF k = "W" THEN cur.w = VAL(v)
                    IF k = "H" THEN cur.h = VAL(v)
                    IF k = "PAGE" THEN cur.page = v
                    IF k = "STATE" THEN cur.state = VAL(v)
                    IF k = "NAME" THEN cur.name = v
                    IF k = "ACTION" THEN cur.action = v
                    IF k = "ENTER_ACTION" OR k = "ON_ENTER" OR k = "SUBMIT_ACTION" THEN cur.enterAction = v
                    IF k = "ESC_ACTION" OR k = "ON_ESC" THEN cur.escAction = v
                    IF k = "KEY_ACTION" OR k = "ON_KEY" THEN cur.keyAction = v
                    IF k = "KEY_CAPTURE" OR k = "CAPTURE_KEYS" THEN cur.keyCapture = VAL(v)
                    IF k = "GROUP" THEN cur.groupName = v
                    IF k = "BIND_FILE" THEN cur.bindFile = ResolveAppBindFilePathFromFile(appPath, v)
                    IF k = "BIND_SECTION" THEN cur.bindSection = v
                    IF k = "BIND_KEY" THEN cur.bindKey = v
                    IF k = "BIND_VALUE" THEN cur.bindValue = v
                    IF k = "SOURCE_DIR" THEN cur.sourceDir = v
                    IF k = "SOURCE_MASK" THEN cur.sourceMask = v
                    IF k = "SOURCE_KIND" OR k = "SOURCE_TYPE" THEN cur.sourceKind = UCASE$(TRIM$(v))
                    IF k = "SOURCE_INDEX" OR k = "INDEX_FILE" THEN cur.sourceIndex = v
                    IF k = "VALUE_PREFIX" THEN cur.valuePrefix = v
                    IF k = "SOURCE_CONTROL" THEN cur.sourceControl = v
                    IF k = "MODE_GROUP" THEN cur.modeGroup = v
                    IF k = "DROP_ROWS" THEN cur.dropRows = VAL(v)
                    IF k = "DROP_W" OR k = "POPUP_W" THEN cur.dropW = VAL(v)
                    IF k = "SOURCE_ITEMS" THEN cur.sourceItems = v
                    IF k = "DEFAULT_VALUE" THEN cur.defaultValue = v
                    IF k = "MAXLEN" THEN cur.maxLen = VAL(v)
                    IF k = "READONLY" THEN cur.noEdit = VAL(v)
                    IF k = "NOEDIT" THEN cur.noEdit = VAL(v)
                    IF k = "MULTISELECT" THEN cur.multiSelect = VAL(v)
                    IF k = "DRAW_STYLE" THEN cur.drawStyle = UCASE$(v)
                    IF k = "STYLE" THEN cur.drawStyle = UCASE$(v)
                    IF k = "GROW_W" THEN cur.growW = VAL(v)
                    IF k = "GROW_H" THEN cur.growH = VAL(v)
                    IF k = "MOVE_X" THEN cur.moveX = VAL(v)
                    IF k = "ANCHOR_RIGHT" THEN cur.moveX = VAL(v)
                    IF k = "MOVE_Y" THEN cur.moveY = VAL(v)
                    IF k = "ANCHOR_BOTTOM" THEN cur.moveY = VAL(v)
                    IF k = "WORD_WRAP" THEN cur.wordWrap = VAL(v)
                END IF
            END IF
        END IF
    LOOP

    IF sectionIsElement <> 0 THEN
        IF uiCount < 192 THEN
            IF cur.text <> "" OR cur.w <> 0 OR cur.h <> 0 OR cur.x <> 0 OR cur.y <> 0 THEN
                uiCount = uiCount + 1
                cur.baseX = cur.x
                cur.baseY = cur.y
                cur.baseW = cur.w
                cur.baseH = cur.h
                uiElems(uiCount) = cur
                uiElems(uiCount).kind = section
                NormalizeUiElementKeys uiElems(uiCount)
            END IF
        END IF
    END IF

    CLOSE #f
    uiDesignW = uiWinW
    uiDesignH = uiWinH
    SelectTabFromBoundConfig
    IF uiLoadedLayoutHasPageFiles = 0 THEN InitBoundControlsFromConfig

    ' Only controls the current layout actually loaded can be copied into the new window slot.
    ' Do not clear unused editor slots during every app open.
    FOR i = 1 TO uiCount
        IF uiElems(i).kindId = UI_KIND_TEXTBOX THEN
            ResetEditorControlRuntimeState i, uiElems(i).text
            uiElems(i).text = uiEdit(i).txt
        ELSE
            ResetEditorControlRuntimeState i, ""
        END IF
    NEXT

    uiFocusIndex = 0
    uiCaretPos = 0
    uiScrollY = 0
    uiScrollX = 0
    uiCaretVisible = -1
    uiLastCaretBlink = TIMER
END SUB


' ---------------------------
' Textbox metrics, wrapped-line math, and caret navigation
' ---------------------------

FUNCTION TextboxIsMultiline(BYVAL elemIdx AS INTEGER) AS INTEGER
    IF elemIdx < 1 OR elemIdx > uiCount THEN RETURN 0
    IF uiElems(elemIdx).h > 22 THEN RETURN -1
    RETURN 0
END FUNCTION

FUNCTION TextboxWordWrap(BYVAL elemIdx AS INTEGER) AS INTEGER
    IF elemIdx < 1 OR elemIdx > uiCount THEN RETURN 0
    IF TextboxIsMultiline(elemIdx) = 0 THEN RETURN 0
    IF uiElems(elemIdx).wordWrap <> 0 THEN RETURN -1
    RETURN 0
END FUNCTION

FUNCTION TextboxLineCount(BYREF textValue AS STRING) AS INTEGER
    DIM lineCount AS INTEGER

    IF LEN(textValue) <= 0 THEN RETURN 1
    lineCount = TbCaretLine(textValue, LEN(textValue)) + 1
    IF lineCount < 1 THEN lineCount = 1
    RETURN lineCount
END FUNCTION

FUNCTION TextboxCharCodeAt(BYREF textValue AS STRING, BYVAL oneBasedPos AS INTEGER) AS INTEGER
    DIM textLen AS INTEGER
    DIM textPtr AS UBYTE PTR

    textLen = LEN(textValue)
    IF oneBasedPos < 1 OR oneBasedPos > textLen THEN RETURN 0

    textPtr = CAST(UBYTE PTR, STRPTR(textValue))
    RETURN textPtr[oneBasedPos - 1]
END FUNCTION

FUNCTION TextboxCharCodeIsWord(BYVAL chCode AS INTEGER) AS INTEGER
    IF chCode >= ASC("A") AND chCode <= ASC("Z") THEN RETURN -1
    IF chCode >= ASC("a") AND chCode <= ASC("z") THEN RETURN -1
    IF chCode >= ASC("0") AND chCode <= ASC("9") THEN RETURN -1
    IF chCode = ASC("_") THEN RETURN -1
    RETURN 0
END FUNCTION

FUNCTION TextboxVisibleCharCount(BYREF textValue AS STRING) AS INTEGER
    DIM i AS INTEGER
    DIM chCode AS INTEGER
    DIM countChars AS INTEGER
    DIM textLen AS INTEGER
    DIM textPtr AS UBYTE PTR

    textLen = LEN(textValue)
    IF textLen <= 0 THEN RETURN 0

    textPtr = CAST(UBYTE PTR, STRPTR(textValue))
    IF textPtr = 0 THEN RETURN 0

    countChars = 0
    FOR i = 0 TO textLen - 1
        chCode = textPtr[i]
        IF chCode <> 10 AND chCode <> 13 THEN countChars = countChars + 1
    NEXT

    RETURN countChars
END FUNCTION

SUB InvalidateTextboxMetrics(BYVAL elemIdx AS INTEGER)
    IF elemIdx < 1 OR elemIdx > 192 THEN EXIT SUB
    IF tbMetricCacheElem = elemIdx THEN
        tbMetricCacheValid = 0
        tbMetricCacheCharValid = 0
    END IF
    IF tbColsCacheElem = elemIdx THEN tbColsCacheValid = 0
END SUB

SUB EnsureTextboxMetrics(BYVAL elemIdx AS INTEGER, BYREF textValue AS STRING, BYVAL cols AS INTEGER)
    DIM winKey AS INTEGER
    DIM textLen AS INTEGER
    DIM wrapFlag AS INTEGER
    DIM startPos AS INTEGER
    DIM lineEnd AS INTEGER
    DIM nextPos AS INTEGER
    DIM countLines AS INTEGER
    DIM scanIdx AS INTEGER
    DIM nextStart AS INTEGER
    DIM chCode AS INTEGER
    DIM textPtr AS UBYTE PTR

    IF elemIdx < 1 OR elemIdx > uiCount THEN EXIT SUB
    IF cols < 1 THEN cols = 1

    winKey = activeLayoutWindow
    IF drawLayoutWindow >= LBOUND(layoutWindows) AND drawLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(drawLayoutWindow).used <> 0 THEN winKey = drawLayoutWindow
    END IF

    textLen = LEN(textValue)
    wrapFlag = TextboxWordWrap(elemIdx)

    IF tbMetricCacheValid <> 0 THEN
        IF tbMetricCacheWin = winKey AND tbMetricCacheElem = elemIdx AND _
           tbMetricCacheLen = textLen AND tbMetricCacheCols = cols AND _
           tbMetricCacheWrap = wrapFlag THEN EXIT SUB
    END IF

    tbMetricCacheStartCount = 0
    tbMetricLineStarts(0) = 0

    IF textLen <= 0 THEN
        countLines = 1
    ELSEIF wrapFlag = 0 THEN
        ' Plain multiline boxes are common and do not need repeated TbLineEndPos /
        ' TbNextLineStart helper calls. Build the line-start table in one pointer scan.
        textPtr = CAST(UBYTE PTR, STRPTR(textValue))
        IF textPtr = 0 THEN
            countLines = 1
        ELSE
            countLines = 1
            scanIdx = 0
            DO WHILE scanIdx < textLen
                chCode = textPtr[scanIdx]
                IF chCode = 13 OR chCode = 10 THEN
                    nextStart = scanIdx + 1
                    IF chCode = 13 AND nextStart < textLen THEN
                        IF textPtr[nextStart] = 10 THEN nextStart = nextStart + 1
                    END IF
                    IF countLines <= UBOUND(tbMetricLineStarts) THEN tbMetricLineStarts(countLines) = nextStart
                    countLines = countLines + 1
                    scanIdx = nextStart
                ELSE
                    scanIdx = scanIdx + 1
                END IF
            LOOP
        END IF
    ELSE
        countLines = 0
        startPos = 0
        DO
            IF countLines <= UBOUND(tbMetricLineStarts) THEN tbMetricLineStarts(countLines) = startPos
            countLines = countLines + 1

            lineEnd = TbWrappedLineEndPos(textValue, startPos, cols)
            IF lineEnd >= textLen THEN EXIT DO
            nextPos = TbWrappedNextLineStart(textValue, startPos, lineEnd, cols)

            IF nextPos <= startPos THEN EXIT DO
            startPos = nextPos
        LOOP
        IF countLines < 1 THEN countLines = 1
    END IF

    tbMetricCacheValid = -1
    tbMetricCacheWin = winKey
    tbMetricCacheElem = elemIdx
    tbMetricCacheLen = textLen
    tbMetricCacheCols = cols
    tbMetricCacheWrap = wrapFlag
    tbMetricCacheLineCount = countLines
    tbMetricCacheCharCount = 0
    tbMetricCacheCharValid = 0
    tbMetricCacheStartCount = countLines
END SUB

FUNCTION TextboxMetricLineCount(BYVAL elemIdx AS INTEGER, BYREF textValue AS STRING, BYVAL cols AS INTEGER) AS INTEGER
    EnsureTextboxMetrics elemIdx, textValue, cols
    IF tbMetricCacheValid <> 0 AND tbMetricCacheElem = elemIdx THEN RETURN tbMetricCacheLineCount
    IF TextboxWordWrap(elemIdx) <> 0 THEN RETURN TbWrappedLineCount(textValue, cols)
    RETURN TextboxLineCount(textValue)
END FUNCTION

FUNCTION TextboxMetricCharCount(BYVAL elemIdx AS INTEGER, BYREF textValue AS STRING, BYVAL cols AS INTEGER) AS INTEGER
    EnsureTextboxMetrics elemIdx, textValue, cols
    IF tbMetricCacheValid <> 0 AND tbMetricCacheElem = elemIdx THEN
        IF tbMetricCacheCharValid = 0 THEN
            tbMetricCacheCharCount = TextboxVisibleCharCount(textValue)
            tbMetricCacheCharValid = -1
        END IF
        RETURN tbMetricCacheCharCount
    END IF
    RETURN TextboxVisibleCharCount(textValue)
END FUNCTION

FUNCTION TextboxMetricLineStart(BYVAL elemIdx AS INTEGER, BYREF textValue AS STRING, BYVAL targetLine AS INTEGER, BYVAL cols AS INTEGER) AS INTEGER
    EnsureTextboxMetrics elemIdx, textValue, cols
    IF targetLine < 0 THEN targetLine = 0
    IF tbMetricCacheValid <> 0 AND tbMetricCacheElem = elemIdx THEN
        IF targetLine >= tbMetricCacheLineCount THEN RETURN LEN(textValue)
        IF targetLine <= UBOUND(tbMetricLineStarts) THEN RETURN tbMetricLineStarts(targetLine)
    END IF
    IF TextboxWordWrap(elemIdx) <> 0 THEN RETURN TbWrappedLineStartForLine(textValue, targetLine, cols)
    RETURN TbLineStartForLine(textValue, targetLine)
END FUNCTION


FUNCTION TextboxMetricCaretLine(BYVAL elemIdx AS INTEGER, BYREF textValue AS STRING, BYVAL caretPos AS INTEGER, BYVAL cols AS INTEGER) AS INTEGER
    DIM lowLine AS INTEGER
    DIM highLine AS INTEGER
    DIM midLine AS INTEGER
    DIM midStart AS INTEGER
    DIM nextStart AS INTEGER
    DIM lastLine AS INTEGER

    IF elemIdx < 1 OR elemIdx > uiCount THEN RETURN 0
    IF cols < 1 THEN cols = 1
    IF caretPos < 0 THEN caretPos = 0
    IF caretPos > LEN(textValue) THEN caretPos = LEN(textValue)

    EnsureTextboxMetrics elemIdx, textValue, cols

    ' The metrics pass already built every visible wrapped/plain line start.
    ' Use that index to find the caret line instead of rescanning text from byte zero.
    IF tbMetricCacheValid <> 0 AND tbMetricCacheElem = elemIdx THEN
        IF tbMetricCacheLineCount < 1 THEN RETURN 0
        lastLine = tbMetricCacheLineCount - 1
        IF lastLine < 0 THEN lastLine = 0
        IF caretPos >= LEN(textValue) THEN RETURN lastLine

        lowLine = 0
        highLine = lastLine

        DO WHILE lowLine <= highLine
            midLine = (lowLine + highLine) \ 2
            midStart = tbMetricLineStarts(midLine)

            IF midLine < lastLine THEN
                nextStart = tbMetricLineStarts(midLine + 1)
            ELSE
                nextStart = LEN(textValue) + 1
            END IF

            IF caretPos < midStart THEN
                highLine = midLine - 1
            ELSEIF caretPos >= nextStart THEN
                lowLine = midLine + 1
            ELSE
                RETURN midLine
            END IF
        LOOP

        IF highLine < 0 THEN RETURN 0
        IF highLine > lastLine THEN RETURN lastLine
        RETURN highLine
    END IF

    IF TextboxWordWrap(elemIdx) <> 0 THEN RETURN TbWrappedCaretLine(textValue, caretPos, cols)
    RETURN TbCaretLine(textValue, caretPos)
END FUNCTION

FUNCTION TextboxMetricColumnAtPos(BYVAL elemIdx AS INTEGER, BYREF textValue AS STRING, BYVAL caretPos AS INTEGER, BYVAL cols AS INTEGER) AS INTEGER
    DIM lineNum AS INTEGER
    DIM lineStart AS INTEGER
    DIM colNum AS INTEGER

    IF cols < 1 THEN cols = 1
    IF caretPos < 0 THEN caretPos = 0
    IF caretPos > LEN(textValue) THEN caretPos = LEN(textValue)

    lineNum = TextboxMetricCaretLine(elemIdx, textValue, caretPos, cols)
    lineStart = TextboxMetricLineStart(elemIdx, textValue, lineNum, cols)

    colNum = caretPos - lineStart
    IF colNum < 0 THEN colNum = 0
    IF TextboxWordWrap(elemIdx) <> 0 THEN
        IF colNum > cols THEN colNum = cols
    END IF

    RETURN colNum
END FUNCTION

FUNCTION TextboxMetricPosFromLineCol(BYVAL elemIdx AS INTEGER, BYREF textValue AS STRING, BYVAL targetLine AS INTEGER, BYVAL colNum AS INTEGER, BYVAL cols AS INTEGER) AS INTEGER
    DIM lineStart AS INTEGER
    DIM lineEnd AS INTEGER

    IF cols < 1 THEN cols = 1
    IF targetLine < 0 THEN targetLine = 0
    IF colNum < 0 THEN colNum = 0

    lineStart = TextboxMetricLineStart(elemIdx, textValue, targetLine, cols)
    IF TextboxWordWrap(elemIdx) <> 0 THEN
        lineEnd = TbWrappedLineEndPos(textValue, lineStart, cols)
    ELSE
        lineEnd = TbLineEndPos(textValue, lineStart)
    END IF

    IF lineEnd < lineStart THEN lineEnd = lineStart
    IF lineEnd > LEN(textValue) THEN lineEnd = LEN(textValue)
    IF colNum > lineEnd - lineStart THEN colNum = lineEnd - lineStart

    RETURN lineStart + colNum
END FUNCTION

FUNCTION TextboxDrawScrollWindow() AS INTEGER
    ' Textbox drawing can occur for inactive windows while a dialog is active.
    ' Use the window being drawn so its own scroll position controls the view.
    IF drawLayoutWindow >= LBOUND(layoutWindows) AND drawLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(drawLayoutWindow).used <> 0 THEN RETURN drawLayoutWindow
    END IF

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN RETURN activeLayoutWindow
    END IF

    RETURN 0
END FUNCTION

SUB ScrollActiveTextboxPositionIntoView(BYVAL elemIdx AS INTEGER, BYVAL textPos AS INTEGER)
    DIM cols AS INTEGER
    DIM rows AS INTEGER
    DIM lineCount AS INTEGER
    DIM targetLine AS INTEGER
    DIM topLine AS INTEGER
    DIM maxTop AS INTEGER

    IF activeLayoutWindow < LBOUND(layoutWindows) OR activeLayoutWindow > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(activeLayoutWindow).used = 0 THEN EXIT SUB
    IF elemIdx < 1 OR elemIdx > uiCount THEN EXIT SUB
    IF uiElems(elemIdx).kindId <> UI_KIND_TEXTBOX THEN EXIT SUB
    IF TextboxIsMultiline(elemIdx) = 0 THEN EXIT SUB

    cols = TextboxCols(elemIdx)
    rows = TextboxRows(elemIdx)
    IF cols < 1 THEN cols = 1
    IF rows < 1 THEN rows = 1

    IF textPos < 0 THEN textPos = 0
    IF textPos > LEN(uiElems(elemIdx).text) THEN textPos = LEN(uiElems(elemIdx).text)

    lineCount = TextboxMetricLineCount(elemIdx, uiElems(elemIdx).text, cols)
    IF lineCount < 1 THEN lineCount = 1

    maxTop = lineCount - rows
    IF maxTop < 0 THEN maxTop = 0

    targetLine = TextboxMetricCaretLine(elemIdx, uiElems(elemIdx).text, textPos, cols)
    IF targetLine < 0 THEN targetLine = 0
    IF targetLine > lineCount - 1 THEN targetLine = lineCount - 1

    topLine = ClampScrollPos(comboScrollTop(activeLayoutWindow, elemIdx), maxTop)

    ' Find/replace changes the selection without normal caret navigation.
    ' Keep the matching line visible by adjusting only this textbox scroll slot.
    IF targetLine < topLine THEN
        topLine = targetLine
    ELSEIF targetLine >= topLine + rows THEN
        topLine = targetLine - rows + 1
    END IF

    comboScrollTop(activeLayoutWindow, elemIdx) = ClampScrollPos(topLine, maxTop)
    MarkLayoutDirtyElement activeLayoutWindow, elemIdx
    MarkLayoutWindowVisualDirty activeLayoutWindow
END SUB

FUNCTION TextboxLineCountExceedsRows(BYREF textValue AS STRING, BYVAL rows AS INTEGER) AS INTEGER
    DIM scanIdx AS INTEGER
    DIM countLines AS INTEGER
    DIM chCode AS INTEGER
    DIM textLen AS INTEGER
    DIM textPtr AS UBYTE PTR

    IF rows < 1 THEN rows = 1
    textLen = LEN(textValue)
    IF textLen <= 0 THEN RETURN 0

    textPtr = CAST(UBYTE PTR, STRPTR(textValue))
    IF textPtr = 0 THEN RETURN 0

    countLines = 1
    scanIdx = 0
    DO WHILE scanIdx < textLen
        chCode = textPtr[scanIdx]
        IF chCode = 13 OR chCode = 10 THEN
            countLines = countLines + 1
            IF countLines > rows THEN RETURN -1
            IF chCode = 13 AND scanIdx + 1 < textLen THEN
                IF textPtr[scanIdx + 1] = 10 THEN scanIdx = scanIdx + 1
            END IF
        END IF
        scanIdx = scanIdx + 1
    LOOP

    RETURN 0
END FUNCTION

FUNCTION TbWrappedLineCountExceedsRows(BYREF textIn AS STRING, BYVAL cols AS INTEGER, BYVAL rows AS INTEGER) AS INTEGER
    DIM countLines AS INTEGER
    DIM startPos AS INTEGER
    DIM lineEnd AS INTEGER
    DIM nextPos AS INTEGER
    DIM textLen AS INTEGER

    IF rows < 1 THEN rows = 1
    IF cols < 1 THEN cols = 1
    textLen = LEN(textIn)
    IF textLen <= 0 THEN RETURN 0

    countLines = 0
    startPos = 0
    DO
        countLines = countLines + 1
        IF countLines > rows THEN RETURN -1
        lineEnd = TbWrappedLineEndPos(textIn, startPos, cols)
        IF lineEnd >= textLen THEN EXIT DO
        nextPos = TbWrappedNextLineStart(textIn, startPos, lineEnd, cols)
        IF nextPos <= startPos THEN EXIT DO
        startPos = nextPos
    LOOP

    RETURN 0
END FUNCTION

FUNCTION TextStatsLabelText(BYVAL elemIdx AS INTEGER) AS STRING
    DIM sourceIdx AS INTEGER
    DIM sourceName AS STRING
    DIM lineCount AS INTEGER
    DIM charCount AS INTEGER
    DIM caretPos AS INTEGER
    DIM currentLine AS INTEGER
    DIM statsText AS STRING
    DIM suffixText AS STRING
    DIM sourceCols AS INTEGER
    DIM sourceLen AS INTEGER

    IF elemIdx < 1 OR elemIdx > uiCount THEN RETURN ""

    sourceName = TRIM$(uiElems(elemIdx).sourceControl)
    IF sourceName = "" THEN RETURN RTRIM$(uiElems(elemIdx).text)

    sourceIdx = GetControlIndexByName(sourceName)
    IF sourceIdx < 1 OR sourceIdx > uiCount THEN RETURN RTRIM$(uiElems(elemIdx).text)
    IF uiElems(sourceIdx).kindId <> UI_KIND_TEXTBOX THEN RETURN RTRIM$(uiElems(elemIdx).text)

    sourceCols = TextboxCols(sourceIdx)
    sourceLen = LEN(uiElems(sourceIdx).text)
    lineCount = TextboxMetricLineCount(sourceIdx, uiElems(sourceIdx).text, sourceCols)
    charCount = TextboxMetricCharCount(sourceIdx, uiElems(sourceIdx).text, sourceCols)

    caretPos = uiEdit(sourceIdx).curPos
    IF sourceIdx = uiFocusIndex THEN caretPos = uiCaretPos
    IF caretPos < 0 THEN caretPos = 0
    IF caretPos > sourceLen THEN caretPos = sourceLen

    currentLine = TextboxMetricCaretLine(sourceIdx, uiElems(sourceIdx).text, caretPos, sourceCols) + 1
    IF currentLine < 1 THEN currentLine = 1
    IF currentLine > lineCount THEN currentLine = lineCount

    statsText = "Line:  " + LTRIM$(STR$(currentLine)) + "  Of  " + LTRIM$(STR$(lineCount)) + ":  Characters:  " + LTRIM$(STR$(charCount))
    suffixText = TRIM$(uiElems(elemIdx).text)
    IF suffixText <> "" THEN statsText = statsText + "  " + suffixText

    RETURN statsText
END FUNCTION

SUB MarkTextStatsLabelsDirtyForSource(BYVAL winIdx AS INTEGER, BYVAL sourceElemIdx AS INTEGER)
    DIM sourceName AS STRING
    DIM i AS INTEGER

    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(winIdx).used = 0 THEN EXIT SUB
    IF sourceElemIdx < 1 OR sourceElemIdx > uiCount THEN EXIT SUB

    sourceName = UCASE$(TRIM$(uiElems(sourceElemIdx).name))
    IF sourceName = "" THEN EXIT SUB

    FOR i = 1 TO uiCount
        IF uiElems(i).kindId = UI_KIND_LABEL THEN
            IF uiElems(i).modeId = UI_MODE_TEXT_STATS THEN
                IF uiElems(i).sourceControlKey = sourceName THEN
                    layoutTextStatsCacheValid(winIdx, i) = 0
                    layoutTextStatsCacheText(winIdx, i) = ""
                    MarkLayoutDirtyElement winIdx, i
                END IF
            END IF
        END IF
    NEXT
END SUB

FUNCTION TbWrappedLineEndPos(BYREF textIn AS STRING, BYVAL startPos AS INTEGER, BYVAL cols AS INTEGER) AS INTEGER
    DIM maxEnd AS INTEGER
    DIM scanPos AS INTEGER
    DIM lastSpace AS INTEGER
    DIM chCode AS INTEGER
    DIM textLen AS INTEGER
    DIM textPtr AS UBYTE PTR

    textLen = LEN(textIn)
    IF startPos < 0 THEN startPos = 0
    IF startPos > textLen THEN startPos = textLen
    IF cols < 1 THEN cols = 1

    maxEnd = startPos + cols
    IF maxEnd > textLen THEN maxEnd = textLen

    textPtr = CAST(UBYTE PTR, STRPTR(textIn))
    IF textPtr = 0 THEN RETURN maxEnd

    lastSpace = -1
    scanPos = startPos
    DO WHILE scanPos < maxEnd
        chCode = textPtr[scanPos]
        IF chCode = 13 OR chCode = 10 THEN RETURN scanPos
        IF chCode = 32 OR chCode = 9 THEN lastSpace = scanPos + 1
        scanPos = scanPos + 1
    LOOP

    IF maxEnd >= textLen THEN RETURN textLen
    IF lastSpace > startPos THEN RETURN lastSpace
    RETURN maxEnd
END FUNCTION

FUNCTION TbWrappedNextLineStart(BYREF textIn AS STRING, BYVAL startPos AS INTEGER, BYVAL lineEnd AS INTEGER, BYVAL cols AS INTEGER) AS INTEGER
    DIM nextPos AS INTEGER
    DIM nextCode AS INTEGER
    DIM textLen AS INTEGER
    DIM textPtr AS UBYTE PTR

    textLen = LEN(textIn)
    IF startPos < 0 THEN startPos = 0
    IF startPos > textLen THEN startPos = textLen
    IF lineEnd < startPos THEN lineEnd = startPos
    IF lineEnd > textLen THEN lineEnd = textLen

    textPtr = CAST(UBYTE PTR, STRPTR(textIn))
    IF textPtr = 0 THEN RETURN lineEnd

    IF lineEnd < textLen THEN
        nextCode = textPtr[lineEnd]
        IF nextCode <> 13 AND nextCode <> 10 THEN
            nextPos = lineEnd
            DO WHILE nextPos < textLen
                nextCode = textPtr[nextPos]
                IF nextCode = 13 OR nextCode = 10 THEN EXIT DO
                IF nextCode <> 32 AND nextCode <> 9 THEN EXIT DO
                nextPos = nextPos + 1
            LOOP
            IF nextPos <= startPos THEN nextPos = startPos + 1
            IF nextPos > textLen THEN nextPos = textLen
            RETURN nextPos
        END IF
    END IF

    RETURN TbNextLineStart(textIn, lineEnd)
END FUNCTION

FUNCTION TbWrappedLineCount(BYREF textIn AS STRING, BYVAL cols AS INTEGER) AS INTEGER
    DIM countLines AS INTEGER
    DIM startPos AS INTEGER
    DIM lineEnd AS INTEGER
    DIM nextPos AS INTEGER
    DIM textLen AS INTEGER

    IF cols < 1 THEN cols = 1
    textLen = LEN(textIn)
    IF textLen <= 0 THEN RETURN 1

    countLines = 0
    startPos = 0
    DO
        countLines = countLines + 1
        lineEnd = TbWrappedLineEndPos(textIn, startPos, cols)
        IF lineEnd >= textLen THEN EXIT DO
        nextPos = TbWrappedNextLineStart(textIn, startPos, lineEnd, cols)
        IF nextPos <= startPos THEN EXIT DO
        startPos = nextPos
    LOOP

    IF countLines < 1 THEN countLines = 1
    RETURN countLines
END FUNCTION

FUNCTION TbWrappedLineStartForLine(BYREF textIn AS STRING, BYVAL targetLine AS INTEGER, BYVAL cols AS INTEGER) AS INTEGER
    DIM lineNum AS INTEGER
    DIM startPos AS INTEGER
    DIM lineEnd AS INTEGER
    DIM nextPos AS INTEGER
    DIM textLen AS INTEGER

    IF targetLine < 0 THEN targetLine = 0
    IF cols < 1 THEN cols = 1
    textLen = LEN(textIn)
    startPos = 0
    lineNum = 0

    DO WHILE lineNum < targetLine AND startPos < textLen
        lineEnd = TbWrappedLineEndPos(textIn, startPos, cols)
        nextPos = TbWrappedNextLineStart(textIn, startPos, lineEnd, cols)
        IF nextPos <= startPos THEN EXIT DO
        startPos = nextPos
        lineNum = lineNum + 1
    LOOP

    IF startPos > textLen THEN startPos = textLen
    RETURN startPos
END FUNCTION

FUNCTION TbWrappedCaretLine(BYREF textIn AS STRING, BYVAL caretPos AS INTEGER, BYVAL cols AS INTEGER) AS INTEGER
    DIM lineNum AS INTEGER
    DIM startPos AS INTEGER
    DIM lineEnd AS INTEGER
    DIM nextPos AS INTEGER
    DIM textLen AS INTEGER

    IF cols < 1 THEN cols = 1
    textLen = LEN(textIn)
    IF caretPos < 0 THEN caretPos = 0
    IF caretPos > textLen THEN caretPos = textLen

    startPos = 0
    lineNum = 0

    DO
        lineEnd = TbWrappedLineEndPos(textIn, startPos, cols)
        IF caretPos <= lineEnd THEN RETURN lineNum
        IF lineEnd >= textLen THEN RETURN lineNum
        nextPos = TbWrappedNextLineStart(textIn, startPos, lineEnd, cols)
        IF nextPos <= startPos THEN RETURN lineNum
        startPos = nextPos
        lineNum = lineNum + 1
    LOOP
END FUNCTION

FUNCTION TbWrappedColumnAtPos(BYREF textIn AS STRING, BYVAL caretPos AS INTEGER, BYVAL cols AS INTEGER) AS INTEGER
    DIM lineNum AS INTEGER
    DIM startPos AS INTEGER
    DIM colNum AS INTEGER

    IF cols < 1 THEN cols = 1
    lineNum = TbWrappedCaretLine(textIn, caretPos, cols)
    startPos = TbWrappedLineStartForLine(textIn, lineNum, cols)
    colNum = caretPos - startPos
    IF colNum < 0 THEN colNum = 0
    IF colNum > cols THEN colNum = cols
    RETURN colNum
END FUNCTION

FUNCTION TbWrappedPosFromLineCol(BYREF textIn AS STRING, BYVAL targetLine AS INTEGER, BYVAL colNum AS INTEGER, BYVAL cols AS INTEGER) AS INTEGER
    DIM lineStart AS INTEGER
    DIM lineEnd AS INTEGER

    IF cols < 1 THEN cols = 1
    IF targetLine < 0 THEN targetLine = 0
    IF colNum < 0 THEN colNum = 0

    lineStart = TbWrappedLineStartForLine(textIn, targetLine, cols)
    lineEnd = TbWrappedLineEndPos(textIn, lineStart, cols)
    IF lineEnd < lineStart THEN lineEnd = lineStart
    IF lineEnd > LEN(textIn) THEN lineEnd = LEN(textIn)
    IF colNum > lineEnd - lineStart THEN colNum = lineEnd - lineStart

    RETURN lineStart + colNum
END FUNCTION

FUNCTION HandleTextboxNavigationKey(BYVAL elemIdx AS INTEGER, BYVAL keyIn AS STRING, BYREF ed AS EDSTATE, BYREF prefCol AS INTEGER, BYVAL shiftDown AS INTEGER, BYVAL ctrlDown AS INTEGER) AS INTEGER
    DIM extCode AS INTEGER
    DIM keyCode AS INTEGER
    DIM rawKeyCode AS INTEGER
    DIM cols AS INTEGER
    DIM rows AS INTEGER
    DIM lineCount AS INTEGER
    DIM lineNum AS INTEGER
    DIM lineStart AS INTEGER
    DIM colNum AS INTEGER
    DIM newPos AS INTEGER

    IF elemIdx < 1 OR elemIdx > uiCount THEN RETURN 0
    IF uiElems(elemIdx).kindKey <> "TEXTBOX" THEN RETURN 0
    IF TextboxIsMultiline(elemIdx) = 0 THEN RETURN 0

    extCode = -1
    IF LEN(keyIn) >= 2 THEN extCode = ASC(RIGHT$(keyIn, 1))

    IF extCode = -1 THEN
        IF MULTIKEY(71) THEN extCode = ASC("G")
        IF MULTIKEY(79) THEN extCode = ASC("O")
        IF MULTIKEY(72) THEN extCode = ASC("H")
        IF MULTIKEY(80) THEN extCode = ASC("P")
        IF MULTIKEY(75) THEN extCode = ASC("K")
        IF MULTIKEY(77) THEN extCode = ASC("M")
        IF MULTIKEY(73) THEN extCode = ASC("I")
        IF MULTIKEY(81) THEN extCode = ASC("Q")
    END IF

    IF extCode = -1 THEN RETURN 0

    rawKeyCode = extCode
    keyCode = rawKeyCode

    ' Extended Ctrl navigation scan codes overlap lowercase ASCII letters.
    ' Do not uppercase those scan codes or Ctrl+Left/Right/Home/End cannot match.
    IF rawKeyCode >= ASC("a") AND rawKeyCode <= ASC("z") THEN
        SELECT CASE rawKeyCode
        CASE 115, 116, 117, 119
            keyCode = rawKeyCode
        CASE ELSE
            keyCode = rawKeyCode - 32
        END SELECT
    END IF

    cols = TextboxCols(elemIdx)
    rows = TextboxRows(elemIdx)
    IF cols < 1 THEN cols = 1
    IF rows < 1 THEN rows = 1

    SELECT CASE keyCode
    CASE ASC("K")
        IF ctrlDown <> 0 THEN
            newPos = ed.curPos
            DO WHILE newPos > 0
                IF TextboxCharCodeIsWord(TextboxCharCodeAt(ed.txt, newPos)) <> 0 THEN EXIT DO
                newPos = newPos - 1
            LOOP
            DO WHILE newPos > 0
                IF TextboxCharCodeIsWord(TextboxCharCodeAt(ed.txt, newPos)) = 0 THEN EXIT DO
                newPos = newPos - 1
            LOOP
            Ed_MoveCaret ed, newPos, shiftDown
        ELSE
            Ed_MoveCaret ed, ed.curPos - 1, shiftDown
        END IF
        prefCol = -1
        RETURN -1

    CASE ASC("M")
        IF ctrlDown <> 0 THEN
            newPos = ed.curPos
            DO WHILE newPos < ed.txtLen
                IF TextboxCharCodeIsWord(TextboxCharCodeAt(ed.txt, newPos + 1)) = 0 THEN EXIT DO
                newPos = newPos + 1
            LOOP
            DO WHILE newPos < ed.txtLen
                IF TextboxCharCodeIsWord(TextboxCharCodeAt(ed.txt, newPos + 1)) <> 0 THEN EXIT DO
                newPos = newPos + 1
            LOOP
            Ed_MoveCaret ed, newPos, shiftDown
        ELSE
            Ed_MoveCaret ed, ed.curPos + 1, shiftDown
        END IF
        prefCol = -1
        RETURN -1

    CASE 115
        newPos = ed.curPos
        DO WHILE newPos > 0
            IF TextboxCharCodeIsWord(TextboxCharCodeAt(ed.txt, newPos)) <> 0 THEN EXIT DO
            newPos = newPos - 1
        LOOP
        DO WHILE newPos > 0
            IF TextboxCharCodeIsWord(TextboxCharCodeAt(ed.txt, newPos)) = 0 THEN EXIT DO
            newPos = newPos - 1
        LOOP
        Ed_MoveCaret ed, newPos, shiftDown
        prefCol = -1
        RETURN -1

    CASE 116
        newPos = ed.curPos
        DO WHILE newPos < ed.txtLen
            IF TextboxCharCodeIsWord(TextboxCharCodeAt(ed.txt, newPos + 1)) = 0 THEN EXIT DO
            newPos = newPos + 1
        LOOP
        DO WHILE newPos < ed.txtLen
            IF TextboxCharCodeIsWord(TextboxCharCodeAt(ed.txt, newPos + 1)) <> 0 THEN EXIT DO
            newPos = newPos + 1
        LOOP
        Ed_MoveCaret ed, newPos, shiftDown
        prefCol = -1
        RETURN -1

    CASE ASC("G")
        IF ctrlDown <> 0 THEN
            newPos = 0
        ELSE
            lineNum = TextboxMetricCaretLine(elemIdx, ed.txt, ed.curPos, cols)
            newPos = TextboxMetricLineStart(elemIdx, ed.txt, lineNum, cols)
        END IF
        Ed_MoveCaret ed, newPos, shiftDown
        prefCol = -1
        RETURN -1

    CASE ASC("O")
        IF ctrlDown <> 0 THEN
            newPos = ed.txtLen
        ELSE
            lineNum = TextboxMetricCaretLine(elemIdx, ed.txt, ed.curPos, cols)
            lineStart = TextboxMetricLineStart(elemIdx, ed.txt, lineNum, cols)
            IF TextboxWordWrap(elemIdx) <> 0 THEN
                newPos = TbWrappedLineEndPos(ed.txt, lineStart, cols)
            ELSE
                newPos = TbLineEndPos(ed.txt, lineStart)
            END IF
        END IF
        Ed_MoveCaret ed, newPos, shiftDown
        prefCol = -1
        RETURN -1

    CASE ASC("H")
        colNum = TextboxMetricColumnAtPos(elemIdx, ed.txt, ed.curPos, cols)
        IF prefCol >= 0 THEN colNum = prefCol
        prefCol = colNum
        lineNum = TextboxMetricCaretLine(elemIdx, ed.txt, ed.curPos, cols)
        IF lineNum > 0 THEN
            newPos = TextboxMetricPosFromLineCol(elemIdx, ed.txt, lineNum - 1, colNum, cols)
            Ed_MoveCaret ed, newPos, shiftDown
        END IF
        RETURN -1

    CASE ASC("P")
        colNum = TextboxMetricColumnAtPos(elemIdx, ed.txt, ed.curPos, cols)
        IF prefCol >= 0 THEN colNum = prefCol
        prefCol = colNum
        lineNum = TextboxMetricCaretLine(elemIdx, ed.txt, ed.curPos, cols)
        IF TextboxWordWrap(elemIdx) <> 0 THEN
            lineCount = TextboxMetricLineCount(elemIdx, ed.txt, cols)
            IF lineNum < lineCount - 1 THEN
                newPos = TextboxMetricPosFromLineCol(elemIdx, ed.txt, lineNum + 1, colNum, cols)
                Ed_MoveCaret ed, newPos, shiftDown
            END IF
        ELSE
            newPos = TextboxMetricPosFromLineCol(elemIdx, ed.txt, lineNum + 1, colNum, cols)
            Ed_MoveCaret ed, newPos, shiftDown
        END IF
        RETURN -1

    CASE ASC("I")
        colNum = TextboxMetricColumnAtPos(elemIdx, ed.txt, ed.curPos, cols)
        IF prefCol >= 0 THEN colNum = prefCol
        prefCol = colNum
        lineNum = TextboxMetricCaretLine(elemIdx, ed.txt, ed.curPos, cols) - rows
        IF lineNum < 0 THEN lineNum = 0
        newPos = TextboxMetricPosFromLineCol(elemIdx, ed.txt, lineNum, colNum, cols)
        Ed_MoveCaret ed, newPos, shiftDown
        RETURN -1

    CASE ASC("Q")
        colNum = TextboxMetricColumnAtPos(elemIdx, ed.txt, ed.curPos, cols)
        IF prefCol >= 0 THEN colNum = prefCol
        prefCol = colNum
        lineNum = TextboxMetricCaretLine(elemIdx, ed.txt, ed.curPos, cols) + rows
        IF TextboxWordWrap(elemIdx) <> 0 THEN
            lineCount = TextboxMetricLineCount(elemIdx, ed.txt, cols)
            IF lineNum > lineCount - 1 THEN lineNum = lineCount - 1
            IF lineNum < 0 THEN lineNum = 0
        END IF
        newPos = TextboxMetricPosFromLineCol(elemIdx, ed.txt, lineNum, colNum, cols)
        Ed_MoveCaret ed, newPos, shiftDown
        RETURN -1

    CASE 147
        Ed_SaveUndo ed, ED_UNDO_EDIT
        IF Ed_DeleteSelection(ed) = 0 THEN
            newPos = ed.curPos
            DO WHILE newPos < ed.txtLen
                IF TextboxCharCodeIsWord(TextboxCharCodeAt(ed.txt, newPos + 1)) <> 0 THEN EXIT DO
                newPos = newPos + 1
            LOOP
            DO WHILE newPos < ed.txtLen
                IF TextboxCharCodeIsWord(TextboxCharCodeAt(ed.txt, newPos + 1)) = 0 THEN EXIT DO
                newPos = newPos + 1
            LOOP
            IF newPos > ed.curPos THEN Ed_DeleteRange ed, ed.curPos, newPos
        END IF
        Ed_ResetUndoGroup ed
        prefCol = -1
        RETURN -1

    CASE ASC("S")
        IF ctrlDown <> 0 THEN
            Ed_SaveUndo ed, ED_UNDO_EDIT
            IF Ed_DeleteSelection(ed) = 0 THEN
                newPos = ed.curPos
                DO WHILE newPos < ed.txtLen
                    IF TextboxCharCodeIsWord(TextboxCharCodeAt(ed.txt, newPos + 1)) <> 0 THEN EXIT DO
                    newPos = newPos + 1
                LOOP
                DO WHILE newPos < ed.txtLen
                    IF TextboxCharCodeIsWord(TextboxCharCodeAt(ed.txt, newPos + 1)) = 0 THEN EXIT DO
                    newPos = newPos + 1
                LOOP
                IF newPos > ed.curPos THEN Ed_DeleteRange ed, ed.curPos, newPos
            END IF
            Ed_ResetUndoGroup ed
            prefCol = -1
            RETURN -1
        END IF

    CASE 117
        Ed_MoveCaret ed, ed.txtLen, shiftDown
        prefCol = -1
        RETURN -1

    CASE 119
        Ed_MoveCaret ed, 0, shiftDown
        prefCol = -1
        RETURN -1
    END SELECT

    RETURN 0
END FUNCTION

FUNCTION TextboxDisplayLineCount(BYVAL elemIdx AS INTEGER, BYREF textValue AS STRING) AS INTEGER
    DIM cols AS INTEGER

    cols = TextboxCols(elemIdx)
    RETURN TextboxMetricLineCount(elemIdx, textValue, cols)
END FUNCTION

FUNCTION TextboxRows(BYVAL elemIdx AS INTEGER) AS INTEGER
    DIM rows AS INTEGER
    IF elemIdx < 1 OR elemIdx > uiCount THEN RETURN 1
    rows = (uiElems(elemIdx).h - 8) \ 8
    IF rows < 1 THEN rows = 1
    RETURN rows
END FUNCTION

FUNCTION TextboxCols(BYVAL elemIdx AS INTEGER) AS INTEGER
    DIM cols AS INTEGER
    DIM textW AS INTEGER
    DIM rows AS INTEGER
    DIM colsNoScroll AS INTEGER
    DIM textLen AS INTEGER
    DIM wrapFlag AS INTEGER
    DIM winKey AS INTEGER
    DIM needsScroll AS INTEGER

    IF elemIdx < 1 OR elemIdx > uiCount THEN RETURN 1
    textW = uiElems(elemIdx).w - 8
    IF TextboxIsMultiline(elemIdx) <> 0 THEN
        rows = TextboxRows(elemIdx)
        textLen = LEN(uiElems(elemIdx).text)
        wrapFlag = TextboxWordWrap(elemIdx)

        winKey = activeLayoutWindow
        IF drawLayoutWindow >= LBOUND(layoutWindows) AND drawLayoutWindow <= UBOUND(layoutWindows) THEN
            IF layoutWindows(drawLayoutWindow).used <> 0 THEN winKey = drawLayoutWindow
        END IF

        IF tbColsCacheValid <> 0 THEN
            IF tbColsCacheWin = winKey AND tbColsCacheElem = elemIdx AND _
               tbColsCacheTextW = textW AND tbColsCacheRows = rows AND _
               tbColsCacheWrap = wrapFlag THEN
                IF tbColsCacheLen = textLen THEN RETURN tbColsCacheCols
                IF tbColsCacheNeedsScroll <> 0 AND textLen > tbColsCacheLen THEN
                    tbColsCacheLen = textLen
                    RETURN tbColsCacheCols
                END IF
            END IF
        END IF

        needsScroll = 0
        colsNoScroll = textW \ 8
        IF colsNoScroll < 1 THEN colsNoScroll = 1
        IF wrapFlag <> 0 THEN
            IF TbWrappedLineCountExceedsRows(uiElems(elemIdx).text, colsNoScroll, rows) <> 0 THEN needsScroll = -1
        ELSE
            IF TextboxLineCountExceedsRows(uiElems(elemIdx).text, rows) <> 0 THEN needsScroll = -1
        END IF
        IF needsScroll <> 0 THEN textW = textW - 14

        cols = textW \ 8
        IF cols < 1 THEN cols = 1

        tbColsCacheValid = -1
        tbColsCacheWin = winKey
        tbColsCacheElem = elemIdx
        tbColsCacheLen = textLen
        tbColsCacheTextW = uiElems(elemIdx).w - 8
        tbColsCacheRows = rows
        tbColsCacheWrap = wrapFlag
        tbColsCacheCols = cols
        tbColsCacheNeedsScroll = needsScroll

        RETURN cols
    END IF

    cols = textW \ 8
    IF cols < 1 THEN cols = 1
    RETURN cols
END FUNCTION

FUNCTION TextboxPosFromPoint(BYVAL elemIdx AS INTEGER, BYREF textValue AS STRING, BYVAL localX AS INTEGER, BYVAL localY AS INTEGER) AS INTEGER
    DIM rowNum AS INTEGER
    DIM colNum AS INTEGER
    DIM firstLine AS INTEGER
    DIM lineCount AS INTEGER
    DIM lineNum AS INTEGER
    DIM lineStart AS INTEGER
    DIM lineEnd AS INTEGER
    DIM cols AS INTEGER
    DIM rows AS INTEGER
    DIM textLen AS INTEGER

    IF elemIdx < 1 OR elemIdx > uiCount THEN RETURN 0
    IF localX < 0 THEN localX = 0
    IF localY < 0 THEN localY = 0

    rows = TextboxRows(elemIdx)
    textLen = LEN(textValue)

    rowNum = localY \ 8
    IF rowNum < 0 THEN rowNum = 0
    IF rowNum >= rows THEN rowNum = rows - 1
    IF rowNum < 0 THEN rowNum = 0

    cols = TextboxCols(elemIdx)
    colNum = localX \ 8
    IF colNum < 0 THEN colNum = 0
    IF colNum > cols THEN colNum = cols

    firstLine = 0
    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN firstLine = comboScrollTop(activeLayoutWindow, elemIdx)
    END IF

    IF TextboxWordWrap(elemIdx) <> 0 THEN
        lineCount = TextboxMetricLineCount(elemIdx, textValue, cols)
        lineNum = firstLine + rowNum
        IF lineNum < 0 THEN lineNum = 0
        IF lineNum >= lineCount THEN lineNum = lineCount - 1
        IF lineNum < 0 THEN lineNum = 0
        lineStart = TextboxMetricLineStart(elemIdx, textValue, lineNum, cols)
        lineEnd = TbWrappedLineEndPos(textValue, lineStart, cols)
    ELSE
        lineCount = TextboxMetricLineCount(elemIdx, textValue, cols)
        lineNum = firstLine + rowNum
        IF lineNum < 0 THEN lineNum = 0
        IF lineNum >= lineCount THEN lineNum = lineCount - 1
        IF lineNum < 0 THEN lineNum = 0
        lineStart = TextboxMetricLineStart(elemIdx, textValue, lineNum, cols)
        IF lineStart < 0 THEN lineStart = textLen
        IF lineStart > textLen THEN lineStart = textLen
        lineEnd = TbLineEndPos(textValue, lineStart)
    END IF

    IF lineEnd < lineStart THEN lineEnd = lineStart
    IF lineEnd > LEN(textValue) THEN lineEnd = LEN(textValue)
    IF colNum > lineEnd - lineStart THEN colNum = lineEnd - lineStart
    IF colNum < 0 THEN colNum = 0

    RETURN lineStart + colNum
END FUNCTION

SUB SyncTextboxScrollToCaret(BYVAL elemIdx AS INTEGER)
    DIM rows AS INTEGER
    DIM lineCount AS INTEGER
    DIM maxTop AS INTEGER
    DIM topLine AS INTEGER
    DIM caretLine AS INTEGER
    DIM cols AS INTEGER

    IF elemIdx < 1 OR elemIdx > uiCount THEN EXIT SUB
    IF TextboxIsMultiline(elemIdx) = 0 THEN EXIT SUB
    IF activeLayoutWindow < LBOUND(layoutWindows) OR activeLayoutWindow > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(activeLayoutWindow).used = 0 THEN EXIT SUB

    rows = TextboxRows(elemIdx)
    cols = TextboxCols(elemIdx)
    lineCount = TextboxMetricLineCount(elemIdx, uiElems(elemIdx).text, cols)
    caretLine = TextboxMetricCaretLine(elemIdx, uiElems(elemIdx).text, uiCaretPos, cols)
    maxTop = lineCount - rows
    IF maxTop < 0 THEN maxTop = 0

    topLine = ClampScrollPos(comboScrollTop(activeLayoutWindow, elemIdx), maxTop)
    IF caretLine < 0 THEN caretLine = 0

    IF caretLine < topLine THEN topLine = caretLine
    IF caretLine >= topLine + rows THEN topLine = caretLine - rows + 1
    comboScrollTop(activeLayoutWindow, elemIdx) = ClampScrollPos(topLine, maxTop)
END SUB

' ---------------------------
' Clipped control drawing and cached layout rendering
' ---------------------------

SUB Draw3DRect(BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER, BYVAL raised AS INTEGER)
    LINE (x1, y1)-(x2, y2), uiStyle.panelFaceCol, BF

    IF uiStyle.windowModern <> 0 THEN
        LINE (x1, y1)-(x2, y2), uiStyle.bevelLoCol, B
        IF x2 - x1 > 2 AND y2 - y1 > 2 THEN
            IF raised <> 0 THEN
                LINE (x1 + 1, y1 + 1)-(x2 - 1, y1 + 1), uiStyle.bevelHiCol
                LINE (x1 + 1, y1 + 1)-(x1 + 1, y2 - 1), uiStyle.bevelHiCol
            ELSE
                LINE (x1 + 1, y1 + 1)-(x2 - 1, y1 + 1), uiStyle.bevelLoCol
                LINE (x1 + 1, y1 + 1)-(x1 + 1, y2 - 1), uiStyle.bevelLoCol
                LINE (x1 + 1, y2 - 1)-(x2 - 1, y2 - 1), uiStyle.bevelHiCol
                LINE (x2 - 1, y1 + 1)-(x2 - 1, y2 - 1), uiStyle.bevelHiCol
            END IF
        END IF
        EXIT SUB
    END IF

    IF raised <> 0 THEN
        LINE (x1, y1)-(x2, y1), uiStyle.bevelHiCol
        LINE (x1, y1)-(x1, y2), uiStyle.bevelHiCol
        LINE (x1, y2)-(x2, y2), uiStyle.bevelLoCol
        LINE (x2, y1)-(x2, y2), uiStyle.bevelLoCol
    ELSE
        LINE (x1, y1)-(x2, y1), uiStyle.bevelLoCol
        LINE (x1, y1)-(x1, y2), uiStyle.bevelLoCol
        LINE (x1, y2)-(x2, y2), uiStyle.bevelHiCol
        LINE (x2, y1)-(x2, y2), uiStyle.bevelHiCol
    END IF
END SUB

FUNCTION RectIntersectsClip(BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER, _
                            BYVAL clipL AS INTEGER, BYVAL clipT AS INTEGER, BYVAL clipR AS INTEGER, BYVAL clipB AS INTEGER) AS INTEGER
    IF x2 < clipL THEN RETURN 0
    IF x1 > clipR THEN RETURN 0
    IF y2 < clipT THEN RETURN 0
    IF y1 > clipB THEN RETURN 0
    RETURN -1
END FUNCTION

FUNCTION PointInControlClip(BYVAL px AS INTEGER, BYVAL py AS INTEGER, _
                            BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER, _
                            BYVAL clipL AS INTEGER, BYVAL clipT AS INTEGER, BYVAL clipR AS INTEGER, BYVAL clipB AS INTEGER) AS INTEGER
    IF px < x1 OR px > x2 THEN RETURN 0
    IF py < y1 OR py > y2 THEN RETURN 0
    IF px < clipL OR px > clipR THEN RETURN 0
    IF py < clipT OR py > clipB THEN RETURN 0
    RETURN -1
END FUNCTION

SUB FillRectClipped(BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER, _
                    BYVAL clipL AS INTEGER, BYVAL clipT AS INTEGER, BYVAL clipR AS INTEGER, BYVAL clipB AS INTEGER, _
                    BYVAL colValue AS INTEGER)
    IF x1 < clipL THEN x1 = clipL
    IF y1 < clipT THEN y1 = clipT
    IF x2 > clipR THEN x2 = clipR
    IF y2 > clipB THEN y2 = clipB
    IF x2 < x1 OR y2 < y1 THEN EXIT SUB
    LINE (x1, y1)-(x2, y2), colValue, BF
END SUB

SUB LineHClipped(BYVAL x1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y AS INTEGER, _
                 BYVAL clipL AS INTEGER, BYVAL clipT AS INTEGER, BYVAL clipR AS INTEGER, BYVAL clipB AS INTEGER, _
                 BYVAL colValue AS INTEGER)
    IF y < clipT OR y > clipB THEN EXIT SUB
    IF x1 > x2 THEN SWAP x1, x2
    IF x1 < clipL THEN x1 = clipL
    IF x2 > clipR THEN x2 = clipR
    IF x2 < x1 THEN EXIT SUB
    LINE (x1, y)-(x2, y), colValue
END SUB

SUB LineVClipped(BYVAL x AS INTEGER, BYVAL y1 AS INTEGER, BYVAL y2 AS INTEGER, _
                 BYVAL clipL AS INTEGER, BYVAL clipT AS INTEGER, BYVAL clipR AS INTEGER, BYVAL clipB AS INTEGER, _
                 BYVAL colValue AS INTEGER)
    IF x < clipL OR x > clipR THEN EXIT SUB
    IF y1 > y2 THEN SWAP y1, y2
    IF y1 < clipT THEN y1 = clipT
    IF y2 > clipB THEN y2 = clipB
    IF y2 < y1 THEN EXIT SUB
    LINE (x, y1)-(x, y2), colValue
END SUB

' ---------------------------
' Clipped control drawing and cached layout rendering
' ---------------------------

SUB Draw3DRectClipped(BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER, BYVAL raised AS INTEGER, _
                      BYVAL clipL AS INTEGER, BYVAL clipT AS INTEGER, BYVAL clipR AS INTEGER, BYVAL clipB AS INTEGER)
    IF RectIntersectsClip(x1, y1, x2, y2, clipL, clipT, clipR, clipB) = 0 THEN EXIT SUB

    FillRectClipped x1, y1, x2, y2, clipL, clipT, clipR, clipB, uiStyle.panelFaceCol

    IF uiStyle.windowModern <> 0 THEN
        LineHClipped x1, x2, y1, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
        LineVClipped x1, y1, y2, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
        LineHClipped x1, x2, y2, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
        LineVClipped x2, y1, y2, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol

        IF x2 - x1 > 2 AND y2 - y1 > 2 THEN
            IF raised <> 0 THEN
                LineHClipped x1 + 1, x2 - 1, y1 + 1, clipL, clipT, clipR, clipB, uiStyle.bevelHiCol
                LineVClipped x1 + 1, y1 + 1, y2 - 1, clipL, clipT, clipR, clipB, uiStyle.bevelHiCol
            ELSE
                LineHClipped x1 + 1, x2 - 1, y1 + 1, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
                LineVClipped x1 + 1, y1 + 1, y2 - 1, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
                LineHClipped x1 + 1, x2 - 1, y2 - 1, clipL, clipT, clipR, clipB, uiStyle.bevelHiCol
                LineVClipped x2 - 1, y1 + 1, y2 - 1, clipL, clipT, clipR, clipB, uiStyle.bevelHiCol
            END IF
        END IF
        EXIT SUB
    END IF

    IF raised <> 0 THEN
        LineHClipped x1, x2, y1, clipL, clipT, clipR, clipB, uiStyle.bevelHiCol
        LineVClipped x1, y1, y2, clipL, clipT, clipR, clipB, uiStyle.bevelHiCol
        LineHClipped x1, x2, y2, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
        LineVClipped x2, y1, y2, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
    ELSE
        LineHClipped x1, x2, y1, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
        LineVClipped x1, y1, y2, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
        LineHClipped x1, x2, y2, clipL, clipT, clipR, clipB, uiStyle.bevelHiCol
        LineVClipped x2, y1, y2, clipL, clipT, clipR, clipB, uiStyle.bevelHiCol
    END IF
END SUB

SUB DrawButtonBevelBoxClipped(BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER, BYVAL pressed AS INTEGER, _
                              BYVAL clipL AS INTEGER, BYVAL clipT AS INTEGER, BYVAL clipR AS INTEGER, BYVAL clipB AS INTEGER)
    IF RectIntersectsClip(x1, y1, x2, y2, clipL, clipT, clipR, clipB) = 0 THEN EXIT SUB

    FillRectClipped x1, y1, x2, y2, clipL, clipT, clipR, clipB, uiStyle.buttonFaceCol

    SELECT CASE uiStyle.buttonStyleId
    CASE 5
        IF x2 - x1 > 6 AND y2 - y1 > 6 THEN
            IF pressed <> 0 THEN
                LineHClipped x1 + 2, x2 - 2, y1, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
                LineVClipped x1, y1 + 2, y2 - 2, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
                LineHClipped x1 + 2, x2 - 2, y2, clipL, clipT, clipR, clipB, uiStyle.bevelHiCol
                LineVClipped x2, y1 + 2, y2 - 2, clipL, clipT, clipR, clipB, uiStyle.bevelHiCol
            ELSE
                LineHClipped x1 + 2, x2 - 2, y1, clipL, clipT, clipR, clipB, uiStyle.bevelHiCol
                LineVClipped x1, y1 + 2, y2 - 2, clipL, clipT, clipR, clipB, uiStyle.bevelHiCol
                LineHClipped x1 + 2, x2 - 2, y2, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
                LineVClipped x2, y1 + 2, y2 - 2, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
            END IF
            EXIT SUB
        END IF
        ' Very small buttons use the classic fallback path.
    CASE 4
        LineHClipped x1, x2, y1, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
        LineVClipped x1, y1, y2, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
        LineHClipped x1, x2, y2, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
        LineVClipped x2, y1, y2, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
        IF pressed <> 0 AND x2 - x1 > 3 AND y2 - y1 > 3 THEN
            LineHClipped x1 + 1, x2 - 1, y1 + 1, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
            LineVClipped x1 + 1, y1 + 1, y2 - 1, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
            LineHClipped x1 + 1, x2 - 1, y2 - 1, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
            LineVClipped x2 - 1, y1 + 1, y2 - 1, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
        END IF
        EXIT SUB
    CASE 3
        LineHClipped x1, x2, y1, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
        LineVClipped x1, y1, y2, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
        LineHClipped x1, x2, y2, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
        LineVClipped x2, y1, y2, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
        IF x2 - x1 > 2 AND y2 - y1 > 2 THEN
            IF pressed <> 0 THEN
                LineHClipped x1 + 1, x2 - 1, y1 + 1, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
                LineVClipped x1 + 1, y1 + 1, y2 - 1, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
                LineHClipped x1 + 1, x2 - 1, y2 - 1, clipL, clipT, clipR, clipB, uiStyle.bevelHiCol
            ELSE
                LineHClipped x1 + 1, x2 - 1, y1 + 1, clipL, clipT, clipR, clipB, uiStyle.bevelHiCol
                LineVClipped x1 + 1, y1 + 1, y2 - 1, clipL, clipT, clipR, clipB, uiStyle.bevelHiCol
            END IF
        END IF
        EXIT SUB
    CASE 2
        LineHClipped x1, x2, y1, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
        LineVClipped x1, y1, y2, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
        LineHClipped x1, x2, y2, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
        LineVClipped x2, y1, y2, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
        IF x2 - x1 > 2 AND y2 - y1 > 2 THEN
            IF pressed <> 0 THEN
                LineHClipped x1 + 1, x2 - 1, y1 + 1, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
                LineVClipped x1 + 1, y1 + 1, y2 - 1, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
            ELSE
                LineHClipped x1 + 1, x2 - 1, y1 + 1, clipL, clipT, clipR, clipB, uiStyle.bevelHiCol
                LineVClipped x1 + 1, y1 + 1, y2 - 1, clipL, clipT, clipR, clipB, uiStyle.bevelHiCol
            END IF
        END IF
        EXIT SUB
    END SELECT

    IF pressed <> 0 THEN
        LineHClipped x1, x2, y1, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
        LineVClipped x1, y1, y2, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
        LineHClipped x1, x2, y2, clipL, clipT, clipR, clipB, uiStyle.bevelHiCol
        LineVClipped x2, y1, y2, clipL, clipT, clipR, clipB, uiStyle.bevelHiCol
    ELSE
        LineHClipped x1, x2, y1, clipL, clipT, clipR, clipB, uiStyle.bevelHiCol
        LineVClipped x1, y1, y2, clipL, clipT, clipR, clipB, uiStyle.bevelHiCol
        LineHClipped x1, x2, y2, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
        LineVClipped x2, y1, y2, clipL, clipT, clipR, clipB, uiStyle.bevelLoCol
    END IF
END SUB

' ---------------------------
' Generic app-owned drawable/input view service
' ---------------------------
SUB AppViewFreeSlot(BYVAL winIdx AS INTEGER)
    DIM u AS INTEGER
    IF winIdx < 1 OR winIdx > 12 THEN EXIT SUB
    IF appViewPix(winIdx) <> 0 THEN
        DEALLOCATE appViewPix(winIdx)
        appViewPix(winIdx) = 0
    END IF
    FOR u = 1 TO 16
        IF appViewUndoPix(winIdx, u) <> 0 THEN
            DEALLOCATE appViewUndoPix(winIdx, u)
            appViewUndoPix(winIdx, u) = 0
        END IF
        appViewUndoW(winIdx, u) = 0
        appViewUndoH(winIdx, u) = 0
        appViewUndoColors(winIdx, u) = 0
    NEXT
    appViewUndoCount(winIdx) = 0
    appViewLoaded(winIdx) = 0
    appViewW(winIdx) = 0
    appViewH(winIdx) = 0
    appViewColors(winIdx) = 0
    appViewClearIndex(winIdx) = 0
    appViewLeftColor(winIdx) = 0
    appViewRightColor(winIdx) = 0
    appViewTool(winIdx) = 1
    appViewDragActive(winIdx) = 0
    appViewDragTool(winIdx) = 0
    appViewDragColor(winIdx) = 0
    appViewDragStartX(winIdx) = 0
    appViewDragStartY(winIdx) = 0
    appViewDragLastX(winIdx) = -1
    appViewDragLastY(winIdx) = -1
    appViewDirty(winIdx) = 0
    appViewVersion(winIdx) = appViewVersion(winIdx) + 1
    appViewFileName(winIdx) = ""
    appViewPalettePath(winIdx) = ""
END SUB


FUNCTION AppViewFindElemByName(BYVAL controlName AS STRING) AS INTEGER
    RETURN GetControlIndexByName(controlName)
END FUNCTION

FUNCTION AppViewPayloadField(BYVAL payload AS STRING, BYVAL fieldIdx AS INTEGER) AS STRING
    DIM curField AS INTEGER
    DIM startAt AS INTEGER
    DIM sepAt AS INTEGER

    IF fieldIdx < 1 THEN RETURN ""
    curField = 1
    startAt = 1
    DO
        sepAt = INSTR(startAt, payload, "|")
        IF curField = fieldIdx THEN
            IF sepAt > 0 THEN RETURN MID$(payload, startAt, sepAt - startAt)
            RETURN MID$(payload, startAt)
        END IF
        IF sepAt <= 0 THEN EXIT DO
        startAt = sepAt + 1
        curField = curField + 1
    LOOP
    RETURN ""
END FUNCTION

FUNCTION AppViewPayloadInt(BYVAL payload AS STRING, BYVAL fieldIdx AS INTEGER) AS INTEGER
    RETURN VAL(AppViewPayloadField(payload, fieldIdx))
END FUNCTION

FUNCTION AppViewColor(BYVAL winIdx AS INTEGER, BYVAL colorIdx AS INTEGER) AS UINTEGER
    DIM r AS INTEGER
    DIM g AS INTEGER
    DIM b AS INTEGER

    IF winIdx < 1 OR winIdx > 12 THEN RETURN COL_CONTROL_BG
    IF colorIdx < 0 THEN colorIdx = 0
    IF colorIdx > 255 THEN colorIdx = 255

    IF cfg.colorDepth = 4 THEN
        IF appViewColors(winIdx) <= 16 THEN RETURN (colorIdx AND 15)

        r = appViewPalR(winIdx, colorIdx)
        g = appViewPalG(winIdx, colorIdx)
        b = appViewPalB(winIdx, colorIdx)
        RETURN Backlash16ColorIndex(r, g, b)
    END IF

    RETURN MakeCol(appViewPalR(winIdx, colorIdx), appViewPalG(winIdx, colorIdx), appViewPalB(winIdx, colorIdx))
END FUNCTION

SUB AppViewInitDefaultPalette(BYVAL winIdx AS INTEGER, BYVAL colorCount AS INTEGER)
    DIM i AS INTEGER
    DIM ri AS INTEGER
    DIM gi AS INTEGER
    DIM bi AS INTEGER
    DIM shade AS INTEGER

    IF winIdx < 1 OR winIdx > 12 THEN EXIT SUB
    FOR i = 0 TO 255
        appViewPalR(winIdx, i) = 0
        appViewPalG(winIdx, i) = 0
        appViewPalB(winIdx, i) = 0
    NEXT

    appViewPalR(winIdx, 0) = 0: appViewPalG(winIdx, 0) = 0: appViewPalB(winIdx, 0) = 0
    appViewPalR(winIdx, 1) = 0: appViewPalG(winIdx, 1) = 0: appViewPalB(winIdx, 1) = 170
    appViewPalR(winIdx, 2) = 0: appViewPalG(winIdx, 2) = 170: appViewPalB(winIdx, 2) = 0
    appViewPalR(winIdx, 3) = 0: appViewPalG(winIdx, 3) = 170: appViewPalB(winIdx, 3) = 170
    appViewPalR(winIdx, 4) = 170: appViewPalG(winIdx, 4) = 0: appViewPalB(winIdx, 4) = 0
    appViewPalR(winIdx, 5) = 170: appViewPalG(winIdx, 5) = 0: appViewPalB(winIdx, 5) = 170
    appViewPalR(winIdx, 6) = 170: appViewPalG(winIdx, 6) = 85: appViewPalB(winIdx, 6) = 0
    appViewPalR(winIdx, 7) = 170: appViewPalG(winIdx, 7) = 170: appViewPalB(winIdx, 7) = 170
    appViewPalR(winIdx, 8) = 85: appViewPalG(winIdx, 8) = 85: appViewPalB(winIdx, 8) = 85
    appViewPalR(winIdx, 9) = 85: appViewPalG(winIdx, 9) = 85: appViewPalB(winIdx, 9) = 255
    appViewPalR(winIdx, 10) = 85: appViewPalG(winIdx, 10) = 255: appViewPalB(winIdx, 10) = 85
    appViewPalR(winIdx, 11) = 85: appViewPalG(winIdx, 11) = 255: appViewPalB(winIdx, 11) = 255
    appViewPalR(winIdx, 12) = 255: appViewPalG(winIdx, 12) = 85: appViewPalB(winIdx, 12) = 85
    appViewPalR(winIdx, 13) = 255: appViewPalG(winIdx, 13) = 0: appViewPalB(winIdx, 13) = 255
    appViewPalR(winIdx, 14) = 255: appViewPalG(winIdx, 14) = 255: appViewPalB(winIdx, 14) = 85
    appViewPalR(winIdx, 15) = 255: appViewPalG(winIdx, 15) = 255: appViewPalB(winIdx, 15) = 255

    IF colorCount > 16 THEN
        FOR ri = 0 TO 5
            FOR gi = 0 TO 5
                FOR bi = 0 TO 5
                    i = 16 + ri * 36 + gi * 6 + bi
                    appViewPalR(winIdx, i) = ri * 51
                    appViewPalG(winIdx, i) = gi * 51
                    appViewPalB(winIdx, i) = bi * 51
                NEXT
            NEXT
        NEXT
        FOR i = 232 TO 255
            shade = 8 + (i - 232) * 10
            appViewPalR(winIdx, i) = shade
            appViewPalG(winIdx, i) = shade
            appViewPalB(winIdx, i) = shade
        NEXT
    END IF
END SUB

FUNCTION AppViewLoadPaletteFile(BYVAL winIdx AS INTEGER, BYVAL palPath AS STRING) AS INTEGER
    DIM f AS INTEGER
    DIM rawLine AS STRING
    DIM lineText AS STRING
    DIM leftText AS STRING
    DIM valText AS STRING
    DIM p AS INTEGER
    DIM comma1 AS INTEGER
    DIM comma2 AS INTEGER
    DIM idx AS INTEGER
    DIM autoIdx AS INTEGER
    DIM r AS INTEGER
    DIM g AS INTEGER
    DIM b AS INTEGER

    AppViewLoadPaletteFile = 0
    IF winIdx < 1 OR winIdx > 12 THEN EXIT FUNCTION
    palPath = NormalizePath(TRIM$(palPath))
    IF palPath = "" THEN EXIT FUNCTION
    IF DIR(palPath) = "" THEN EXIT FUNCTION

    f = FREEFILE
    IF OPEN(palPath FOR INPUT AS #f) <> 0 THEN EXIT FUNCTION
    autoIdx = 0
    DO WHILE EOF(f) = 0
        LINE INPUT #f, rawLine
        lineText = TRIM$(rawLine)
        IF lineText <> "" THEN
            IF LEFT$(lineText, 1) <> ";" AND LEFT$(lineText, 1) <> "#" THEN
                p = INSTR(lineText, "=")
                IF p > 0 THEN
                    leftText = TRIM$(LEFT$(lineText, p - 1))
                    valText = TRIM$(MID$(lineText, p + 1))
                    idx = VAL(leftText)
                ELSE
                    valText = lineText
                    idx = autoIdx
                END IF
                comma1 = INSTR(valText, ",")
                comma2 = 0
                IF comma1 > 0 THEN comma2 = INSTR(comma1 + 1, valText, ",")
                IF comma1 > 0 AND comma2 > 0 THEN
                    r = ClampI(VAL(LEFT$(valText, comma1 - 1)), 0, 255)
                    g = ClampI(VAL(MID$(valText, comma1 + 1, comma2 - comma1 - 1)), 0, 255)
                    b = ClampI(VAL(MID$(valText, comma2 + 1)), 0, 255)
                    IF idx >= 0 AND idx <= 255 THEN
                        appViewPalR(winIdx, idx) = r
                        appViewPalG(winIdx, idx) = g
                        appViewPalB(winIdx, idx) = b
                    END IF
                    autoIdx = idx + 1
                END IF
            END IF
        END IF
    LOOP
    CLOSE #f
    appViewPalettePath(winIdx) = palPath
    AppViewLoadPaletteFile = -1
END FUNCTION
FUNCTION AppViewEnsureSurface(BYVAL winIdx AS INTEGER, BYVAL surfaceW AS INTEGER, BYVAL surfaceH AS INTEGER, BYVAL colorCount AS INTEGER, BYVAL clearIndex AS INTEGER, BYVAL palPath AS STRING) AS INTEGER
    DIM totalPix AS LONG
    DIM i AS LONG

    AppViewEnsureSurface = 0
    IF winIdx < 1 OR winIdx > 12 THEN EXIT FUNCTION
    IF surfaceW < 1 OR surfaceW > 128 THEN EXIT FUNCTION
    IF surfaceH < 1 OR surfaceH > 128 THEN EXIT FUNCTION
    IF colorCount <= 16 THEN
        colorCount = 16
    ELSE
        colorCount = 256
    END IF
    clearIndex = ClampI(clearIndex, 0, colorCount - 1)

    AppViewFreeSlot winIdx
    totalPix = CLNG(surfaceW) * CLNG(surfaceH)
    appViewPix(winIdx) = CAST(UBYTE PTR, ALLOCATE(totalPix * SIZEOF(UBYTE)))
    IF appViewPix(winIdx) = 0 THEN EXIT FUNCTION

    FOR i = 0 TO totalPix - 1
        appViewPix(winIdx)[i] = CUBYTE(clearIndex)
    NEXT

    appViewW(winIdx) = surfaceW
    appViewH(winIdx) = surfaceH
    appViewColors(winIdx) = colorCount
    appViewClearIndex(winIdx) = clearIndex
    appViewLeftColor(winIdx) = 1
    IF appViewLeftColor(winIdx) >= colorCount THEN appViewLeftColor(winIdx) = 0
    appViewRightColor(winIdx) = clearIndex
    appViewTool(winIdx) = 1
    appViewDragActive(winIdx) = 0
    appViewDragLastX(winIdx) = -1
    appViewDragLastY(winIdx) = -1
    appViewDirty(winIdx) = 0
    appViewLoaded(winIdx) = -1
    appViewVersion(winIdx) = appViewVersion(winIdx) + 1

    AppViewInitDefaultPalette winIdx, colorCount
    IF TRIM$(palPath) <> "" THEN AppViewLoadPaletteFile winIdx, palPath
    AppViewEnsureSurface = -1
END FUNCTION


SUB AppViewMarkRelated(BYVAL winIdx AS INTEGER)
    DIM i AS INTEGER
    IF winIdx < 1 OR winIdx > 12 THEN EXIT SUB
    IF layoutWindows(winIdx).used = 0 THEN EXIT SUB
    FOR i = 1 TO layoutUiCount(winIdx)
        IF layoutUiElems(winIdx, i).kindId = UI_KIND_APPVIEW THEN MarkLayoutDirtyElement winIdx, i
    NEXT
    MarkLayoutWindowVisualDirty winIdx
END SUB
FUNCTION AppViewToolId(BYVAL toolName AS STRING) AS INTEGER
    toolName = UCASE$(TRIM$(toolName))
    SELECT CASE toolName
    CASE "LINE"
        RETURN 2
    CASE "RECT", "RECTANGLE", "SQUARE", "BOX"
        RETURN 3
    CASE "CIRCLE", "ELLIPSE", "OVAL"
        RETURN 4
    CASE "FILL", "BUCKET", "PAINTBUCKET", "FLOOD"
        RETURN 5
    CASE ELSE
        RETURN 1
    END SELECT
END FUNCTION

FUNCTION AppViewToolName(BYVAL toolId AS INTEGER) AS STRING
    SELECT CASE toolId
    CASE 2
        RETURN "Line"
    CASE 3
        RETURN "Square"
    CASE 4
        RETURN "Oval"
    CASE 5
        RETURN "Fill"
    CASE ELSE
        RETURN "Pencil"
    END SELECT
END FUNCTION

SUB AppViewSetTool(BYVAL winIdx AS INTEGER, BYVAL toolName AS STRING)
    IF winIdx < 1 OR winIdx > 12 THEN EXIT SUB
    appViewTool(winIdx) = AppViewToolId(toolName)
    appViewDragActive(winIdx) = 0
    appViewDragLastX(winIdx) = -1
    appViewDragLastY(winIdx) = -1
    appViewVersion(winIdx) = appViewVersion(winIdx) + 1
END SUB

SUB AppViewClearUndo(BYVAL winIdx AS INTEGER)
    DIM u AS INTEGER
    IF winIdx < 1 OR winIdx > 12 THEN EXIT SUB
    FOR u = 1 TO 16
        IF appViewUndoPix(winIdx, u) <> 0 THEN
            DEALLOCATE appViewUndoPix(winIdx, u)
            appViewUndoPix(winIdx, u) = 0
        END IF
        appViewUndoW(winIdx, u) = 0
        appViewUndoH(winIdx, u) = 0
        appViewUndoColors(winIdx, u) = 0
    NEXT
    appViewUndoCount(winIdx) = 0
END SUB

SUB AppViewPushUndo(BYVAL winIdx AS INTEGER)
    DIM totalPix AS LONG
    DIM u AS INTEGER
    DIM i AS LONG
    DIM dst AS UBYTE PTR

    IF winIdx < 1 OR winIdx > 12 THEN EXIT SUB
    IF appViewLoaded(winIdx) = 0 OR appViewPix(winIdx) = 0 THEN EXIT SUB
    totalPix = CLNG(appViewW(winIdx)) * CLNG(appViewH(winIdx))
    IF totalPix <= 0 THEN EXIT SUB

    IF appViewUndoCount(winIdx) >= 16 THEN
        IF appViewUndoPix(winIdx, 1) <> 0 THEN DEALLOCATE appViewUndoPix(winIdx, 1)
        FOR u = 1 TO 15
            appViewUndoPix(winIdx, u) = appViewUndoPix(winIdx, u + 1)
            appViewUndoW(winIdx, u) = appViewUndoW(winIdx, u + 1)
            appViewUndoH(winIdx, u) = appViewUndoH(winIdx, u + 1)
            appViewUndoColors(winIdx, u) = appViewUndoColors(winIdx, u + 1)
        NEXT
        appViewUndoPix(winIdx, 16) = 0
        appViewUndoCount(winIdx) = 15
    END IF

    dst = CAST(UBYTE PTR, ALLOCATE(totalPix * SIZEOF(UBYTE)))
    IF dst = 0 THEN EXIT SUB
    FOR i = 0 TO totalPix - 1
        dst[i] = appViewPix(winIdx)[i]
    NEXT
    appViewUndoCount(winIdx) = appViewUndoCount(winIdx) + 1
    u = appViewUndoCount(winIdx)
    appViewUndoPix(winIdx, u) = dst
    appViewUndoW(winIdx, u) = appViewW(winIdx)
    appViewUndoH(winIdx, u) = appViewH(winIdx)
    appViewUndoColors(winIdx, u) = appViewColors(winIdx)
END SUB

FUNCTION AppViewUndo(BYVAL winIdx AS INTEGER) AS INTEGER
    DIM u AS INTEGER
    DIM totalPix AS LONG
    DIM i AS LONG

    AppViewUndo = 0
    IF winIdx < 1 OR winIdx > 12 THEN EXIT FUNCTION
    u = appViewUndoCount(winIdx)
    IF u < 1 THEN EXIT FUNCTION
    IF appViewUndoPix(winIdx, u) = 0 THEN EXIT FUNCTION
    IF appViewPix(winIdx) = 0 THEN EXIT FUNCTION
    IF appViewUndoW(winIdx, u) <> appViewW(winIdx) THEN EXIT FUNCTION
    IF appViewUndoH(winIdx, u) <> appViewH(winIdx) THEN EXIT FUNCTION

    totalPix = CLNG(appViewW(winIdx)) * CLNG(appViewH(winIdx))
    FOR i = 0 TO totalPix - 1
        appViewPix(winIdx)[i] = appViewUndoPix(winIdx, u)[i]
    NEXT
    DEALLOCATE appViewUndoPix(winIdx, u)
    appViewUndoPix(winIdx, u) = 0
    appViewUndoW(winIdx, u) = 0
    appViewUndoH(winIdx, u) = 0
    appViewUndoColors(winIdx, u) = 0
    appViewUndoCount(winIdx) = u - 1
    appViewDirty(winIdx) = -1
    appViewDragActive(winIdx) = 0
    appViewVersion(winIdx) = appViewVersion(winIdx) + 1
    AppViewMarkRelated winIdx
    AppViewUndo = -1
END FUNCTION

FUNCTION AppViewSetPixel(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER, BYVAL cellX AS INTEGER, BYVAL cellY AS INTEGER, BYVAL colorIdx AS INTEGER, BYVAL directDraw AS INTEGER) AS INTEGER
    DIM pixIdx AS LONG
    DIM i AS INTEGER

    AppViewSetPixel = 0
    IF winIdx < 1 OR winIdx > 12 THEN EXIT FUNCTION
    IF appViewLoaded(winIdx) = 0 OR appViewPix(winIdx) = 0 THEN EXIT FUNCTION
    IF cellX < 0 OR cellY < 0 OR cellX >= appViewW(winIdx) OR cellY >= appViewH(winIdx) THEN EXIT FUNCTION
    colorIdx = ClampI(colorIdx, 0, appViewColors(winIdx) - 1)
    pixIdx = CLNG(cellY) * appViewW(winIdx) + cellX
    IF appViewPix(winIdx)[pixIdx] = colorIdx THEN EXIT FUNCTION
    appViewPix(winIdx)[pixIdx] = CUBYTE(colorIdx)
    appViewDirty(winIdx) = -1
    appViewVersion(winIdx) = appViewVersion(winIdx) + 1
    IF directDraw <> 0 AND elemIdx >= 1 AND elemIdx <= uiCount THEN
        AppViewDrawGridCell winIdx, elemIdx, cellX, cellY
        FOR i = 1 TO uiCount
            IF uiElems(i).kindId = UI_KIND_APPVIEW THEN
                IF uiElems(i).drawStyleId = UI_DRAW_PREVIEW OR uiElems(i).drawStyleId = UI_DRAW_ACTUAL THEN AppViewDrawPreviewPixel winIdx, i, cellX, cellY
            END IF
        NEXT
    END IF
    AppViewSetPixel = -1
END FUNCTION

SUB AppViewPaintLine(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER, BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER, BYVAL colorIdx AS INTEGER, BYVAL directDraw AS INTEGER)
    DIM dx AS INTEGER
    DIM dy AS INTEGER
    DIM sx AS INTEGER
    DIM sy AS INTEGER
    DIM errVal AS INTEGER
    DIM e2 AS INTEGER

    dx = AbsI(x2 - x1)
    dy = AbsI(y2 - y1)
    IF x1 < x2 THEN sx = 1 ELSE sx = -1
    IF y1 < y2 THEN sy = 1 ELSE sy = -1
    errVal = dx - dy

    DO
        AppViewSetPixel winIdx, elemIdx, x1, y1, colorIdx, directDraw
        IF x1 = x2 AND y1 = y2 THEN EXIT DO
        e2 = errVal * 2
        IF e2 > -dy THEN
            errVal = errVal - dy
            x1 = x1 + sx
        END IF
        IF e2 < dx THEN
            errVal = errVal + dx
            y1 = y1 + sy
        END IF
    LOOP
END SUB

SUB AppViewPaintRect(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER, BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER, BYVAL colorIdx AS INTEGER, BYVAL directDraw AS INTEGER)
    DIM t AS INTEGER
    IF x1 > x2 THEN t = x1: x1 = x2: x2 = t
    IF y1 > y2 THEN t = y1: y1 = y2: y2 = t
    AppViewPaintLine winIdx, elemIdx, x1, y1, x2, y1, colorIdx, directDraw
    AppViewPaintLine winIdx, elemIdx, x1, y2, x2, y2, colorIdx, directDraw
    AppViewPaintLine winIdx, elemIdx, x1, y1, x1, y2, colorIdx, directDraw
    AppViewPaintLine winIdx, elemIdx, x2, y1, x2, y2, colorIdx, directDraw
END SUB

SUB AppViewPaintCircle(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER, BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER, BYVAL colorIdx AS INTEGER, BYVAL directDraw AS INTEGER)
    DIM t AS INTEGER
    DIM minX AS INTEGER
    DIM minY AS INTEGER
    DIM maxX AS INTEGER
    DIM maxY AS INTEGER
    DIM cx AS DOUBLE
    DIM cy AS DOUBLE
    DIM rx AS DOUBLE
    DIM ry AS DOUBLE
    DIM ang AS DOUBLE
    DIM px AS INTEGER
    DIM py AS INTEGER
    DIM firstX AS INTEGER
    DIM firstY AS INTEGER
    DIM prevX AS INTEGER
    DIM prevY AS INTEGER
    DIM deg AS INTEGER
    DIM firstSet AS INTEGER

    IF x1 > x2 THEN t = x1: x1 = x2: x2 = t
    IF y1 > y2 THEN t = y1: y1 = y2: y2 = t
    minX = x1: minY = y1: maxX = x2: maxY = y2

    IF minX = maxX OR minY = maxY THEN
        AppViewPaintLine winIdx, elemIdx, minX, minY, maxX, maxY, colorIdx, directDraw
        EXIT SUB
    END IF

    cx = (CDbl(minX) + CDbl(maxX)) / 2.0
    cy = (CDbl(minY) + CDbl(maxY)) / 2.0
    rx = (CDbl(maxX - minX)) / 2.0
    ry = (CDbl(maxY - minY)) / 2.0

    firstSet = 0
    FOR deg = 0 TO 359
        ang = CDbl(deg) * 0.0174532925199433
        px = CINT(cx + COS(ang) * rx)
        py = CINT(cy + SIN(ang) * ry)
        IF firstSet = 0 THEN
            firstX = px: firstY = py
            prevX = px: prevY = py
            AppViewSetPixel winIdx, elemIdx, px, py, colorIdx, directDraw
            firstSet = -1
        ELSE
            AppViewPaintLine winIdx, elemIdx, prevX, prevY, px, py, colorIdx, directDraw
            prevX = px: prevY = py
        END IF
    NEXT
    IF firstSet <> 0 THEN AppViewPaintLine winIdx, elemIdx, prevX, prevY, firstX, firstY, colorIdx, directDraw
END SUB


' APPVIEW flood fill uses the same in-memory surface as the existing pencil/line/shape tools.
' It is generic APPVIEW tool support; it does not name or depend on any specific app.
FUNCTION AppViewFloodFill(BYVAL winIdx AS INTEGER, BYVAL startX AS INTEGER, BYVAL startY AS INTEGER, BYVAL colorIdx AS INTEGER) AS INTEGER
    DIM totalPix AS LONG
    DIM widthVal AS INTEGER
    DIM heightVal AS INTEGER
    DIM targetColor AS INTEGER
    DIM fillColor AS INTEGER
    DIM startIdx AS LONG
    DIM curIdx AS LONG
    DIM nextIdx AS LONG
    DIM head AS LONG
    DIM tail AS LONG
    DIM x AS INTEGER
    DIM y AS INTEGER
    DIM queue AS LONG PTR

    AppViewFloodFill = 0
    IF winIdx < 1 OR winIdx > 12 THEN EXIT FUNCTION
    IF appViewLoaded(winIdx) = 0 OR appViewPix(winIdx) = 0 THEN EXIT FUNCTION

    widthVal = appViewW(winIdx)
    heightVal = appViewH(winIdx)
    IF widthVal < 1 OR heightVal < 1 THEN EXIT FUNCTION
    IF startX < 0 OR startY < 0 OR startX >= widthVal OR startY >= heightVal THEN EXIT FUNCTION

    fillColor = ClampI(colorIdx, 0, appViewColors(winIdx) - 1)
    startIdx = CLNG(startY) * widthVal + startX
    targetColor = appViewPix(winIdx)[startIdx]
    IF targetColor = fillColor THEN EXIT FUNCTION

    totalPix = CLNG(widthVal) * heightVal
    IF totalPix <= 0 THEN EXIT FUNCTION

    queue = CAST(LONG PTR, ALLOCATE(totalPix * SIZEOF(LONG)))
    IF queue = 0 THEN EXIT FUNCTION

    head = 0
    tail = 0
    queue[tail] = startIdx
    tail = tail + 1
    appViewPix(winIdx)[startIdx] = CUBYTE(fillColor)

    DO WHILE head < tail
        curIdx = queue[head]
        head = head + 1
        x = CINT(curIdx MOD widthVal)
        y = CINT(curIdx \ widthVal)

        IF x > 0 THEN
            nextIdx = curIdx - 1
            IF appViewPix(winIdx)[nextIdx] = targetColor THEN
                appViewPix(winIdx)[nextIdx] = CUBYTE(fillColor)
                queue[tail] = nextIdx
                tail = tail + 1
            END IF
        END IF

        IF x < widthVal - 1 THEN
            nextIdx = curIdx + 1
            IF appViewPix(winIdx)[nextIdx] = targetColor THEN
                appViewPix(winIdx)[nextIdx] = CUBYTE(fillColor)
                queue[tail] = nextIdx
                tail = tail + 1
            END IF
        END IF

        IF y > 0 THEN
            nextIdx = curIdx - widthVal
            IF appViewPix(winIdx)[nextIdx] = targetColor THEN
                appViewPix(winIdx)[nextIdx] = CUBYTE(fillColor)
                queue[tail] = nextIdx
                tail = tail + 1
            END IF
        END IF

        IF y < heightVal - 1 THEN
            nextIdx = curIdx + widthVal
            IF appViewPix(winIdx)[nextIdx] = targetColor THEN
                appViewPix(winIdx)[nextIdx] = CUBYTE(fillColor)
                queue[tail] = nextIdx
                tail = tail + 1
            END IF
        END IF
    LOOP

    DEALLOCATE queue
    appViewDirty(winIdx) = -1
    appViewVersion(winIdx) = appViewVersion(winIdx) + 1
    AppViewFloodFill = -1
END FUNCTION

SUB AppViewRedrawPaintViews(BYVAL winIdx AS INTEGER, BYVAL gridElemIdx AS INTEGER)
    DIM i AS INTEGER
    DIM ex AS INTEGER
    DIM ey AS INTEGER
    DIM ew AS INTEGER
    DIM eh AS INTEGER

    IF winIdx < 1 OR winIdx > 12 THEN EXIT SUB

    IF gridElemIdx >= 1 AND gridElemIdx <= uiCount THEN
        AppViewElementRect gridElemIdx, ex, ey, ew, eh
        AppViewDrawElement winIdx, gridElemIdx, ex, ey, ew, eh, ex + 2, ey + 2, ex + ew - 2, ey + eh - 2
    END IF

    FOR i = 1 TO uiCount
        IF i <> gridElemIdx THEN
            IF uiElems(i).kindId = UI_KIND_APPVIEW THEN
                IF uiElems(i).drawStyleId = UI_DRAW_PREVIEW OR uiElems(i).drawStyleId = UI_DRAW_ACTUAL THEN
                    AppViewElementRect i, ex, ey, ew, eh
                    AppViewDrawElement winIdx, i, ex, ey, ew, eh, ex, ey, ex + ew, ey + eh
                END IF
            END IF
        END IF
    NEXT
END SUB


SUB AppViewElementRect(BYVAL elemIdx AS INTEGER, BYREF ex AS INTEGER, BYREF ey AS INTEGER, BYREF ew AS INTEGER, BYREF eh AS INTEGER)
    ex = uiWinX + uiElems(elemIdx).x - uiScrollX
    ey = uiWinY + 22 + uiElems(elemIdx).y - uiScrollY
    ew = uiElems(elemIdx).w
    eh = uiElems(elemIdx).h
    IF ew <= 0 THEN ew = 120
    IF eh <= 0 THEN eh = 100
END SUB

SUB AppViewGridMetrics(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER, BYVAL ew AS INTEGER, BYVAL eh AS INTEGER, BYREF offX AS INTEGER, BYREF offY AS INTEGER, BYREF cellSize AS INTEGER)
    DIM innerW AS INTEGER
    DIM innerH AS INTEGER
    IF winIdx < 1 OR winIdx > 12 OR appViewLoaded(winIdx) = 0 THEN
        offX = 3: offY = 3: cellSize = 1
        EXIT SUB
    END IF
    innerW = ew - 6
    innerH = eh - 6
    IF innerW < 1 THEN innerW = 1
    IF innerH < 1 THEN innerH = 1
    cellSize = innerW \ appViewW(winIdx)
    IF innerH \ appViewH(winIdx) < cellSize THEN cellSize = innerH \ appViewH(winIdx)
    IF cellSize < 1 THEN cellSize = 1
    offX = 3 + (innerW - (appViewW(winIdx) * cellSize)) \ 2
    offY = 3 + (innerH - (appViewH(winIdx) * cellSize)) \ 2
END SUB

SUB AppViewDrawGridCellClipped(BYVAL winIdx AS INTEGER, BYVAL ex AS INTEGER, BYVAL ey AS INTEGER, BYVAL ew AS INTEGER, BYVAL eh AS INTEGER, BYVAL cellX AS INTEGER, BYVAL cellY AS INTEGER, BYVAL clipL AS INTEGER, BYVAL clipT AS INTEGER, BYVAL clipR AS INTEGER, BYVAL clipB AS INTEGER)
    DIM offX AS INTEGER
    DIM offY AS INTEGER
    DIM cellSize AS INTEGER
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER
    DIM pixIdx AS LONG
    DIM colIdx AS INTEGER

    IF winIdx < 1 OR winIdx > 12 THEN EXIT SUB
    IF appViewLoaded(winIdx) = 0 OR appViewPix(winIdx) = 0 THEN EXIT SUB
    IF cellX < 0 OR cellY < 0 OR cellX >= appViewW(winIdx) OR cellY >= appViewH(winIdx) THEN EXIT SUB
    AppViewGridMetrics winIdx, 0, ew, eh, offX, offY, cellSize
    x1 = ex + offX + cellX * cellSize
    y1 = ey + offY + cellY * cellSize
    x2 = x1 + cellSize - 1
    y2 = y1 + cellSize - 1
    pixIdx = CLNG(cellY) * appViewW(winIdx) + cellX
    colIdx = appViewPix(winIdx)[pixIdx]
    FillRectClipped x1, y1, x2, y2, clipL, clipT, clipR, clipB, AppViewColor(winIdx, colIdx)
    IF cellSize >= 5 THEN
        LineHClipped x1, x2, y1, clipL, clipT, clipR, clipB, COL_BEVEL_LO
        LineVClipped x1, y1, y2, clipL, clipT, clipR, clipB, COL_BEVEL_LO
    END IF
END SUB

SUB AppViewDrawGridCell(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER, BYVAL cellX AS INTEGER, BYVAL cellY AS INTEGER)
    DIM ex AS INTEGER
    DIM ey AS INTEGER
    DIM ew AS INTEGER
    DIM eh AS INTEGER
    IF elemIdx < 1 OR elemIdx > uiCount THEN EXIT SUB
    AppViewElementRect elemIdx, ex, ey, ew, eh
    AppViewDrawGridCellClipped winIdx, ex, ey, ew, eh, cellX, cellY, ex + 2, ey + 2, ex + ew - 2, ey + eh - 2
END SUB
SUB AppViewDrawShapePreviewPixel(BYVAL winIdx AS INTEGER, BYVAL ex AS INTEGER, BYVAL ey AS INTEGER, BYVAL ew AS INTEGER, BYVAL eh AS INTEGER, BYVAL cellX AS INTEGER, BYVAL cellY AS INTEGER, BYVAL colorIdx AS INTEGER)
    DIM offX AS INTEGER
    DIM offY AS INTEGER
    DIM cellSize AS INTEGER
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER

    IF winIdx < 1 OR winIdx > 12 THEN EXIT SUB
    IF appViewLoaded(winIdx) = 0 THEN EXIT SUB
    IF cellX < 0 OR cellY < 0 OR cellX >= appViewW(winIdx) OR cellY >= appViewH(winIdx) THEN EXIT SUB
    AppViewGridMetrics winIdx, 0, ew, eh, offX, offY, cellSize
    x1 = ex + offX + cellX * cellSize
    y1 = ey + offY + cellY * cellSize
    x2 = x1 + cellSize - 1
    y2 = y1 + cellSize - 1
    FillRectClipped x1, y1, x2, y2, ex + 2, ey + 2, ex + ew - 2, ey + eh - 2, AppViewColor(winIdx, colorIdx)
    IF cellSize >= 5 THEN
        LineHClipped x1, x2, y1, ex + 2, ey + 2, ex + ew - 2, ey + eh - 2, COL_TEXT
        LineVClipped x1, y1, y2, ex + 2, ey + 2, ex + ew - 2, ey + eh - 2, COL_TEXT
    END IF
END SUB

SUB AppViewPreviewLine(BYVAL winIdx AS INTEGER, BYVAL ex AS INTEGER, BYVAL ey AS INTEGER, BYVAL ew AS INTEGER, BYVAL eh AS INTEGER, BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER, BYVAL colorIdx AS INTEGER)
    DIM dx AS INTEGER
    DIM dy AS INTEGER
    DIM sx AS INTEGER
    DIM sy AS INTEGER
    DIM errVal AS INTEGER
    DIM e2 AS INTEGER

    dx = AbsI(x2 - x1)
    dy = AbsI(y2 - y1)
    IF x1 < x2 THEN sx = 1 ELSE sx = -1
    IF y1 < y2 THEN sy = 1 ELSE sy = -1
    errVal = dx - dy

    DO
        AppViewDrawShapePreviewPixel winIdx, ex, ey, ew, eh, x1, y1, colorIdx
        IF x1 = x2 AND y1 = y2 THEN EXIT DO
        e2 = errVal * 2
        IF e2 > -dy THEN
            errVal = errVal - dy
            x1 = x1 + sx
        END IF
        IF e2 < dx THEN
            errVal = errVal + dx
            y1 = y1 + sy
        END IF
    LOOP
END SUB

SUB AppViewPreviewRect(BYVAL winIdx AS INTEGER, BYVAL ex AS INTEGER, BYVAL ey AS INTEGER, BYVAL ew AS INTEGER, BYVAL eh AS INTEGER, BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER, BYVAL colorIdx AS INTEGER)
    DIM t AS INTEGER
    IF x1 > x2 THEN t = x1: x1 = x2: x2 = t
    IF y1 > y2 THEN t = y1: y1 = y2: y2 = t
    AppViewPreviewLine winIdx, ex, ey, ew, eh, x1, y1, x2, y1, colorIdx
    AppViewPreviewLine winIdx, ex, ey, ew, eh, x1, y2, x2, y2, colorIdx
    AppViewPreviewLine winIdx, ex, ey, ew, eh, x1, y1, x1, y2, colorIdx
    AppViewPreviewLine winIdx, ex, ey, ew, eh, x2, y1, x2, y2, colorIdx
END SUB

SUB AppViewPreviewEllipse(BYVAL winIdx AS INTEGER, BYVAL ex AS INTEGER, BYVAL ey AS INTEGER, BYVAL ew AS INTEGER, BYVAL eh AS INTEGER, BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER, BYVAL colorIdx AS INTEGER)
    DIM t AS INTEGER
    DIM cx AS DOUBLE
    DIM cy AS DOUBLE
    DIM rx AS DOUBLE
    DIM ry AS DOUBLE
    DIM ang AS DOUBLE
    DIM px AS INTEGER
    DIM py AS INTEGER
    DIM firstX AS INTEGER
    DIM firstY AS INTEGER
    DIM prevX AS INTEGER
    DIM prevY AS INTEGER
    DIM deg AS INTEGER
    DIM firstSet AS INTEGER

    IF x1 > x2 THEN t = x1: x1 = x2: x2 = t
    IF y1 > y2 THEN t = y1: y1 = y2: y2 = t
    IF x1 = x2 OR y1 = y2 THEN
        AppViewPreviewLine winIdx, ex, ey, ew, eh, x1, y1, x2, y2, colorIdx
        EXIT SUB
    END IF

    cx = (CDbl(x1) + CDbl(x2)) / 2.0
    cy = (CDbl(y1) + CDbl(y2)) / 2.0
    rx = (CDbl(x2 - x1)) / 2.0
    ry = (CDbl(y2 - y1)) / 2.0

    firstSet = 0
    FOR deg = 0 TO 359
        ang = CDbl(deg) * 0.0174532925199433
        px = CINT(cx + COS(ang) * rx)
        py = CINT(cy + SIN(ang) * ry)
        IF firstSet = 0 THEN
            firstX = px: firstY = py
            prevX = px: prevY = py
            AppViewDrawShapePreviewPixel winIdx, ex, ey, ew, eh, px, py, colorIdx
            firstSet = -1
        ELSE
            AppViewPreviewLine winIdx, ex, ey, ew, eh, prevX, prevY, px, py, colorIdx
            prevX = px: prevY = py
        END IF
    NEXT
    IF firstSet <> 0 THEN AppViewPreviewLine winIdx, ex, ey, ew, eh, prevX, prevY, firstX, firstY, colorIdx
END SUB

SUB AppViewDrawShapePreview(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER, BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER, BYVAL toolId AS INTEGER, BYVAL colorIdx AS INTEGER, BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER)
    DIM ex AS INTEGER
    DIM ey AS INTEGER
    DIM ew AS INTEGER
    DIM eh AS INTEGER

    IF elemIdx < 1 OR elemIdx > uiCount THEN EXIT SUB
    AppViewElementRect elemIdx, ex, ey, ew, eh

    SCREENLOCK
    RestoreCursorBackBuffer
    AppViewDrawElement winIdx, elemIdx, ex, ey, ew, eh, ex + 2, ey + 2, ex + ew - 2, ey + eh - 2
    SELECT CASE toolId
    CASE 2
        AppViewPreviewLine winIdx, ex, ey, ew, eh, x1, y1, x2, y2, colorIdx
    CASE 3
        AppViewPreviewRect winIdx, ex, ey, ew, eh, x1, y1, x2, y2, colorIdx
    CASE 4
        AppViewPreviewEllipse winIdx, ex, ey, ew, eh, x1, y1, x2, y2, colorIdx
    END SELECT
    SaveCursorBackBuffer mouseX, mouseY
    DrawCursor mouseX, mouseY
    SCREENUNLOCK
END SUB

SUB AppViewDrawPreviewPixel(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER, BYVAL cellX AS INTEGER, BYVAL cellY AS INTEGER)
    DIM ex AS INTEGER
    DIM ey AS INTEGER
    DIM ew AS INTEGER
    DIM eh AS INTEGER
    DIM px AS INTEGER
    DIM py AS INTEGER
    DIM pixIdx AS LONG
    DIM colIdx AS INTEGER
    IF winIdx < 1 OR winIdx > 12 THEN EXIT SUB
    IF appViewLoaded(winIdx) = 0 OR appViewPix(winIdx) = 0 THEN EXIT SUB
    IF elemIdx < 1 OR elemIdx > uiCount THEN EXIT SUB
    IF cellX < 0 OR cellY < 0 OR cellX >= appViewW(winIdx) OR cellY >= appViewH(winIdx) THEN EXIT SUB
    AppViewElementRect elemIdx, ex, ey, ew, eh
    px = ex + 3 + cellX
    py = ey + 3 + cellY
    pixIdx = CLNG(cellY) * appViewW(winIdx) + cellX
    colIdx = appViewPix(winIdx)[pixIdx]
    FillRectClipped px, py, px, py, ex + 2, ey + 2, ex + appViewW(winIdx) + 3, ey + appViewH(winIdx) + 3, AppViewColor(winIdx, colIdx)
END SUB


SUB AppViewDrawElement(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER, BYVAL ex AS INTEGER, BYVAL ey AS INTEGER, BYVAL ew AS INTEGER, BYVAL eh AS INTEGER, BYVAL clipL AS INTEGER, BYVAL clipT AS INTEGER, BYVAL clipR AS INTEGER, BYVAL clipB AS INTEGER)
    DIM styleName AS STRING
    DIM x AS INTEGER
    DIM y AS INTEGER
    DIM idx AS INTEGER
    DIM pixIdx AS LONG
    DIM colIdx AS INTEGER
    DIM offX AS INTEGER
    DIM offY AS INTEGER
    DIM cellSize AS INTEGER
    DIM cols AS INTEGER
    DIM rows AS INTEGER
    DIM sw AS INTEGER
    DIM sx AS INTEGER
    DIM sy AS INTEGER
    DIM boxR AS INTEGER
    DIM boxB AS INTEGER

    IF elemIdx < 1 OR elemIdx > uiCount THEN EXIT SUB
    styleName = uiElems(elemIdx).drawStyleKey
    IF styleName = "" THEN styleName = "GRID"

    IF styleName = "PREVIEW" OR styleName = "ACTUAL" THEN
        FillRectClipped ex, ey, ex + ew, ey + eh, clipL, clipT, clipR, clipB, COL_TASKBAR
        IF winIdx < 1 OR winIdx > 12 OR appViewLoaded(winIdx) = 0 OR appViewPix(winIdx) = 0 THEN EXIT SUB
        boxR = ex + appViewW(winIdx) + 5
        boxB = ey + appViewH(winIdx) + 5
        IF boxR > ex + ew THEN boxR = ex + ew
        IF boxB > ey + eh THEN boxB = ey + eh
        Draw3DRectClipped ex, ey, boxR, boxB, 0, clipL, clipT, clipR, clipB
        FillRectClipped ex + 2, ey + 2, boxR - 2, boxB - 2, clipL, clipT, clipR, clipB, COL_CONTROL_BG
        FOR y = 0 TO appViewH(winIdx) - 1
            FOR x = 0 TO appViewW(winIdx) - 1
                pixIdx = CLNG(y) * appViewW(winIdx) + x
                colIdx = appViewPix(winIdx)[pixIdx]
                FillRectClipped ex + 3 + x, ey + 3 + y, ex + 3 + x, ey + 3 + y, clipL, clipT, clipR, clipB, AppViewColor(winIdx, colIdx)
            NEXT
        NEXT
        EXIT SUB
    END IF

    Draw3DRectClipped ex, ey, ex + ew, ey + eh, 0, clipL, clipT, clipR, clipB
    FillRectClipped ex + 2, ey + 2, ex + ew - 2, ey + eh - 2, clipL, clipT, clipR, clipB, COL_CONTROL_BG

    IF styleName = "LEFT_COLOR" OR styleName = "RIGHT_COLOR" THEN
        IF winIdx >= 1 AND winIdx <= 12 THEN
            IF appViewLoaded(winIdx) <> 0 THEN
                IF styleName = "LEFT_COLOR" THEN
                    colIdx = appViewLeftColor(winIdx)
                ELSE
                    colIdx = appViewRightColor(winIdx)
                END IF
                FillRectClipped ex + 3, ey + 3, ex + ew - 3, ey + eh - 3, clipL, clipT, clipR, clipB, AppViewColor(winIdx, colIdx)
            END IF
        END IF
        EXIT SUB
    END IF

    IF winIdx < 1 OR winIdx > 12 OR appViewLoaded(winIdx) = 0 OR appViewPix(winIdx) = 0 THEN
        IF TRIM$(uiElems(elemIdx).defaultValue) <> "" THEN DrawStringRefClipped ex + 4, ey + 4, uiElems(elemIdx).defaultValue, COL_TEXT, clipL, clipT, clipR, clipB
        EXIT SUB
    END IF

    SELECT CASE styleName
    CASE "PALETTE"
        cols = 16
        IF appViewColors(winIdx) <= 16 THEN
            rows = 1
        ELSE
            rows = 16
        END IF
        sw = (ew - 6) \ cols
        IF rows > 0 THEN
            IF (eh - 6) \ rows < sw THEN sw = (eh - 6) \ rows
        END IF
        IF sw < 4 THEN sw = 4
        FOR idx = 0 TO appViewColors(winIdx) - 1
            sx = idx MOD cols
            sy = idx \ cols
            FillRectClipped ex + 3 + sx * sw, ey + 3 + sy * sw, ex + 3 + sx * sw + sw - 2, ey + 3 + sy * sw + sw - 2, clipL, clipT, clipR, clipB, AppViewColor(winIdx, idx)
            IF idx = appViewLeftColor(winIdx) THEN Draw3DRectClipped ex + 3 + sx * sw, ey + 3 + sy * sw, ex + 3 + sx * sw + sw - 2, ey + 3 + sy * sw + sw - 2, 1, clipL, clipT, clipR, clipB
            IF idx = appViewRightColor(winIdx) THEN Draw3DRectClipped ex + 4 + sx * sw, ey + 4 + sy * sw, ex + 3 + sx * sw + sw - 3, ey + 3 + sy * sw + sw - 3, 0, clipL, clipT, clipR, clipB
        NEXT

    CASE ELSE
        AppViewGridMetrics winIdx, elemIdx, ew, eh, offX, offY, cellSize
        FOR y = 0 TO appViewH(winIdx) - 1
            FOR x = 0 TO appViewW(winIdx) - 1
                AppViewDrawGridCellClipped winIdx, ex, ey, ew, eh, x, y, clipL, clipT, clipR, clipB
            NEXT
        NEXT
    END SELECT
END SUB


FUNCTION AppViewPaintFromPayload(BYVAL winIdx AS INTEGER, BYVAL viewName AS STRING) AS INTEGER
    DIM elemIdx AS INTEGER
    DIM payload AS STRING
    DIM eventName AS STRING
    DIM localX AS INTEGER
    DIM localY AS INTEGER
    DIM buttonMask AS INTEGER
    DIM screenX AS INTEGER
    DIM screenY AS INTEGER
    DIM ex AS INTEGER
    DIM ey AS INTEGER
    DIM ew AS INTEGER
    DIM eh AS INTEGER
    DIM offX AS INTEGER
    DIM offY AS INTEGER
    DIM cellSize AS INTEGER
    DIM cellX AS INTEGER
    DIM cellY AS INTEGER
    DIM newColor AS INTEGER
    DIM toolId AS INTEGER

    AppViewPaintFromPayload = 0
    IF winIdx < 1 OR winIdx > 12 THEN EXIT FUNCTION
    IF appViewLoaded(winIdx) = 0 OR appViewPix(winIdx) = 0 THEN EXIT FUNCTION
    elemIdx = AppViewFindElemByName(viewName)
    IF elemIdx < 1 THEN EXIT FUNCTION
    payload = uiElems(elemIdx).text
    eventName = UCASE$(TRIM$(AppViewPayloadField(payload, 1)))
    localX = AppViewPayloadInt(payload, 2)
    localY = AppViewPayloadInt(payload, 3)
    buttonMask = AppViewPayloadInt(payload, 4)
    screenX = AppViewPayloadInt(payload, 5)
    screenY = AppViewPayloadInt(payload, 6)
    AppViewElementRect elemIdx, ex, ey, ew, eh
    AppViewGridMetrics winIdx, elemIdx, ew, eh, offX, offY, cellSize
    cellX = (localX - offX) \ cellSize
    cellY = (localY - offY) \ cellSize
    IF cellX < 0 OR cellY < 0 OR cellX >= appViewW(winIdx) OR cellY >= appViewH(winIdx) THEN EXIT FUNCTION

    IF buttonMask = 2 THEN
        newColor = appViewRightColor(winIdx)
    ELSE
        newColor = appViewLeftColor(winIdx)
    END IF
    newColor = ClampI(newColor, 0, appViewColors(winIdx) - 1)
    toolId = appViewTool(winIdx)
    IF toolId < 1 THEN toolId = 1

    IF eventName = "LEFT_DOWN" OR eventName = "RIGHT_DOWN" THEN
        IF toolId = 5 THEN
            IF appViewPix(winIdx)[CLNG(cellY) * appViewW(winIdx) + cellX] = newColor THEN EXIT FUNCTION
            AppViewPushUndo winIdx
            SCREENLOCK
            RestoreCursorBackBuffer
            IF AppViewFloodFill(winIdx, cellX, cellY, newColor) <> 0 THEN
                AppViewRedrawPaintViews winIdx, elemIdx
                AppViewPaintFromPayload = -1
            END IF
            SaveCursorBackBuffer screenX, screenY
            DrawCursor screenX, screenY
            SCREENUNLOCK
            appViewDragActive(winIdx) = 0
            appViewDragLastX(winIdx) = -1
            appViewDragLastY(winIdx) = -1
            EXIT FUNCTION
        END IF

        AppViewPushUndo winIdx
        appViewDragActive(winIdx) = -1
        appViewDragTool(winIdx) = toolId
        appViewDragColor(winIdx) = newColor
        appViewDragStartX(winIdx) = cellX
        appViewDragStartY(winIdx) = cellY
        appViewDragLastX(winIdx) = cellX
        appViewDragLastY(winIdx) = cellY
        IF toolId = 1 THEN
            SCREENLOCK
            RestoreCursorBackBuffer
            IF AppViewSetPixel(winIdx, elemIdx, cellX, cellY, newColor, -1) <> 0 THEN AppViewPaintFromPayload = -1
            SaveCursorBackBuffer screenX, screenY
            DrawCursor screenX, screenY
            SCREENUNLOCK
        ELSE
            AppViewDrawShapePreview winIdx, elemIdx, appViewDragStartX(winIdx), appViewDragStartY(winIdx), cellX, cellY, toolId, newColor, screenX, screenY
        END IF
        EXIT FUNCTION
    END IF

    IF appViewDragActive(winIdx) = 0 THEN EXIT FUNCTION

    IF eventName = "LEFT_DRAG" OR eventName = "RIGHT_DRAG" THEN
        IF appViewDragTool(winIdx) = 1 THEN
            SCREENLOCK
            RestoreCursorBackBuffer
            AppViewPaintLine winIdx, elemIdx, appViewDragLastX(winIdx), appViewDragLastY(winIdx), cellX, cellY, appViewDragColor(winIdx), -1
            SaveCursorBackBuffer screenX, screenY
            DrawCursor screenX, screenY
            SCREENUNLOCK
            appViewDragLastX(winIdx) = cellX
            appViewDragLastY(winIdx) = cellY
            AppViewPaintFromPayload = -1
        ELSE
            AppViewDrawShapePreview winIdx, elemIdx, appViewDragStartX(winIdx), appViewDragStartY(winIdx), cellX, cellY, appViewDragTool(winIdx), appViewDragColor(winIdx), screenX, screenY
        END IF
        EXIT FUNCTION
    END IF

    IF eventName = "LEFT_UP" OR eventName = "RIGHT_UP" THEN
        SCREENLOCK
        RestoreCursorBackBuffer
        IF appViewDragTool(winIdx) <> 1 THEN AppViewDrawElement winIdx, elemIdx, ex, ey, ew, eh, ex + 2, ey + 2, ex + ew - 2, ey + eh - 2
        SELECT CASE appViewDragTool(winIdx)
        CASE 2
            AppViewPaintLine winIdx, elemIdx, appViewDragStartX(winIdx), appViewDragStartY(winIdx), cellX, cellY, appViewDragColor(winIdx), -1
            AppViewPaintFromPayload = -1
        CASE 3
            AppViewPaintRect winIdx, elemIdx, appViewDragStartX(winIdx), appViewDragStartY(winIdx), cellX, cellY, appViewDragColor(winIdx), -1
            AppViewPaintFromPayload = -1
        CASE 4
            AppViewPaintCircle winIdx, elemIdx, appViewDragStartX(winIdx), appViewDragStartY(winIdx), cellX, cellY, appViewDragColor(winIdx), -1
            AppViewPaintFromPayload = -1
        END SELECT
        SaveCursorBackBuffer screenX, screenY
        DrawCursor screenX, screenY
        SCREENUNLOCK
        appViewDragActive(winIdx) = 0
        appViewDragLastX(winIdx) = -1
        appViewDragLastY(winIdx) = -1
        EXIT FUNCTION
    END IF
END FUNCTION


FUNCTION AppViewSelectColorFromPayload(BYVAL winIdx AS INTEGER, BYVAL viewName AS STRING) AS INTEGER
    DIM elemIdx AS INTEGER
    DIM payload AS STRING
    DIM localX AS INTEGER
    DIM localY AS INTEGER
    DIM buttonMask AS INTEGER
    DIM ew AS INTEGER
    DIM eh AS INTEGER
    DIM cols AS INTEGER
    DIM rows AS INTEGER
    DIM sw AS INTEGER
    DIM sx AS INTEGER
    DIM sy AS INTEGER
    DIM idx AS INTEGER

    AppViewSelectColorFromPayload = 0
    IF winIdx < 1 OR winIdx > 12 THEN EXIT FUNCTION
    IF appViewLoaded(winIdx) = 0 THEN EXIT FUNCTION
    elemIdx = AppViewFindElemByName(viewName)
    IF elemIdx < 1 THEN EXIT FUNCTION
    payload = uiElems(elemIdx).text
    localX = AppViewPayloadInt(payload, 2)
    localY = AppViewPayloadInt(payload, 3)
    buttonMask = AppViewPayloadInt(payload, 4)
    ew = uiElems(elemIdx).w
    eh = uiElems(elemIdx).h
    IF ew <= 0 THEN ew = 120
    IF eh <= 0 THEN eh = 100
    cols = 16
    IF appViewColors(winIdx) <= 16 THEN rows = 1 ELSE rows = 16
    sw = (ew - 6) \ cols
    IF rows > 0 THEN
        IF (eh - 6) \ rows < sw THEN sw = (eh - 6) \ rows
    END IF
    IF sw < 4 THEN sw = 4
    sx = (localX - 3) \ sw
    sy = (localY - 3) \ sw
    idx = sy * cols + sx
    IF idx < 0 OR idx >= appViewColors(winIdx) THEN EXIT FUNCTION
    IF buttonMask = 2 THEN
        appViewRightColor(winIdx) = idx
        AppViewSelectColorFromPayload = 2
    ELSE
        appViewLeftColor(winIdx) = idx
        AppViewSelectColorFromPayload = 1
    END IF
    appViewVersion(winIdx) = appViewVersion(winIdx) + 1
    AppViewMarkRelated winIdx
END FUNCTION

FUNCTION AppViewBmpByteAt(BYVAL dataText AS STRING, BYVAL byteOffset AS LONG) AS INTEGER
    IF byteOffset < 0 OR byteOffset >= LEN(dataText) THEN RETURN 0
    RETURN ASC(MID$(dataText, byteOffset + 1, 1))
END FUNCTION

FUNCTION AppViewBmpU16At(BYVAL dataText AS STRING, BYVAL byteOffset AS LONG) AS INTEGER
    RETURN AppViewBmpByteAt(dataText, byteOffset) + AppViewBmpByteAt(dataText, byteOffset + 1) * 256
END FUNCTION

FUNCTION AppViewBmpU32At(BYVAL dataText AS STRING, BYVAL byteOffset AS LONG) AS LONG
    DIM v AS LONG
    v = CLNG(AppViewBmpByteAt(dataText, byteOffset)) + CLNG(AppViewBmpByteAt(dataText, byteOffset + 1)) * 256
    v = v + CLNG(AppViewBmpByteAt(dataText, byteOffset + 2)) * 65536
    v = v + CLNG(AppViewBmpByteAt(dataText, byteOffset + 3)) * 16777216
    RETURN v
END FUNCTION

FUNCTION AppViewNearestColor(BYVAL winIdx AS INTEGER, BYVAL r AS INTEGER, BYVAL g AS INTEGER, BYVAL b AS INTEGER) AS INTEGER
    DIM bestIdx AS INTEGER
    DIM bestDist AS LONG
    DIM i AS INTEGER
    DIM dr AS LONG
    DIM dg AS LONG
    DIM db AS LONG
    DIM dist AS LONG
    bestIdx = 0
    bestDist = 2147483647
    FOR i = 0 TO appViewColors(winIdx) - 1
        dr = CLNG(r - appViewPalR(winIdx, i))
        dg = CLNG(g - appViewPalG(winIdx, i))
        db = CLNG(b - appViewPalB(winIdx, i))
        dist = dr * dr + dg * dg + db * db
        IF dist < bestDist THEN
            bestDist = dist
            bestIdx = i
            IF dist = 0 THEN EXIT FOR
        END IF
    NEXT
    RETURN bestIdx
END FUNCTION

FUNCTION AppViewLoadBmp(BYVAL winIdx AS INTEGER, BYVAL fileName AS STRING) AS INTEGER
    DIM f AS INTEGER
    DIM dataText AS STRING
    DIM dataLen AS LONG
    DIM bmpOff AS LONG
    DIM dibSize AS LONG
    DIM bmpW AS LONG
    DIM bmpHRaw AS LONG
    DIM bmpH AS LONG
    DIM bpp AS INTEGER
    DIM rowSize AS LONG
    DIM colorCount AS INTEGER
    DIM palCount AS INTEGER
    DIM y AS INTEGER
    DIM x AS INTEGER
    DIM fileY AS INTEGER
    DIM rowOff AS LONG
    DIM b AS INTEGER
    DIM g AS INTEGER
    DIM r AS INTEGER
    DIM idx AS INTEGER
    DIM pixIdx AS LONG
    DIM byteVal AS INTEGER
    DIM palOff AS LONG

    AppViewLoadBmp = 0
    fileName = NormalizePath(TRIM$(fileName))
    IF winIdx < 1 OR winIdx > 12 THEN EXIT FUNCTION
    IF fileName = "" OR DIR(fileName) = "" THEN EXIT FUNCTION
    f = FREEFILE
    IF OPEN(fileName FOR BINARY AS #f) <> 0 THEN EXIT FUNCTION
    dataLen = LOF(f)
    IF dataLen < 54 THEN
        CLOSE #f
        EXIT FUNCTION
    END IF
    dataText = SPACE$(dataLen)
    GET #f, 1, dataText
    CLOSE #f

    IF AppViewBmpByteAt(dataText, 0) <> ASC("B") OR AppViewBmpByteAt(dataText, 1) <> ASC("M") THEN EXIT FUNCTION
    bmpOff = AppViewBmpU32At(dataText, 10)
    dibSize = AppViewBmpU32At(dataText, 14)
    IF dibSize < 40 THEN EXIT FUNCTION
    bmpW = AppViewBmpU32At(dataText, 18)
    bmpHRaw = AppViewBmpU32At(dataText, 22)
    IF bmpHRaw < 0 THEN bmpH = -bmpHRaw ELSE bmpH = bmpHRaw
    bpp = AppViewBmpU16At(dataText, 28)
    IF bmpW < 1 OR bmpW > 128 THEN EXIT FUNCTION
    IF bmpH < 1 OR bmpH > 128 THEN EXIT FUNCTION
    IF bpp <> 4 AND bpp <> 8 AND bpp <> 24 THEN EXIT FUNCTION
    IF bpp = 4 THEN colorCount = 16 ELSE colorCount = 256

    AppViewEnsureSurface winIdx, bmpW, bmpH, colorCount, 13, ""
    IF appViewLoaded(winIdx) = 0 THEN EXIT FUNCTION

    IF bpp = 4 OR bpp = 8 THEN
        palCount = colorCount
        palOff = 14 + dibSize
        FOR idx = 0 TO palCount - 1
            IF palOff + idx * 4 + 3 < LEN(dataText) THEN
                appViewPalB(winIdx, idx) = AppViewBmpByteAt(dataText, palOff + idx * 4)
                appViewPalG(winIdx, idx) = AppViewBmpByteAt(dataText, palOff + idx * 4 + 1)
                appViewPalR(winIdx, idx) = AppViewBmpByteAt(dataText, palOff + idx * 4 + 2)
            END IF
        NEXT
    END IF

    rowSize = ((CLNG(bmpW) * bpp + 31) \ 32) * 4
    FOR y = 0 TO bmpH - 1
        IF bmpHRaw < 0 THEN fileY = y ELSE fileY = bmpH - 1 - y
        rowOff = bmpOff + CLNG(fileY) * rowSize
        FOR x = 0 TO bmpW - 1
            IF bpp = 4 THEN
                byteVal = AppViewBmpByteAt(dataText, rowOff + (x \ 2))
                IF (x MOD 2) = 0 THEN idx = (byteVal \ 16) AND 15 ELSE idx = byteVal AND 15
            ELSEIF bpp = 8 THEN
                idx = AppViewBmpByteAt(dataText, rowOff + x)
            ELSE
                b = AppViewBmpByteAt(dataText, rowOff + CLNG(x) * 3)
                g = AppViewBmpByteAt(dataText, rowOff + CLNG(x) * 3 + 1)
                r = AppViewBmpByteAt(dataText, rowOff + CLNG(x) * 3 + 2)
                idx = AppViewNearestColor(winIdx, r, g, b)
            END IF
            IF idx < 0 THEN idx = 0
            IF idx >= colorCount THEN idx = colorCount - 1
            IF bpp = 4 THEN idx = Backlash16ColorIndex(appViewPalR(winIdx, idx), appViewPalG(winIdx, idx), appViewPalB(winIdx, idx))
            pixIdx = CLNG(y) * bmpW + x
            appViewPix(winIdx)[pixIdx] = CUBYTE(idx)
        NEXT
    NEXT
    IF bpp = 4 THEN
        FOR idx = 0 TO 15
            Backlash16PaletteRgb idx, r, g, b
            appViewPalR(winIdx, idx) = r
            appViewPalG(winIdx, idx) = g
            appViewPalB(winIdx, idx) = b
        NEXT
    END IF

    appViewFileName(winIdx) = fileName
    appViewDirty(winIdx) = 0
    appViewVersion(winIdx) = appViewVersion(winIdx) + 1
    AppViewLoadBmp = -1
END FUNCTION

FUNCTION AppViewBmpByte(BYVAL v AS INTEGER) AS STRING
    RETURN CHR$(ClampI(v, 0, 255))
END FUNCTION

FUNCTION AppViewBmpU16(BYVAL v AS LONG) AS STRING
    RETURN CHR$(v AND 255) + CHR$((v \ 256) AND 255)
END FUNCTION

FUNCTION AppViewBmpU32(BYVAL v AS LONG) AS STRING
    RETURN CHR$(v AND 255) + CHR$((v \ 256) AND 255) + CHR$((v \ 65536) AND 255) + CHR$((v \ 16777216) AND 255)
END FUNCTION

FUNCTION AppViewSaveBmp(BYVAL winIdx AS INTEGER, BYVAL fileName AS STRING) AS INTEGER
    DIM f AS INTEGER
    DIM bpp AS INTEGER
    DIM palCount AS INTEGER
    DIM rowSize AS LONG
    DIM imgSize AS LONG
    DIM fileSize AS LONG
    DIM dataOff AS LONG
    DIM outText AS STRING
    DIM rowText AS STRING
    DIM padCount AS INTEGER
    DIM y AS INTEGER
    DIM x AS INTEGER
    DIM idx AS INTEGER
    DIM hiIdx AS INTEGER
    DIM loIdx AS INTEGER
    DIM pixIdx AS LONG
    DIM r AS INTEGER
    DIM g AS INTEGER
    DIM b AS INTEGER

    AppViewSaveBmp = 0
    IF winIdx < 1 OR winIdx > 12 THEN EXIT FUNCTION
    IF appViewLoaded(winIdx) = 0 OR appViewPix(winIdx) = 0 THEN EXIT FUNCTION
    fileName = NormalizePath(TRIM$(fileName))
    IF fileName = "" THEN EXIT FUNCTION
    IF appViewColors(winIdx) <= 16 THEN
        bpp = 4
        palCount = 16
    ELSE
        bpp = 8
        palCount = 256
    END IF
    rowSize = ((CLNG(appViewW(winIdx)) * bpp + 31) \ 32) * 4
    imgSize = rowSize * appViewH(winIdx)
    dataOff = 14 + 40 + palCount * 4
    fileSize = dataOff + imgSize

    outText = "BM" + AppViewBmpU32(fileSize) + AppViewBmpU16(0) + AppViewBmpU16(0) + AppViewBmpU32(dataOff)
    outText = outText + AppViewBmpU32(40) + AppViewBmpU32(appViewW(winIdx)) + AppViewBmpU32(appViewH(winIdx))
    outText = outText + AppViewBmpU16(1) + AppViewBmpU16(bpp) + AppViewBmpU32(0) + AppViewBmpU32(imgSize)
    outText = outText + AppViewBmpU32(2835) + AppViewBmpU32(2835) + AppViewBmpU32(palCount) + AppViewBmpU32(0)

    FOR idx = 0 TO palCount - 1
        IF bpp = 4 THEN
            Backlash16PaletteRgb idx, r, g, b
            outText = outText + CHR$(ClampI(b, 0, 255)) + CHR$(ClampI(g, 0, 255)) + CHR$(ClampI(r, 0, 255)) + CHR$(0)
        ELSE
            outText = outText + CHR$(ClampI(appViewPalB(winIdx, idx), 0, 255)) + CHR$(ClampI(appViewPalG(winIdx, idx), 0, 255)) + CHR$(ClampI(appViewPalR(winIdx, idx), 0, 255)) + CHR$(0)
        END IF
    NEXT

    FOR y = appViewH(winIdx) - 1 TO 0 STEP -1
        rowText = ""
        IF bpp = 8 THEN
            FOR x = 0 TO appViewW(winIdx) - 1
                pixIdx = CLNG(y) * appViewW(winIdx) + x
                rowText = rowText + CHR$(appViewPix(winIdx)[pixIdx])
            NEXT
        ELSE
            FOR x = 0 TO appViewW(winIdx) - 1 STEP 2
                pixIdx = CLNG(y) * appViewW(winIdx) + x
                hiIdx = appViewPix(winIdx)[pixIdx] AND 15
                loIdx = 0
                IF x + 1 < appViewW(winIdx) THEN loIdx = appViewPix(winIdx)[pixIdx + 1] AND 15
                rowText = rowText + CHR$(hiIdx * 16 + loIdx)
            NEXT
        END IF
        padCount = rowSize - LEN(rowText)
        IF padCount > 0 THEN rowText = rowText + STRING$(padCount, CHR$(0))
        outText = outText + rowText
    NEXT

    f = FREEFILE
    IF OPEN(fileName FOR BINARY AS #f) <> 0 THEN EXIT FUNCTION
    PUT #f, 1, outText
    CLOSE #f
    AppViewSaveBmp = -1
END FUNCTION

FUNCTION LayoutAppViewHit(BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER) AS INTEGER
    DIM activePage AS STRING
    DIM tabNumber AS INTEGER
    DIM i AS INTEGER
    DIM ex AS INTEGER
    DIM ey AS INTEGER
    DIM ew AS INTEGER
    DIM eh AS INTEGER
    DIM contentW AS INTEGER
    DIM contentH AS INTEGER
    DIM showHScroll AS INTEGER
    DIM showVScroll AS INTEGER
    DIM clientW AS INTEGER
    DIM clientH AS INTEGER
    DIM maxScrollX AS INTEGER
    DIM maxScrollY AS INTEGER
    DIM contentRight AS INTEGER
    DIM contentBottom AS INTEGER

    LayoutAppViewHit = 0
    IF activeLayoutWindow < LBOUND(layoutWindows) OR activeLayoutWindow > UBOUND(layoutWindows) THEN EXIT FUNCTION
    IF layoutWindows(activeLayoutWindow).used = 0 THEN EXIT FUNCTION

    activePage = ""
    tabNumber = 0
    FOR i = 1 TO uiCount
        IF uiElems(i).kindId = UI_KIND_TAB THEN
            tabNumber = tabNumber + 1
            IF tabNumber = uiSelectedTab THEN
                activePage = UCASE$(uiElems(i).text)
                EXIT FOR
            END IF
        END IF
    NEXT
    IF activePage = "" THEN
        FOR i = 1 TO uiCount
            IF uiElems(i).kindId = UI_KIND_TAB THEN
                activePage = UCASE$(uiElems(i).text)
                EXIT FOR
            END IF
        NEXT
    END IF

    GetLayoutContentExtents contentW, contentH
    GetLayoutScrollMetricsFromContent contentW, contentH, showHScroll, showVScroll, clientW, clientH, maxScrollX, maxScrollY
    contentRight = LayoutVisibleClientRight(showVScroll)
    contentBottom = LayoutVisibleClientBottom(showHScroll)

    FOR i = uiCount TO 1 STEP -1
        IF uiElems(i).kindId = UI_KIND_APPVIEW THEN
            IF uiElems(i).page = "" OR uiElems(i).pageKey = activePage THEN
                ex = uiWinX + uiElems(i).x - uiScrollX
                ey = uiWinY + 22 + uiElems(i).y - uiScrollY
                ew = uiElems(i).w
                eh = uiElems(i).h
                IF ew <= 0 THEN ew = 120
                IF eh <= 0 THEN eh = 100
                IF RectIntersectsClip(ex, ey, ex + ew, ey + eh, uiWinX + 2, uiWinY + 19, contentRight, contentBottom) <> 0 THEN
                    IF PointInControlClip(mouseX, mouseY, ex, ey, ex + ew, ey + eh, uiWinX + 2, uiWinY + 19, contentRight, contentBottom) <> 0 THEN
                        LayoutAppViewHit = i
                        EXIT FUNCTION
                    END IF
                END IF
            END IF
        END IF
    NEXT
END FUNCTION

SUB DispatchAppViewMouseEvent(BYVAL elemIdx AS INTEGER, BYVAL eventName AS STRING, BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER, BYVAL buttonMask AS INTEGER)
    DIM ex AS INTEGER
    DIM ey AS INTEGER
    DIM ew AS INTEGER
    DIM eh AS INTEGER
    DIM localX AS INTEGER
    DIM localY AS INTEGER
    DIM payload AS STRING

    IF elemIdx < 1 OR elemIdx > uiCount THEN EXIT SUB
    IF uiElems(elemIdx).kindKey <> "APPVIEW" THEN EXIT SUB
    IF activeLayoutWindow < LBOUND(layoutWindows) OR activeLayoutWindow > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(activeLayoutWindow).used = 0 THEN EXIT SUB

    ex = uiWinX + uiElems(elemIdx).x - uiScrollX
    ey = uiWinY + 22 + uiElems(elemIdx).y - uiScrollY
    ew = uiElems(elemIdx).w
    eh = uiElems(elemIdx).h
    IF ew <= 0 THEN ew = 120
    IF eh <= 0 THEN eh = 100

    localX = mouseX - ex
    localY = mouseY - ey
    IF localX < 0 THEN localX = 0
    IF localY < 0 THEN localY = 0
    IF localX >= ew THEN localX = ew - 1
    IF localY >= eh THEN localY = eh - 1

    payload = UCASE$(TRIM$(eventName)) + "|" + LTRIM$(STR$(localX)) + "|" + LTRIM$(STR$(localY)) + "|" + _
        LTRIM$(STR$(buttonMask)) + "|" + LTRIM$(STR$(mouseX)) + "|" + LTRIM$(STR$(mouseY)) + "|" + _
        LTRIM$(STR$(ew)) + "|" + LTRIM$(STR$(eh))

    uiElems(elemIdx).text = payload
    layoutUiElems(activeLayoutWindow, elemIdx).text = payload
    layoutWindows(activeLayoutWindow).focusIndex = elemIdx
    uiFocusIndex = elemIdx

    AppRuntime_HandleEvent activeLayoutWindow, UCASE$(TRIM$(eventName)), _
        uiElems(elemIdx).name, payload, uiElems(elemIdx).action
END SUB



FUNCTION DrawFastTextboxViewportOnly(BYVAL elemIdx AS INTEGER) AS INTEGER
    DIM ex AS INTEGER
    DIM ey AS INTEGER
    DIM ew AS INTEGER
    DIM eh AS INTEGER
    DIM contentW AS INTEGER
    DIM contentH AS INTEGER
    DIM showHScroll AS INTEGER
    DIM showVScroll AS INTEGER
    DIM clientW AS INTEGER
    DIM clientH AS INTEGER
    DIM maxScrollX AS INTEGER
    DIM maxScrollY AS INTEGER
    DIM clipL AS INTEGER
    DIM clipT AS INTEGER
    DIM clipR AS INTEGER
    DIM clipB AS INTEGER
    DIM contentRight AS INTEGER
    DIM tbWrap AS INTEGER
    DIM tbRows AS INTEGER
    DIM tbCols AS INTEGER
    DIM tbLineCount AS INTEGER
    DIM tbMaxTop AS INTEGER
    DIM tbFirstLine AS INTEGER
    DIM tbStartPos AS INTEGER
    DIM tbLineEnd AS INTEGER
    DIM tbRow AS INTEGER
    DIM tbRowY AS INTEGER
    DIM tbScrollLeft AS INTEGER
    DIM tbTextClipR AS INTEGER
    DIM tbTrackTop AS INTEGER
    DIM tbTrackBottom AS INTEGER
    DIM tbTrackH AS INTEGER
    DIM tbThumbH AS INTEGER
    DIM tbThumbTop AS INTEGER
    DIM tbThumbBottom AS INTEGER
    DIM tbLocked AS INTEGER
    DIM tbFillCol AS UINTEGER
    DIM tbTextCol AS UINTEGER
    DIM tbTextLen AS INTEGER
    DIM tbSelA AS INTEGER
    DIM tbSelB AS INTEGER
    DIM tbSegA AS INTEGER
    DIM tbSegB AS INTEGER
    DIM tbSelX1 AS INTEGER
    DIM tbSelX2 AS INTEGER
    DIM tbFocus AS INTEGER
    DIM tbCaret AS INTEGER
    DIM tbCaretLineNum AS INTEGER
    DIM tbCol AS INTEGER
    DIM tx AS INTEGER
    DIM tbScrollWin AS INTEGER

    DrawFastTextboxViewportOnly = 0

    IF elemIdx < 1 OR elemIdx > uiCount THEN EXIT FUNCTION
    IF uiElems(elemIdx).kindKey <> "TEXTBOX" THEN EXIT FUNCTION
    IF TextboxIsMultiline(elemIdx) = 0 THEN EXIT FUNCTION
    IF activeLayoutWindow < LBOUND(layoutWindows) OR activeLayoutWindow > UBOUND(layoutWindows) THEN EXIT FUNCTION
    IF layoutWindows(activeLayoutWindow).used = 0 THEN EXIT FUNCTION

    ex = uiWinX + uiElems(elemIdx).x - uiScrollX
    ey = uiWinY + 22 + uiElems(elemIdx).y - uiScrollY
    ew = uiElems(elemIdx).w
    eh = uiElems(elemIdx).h
    IF ew <= 0 THEN ew = 120
    IF eh <= 0 THEN eh = 22

    GetLayoutContentExtents contentW, contentH
    GetLayoutScrollMetricsFromContent contentW, contentH, showHScroll, showVScroll, clientW, clientH, maxScrollX, maxScrollY

    contentRight = LayoutVisibleClientRight(showVScroll)
    clipL = uiWinX + 2
    clipT = uiWinY + 19
    clipR = contentRight
    clipB = LayoutVisibleClientBottom(showHScroll)

    IF RectIntersectsClip(ex, ey, ex + ew, ey + eh, clipL, clipT, clipR, clipB) = 0 THEN
        DrawFastTextboxViewportOnly = -1
        EXIT FUNCTION
    END IF

    tbTextLen = LEN(uiElems(elemIdx).text)
    tbWrap = TextboxWordWrap(elemIdx)
    tbRows = TextboxRows(elemIdx)
    tbCols = TextboxCols(elemIdx)
    tbLineCount = TextboxDisplayLineCount(elemIdx, uiElems(elemIdx).text)
    tbMaxTop = tbLineCount - tbRows
    IF tbMaxTop < 0 THEN tbMaxTop = 0
    IF tbMaxTop <= 0 THEN EXIT FUNCTION

    tbScrollLeft = ex + ew - 14
    tbTextClipR = tbScrollLeft - 1
    IF tbTextClipR > clipR THEN tbTextClipR = clipR
    IF tbTextClipR < clipL THEN tbTextClipR = clipL

    tbScrollWin = TextboxDrawScrollWindow()
    IF tbScrollWin > 0 THEN
        tbFirstLine = ClampScrollPos(comboScrollTop(tbScrollWin, elemIdx), tbMaxTop)
        comboScrollTop(tbScrollWin, elemIdx) = tbFirstLine
    ELSE
        tbFirstLine = 0
    END IF

    tbLocked = 0
    IF uiElems(elemIdx).noEdit <> 0 AND uiElems(elemIdx).state < 0 THEN tbLocked = -1
    tbFillCol = COL_CONTROL_BG
    tbTextCol = COL_TEXT
    IF tbLocked <> 0 THEN
        tbFillCol = COL_BEVEL_HI
        tbTextCol = COL_BEVEL_LO
    END IF

    FillRectClipped ex + 3, ey + 3, tbTextClipR, ey + eh - 3, clipL, clipT, tbTextClipR, clipB, tbFillCol

    Draw3DRectClipped tbScrollLeft, ey + 2, ex + ew - 2, ey + eh - 2, 0, clipL, clipT, clipR, clipB
    tbTrackTop = ey + 3
    tbTrackBottom = ey + eh - 3
    tbTrackH = tbTrackBottom - tbTrackTop + 1
    IF tbTrackH < 1 THEN tbTrackH = 1
    tbThumbH = CalcScrollThumbSize(tbRows, tbLineCount, tbTrackH, 12)
    tbThumbTop = CalcScrollThumbTop(tbFirstLine, tbMaxTop, tbTrackTop, tbTrackH, tbThumbH)
    tbThumbBottom = tbThumbTop + tbThumbH - 1
    Draw3DRectClipped tbScrollLeft + 1, tbThumbTop, ex + ew - 3, tbThumbBottom, 1, clipL, clipT, clipR, clipB

    tbSelA = 0
    tbSelB = 0
    IF Ed_SelHas(uiEdit(elemIdx)) <> 0 THEN Ed_SelNorm uiEdit(elemIdx), tbSelA, tbSelB

    tbFocus = 0
    tbCaret = uiCaretPos
    IF uiWindowActive <> 0 AND uiFocusIndex = elemIdx THEN tbFocus = -1
    tbCaretLineNum = -1
    IF tbFocus <> 0 AND uiCaretVisible <> 0 THEN
        tbCaretLineNum = TextboxMetricCaretLine(elemIdx, uiElems(elemIdx).text, tbCaret, tbCols)
    END IF

    tbStartPos = TextboxMetricLineStart(elemIdx, uiElems(elemIdx).text, tbFirstLine, tbCols)
    IF tbStartPos < 0 THEN tbStartPos = 0

    FOR tbRow = 0 TO tbRows - 1
        IF tbStartPos > tbTextLen AND tbRow > 0 THEN EXIT FOR

        IF tbWrap <> 0 THEN
            tbLineEnd = TbWrappedLineEndPos(uiElems(elemIdx).text, tbStartPos, tbCols)
        ELSE
            tbLineEnd = TbLineEndPos(uiElems(elemIdx).text, tbStartPos)
        END IF
        IF tbLineEnd < tbStartPos THEN tbLineEnd = tbStartPos

        tbRowY = ey + 4 + tbRow * 8
        DrawStringSliceClipped ex + 4, tbRowY, uiElems(elemIdx).text, tbStartPos + 1, tbLineEnd - tbStartPos, tbCols, tbTextCol, clipL, clipT, tbTextClipR, clipB

        IF tbSelB > tbSelA THEN
            tbSegA = tbSelA
            tbSegB = tbSelB
            IF tbSegA < tbStartPos THEN tbSegA = tbStartPos
            IF tbSegB > tbLineEnd THEN tbSegB = tbLineEnd
            IF tbSegB > tbSegA THEN
                tbSelX1 = tbSegA - tbStartPos
                tbSelX2 = tbSegB - tbStartPos
                IF tbSelX1 < 0 THEN tbSelX1 = 0
                IF tbSelX2 > tbCols THEN tbSelX2 = tbCols
                IF tbSelX2 > tbSelX1 THEN
                    FillRectClipped ex + 4 + tbSelX1 * 8, tbRowY, ex + 3 + tbSelX2 * 8, tbRowY + 7, clipL, clipT, tbTextClipR, clipB, COL_SELECT
                    DrawStringSliceClipped ex + 4 + tbSelX1 * 8, tbRowY, uiElems(elemIdx).text, tbStartPos + tbSelX1 + 1, tbSelX2 - tbSelX1, tbCols, COL_SELECTED_TEXT, clipL, clipT, tbTextClipR, clipB
                END IF
            END IF
        END IF

        IF tbFocus <> 0 AND uiCaretVisible <> 0 AND (tbFirstLine + tbRow) = tbCaretLineNum THEN
            tbCol = tbCaret - tbStartPos
            IF tbCol < 0 THEN tbCol = 0
            IF tbCol > tbCols THEN tbCol = tbCols
            tx = ex + 4 + tbCol * 8
            IF tx > ex + ew - 5 THEN tx = ex + ew - 5
            LineVClipped tx, tbRowY, tbRowY + 7, clipL, clipT, tbTextClipR, clipB, tbTextCol
        END IF

        IF tbLineEnd >= tbTextLen THEN EXIT FOR
        IF tbWrap <> 0 THEN
            tbStartPos = TbWrappedNextLineStart(uiElems(elemIdx).text, tbStartPos, tbLineEnd, tbCols)
        ELSE
            tbStartPos = TbNextLineStart(uiElems(elemIdx).text, tbLineEnd)
        END IF
    NEXT

    DrawFastTextboxViewportOnly = -1
END FUNCTION


SUB DrawStringClipped(BYVAL drawX AS INTEGER, BYVAL drawY AS INTEGER, BYVAL textValue AS STRING, _
                      BYVAL colValue AS INTEGER, _
                      BYVAL clipL AS INTEGER, BYVAL clipT AS INTEGER, BYVAL clipR AS INTEGER, BYVAL clipB AS INTEGER)
    ' Literal-safe wrapper. Hot variable-string draw paths call DrawStringRefClipped directly.
    DrawStringRefClipped drawX, drawY, textValue, colValue, clipL, clipT, clipR, clipB
END SUB

SUB DrawStringRefClipped(BYVAL drawX AS INTEGER, BYVAL drawY AS INTEGER, BYREF textValue AS STRING, _
                         BYVAL colValue AS INTEGER, _
                         BYVAL clipL AS INTEGER, BYVAL clipT AS INTEGER, BYVAL clipR AS INTEGER, BYVAL clipB AS INTEGER)
    DIM textLen AS INTEGER
    DIM firstChar AS INTEGER
    DIM lastChar AS INTEGER
    DIM drawVisibleX AS INTEGER
    DIM pixelRight AS LONG
    DIM visibleText AS STRING

    IF drawY + 7 < clipT THEN EXIT SUB
    IF drawY > clipB THEN EXIT SUB

    textLen = LEN(textValue)
    IF textLen <= 0 THEN EXIT SUB

    pixelRight = CLNG(drawX) + CLNG(textLen) * 8 - 1
    IF drawX > clipR OR pixelRight < clipL THEN EXIT SUB

    firstChar = 1
    IF drawX < clipL THEN firstChar = ((clipL - drawX) \ 8) + 1

    lastChar = ((clipR - drawX) \ 8) + 1
    IF lastChar > textLen THEN lastChar = textLen

    IF firstChar < 1 THEN firstChar = 1
    IF lastChar < firstChar THEN EXIT SUB

    IF firstChar = 1 AND lastChar = textLen THEN
        DRAW STRING (drawX, drawY), textValue, colValue
    ELSE
        drawVisibleX = drawX + (firstChar - 1) * 8
        visibleText = MID$(textValue, firstChar, lastChar - firstChar + 1)
        DRAW STRING (drawVisibleX, drawY), visibleText, colValue
    END IF
END SUB

SUB DrawStringSliceClipped(BYVAL drawX AS INTEGER, BYVAL drawY AS INTEGER, BYREF textValue AS STRING, _
                           BYVAL firstChar AS INTEGER, BYVAL charCount AS INTEGER, BYVAL maxChars AS INTEGER, _
                           BYVAL colValue AS INTEGER, _
                           BYVAL clipL AS INTEGER, BYVAL clipT AS INTEGER, BYVAL clipR AS INTEGER, BYVAL clipB AS INTEGER)
    DIM sourceLen AS INTEGER
    DIM sliceLen AS INTEGER
    DIM firstVisible AS INTEGER
    DIM lastVisible AS INTEGER
    DIM drawVisibleX AS INTEGER
    DIM pixelRight AS LONG
    DIM visibleText AS STRING

    IF drawY + 7 < clipT THEN EXIT SUB
    IF drawY > clipB THEN EXIT SUB

    sourceLen = LEN(textValue)
    IF sourceLen <= 0 THEN EXIT SUB
    IF firstChar < 1 THEN firstChar = 1
    IF firstChar > sourceLen THEN EXIT SUB
    IF charCount <= 0 THEN EXIT SUB

    sliceLen = charCount
    IF maxChars > 0 AND sliceLen > maxChars THEN sliceLen = maxChars
    IF firstChar + sliceLen - 1 > sourceLen THEN sliceLen = sourceLen - firstChar + 1
    IF sliceLen <= 0 THEN EXIT SUB

    pixelRight = CLNG(drawX) + CLNG(sliceLen) * 8 - 1
    IF drawX > clipR OR pixelRight < clipL THEN EXIT SUB

    firstVisible = 1
    IF drawX < clipL THEN firstVisible = ((clipL - drawX) \ 8) + 1

    lastVisible = ((clipR - drawX) \ 8) + 1
    IF lastVisible > sliceLen THEN lastVisible = sliceLen

    IF firstVisible < 1 THEN firstVisible = 1
    IF lastVisible < firstVisible THEN EXIT SUB

    IF firstChar = 1 AND firstVisible = 1 AND lastVisible = sourceLen THEN
        DRAW STRING (drawX, drawY), textValue, colValue
    ELSE
        drawVisibleX = drawX + (firstVisible - 1) * 8
        visibleText = MID$(textValue, firstChar + firstVisible - 1, lastVisible - firstVisible + 1)
        DRAW STRING (drawVisibleX, drawY), visibleText, colValue
    END IF
END SUB


SUB DrawOpenComboPopup(BYVAL elemIdx AS INTEGER, BYVAL contentRight AS INTEGER)
    DIM ex AS INTEGER
    DIM ey AS INTEGER
    DIM ew AS INTEGER
    DIM eh AS INTEGER
    DIM comboRows AS INTEGER
    DIM comboTop AS INTEGER
    DIM comboBottom AS INTEGER
    DIM comboItemH AS INTEGER
    DIM itemCount AS INTEGER
    DIM topIdx AS INTEGER
    DIM itemIdx AS INTEGER
    DIM visibleRow AS INTEGER
    DIM comboPopupH AS INTEGER
    DIM comboRowTop AS INTEGER
    DIM comboRowH AS INTEGER
    DIM comboRowMid AS INTEGER
    DIM comboTextRight AS INTEGER
    DIM comboPopupW AS INTEGER
    DIM comboPopupRight AS INTEGER
    DIM showComboScroll AS INTEGER
    DIM comboScrollLeft AS INTEGER
    DIM comboTrackTop AS INTEGER
    DIM comboTrackBottom AS INTEGER
    DIM comboTrackH AS INTEGER
    DIM comboThumbH AS INTEGER
    DIM comboThumbTop AS INTEGER
    DIM comboThumbBottom AS INTEGER
    DIM activePage AS STRING
    DIM tabNumber AS INTEGER
    DIM visible AS INTEGER
    DIM comboCacheSlot AS INTEGER
    DIM comboItemText AS STRING
    DIM comboSelectedTextUpper AS STRING
    DIM comboItemTextUpper AS STRING
    DIM comboItemDivider AS INTEGER

    IF activeLayoutWindow < 1 OR activeLayoutWindow > 12 THEN EXIT SUB
    IF elemIdx < 1 OR elemIdx > uiCount THEN EXIT SUB
    IF uiElems(elemIdx).kindKey <> "COMBO" THEN EXIT SUB
    IF comboOpenIndex(activeLayoutWindow) <> elemIdx THEN EXIT SUB

    activePage = ""
    tabNumber = 0
    FOR itemIdx = 1 TO uiCount
        IF uiElems(itemIdx).kindId = UI_KIND_TAB THEN
            tabNumber = tabNumber + 1
            IF tabNumber = uiSelectedTab THEN
                activePage = UCASE$(uiElems(itemIdx).text)
                EXIT FOR
            END IF
        END IF
    NEXT
    IF activePage = "" THEN
        FOR itemIdx = 1 TO uiCount
            IF uiElems(itemIdx).kindId = UI_KIND_TAB THEN
                activePage = UCASE$(uiElems(itemIdx).text)
                EXIT FOR
            END IF
        NEXT
    END IF

    visible = 0
    IF uiElems(elemIdx).page = "" THEN
        visible = -1
    ELSEIF UCASE$(uiElems(elemIdx).page) = activePage THEN
        visible = -1
    END IF
    IF visible = 0 THEN EXIT SUB

    ex = uiWinX + uiElems(elemIdx).x - uiScrollX
    ey = uiWinY + 22 + uiElems(elemIdx).y - uiScrollY
    ew = uiElems(elemIdx).w
    eh = uiElems(elemIdx).h
    IF ew <= 0 THEN ew = 120
    IF eh <= 0 THEN eh = 22

    IF ex < uiWinX + 2 OR ey < uiWinY + 19 THEN EXIT SUB
    IF ex + ew > contentRight OR ey + eh > uiWinY + uiWinH - 2 THEN EXIT SUB

    ' Open combo popups redraw often while the mouse moves.
    ' Render from the existing item cache instead of rebuilding the list on every draw.
    comboCacheSlot = EnsureComboItemCacheSlot(elemIdx)
    IF comboCacheSlot > 0 THEN
        itemCount = comboItemCacheCount(comboCacheSlot)
    ELSE
        BuildComboItems elemIdx
        itemCount = tempComboItemCount
    END IF
    comboRows = EffectiveComboRows(elemIdx, ex, ey, ew, eh)
    comboItemH = 16
    IF comboRows < 1 THEN comboRows = 1
    IF itemCount < comboRows THEN comboRows = itemCount
    IF comboRows < 1 THEN comboRows = 1

    topIdx = comboScrollTop(activeLayoutWindow, elemIdx)
    IF topIdx < 0 THEN topIdx = 0
    IF itemCount > comboRows THEN
        IF topIdx > itemCount - comboRows THEN topIdx = itemCount - comboRows
    ELSE
        topIdx = 0
    END IF
    comboScrollTop(activeLayoutWindow, elemIdx) = topIdx

    comboTop = ey + eh
    IF comboCacheSlot > 0 THEN
        comboPopupH = ComboCachedPopupVisibleHeight(comboCacheSlot, topIdx, comboRows)
    ELSE
        comboPopupH = ComboPopupVisibleHeight(topIdx, comboRows)
    END IF
    comboBottom = comboTop + comboPopupH
    comboPopupW = ComboPopupWidth(elemIdx, ew)
    IF ex + comboPopupW > contentRight THEN comboPopupW = contentRight - ex
    IF comboPopupW < ew THEN comboPopupW = ew
    comboPopupRight = ex + comboPopupW
    Draw3DRect ex, comboTop, comboPopupRight, comboBottom, 1
    LINE (ex + 2, comboTop + 2)-(comboPopupRight - 2, comboBottom - 2), COL_CONTROL_BG, BF

    showComboScroll = 0
    comboTextRight = comboPopupRight - 2
    IF itemCount > comboRows THEN
        showComboScroll = -1
        comboScrollLeft = comboPopupRight - 14
        comboTextRight = comboScrollLeft - 1
        Draw3DRect comboScrollLeft, comboTop + 1, comboPopupRight - 1, comboBottom - 1, 0
        comboTrackTop = comboTop + 3
        comboTrackBottom = comboBottom - 3
        comboTrackH = comboTrackBottom - comboTrackTop + 1
        comboThumbH = CalcScrollThumbSize(comboRows, itemCount, comboTrackH, 12)
        comboThumbTop = CalcScrollThumbTop(topIdx, itemCount - comboRows, comboTrackTop, comboTrackH, comboThumbH)
        comboThumbBottom = comboThumbTop + comboThumbH - 1
        Draw3DRect comboScrollLeft + 1, comboThumbTop, comboPopupRight - 2, comboThumbBottom, 1
    END IF

    comboSelectedTextUpper = UCASE$(RTRIM$(uiElems(elemIdx).text))
    comboRowTop = comboTop
    FOR visibleRow = 0 TO comboRows - 1
        itemIdx = topIdx + visibleRow + 1
        IF itemIdx <= itemCount THEN
            IF comboCacheSlot > 0 THEN
                comboItemDivider = ComboCachedItemIsDivider(comboCacheSlot, itemIdx)
                comboItemText = RTRIM$(comboItemCacheItems(comboCacheSlot, itemIdx))
            ELSE
                comboItemDivider = ComboItemIsDivider(itemIdx)
                comboItemText = RTRIM$(tempComboItems(itemIdx))
            END IF

            IF comboItemDivider <> 0 THEN
                comboRowH = 8
                comboRowMid = comboRowTop + (comboRowH \ 2)
                IF comboTextRight - 6 > ex + 6 THEN
                    LINE (ex + 6, comboRowMid)-(comboTextRight - 6, comboRowMid), COL_BEVEL_LO
                    LINE (ex + 6, comboRowMid + 1)-(comboTextRight - 6, comboRowMid + 1), COL_BEVEL_HI
                END IF
            ELSE
                comboRowH = 16
                comboItemTextUpper = UCASE$(comboItemText)
                IF comboItemTextUpper = comboSelectedTextUpper THEN
                    LINE (ex + 2, comboRowTop + 2)-(comboTextRight - 1, comboRowTop + comboRowH - 1), COL_SELECT, BF
                    DRAW STRING (ex + 4, comboRowTop + 4), comboItemText, COL_SELECTED_TEXT
                ELSE
                    DRAW STRING (ex + 4, comboRowTop + 4), comboItemText, COL_TEXT
                END IF
            END IF

            comboRowTop = comboRowTop + comboRowH
        END IF
    NEXT
END SUB




SUB FreeLayoutOverlayCacheSlot(BYVAL slotIdx AS INTEGER)
    IF slotIdx < 1 OR slotIdx > LAYOUT_OVERLAY_CACHE_MAX THEN EXIT SUB

    IF layoutOverlayCacheImg(slotIdx) <> 0 THEN
        ImageDestroy layoutOverlayCacheImg(slotIdx)
        layoutOverlayCacheImg(slotIdx) = 0
    END IF
    IF layoutOverlayCachePix(slotIdx) <> 0 THEN
        DEALLOCATE layoutOverlayCachePix(slotIdx)
        layoutOverlayCachePix(slotIdx) = 0
    END IF
    FreeTransparentRunCache layoutOverlayCacheRunY(slotIdx), layoutOverlayCacheRunX1(slotIdx), _
                            layoutOverlayCacheRunX2(slotIdx), layoutOverlayCacheRunCol(slotIdx), _
                            layoutOverlayCacheRunCount(slotIdx)

    layoutOverlayCachePath(slotIdx) = ""
    layoutOverlayCacheStamp(slotIdx) = 0
    layoutOverlayCacheW(slotIdx) = 0
    layoutOverlayCacheH(slotIdx) = 0
    layoutOverlayCacheLoaded(slotIdx) = 0
    layoutOverlayCacheHasTrans(slotIdx) = 0
    layoutOverlayCacheAge(slotIdx) = 0
END SUB

SUB ClearLayoutOverlayCache()
    DIM slotIdx AS INTEGER

    FOR slotIdx = 1 TO LAYOUT_OVERLAY_CACHE_MAX
        FreeLayoutOverlayCacheSlot slotIdx
    NEXT
    layoutOverlayCacheTick = 0
END SUB

FUNCTION ResolveLayoutOverlayBmpPath(BYVAL appPath AS STRING, BYVAL bmpSpec AS STRING) AS STRING
    DIM resolvedPath AS STRING
    DIM cleanSpec AS STRING

    cleanSpec = NormalizePath(TRIM$(bmpSpec))
    IF cleanSpec = "" THEN RETURN ""

    resolvedPath = ResolveAppLocalFilePathFromFile(appPath, cleanSpec)
    resolvedPath = LayoutFilePath(NormalizePath(resolvedPath))
    RETURN resolvedPath
END FUNCTION

FUNCTION EnsureLayoutOverlayCache(BYVAL bmpPath AS STRING) AS INTEGER
    DIM normPath AS STRING
    DIM fileStamp AS DOUBLE
    DIM slotIdx AS INTEGER
    DIM freeSlot AS INTEGER
    DIM oldestSlot AS INTEGER
    DIM oldestAge AS LONG
    DIM loadedPix AS UINTEGER PTR
    DIM loadedW AS INTEGER
    DIM loadedH AS INTEGER
    DIM hasTrans AS INTEGER

    normPath = LayoutFilePath(NormalizePath(bmpPath))
    IF normPath = "" THEN RETURN 0
    IF DIR(normPath) = "" THEN RETURN 0

    fileStamp = FileDateTime(normPath)

    FOR slotIdx = 1 TO LAYOUT_OVERLAY_CACHE_MAX
        IF layoutOverlayCacheLoaded(slotIdx) <> 0 THEN
            IF layoutOverlayCachePath(slotIdx) = normPath AND layoutOverlayCacheStamp(slotIdx) = fileStamp THEN
                layoutOverlayCacheTick = layoutOverlayCacheTick + 1
                layoutOverlayCacheAge(slotIdx) = layoutOverlayCacheTick
                RETURN slotIdx
            END IF
        END IF
    NEXT

    freeSlot = 0
    FOR slotIdx = 1 TO LAYOUT_OVERLAY_CACHE_MAX
        IF layoutOverlayCacheLoaded(slotIdx) = 0 THEN
            freeSlot = slotIdx
            EXIT FOR
        END IF
    NEXT

    IF freeSlot = 0 THEN
        oldestSlot = 1
        oldestAge = layoutOverlayCacheAge(1)
        FOR slotIdx = 2 TO LAYOUT_OVERLAY_CACHE_MAX
            IF layoutOverlayCacheAge(slotIdx) < oldestAge THEN
                oldestAge = layoutOverlayCacheAge(slotIdx)
                oldestSlot = slotIdx
            END IF
        NEXT
        freeSlot = oldestSlot
    END IF

    FreeLayoutOverlayCacheSlot freeSlot

    loadedPix = 0
    loadedW = 0
    loadedH = 0
    IF LoadBmpColor(normPath, loadedPix, loadedW, loadedH) = 0 THEN RETURN 0
    IF loadedPix = 0 OR loadedW <= 0 OR loadedH <= 0 THEN
        IF loadedPix <> 0 THEN DEALLOCATE loadedPix
        RETURN 0
    END IF

    hasTrans = PixelBufferHasTransparency(loadedPix, loadedW, loadedH)

    layoutOverlayCachePath(freeSlot) = normPath
    layoutOverlayCacheStamp(freeSlot) = fileStamp
    layoutOverlayCachePix(freeSlot) = loadedPix
    layoutOverlayCacheW(freeSlot) = loadedW
    layoutOverlayCacheH(freeSlot) = loadedH
    layoutOverlayCacheHasTrans(freeSlot) = hasTrans
    IF hasTrans <> 0 THEN
        BuildTransparentRunCache loadedPix, loadedW, loadedH, layoutOverlayCacheRunY(freeSlot), _
                                 layoutOverlayCacheRunX1(freeSlot), layoutOverlayCacheRunX2(freeSlot), _
                                 layoutOverlayCacheRunCol(freeSlot), layoutOverlayCacheRunCount(freeSlot)
    ELSE
        layoutOverlayCacheImg(freeSlot) = BuildImageBufferFromPixels(loadedPix, loadedW, loadedH)
    END IF
    layoutOverlayCacheTick = layoutOverlayCacheTick + 1
    layoutOverlayCacheAge(freeSlot) = layoutOverlayCacheTick
    layoutOverlayCacheLoaded(freeSlot) = -1

    RETURN freeSlot
END FUNCTION

SUB DrawLayoutOverlayCacheSlot(BYVAL slotIdx AS INTEGER, BYVAL drawX AS INTEGER, BYVAL drawY AS INTEGER, _
                                  BYVAL limitW AS INTEGER, BYVAL limitH AS INTEGER, _
                                  BYVAL clipL AS INTEGER, BYVAL clipT AS INTEGER, _
                                  BYVAL clipR AS INTEGER, BYVAL clipB AS INTEGER)
    DIM bmpW AS INTEGER
    DIM bmpH AS INTEGER
    DIM srcX1 AS INTEGER
    DIM srcY1 AS INTEGER
    DIM srcX2 AS INTEGER
    DIM srcY2 AS INTEGER
    DIM runIdx AS INTEGER
    DIM screenY AS INTEGER
    DIM sx1 AS INTEGER
    DIM sx2 AS INTEGER
    DIM runStart AS INTEGER
    DIM runCol AS UINTEGER
    DIM curCol AS UINTEGER
    DIM srcX AS INTEGER
    DIM srcY AS INTEGER
    DIM rowBase AS LONG
    DIM transMode AS INTEGER
    DIM pixPtr AS UINTEGER PTR
    DIM runYPtr AS INTEGER PTR
    DIM runX1Ptr AS INTEGER PTR
    DIM runX2Ptr AS INTEGER PTR
    DIM runColPtr AS UINTEGER PTR

    IF slotIdx < 1 OR slotIdx > LAYOUT_OVERLAY_CACHE_MAX THEN EXIT SUB
    IF layoutOverlayCacheLoaded(slotIdx) = 0 THEN EXIT SUB
    IF layoutOverlayCachePix(slotIdx) = 0 THEN EXIT SUB

    pixPtr = layoutOverlayCachePix(slotIdx)
    bmpW = layoutOverlayCacheW(slotIdx)
    bmpH = layoutOverlayCacheH(slotIdx)
    IF bmpW <= 0 OR bmpH <= 0 THEN EXIT SUB

    IF limitW <= 0 OR limitW > bmpW THEN limitW = bmpW
    IF limitH <= 0 OR limitH > bmpH THEN limitH = bmpH
    IF limitW <= 0 OR limitH <= 0 THEN EXIT SUB

    IF drawX > clipR OR drawY > clipB THEN EXIT SUB
    IF drawX + limitW - 1 < clipL OR drawY + limitH - 1 < clipT THEN EXIT SUB
    IF drawX >= SCR_W OR drawY >= SCR_H THEN EXIT SUB
    IF drawX + limitW - 1 < 0 OR drawY + limitH - 1 < 0 THEN EXIT SUB

    IF layoutOverlayCacheImg(slotIdx) <> 0 AND layoutOverlayCacheHasTrans(slotIdx) = 0 AND _
       drawX >= clipL AND drawY >= clipT AND drawX + bmpW - 1 <= clipR AND drawY + bmpH - 1 <= clipB AND _
       drawX >= 0 AND drawY >= 0 AND drawX + bmpW - 1 < SCR_W AND drawY + bmpH - 1 < SCR_H AND _
       limitW = bmpW AND limitH = bmpH THEN
        PUT (drawX, drawY), layoutOverlayCacheImg(slotIdx), PSET
        EXIT SUB
    END IF

    runYPtr = layoutOverlayCacheRunY(slotIdx)
    runX1Ptr = layoutOverlayCacheRunX1(slotIdx)
    runX2Ptr = layoutOverlayCacheRunX2(slotIdx)
    runColPtr = layoutOverlayCacheRunCol(slotIdx)
    IF layoutOverlayCacheHasTrans(slotIdx) <> 0 AND layoutOverlayCacheRunCount(slotIdx) > 0 AND _
       runYPtr <> 0 AND runX1Ptr <> 0 AND runX2Ptr <> 0 AND runColPtr <> 0 THEN
        FOR runIdx = 0 TO layoutOverlayCacheRunCount(slotIdx) - 1
            IF runYPtr[runIdx] >= 0 AND runYPtr[runIdx] < limitH THEN
                screenY = drawY + runYPtr[runIdx]
                IF screenY >= clipT AND screenY <= clipB AND screenY >= 0 AND screenY < SCR_H THEN
                    sx1 = drawX + runX1Ptr[runIdx]
                    sx2 = drawX + runX2Ptr[runIdx]
                    IF sx1 < drawX THEN sx1 = drawX
                    IF sx2 > drawX + limitW - 1 THEN sx2 = drawX + limitW - 1
                    IF sx2 >= clipL AND sx1 <= clipR AND sx2 >= 0 AND sx1 < SCR_W THEN
                        IF sx1 < clipL THEN sx1 = clipL
                        IF sx2 > clipR THEN sx2 = clipR
                        IF sx1 < 0 THEN sx1 = 0
                        IF sx2 >= SCR_W THEN sx2 = SCR_W - 1
                        IF sx1 <= sx2 THEN LINE (sx1, screenY)-(sx2, screenY), runColPtr[runIdx]
                    END IF
                END IF
            END IF
        NEXT
        EXIT SUB
    END IF

    srcX1 = 0
    srcY1 = 0
    srcX2 = limitW - 1
    srcY2 = limitH - 1

    IF drawX < clipL THEN srcX1 = clipL - drawX
    IF drawY < clipT THEN srcY1 = clipT - drawY
    IF drawX + srcX2 > clipR THEN srcX2 = clipR - drawX
    IF drawY + srcY2 > clipB THEN srcY2 = clipB - drawY
    IF drawX < 0 AND -drawX > srcX1 THEN srcX1 = -drawX
    IF drawY < 0 AND -drawY > srcY1 THEN srcY1 = -drawY
    IF drawX + srcX2 >= SCR_W THEN srcX2 = SCR_W - drawX - 1
    IF drawY + srcY2 >= SCR_H THEN srcY2 = SCR_H - drawY - 1

    IF srcX1 > srcX2 OR srcY1 > srcY2 THEN EXIT SUB

    transMode = layoutOverlayCacheHasTrans(slotIdx)
    FOR srcY = srcY1 TO srcY2
        screenY = drawY + srcY
        rowBase = CLNG(srcY) * bmpW
        runStart = -1
        runCol = 0
        FOR srcX = srcX1 TO srcX2
            curCol = pixPtr[rowBase + srcX]
            IF transMode <> 0 AND IsTransparentBmpColor(curCol) <> 0 THEN
                IF runStart >= 0 THEN
                    LINE (drawX + runStart, screenY)-(drawX + srcX - 1, screenY), runCol
                    runStart = -1
                END IF
            ELSEIF runStart < 0 THEN
                runStart = srcX
                runCol = curCol
            ELSEIF curCol <> runCol THEN
                LINE (drawX + runStart, screenY)-(drawX + srcX - 1, screenY), runCol
                runStart = srcX
                runCol = curCol
            END IF
        NEXT
        IF runStart >= 0 THEN LINE (drawX + runStart, screenY)-(drawX + srcX2, screenY), runCol
    NEXT
END SUB

FUNCTION LayoutOverlayIsWholeWindow(BYVAL elemIdx AS INTEGER) AS INTEGER
    DIM scopeText AS STRING

    LayoutOverlayIsWholeWindow = 0
    IF elemIdx < 1 OR elemIdx > uiCount THEN EXIT FUNCTION
    IF uiElems(elemIdx).kindId <> UI_KIND_OVERLAY THEN EXIT FUNCTION

    scopeText = UCASE$(TRIM$(uiElems(elemIdx).drawStyle))
    IF scopeText = "WINDOW" OR scopeText = "FULL_WINDOW" OR scopeText = "WHOLE_WINDOW" OR scopeText = "CHROME" THEN
        LayoutOverlayIsWholeWindow = -1
        EXIT FUNCTION
    END IF

    scopeText = UCASE$(TRIM$(uiElems(elemIdx).modeGroup))
    IF scopeText = "WINDOW" OR scopeText = "FULL_WINDOW" OR scopeText = "WHOLE_WINDOW" OR scopeText = "CHROME" THEN
        LayoutOverlayIsWholeWindow = -1
    END IF
END FUNCTION

SUB DrawLayoutOverlayElement(BYVAL elemIdx AS INTEGER, BYVAL activePage AS STRING, _
                                BYVAL clipL AS INTEGER, BYVAL clipT AS INTEGER, _
                                BYVAL clipR AS INTEGER, BYVAL clipB AS INTEGER, _
                                BYVAL windowScope AS INTEGER)
    DIM bmpSpec AS STRING
    DIM bmpPath AS STRING
    DIM slotIdx AS INTEGER
    DIM ex AS INTEGER
    DIM ey AS INTEGER
    DIM ew AS INTEGER
    DIM eh AS INTEGER
    DIM sourceText AS STRING

    IF elemIdx < 1 OR elemIdx > uiCount THEN EXIT SUB
    IF uiElems(elemIdx).kindId <> UI_KIND_OVERLAY THEN EXIT SUB
    IF uiElems(elemIdx).page <> "" THEN
        IF uiElems(elemIdx).pageKey <> activePage THEN EXIT SUB
    END IF

    bmpSpec = TRIM$(uiElems(elemIdx).text)
    IF TRIM$(uiElems(elemIdx).sourceControl) <> "" THEN
        sourceText = TRIM$(GetControlTextValue(uiElems(elemIdx).sourceControl))
        IF sourceText <> "" THEN bmpSpec = sourceText
    END IF
    IF bmpSpec = "" THEN EXIT SUB

    bmpPath = ResolveLayoutOverlayBmpPath(uiLayoutAppPath, bmpSpec)
    IF bmpPath = "" THEN EXIT SUB

    slotIdx = EnsureLayoutOverlayCache(bmpPath)
    IF slotIdx < 1 THEN EXIT SUB

    ew = uiElems(elemIdx).w
    eh = uiElems(elemIdx).h

    IF windowScope <> 0 THEN
        ex = uiWinX + uiElems(elemIdx).x
        ey = uiWinY + uiElems(elemIdx).y
        IF ew <= 0 THEN ew = (uiWinW + 1) - uiElems(elemIdx).x
        IF eh <= 0 THEN eh = (uiWinH + 1) - uiElems(elemIdx).y
    ELSE
        ex = uiWinX + uiElems(elemIdx).x - uiScrollX
        ey = uiWinY + 22 + uiElems(elemIdx).y - uiScrollY
        IF ew <= 0 THEN ew = layoutOverlayCacheW(slotIdx)
        IF eh <= 0 THEN eh = layoutOverlayCacheH(slotIdx)
    END IF

    DrawLayoutOverlayCacheSlot slotIdx, ex, ey, ew, eh, clipL, clipT, clipR, clipB
END SUB

SUB DrawLayoutOverlays(BYVAL activePage AS STRING, BYVAL clipL AS INTEGER, BYVAL clipT AS INTEGER, BYVAL clipR AS INTEGER, BYVAL clipB AS INTEGER)
    DIM elemIdx AS INTEGER
    DIM drawOverlay AS INTEGER

    IF layoutDrawPass = 1 THEN EXIT SUB

    FOR elemIdx = 1 TO uiCount
        IF uiElems(elemIdx).kindId = UI_KIND_OVERLAY THEN
            IF LayoutOverlayIsWholeWindow(elemIdx) = 0 THEN
                drawOverlay = 0
                IF layoutDrawPass = 0 OR layoutDrawPass = 2 OR layoutDrawPass = 3 OR layoutDrawPass = 4 THEN drawOverlay = -1
                IF drawOverlay <> 0 THEN DrawLayoutOverlayElement elemIdx, activePage, clipL, clipT, clipR, clipB, 0
            END IF
        END IF
    NEXT
END SUB

SUB DrawLayoutWindowOverlays(BYVAL activePage AS STRING, BYVAL clipL AS INTEGER, BYVAL clipT AS INTEGER, BYVAL clipR AS INTEGER, BYVAL clipB AS INTEGER)
    DIM elemIdx AS INTEGER
    DIM drawOverlay AS INTEGER

    IF layoutDrawPass = 1 THEN EXIT SUB

    FOR elemIdx = 1 TO uiCount
        IF uiElems(elemIdx).kindId = UI_KIND_OVERLAY THEN
            IF LayoutOverlayIsWholeWindow(elemIdx) <> 0 THEN
                drawOverlay = 0
                IF layoutDrawPass = 0 OR layoutDrawPass = 2 OR layoutDrawPass = 3 OR layoutDrawPass = 4 THEN drawOverlay = -1
                IF drawOverlay <> 0 THEN DrawLayoutOverlayElement elemIdx, activePage, clipL, clipT, clipR, clipB, -1
            END IF
        END IF
    NEXT
END SUB

' ---------------------------
' Generic windowed canvas support
' ---------------------------

SUB CanvasFreeSpriteSlot(BYVAL winIdx AS INTEGER, BYVAL spriteIdx AS INTEGER)
    IF winIdx < 1 OR winIdx > 12 THEN EXIT SUB
    IF spriteIdx < 1 OR spriteIdx > CANVAS_MAX_SPRITES THEN EXIT SUB
    IF canvasSpritePix(winIdx, spriteIdx) <> 0 THEN
        DEALLOCATE canvasSpritePix(winIdx, spriteIdx)
        canvasSpritePix(winIdx, spriteIdx) = 0
    END IF
    canvasSpriteLoaded(winIdx, spriteIdx) = 0
    canvasSpriteName(winIdx, spriteIdx) = ""
    canvasSpriteW(winIdx, spriteIdx) = 0
    canvasSpriteH(winIdx, spriteIdx) = 0
    canvasSpriteTransparent(winIdx, spriteIdx) = -1
END SUB

SUB CanvasFreeSprites(BYVAL winIdx AS INTEGER)
    DIM i AS INTEGER
    IF winIdx < 1 OR winIdx > 12 THEN EXIT SUB
    FOR i = 1 TO CANVAS_MAX_SPRITES
        CanvasFreeSpriteSlot winIdx, i
    NEXT
END SUB

SUB CanvasFreeSlot(BYVAL winIdx AS INTEGER)
    IF winIdx < 1 OR winIdx > 12 THEN EXIT SUB
    IF canvasPix(winIdx) <> 0 THEN
        DEALLOCATE canvasPix(winIdx)
        canvasPix(winIdx) = 0
    END IF
    IF canvasWorkPix(winIdx) <> 0 THEN
        DEALLOCATE canvasWorkPix(winIdx)
        canvasWorkPix(winIdx) = 0
    END IF
    CanvasFreeSprites winIdx
    canvasLoaded(winIdx) = 0
    canvasViewName(winIdx) = ""
    canvasW(winIdx) = 0
    canvasH(winIdx) = 0
    canvasColors(winIdx) = 0
    canvasClearIndex(winIdx) = 0
    canvasDirty(winIdx) = 0
    canvasDirtyX1(winIdx) = 0
    canvasDirtyY1(winIdx) = 0
    canvasDirtyX2(winIdx) = 0
    canvasDirtyY2(winIdx) = 0
    canvasPalettePath(winIdx) = ""
    canvasTickEnabled(winIdx) = 0
    canvasTickMs(winIdx) = 0
    canvasLastTick(winIdx) = 0
END SUB

FUNCTION CanvasViewMatches(BYVAL winIdx AS INTEGER, BYVAL viewName AS STRING) AS INTEGER
    DIM keyName AS STRING

    IF winIdx < 1 OR winIdx > 12 THEN RETURN 0
    IF canvasLoaded(winIdx) = 0 THEN RETURN 0
    keyName = UCASE$(TRIM$(viewName))
    IF keyName = "" THEN RETURN -1
    IF canvasViewName(winIdx) = keyName THEN RETURN -1
    RETURN 0
END FUNCTION

SUB CanvasRebuildColorCache(BYVAL winIdx AS INTEGER)
    DIM i AS INTEGER
    DIM r AS INTEGER
    DIM g AS INTEGER
    DIM b AS INTEGER

    IF winIdx < 1 OR winIdx > 12 THEN EXIT SUB
    FOR i = 0 TO 255
        IF cfg.colorDepth = 4 THEN
            IF canvasColors(winIdx) <= 16 THEN
                canvasColorCache(winIdx, i) = i AND 15
            ELSE
                r = canvasPalR(winIdx, i)
                g = canvasPalG(winIdx, i)
                b = canvasPalB(winIdx, i)
                canvasColorCache(winIdx, i) = Backlash16ColorIndex(r, g, b)
            END IF
        ELSE
            canvasColorCache(winIdx, i) = MakeCol(canvasPalR(winIdx, i), canvasPalG(winIdx, i), canvasPalB(winIdx, i))
        END IF
    NEXT
    canvasColorDepth(winIdx) = cfg.colorDepth
END SUB

FUNCTION CanvasColor(BYVAL winIdx AS INTEGER, BYVAL colorIdx AS INTEGER) AS UINTEGER
    IF winIdx < 1 OR winIdx > 12 THEN RETURN COL_CONTROL_BG
    IF canvasColorDepth(winIdx) <> cfg.colorDepth THEN CanvasRebuildColorCache winIdx
    IF colorIdx < 0 THEN colorIdx = 0
    IF colorIdx > 255 THEN colorIdx = 255
    RETURN canvasColorCache(winIdx, colorIdx)
END FUNCTION

SUB CanvasInitDefaultPalette(BYVAL winIdx AS INTEGER, BYVAL colorCount AS INTEGER)
    DIM i AS INTEGER
    DIM ri AS INTEGER
    DIM gi AS INTEGER
    DIM bi AS INTEGER
    DIM shade AS INTEGER

    IF winIdx < 1 OR winIdx > 12 THEN EXIT SUB
    FOR i = 0 TO 255
        canvasPalR(winIdx, i) = 0
        canvasPalG(winIdx, i) = 0
        canvasPalB(winIdx, i) = 0
    NEXT

    canvasPalR(winIdx, 0) = 0: canvasPalG(winIdx, 0) = 0: canvasPalB(winIdx, 0) = 0
    canvasPalR(winIdx, 1) = 0: canvasPalG(winIdx, 1) = 0: canvasPalB(winIdx, 1) = 170
    canvasPalR(winIdx, 2) = 0: canvasPalG(winIdx, 2) = 170: canvasPalB(winIdx, 2) = 0
    canvasPalR(winIdx, 3) = 0: canvasPalG(winIdx, 3) = 170: canvasPalB(winIdx, 3) = 170
    canvasPalR(winIdx, 4) = 170: canvasPalG(winIdx, 4) = 0: canvasPalB(winIdx, 4) = 0
    canvasPalR(winIdx, 5) = 170: canvasPalG(winIdx, 5) = 0: canvasPalB(winIdx, 5) = 170
    canvasPalR(winIdx, 6) = 170: canvasPalG(winIdx, 6) = 85: canvasPalB(winIdx, 6) = 0
    canvasPalR(winIdx, 7) = 170: canvasPalG(winIdx, 7) = 170: canvasPalB(winIdx, 7) = 170
    canvasPalR(winIdx, 8) = 85: canvasPalG(winIdx, 8) = 85: canvasPalB(winIdx, 8) = 85
    canvasPalR(winIdx, 9) = 85: canvasPalG(winIdx, 9) = 85: canvasPalB(winIdx, 9) = 255
    canvasPalR(winIdx, 10) = 85: canvasPalG(winIdx, 10) = 255: canvasPalB(winIdx, 10) = 85
    canvasPalR(winIdx, 11) = 85: canvasPalG(winIdx, 11) = 255: canvasPalB(winIdx, 11) = 255
    canvasPalR(winIdx, 12) = 255: canvasPalG(winIdx, 12) = 85: canvasPalB(winIdx, 12) = 85
    canvasPalR(winIdx, 13) = 255: canvasPalG(winIdx, 13) = 0: canvasPalB(winIdx, 13) = 255
    canvasPalR(winIdx, 14) = 255: canvasPalG(winIdx, 14) = 255: canvasPalB(winIdx, 14) = 85
    canvasPalR(winIdx, 15) = 255: canvasPalG(winIdx, 15) = 255: canvasPalB(winIdx, 15) = 255

    IF colorCount > 16 THEN
        FOR ri = 0 TO 5
            FOR gi = 0 TO 5
                FOR bi = 0 TO 5
                    i = 16 + ri * 36 + gi * 6 + bi
                    canvasPalR(winIdx, i) = ri * 51
                    canvasPalG(winIdx, i) = gi * 51
                    canvasPalB(winIdx, i) = bi * 51
                NEXT
            NEXT
        NEXT
        FOR i = 232 TO 255
            shade = 8 + (i - 232) * 10
            canvasPalR(winIdx, i) = shade
            canvasPalG(winIdx, i) = shade
            canvasPalB(winIdx, i) = shade
        NEXT
    END IF
    CanvasRebuildColorCache winIdx
END SUB

FUNCTION CanvasLoadPaletteFile(BYVAL winIdx AS INTEGER, BYVAL palPath AS STRING) AS INTEGER
    DIM f AS INTEGER
    DIM rawLine AS STRING
    DIM lineText AS STRING
    DIM leftText AS STRING
    DIM valText AS STRING
    DIM p AS INTEGER
    DIM comma1 AS INTEGER
    DIM comma2 AS INTEGER
    DIM idx AS INTEGER
    DIM autoIdx AS INTEGER
    DIM r AS INTEGER
    DIM g AS INTEGER
    DIM b AS INTEGER

    CanvasLoadPaletteFile = 0
    IF winIdx < 1 OR winIdx > 12 THEN EXIT FUNCTION
    palPath = NormalizePath(TRIM$(palPath))
    IF palPath = "" THEN EXIT FUNCTION
    IF DIR(palPath) = "" THEN EXIT FUNCTION

    f = FREEFILE
    IF OPEN(palPath FOR INPUT AS #f) <> 0 THEN EXIT FUNCTION
    autoIdx = 0
    DO WHILE EOF(f) = 0
        LINE INPUT #f, rawLine
        lineText = TRIM$(rawLine)
        IF lineText <> "" THEN
            IF LEFT$(lineText, 1) <> ";" AND LEFT$(lineText, 1) <> "#" THEN
                p = INSTR(lineText, "=")
                IF p > 0 THEN
                    leftText = TRIM$(LEFT$(lineText, p - 1))
                    valText = TRIM$(MID$(lineText, p + 1))
                    idx = VAL(leftText)
                ELSE
                    valText = lineText
                    idx = autoIdx
                END IF
                comma1 = INSTR(valText, ",")
                comma2 = 0
                IF comma1 > 0 THEN comma2 = INSTR(comma1 + 1, valText, ",")
                IF comma1 > 0 AND comma2 > 0 THEN
                    r = ClampI(VAL(LEFT$(valText, comma1 - 1)), 0, 255)
                    g = ClampI(VAL(MID$(valText, comma1 + 1, comma2 - comma1 - 1)), 0, 255)
                    b = ClampI(VAL(MID$(valText, comma2 + 1)), 0, 255)
                    IF idx >= 0 AND idx <= 255 THEN
                        canvasPalR(winIdx, idx) = r
                        canvasPalG(winIdx, idx) = g
                        canvasPalB(winIdx, idx) = b
                    END IF
                    autoIdx = idx + 1
                END IF
            END IF
        END IF
    LOOP
    CLOSE #f
    canvasPalettePath(winIdx) = palPath
    CanvasRebuildColorCache winIdx
    CanvasLoadPaletteFile = -1
END FUNCTION

FUNCTION CanvasEnsureSurface(BYVAL winIdx AS INTEGER, BYVAL viewName AS STRING, BYVAL surfaceW AS INTEGER, BYVAL surfaceH AS INTEGER, BYVAL colorCount AS INTEGER, BYVAL clearIndex AS INTEGER, BYVAL palPath AS STRING) AS INTEGER
    DIM totalPix AS LONG
    DIM i AS LONG

    CanvasEnsureSurface = 0
    IF winIdx < 1 OR winIdx > 12 THEN EXIT FUNCTION
    IF surfaceW < 1 OR surfaceW > CANVAS_MAX_W THEN EXIT FUNCTION
    IF surfaceH < 1 OR surfaceH > CANVAS_MAX_H THEN EXIT FUNCTION
    IF colorCount <= 16 THEN
        colorCount = 16
    ELSE
        colorCount = 256
    END IF
    clearIndex = ClampI(clearIndex, 0, colorCount - 1)

    CanvasFreeSlot winIdx
    totalPix = CLNG(surfaceW) * CLNG(surfaceH)
    canvasPix(winIdx) = CAST(UBYTE PTR, ALLOCATE(totalPix * SIZEOF(UBYTE)))
    IF canvasPix(winIdx) = 0 THEN EXIT FUNCTION
    canvasWorkPix(winIdx) = CAST(UBYTE PTR, ALLOCATE(totalPix * SIZEOF(UBYTE)))
    IF canvasWorkPix(winIdx) = 0 THEN
        DEALLOCATE canvasPix(winIdx)
        canvasPix(winIdx) = 0
        EXIT FUNCTION
    END IF

    FOR i = 0 TO totalPix - 1
        canvasPix(winIdx)[i] = CUBYTE(clearIndex)
        canvasWorkPix(winIdx)[i] = CUBYTE(clearIndex)
    NEXT

    canvasViewName(winIdx) = UCASE$(TRIM$(viewName))
    canvasW(winIdx) = surfaceW
    canvasH(winIdx) = surfaceH
    canvasColors(winIdx) = colorCount
    canvasClearIndex(winIdx) = clearIndex
    canvasDirty(winIdx) = 0
    canvasDirtyX1(winIdx) = 0
    canvasDirtyY1(winIdx) = 0
    canvasDirtyX2(winIdx) = 0
    canvasDirtyY2(winIdx) = 0
    canvasLoaded(winIdx) = -1
    canvasVersion(winIdx) = canvasVersion(winIdx) + 1

    CanvasInitDefaultPalette winIdx, colorCount
    IF TRIM$(palPath) <> "" THEN CanvasLoadPaletteFile winIdx, palPath
    CanvasMarkRelated winIdx
    CanvasEnsureSurface = -1
END FUNCTION

SUB CanvasMarkRelated(BYVAL winIdx AS INTEGER)
    DIM i AS INTEGER
    IF winIdx < 1 OR winIdx > 12 THEN EXIT SUB
    IF layoutWindows(winIdx).used = 0 THEN EXIT SUB
    FOR i = 1 TO layoutUiCount(winIdx)
        IF layoutUiElems(winIdx, i).kindId = UI_KIND_CANVAS THEN
            IF CanvasViewMatches(winIdx, layoutUiElems(winIdx, i).name) <> 0 THEN MarkLayoutDirtyElement winIdx, i
        END IF
    NEXT
END SUB

SUB CanvasMarkDirtyRect(BYVAL winIdx AS INTEGER, BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER)
    DIM t AS INTEGER

    IF winIdx < 1 OR winIdx > 12 THEN EXIT SUB
    IF canvasLoaded(winIdx) = 0 THEN EXIT SUB
    IF x1 > x2 THEN t = x1: x1 = x2: x2 = t
    IF y1 > y2 THEN t = y1: y1 = y2: y2 = t
    IF x2 < 0 OR y2 < 0 OR x1 >= canvasW(winIdx) OR y1 >= canvasH(winIdx) THEN EXIT SUB
    IF x1 < 0 THEN x1 = 0
    IF y1 < 0 THEN y1 = 0
    IF x2 >= canvasW(winIdx) THEN x2 = canvasW(winIdx) - 1
    IF y2 >= canvasH(winIdx) THEN y2 = canvasH(winIdx) - 1

    IF canvasDirty(winIdx) = 0 THEN
        canvasDirtyX1(winIdx) = x1
        canvasDirtyY1(winIdx) = y1
        canvasDirtyX2(winIdx) = x2
        canvasDirtyY2(winIdx) = y2
    ELSE
        IF x1 < canvasDirtyX1(winIdx) THEN canvasDirtyX1(winIdx) = x1
        IF y1 < canvasDirtyY1(winIdx) THEN canvasDirtyY1(winIdx) = y1
        IF x2 > canvasDirtyX2(winIdx) THEN canvasDirtyX2(winIdx) = x2
        IF y2 > canvasDirtyY2(winIdx) THEN canvasDirtyY2(winIdx) = y2
    END IF
    canvasDirty(winIdx) = -1
END SUB

SUB CanvasClearSurface(BYVAL winIdx AS INTEGER, BYVAL colorIdx AS INTEGER)
    DIM totalPix AS LONG
    DIM i AS LONG

    IF winIdx < 1 OR winIdx > 12 THEN EXIT SUB
    IF canvasLoaded(winIdx) = 0 OR canvasWorkPix(winIdx) = 0 THEN EXIT SUB
    colorIdx = ClampI(colorIdx, 0, canvasColors(winIdx) - 1)
    totalPix = CLNG(canvasW(winIdx)) * CLNG(canvasH(winIdx))
    FOR i = 0 TO totalPix - 1
        canvasWorkPix(winIdx)[i] = CUBYTE(colorIdx)
    NEXT
    CanvasMarkDirtyRect winIdx, 0, 0, canvasW(winIdx) - 1, canvasH(winIdx) - 1
END SUB

FUNCTION CanvasSetPixel(BYVAL winIdx AS INTEGER, BYVAL cellX AS INTEGER, BYVAL cellY AS INTEGER, BYVAL colorIdx AS INTEGER) AS INTEGER
    DIM pixIdx AS LONG

    CanvasSetPixel = 0
    IF winIdx < 1 OR winIdx > 12 THEN EXIT FUNCTION
    IF canvasLoaded(winIdx) = 0 OR canvasWorkPix(winIdx) = 0 THEN EXIT FUNCTION
    IF cellX < 0 OR cellX >= canvasW(winIdx) THEN EXIT FUNCTION
    IF cellY < 0 OR cellY >= canvasH(winIdx) THEN EXIT FUNCTION
    colorIdx = ClampI(colorIdx, 0, canvasColors(winIdx) - 1)
    pixIdx = CLNG(cellY) * canvasW(winIdx) + cellX
    IF canvasWorkPix(winIdx)[pixIdx] = colorIdx THEN EXIT FUNCTION
    canvasWorkPix(winIdx)[pixIdx] = CUBYTE(colorIdx)
    CanvasMarkDirtyRect winIdx, cellX, cellY, cellX, cellY
    CanvasSetPixel = -1
END FUNCTION

SUB CanvasDrawLine(BYVAL winIdx AS INTEGER, BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER, BYVAL colorIdx AS INTEGER)
    DIM dx AS INTEGER
    DIM dy AS INTEGER
    DIM sx AS INTEGER
    DIM sy AS INTEGER
    DIM errVal AS INTEGER
    DIM e2 AS INTEGER

    IF winIdx < 1 OR winIdx > 12 THEN EXIT SUB
    IF canvasLoaded(winIdx) = 0 OR canvasWorkPix(winIdx) = 0 THEN EXIT SUB

    dx = AbsI(x2 - x1)
    dy = -AbsI(y2 - y1)
    IF x1 < x2 THEN sx = 1 ELSE sx = -1
    IF y1 < y2 THEN sy = 1 ELSE sy = -1
    errVal = dx + dy

    DO
        CanvasSetPixel winIdx, x1, y1, colorIdx
        IF x1 = x2 AND y1 = y2 THEN EXIT DO
        e2 = errVal * 2
        IF e2 >= dy THEN
            errVal = errVal + dy
            x1 = x1 + sx
        END IF
        IF e2 <= dx THEN
            errVal = errVal + dx
            y1 = y1 + sy
        END IF
    LOOP
END SUB

SUB CanvasDrawRect(BYVAL winIdx AS INTEGER, BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER, BYVAL colorIdx AS INTEGER, BYVAL fillFlag AS INTEGER)
    DIM x AS INTEGER
    DIM y AS INTEGER
    DIM t AS INTEGER
    DIM rowBase AS LONG

    IF winIdx < 1 OR winIdx > 12 THEN EXIT SUB
    IF canvasLoaded(winIdx) = 0 OR canvasWorkPix(winIdx) = 0 THEN EXIT SUB
    IF x1 > x2 THEN t = x1: x1 = x2: x2 = t
    IF y1 > y2 THEN t = y1: y1 = y2: y2 = t
    IF x2 < 0 OR y2 < 0 OR x1 >= canvasW(winIdx) OR y1 >= canvasH(winIdx) THEN EXIT SUB
    IF x1 < 0 THEN x1 = 0
    IF y1 < 0 THEN y1 = 0
    IF x2 >= canvasW(winIdx) THEN x2 = canvasW(winIdx) - 1
    IF y2 >= canvasH(winIdx) THEN y2 = canvasH(winIdx) - 1
    colorIdx = ClampI(colorIdx, 0, canvasColors(winIdx) - 1)

    IF fillFlag <> 0 THEN
        FOR y = y1 TO y2
            rowBase = CLNG(y) * canvasW(winIdx)
            FOR x = x1 TO x2
                canvasWorkPix(winIdx)[rowBase + x] = CUBYTE(colorIdx)
            NEXT
        NEXT
    ELSE
        rowBase = CLNG(y1) * canvasW(winIdx)
        FOR x = x1 TO x2
            canvasWorkPix(winIdx)[rowBase + x] = CUBYTE(colorIdx)
        NEXT
        IF y2 <> y1 THEN
            rowBase = CLNG(y2) * canvasW(winIdx)
            FOR x = x1 TO x2
                canvasWorkPix(winIdx)[rowBase + x] = CUBYTE(colorIdx)
            NEXT
        END IF
        FOR y = y1 + 1 TO y2 - 1
            rowBase = CLNG(y) * canvasW(winIdx)
            canvasWorkPix(winIdx)[rowBase + x1] = CUBYTE(colorIdx)
            IF x2 <> x1 THEN canvasWorkPix(winIdx)[rowBase + x2] = CUBYTE(colorIdx)
        NEXT
    END IF
    CanvasMarkDirtyRect winIdx, x1, y1, x2, y2
END SUB

FUNCTION CanvasNearestColor(BYVAL winIdx AS INTEGER, BYVAL r AS INTEGER, BYVAL g AS INTEGER, BYVAL b AS INTEGER) AS INTEGER
    DIM bestIdx AS INTEGER
    DIM bestDist AS LONG
    DIM i AS INTEGER
    DIM dr AS LONG
    DIM dg AS LONG
    DIM db AS LONG
    DIM dist AS LONG

    bestIdx = 0
    bestDist = 2147483647
    IF winIdx < 1 OR winIdx > 12 THEN RETURN 0
    IF canvasColors(winIdx) <= 0 THEN RETURN 0
    FOR i = 0 TO canvasColors(winIdx) - 1
        dr = CLNG(r - canvasPalR(winIdx, i))
        dg = CLNG(g - canvasPalG(winIdx, i))
        db = CLNG(b - canvasPalB(winIdx, i))
        dist = dr * dr + dg * dg + db * db
        IF dist < bestDist THEN
            bestDist = dist
            bestIdx = i
            IF dist = 0 THEN EXIT FOR
        END IF
    NEXT
    RETURN bestIdx
END FUNCTION

FUNCTION CanvasLoadBmpIndexed(BYVAL winIdx AS INTEGER, BYVAL fileName AS STRING, BYREF outPix AS UBYTE PTR, BYREF outW AS INTEGER, BYREF outH AS INTEGER) AS INTEGER
    DIM f AS INTEGER
    DIM dataText AS STRING
    DIM dataLen AS LONG
    DIM bmpOff AS LONG
    DIM dibSize AS LONG
    DIM bmpW AS LONG
    DIM bmpHRaw AS LONG
    DIM bmpH AS LONG
    DIM bpp AS INTEGER
    DIM rowSize AS LONG
    DIM y AS INTEGER
    DIM x AS INTEGER
    DIM fileY AS INTEGER
    DIM rowOff AS LONG
    DIM b AS INTEGER
    DIM g AS INTEGER
    DIM r AS INTEGER
    DIM idx AS INTEGER
    DIM byteVal AS INTEGER
    DIM pixIdx AS LONG
    DIM palOff AS LONG
    DIM palR(0 TO 255) AS INTEGER
    DIM palG(0 TO 255) AS INTEGER
    DIM palB(0 TO 255) AS INTEGER

    CanvasLoadBmpIndexed = 0
    outPix = 0
    outW = 0
    outH = 0
    IF winIdx < 1 OR winIdx > 12 THEN EXIT FUNCTION
    IF canvasLoaded(winIdx) = 0 THEN EXIT FUNCTION
    fileName = NormalizePath(TRIM$(fileName))
    IF fileName = "" OR DIR(fileName) = "" THEN EXIT FUNCTION

    f = FREEFILE
    IF OPEN(fileName FOR BINARY AS #f) <> 0 THEN EXIT FUNCTION
    dataLen = LOF(f)
    IF dataLen < 54 THEN
        CLOSE #f
        EXIT FUNCTION
    END IF
    dataText = SPACE$(dataLen)
    GET #f, 1, dataText
    CLOSE #f

    IF AppViewBmpByteAt(dataText, 0) <> ASC("B") OR AppViewBmpByteAt(dataText, 1) <> ASC("M") THEN EXIT FUNCTION
    bmpOff = AppViewBmpU32At(dataText, 10)
    dibSize = AppViewBmpU32At(dataText, 14)
    IF dibSize < 40 THEN EXIT FUNCTION
    bmpW = AppViewBmpU32At(dataText, 18)
    bmpHRaw = AppViewBmpU32At(dataText, 22)
    IF bmpHRaw < 0 THEN bmpH = -bmpHRaw ELSE bmpH = bmpHRaw
    bpp = AppViewBmpU16At(dataText, 28)
    IF bmpW < 1 OR bmpW > CANVAS_MAX_W THEN EXIT FUNCTION
    IF bmpH < 1 OR bmpH > CANVAS_MAX_H THEN EXIT FUNCTION
    IF bpp <> 4 AND bpp <> 8 AND bpp <> 24 THEN EXIT FUNCTION

    outPix = CAST(UBYTE PTR, ALLOCATE(CLNG(bmpW) * CLNG(bmpH) * SIZEOF(UBYTE)))
    IF outPix = 0 THEN EXIT FUNCTION

    IF bpp = 4 OR bpp = 8 THEN
        palOff = 14 + dibSize
        FOR idx = 0 TO 255
            IF palOff + idx * 4 + 3 < LEN(dataText) THEN
                palB(idx) = AppViewBmpByteAt(dataText, palOff + idx * 4)
                palG(idx) = AppViewBmpByteAt(dataText, palOff + idx * 4 + 1)
                palR(idx) = AppViewBmpByteAt(dataText, palOff + idx * 4 + 2)
            END IF
        NEXT
    END IF

    rowSize = ((CLNG(bmpW) * bpp + 31) \ 32) * 4
    FOR y = 0 TO bmpH - 1
        IF bmpHRaw < 0 THEN fileY = y ELSE fileY = bmpH - 1 - y
        rowOff = bmpOff + CLNG(fileY) * rowSize
        FOR x = 0 TO bmpW - 1
            IF bpp = 4 THEN
                byteVal = AppViewBmpByteAt(dataText, rowOff + (x \ 2))
                IF (x MOD 2) = 0 THEN idx = (byteVal \ 16) AND 15 ELSE idx = byteVal AND 15
                IF canvasColors(winIdx) <= 16 THEN idx = Backlash16ColorIndex(palR(idx), palG(idx), palB(idx))
            ELSEIF bpp = 8 THEN
                idx = AppViewBmpByteAt(dataText, rowOff + x)
                IF canvasColors(winIdx) <= 16 THEN idx = CanvasNearestColor(winIdx, palR(idx), palG(idx), palB(idx))
            ELSE
                b = AppViewBmpByteAt(dataText, rowOff + CLNG(x) * 3)
                g = AppViewBmpByteAt(dataText, rowOff + CLNG(x) * 3 + 1)
                r = AppViewBmpByteAt(dataText, rowOff + CLNG(x) * 3 + 2)
                idx = CanvasNearestColor(winIdx, r, g, b)
            END IF
            idx = ClampI(idx, 0, canvasColors(winIdx) - 1)
            pixIdx = CLNG(y) * bmpW + x
            outPix[pixIdx] = CUBYTE(idx)
        NEXT
    NEXT

    outW = bmpW
    outH = bmpH
    CanvasLoadBmpIndexed = -1
END FUNCTION

SUB CanvasBlitPixels(BYVAL winIdx AS INTEGER, BYVAL srcPix AS UBYTE PTR, BYVAL srcW AS INTEGER, BYVAL srcH AS INTEGER, BYVAL srcX AS INTEGER, BYVAL srcY AS INTEGER, BYVAL copyW AS INTEGER, BYVAL copyH AS INTEGER, BYVAL dstX AS INTEGER, BYVAL dstY AS INTEGER, BYVAL transparentIdx AS INTEGER)
    DIM x AS INTEGER
    DIM y AS INTEGER
    DIM srcRow AS LONG
    DIM dstRow AS LONG
    DIM colIdx AS INTEGER
    DIM dirtySet AS INTEGER
    DIM dirtyX1 AS INTEGER
    DIM dirtyY1 AS INTEGER
    DIM dirtyX2 AS INTEGER
    DIM dirtyY2 AS INTEGER

    IF winIdx < 1 OR winIdx > 12 THEN EXIT SUB
    IF canvasLoaded(winIdx) = 0 OR canvasWorkPix(winIdx) = 0 THEN EXIT SUB
    IF srcPix = 0 OR srcW < 1 OR srcH < 1 THEN EXIT SUB
    IF copyW < 1 OR copyH < 1 THEN EXIT SUB

    FOR y = 0 TO copyH - 1
        IF srcY + y >= 0 AND srcY + y < srcH AND dstY + y >= 0 AND dstY + y < canvasH(winIdx) THEN
            srcRow = CLNG(srcY + y) * srcW
            dstRow = CLNG(dstY + y) * canvasW(winIdx)
            FOR x = 0 TO copyW - 1
                IF srcX + x >= 0 AND srcX + x < srcW AND dstX + x >= 0 AND dstX + x < canvasW(winIdx) THEN
                    colIdx = srcPix[srcRow + srcX + x]
                    IF transparentIdx < 0 OR colIdx <> transparentIdx THEN
                        canvasWorkPix(winIdx)[dstRow + dstX + x] = CUBYTE(ClampI(colIdx, 0, canvasColors(winIdx) - 1))
                        IF dirtySet = 0 THEN
                            dirtyX1 = dstX + x
                            dirtyY1 = dstY + y
                            dirtyX2 = dstX + x
                            dirtyY2 = dstY + y
                            dirtySet = -1
                        ELSE
                            IF dstX + x < dirtyX1 THEN dirtyX1 = dstX + x
                            IF dstY + y < dirtyY1 THEN dirtyY1 = dstY + y
                            IF dstX + x > dirtyX2 THEN dirtyX2 = dstX + x
                            IF dstY + y > dirtyY2 THEN dirtyY2 = dstY + y
                        END IF
                    END IF
                END IF
            NEXT
        END IF
    NEXT

    IF dirtySet <> 0 THEN CanvasMarkDirtyRect winIdx, dirtyX1, dirtyY1, dirtyX2, dirtyY2
END SUB

FUNCTION CanvasDrawBmp(BYVAL winIdx AS INTEGER, BYVAL viewName AS STRING, BYVAL fileName AS STRING, BYVAL dstX AS INTEGER, BYVAL dstY AS INTEGER, BYVAL transparentIdx AS INTEGER) AS INTEGER
    DIM tempPix AS UBYTE PTR
    DIM tempW AS INTEGER
    DIM tempH AS INTEGER

    CanvasDrawBmp = 0
    IF CanvasViewMatches(winIdx, viewName) = 0 THEN EXIT FUNCTION
    fileName = ResolvePathFromAppWindow(winIdx, fileName)
    IF CanvasLoadBmpIndexed(winIdx, fileName, tempPix, tempW, tempH) = 0 THEN EXIT FUNCTION
    CanvasBlitPixels winIdx, tempPix, tempW, tempH, 0, 0, tempW, tempH, dstX, dstY, transparentIdx
    DEALLOCATE tempPix
    CanvasDrawBmp = -1
END FUNCTION

FUNCTION CanvasSpriteSlot(BYVAL winIdx AS INTEGER, BYVAL spriteName AS STRING, BYVAL createMissing AS INTEGER) AS INTEGER
    DIM i AS INTEGER
    DIM freeSlot AS INTEGER
    DIM nameKey AS STRING

    CanvasSpriteSlot = 0
    IF winIdx < 1 OR winIdx > 12 THEN EXIT FUNCTION
    nameKey = UCASE$(TRIM$(spriteName))
    IF nameKey = "" THEN EXIT FUNCTION

    FOR i = 1 TO CANVAS_MAX_SPRITES
        IF canvasSpriteLoaded(winIdx, i) <> 0 THEN
            IF canvasSpriteName(winIdx, i) = nameKey THEN RETURN i
        ELSEIF freeSlot = 0 THEN
            freeSlot = i
        END IF
    NEXT

    IF createMissing <> 0 AND freeSlot <> 0 THEN RETURN freeSlot
END FUNCTION

FUNCTION CanvasSpriteLoad(BYVAL winIdx AS INTEGER, BYVAL spriteName AS STRING, BYVAL fileName AS STRING, BYVAL transparentIdx AS INTEGER) AS INTEGER
    DIM slotIdx AS INTEGER
    DIM tempPix AS UBYTE PTR
    DIM tempW AS INTEGER
    DIM tempH AS INTEGER

    CanvasSpriteLoad = 0
    IF winIdx < 1 OR winIdx > 12 THEN EXIT FUNCTION
    IF canvasLoaded(winIdx) = 0 THEN EXIT FUNCTION
    slotIdx = CanvasSpriteSlot(winIdx, spriteName, -1)
    IF slotIdx = 0 THEN EXIT FUNCTION

    fileName = ResolvePathFromAppWindow(winIdx, fileName)
    IF CanvasLoadBmpIndexed(winIdx, fileName, tempPix, tempW, tempH) = 0 THEN EXIT FUNCTION

    CanvasFreeSpriteSlot winIdx, slotIdx
    canvasSpritePix(winIdx, slotIdx) = tempPix
    canvasSpriteW(winIdx, slotIdx) = tempW
    canvasSpriteH(winIdx, slotIdx) = tempH
    canvasSpriteTransparent(winIdx, slotIdx) = transparentIdx
    canvasSpriteName(winIdx, slotIdx) = UCASE$(TRIM$(spriteName))
    canvasSpriteLoaded(winIdx, slotIdx) = -1
    CanvasSpriteLoad = -1
END FUNCTION

FUNCTION CanvasSpriteDrawFrame(BYVAL winIdx AS INTEGER, BYVAL spriteName AS STRING, BYVAL frameX AS INTEGER, BYVAL frameY AS INTEGER, BYVAL frameW AS INTEGER, BYVAL frameH AS INTEGER, BYVAL dstX AS INTEGER, BYVAL dstY AS INTEGER, BYVAL transparentIdx AS INTEGER) AS INTEGER
    DIM slotIdx AS INTEGER

    CanvasSpriteDrawFrame = 0
    slotIdx = CanvasSpriteSlot(winIdx, spriteName, 0)
    IF slotIdx = 0 THEN EXIT FUNCTION
    IF canvasSpriteLoaded(winIdx, slotIdx) = 0 OR canvasSpritePix(winIdx, slotIdx) = 0 THEN EXIT FUNCTION
    IF frameW <= 0 THEN frameW = canvasSpriteW(winIdx, slotIdx)
    IF frameH <= 0 THEN frameH = canvasSpriteH(winIdx, slotIdx)
    IF transparentIdx < 0 THEN transparentIdx = canvasSpriteTransparent(winIdx, slotIdx)
    CanvasBlitPixels winIdx, canvasSpritePix(winIdx, slotIdx), canvasSpriteW(winIdx, slotIdx), canvasSpriteH(winIdx, slotIdx), frameX, frameY, frameW, frameH, dstX, dstY, transparentIdx
    CanvasSpriteDrawFrame = -1
END FUNCTION

SUB CanvasPresent(BYVAL winIdx AS INTEGER, BYVAL viewName AS STRING)
    DIM x AS INTEGER
    DIM y AS INTEGER
    DIM srcRow AS LONG
    DIM dstRow AS LONG

    IF winIdx < 1 OR winIdx > 12 THEN EXIT SUB
    IF canvasLoaded(winIdx) = 0 OR canvasPix(winIdx) = 0 OR canvasWorkPix(winIdx) = 0 THEN EXIT SUB
    IF CanvasViewMatches(winIdx, viewName) = 0 THEN EXIT SUB
    IF canvasDirty(winIdx) = 0 THEN EXIT SUB

    FOR y = canvasDirtyY1(winIdx) TO canvasDirtyY2(winIdx)
        srcRow = CLNG(y) * canvasW(winIdx)
        dstRow = srcRow
        FOR x = canvasDirtyX1(winIdx) TO canvasDirtyX2(winIdx)
            canvasPix(winIdx)[dstRow + x] = canvasWorkPix(winIdx)[srcRow + x]
        NEXT
    NEXT

    canvasDirty(winIdx) = 0
    canvasVersion(winIdx) = canvasVersion(winIdx) + 1
    CanvasMarkRelated winIdx
END SUB

SUB CanvasDrawElement(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER, BYVAL ex AS INTEGER, BYVAL ey AS INTEGER, BYVAL ew AS INTEGER, BYVAL eh AS INTEGER, BYVAL clipL AS INTEGER, BYVAL clipT AS INTEGER, BYVAL clipR AS INTEGER, BYVAL clipB AS INTEGER)
    DIM drawW AS INTEGER
    DIM drawH AS INTEGER
    DIM x AS INTEGER
    DIM y AS INTEGER
    DIM sx AS INTEGER
    DIM sy AS INTEGER
    DIM colIdx AS INTEGER
    DIM runColor AS INTEGER
    DIM runStart AS INTEGER
    DIM rowBase AS LONG
    DIM xStart AS INTEGER
    DIM xEnd AS INTEGER
    DIM yStart AS INTEGER
    DIM yEnd AS INTEGER

    IF elemIdx < 1 OR elemIdx > uiCount THEN EXIT SUB
    FillRectClipped ex, ey, ex + ew, ey + eh, clipL, clipT, clipR, clipB, COL_CONTROL_BG
    IF winIdx < 1 OR winIdx > 12 THEN EXIT SUB
    IF canvasLoaded(winIdx) = 0 OR canvasPix(winIdx) = 0 THEN EXIT SUB
    IF CanvasViewMatches(winIdx, uiElems(elemIdx).name) = 0 THEN EXIT SUB

    drawW = ew + 1
    drawH = eh + 1
    IF drawW < 1 OR drawH < 1 THEN EXIT SUB

    xStart = clipL - ex
    yStart = clipT - ey
    xEnd = clipR - ex
    yEnd = clipB - ey
    IF xStart < 0 THEN xStart = 0
    IF yStart < 0 THEN yStart = 0
    IF xEnd >= drawW THEN xEnd = drawW - 1
    IF yEnd >= drawH THEN yEnd = drawH - 1
    IF xEnd < xStart OR yEnd < yStart THEN EXIT SUB

    IF drawW = canvasW(winIdx) AND drawH = canvasH(winIdx) THEN
        FOR y = yStart TO yEnd
            rowBase = CLNG(y) * canvasW(winIdx)
            runStart = xStart
            runColor = canvasPix(winIdx)[rowBase + xStart]
            FOR x = xStart + 1 TO xEnd
                colIdx = canvasPix(winIdx)[rowBase + x]
                IF colIdx <> runColor THEN
                    FillRectClipped ex + runStart, ey + y, ex + x - 1, ey + y, clipL, clipT, clipR, clipB, CanvasColor(winIdx, runColor)
                    runStart = x
                    runColor = colIdx
                END IF
            NEXT
            FillRectClipped ex + runStart, ey + y, ex + xEnd, ey + y, clipL, clipT, clipR, clipB, CanvasColor(winIdx, runColor)
        NEXT
        EXIT SUB
    END IF

    FOR y = yStart TO yEnd
        sy = CLNG(y) * canvasH(winIdx) \ drawH
        rowBase = CLNG(sy) * canvasW(winIdx)
        runStart = xStart
        sx = CLNG(xStart) * canvasW(winIdx) \ drawW
        runColor = canvasPix(winIdx)[rowBase + sx]
        FOR x = xStart + 1 TO xEnd
            sx = CLNG(x) * canvasW(winIdx) \ drawW
            colIdx = canvasPix(winIdx)[rowBase + sx]
            IF colIdx <> runColor THEN
                FillRectClipped ex + runStart, ey + y, ex + x - 1, ey + y, clipL, clipT, clipR, clipB, CanvasColor(winIdx, runColor)
                runStart = x
                runColor = colIdx
            END IF
        NEXT
        FillRectClipped ex + runStart, ey + y, ex + xEnd, ey + y, clipL, clipT, clipR, clipB, CanvasColor(winIdx, runColor)
    NEXT
END SUB

FUNCTION CanvasKeyDown(BYVAL keyName AS STRING) AS INTEGER
    RETURN KeyDownGeneric(keyName)
END FUNCTION

FUNCTION CanvasFindElementIndex(BYVAL winIdx AS INTEGER, BYVAL viewName AS STRING) AS INTEGER
    DIM i AS INTEGER

    CanvasFindElementIndex = 0
    IF winIdx < 1 OR winIdx > 12 THEN EXIT FUNCTION
    FOR i = 1 TO layoutUiCount(winIdx)
        IF layoutUiElems(winIdx, i).kindId = UI_KIND_CANVAS THEN
            IF UCASE$(TRIM$(layoutUiElems(winIdx, i).name)) = UCASE$(TRIM$(viewName)) THEN RETURN i
        END IF
    NEXT
END FUNCTION

FUNCTION CanvasMouseLocal(BYVAL winIdx AS INTEGER, BYVAL viewName AS STRING, BYREF localX AS INTEGER, BYREF localY AS INTEGER, BYREF buttonMask AS INTEGER) AS INTEGER
    DIM elemIdx AS INTEGER
    DIM mx AS INTEGER
    DIM my AS INTEGER
    DIM mw AS INTEGER
    DIM mb AS INTEGER
    DIM ex AS INTEGER
    DIM ey AS INTEGER
    DIM ew AS INTEGER
    DIM eh AS INTEGER

    CanvasMouseLocal = 0
    localX = -1
    localY = -1
    buttonMask = 0
    IF winIdx < 1 OR winIdx > 12 THEN EXIT FUNCTION
    IF layoutWindows(winIdx).used = 0 THEN EXIT FUNCTION
    elemIdx = CanvasFindElementIndex(winIdx, viewName)
    IF elemIdx = 0 THEN EXIT FUNCTION

    GETMOUSE mx, my, mw, mb
    buttonMask = mb
    SyncGlobalsFromLayoutWindow winIdx
    ex = uiWinX + layoutUiElems(winIdx, elemIdx).x - uiScrollX
    ey = uiWinY + layoutUiElems(winIdx, elemIdx).y - uiScrollY
    ew = layoutUiElems(winIdx, elemIdx).w
    eh = layoutUiElems(winIdx, elemIdx).h
    IF ew <= 0 THEN ew = canvasW(winIdx)
    IF eh <= 0 THEN eh = canvasH(winIdx)
    IF InRect(mx, my, ex, ey, ex + ew, ey + eh) = 0 THEN EXIT FUNCTION
    localX = CLNG(mx - ex) * canvasW(winIdx) \ (ew + 1)
    localY = CLNG(my - ey) * canvasH(winIdx) \ (eh + 1)
    localX = ClampI(localX, 0, canvasW(winIdx) - 1)
    localY = ClampI(localY, 0, canvasH(winIdx) - 1)
    CanvasMouseLocal = -1
END FUNCTION

FUNCTION CanvasTickActiveWindowAt(BYVAL nowTime AS DOUBLE) AS INTEGER
    DIM winIdx AS INTEGER
    DIM tickElapsed AS DOUBLE
    DIM viewName AS STRING

    CanvasTickActiveWindowAt = 0
    IF canvasTickBusy <> 0 THEN EXIT FUNCTION
    winIdx = activeLayoutWindow
    IF winIdx < 1 OR winIdx > 12 THEN EXIT FUNCTION
    IF layoutWindows(winIdx).used = 0 THEN EXIT FUNCTION
    IF layoutWindows(winIdx).minimized <> 0 THEN EXIT FUNCTION
    IF canvasLoaded(winIdx) = 0 THEN EXIT FUNCTION
    IF canvasTickEnabled(winIdx) = 0 THEN EXIT FUNCTION
    IF canvasTickMs(winIdx) < CANVAS_MIN_TICK_MS THEN canvasTickMs(winIdx) = CANVAS_MIN_TICK_MS

    tickElapsed = TimerElapsedSecondsAt(canvasLastTick(winIdx), nowTime)
    IF canvasLastTick(winIdx) <> 0 AND tickElapsed * 1000.0 < canvasTickMs(winIdx) THEN EXIT FUNCTION

    canvasLastTick(winIdx) = nowTime
    viewName = canvasViewName(winIdx)
    canvasTickBusy = -1
    AppRuntime_HandleEvent winIdx, "TICK", viewName, "", ""
    canvasTickBusy = 0
    CanvasTickActiveWindowAt = -1
END FUNCTION

FUNCTION LayoutElementIsDynamic(BYVAL elemIdx AS INTEGER) AS INTEGER
    DIM elemKind AS STRING
    DIM elemMode AS STRING
    DIM elemStyle AS STRING
    DIM elemAction AS STRING
    DIM elemVerb AS STRING

    IF elemIdx < 1 OR elemIdx > uiCount THEN RETURN -1

    elemKind = uiElems(elemIdx).kindKey
    elemMode = uiElems(elemIdx).modeKey
    elemStyle = uiElems(elemIdx).drawStyleKey

    SELECT CASE elemKind
    CASE "TEXTBOX", "PREVIEW", "APPVIEW", "CANVAS", "OVERLAY"
        RETURN -1
    CASE "COMBO", "LISTBOX"
        ' Combo/list contents, scroll position, and selection are still dynamic.
        ' Their frames remain protected by the existing full-window cache.
        RETURN -1
    CASE "BUTTON"
        ' Ordinary buttons are static until their pressed state changes.
        ' Icon-editor/app-view tool buttons depend on appViewTool and stay dynamic.
        elemAction = TRIM$(uiElems(elemIdx).action)
        elemVerb = UCASE$(NextActionToken(elemAction))
        IF elemVerb = "APPVIEW_TOOL" THEN RETURN -1
        RETURN 0
    CASE "RADIO", "CHECKBOX"
        RETURN 0
    CASE "LABEL"
        IF TRIM$(uiElems(elemIdx).sourceControl) <> "" THEN RETURN -1
        IF elemMode = "TEXT_STATS" THEN RETURN -1
        RETURN 0
    CASE ELSE
        RETURN 0
    END SELECT
END FUNCTION


FUNCTION LayoutElementTextChecksumRef(BYREF textValue AS STRING, BYVAL maxChars AS INTEGER) AS LONG
    DIM i AS INTEGER
    DIM charPos AS INTEGER
    DIM limitLen AS INTEGER
    DIM textLen AS INTEGER
    DIM sig AS LONG
    DIM textPtr AS UBYTE PTR

    IF maxChars < 1 THEN maxChars = 1
    textLen = LEN(textValue)
    limitLen = textLen
    IF limitLen > maxChars THEN limitLen = maxChars

    sig = CLNG(textLen) * 131
    IF textLen > 0 THEN
        textPtr = CAST(UBYTE PTR, STRPTR(textValue))
        IF textPtr <> 0 THEN
            FOR i = 0 TO limitLen - 1
                charPos = i + 1
                sig = sig + CLNG(textPtr[i]) * CLNG((charPos MOD 31) + 1)
                IF sig > 1000000000 THEN sig = sig MOD 1000000000
            NEXT

            IF textLen > limitLen THEN
                sig = sig + CLNG(textPtr[textLen - 1]) * 997
            END IF
        END IF
    END IF

    IF sig > 1000000 THEN sig = sig MOD 1000000
    IF sig < -1000000 THEN sig = sig MOD 1000000
    RETURN sig
END FUNCTION

FUNCTION LayoutElementTextChecksum(BYVAL textValue AS STRING, BYVAL maxChars AS INTEGER) AS LONG
    RETURN LayoutElementTextChecksumRef(textValue, maxChars)
END FUNCTION

FUNCTION LayoutElementStaticDrawSignature(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER) AS LONG
    DIM sig AS LONG
    DIM elemKind AS STRING

    IF winIdx < 1 OR winIdx > 12 THEN RETURN 0
    IF elemIdx < 1 OR elemIdx > uiCount THEN RETURN 0

    IF layoutElemStaticDrawSigValid(winIdx, elemIdx) <> 0 THEN
        RETURN layoutElemStaticDrawSig(winIdx, elemIdx)
    END IF

    ' These fields are fixed for the lifetime of the currently loaded control.
    ' Cache their checksum contribution so element cache probes do not rehash them every redraw.
    elemKind = uiElems(elemIdx).kindKey
    sig = 0
    sig = sig + LayoutElementTextChecksumRef(elemKind, 32) * 59
    sig = sig + LayoutElementTextChecksumRef(uiElems(elemIdx).name, 64) * 71
    sig = sig + LayoutElementTextChecksumRef(uiElems(elemIdx).sourceControl, 64) * 73
    sig = sig + LayoutElementTextChecksumRef(uiElems(elemIdx).modeGroup, 64) * 79
    sig = sig + LayoutElementTextChecksumRef(uiElems(elemIdx).drawStyle, 64) * 83

    IF sig > 1000000000 THEN sig = sig MOD 1000000000
    IF sig < -1000000000 THEN sig = sig MOD 1000000000

    layoutElemStaticDrawSig(winIdx, elemIdx) = sig
    layoutElemStaticDrawSigValid(winIdx, elemIdx) = -1
    RETURN sig
END FUNCTION

FUNCTION LayoutElementCacheAllowed(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER, BYVAL ew AS INTEGER, BYVAL eh AS INTEGER) AS INTEGER
    DIM elemKind AS STRING

    LayoutElementCacheAllowed = 0
    IF winIdx < 1 OR winIdx > 12 THEN EXIT FUNCTION
    IF elemIdx < 1 OR elemIdx > uiCount THEN EXIT FUNCTION
    IF winIdx <> activeLayoutWindow THEN EXIT FUNCTION
    IF layoutWindows(winIdx).used = 0 THEN EXIT FUNCTION
    IF ew < 1 OR eh < 1 THEN EXIT FUNCTION
    IF LayoutElementIsDynamic(elemIdx) = 0 THEN EXIT FUNCTION

    elemKind = uiElems(elemIdx).kindKey
    SELECT CASE elemKind
    CASE "BUTTON", "CHECKBOX", "RADIO", "COMBO", "LISTBOX", "PREVIEW", "APPVIEW", "CANVAS"
        LayoutElementCacheAllowed = -1
    CASE "TEXTBOX"
        IF uiWindowActive <> 0 AND uiFocusIndex = elemIdx THEN EXIT FUNCTION
        IF LEN(uiElems(elemIdx).text) > 512 THEN EXIT FUNCTION
        LayoutElementCacheAllowed = -1
    CASE ELSE
        LayoutElementCacheAllowed = 0
    END SELECT

    IF elemKind = "COMBO" THEN
        IF comboOpenIndex(winIdx) = elemIdx THEN LayoutElementCacheAllowed = 0
    END IF
END FUNCTION

FUNCTION LayoutElementDrawSignature(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER, BYVAL ex AS INTEGER, BYVAL ey AS INTEGER, BYVAL ew AS INTEGER, BYVAL eh AS INTEGER) AS LONG
    DIM sig AS LONG
    DIM elemKind AS STRING
    DIM srcIdx AS INTEGER

    IF winIdx < 1 OR winIdx > 12 THEN RETURN 0
    IF elemIdx < 1 OR elemIdx > uiCount THEN RETURN 0

    elemKind = uiElems(elemIdx).kindKey

    sig = 23
    sig = sig + CLNG(layoutRenderVersion) * 3
    sig = sig + UIStyleDrawSignature() * 257
    sig = sig + CLNG(winIdx) * 5
    sig = sig + CLNG(elemIdx) * 7
    sig = sig + CLNG(ex + 32768) * 11
    sig = sig + CLNG(ey + 32768) * 13
    sig = sig + CLNG(ew + 32768) * 17
    sig = sig + CLNG(eh + 32768) * 19
    sig = sig + CLNG(uiSelectedTab) * 23
    sig = sig + CLNG(uiScrollX + 32768) * 29
    sig = sig + CLNG(uiScrollY + 32768) * 31
    IF uiWindowActive <> 0 AND uiFocusIndex = elemIdx THEN sig = sig + 37
    IF uiPressedIndex = elemIdx THEN sig = sig + 41
    IF uiFocusIndex = elemIdx THEN sig = sig + 43
    sig = sig + CLNG(uiElems(elemIdx).state) * 47
    sig = sig + CLNG(layoutElemDirtyVersion(winIdx, elemIdx)) * 51
    sig = sig + CLNG(comboScrollTop(winIdx, elemIdx) + 32768) * 53
    sig = sig + LayoutElementStaticDrawSignature(winIdx, elemIdx)
    sig = sig + LayoutElementTextChecksumRef(uiElems(elemIdx).text, 512) * 61
    ' PAGE controls visibility only. It is checked before draw-signature use and
    ' does not alter the rendered control image, so it must not be rehashed here.
    sig = sig + CLNG(uiElems(elemIdx).multiSelect) * 89
    sig = sig + CLNG(uiElems(elemIdx).noEdit) * 97

    SELECT CASE elemKind
    CASE "TEXTBOX"
        sig = sig + CLNG(uiCaretPos) * 101
        sig = sig + CLNG(uiSelAnchor(elemIdx)) * 103
        sig = sig + CLNG(uiEdit(elemIdx).curPos) * 107
        sig = sig + CLNG(uiEdit(elemIdx).selA) * 109
        sig = sig + CLNG(uiEdit(elemIdx).selB) * 113
        sig = sig + CLNG(uiEdit(elemIdx).txtLen) * 127
        sig = sig + LayoutElementTextChecksumRef(uiEdit(elemIdx).txt, 512) * 131
        sig = sig + CLNG(layoutDirtyVersion(winIdx)) * 137
    CASE "LISTBOX"
        ' Directory/list-source rebuilds already advance the owning window dirty
        ' version. Do not rehash long source strings on every cache probe.
        sig = sig + CLNG(layoutDirtyVersion(winIdx)) * 139
        sig = sig + LayoutElementTextChecksumRef(layoutListMultiSel(winIdx, elemIdx), 512) * 149
    CASE "COMBO"
        ' Combo source rebuilds are likewise protected by layoutDirtyVersion.
        sig = sig + CLNG(layoutDirtyVersion(winIdx)) * 167
    CASE "APPVIEW"
        sig = sig + CLNG(layoutDirtyVersion(winIdx)) * 181
        sig = sig + CLNG(appViewVersion(winIdx)) * 183
    CASE "CANVAS"
        sig = sig + CLNG(layoutDirtyVersion(winIdx)) * 187
        sig = sig + CLNG(canvasVersion(winIdx)) * 189
    CASE "PREVIEW"
        sig = sig + CLNG(layoutDirtyVersion(winIdx)) * 191
        sig = sig + CLNG(previewLoaded) * 193
        sig = sig + CLNG(previewW) * 197
        sig = sig + CLNG(previewH) * 199
        sig = sig + LayoutElementTextChecksumRef(previewPath, 260) * 211
        srcIdx = GetControlIndexByName(uiElems(elemIdx).sourceControl)
        IF srcIdx >= 1 AND srcIdx <= uiCount THEN
            sig = sig + LayoutElementTextChecksumRef(uiElems(srcIdx).text, 512) * 223
            sig = sig + CLNG(uiElems(srcIdx).state) * 227
        END IF
        sig = sig + LayoutElementTextChecksum(GetSelectedRadioValue(uiElems(elemIdx).modeGroup), 32) * 229
    END SELECT

    IF sig > 1000000000 THEN sig = sig MOD 1000000000
    IF sig < -1000000000 THEN sig = sig MOD 1000000000
    RETURN sig
END FUNCTION

FUNCTION DrawLayoutElementFromCache(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER, BYVAL ex AS INTEGER, BYVAL ey AS INTEGER, BYVAL ew AS INTEGER, BYVAL eh AS INTEGER, BYVAL clipL AS INTEGER, BYVAL clipT AS INTEGER, BYVAL clipR AS INTEGER, BYVAL clipB AS INTEGER, BYREF drawSigOut AS LONG, BYREF drawSigReadyOut AS INTEGER) AS INTEGER
    DIM cx1 AS INTEGER
    DIM cy1 AS INTEGER
    DIM cx2 AS INTEGER
    DIM cy2 AS INTEGER
    DIM cw AS INTEGER
    DIM ch AS INTEGER
    DIM sig AS LONG

    DrawLayoutElementFromCache = 0
    drawSigOut = 0
    drawSigReadyOut = 0
    IF LayoutElementCacheAllowed(winIdx, elemIdx, ew, eh) = 0 THEN EXIT FUNCTION

    cx1 = ex
    cy1 = ey
    cx2 = ex + ew
    cy2 = ey + eh
    IF cx1 < clipL THEN cx1 = clipL
    IF cy1 < clipT THEN cy1 = clipT
    IF cx2 > clipR THEN cx2 = clipR
    IF cy2 > clipB THEN cy2 = clipB
    IF cx2 < cx1 OR cy2 < cy1 THEN
        DrawLayoutElementFromCache = -1
        EXIT FUNCTION
    END IF

    cw = cx2 - cx1 + 1
    ch = cy2 - cy1 + 1
    sig = LayoutElementDrawSignature(winIdx, elemIdx, ex, ey, ew, eh)
    drawSigOut = sig
    drawSigReadyOut = -1

    IF layoutElemDrawCache(winIdx, elemIdx) <> 0 AND layoutElemDrawCacheValid(winIdx, elemIdx) <> 0 THEN
        IF layoutElemDrawCacheSig(winIdx, elemIdx) = sig AND _
           layoutElemDrawCacheW(winIdx, elemIdx) = cw AND _
           layoutElemDrawCacheH(winIdx, elemIdx) = ch AND _
           layoutElemDrawCacheX(winIdx, elemIdx) = cx1 AND _
           layoutElemDrawCacheY(winIdx, elemIdx) = cy1 THEN
            PUT (cx1, cy1), layoutElemDrawCache(winIdx, elemIdx), PSET
            DrawLayoutElementFromCache = -1
            EXIT FUNCTION
        END IF
    END IF
END FUNCTION

SUB CaptureLayoutElementDrawCache(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER, BYVAL ex AS INTEGER, BYVAL ey AS INTEGER, BYVAL ew AS INTEGER, BYVAL eh AS INTEGER, BYVAL clipL AS INTEGER, BYVAL clipT AS INTEGER, BYVAL clipR AS INTEGER, BYVAL clipB AS INTEGER, BYVAL drawSigIn AS LONG, BYVAL drawSigReadyIn AS INTEGER)
    DIM cx1 AS INTEGER
    DIM cy1 AS INTEGER
    DIM cx2 AS INTEGER
    DIM cy2 AS INTEGER
    DIM cw AS INTEGER
    DIM ch AS INTEGER
    DIM sig AS LONG

    IF LayoutElementCacheAllowed(winIdx, elemIdx, ew, eh) = 0 THEN EXIT SUB

    cx1 = ex
    cy1 = ey
    cx2 = ex + ew
    cy2 = ey + eh
    IF cx1 < clipL THEN cx1 = clipL
    IF cy1 < clipT THEN cy1 = clipT
    IF cx2 > clipR THEN cx2 = clipR
    IF cy2 > clipB THEN cy2 = clipB
    IF cx2 < cx1 OR cy2 < cy1 THEN EXIT SUB

    cw = cx2 - cx1 + 1
    ch = cy2 - cy1 + 1

    IF layoutElemDrawCache(winIdx, elemIdx) = 0 OR _
       layoutElemDrawCacheW(winIdx, elemIdx) <> cw OR _
       layoutElemDrawCacheH(winIdx, elemIdx) <> ch THEN
        FreeLayoutElementDrawCache winIdx, elemIdx
        layoutElemDrawCache(winIdx, elemIdx) = ImageCreate(cw, ch, 0)
    END IF

    IF layoutElemDrawCache(winIdx, elemIdx) <> 0 THEN
        GET (cx1, cy1)-(cx2, cy2), layoutElemDrawCache(winIdx, elemIdx)
        ' The cache probe already built this signature on a miss.
        ' Reuse it here instead of hashing the same element a second time.
        IF drawSigReadyIn <> 0 THEN
            sig = drawSigIn
        ELSE
            sig = LayoutElementDrawSignature(winIdx, elemIdx, ex, ey, ew, eh)
        END IF
        layoutElemDrawCacheSig(winIdx, elemIdx) = sig
        layoutElemDrawCacheW(winIdx, elemIdx) = cw
        layoutElemDrawCacheH(winIdx, elemIdx) = ch
        layoutElemDrawCacheX(winIdx, elemIdx) = cx1
        layoutElemDrawCacheY(winIdx, elemIdx) = cy1
        layoutElemDrawCacheValid(winIdx, elemIdx) = -1
    END IF
END SUB

FUNCTION LayoutStaticWindowSignature(BYVAL winIdx AS INTEGER) AS LONG
    DIM sig AS LONG
    DIM s AS STRING
    DIM sl AS INTEGER
    DIM staticPressed AS INTEGER

    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN RETURN 0
    IF layoutWindows(winIdx).used = 0 THEN RETURN 0

    sig = 19
    sig = sig + CLNG(layoutRenderVersion) * 23
    sig = sig + UIStyleDrawSignature() * 263
    sig = sig + CLNG(winIdx) * 29
    sig = sig + CLNG(layoutWindows(winIdx).x + 32768) * 3
    sig = sig + CLNG(layoutWindows(winIdx).y + 32768) * 5
    sig = sig + CLNG(layoutWindows(winIdx).w + 32768) * 7
    sig = sig + CLNG(layoutWindows(winIdx).h + 32768) * 11
    sig = sig + CLNG(layoutWindows(winIdx).active) * 13
    sig = sig + CLNG(layoutWindows(winIdx).selectedTab) * 17
    sig = sig + CLNG(layoutWindows(winIdx).scrollY) * 37
    sig = sig + CLNG(layoutWindows(winIdx).scrollX) * 41
    sig = sig + CLNG(layoutWindows(winIdx).resizable) * 43
    sig = sig + CLNG(layoutWindows(winIdx).minimized) * 47
    sig = sig + CLNG(layoutWindows(winIdx).maximized) * 53
    sig = sig + CLNG(layoutWindows(winIdx).designW) * 59
    sig = sig + CLNG(layoutWindows(winIdx).designH) * 61
    sig = sig + CLNG(layoutUiCount(winIdx)) * 71

    staticPressed = 0
    IF layoutWindows(winIdx).pressedIndex >= 1 AND layoutWindows(winIdx).pressedIndex <= layoutUiCount(winIdx) THEN
        ' The static cache now owns tabs, ordinary buttons, checkboxes, and radio buttons.
        ' Include only static pressed controls here so transient button-down visuals cannot reuse stale cache pixels.
        IF layoutWindows(winIdx).pressedIndex <= uiCount THEN
            IF LayoutElementIsDynamic(layoutWindows(winIdx).pressedIndex) = 0 THEN staticPressed = layoutWindows(winIdx).pressedIndex
        END IF
    END IF
    sig = sig + CLNG(staticPressed) * 73

    s = RTRIM$(layoutWindows(winIdx).appPath)
    sl = LEN(s)
    sig = sig + CLNG(sl) * 79
    IF sl > 0 THEN sig = sig + CLNG(ASC(LEFT$(s, 1))) * 83 + CLNG(ASC(RIGHT$(s, 1))) * 89

    s = RTRIM$(layoutWindows(winIdx).title)
    sl = LEN(s)
    sig = sig + CLNG(sl) * 97
    IF sl > 0 THEN sig = sig + CLNG(ASC(LEFT$(s, 1))) * 101 + CLNG(ASC(RIGHT$(s, 1))) * 103

    IF sig > 1000000000 THEN sig = sig MOD 1000000000
    IF sig < -1000000000 THEN sig = sig MOD 1000000000
    RETURN sig
END FUNCTION
FUNCTION LayoutWindowDrawSignature(BYVAL winIdx AS INTEGER) AS LONG
    DIM sig AS LONG
    DIM s AS STRING
    DIM sl AS INTEGER

    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN RETURN 0
    IF layoutWindows(winIdx).used = 0 THEN RETURN 0

    sig = 17
    sig = sig + CLNG(layoutRenderVersion) * 23
    sig = sig + UIStyleDrawSignature() * 269
    sig = sig + CLNG(winIdx) * 29
    sig = sig + CLNG(layoutDirtyVersion(winIdx)) * 31
    sig = sig + CLNG(layoutWindows(winIdx).x + 32768) * 3
    sig = sig + CLNG(layoutWindows(winIdx).y + 32768) * 5
    sig = sig + CLNG(layoutWindows(winIdx).w + 32768) * 7
    sig = sig + CLNG(layoutWindows(winIdx).h + 32768) * 11
    sig = sig + CLNG(layoutWindows(winIdx).active) * 13
    sig = sig + CLNG(layoutWindows(winIdx).selectedTab) * 17
    sig = sig + CLNG(layoutWindows(winIdx).pressedIndex) * 19
    sig = sig + CLNG(layoutWindows(winIdx).focusIndex) * 23
    sig = sig + CLNG(layoutWindows(winIdx).caretPos) * 31
    IF winIdx = activeLayoutWindow THEN sig = sig + CLNG(uiCaretVisible) * 103
    sig = sig + CLNG(layoutWindows(winIdx).scrollY) * 37
    sig = sig + CLNG(layoutWindows(winIdx).scrollX) * 41
    sig = sig + CLNG(layoutWindows(winIdx).resizable) * 43
    sig = sig + CLNG(layoutWindows(winIdx).minimized) * 47
    sig = sig + CLNG(layoutWindows(winIdx).maximized) * 53
    sig = sig + CLNG(layoutWindows(winIdx).designW) * 59
    sig = sig + CLNG(layoutWindows(winIdx).designH) * 61
    sig = sig + CLNG(comboOpenIndex(winIdx)) * 67
    sig = sig + CLNG(layoutUiCount(winIdx)) * 71

    s = RTRIM$(layoutWindows(winIdx).appPath)
    sl = LEN(s)
    sig = sig + CLNG(sl) * 73
    IF sl > 0 THEN sig = sig + CLNG(ASC(LEFT$(s, 1))) * 79 + CLNG(ASC(RIGHT$(s, 1))) * 83

    s = RTRIM$(layoutWindows(winIdx).title)
    sl = LEN(s)
    sig = sig + CLNG(sl) * 89
    IF sl > 0 THEN sig = sig + CLNG(ASC(LEFT$(s, 1))) * 97 + CLNG(ASC(RIGHT$(s, 1))) * 101

    IF sig > 1000000000 THEN sig = sig MOD 1000000000
    IF sig < -1000000000 THEN sig = sig MOD 1000000000
    RETURN sig
END FUNCTION


SUB DrawLayoutWindowStaticCached(BYVAL winIdx AS INTEGER)
    DIM sig AS LONG

    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(winIdx).used = 0 THEN EXIT SUB
    IF layoutWindows(winIdx).minimized <> 0 THEN EXIT SUB

    sig = LayoutStaticWindowSignature(winIdx)

    IF layoutStaticCache(winIdx) <> 0 AND layoutStaticCacheValid(winIdx) <> 0 THEN
        IF layoutStaticCacheSig(winIdx) = sig AND _
           layoutStaticCacheW(winIdx) = layoutWindows(winIdx).w AND _
           layoutStaticCacheH(winIdx) = layoutWindows(winIdx).h THEN
            PUT (layoutWindows(winIdx).x, layoutWindows(winIdx).y), layoutStaticCache(winIdx), PSET
            EXIT SUB
        END IF
    END IF

    layoutDrawPass = 1
    DrawAppLayout
    layoutDrawPass = 0

    IF layoutStaticCache(winIdx) = 0 OR _
       layoutStaticCacheW(winIdx) <> layoutWindows(winIdx).w OR _
       layoutStaticCacheH(winIdx) <> layoutWindows(winIdx).h THEN
        FreeLayoutWindowStaticCache winIdx
        layoutStaticCache(winIdx) = ImageCreate(layoutWindows(winIdx).w + 1, layoutWindows(winIdx).h + 1, 0)
    END IF
    IF layoutStaticCache(winIdx) <> 0 THEN
        GET (layoutWindows(winIdx).x, layoutWindows(winIdx).y)-(layoutWindows(winIdx).x + layoutWindows(winIdx).w, layoutWindows(winIdx).y + layoutWindows(winIdx).h), layoutStaticCache(winIdx)
        layoutStaticCacheSig(winIdx) = sig
        layoutStaticCacheW(winIdx) = layoutWindows(winIdx).w
        layoutStaticCacheH(winIdx) = layoutWindows(winIdx).h
        layoutStaticCacheValid(winIdx) = -1
    END IF
END SUB

SUB DrawLayoutWindowCached(BYVAL winIdx AS INTEGER)
    DIM sig AS LONG
    DIM cacheAllowed AS INTEGER
    DIM captureFullWindowCache AS INTEGER
    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(winIdx).used = 0 THEN EXIT SUB
    IF layoutWindows(winIdx).minimized <> 0 THEN EXIT SUB

    cacheAllowed = 0
    IF winIdx = activeLayoutWindow THEN cacheAllowed = -1
    ' Keep persistent full-window/static/control caches limited to the active
    ' top window so repeated open/close cycles do not retain large buffers for
    ' every inactive window.
    captureFullWindowCache = -1
    IF layoutSkipFullWindowCacheCapture <> 0 AND winIdx = activeLayoutWindow THEN captureFullWindowCache = 0
    IF layoutWindows(winIdx).x < 0 OR layoutWindows(winIdx).y < 0 THEN cacheAllowed = 0
    IF layoutWindows(winIdx).x + layoutWindows(winIdx).w >= SCR_W THEN cacheAllowed = 0
    IF layoutWindows(winIdx).y + layoutWindows(winIdx).h >= SCR_H THEN cacheAllowed = 0
    IF layoutWindows(winIdx).w < 1 OR layoutWindows(winIdx).h < 1 THEN cacheAllowed = 0

    sig = LayoutWindowDrawSignature(winIdx)

    IF cacheAllowed <> 0 THEN
        IF layoutDrawCache(winIdx) <> 0 AND layoutDrawCacheValid(winIdx) <> 0 THEN
            IF layoutDrawCacheSig(winIdx) = sig AND _
               layoutDrawCacheVersion(winIdx) = layoutDirtyVersion(winIdx) AND _
               layoutDrawCacheW(winIdx) = layoutWindows(winIdx).w AND _
               layoutDrawCacheH(winIdx) = layoutWindows(winIdx).h THEN
                PUT (layoutWindows(winIdx).x, layoutWindows(winIdx).y), layoutDrawCache(winIdx), PSET
                IF activeLayoutWindow = winIdx THEN SyncGlobalsFromLayoutWindow winIdx
                EXIT SUB
            END IF
        END IF
    ELSE
        IF layoutDrawCache(winIdx) <> 0 THEN FreeLayoutWindowDrawCache winIdx
        IF layoutStaticCache(winIdx) <> 0 THEN FreeLayoutWindowStaticCache winIdx
        IF layoutChromeCache(winIdx) <> 0 THEN FreeLayoutWindowChromeCache winIdx
    END IF

    drawLayoutWindow = winIdx
    SyncGlobalsFromLayoutWindow winIdx

    IF cacheAllowed <> 0 THEN
        DrawLayoutWindowStaticCached winIdx
        layoutDrawPass = 2
        DrawAppLayout
        layoutDrawPass = 0
    ELSE
        layoutDrawPass = 0
        DrawAppLayout
    END IF

    drawLayoutWindow = 0
    layoutDrawPass = 0

    IF cacheAllowed <> 0 AND captureFullWindowCache <> 0 THEN
        IF layoutDrawCache(winIdx) = 0 OR _
           layoutDrawCacheW(winIdx) <> layoutWindows(winIdx).w OR _
           layoutDrawCacheH(winIdx) <> layoutWindows(winIdx).h THEN
            FreeLayoutWindowDrawCache winIdx
            layoutDrawCache(winIdx) = ImageCreate(layoutWindows(winIdx).w + 1, layoutWindows(winIdx).h + 1, 0)
        END IF
        IF layoutDrawCache(winIdx) <> 0 THEN
            GET (layoutWindows(winIdx).x, layoutWindows(winIdx).y)-(layoutWindows(winIdx).x + layoutWindows(winIdx).w, layoutWindows(winIdx).y + layoutWindows(winIdx).h), layoutDrawCache(winIdx)
            layoutDrawCacheSig(winIdx) = sig
            layoutDrawCacheVersion(winIdx) = layoutDirtyVersion(winIdx)
            layoutDrawCacheW(winIdx) = layoutWindows(winIdx).w
            layoutDrawCacheH(winIdx) = layoutWindows(winIdx).h
            layoutDrawCacheValid(winIdx) = -1
        END IF
    ELSEIF cacheAllowed <> 0 THEN
        layoutDrawCacheValid(winIdx) = 0
    END IF

    ClearLayoutDirtyElements winIdx
END SUB

SUB DrawAllLayoutWindows()
    DIM drawPos AS INTEGER
    DIM slotIdx AS INTEGER
    DIM fallbackIdx AS INTEGER
    DIM alreadyDrawn AS INTEGER
    DIM k AS INTEGER
    DIM lastCachedWindowDrawn AS INTEGER

    lastCachedWindowDrawn = 0

    FOR drawPos = LBOUND(layoutZOrder) TO UBOUND(layoutZOrder)
        slotIdx = layoutZOrder(drawPos)
        IF slotIdx >= LBOUND(layoutWindows) AND slotIdx <= UBOUND(layoutWindows) THEN
            IF layoutWindows(slotIdx).used <> 0 AND layoutWindows(slotIdx).minimized = 0 THEN
                DrawLayoutWindowCached slotIdx
                lastCachedWindowDrawn = slotIdx
            END IF
        END IF
    NEXT

    FOR fallbackIdx = LBOUND(layoutWindows) TO UBOUND(layoutWindows)
        IF layoutWindows(fallbackIdx).used <> 0 AND layoutWindows(fallbackIdx).minimized = 0 THEN
            alreadyDrawn = 0
            FOR k = LBOUND(layoutZOrder) TO UBOUND(layoutZOrder)
                IF layoutZOrder(k) = fallbackIdx THEN
                    alreadyDrawn = -1
                    EXIT FOR
                END IF
            NEXT
            IF alreadyDrawn = 0 THEN
                DrawLayoutWindowCached fallbackIdx
                lastCachedWindowDrawn = fallbackIdx
            END IF
        END IF
    NEXT

    ' Cached window drawing already reloads the active window globals while it draws.
    ' Only do the final restore when a later window left globals pointed somewhere else.
    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
            IF lastCachedWindowDrawn <> activeLayoutWindow THEN SyncGlobalsFromLayoutWindow activeLayoutWindow
        END IF
    END IF
END SUB


SUB FreeLayoutDragOutlineBackBuffer()
    IF layoutDragOutlineBack <> 0 THEN
        ImageDestroy layoutDragOutlineBack
        layoutDragOutlineBack = 0
    END IF
    layoutDragOutlineBackW = 0
    layoutDragOutlineBackH = 0
    layoutDragOutlineBackX = 0
    layoutDragOutlineBackY = 0
    layoutDragOutlineBackValid = 0
END SUB

SUB RestoreLayoutDragOutlineBackBuffer()
    IF layoutDragOutlineBack <> 0 AND layoutDragOutlineBackValid <> 0 THEN
        PUT (layoutDragOutlineBackX, layoutDragOutlineBackY), layoutDragOutlineBack, PSET
    END IF
    layoutDragOutlineBackValid = 0
END SUB

SUB DrawLayoutWindowSolidOutlineAt(BYVAL bx AS INTEGER, BYVAL by AS INTEGER, BYVAL bw AS INTEGER, BYVAL bh AS INTEGER)
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER
    DIM capW AS INTEGER
    DIM capH AS INTEGER
    DIM titleY AS INTEGER
    DIM hiCol AS UINTEGER
    DIM loCol AS UINTEGER

    IF bw < 4 OR bh < 4 THEN EXIT SUB

    x1 = bx
    y1 = by
    x2 = bx + bw
    y2 = by + bh

    IF x2 < 0 OR y2 < 0 OR x1 >= SCR_W OR y1 >= SCR_H THEN EXIT SUB
    IF x1 < 0 THEN x1 = 0
    IF y1 < 0 THEN y1 = 0
    IF x2 >= SCR_W THEN x2 = SCR_W - 1
    IF y2 >= SCR_H THEN y2 = SCR_H - 1
    IF x2 <= x1 OR y2 <= y1 THEN EXIT SUB

    capW = x2 - x1 + 1
    capH = y2 - y1 + 1

    IF layoutDragOutlineBack <> 0 THEN
        IF layoutDragOutlineBackW <> capW OR layoutDragOutlineBackH <> capH THEN
            ImageDestroy layoutDragOutlineBack
            layoutDragOutlineBack = 0
            layoutDragOutlineBackValid = 0
        END IF
    END IF

    IF layoutDragOutlineBack = 0 THEN
        layoutDragOutlineBack = ImageCreate(capW, capH, 0)
        layoutDragOutlineBackW = capW
        layoutDragOutlineBackH = capH
    END IF
    IF layoutDragOutlineBack = 0 THEN EXIT SUB

    GET (x1, y1)-(x2, y2), layoutDragOutlineBack
    layoutDragOutlineBackX = x1
    layoutDragOutlineBackY = y1
    layoutDragOutlineBackValid = -1

    IF cfg.colorDepth = 4 OR cfg.colorDepth = 8 THEN
        hiCol = 15
        loCol = 0
    ELSE
        hiCol = RGB(255, 255, 255)
        loCol = RGB(0, 0, 0)
    END IF

    ' Solid saved-background outline is slightly more work than XOR, but it is
    ' visible on every color depth and restores only the drag rectangle.
    LINE (x1, y1)-(x2, y2), loCol, B
    IF x2 - x1 > 2 AND y2 - y1 > 2 THEN LINE (x1 + 1, y1 + 1)-(x2 - 1, y2 - 1), hiCol, B

    titleY = by + 18
    IF titleY >= y1 AND titleY <= y2 THEN
        LINE (x1, titleY)-(x2, titleY), loCol
        IF titleY + 1 <= y2 THEN LINE (x1, titleY + 1)-(x2, titleY + 1), hiCol
    END IF
END SUB

SUB DrawXorHLineClipped(BYVAL x1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y AS INTEGER)
    DIM px AS INTEGER
    DIM t AS INTEGER
    DIM oldCol AS UINTEGER
    DIM maskCol AS UINTEGER

    IF cfg.colorDepth <= 8 THEN
        maskCol = 15
    ELSE
        maskCol = RGB(255, 255, 255)
    END IF

    IF y < 0 OR y >= SCR_H THEN EXIT SUB
    IF x1 > x2 THEN
        t = x1
        x1 = x2
        x2 = t
    END IF
    IF x2 < 0 OR x1 >= SCR_W THEN EXIT SUB
    IF x1 < 0 THEN x1 = 0
    IF x2 >= SCR_W THEN x2 = SCR_W - 1

    FOR px = x1 TO x2
        oldCol = POINT(px, y)
        PSET (px, y), (oldCol XOR maskCol)
    NEXT
END SUB

SUB DrawXorVLineClipped(BYVAL x AS INTEGER, BYVAL y1 AS INTEGER, BYVAL y2 AS INTEGER)
    DIM py AS INTEGER
    DIM t AS INTEGER
    DIM oldCol AS UINTEGER
    DIM maskCol AS UINTEGER

    IF cfg.colorDepth <= 8 THEN
        maskCol = 15
    ELSE
        maskCol = RGB(255, 255, 255)
    END IF

    IF x < 0 OR x >= SCR_W THEN EXIT SUB
    IF y1 > y2 THEN
        t = y1
        y1 = y2
        y2 = t
    END IF
    IF y2 < 0 OR y1 >= SCR_H THEN EXIT SUB
    IF y1 < 0 THEN y1 = 0
    IF y2 >= SCR_H THEN y2 = SCR_H - 1

    FOR py = y1 TO y2
        oldCol = POINT(x, py)
        PSET (x, py), (oldCol XOR maskCol)
    NEXT
END SUB

SUB DrawLayoutWindowXorOutlineAt(BYVAL bx AS INTEGER, BYVAL by AS INTEGER, BYVAL bw AS INTEGER, BYVAL bh AS INTEGER)
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER
    DIM titleY AS INTEGER

    IF bw < 4 OR bh < 4 THEN EXIT SUB

    x2 = bx + bw
    y2 = by + bh
    titleY = by + 18
    IF titleY > y2 - 1 THEN titleY = y2 - 1

    ' Fast outline dragging draws and erases by XORing the same pixels.
    ' This avoids a full desktop/window-stack repaint on every mouse move.
    DrawXorHLineClipped bx, x2, by
    DrawXorHLineClipped bx, x2, y2
    DrawXorVLineClipped bx, by, y2
    DrawXorVLineClipped x2, by, y2
    DrawXorHLineClipped bx + 1, x2 - 1, titleY
END SUB

SUB DrawLayoutWindowDragOutline(BYVAL slotIdx AS INTEGER)
    DIM bx AS INTEGER
    DIM by AS INTEGER
    DIM bw AS INTEGER
    DIM bh AS INTEGER
    DIM ttl AS STRING

    IF slotIdx < LBOUND(layoutWindows) OR slotIdx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(slotIdx).used = 0 THEN EXIT SUB

    bx = layoutWindows(slotIdx).x
    by = layoutWindows(slotIdx).y
    bw = layoutWindows(slotIdx).w
    bh = layoutWindows(slotIdx).h
    ttl = RTRIM$(layoutWindows(slotIdx).title)

    Draw3DRect bx, by, bx + bw, by + bh, 1
    DrawThemedTitleBar bx + 1, by + 1, bx + bw - 1, by + 18, -1
    DRAW STRING (bx + 8, by + 5), ttl, COL_TEXT_INV
    DrawTitleButtonBevelBox bx + bw - 55, by + 2, bx + bw - 39, by + 16, 0
    LINE (bx + bw - 51, by + 12)-(bx + bw - 43, by + 12), uiStyle.titleButtonSymbolCol
    LINE (bx + bw - 51, by + 13)-(bx + bw - 43, by + 13), uiStyle.titleButtonSymbolCol
    DrawTitleButtonBevelBox bx + bw - 37, by + 2, bx + bw - 21, by + 16, 0
    LINE (bx + bw - 33, by + 5)-(bx + bw - 25, by + 13), uiStyle.titleButtonSymbolCol, B
    LINE (bx + bw - 33, by + 6)-(bx + bw - 25, by + 6), uiStyle.titleButtonSymbolCol
    DrawTitleButtonBevelBox bx + bw - 19, by + 2, bx + bw - 3, by + 16, 0
    LINE (bx + bw - 15, by + 5)-(bx + bw - 7, by + 13), uiStyle.titleButtonSymbolCol
    LINE (bx + bw - 7, by + 5)-(bx + bw - 15, by + 13), uiStyle.titleButtonSymbolCol
    LINE (bx + 3, by + 22)-(bx + bw - 3, by + bh - 3), COL_BEVEL_LO, B
END SUB

SUB DrawAllLayoutWindowsFastDrag(BYVAL dragSlot AS INTEGER)
    DIM drawPos AS INTEGER
    DIM slotIdx AS INTEGER
    DIM fallbackIdx AS INTEGER
    DIM alreadyDrawn AS INTEGER
    DIM k AS INTEGER
    DIM lastCachedWindowDrawn AS INTEGER

    lastCachedWindowDrawn = 0

    FOR drawPos = LBOUND(layoutZOrder) TO UBOUND(layoutZOrder)
        slotIdx = layoutZOrder(drawPos)
        IF slotIdx >= LBOUND(layoutWindows) AND slotIdx <= UBOUND(layoutWindows) THEN
            IF layoutWindows(slotIdx).used <> 0 AND layoutWindows(slotIdx).minimized = 0 THEN
                IF slotIdx = dragSlot THEN
                    DrawLayoutWindowDragOutline slotIdx
                ELSE
                    DrawLayoutWindowCached slotIdx
                    lastCachedWindowDrawn = slotIdx
                END IF
            END IF
        END IF
    NEXT

    FOR fallbackIdx = LBOUND(layoutWindows) TO UBOUND(layoutWindows)
        IF layoutWindows(fallbackIdx).used <> 0 AND layoutWindows(fallbackIdx).minimized = 0 THEN
            alreadyDrawn = 0
            FOR k = LBOUND(layoutZOrder) TO UBOUND(layoutZOrder)
                IF layoutZOrder(k) = fallbackIdx THEN
                    alreadyDrawn = -1
                    EXIT FOR
                END IF
            NEXT
            IF alreadyDrawn = 0 THEN
                IF fallbackIdx = dragSlot THEN
                    DrawLayoutWindowDragOutline fallbackIdx
                ELSE
                    DrawLayoutWindowCached fallbackIdx
                    lastCachedWindowDrawn = fallbackIdx
                END IF
            END IF
        END IF
    NEXT

    ' Outline dragging skips the normal cached draw for the dragged window.
    ' Keep the restore unless the active window was the last cached window drawn.
    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
            IF lastCachedWindowDrawn <> activeLayoutWindow THEN SyncGlobalsFromLayoutWindow activeLayoutWindow
        END IF
    END IF
END SUB


FUNCTION LayoutWindowChromeSignature(BYVAL winIdx AS INTEGER) AS LONG
    DIM sig AS LONG
    DIM titleText AS STRING
    DIM i AS INTEGER

    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN RETURN 0
    IF layoutWindows(winIdx).used = 0 THEN RETURN 0

    sig = 31
    sig = sig + CLNG(layoutRenderVersion) * 37
    sig = sig + CLNG(cfg.colorDepth) * 41
    sig = sig + CLNG(layoutWindows(winIdx).x + 32768) * 3
    sig = sig + CLNG(layoutWindows(winIdx).y + 32768) * 5
    sig = sig + CLNG(layoutWindows(winIdx).w + 32768) * 7
    sig = sig + CLNG(layoutWindows(winIdx).h + 32768) * 11
    sig = sig + CLNG(layoutWindows(winIdx).active) * 13
    sig = sig + CLNG(layoutWindows(winIdx).resizable) * 17
    sig = sig + CLNG(layoutWindows(winIdx).maximized) * 19
    sig = sig + CLNG(theme.selectR) * 23 + CLNG(theme.selectG) * 29 + CLNG(theme.selectB) * 31
    sig = sig + CLNG(COL_BACKGROUND AND &HFFFF) * 43
    sig = sig + CLNG(COL_TITLE AND &HFFFF) * 47
    sig = sig + CLNG(COL_TEXT AND &HFFFF) * 53
    sig = sig + CLNG(COL_TEXT_INV AND &HFFFF) * 59
    sig = sig + UIStyleDrawSignature() * 67

    titleText = RTRIM$(layoutWindows(winIdx).title)
    sig = sig + CLNG(LEN(titleText)) * 61
    FOR i = 1 TO LEN(titleText)
        sig = sig + CLNG(ASC(MID$(titleText, i, 1))) * CLNG(i + 67)
        IF sig > 1000000000 THEN sig = sig MOD 1000000000
    NEXT

    IF sig > 1000000000 THEN sig = sig MOD 1000000000
    IF sig < -1000000000 THEN sig = sig MOD 1000000000
    RETURN sig
END FUNCTION

SUB DrawLayoutWindowChromeRaw()
    DIM titleHasMaxButton AS INTEGER
    DIM titleMinLeft AS INTEGER
    DIM titleMinRight AS INTEGER

    titleHasMaxButton = 0
    IF drawLayoutWindow >= LBOUND(layoutWindows) AND drawLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(drawLayoutWindow).used <> 0 THEN
            IF layoutWindows(drawLayoutWindow).resizable <> 0 THEN titleHasMaxButton = -1
        END IF
    END IF

    IF titleHasMaxButton <> 0 THEN
        titleMinLeft = uiWinX + uiWinW - 55
        titleMinRight = uiWinX + uiWinW - 39
    ELSE
        titleMinLeft = uiWinX + uiWinW - 37
        titleMinRight = uiWinX + uiWinW - 21
    END IF

    Draw3DRect uiWinX, uiWinY, uiWinX + uiWinW, uiWinY + uiWinH, 1
    IF uiStyle.windowModern <> 0 THEN
        LINE (uiWinX, uiWinY)-(uiWinX + uiWinW, uiWinY + uiWinH), uiStyle.windowBorderLoCol, B
        IF uiWinW > 4 AND uiWinH > 4 THEN
            LINE (uiWinX + 1, uiWinY + 1)-(uiWinX + uiWinW - 1, uiWinY + 1), uiStyle.windowBorderHiCol
            LINE (uiWinX + 1, uiWinY + 1)-(uiWinX + 1, uiWinY + uiWinH - 1), uiStyle.windowBorderHiCol
        END IF
    END IF
    IF uiWindowActive <> 0 THEN
        DrawThemedTitleBar uiWinX + 1, uiWinY + 1, uiWinX + uiWinW - 1, uiWinY + 18, -1
        DRAW STRING (uiWinX + 8, uiWinY + 5), uiTitle, COL_TEXT_INV
    ELSE
        DrawThemedTitleBar uiWinX + 1, uiWinY + 1, uiWinX + uiWinW - 1, uiWinY + 18, 0
        DRAW STRING (uiWinX + 8, uiWinY + 5), uiTitle, COL_TEXT
    END IF

    DrawTitleButtonBevelBox titleMinLeft, uiWinY + 2, titleMinRight, uiWinY + 16, 0
    LINE (titleMinLeft + 4, uiWinY + 12)-(titleMinRight - 4, uiWinY + 12), uiStyle.titleButtonSymbolCol
    LINE (titleMinLeft + 4, uiWinY + 13)-(titleMinRight - 4, uiWinY + 13), uiStyle.titleButtonSymbolCol

    IF titleHasMaxButton <> 0 THEN
        DrawTitleButtonBevelBox uiWinX + uiWinW - 37, uiWinY + 2, uiWinX + uiWinW - 21, uiWinY + 16, 0
        IF drawLayoutWindow >= LBOUND(layoutWindows) AND drawLayoutWindow <= UBOUND(layoutWindows) THEN
            IF layoutWindows(drawLayoutWindow).used <> 0 AND layoutWindows(drawLayoutWindow).maximized <> 0 THEN
                LINE (uiWinX + uiWinW - 32, uiWinY + 8)-(uiWinX + uiWinW - 25, uiWinY + 14), uiStyle.titleButtonSymbolCol, B
                LINE (uiWinX + uiWinW - 30, uiWinY + 5)-(uiWinX + uiWinW - 23, uiWinY + 11), uiStyle.titleButtonSymbolCol, B
            ELSE
                LINE (uiWinX + uiWinW - 33, uiWinY + 5)-(uiWinX + uiWinW - 25, uiWinY + 13), uiStyle.titleButtonSymbolCol, B
                LINE (uiWinX + uiWinW - 33, uiWinY + 6)-(uiWinX + uiWinW - 25, uiWinY + 6), uiStyle.titleButtonSymbolCol
            END IF
        ELSE
            LINE (uiWinX + uiWinW - 33, uiWinY + 5)-(uiWinX + uiWinW - 25, uiWinY + 13), uiStyle.titleButtonSymbolCol, B
            LINE (uiWinX + uiWinW - 33, uiWinY + 6)-(uiWinX + uiWinW - 25, uiWinY + 6), uiStyle.titleButtonSymbolCol
        END IF
    END IF

    DrawTitleButtonBevelBox uiWinX + uiWinW - 19, uiWinY + 2, uiWinX + uiWinW - 3, uiWinY + 16, 0
    DrawCloseGlyph uiWinX + uiWinW - 19, uiWinY + 2, uiWinX + uiWinW - 3, uiWinY + 16
END SUB

SUB DrawLayoutWindowChromeCached(BYVAL winIdx AS INTEGER)
    DIM sig AS LONG

    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN
        DrawLayoutWindowChromeRaw
        EXIT SUB
    END IF
    IF layoutWindows(winIdx).used = 0 THEN EXIT SUB
    IF layoutWindows(winIdx).minimized <> 0 THEN EXIT SUB

    IF winIdx <> activeLayoutWindow THEN
        DrawLayoutWindowChromeRaw
        EXIT SUB
    END IF

    IF layoutWindows(winIdx).x < 0 OR layoutWindows(winIdx).y < 0 THEN
        DrawLayoutWindowChromeRaw
        EXIT SUB
    END IF
    IF layoutWindows(winIdx).x + layoutWindows(winIdx).w >= SCR_W THEN
        DrawLayoutWindowChromeRaw
        EXIT SUB
    END IF
    IF layoutWindows(winIdx).y + layoutWindows(winIdx).h >= SCR_H THEN
        DrawLayoutWindowChromeRaw
        EXIT SUB
    END IF
    IF layoutWindows(winIdx).w < 1 OR layoutWindows(winIdx).h < 1 THEN
        DrawLayoutWindowChromeRaw
        EXIT SUB
    END IF

    sig = LayoutWindowChromeSignature(winIdx)
    IF layoutChromeCache(winIdx) <> 0 AND layoutChromeCacheValid(winIdx) <> 0 THEN
        IF layoutChromeCacheSig(winIdx) = sig AND _
           layoutChromeCacheW(winIdx) = layoutWindows(winIdx).w AND _
           layoutChromeCacheH(winIdx) = layoutWindows(winIdx).h THEN
            PUT (layoutWindows(winIdx).x, layoutWindows(winIdx).y), layoutChromeCache(winIdx), PSET
            EXIT SUB
        END IF
    END IF

    DrawLayoutWindowChromeRaw

    IF layoutChromeCache(winIdx) = 0 OR _
       layoutChromeCacheW(winIdx) <> layoutWindows(winIdx).w OR _
       layoutChromeCacheH(winIdx) <> layoutWindows(winIdx).h THEN
        FreeLayoutWindowChromeCache winIdx
        layoutChromeCache(winIdx) = ImageCreate(layoutWindows(winIdx).w + 1, layoutWindows(winIdx).h + 1, 0)
    END IF
    IF layoutChromeCache(winIdx) <> 0 THEN
        GET (layoutWindows(winIdx).x, layoutWindows(winIdx).y)-(layoutWindows(winIdx).x + layoutWindows(winIdx).w, layoutWindows(winIdx).y + layoutWindows(winIdx).h), layoutChromeCache(winIdx)
        layoutChromeCacheSig(winIdx) = sig
        layoutChromeCacheW(winIdx) = layoutWindows(winIdx).w
        layoutChromeCacheH(winIdx) = layoutWindows(winIdx).h
        layoutChromeCacheValid(winIdx) = -1
    END IF
END SUB

' Draws the visible controls for an app window.
SUB DrawAppLayout()
    DIM i AS INTEGER
    DIM activePage AS STRING
    DIM tabNumber AS INTEGER
    DIM ex AS INTEGER
    DIM ey AS INTEGER
    DIM ew AS INTEGER
    DIM eh AS INTEGER
    DIM visible AS INTEGER
    DIM txtLen AS INTEGER
    DIM tx AS INTEGER
    DIM ty AS INTEGER
    DIM contBottom AS INTEGER
    DIM clientHt AS INTEGER
    DIM maxScrl AS INTEGER
    DIM sbLeft AS INTEGER
    DIM sbRight AS INTEGER
    DIM trackHt AS INTEGER
    DIM thumbHt AS INTEGER
    DIM thumbTopPos AS INTEGER
    DIM thumbBottomPos AS INTEGER
    DIM elemBottom AS INTEGER
    DIM showVScroll AS INTEGER
    DIM contentRight AS INTEGER
    DIM comboRows AS INTEGER
    DIM comboTop AS INTEGER
    DIM comboBottom AS INTEGER
    DIM comboItemH AS INTEGER
    DIM itemIdx AS INTEGER
    DIM visibleRow AS INTEGER
    DIM topIdx AS INTEGER
    DIM itemText AS STRING
    DIM labelText AS STRING
    DIM sourceLabelText AS STRING
    DIM itemCount AS INTEGER
    DIM showComboScroll AS INTEGER
    DIM comboScrollLeft AS INTEGER
    DIM comboTextRight AS INTEGER
    DIM comboTrackTop AS INTEGER
    DIM comboTrackBottom AS INTEGER
    DIM comboTrackH AS INTEGER
    DIM comboThumbH AS INTEGER
    DIM comboThumbTop AS INTEGER
    DIM comboThumbBottom AS INTEGER
    DIM listRowY AS INTEGER
    DIM listRows AS INTEGER
    DIM clipL AS INTEGER
    DIM clipT AS INTEGER
    DIM clipR AS INTEGER
    DIM clipB AS INTEGER
    DIM contentW AS INTEGER
    DIM showHScroll AS INTEGER
    DIM clientW AS INTEGER
    DIM maxScrollX AS INTEGER
    DIM listItemSelected AS INTEGER
    DIM listItemValue AS STRING
    DIM listBaseText AS STRING
    DIM listItemTextUpper AS STRING
    DIM listItemValueUpper AS STRING
    DIM listHighlightAllowed AS INTEGER
    DIM listSelectedTextUpper AS STRING
    DIM listMultiSelBagUpper AS STRING
    DIM listMultiSelNeedle AS STRING
    DIM listCacheSlot AS INTEGER
    DIM depthTab AS INTEGER
    DIM tabIsSelected AS INTEGER
    DIM tabIsDepressed AS INTEGER
    DIM tabFillColor AS UINTEGER
    DIM tabTextColor AS UINTEGER
    DIM tabTextX AS INTEGER
    DIM tabTextY AS INTEGER
    DIM elemIsDynamic AS INTEGER
    DIM elemShouldDraw AS INTEGER
    DIM elemCacheSig AS LONG
    DIM elemCacheSigReady AS INTEGER
    DIM labelClearWidth AS INTEGER
    DIM drawStart AS INTEGER
    DIM drawEnd AS INTEGER
    DIM buttonIsDepressed AS INTEGER
    DIM buttonActionWork AS STRING
    DIM buttonActionVerb AS STRING
    DIM buttonToolName AS STRING
    DIM buttonToolId AS INTEGER
    DIM titleIsMaximized AS INTEGER

    titleIsMaximized = 0
    IF drawLayoutWindow >= LBOUND(layoutWindows) AND drawLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(drawLayoutWindow).used <> 0 THEN
            IF layoutWindows(drawLayoutWindow).maximized <> 0 THEN titleIsMaximized = -1
        END IF
    END IF

    IF layoutDrawPass <> 2 AND layoutDrawPass <> 3 AND layoutDrawPass <> 4 THEN
        DrawLayoutWindowChromeCached drawLayoutWindow
    END IF

    activePage = ""
    tabNumber = 0

    FOR i = 1 TO uiCount
        IF uiElems(i).kindId = UI_KIND_TAB THEN
            tabNumber = tabNumber + 1
            IF tabNumber = uiSelectedTab THEN
                activePage = UCASE$(uiElems(i).text)
                EXIT FOR
            END IF
        END IF
    NEXT
    IF activePage = "" THEN
        FOR i = 1 TO uiCount
            IF uiElems(i).kindId = UI_KIND_TAB THEN
                activePage = UCASE$(uiElems(i).text)
                EXIT FOR
            END IF
        NEXT
    END IF

    GetLayoutContentExtents contentW, contBottom
    GetLayoutScrollMetricsFromContent contentW, contBottom, showHScroll, showVScroll, clientW, clientHt, maxScrollX, maxScrl

    uiScrollX = ClampScrollPos(uiScrollX, maxScrollX)
    uiScrollY = ClampScrollPos(uiScrollY, maxScrl)

    sbLeft = uiWinX + uiWinW - 14
    sbRight = uiWinX + uiWinW - 2
    contentRight = LayoutVisibleClientRight(showVScroll)

    clipL = uiWinX + 2
    clipT = uiWinY + 19
    clipR = contentRight
    clipB = LayoutVisibleClientBottom(showHScroll)

    IF layoutDrawPass <> 2 AND layoutDrawPass <> 3 AND layoutDrawPass <> 4 THEN
        FillRectClipped clipL, clipT, clipR, clipB, clipL, clipT, clipR, clipB, COL_BACKGROUND
    END IF

    drawStart = 1
    drawEnd = uiCount
    IF layoutDrawPass = 3 THEN
        IF layoutDrawOnlyElement < 1 OR layoutDrawOnlyElement > uiCount THEN EXIT SUB
        drawStart = layoutDrawOnlyElement
        drawEnd = layoutDrawOnlyElement
    END IF

    tabNumber = 0

    FOR i = drawStart TO drawEnd
        ex = uiWinX + uiElems(i).x - uiScrollX
        ey = uiWinY + 22 + uiElems(i).y - uiScrollY
        ew = uiElems(i).w
        eh = uiElems(i).h

        IF uiElems(i).kindId = UI_KIND_TAB THEN
            tabNumber = tabNumber + 1
            IF layoutDrawPass <> 2 AND layoutDrawPass <> 3 AND layoutDrawPass <> 4 THEN
                IF RectIntersectsClip(ex, ey, ex + ew, ey + eh, clipL, clipT, clipR, clipB) <> 0 THEN
                depthTab = LayoutTabHasConfigBinding(i, drawLayoutWindow)
                tabIsSelected = 0
                IF tabNumber = uiSelectedTab THEN tabIsSelected = -1
                tabIsDepressed = 0
                IF i = uiPressedIndex THEN tabIsDepressed = -1
                IF depthTab <> 0 AND tabIsSelected <> 0 THEN tabIsDepressed = -1

                IF tabIsDepressed <> 0 THEN
                    Draw3DRectClipped ex, ey, ex + ew, ey + eh, 0, clipL, clipT, clipR, clipB
                ELSE
                    Draw3DRectClipped ex, ey, ex + ew, ey + eh, 1, clipL, clipT, clipR, clipB
                END IF

                tabFillColor = COL_BACKGROUND
                tabTextColor = COL_TEXT
                IF tabIsSelected <> 0 THEN
                    tabFillColor = COL_SELECT
                    tabTextColor = COL_SELECTED_TEXT
                ELSEIF depthTab <> 0 THEN
                    tabFillColor = COL_BUTTON
                END IF

                FillRectClipped ex + 2, ey + 2, ex + ew - 2, ey + eh - 2, clipL, clipT, clipR, clipB, tabFillColor

                tabTextX = ex + 6
                tabTextY = ey + 6
                IF tabIsDepressed <> 0 THEN
                    tabTextX = tabTextX + 1
                    tabTextY = tabTextY + 1
                END IF
                DrawStringRefClipped tabTextX, tabTextY, uiElems(i).text, tabTextColor, clipL, clipT, clipR, clipB
                END IF
            END IF
        ELSE
            visible = 0
            IF uiElems(i).page = "" THEN
                visible = -1
            ELSEIF uiElems(i).pageKey = activePage THEN
                visible = -1
            END IF

            IF visible <> 0 THEN
                elemIsDynamic = LayoutElementIsDynamic(i)
                elemShouldDraw = 0
                IF layoutDrawPass = 0 THEN elemShouldDraw = -1
                IF layoutDrawPass = 1 AND elemIsDynamic = 0 THEN elemShouldDraw = -1
                IF layoutDrawPass = 2 AND elemIsDynamic <> 0 THEN elemShouldDraw = -1
                IF layoutDrawPass = 3 THEN
                    IF i = layoutDrawOnlyElement THEN
                        elemShouldDraw = -1
                    ELSE
                        elemShouldDraw = 0
                    END IF
                END IF
                IF layoutDrawPass = 4 THEN
                    IF drawLayoutWindow >= LBOUND(layoutWindows) AND drawLayoutWindow <= UBOUND(layoutWindows) THEN
                        IF layoutDirtyElemMarked(drawLayoutWindow, i) <> 0 THEN elemShouldDraw = -1
                    END IF
                END IF
                IF elemShouldDraw <> 0 THEN
                    IF layoutDrawPass = 2 AND elemIsDynamic <> 0 THEN
                        elemCacheSig = 0
                        elemCacheSigReady = 0
                        IF DrawLayoutElementFromCache(drawLayoutWindow, i, ex, ey, ew, eh, clipL, clipT, clipR, clipB, elemCacheSig, elemCacheSigReady) <> 0 THEN
                            elemShouldDraw = 0
                        END IF
                    END IF
                END IF
                IF elemShouldDraw <> 0 THEN
                SELECT CASE uiElems(i).kindKey
                CASE "LABEL"
                    labelText = uiElems(i).text
                    IF uiElems(i).modeId = UI_MODE_TEXT_STATS THEN
                        IF drawLayoutWindow >= LBOUND(layoutWindows) AND drawLayoutWindow <= UBOUND(layoutWindows) THEN
                            IF layoutTextStatsCacheValid(drawLayoutWindow, i) <> 0 THEN
                                labelText = layoutTextStatsCacheText(drawLayoutWindow, i)
                            ELSE
                                labelText = TextStatsLabelText(i)
                                layoutTextStatsCacheText(drawLayoutWindow, i) = labelText
                                layoutTextStatsCacheValid(drawLayoutWindow, i) = -1
                            END IF
                        ELSE
                            labelText = TextStatsLabelText(i)
                        END IF
                    ELSEIF TRIM$(uiElems(i).sourceControl) <> "" THEN
                        sourceLabelText = GetControlTextValue(uiElems(i).sourceControl)
                        IF sourceLabelText <> "" THEN labelText = sourceLabelText
                    END IF
                    txtLen = LEN(labelText) * 8
                    IF layoutDrawPass = 3 OR layoutDrawPass = 4 THEN
                        IF drawLayoutWindow >= LBOUND(layoutWindows) AND drawLayoutWindow <= UBOUND(layoutWindows) THEN
                            labelClearWidth = txtLen
                            IF layoutDirectLabelLastWidth(drawLayoutWindow, i) > labelClearWidth THEN labelClearWidth = layoutDirectLabelLastWidth(drawLayoutWindow, i)
                            IF labelClearWidth > 0 THEN FillRectClipped ex, ey, ex + labelClearWidth, ey + 8, clipL, clipT, clipR, clipB, COL_BACKGROUND
                        END IF
                    END IF
                    IF RectIntersectsClip(ex, ey, ex + txtLen, ey + 8, clipL, clipT, clipR, clipB) <> 0 THEN
                        DrawStringRefClipped ex, ey, labelText, COL_TEXT, clipL, clipT, clipR, clipB
                    END IF
                    IF drawLayoutWindow >= LBOUND(layoutWindows) AND drawLayoutWindow <= UBOUND(layoutWindows) THEN layoutDirectLabelLastWidth(drawLayoutWindow, i) = txtLen

                CASE "APPVIEW"
                    IF RectIntersectsClip(ex, ey, ex + ew, ey + eh, clipL, clipT, clipR, clipB) <> 0 THEN
                        AppViewDrawElement drawLayoutWindow, i, ex, ey, ew, eh, clipL, clipT, clipR, clipB
                    END IF

                CASE "CANVAS"
                    IF RectIntersectsClip(ex, ey, ex + ew, ey + eh, clipL, clipT, clipR, clipB) <> 0 THEN
                        CanvasDrawElement drawLayoutWindow, i, ex, ey, ew, eh, clipL, clipT, clipR, clipB
                    END IF

                CASE "PREVIEW"
                    IF RectIntersectsClip(ex, ey, ex + ew, ey + eh, clipL, clipT, clipR, clipB) <> 0 THEN
                        Draw3DRectClipped ex, ey, ex + ew, ey + eh, 0, clipL, clipT, clipR, clipB
                        IF uiElems(i).sourceControl <> "" THEN
                            DrawBoundPreview i, ex, ey, ex + ew, ey + eh, clipL, clipT, clipR, clipB
                        END IF
                    END IF

                CASE "RADIO"
                    txtLen = LEN(uiElems(i).text) * 8
                    IF RectIntersectsClip(ex, ey, ex + 22 + txtLen, ey + 16, clipL, clipT, clipR, clipB) <> 0 THEN
                        CIRCLE (ex + 8, ey + 8), 7, COL_TEXT
                        CIRCLE (ex + 8, ey + 8), 6, COL_BEVEL_LO
                        IF uiElems(i).state <> 0 THEN
                            PAINT (ex + 8, ey + 8), COL_TEXT, COL_TEXT
                        END IF
                        DrawStringRefClipped ex + 22, ey + 2, uiElems(i).text, COL_TEXT, clipL, clipT, clipR, clipB
                    END IF

                CASE "CHECKBOX"
                    txtLen = LEN(uiElems(i).text) * 8
                    IF RectIntersectsClip(ex, ey, ex + 22 + txtLen, ey + 16, clipL, clipT, clipR, clipB) <> 0 THEN
                        Draw3DRectClipped ex + 1, ey + 2, ex + 14, ey + 15, 0, clipL, clipT, clipR, clipB
                        FillRectClipped ex + 3, ey + 4, ex + 12, ey + 13, clipL, clipT, clipR, clipB, COL_TEXT_INV
                        IF uiElems(i).state <> 0 THEN
                            DrawCheckMark ex, ey
                        END IF
                        DrawStringRefClipped ex + 22, ey + 2, uiElems(i).text, COL_TEXT, clipL, clipT, clipR, clipB
                    END IF

                CASE "BUTTON"
                    IF ew <= 0 THEN ew = LEN(uiElems(i).text) * 8 + 20
                    IF eh <= 0 THEN eh = 22
                    IF RectIntersectsClip(ex, ey, ex + ew, ey + eh, clipL, clipT, clipR, clipB) <> 0 THEN
                        buttonIsDepressed = 0
                        IF i = uiPressedIndex THEN buttonIsDepressed = -1

                        buttonActionWork = TRIM$(uiElems(i).action)
                        buttonActionVerb = UCASE$(NextActionToken(buttonActionWork))
                        IF buttonActionVerb = "APPVIEW_TOOL" THEN
                            buttonToolName = NextActionToken(buttonActionWork)
                            buttonToolId = AppViewToolId(buttonToolName)
                            IF drawLayoutWindow >= LBOUND(layoutWindows) AND drawLayoutWindow <= UBOUND(layoutWindows) THEN
                                IF layoutWindows(drawLayoutWindow).used <> 0 THEN
                                    IF appViewTool(drawLayoutWindow) = buttonToolId THEN buttonIsDepressed = -1
                                END IF
                            END IF
                        END IF

                        DrawButtonBevelBoxClipped ex, ey, ex + ew, ey + eh, buttonIsDepressed, clipL, clipT, clipR, clipB
                        IF uiStyle.buttonStyleId = 1 THEN FillRectClipped ex + 2, ey + 2, ex + ew - 2, ey + eh - 2, clipL, clipT, clipR, clipB, uiStyle.buttonFaceCol
                        txtLen = LEN(uiElems(i).text)
                        tx = ex + (ew - txtLen * 8) \ 2
                        ty = ey + (eh - 8) \ 2
                        IF buttonIsDepressed <> 0 THEN
                            tx = tx + uiStyle.pressedOffset
                            ty = ty + uiStyle.pressedOffset
                        END IF
                        IF tx < ex + 4 THEN tx = ex + 4
                        IF ty < ey + 4 THEN ty = ey + 4
                        DrawStringRefClipped tx, ty, uiElems(i).text, COL_TEXT, clipL, clipT, clipR, clipB
                    END IF

                CASE "COMBO"
                    IF ew <= 0 THEN ew = 120
                    IF eh <= 0 THEN eh = 22
                    IF RectIntersectsClip(ex, ey, ex + ew, ey + eh, clipL, clipT, clipR, clipB) <> 0 THEN
                        IF uiElems(i).drawStyleId = UI_DRAW_BUTTON THEN
                            DrawButtonBevelBoxClipped ex, ey, ex + ew, ey + eh, (i = uiPressedIndex), clipL, clipT, clipR, clipB
                            IF uiStyle.buttonStyleId = 1 THEN FillRectClipped ex + 2, ey + 2, ex + ew - 2, ey + eh - 2, clipL, clipT, clipR, clipB, uiStyle.buttonFaceCol
                            itemText = RTRIM$(uiElems(i).text)
                            txtLen = LEN(itemText)
                            tx = ex + (ew - txtLen * 8) \ 2
                            ty = ey + (eh - 8) \ 2
                            IF i = uiPressedIndex THEN
                                tx = tx + uiStyle.pressedOffset
                                ty = ty + uiStyle.pressedOffset
                            END IF
                            IF tx < ex + 4 THEN tx = ex + 4
                            IF ty < ey + 4 THEN ty = ey + 4
                            IF itemText <> "" THEN DrawStringRefClipped tx, ty, itemText, COL_TEXT, clipL, clipT, clipR, clipB
                        ELSE
                            Draw3DRectClipped ex, ey, ex + ew, ey + eh, 0, clipL, clipT, clipR, clipB
                            FillRectClipped ex + 2, ey + 2, ex + ew - 20, ey + eh - 2, clipL, clipT, clipR, clipB, COL_CONTROL_BG
                            Draw3DRectClipped ex + ew - 18, ey + 1, ex + ew - 1, ey + eh - 1, 1, clipL, clipT, clipR, clipB
                            LineHClipped ex + ew - 13, ex + ew - 5, ey + eh \ 2 - 2, clipL, clipT, clipR, clipB, COL_TEXT
                            LineHClipped ex + ew - 12, ex + ew - 6, ey + eh \ 2 - 1, clipL, clipT, clipR, clipB, COL_TEXT
                            LineHClipped ex + ew - 11, ex + ew - 7, ey + eh \ 2, clipL, clipT, clipR, clipB, COL_TEXT
                            itemText = RTRIM$(uiElems(i).text)
                            IF itemText <> "" THEN
                                DrawStringRefClipped ex + 4, ey + ((eh - 8) \ 2), itemText, COL_TEXT, clipL, clipT, clipR, clipB
                            END IF
                        END IF
                    END IF
                CASE "LISTBOX"
                    IF ew <= 0 THEN ew = 120
                    IF eh <= 0 THEN eh = 100
                    IF RectIntersectsClip(ex, ey, ex + ew, ey + eh, clipL, clipT, clipR, clipB) <> 0 THEN
                        Draw3DRectClipped ex, ey, ex + ew, ey + eh, 0, clipL, clipT, clipR, clipB
                        FillRectClipped ex + 2, ey + 2, ex + ew - 2, ey + eh - 2, clipL, clipT, clipR, clipB, COL_CONTROL_BG

                        listCacheSlot = EnsureComboItemCacheSlot(i)
                        IF listCacheSlot > 0 THEN
                            itemCount = comboItemCacheCount(listCacheSlot)
                        ELSE
                            BuildComboItems i
                            itemCount = tempComboItemCount
                        END IF
                        comboItemH = 16
                        listRows = (eh - 4) \ comboItemH
                        IF listRows < 1 THEN listRows = 1
                        IF activeLayoutWindow >= 1 AND activeLayoutWindow <= 12 THEN
                            comboScrollTop(activeLayoutWindow, i) = ClampScrollPos(comboScrollTop(activeLayoutWindow, i), itemCount - listRows)
                            topIdx = comboScrollTop(activeLayoutWindow, i)
                        ELSE
                            topIdx = 0
                        END IF

                        showComboScroll = 0
                        IF itemCount > listRows THEN showComboScroll = -1
                        comboTextRight = ex + ew - 4
                        IF showComboScroll <> 0 THEN comboTextRight = ex + ew - 16

                        listHighlightAllowed = -1
                        IF uiElems(i).drawStyleId = UI_DRAW_FOCUS_SELECT THEN
                            listHighlightAllowed = 0
                            IF uiWindowActive <> 0 AND uiFocusIndex = i THEN listHighlightAllowed = -1
                        END IF
                        listSelectedTextUpper = ""
                        listMultiSelBagUpper = ""
                        IF listHighlightAllowed <> 0 THEN
                            listSelectedTextUpper = UCASE$(RTRIM$(uiElems(i).text))
                            IF uiElems(i).multiSelect <> 0 THEN
                                IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
                                    IF layoutListMultiSel(activeLayoutWindow, i) <> "" THEN
                                        listMultiSelBagUpper = CHR$(1) + UCASE$(layoutListMultiSel(activeLayoutWindow, i)) + CHR$(1)
                                    END IF
                                END IF
                            END IF
                        END IF

                        FOR visibleRow = 0 TO listRows - 1
                            itemIdx = topIdx + visibleRow + 1
                            IF itemIdx >= 1 AND itemIdx <= itemCount THEN
                                listRowY = ey + 2 + visibleRow * comboItemH
                                IF listCacheSlot > 0 THEN
                                    itemText = RTRIM$(comboItemCacheItems(listCacheSlot, itemIdx))
                                    listItemValue = RTRIM$(comboItemCacheValues(listCacheSlot, itemIdx))
                                ELSE
                                    itemText = RTRIM$(tempComboItems(itemIdx))
                                    listItemValue = RTRIM$(tempComboValues(itemIdx))
                                END IF
                                listBaseText = itemText
                                IF uiElems(i).sourceKindId = UI_SOURCE_FILES AND LEFT$(listItemValue, 2) = "F:" THEN
                                    itemText = CachedFilePaneCaption(listItemValue, listBaseText, uiElems(i).w)
                                END IF
                                listItemSelected = 0
                                IF listHighlightAllowed <> 0 THEN
                                    listItemValueUpper = UCASE$(listItemValue)
                                    IF LEFT$(listItemValue, 2) = "P:" THEN
                                        IF listSelectedTextUpper = listItemValueUpper THEN listItemSelected = -1
                                    ELSE
                                        listItemTextUpper = UCASE$(itemText)
                                        IF listSelectedTextUpper = listItemTextUpper OR listSelectedTextUpper = UCASE$(listBaseText) OR listSelectedTextUpper = listItemValueUpper THEN listItemSelected = -1
                                    END IF
                                    IF uiElems(i).multiSelect <> 0 AND listMultiSelBagUpper <> "" AND listItemValue <> "" THEN
                                        listMultiSelNeedle = CHR$(1) + listItemValueUpper + CHR$(1)
                                        IF INSTR(listMultiSelBagUpper, listMultiSelNeedle) > 0 THEN listItemSelected = -1
                                    END IF
                                END IF

                                IF listItemSelected <> 0 THEN
                                    FillRectClipped ex + 2, listRowY, comboTextRight, listRowY + comboItemH - 1, clipL, clipT, clipR, clipB, COL_SELECT
                                    IF itemText <> "" THEN DrawStringRefClipped ex + 4, listRowY + 4, itemText, COL_SELECTED_TEXT, clipL, clipT, comboTextRight - 1, clipB
                                ELSE
                                    IF itemText <> "" THEN DrawStringRefClipped ex + 4, listRowY + 4, itemText, COL_TEXT, clipL, clipT, comboTextRight - 1, clipB
                                END IF
                            END IF
                        NEXT

                        IF showComboScroll <> 0 THEN
                            comboScrollLeft = ex + ew - 14
                            comboTrackTop = ey + 3
                            comboTrackBottom = ey + eh - 3
                            comboTrackH = comboTrackBottom - comboTrackTop + 1
                            Draw3DRectClipped comboScrollLeft, ey + 2, ex + ew - 2, ey + eh - 2, 0, clipL, clipT, clipR, clipB
                            comboThumbH = CalcScrollThumbSize(listRows, itemCount, comboTrackH, 12)
                            comboThumbTop = CalcScrollThumbTop(topIdx, itemCount - listRows, comboTrackTop, comboTrackH, comboThumbH)
                            comboThumbBottom = comboThumbTop + comboThumbH - 1
                            Draw3DRectClipped comboScrollLeft + 1, comboThumbTop, ex + ew - 3, comboThumbBottom, 1, clipL, clipT, clipR, clipB
                        END IF
                    END IF

                CASE "SPLITTER"
                    IF ew <= 0 THEN ew = 6
                    IF eh <= 0 THEN eh = 100
                    IF RectIntersectsClip(ex, ey, ex + ew, ey + eh, clipL, clipT, clipR, clipB) <> 0 THEN
                        Draw3DRectClipped ex, ey, ex + ew, ey + eh, 1, clipL, clipT, clipR, clipB
                        LineVClipped ex + (ew \ 2), ey + 4, ey + eh - 4, clipL, clipT, clipR, clipB, COL_BEVEL_LO
                    END IF

                CASE "TEXTBOX"
                    IF ew <= 0 THEN ew = 120
                    IF eh <= 0 THEN eh = 22
                    IF RectIntersectsClip(ex, ey, ex + ew, ey + eh, clipL, clipT, clipR, clipB) <> 0 THEN
                        DIM tbFocus AS INTEGER
                        DIM tbCaret AS INTEGER
                        DIM tbRows AS INTEGER
                        DIM tbCols AS INTEGER
                        DIM tbFirstLine AS INTEGER
                        DIM tbCaretLineNum AS INTEGER
                        DIM tbRow AS INTEGER
                        DIM tbStartPos AS INTEGER
                        DIM tbLineEnd AS INTEGER
                        DIM tbCol AS INTEGER
                        DIM tbSelA AS INTEGER
                        DIM tbSelB AS INTEGER
                        DIM tbSegA AS INTEGER
                        DIM tbSegB AS INTEGER
                        DIM tbSelX1 AS INTEGER
                        DIM tbSelX2 AS INTEGER
                        DIM tbLocked AS INTEGER
                        DIM tbFillCol AS UINTEGER
                        DIM tbTextCol AS UINTEGER
                        DIM tbLineCount AS INTEGER
                        DIM tbMaxTop AS INTEGER
                        DIM tbShowScroll AS INTEGER
                        DIM tbScrollLeft AS INTEGER
                        DIM tbTextClipR AS INTEGER
                        DIM tbTrackTop AS INTEGER
                        DIM tbTrackBottom AS INTEGER
                        DIM tbTrackH AS INTEGER
                        DIM tbThumbH AS INTEGER
                        DIM tbThumbTop AS INTEGER
                        DIM tbThumbBottom AS INTEGER
                        DIM tbWrap AS INTEGER
                        DIM tbTextLen AS INTEGER
                        DIM tbTrimLen AS INTEGER
                        DIM tbDrawStart AS INTEGER
                        DIM tbDrawLen AS INTEGER
                        DIM tbTextY AS INTEGER
                        DIM tbScrollWin AS INTEGER

                        Draw3DRectClipped ex, ey, ex + ew, ey + eh, 0, clipL, clipT, clipR, clipB
                        tbLocked = 0
                        IF uiElems(i).noEdit <> 0 AND uiElems(i).state < 0 THEN tbLocked = -1
                        tbFillCol = COL_CONTROL_BG
                        tbTextCol = COL_TEXT
                        IF tbLocked <> 0 THEN
                            tbFillCol = COL_BEVEL_HI
                            tbTextCol = COL_BEVEL_LO
                        END IF
                        FillRectClipped ex + 2, ey + 2, ex + ew - 2, ey + eh - 2, clipL, clipT, clipR, clipB, tbFillCol

                        tbFocus = 0
                        tbCaret = uiCaretPos
                        IF uiWindowActive <> 0 AND uiFocusIndex = i THEN
                            tbFocus = -1
                        END IF

                        IF tbFocus <> 0 THEN
                            LineHClipped ex + 1, ex + ew - 1, ey + 1, clipL, clipT, clipR, clipB, COL_SELECT
                            LineHClipped ex + 1, ex + ew - 1, ey + eh - 1, clipL, clipT, clipR, clipB, COL_SELECT
                            LineVClipped ex + 1, ey + 1, ey + eh - 1, clipL, clipT, clipR, clipB, COL_SELECT
                            LineVClipped ex + ew - 1, ey + 1, ey + eh - 1, clipL, clipT, clipR, clipB, COL_SELECT
                        END IF

                        tbTextLen = LEN(uiElems(i).text)
                        tbWrap = TextboxWordWrap(i)
                        tbRows = TextboxRows(i)
                        tbCols = TextboxCols(i)
                        tbLineCount = TextboxDisplayLineCount(i, uiElems(i).text)
                        tbScrollWin = TextboxDrawScrollWindow()
                        tbShowScroll = 0
                        tbTextClipR = clipR
                        IF TextboxIsMultiline(i) <> 0 AND tbLineCount > tbRows THEN
                            tbShowScroll = -1
                            tbScrollLeft = ex + ew - 14
                            tbTextClipR = tbScrollLeft - 1
                            IF tbTextClipR < clipL THEN tbTextClipR = clipL
                        END IF
                        tbSelA = 0
                        tbSelB = 0
                        IF Ed_SelHas(uiEdit(i)) <> 0 THEN
                            Ed_SelNorm uiEdit(i), tbSelA, tbSelB
                        END IF

                        IF tbShowScroll <> 0 THEN
                            Draw3DRectClipped tbScrollLeft, ey + 2, ex + ew - 2, ey + eh - 2, 0, clipL, clipT, clipR, clipB
                            tbTrackTop = ey + 3
                            tbTrackBottom = ey + eh - 3
                            tbTrackH = tbTrackBottom - tbTrackTop + 1
                            IF tbTrackH < 1 THEN tbTrackH = 1
                            tbMaxTop = tbLineCount - tbRows
                            IF tbMaxTop < 0 THEN tbMaxTop = 0
                            IF tbScrollWin > 0 THEN
                                comboScrollTop(tbScrollWin, i) = ClampScrollPos(comboScrollTop(tbScrollWin, i), tbMaxTop)
                                tbThumbH = CalcScrollThumbSize(tbRows, tbLineCount, tbTrackH, 12)
                                tbThumbTop = CalcScrollThumbTop(comboScrollTop(tbScrollWin, i), tbMaxTop, tbTrackTop, tbTrackH, tbThumbH)
                                tbThumbBottom = tbThumbTop + tbThumbH - 1
                                Draw3DRectClipped tbScrollLeft + 1, tbThumbTop, ex + ew - 3, tbThumbBottom, 1, clipL, clipT, clipR, clipB
                            END IF
                        END IF

                        IF TextboxIsMultiline(i) <> 0 THEN
                            tbCaretLineNum = TextboxMetricCaretLine(i, uiElems(i).text, tbCaret, tbCols)
                            tbMaxTop = tbLineCount - tbRows
                            IF tbMaxTop < 0 THEN tbMaxTop = 0
                            tbFirstLine = 0
                            IF tbScrollWin > 0 THEN tbFirstLine = comboScrollTop(tbScrollWin, i)
                            tbFirstLine = ClampScrollPos(tbFirstLine, tbMaxTop)
                            IF tbScrollWin > 0 THEN comboScrollTop(tbScrollWin, i) = tbFirstLine
                            tbStartPos = TextboxMetricLineStart(i, uiElems(i).text, tbFirstLine, tbCols)

                            IF tbStartPos < 0 THEN tbStartPos = 0

                            FOR tbRow = 0 TO tbRows - 1
                                IF tbStartPos > tbTextLen AND tbRow > 0 THEN EXIT FOR
                                IF tbWrap <> 0 THEN
                                    tbLineEnd = TbWrappedLineEndPos(uiElems(i).text, tbStartPos, tbCols)
                                ELSE
                                    tbLineEnd = TbLineEndPos(uiElems(i).text, tbStartPos)
                                END IF
                                DrawStringSliceClipped ex + 4, ey + 4 + tbRow * 8, uiElems(i).text, tbStartPos + 1, tbLineEnd - tbStartPos, tbCols, tbTextCol, clipL, clipT, tbTextClipR, clipB

                                IF tbSelB > tbSelA THEN
                                    tbSegA = tbSelA
                                    tbSegB = tbSelB
                                    IF tbSegA < tbStartPos THEN tbSegA = tbStartPos
                                    IF tbSegB > tbLineEnd THEN tbSegB = tbLineEnd
                                    IF tbSegB > tbSegA THEN
                                        tbSelX1 = tbSegA - tbStartPos
                                        tbSelX2 = tbSegB - tbStartPos
                                        IF tbSelX1 < 0 THEN tbSelX1 = 0
                                        IF tbSelX2 > tbCols THEN tbSelX2 = tbCols
                                        IF tbSelX2 > tbSelX1 THEN
                                            FillRectClipped ex + 4 + tbSelX1 * 8, ey + 4 + tbRow * 8, ex + 3 + tbSelX2 * 8, ey + 11 + tbRow * 8, clipL, clipT, tbTextClipR, clipB, COL_SELECT
                                            DrawStringSliceClipped ex + 4 + tbSelX1 * 8, ey + 4 + tbRow * 8, uiElems(i).text, tbStartPos + tbSelX1 + 1, tbSelX2 - tbSelX1, tbCols, COL_SELECTED_TEXT, clipL, clipT, tbTextClipR, clipB
                                        END IF
                                    END IF
                                END IF

                                IF tbFocus <> 0 AND uiCaretVisible <> 0 AND (tbFirstLine + tbRow) = tbCaretLineNum THEN
                                    tbCol = tbCaret - tbStartPos
                                    IF tbCol < 0 THEN tbCol = 0
                                    IF tbCol > tbCols THEN tbCol = tbCols
                                    tx = ex + 4 + tbCol * 8
                                    IF tx > ex + ew - 5 THEN tx = ex + ew - 5
                                    LineVClipped tx, ey + 4 + tbRow * 8, ey + 11 + tbRow * 8, clipL, clipT, tbTextClipR, clipB, tbTextCol
                                END IF

                                IF tbLineEnd >= tbTextLen THEN EXIT FOR
                                IF tbWrap <> 0 THEN
                                    tbStartPos = TbWrappedNextLineStart(uiElems(i).text, tbStartPos, tbLineEnd, tbCols)
                                ELSE
                                    tbStartPos = TbNextLineStart(uiElems(i).text, tbLineEnd)
                                END IF
                            NEXT
                        ELSE
                            tbTrimLen = tbTextLen
                            DO WHILE tbTrimLen > 0
                                IF TextboxCharCodeAt(uiElems(i).text, tbTrimLen) <> ASC(" ") THEN EXIT DO
                                tbTrimLen = tbTrimLen - 1
                            LOOP

                            tbDrawLen = tbTrimLen
                            tbDrawStart = 1
                            IF tbDrawLen > tbCols THEN
                                tbDrawStart = tbTrimLen - tbCols + 1
                                tbDrawLen = tbCols
                            END IF

                            tbTextY = ey + ((eh - 8) \ 2)
                            IF tbDrawLen > 0 THEN
                                DrawStringSliceClipped ex + 4, tbTextY, uiElems(i).text, tbDrawStart, tbDrawLen, tbCols, tbTextCol, clipL, clipT, clipR, clipB
                            END IF

                            IF tbSelB > tbSelA THEN
                                tbSelX1 = tbSelA
                                tbSelX2 = tbSelB
                                IF tbSelX1 < 0 THEN tbSelX1 = 0
                                IF tbSelX2 > tbDrawLen THEN tbSelX2 = tbDrawLen
                                IF tbSelX2 > tbSelX1 THEN
                                    FillRectClipped ex + 4 + tbSelX1 * 8, tbTextY, ex + 3 + tbSelX2 * 8, tbTextY + 7, clipL, clipT, clipR, clipB, COL_SELECT
                                    DrawStringSliceClipped ex + 4 + tbSelX1 * 8, tbTextY, uiElems(i).text, tbDrawStart + tbSelX1, tbSelX2 - tbSelX1, tbCols, COL_SELECTED_TEXT, clipL, clipT, clipR, clipB
                                END IF
                            END IF
                            IF tbFocus <> 0 AND uiCaretVisible <> 0 THEN
                                tx = ex + 4 + tbCaret * 8
                                IF tx < ex + 4 THEN tx = ex + 4
                                IF tx > ex + ew - 5 THEN tx = ex + ew - 5
                                LineVClipped tx, ey + 4, ey + eh - 5, clipL, clipT, clipR, clipB, tbTextCol
                            END IF
                        END IF
                    END IF
                END SELECT
                    IF layoutDrawPass = 2 AND elemIsDynamic <> 0 THEN
                        CaptureLayoutElementDrawCache drawLayoutWindow, i, ex, ey, ew, eh, clipL, clipT, clipR, clipB, elemCacheSig, elemCacheSigReady
                    END IF
                END IF
            END IF
        END IF
    NEXT

    DrawLayoutOverlays activePage, clipL, clipT, clipR, clipB

    IF layoutDrawPass <> 1 AND layoutDrawPass <> 3 AND layoutDrawPass <> 4 THEN
        IF activeLayoutWindow >= 1 AND activeLayoutWindow <= 12 THEN
            IF comboOpenIndex(activeLayoutWindow) >= 1 AND comboOpenIndex(activeLayoutWindow) <= uiCount THEN
                DrawOpenComboPopup comboOpenIndex(activeLayoutWindow), contentRight
            END IF
        END IF
    END IF

    IF layoutDrawPass <> 2 AND layoutDrawPass <> 3 AND layoutDrawPass <> 4 THEN
    IF showVScroll <> 0 THEN
        DIM vTrackBottom AS INTEGER
        vTrackBottom = LayoutVisibleClientBottom(showHScroll)
        Draw3DRect sbLeft, uiWinY + 19, sbRight, vTrackBottom, 0
        IF maxScrl > 0 THEN
            trackHt = vTrackBottom - (uiWinY + 19) + 1
            IF trackHt < 1 THEN trackHt = 1
            thumbHt = CalcScrollThumbSize(clientHt, contBottom, trackHt, 16)
            thumbTopPos = CalcScrollThumbTop(uiScrollY, maxScrl, uiWinY + 19, trackHt, thumbHt)
            thumbBottomPos = thumbTopPos + thumbHt - 1
            Draw3DRect sbLeft + 1, thumbTopPos, sbRight - 1, thumbBottomPos, 1
        END IF
    END IF

    IF showHScroll <> 0 THEN
        DIM hTrackLeft AS INTEGER
        DIM hTrackRight AS INTEGER
        DIM hTrackW AS INTEGER
        DIM hThumbW AS INTEGER
        DIM hThumbLeft AS INTEGER
        DIM hThumbRight AS INTEGER
        hTrackLeft = uiWinX + 2
        hTrackRight = LayoutVisibleClientRight(showVScroll)
        hTrackW = hTrackRight - hTrackLeft + 1
        IF hTrackW < 1 THEN hTrackW = 1
        Draw3DRect hTrackLeft, uiWinY + uiWinH - 14, hTrackRight, uiWinY + uiWinH - 2, 0
        IF maxScrollX > 0 THEN
            hThumbW = CalcScrollThumbSize(clientW, contentW, hTrackW, 16)
            hThumbLeft = CalcScrollThumbTop(uiScrollX, maxScrollX, hTrackLeft, hTrackW, hThumbW)
            hThumbRight = hThumbLeft + hThumbW - 1
            Draw3DRect hThumbLeft, uiWinY + uiWinH - 13, hThumbRight, uiWinY + uiWinH - 3, 1
        END IF
    END IF

    IF uiResizable <> 0 AND titleIsMaximized = 0 THEN
        Draw3DRect sbLeft, uiWinY + uiWinH - 14, sbRight, uiWinY + uiWinH - 2, 0
        LINE (sbLeft + 6, uiWinY + uiWinH - 4)-(sbRight - 2, uiWinY + uiWinH - 8), COL_BEVEL_LO
        LINE (sbLeft + 4, uiWinY + uiWinH - 4)-(sbRight - 2, uiWinY + uiWinH - 10), COL_BEVEL_LO
        LINE (sbLeft + 2, uiWinY + uiWinH - 4)-(sbRight - 2, uiWinY + uiWinH - 12), COL_BEVEL_LO
    END IF
    END IF

    IF layoutDrawPass = 0 OR layoutDrawPass = 2 THEN
        DrawLayoutWindowOverlays activePage, uiWinX, uiWinY, uiWinX + uiWinW, uiWinY + uiWinH
    ELSEIF layoutDrawPass = 3 OR layoutDrawPass = 4 THEN
        DrawLayoutWindowOverlays activePage, clipL, clipT, clipR, clipB
    END IF
END SUB


' ---------------------------
' Layout window slots, z-order, focus, minimize, and close handling
' ---------------------------

SUB InitLayoutWindowSlot(BYVAL idx AS INTEGER, BYVAL appPath AS STRING, BYVAL titleText AS STRING)
    DIM j AS INTEGER
    DIM copyCount AS INTEGER
    DIM modalText AS STRING

    IF idx < LBOUND(layoutWindows) OR idx > UBOUND(layoutWindows) THEN EXIT SUB

    FreeLayoutWindowDrawCache idx
    FreeLayoutWindowStaticCache idx
    FreeLayoutWindowChromeCache idx
    FreeLayoutWindowElementCaches idx
    layoutDirtyVersion(idx) = 1
    layoutDrawCacheVersion(idx) = 0

    layoutWindows(idx).used = -1
    layoutWindows(idx).appPath = LEFT$(appPath, LEN(layoutWindows(idx).appPath))
    layoutWindows(idx).title = LEFT$(titleText, LEN(layoutWindows(idx).title))
    layoutWindows(idx).x = uiWinX
    layoutWindows(idx).y = uiWinY
    layoutWindows(idx).w = uiWinW
    layoutWindows(idx).h = uiWinH
    layoutWindows(idx).active = uiWindowActive
    layoutWindows(idx).selectedTab = uiSelectedTab
    layoutWindows(idx).pressedIndex = uiPressedIndex
    layoutWindows(idx).focusIndex = uiFocusIndex
    layoutWindows(idx).caretPos = uiCaretPos
    layoutWindows(idx).scrollY = uiScrollY
    layoutWindows(idx).scrollX = uiScrollX
    layoutWindows(idx).resizable = uiResizable

    ' Modal is an APP/SYS window property, not live control state.
    ' Cache it once here so mouse routing does not reread config on every modal check.
    modalText = UCASE$(TRIM$(AppCfgValue(appPath, "modal", "0")))
    layoutWindows(idx).modal = 0
    IF modalText = "1" OR modalText = "YES" OR modalText = "TRUE" THEN layoutWindows(idx).modal = -1

    layoutNoScrollbars(idx) = uiNoScrollbars
    layoutWindows(idx).minimized = 0
    layoutWindows(idx).maximized = 0
    layoutWindows(idx).restoreX = uiWinX
    layoutWindows(idx).restoreY = uiWinY
    layoutWindows(idx).restoreW = uiWinW
    layoutWindows(idx).restoreH = uiWinH
    layoutWindows(idx).designW = uiDesignW
    layoutWindows(idx).designH = uiDesignH
    layoutKeyAction(idx) = TRIM$(AppCfgValue(appPath, "KEY_ACTION", ""))
    layoutCtrlSAction(idx) = TRIM$(AppCfgValue(appPath, "CTRL_S_ACTION", ""))
    layoutTextSaveStatusControl(idx) = TRIM$(AppCfgValue(appPath, "TEXT_SAVE_STATUS_CONTROL", ""))
    comboOpenIndex(idx) = 0
    ClearLayoutDirtyElements idx

    copyCount = uiCount
    IF copyCount < 0 THEN copyCount = 0
    IF copyCount > 192 THEN copyCount = 192

    ' New window slots are already clear when they are free.
    ' Only initialize the controls this app actually loaded instead of
    ' resetting 192 slots and editor states on every window open.
    FOR j = 1 TO copyCount
        comboScrollTop(idx, j) = 0
        layoutListMultiSel(idx, j) = ""
        layoutListAnchorIdx(idx, j) = 0
        layoutDirectLabelLastWidth(idx, j) = 0
        layoutTextStatsCacheValid(idx, j) = 0
        layoutTextStatsCacheText(idx, j) = ""
    NEXT

    layoutUiCount(idx) = copyCount
    FOR j = 1 TO copyCount
        layoutUiElems(idx, j) = uiElems(j)
        layoutUiEdit(idx, j) = uiEdit(j)
        layoutUiSelAnchor(idx, j) = uiSelAnchor(j)
        layoutUiPrefCol(idx, j) = uiPrefCol(j)
        layoutUiWordSelMode(idx, j) = uiWordSelMode(j)
        layoutUiWordSelA(idx, j) = uiWordSelA(j)
        layoutUiWordSelB(idx, j) = uiWordSelB(j)
        layoutUiLineSelMode(idx, j) = uiLineSelMode(j)
        layoutUiLineSelA(idx, j) = uiLineSelA(j)
        layoutUiLineSelB(idx, j) = uiLineSelB(j)
    NEXT

    layoutNameCacheValid(idx) = 0
    SaveBindingSnapshotFromGlobals idx
    InvalidateTaskbarCache
END SUB

SUB SyncGlobalsFromLayoutWindow(BYVAL idx AS INTEGER)
    DIM j AS INTEGER
    DIM copyCount AS INTEGER
    DIM elemKind AS STRING

    IF idx < LBOUND(layoutWindows) OR idx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(idx).used = 0 THEN EXIT SUB

    uiWinX = layoutWindows(idx).x
    uiWinY = layoutWindows(idx).y
    uiWinW = layoutWindows(idx).w
    uiWinH = layoutWindows(idx).h
    uiDesignW = layoutWindows(idx).designW
    uiDesignH = layoutWindows(idx).designH
    uiTitle = RTRIM$(layoutWindows(idx).title)
    uiLayoutAppPath = RTRIM$(layoutWindows(idx).appPath)
    uiWindowActive = layoutWindows(idx).active
    uiSelectedTab = layoutWindows(idx).selectedTab
    uiPressedIndex = layoutWindows(idx).pressedIndex
    uiFocusIndex = layoutWindows(idx).focusIndex
    uiCaretPos = layoutWindows(idx).caretPos
    uiScrollY = layoutWindows(idx).scrollY
    uiScrollX = layoutWindows(idx).scrollX
    uiResizable = layoutWindows(idx).resizable
    uiNoScrollbars = layoutNoScrollbars(idx)

    copyCount = layoutUiCount(idx)
    IF copyCount < 0 THEN copyCount = 0
    IF copyCount > 192 THEN copyCount = 192
    uiCount = copyCount

    FOR j = 1 TO copyCount
        uiElems(j) = layoutUiElems(idx, j)
        elemKind = layoutUiElems(idx, j).kindKey
        IF elemKind = "TEXTBOX" THEN uiEdit(j) = layoutUiEdit(idx, j)
        uiSelAnchor(j) = layoutUiSelAnchor(idx, j)
        uiPrefCol(j) = layoutUiPrefCol(idx, j)
        uiWordSelMode(j) = layoutUiWordSelMode(idx, j)
        uiWordSelA(j) = layoutUiWordSelA(idx, j)
        uiWordSelB(j) = layoutUiWordSelB(idx, j)
        uiLineSelMode(j) = layoutUiLineSelMode(idx, j)
        uiLineSelA(j) = layoutUiLineSelA(idx, j)
        uiLineSelB(j) = layoutUiLineSelB(idx, j)
    NEXT

    uiNameCacheValid = 0
END SUB

SUB SyncLayoutWindowFromGlobals(BYVAL idx AS INTEGER)
    DIM j AS INTEGER
    DIM copyCount AS INTEGER
    DIM changed AS INTEGER
    DIM titleChanged AS INTEGER
    DIM nameCacheChanged AS INTEGER
    DIM elemKind AS STRING

    IF idx < LBOUND(layoutWindows) OR idx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(idx).used = 0 THEN EXIT SUB

    copyCount = uiCount
    IF copyCount < 0 THEN copyCount = 0
    IF copyCount > 192 THEN copyCount = 192

    changed = 0
    titleChanged = 0
    nameCacheChanged = 0
    IF layoutWindows(idx).x <> uiWinX THEN changed = -1
    IF layoutWindows(idx).y <> uiWinY THEN changed = -1
    IF layoutWindows(idx).w <> uiWinW THEN changed = -1
    IF layoutWindows(idx).h <> uiWinH THEN changed = -1
    IF layoutWindows(idx).designW <> uiDesignW THEN changed = -1
    IF layoutWindows(idx).designH <> uiDesignH THEN changed = -1
    IF RTRIM$(layoutWindows(idx).title) <> uiTitle THEN
        changed = -1
        titleChanged = -1
    END IF
    IF layoutWindows(idx).active <> uiWindowActive THEN changed = -1
    IF layoutWindows(idx).selectedTab <> uiSelectedTab THEN changed = -1
    IF layoutWindows(idx).pressedIndex <> uiPressedIndex THEN changed = -1
    IF layoutWindows(idx).scrollY <> uiScrollY THEN changed = -1
    IF layoutWindows(idx).scrollX <> uiScrollX THEN changed = -1
    IF layoutWindows(idx).resizable <> uiResizable THEN changed = -1
    IF layoutNoScrollbars(idx) <> uiNoScrollbars THEN changed = -1
    IF layoutUiCount(idx) <> copyCount THEN
        changed = -1
        nameCacheChanged = -1
    END IF

    layoutWindows(idx).x = uiWinX
    layoutWindows(idx).y = uiWinY
    layoutWindows(idx).w = uiWinW
    layoutWindows(idx).h = uiWinH
    layoutWindows(idx).designW = uiDesignW
    layoutWindows(idx).designH = uiDesignH
    layoutWindows(idx).title = LEFT$(uiTitle, LEN(layoutWindows(idx).title))
    layoutWindows(idx).active = uiWindowActive
    layoutWindows(idx).selectedTab = uiSelectedTab
    layoutWindows(idx).pressedIndex = uiPressedIndex
    layoutWindows(idx).scrollY = uiScrollY
    layoutWindows(idx).scrollX = uiScrollX
    layoutWindows(idx).resizable = uiResizable
    layoutNoScrollbars(idx) = uiNoScrollbars

    layoutUiCount(idx) = copyCount
    FOR j = 1 TO copyCount
        elemKind = uiElems(j).kindKey

        IF changed = 0 THEN
            IF layoutUiElems(idx, j).kind <> uiElems(j).kind THEN changed = -1
            IF layoutUiElems(idx, j).text <> uiElems(j).text THEN changed = -1
            IF layoutUiElems(idx, j).x <> uiElems(j).x THEN changed = -1
            IF layoutUiElems(idx, j).y <> uiElems(j).y THEN changed = -1
            IF layoutUiElems(idx, j).w <> uiElems(j).w THEN changed = -1
            IF layoutUiElems(idx, j).h <> uiElems(j).h THEN changed = -1
            IF layoutUiElems(idx, j).page <> uiElems(j).page THEN changed = -1
            IF layoutUiElems(idx, j).state <> uiElems(j).state THEN changed = -1
            IF layoutUiElems(idx, j).name <> uiElems(j).name THEN
                changed = -1
                nameCacheChanged = -1
            END IF
            IF layoutUiElems(idx, j).sourceDir <> uiElems(j).sourceDir THEN changed = -1
            IF layoutUiElems(idx, j).sourceMask <> uiElems(j).sourceMask THEN changed = -1
            IF layoutUiElems(idx, j).sourceControl <> uiElems(j).sourceControl THEN changed = -1
            IF layoutUiElems(idx, j).sourceItems <> uiElems(j).sourceItems THEN changed = -1
            IF layoutUiElems(idx, j).modeGroup <> uiElems(j).modeGroup THEN changed = -1
            IF layoutUiElems(idx, j).dropRows <> uiElems(j).dropRows THEN changed = -1
            IF layoutUiElems(idx, j).dropW <> uiElems(j).dropW THEN changed = -1
            IF layoutUiElems(idx, j).noEdit <> uiElems(j).noEdit THEN changed = -1
            IF layoutUiElems(idx, j).multiSelect <> uiElems(j).multiSelect THEN changed = -1
            IF layoutUiElems(idx, j).drawStyle <> uiElems(j).drawStyle THEN changed = -1
            IF layoutUiElems(idx, j).baseX <> uiElems(j).baseX THEN changed = -1
            IF layoutUiElems(idx, j).baseY <> uiElems(j).baseY THEN changed = -1
            IF layoutUiElems(idx, j).baseW <> uiElems(j).baseW THEN changed = -1
            IF layoutUiElems(idx, j).baseH <> uiElems(j).baseH THEN changed = -1
            IF layoutUiElems(idx, j).growW <> uiElems(j).growW THEN changed = -1
            IF layoutUiElems(idx, j).growH <> uiElems(j).growH THEN changed = -1
            IF layoutUiElems(idx, j).moveX <> uiElems(j).moveX THEN changed = -1
            IF layoutUiElems(idx, j).moveY <> uiElems(j).moveY THEN changed = -1
            IF layoutUiElems(idx, j).wordWrap <> uiElems(j).wordWrap THEN changed = -1

            IF layoutUiSelAnchor(idx, j) <> uiSelAnchor(j) THEN changed = -1
            IF layoutUiPrefCol(idx, j) <> uiPrefCol(j) THEN changed = -1
            IF layoutUiWordSelMode(idx, j) <> uiWordSelMode(j) THEN changed = -1
            IF layoutUiWordSelA(idx, j) <> uiWordSelA(j) THEN changed = -1
            IF layoutUiWordSelB(idx, j) <> uiWordSelB(j) THEN changed = -1
            IF layoutUiLineSelMode(idx, j) <> uiLineSelMode(j) THEN changed = -1
            IF layoutUiLineSelA(idx, j) <> uiLineSelA(j) THEN changed = -1
            IF layoutUiLineSelB(idx, j) <> uiLineSelB(j) THEN changed = -1

            IF elemKind = "TEXTBOX" THEN
                IF layoutUiEdit(idx, j).txtLen <> uiEdit(j).txtLen THEN changed = -1
                IF layoutUiEdit(idx, j).curPos <> uiEdit(j).curPos THEN changed = -1
                IF layoutUiEdit(idx, j).selA <> uiEdit(j).selA THEN changed = -1
                IF layoutUiEdit(idx, j).selB <> uiEdit(j).selB THEN changed = -1
                IF layoutUiEdit(idx, j).txt <> uiEdit(j).txt THEN changed = -1
            END IF
        END IF

        layoutUiElems(idx, j) = uiElems(j)
        IF elemKind = "TEXTBOX" THEN layoutUiEdit(idx, j) = uiEdit(j)
        layoutUiSelAnchor(idx, j) = uiSelAnchor(j)
        layoutUiPrefCol(idx, j) = uiPrefCol(j)
        layoutUiWordSelMode(idx, j) = uiWordSelMode(j)
        layoutUiWordSelA(idx, j) = uiWordSelA(j)
        layoutUiWordSelB(idx, j) = uiWordSelB(j)
        layoutUiLineSelMode(idx, j) = uiLineSelMode(j)
        layoutUiLineSelA(idx, j) = uiLineSelA(j)
        layoutUiLineSelB(idx, j) = uiLineSelB(j)
    NEXT

    IF titleChanged <> 0 THEN InvalidateTaskbarCache
    IF nameCacheChanged <> 0 THEN layoutNameCacheValid(idx) = 0
    IF changed <> 0 THEN MarkLayoutWindowDirty idx
END SUB

SUB SyncLayoutWindowScrollOnly(BYVAL idx AS INTEGER)
    DIM changed AS INTEGER

    ' Scrollbar drags and page-scroll clicks only move the window viewport.
    ' Do not compare and copy every control just to save scrollX/scrollY.
    IF idx < LBOUND(layoutWindows) OR idx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(idx).used = 0 THEN EXIT SUB

    changed = 0
    IF layoutWindows(idx).scrollX <> uiScrollX THEN changed = -1
    IF layoutWindows(idx).scrollY <> uiScrollY THEN changed = -1

    layoutWindows(idx).scrollX = uiScrollX
    layoutWindows(idx).scrollY = uiScrollY

    IF changed <> 0 THEN MarkLayoutWindowVisualDirty idx
END SUB

SUB SyncLayoutWindowPositionOnly(BYVAL idx AS INTEGER)
    DIM changed AS INTEGER

    ' Window dragging only changes screen position.
    ' Keep the full control array out of that mouse-move path.
    IF idx < LBOUND(layoutWindows) OR idx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(idx).used = 0 THEN EXIT SUB

    changed = 0
    IF layoutWindows(idx).x <> uiWinX THEN changed = -1
    IF layoutWindows(idx).y <> uiWinY THEN changed = -1

    layoutWindows(idx).x = uiWinX
    layoutWindows(idx).y = uiWinY

    IF changed <> 0 THEN MarkLayoutWindowVisualDirty idx
END SUB

SUB SyncLayoutWindowFocusOnly(BYVAL idx AS INTEGER)
    DIM changed AS INTEGER
    DIM oldFocus AS INTEGER
    DIM newFocus AS INTEGER

    ' Focus activation/deactivation changes window draw state, not the control tree.
    ' Keep the full element/text synchronization out of plain pointer focus transitions.
    IF idx < LBOUND(layoutWindows) OR idx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(idx).used = 0 THEN EXIT SUB

    oldFocus = layoutWindows(idx).focusIndex
    newFocus = uiFocusIndex
    changed = 0
    IF layoutWindows(idx).active <> uiWindowActive THEN changed = -1
    IF oldFocus <> newFocus THEN changed = -1
    IF layoutWindows(idx).caretPos <> uiCaretPos THEN changed = -1

    layoutWindows(idx).active = uiWindowActive
    layoutWindows(idx).focusIndex = newFocus
    layoutWindows(idx).caretPos = uiCaretPos

    IF changed <> 0 THEN
        IF oldFocus >= 1 AND oldFocus <= layoutUiCount(idx) THEN MarkLayoutDirtyElement idx, oldFocus
        IF newFocus >= 1 AND newFocus <= layoutUiCount(idx) AND newFocus <> oldFocus THEN MarkLayoutDirtyElement idx, newFocus
        MarkLayoutWindowVisualDirty idx
    END IF
END SUB

SUB SyncLayoutWindowResizeOnly(BYVAL idx AS INTEGER)
    DIM changed AS INTEGER

    ' Live resize already updates moved/grown controls inside ApplyLayoutAutoFit.
    ' Save only window geometry and viewport state here.
    IF idx < LBOUND(layoutWindows) OR idx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(idx).used = 0 THEN EXIT SUB

    changed = 0
    IF layoutWindows(idx).x <> uiWinX THEN changed = -1
    IF layoutWindows(idx).y <> uiWinY THEN changed = -1
    IF layoutWindows(idx).w <> uiWinW THEN changed = -1
    IF layoutWindows(idx).h <> uiWinH THEN changed = -1
    IF layoutWindows(idx).designW <> uiDesignW THEN changed = -1
    IF layoutWindows(idx).designH <> uiDesignH THEN changed = -1
    IF layoutWindows(idx).scrollX <> uiScrollX THEN changed = -1
    IF layoutWindows(idx).scrollY <> uiScrollY THEN changed = -1

    layoutWindows(idx).x = uiWinX
    layoutWindows(idx).y = uiWinY
    layoutWindows(idx).w = uiWinW
    layoutWindows(idx).h = uiWinH
    layoutWindows(idx).designW = uiDesignW
    layoutWindows(idx).designH = uiDesignH
    layoutWindows(idx).scrollX = uiScrollX
    layoutWindows(idx).scrollY = uiScrollY

    IF changed <> 0 THEN MarkLayoutWindowVisualDirty idx
END SUB

SUB SyncLayoutWindowPressedOnly(BYVAL idx AS INTEGER)
    DIM changed AS INTEGER
    DIM oldPressed AS INTEGER
    DIM newPressed AS INTEGER

    ' Mouse-release cleanup only clears the depressed control state.
    ' Do not rescan/copy the active control tree to persist that flag.
    IF idx < LBOUND(layoutWindows) OR idx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(idx).used = 0 THEN EXIT SUB

    oldPressed = layoutWindows(idx).pressedIndex
    newPressed = uiPressedIndex
    changed = 0
    IF oldPressed <> newPressed THEN changed = -1

    layoutWindows(idx).pressedIndex = newPressed

    IF changed <> 0 THEN
        IF oldPressed >= 1 AND oldPressed <= layoutUiCount(idx) THEN MarkLayoutDirtyElement idx, oldPressed
        IF newPressed >= 1 AND newPressed <= layoutUiCount(idx) AND newPressed <> oldPressed THEN MarkLayoutDirtyElement idx, newPressed
        MarkLayoutWindowVisualDirty idx
    END IF
END SUB

SUB SyncLayoutWindowElementOnly(BYVAL idx AS INTEGER, BYVAL elemIdx AS INTEGER)
    DIM oldFocus AS INTEGER
    DIM oldPressed AS INTEGER
    DIM newFocus AS INTEGER
    DIM newPressed AS INTEGER
    DIM copyCount AS INTEGER
    DIM elemKind AS STRING
    DIM structural AS INTEGER
    DIM titleChanged AS INTEGER

    ' Persist one changed control from the active globals back into its window slot.
    ' This keeps ordinary combo/list/focus edits out of the 192-control deep sync path.
    IF idx < LBOUND(layoutWindows) OR idx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(idx).used = 0 THEN EXIT SUB
    IF elemIdx < 1 OR elemIdx > 192 THEN EXIT SUB

    copyCount = uiCount
    IF copyCount < 0 THEN copyCount = 0
    IF copyCount > 192 THEN copyCount = 192
    IF elemIdx > copyCount THEN EXIT SUB

    IF layoutUiCount(idx) <> copyCount THEN
        SyncLayoutWindowFromGlobals idx
        EXIT SUB
    END IF

    IF layoutWindows(idx).x <> uiWinX OR layoutWindows(idx).y <> uiWinY OR _
       layoutWindows(idx).w <> uiWinW OR layoutWindows(idx).h <> uiWinH OR _
       layoutWindows(idx).designW <> uiDesignW OR layoutWindows(idx).designH <> uiDesignH OR _
       layoutWindows(idx).resizable <> uiResizable OR layoutNoScrollbars(idx) <> uiNoScrollbars THEN
        SyncLayoutWindowFromGlobals idx
        EXIT SUB
    END IF

    oldFocus = layoutWindows(idx).focusIndex
    oldPressed = layoutWindows(idx).pressedIndex
    newFocus = uiFocusIndex
    newPressed = uiPressedIndex
    titleChanged = 0
    IF RTRIM$(layoutWindows(idx).title) <> uiTitle THEN titleChanged = -1

    layoutWindows(idx).title = LEFT$(uiTitle, LEN(layoutWindows(idx).title))
    layoutWindows(idx).active = uiWindowActive
    layoutWindows(idx).selectedTab = uiSelectedTab
    layoutWindows(idx).pressedIndex = newPressed
    layoutWindows(idx).focusIndex = newFocus
    layoutWindows(idx).caretPos = uiCaretPos
    layoutWindows(idx).scrollY = uiScrollY
    layoutWindows(idx).scrollX = uiScrollX

    elemKind = uiElems(elemIdx).kindKey
    structural = 0
    IF layoutUiElems(idx, elemIdx).kind <> uiElems(elemIdx).kind THEN structural = -1
    IF layoutUiElems(idx, elemIdx).x <> uiElems(elemIdx).x THEN structural = -1
    IF layoutUiElems(idx, elemIdx).y <> uiElems(elemIdx).y THEN structural = -1
    IF layoutUiElems(idx, elemIdx).w <> uiElems(elemIdx).w THEN structural = -1
    IF layoutUiElems(idx, elemIdx).h <> uiElems(elemIdx).h THEN structural = -1
    IF layoutUiElems(idx, elemIdx).page <> uiElems(elemIdx).page THEN structural = -1
    IF layoutUiElems(idx, elemIdx).name <> uiElems(elemIdx).name THEN
        structural = -1
        layoutNameCacheValid(idx) = 0
    END IF
    IF layoutUiElems(idx, elemIdx).baseX <> uiElems(elemIdx).baseX THEN structural = -1
    IF layoutUiElems(idx, elemIdx).baseY <> uiElems(elemIdx).baseY THEN structural = -1
    IF layoutUiElems(idx, elemIdx).baseW <> uiElems(elemIdx).baseW THEN structural = -1
    IF layoutUiElems(idx, elemIdx).baseH <> uiElems(elemIdx).baseH THEN structural = -1
    IF layoutUiElems(idx, elemIdx).growW <> uiElems(elemIdx).growW THEN structural = -1
    IF layoutUiElems(idx, elemIdx).growH <> uiElems(elemIdx).growH THEN structural = -1
    IF layoutUiElems(idx, elemIdx).moveX <> uiElems(elemIdx).moveX THEN structural = -1
    IF layoutUiElems(idx, elemIdx).moveY <> uiElems(elemIdx).moveY THEN structural = -1

    layoutUiElems(idx, elemIdx) = uiElems(elemIdx)
    IF elemKind = "TEXTBOX" THEN layoutUiEdit(idx, elemIdx) = uiEdit(elemIdx)
    layoutUiSelAnchor(idx, elemIdx) = uiSelAnchor(elemIdx)
    layoutUiPrefCol(idx, elemIdx) = uiPrefCol(elemIdx)
    layoutUiWordSelMode(idx, elemIdx) = uiWordSelMode(elemIdx)
    layoutUiWordSelA(idx, elemIdx) = uiWordSelA(elemIdx)
    layoutUiWordSelB(idx, elemIdx) = uiWordSelB(elemIdx)
    layoutUiLineSelMode(idx, elemIdx) = uiLineSelMode(elemIdx)
    layoutUiLineSelA(idx, elemIdx) = uiLineSelA(elemIdx)
    layoutUiLineSelB(idx, elemIdx) = uiLineSelB(elemIdx)

    IF titleChanged <> 0 THEN InvalidateTaskbarCache

    IF structural <> 0 THEN
        MarkLayoutWindowDirty idx
    ELSE
        IF oldFocus >= 1 AND oldFocus <= layoutUiCount(idx) AND oldFocus <> elemIdx THEN MarkLayoutDirtyElement idx, oldFocus
        IF newFocus >= 1 AND newFocus <= layoutUiCount(idx) AND newFocus <> elemIdx AND newFocus <> oldFocus THEN MarkLayoutDirtyElement idx, newFocus
        IF oldPressed >= 1 AND oldPressed <= layoutUiCount(idx) AND oldPressed <> elemIdx THEN MarkLayoutDirtyElement idx, oldPressed
        IF newPressed >= 1 AND newPressed <= layoutUiCount(idx) AND newPressed <> elemIdx AND newPressed <> oldPressed THEN MarkLayoutDirtyElement idx, newPressed
        MarkLayoutDirtyElement idx, elemIdx
        MarkLayoutWindowVisualDirty idx
    END IF
END SUB


SUB SaveActiveTextboxDrawStateToWindow(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER)
    ' Typing redraws only need current draw state, not a full EDSTATE copy.
    ' Keep undo/history strings out of the per-keystroke hot path.
    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(winIdx).used = 0 THEN EXIT SUB
    IF elemIdx < 1 OR elemIdx > uiCount THEN EXIT SUB
    IF uiElems(elemIdx).kindKey <> "TEXTBOX" THEN EXIT SUB

    layoutWindows(winIdx).focusIndex = uiFocusIndex
    layoutWindows(winIdx).caretPos = uiCaretPos
    layoutUiElems(winIdx, elemIdx) = uiElems(elemIdx)
    layoutUiEdit(winIdx, elemIdx).txt = uiEdit(elemIdx).txt
    layoutUiEdit(winIdx, elemIdx).txtLen = uiEdit(elemIdx).txtLen
    layoutUiEdit(winIdx, elemIdx).curPos = uiEdit(elemIdx).curPos
    layoutUiEdit(winIdx, elemIdx).selA = uiEdit(elemIdx).selA
    layoutUiEdit(winIdx, elemIdx).selB = uiEdit(elemIdx).selB
    layoutUiEdit(winIdx, elemIdx).insertMode = uiEdit(elemIdx).insertMode
    layoutUiPrefCol(winIdx, elemIdx) = uiPrefCol(elemIdx)
END SUB


SUB SaveActiveTextboxSelectionStateToWindow(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER)
    ' Mouse clicks and drags do not change textbox text.
    ' Save only focus/caret/selection state so pointer handling never copies the full file.
    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(winIdx).used = 0 THEN EXIT SUB
    IF elemIdx < 1 OR elemIdx > uiCount THEN EXIT SUB
    IF uiElems(elemIdx).kindKey <> "TEXTBOX" THEN EXIT SUB

    layoutWindows(winIdx).focusIndex = uiFocusIndex
    layoutWindows(winIdx).caretPos = uiCaretPos
    layoutUiSelAnchor(winIdx, elemIdx) = uiSelAnchor(elemIdx)
    layoutUiPrefCol(winIdx, elemIdx) = uiPrefCol(elemIdx)
    layoutUiWordSelMode(winIdx, elemIdx) = uiWordSelMode(elemIdx)
    layoutUiWordSelA(winIdx, elemIdx) = uiWordSelA(elemIdx)
    layoutUiWordSelB(winIdx, elemIdx) = uiWordSelB(elemIdx)
    layoutUiLineSelMode(winIdx, elemIdx) = uiLineSelMode(elemIdx)
    layoutUiLineSelA(winIdx, elemIdx) = uiLineSelA(elemIdx)
    layoutUiLineSelB(winIdx, elemIdx) = uiLineSelB(elemIdx)
    layoutUiEdit(winIdx, elemIdx).curPos = uiEdit(elemIdx).curPos
    layoutUiEdit(winIdx, elemIdx).selA = uiEdit(elemIdx).selA
    layoutUiEdit(winIdx, elemIdx).selB = uiEdit(elemIdx).selB
END SUB


SUB SaveBindingSnapshotFromGlobals(BYVAL idx AS INTEGER)
    DIM j AS INTEGER
    DIM copyCount AS INTEGER
    DIM oldCount AS INTEGER

    IF idx < LBOUND(layoutWindows) OR idx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(idx).used = 0 THEN EXIT SUB

    copyCount = uiCount
    IF copyCount < 0 THEN copyCount = 0
    IF copyCount > 192 THEN copyCount = 192

    oldCount = layoutBindInitCount(idx)
    IF oldCount < 0 THEN oldCount = 0
    IF oldCount > 192 THEN oldCount = 192

    layoutBindInitCount(idx) = copyCount
    FOR j = 1 TO copyCount
        layoutBindInitText(idx, j) = uiElems(j).text
        layoutBindInitState(idx, j) = uiElems(j).state
    NEXT

    FOR j = copyCount + 1 TO oldCount
        layoutBindInitText(idx, j) = ""
        layoutBindInitState(idx, j) = 0
    NEXT
END SUB

SUB RestoreBindingSnapshotToGlobals(BYVAL idx AS INTEGER)
    DIM j AS INTEGER
    DIM copyCount AS INTEGER

    IF idx < LBOUND(layoutWindows) OR idx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(idx).used = 0 THEN EXIT SUB

    copyCount = layoutBindInitCount(idx)
    IF copyCount < 0 THEN copyCount = 0
    IF copyCount > 192 THEN copyCount = 192

    uiCount = copyCount
    FOR j = 1 TO copyCount
        uiElems(j).text = layoutBindInitText(idx, j)
        uiElems(j).state = layoutBindInitState(idx, j)
    NEXT
END SUB


SUB InitLayoutZOrder()
    DIM i AS INTEGER
    FOR i = LBOUND(layoutZOrder) TO UBOUND(layoutZOrder)
        layoutZOrder(i) = 0
    NEXT
END SUB

SUB MoveLayoutWindowToFront(BYVAL idx AS INTEGER)
    DIM zPos AS INTEGER
    DIM i AS INTEGER

    zPos = 0

    FOR i = LBOUND(layoutZOrder) TO UBOUND(layoutZOrder)
        IF layoutZOrder(i) = idx THEN
            zPos = i
            EXIT FOR
        END IF
    NEXT

    IF zPos = 0 THEN
        FOR i = LBOUND(layoutZOrder) TO UBOUND(layoutZOrder)
            IF layoutZOrder(i) = 0 THEN
                zPos = i
                EXIT FOR
            END IF
        NEXT
        IF zPos = 0 THEN zPos = UBOUND(layoutZOrder)
        layoutZOrder(zPos) = idx
    END IF

    FOR i = zPos TO UBOUND(layoutZOrder) - 1
        layoutZOrder(i) = layoutZOrder(i + 1)
    NEXT

    layoutZOrder(UBOUND(layoutZOrder)) = idx
END SUB

FUNCTION LayoutAltTabDown() AS INTEGER
    IF (MULTIKEY(56) OR MULTIKEY(184)) AND MULTIKEY(15) THEN RETURN -1
    RETURN 0
END FUNCTION

FUNCTION LayoutAltTabCycle() AS INTEGER
    DIM z AS INTEGER
    DIM i AS INTEGER
    DIM winIdx AS INTEGER
    DIM activeZ AS INTEGER
    DIM targetIdx AS INTEGER
    DIM usedCount AS INTEGER
    DIM modalIdx AS INTEGER

    LayoutAltTabCycle = 0

    usedCount = 0
    FOR i = LBOUND(layoutWindows) TO UBOUND(layoutWindows)
        IF layoutWindows(i).used <> 0 THEN usedCount = usedCount + 1
    NEXT
    IF usedCount <= 1 THEN EXIT FUNCTION

    modalIdx = TopModalLayoutWindow()
    IF modalIdx <> 0 THEN
        IF activeLayoutWindow <> modalIdx OR layoutWindows(modalIdx).minimized <> 0 THEN
            IF layoutWindows(modalIdx).minimized <> 0 THEN
                RestoreLayoutWindow modalIdx
            ELSE
                ActivateLayoutWindow modalIdx
            END IF
            LayoutAltTabCycle = -1
        END IF
        EXIT FUNCTION
    END IF

    activeZ = 0
    FOR z = LBOUND(layoutZOrder) TO UBOUND(layoutZOrder)
        IF layoutZOrder(z) = activeLayoutWindow THEN
            activeZ = z
            EXIT FOR
        END IF
    NEXT

    targetIdx = 0
    IF activeZ > 0 THEN
        FOR z = activeZ - 1 TO LBOUND(layoutZOrder) STEP -1
            winIdx = layoutZOrder(z)
            IF winIdx >= LBOUND(layoutWindows) AND winIdx <= UBOUND(layoutWindows) THEN
                IF layoutWindows(winIdx).used <> 0 THEN
                    targetIdx = winIdx
                    EXIT FOR
                END IF
            END IF
        NEXT

        IF targetIdx = 0 THEN
            FOR z = UBOUND(layoutZOrder) TO activeZ + 1 STEP -1
                winIdx = layoutZOrder(z)
                IF winIdx >= LBOUND(layoutWindows) AND winIdx <= UBOUND(layoutWindows) THEN
                    IF layoutWindows(winIdx).used <> 0 THEN
                        targetIdx = winIdx
                        EXIT FOR
                    END IF
                END IF
            NEXT
        END IF
    ELSE
        FOR z = UBOUND(layoutZOrder) TO LBOUND(layoutZOrder) STEP -1
            winIdx = layoutZOrder(z)
            IF winIdx >= LBOUND(layoutWindows) AND winIdx <= UBOUND(layoutWindows) THEN
                IF layoutWindows(winIdx).used <> 0 THEN
                    targetIdx = winIdx
                    EXIT FOR
                END IF
            END IF
        NEXT
    END IF

    IF targetIdx = 0 THEN
        FOR i = LBOUND(layoutWindows) TO UBOUND(layoutWindows)
            IF layoutWindows(i).used <> 0 AND i <> activeLayoutWindow THEN
                targetIdx = i
                EXIT FOR
            END IF
        NEXT
    END IF

    IF targetIdx = 0 OR targetIdx = activeLayoutWindow THEN EXIT FUNCTION

    ' Alt-Tab uses the same activation path as the taskbar.
    IF layoutWindows(targetIdx).minimized <> 0 THEN
        RestoreLayoutWindow targetIdx
    ELSE
        ActivateLayoutWindow targetIdx
    END IF

    LayoutAltTabCycle = -1
END FUNCTION

FUNCTION FindLayoutWindowByAppPath(BYVAL appPath AS STRING) AS INTEGER
    DIM i AS INTEGER
    DIM targetPath AS STRING

    targetPath = UCASE$(NormalizePath(TRIM$(appPath)))
    IF targetPath = "" THEN RETURN 0

    FOR i = LBOUND(layoutWindows) TO UBOUND(layoutWindows)
        IF layoutWindows(i).used <> 0 THEN
            IF UCASE$(NormalizePath(RTRIM$(layoutWindows(i).appPath))) = targetPath THEN RETURN i
        END IF
    NEXT

    RETURN 0
END FUNCTION

SUB ActivateLayoutWindow(BYVAL winIdx AS INTEGER)
    DIM i AS INTEGER

    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(winIdx).used = 0 THEN EXIT SUB
    IF layoutWindows(winIdx).minimized <> 0 THEN
        layoutWindows(winIdx).minimized = 0
        InvalidateTaskbarCache
    END IF

    ' Re-activating the window that is already active must stay cheap.
    ' The globals already belong to this window, so a full sync/reload is wasted work.
    IF winIdx = activeLayoutWindow THEN
        layoutWindows(winIdx).active = -1
        MoveLayoutWindowToFront winIdx
        InvalidateTaskbarCache
        EXIT SUB
    END IF

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN SyncLayoutWindowFromGlobals activeLayoutWindow
    END IF

    FOR i = LBOUND(layoutWindows) TO UBOUND(layoutWindows)
        IF layoutWindows(i).used <> 0 THEN layoutWindows(i).active = 0
    NEXT

    activeLayoutWindow = winIdx
    layoutWindows(activeLayoutWindow).active = -1
    MoveLayoutWindowToFront activeLayoutWindow
    FreeInactiveLayoutWindowCaches activeLayoutWindow
    SyncGlobalsFromLayoutWindow activeLayoutWindow
    InvalidateTaskbarCache
END SUB


SUB ClearLayoutWindowTempBindFiles(BYVAL idx AS INTEGER)
    DIM i AS INTEGER
    DIM bindPath AS STRING

    IF idx < LBOUND(layoutWindows) OR idx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(idx).used = 0 THEN EXIT SUB

    FOR i = 1 TO 192
        bindPath = ResolveAppLocalPath(idx, TRIM$(layoutUiElems(idx, i).bindFile))
        IF bindPath <> "" THEN
            IF UCASE$(FileExtensionOf(bindPath)) = "TMP" THEN
                IF INSTR(bindPath, "*") = 0 AND INSTR(bindPath, "?") = 0 THEN
                    IF DIR(bindPath) <> "" THEN KILL bindPath
                END IF
            END IF
        END IF
    NEXT
END SUB


SUB MarkLayoutTextSavedBaseline(BYVAL winIdx AS INTEGER, BYVAL textControlName AS STRING, BYVAL fileControlName AS STRING)
    DIM textIdx AS INTEGER
    DIM fileIdx AS INTEGER
    DIM savedText AS STRING

    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(winIdx).used = 0 THEN EXIT SUB

    textIdx = LayoutControlIndexByName(winIdx, textControlName)
    IF textIdx >= 1 AND textIdx <= layoutUiCount(winIdx) THEN
        IF winIdx = activeLayoutWindow THEN
            savedText = GetTextboxTextByName(textControlName)
            layoutUiElems(winIdx, textIdx) = uiElems(textIdx)
            layoutUiEdit(winIdx, textIdx) = uiEdit(textIdx)
        ELSE
            savedText = Ed_GetTextGlue(layoutUiEdit(winIdx, textIdx), layoutUiElems(winIdx, textIdx).text)
        END IF
        layoutBindInitText(winIdx, textIdx) = savedText
    END IF

    fileIdx = LayoutControlIndexByName(winIdx, fileControlName)
    IF fileIdx >= 1 AND fileIdx <= layoutUiCount(winIdx) THEN
        IF winIdx = activeLayoutWindow THEN
            layoutBindInitText(winIdx, fileIdx) = uiElems(fileIdx).text
            layoutUiElems(winIdx, fileIdx) = uiElems(fileIdx)
        ELSE
            layoutBindInitText(winIdx, fileIdx) = layoutUiElems(winIdx, fileIdx).text
        END IF
    END IF
END SUB

FUNCTION LayoutWindowUnsavedTextDirty(BYVAL idx AS INTEGER) AS INTEGER
    DIM textControlName AS STRING
    DIM textIdx AS INTEGER
    DIM currentText AS STRING
    DIM savedText AS STRING

    LayoutWindowUnsavedTextDirty = 0
    IF idx < LBOUND(layoutWindows) OR idx > UBOUND(layoutWindows) THEN RETURN 0
    IF layoutWindows(idx).used = 0 THEN RETURN 0

    textControlName = TRIM$(AppCfgValue(RTRIM$(layoutWindows(idx).appPath), "UNSAVED_TEXT_CONTROL", ""))
    IF textControlName = "" THEN RETURN 0

    IF idx = activeLayoutWindow THEN SyncLayoutWindowFromGlobals idx

    textIdx = LayoutControlIndexByName(idx, textControlName)
    IF textIdx < 1 OR textIdx > layoutUiCount(idx) THEN RETURN 0
    IF layoutUiElems(idx, textIdx).kindId <> UI_KIND_TEXTBOX THEN RETURN 0

    currentText = Ed_GetTextGlue(layoutUiEdit(idx, textIdx), layoutUiElems(idx, textIdx).text)
    savedText = layoutBindInitText(idx, textIdx)
    IF currentText <> savedText THEN LayoutWindowUnsavedTextDirty = -1
END FUNCTION

FUNCTION RequestLayoutWindowClose(BYVAL idx AS INTEGER) AS INTEGER
    DIM textControlName AS STRING
    DIM fileControlName AS STRING
    DIM saveActionText AS STRING
    DIM messageText AS STRING
    DIM titleText AS STRING
    DIM choice AS INTEGER
    DIM textIdx AS INTEGER
    DIM fileIdx AS INTEGER
    DIM fileName AS STRING
    DIM dataText AS STRING
    DIM saveStatusControlName AS STRING

    RequestLayoutWindowClose = 0
    IF idx < LBOUND(layoutWindows) OR idx > UBOUND(layoutWindows) THEN RETURN 0
    IF layoutWindows(idx).used = 0 THEN RETURN 0

    IF LayoutWindowUnsavedTextDirty(idx) = 0 THEN
        CloseLayoutWindow idx
        RequestLayoutWindowClose = -1
        RETURN -1
    END IF

    textControlName = TRIM$(AppCfgValue(RTRIM$(layoutWindows(idx).appPath), "UNSAVED_TEXT_CONTROL", ""))
    fileControlName = TRIM$(AppCfgValue(RTRIM$(layoutWindows(idx).appPath), "UNSAVED_FILE_CONTROL", ""))
    saveActionText = TRIM$(AppCfgValue(RTRIM$(layoutWindows(idx).appPath), "UNSAVED_SAVE_ACTION", ""))
    messageText = TRIM$(AppCfgValue(RTRIM$(layoutWindows(idx).appPath), "UNSAVED_MESSAGE", "You have not saved your file"))
    titleText = TRIM$(AppCfgValue(RTRIM$(layoutWindows(idx).appPath), "UNSAVED_TITLE", RTRIM$(layoutWindows(idx).title)))
    IF titleText = "" THEN titleText = "Confirm"

    ' Unsaved text close uses a three-choice prompt so close is never destructive by default.
    choice = ShowGuiThreeButtonBox(titleText, messageText, "Save", "Don't Save", "Cancel")

    SELECT CASE choice
    CASE 1
        IF idx = activeLayoutWindow THEN SyncLayoutWindowFromGlobals idx
        textIdx = LayoutControlIndexByName(idx, textControlName)
        fileIdx = LayoutControlIndexByName(idx, fileControlName)
        fileName = ""
        IF fileIdx >= 1 AND fileIdx <= layoutUiCount(idx) THEN fileName = NormalizePath(TRIM$(layoutUiElems(idx, fileIdx).text))

        IF fileName = "" THEN
            IF saveActionText <> "" THEN HostAppAction idx, saveActionText
            RETURN 0
        END IF

        IF textIdx >= 1 AND textIdx <= layoutUiCount(idx) THEN
            dataText = Ed_GetTextGlue(layoutUiEdit(idx, textIdx), layoutUiElems(idx, textIdx).text)
            IF WriteTextFileRaw(ResolveAppLocalPath(idx, fileName), dataText) <> 0 THEN
                MarkLayoutTextSavedBaseline idx, textControlName, fileControlName
                saveStatusControlName = TRIM$(layoutTextSaveStatusControl(idx))
                IF saveStatusControlName <> "" THEN
                    IF idx = activeLayoutWindow THEN
                        SetControlTextByNameAny saveStatusControlName, FileNameOnly(fileName) + " saved"
                        SyncLayoutWindowFromGlobals idx
                    END IF
                END IF
                CloseLayoutWindow idx
                RequestLayoutWindowClose = -1
                RETURN -1
            ELSE
                ShowGuiMessageBox "Save Failed", fileName
                RETURN 0
            END IF
        END IF

    CASE 2
        CloseLayoutWindow idx
        RequestLayoutWindowClose = -1
        RETURN -1
    END SELECT

    RETURN 0
END FUNCTION

SUB CloseLayoutWindow(BYVAL idx AS INTEGER)
    DIM i AS INTEGER
    DIM found AS INTEGER

    IF idx < LBOUND(layoutWindows) OR idx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(idx).used = 0 THEN EXIT SUB

    IF bdbgEnabled <> 0 THEN BDbgWindowEvent "CLOSE_BEGIN", idx
    IF bdbgEnabled <> 0 THEN BDbgWindowEvent "CLOSE_BEFORE_FREE_CACHES", idx
    FreeLayoutWindowDrawCache idx
    FreeLayoutWindowStaticCache idx
    FreeLayoutWindowChromeCache idx
    FreeLayoutWindowElementCaches idx
    InvalidateLayoutContentExtentsCache idx
    layoutDirtyVersion(idx) = 0
    IF bdbgEnabled <> 0 THEN BDbgWindowEvent "CLOSE_AFTER_FREE_CACHES", idx
    IF bdbgEnabled <> 0 THEN BDbgWindowEvent "CLOSE_BEFORE_TEMP_BINDS", idx
    ClearLayoutWindowTempBindFiles idx
    IF bdbgEnabled <> 0 THEN BDbgWindowEvent "CLOSE_AFTER_TEMP_BINDS", idx

    IF scriptPreviewBindCacheWin = idx THEN
        FreeScriptPreviewCache
        ClearScriptPreviewBindCache
    END IF

    IF ctxMenuCfgOwnerWin = idx THEN
        ctxMenuCfgReady = 0
        ctxMenuCfgOwnerWin = 0
        ctxMenuCfgAppPath = ""
        ctxMenuCfgOpenText = ""
        ctxMenuCfgDirOpenText = ""
        ctxMenuCfgNewDirText = ""
