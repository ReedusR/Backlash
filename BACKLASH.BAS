SUB DrawGuiTextInputBox(BYVAL titleText AS STRING, BYVAL msgText AS STRING, BYVAL inputText AS STRING, BYVAL boxX1 AS INTEGER, BYVAL boxY1 AS INTEGER, BYVAL boxX2 AS INTEGER, BYVAL boxY2 AS INTEGER, BYVAL okPressed AS INTEGER, BYVAL cancelPressed AS INTEGER, BYVAL closePressed AS INTEGER)
    DIM okX1 AS INTEGER
    DIM okY1 AS INTEGER
    DIM okX2 AS INTEGER
    DIM okY2 AS INTEGER
    DIM cancelX1 AS INTEGER
    DIM cancelY1 AS INTEGER
    DIM cancelX2 AS INTEGER
    DIM cancelY2 AS INTEGER
    DIM inputX1 AS INTEGER
    DIM inputY1 AS INTEGER
    DIM inputX2 AS INTEGER
    DIM inputY2 AS INTEGER
    DIM drawText AS STRING
    DIM maxChars AS INTEGER
    DIM msgWork AS STRING

    DrawBevelBox boxX1, boxY1, boxX2, boxY2, 0
    LINE (boxX1 + 2, boxY1 + 20)-(boxX2 - 2, boxY2 - 2), COL_CONTROL_BG, BF
    DrawThemedTitleBar boxX1 + 1, boxY1 + 1, boxX2 - 1, boxY1 + 18, -1

    IF TRIM$(titleText) <> "" THEN
        DRAW STRING (boxX1 + 8, boxY1 + 6), LEFT$(TRIM$(titleText), 36), COL_TEXT_INV
    ELSE
        DRAW STRING (boxX1 + 8, boxY1 + 6), "Input", COL_TEXT_INV
    END IF

    DrawBevelBox boxX2 - 18, boxY1 + 3, boxX2 - 4, boxY1 + 17, closePressed
    DrawCloseGlyph boxX2 - 18, boxY1 + 3, boxX2 - 4, boxY1 + 17

    msgWork = LEFT$(TRIM$(msgText), 38)
    IF msgWork <> "" THEN DRAW STRING (boxX1 + 18, boxY1 + 40), msgWork, COL_TEXT

    inputX1 = boxX1 + 18
    inputY1 = boxY1 + 62
    inputX2 = boxX2 - 18
    inputY2 = inputY1 + 22

    DrawBevelBox inputX1, inputY1, inputX2, inputY2, 0
    LINE (inputX1 + 2, inputY1 + 2)-(inputX2 - 2, inputY2 - 2), COL_CONTROL_BG, BF
    maxChars = (inputX2 - inputX1 - 10) \ 8
    drawText = inputText
    IF LEN(drawText) > maxChars THEN drawText = RIGHT$(drawText, maxChars)
    IF drawText <> "" THEN DRAW STRING (inputX1 + 5, inputY1 + 7), drawText, COL_TEXT
    LINE (inputX1 + 5 + LEN(drawText) * 8, inputY1 + 6)-(inputX1 + 5 + LEN(drawText) * 8, inputY1 + 15), COL_TEXT

