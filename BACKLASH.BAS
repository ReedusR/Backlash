                        oldStartPressed = -1
                    ELSEIF smx >= layoutWindows(hitSlot).x + layoutWindows(hitSlot).w - 19 AND _
                       smx <= layoutWindows(hitSlot).x + layoutWindows(hitSlot).w - 3 AND _
                       smy >= layoutWindows(hitSlot).y + 2 AND _
