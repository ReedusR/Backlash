SUB InvalidateLayoutContentExtentsCache(BYVAL winIdx AS INTEGER)
    ' Content size only changes when the layout changes, so this cache can stay quiet during ordinary redraws.
    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB

    layoutContentCacheValid(winIdx) = 0
    layoutContentCacheW(winIdx) = 0
    layoutContentCacheH(winIdx) = 0
    layoutContentCacheVersion(winIdx) = 0
    layoutContentCacheTab(winIdx) = 0
    layoutContentCacheCount(winIdx) = 0
    layoutContentCachePage(winIdx) = ""
END SUB

SUB MarkLayoutWindowDirty(BYVAL winIdx AS INTEGER)
    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB

    layoutDirtyVersion(winIdx) = layoutDirtyVersion(winIdx) + 1
    IF layoutDirtyVersion(winIdx) > 1000000000 THEN layoutDirtyVersion(winIdx) = 1
    layoutDrawCacheValid(winIdx) = 0
    layoutStaticCacheValid(winIdx) = 0
    InvalidateLayoutContentExtentsCache winIdx
END SUB

SUB MarkLayoutWindowVisualDirty(BYVAL winIdx AS INTEGER)
    ' Visual-only changes invalidate the full-window image, but they no longer
    ' advance the structural version that every cached element depends on.
    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB

    layoutDrawCacheValid(winIdx) = 0
END SUB

SUB AdvanceLayoutElementVisualVersion(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER)
    IF winIdx < 1 OR winIdx > 12 THEN EXIT SUB
    IF elemIdx < 1 OR elemIdx > 192 THEN EXIT SUB

    layoutElemDirtyVersion(winIdx, elemIdx) = layoutElemDirtyVersion(winIdx, elemIdx) + 1
    IF layoutElemDirtyVersion(winIdx, elemIdx) > 1000000000 THEN layoutElemDirtyVersion(winIdx, elemIdx) = 1
    layoutElemDrawCacheValid(winIdx, elemIdx) = 0
    layoutDrawCacheValid(winIdx) = 0
END SUB


SUB ClearLayoutDirtyElements(BYVAL winIdx AS INTEGER)
    DIM i AS INTEGER
    DIM elemIdx AS INTEGER

    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB

    FOR i = 1 TO layoutDirtyElemCount(winIdx)
        elemIdx = layoutDirtyElemList(winIdx, i)
        IF elemIdx >= 1 AND elemIdx <= 192 THEN layoutDirtyElemMarked(winIdx, elemIdx) = 0
        layoutDirtyElemList(winIdx, i) = 0
    NEXT
    layoutDirtyElemCount(winIdx) = 0

    IF layoutFastTextboxWin = winIdx THEN
        layoutFastTextboxPending = 0
        layoutFastTextboxWin = 0
        layoutFastTextboxElem = 0
        layoutFastTextboxLine = 0
    END IF
END SUB

SUB MarkLayoutDirtyElement(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER)
    DIM slotIdx AS INTEGER

    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(winIdx).used = 0 THEN EXIT SUB
    IF elemIdx < 1 OR elemIdx > 192 THEN EXIT SUB
    IF elemIdx > layoutUiCount(winIdx) AND winIdx <> activeLayoutWindow THEN EXIT SUB

    AdvanceLayoutElementVisualVersion winIdx, elemIdx

    IF layoutDirtyElemMarked(winIdx, elemIdx) <> 0 THEN EXIT SUB
    IF layoutDirtyElemCount(winIdx) >= 192 THEN EXIT SUB

    slotIdx = layoutDirtyElemCount(winIdx) + 1
    layoutDirtyElemCount(winIdx) = slotIdx
    layoutDirtyElemList(winIdx, slotIdx) = elemIdx
    layoutDirtyElemMarked(winIdx, elemIdx) = -1
    IF winIdx = activeLayoutWindow THEN
        IF LayoutElementIsDynamic(elemIdx) = 0 THEN layoutStaticCacheValid(winIdx) = 0
    END IF
END SUB


