END FUNCTION

FUNCTION DesktopIconEditTempPath() AS STRING
    RETURN ShellDesktopTempPath("ICON_EDIT_TEMP", "DESKTOP_ICON_EDIT_TEMP")
END FUNCTION


FUNCTION DesktopIconEditIntegerText(BYVAL srcText AS STRING) AS INTEGER
    DIM i AS INTEGER
    DIM c AS INTEGER

    srcText = TRIM$(srcText)
    IF srcText = "" THEN RETURN 0

    FOR i = 1 TO LEN(srcText)
        c = ASC(MID$(srcText, i, 1))
        IF c < ASC("0") OR c > ASC("9") THEN RETURN 0
    NEXT

    RETURN -1
END FUNCTION

FUNCTION DskMessageText(BYVAL keyName AS STRING) AS STRING
    DIM msgText AS STRING

    msgText = TRIM$(ReadCfgValueInSection(PATH_DSKMSGCFG, "MESSAGES", keyName, ""))
    IF msgText = "" THEN msgText = keyName

    RETURN msgText
END FUNCTION

SUB ShowDskMessage(BYVAL keyName AS STRING)
    DIM titleText AS STRING
    DIM msgText AS STRING

    titleText = DskMessageText("TITLE")
    msgText = DskMessageText(keyName)

    ShowGuiMessageBox titleText, msgText
END SUB

FUNCTION DesktopIconValidateBasic(BYVAL displayText AS STRING, BYVAL targetText AS STRING, BYVAL iconText AS STRING, BYVAL xText AS STRING, BYVAL yText AS STRING, BYVAL targetKey AS STRING) AS INTEGER
    displayText = TRIM$(displayText)
    targetText = TRIM$(targetText)
    iconText = TRIM$(iconText)
    xText = TRIM$(xText)
    yText = TRIM$(yText)

    IF displayText = "" THEN
        ShowDskMessage "DISPLAY_REQUIRED"
        RETURN 0
    END IF

    IF targetText = "" THEN
        ShowDskMessage targetKey
        RETURN 0
    END IF

    IF iconText = "" THEN
        ShowDskMessage "ICON_REQUIRED"
        RETURN 0
    END IF

    IF DesktopIconEditIntegerText(xText) = 0 THEN
        ShowDskMessage "X_REQUIRED"
        RETURN 0
    END IF

    IF DesktopIconEditIntegerText(yText) = 0 THEN
        ShowDskMessage "Y_REQUIRED"
        RETURN 0
    END IF

    RETURN -1
END FUNCTION

SUB WriteDesktopIconEditTemp(BYVAL iconIdx AS INTEGER)
