        ctxMenuCfgDuplicateText = ""
        ctxMenuCfgPasteText = ""
        ctxMenuCfgRenameText = ""
        ctxMenuCfgDeleteText = ""
        ctxMenuCfgPropText = ""
    END IF

    IF activeLayoutWindow = idx THEN
        IF bdbgEnabled <> 0 THEN BDbgWindowEvent "CLOSE_BEFORE_ACTIVE_EDITOR_RESET", idx
        FOR i = 1 TO 192
            ResetEditorControlRuntimeState i, ""
        NEXT
        IF bdbgEnabled <> 0 THEN BDbgWindowEvent "CLOSE_AFTER_ACTIVE_EDITOR_RESET", idx
        uiFocusIndex = 0
        uiCaretPos = 0
        uiScrollY = 0
        uiScrollX = 0
        uiCaretVisible = -1
        uiLastCaretBlink = TIMER
    END IF

    AppVarClearWindow idx
    KeyQueueClear idx

    IF bdbgEnabled <> 0 THEN BDbgWindowEvent "CLOSE_BEFORE_SLOT_CLEAR", idx
    layoutWindows(idx).used = 0
    layoutWindows(idx).appPath = ""
    layoutWindows(idx).title = ""
