        layoutListAnchorIdx(idx, i) = 0
        layoutDirectLabelLastWidth(idx, i) = 0
        layoutTextStatsCacheValid(idx, i) = 0
        layoutTextStatsCacheText(idx, i) = ""
    NEXT
    layoutUiCount(idx) = 0
    layoutBindInitCount(idx) = 0
