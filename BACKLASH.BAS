SUB LoadShellConfig()
    DIM showContentsDrag AS INTEGER

    LoadCfgReadCacheFile PATH_DISPLAYCFG
    LoadCfgReadCacheFile PATH_DESKTOPCFG
    LoadCfgReadCacheFile PATH_MOUSECFG
    LoadCfgReadCacheFile PATH_SHELLCFG

    cfg.resMode = VALINT(ReadCfgValue(PATH_DISPLAYCFG, "resolution", "2"))
    cfg.colorDepth = VALINT(ReadCfgValue(PATH_DISPLAYCFG, "colordepth", "16"))
    cfg.fullscreen = VALINT(ReadCfgValue(PATH_DISPLAYCFG, "fullscreen", "0"))

    cfg.showIcons = VALINT(ReadCfgValue(PATH_DESKTOPCFG, "showicons", "1"))
    cfg.showTaskbar = VALINT(ReadCfgValue(PATH_DESKTOPCFG, "showtaskbar", "1"))
    cfg.showClock = VALINT(ReadCfgValue(PATH_DESKTOPCFG, "showclock", "1"))
    cfg.doubleClickTime = VALINT(ReadCfgValue(PATH_DESKTOPCFG, "doubleclicktime", "100"))
    cfg.snapIcons = VALINT(ReadCfgValue(PATH_DESKTOPCFG, "snapicons", "1"))

    cfg.leftHanded = VALINT(ReadCfgValue(PATH_MOUSECFG, "lefthanded", "0"))
    cfg.trailEffect = VALINT(ReadCfgValue(PATH_MOUSECFG, "traileffect", "0"))
    cfg.outlineWindowDrag = VALINT(ReadCfgValue(PATH_SHELLCFG, "outlinewindowdrag", "1"))
    showContentsDrag = VALINT(ReadCfgValue(PATH_SHELLCFG, "showwindowcontentsdrag", "-1"))
    IF showContentsDrag >= 0 THEN
        IF showContentsDrag <> 0 THEN
            cfg.outlineWindowDrag = 0
        ELSE
            cfg.outlineWindowDrag = 1
        END IF
    END IF
    cfg.dosRunMode = DosRunModeValue(ReadCfgValue(PATH_SHELLCFG, "dosrunmode", "RESIDENT"))

    cfg.launchLabel = ReadCfgValue(PATH_SHELLCFG, "launchlabel", "Launch")

    IF cfg.resMode < 1 OR cfg.resMode > 3 THEN cfg.resMode = 2
    IF cfg.colorDepth <> 4 AND cfg.colorDepth <> 8 AND cfg.colorDepth <> 16 AND cfg.colorDepth <> 32 THEN cfg.colorDepth = 16
    IF cfg.showClock <> 0 THEN cfg.showClock = 1
    IF cfg.doubleClickTime < 20 THEN cfg.doubleClickTime = 20
    IF cfg.doubleClickTime > 100 THEN cfg.doubleClickTime = 100
    IF cfg.outlineWindowDrag <> 0 THEN cfg.outlineWindowDrag = 1
    IF cfg.dosRunMode = "" THEN cfg.dosRunMode = "RESIDENT"
    IF cfg.launchLabel = "" THEN cfg.launchLabel = "Launch"
END SUB


FUNCTION ThemeCfgValue(BYVAL keyName AS STRING, BYVAL defaultValue AS STRING) AS STRING
    DIM depthKey AS STRING
    DIM baseVal AS STRING
    DIM modeVal AS STRING

    baseVal = ReadCfgValue(PATH_THEMECFG, keyName, defaultValue)
    depthKey = keyName + "_" + LTRIM$(STR$(cfg.colorDepth))
    modeVal = ReadCfgValue(PATH_THEMECFG, depthKey, "")

    IF modeVal <> "" THEN
        ThemeCfgValue = modeVal
    ELSE
        ThemeCfgValue = baseVal
    END IF
END FUNCTION

FUNCTION ThemeWallpaperDepthKey() AS STRING
    IF cfg.colorDepth = 4 THEN RETURN "16"
    IF cfg.colorDepth = 8 THEN RETURN "256"
    RETURN "HIGH"
END FUNCTION

FUNCTION ThemeWallpaperCfgValue(BYVAL defaultValue AS STRING) AS STRING
    DIM marker AS STRING
    DIM depthVal AS STRING

    marker = CHR$(2)
    depthVal = ReadCfgValue(PATH_THEMECFG, "wallpaper_" + ThemeWallpaperDepthKey(), marker)
    IF depthVal <> marker THEN RETURN depthVal

    RETURN ReadCfgValue(PATH_THEMECFG, "wallpaper", defaultValue)
END FUNCTION

