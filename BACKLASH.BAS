SUB DrawTaskbarOnly(BYVAL startPressed AS INTEGER, BYVAL mx AS INTEGER, BYVAL my AS INTEGER)
    IF taskbarClockDirtyOnly <> 0 AND startPressed = 0 AND soundVolumePopupOpen = 0 AND _
       clockCalendarOpen = 0 AND clockTimeOpen = 0 THEN
        DrawTaskbarClockOnly mx, my
        EXIT SUB
    END IF

    SCREENLOCK
    RestoreCursorBackBuffer
    DrawTaskbar startPressed
    taskbarClockDirtyOnly = 0
