SUB ShowFileDragDrop(BYVAL sourceList AS STRING, BYVAL destDir AS STRING, BYVAL dialogAppPath AS STRING, BYVAL sourceWin AS INTEGER, BYVAL statusControlName AS STRING)
    DIM dragApp AS STRING
    DIM itemCount AS INTEGER
    DIM summaryText AS STRING

    sourceList = TRIM$(sourceList)
    destDir = AbsoluteDirPath(TRIM$(destDir))
    dragApp = NormalizePath(TRIM$(dialogAppPath))
    IF sourceList = "" THEN EXIT SUB
    IF destDir = "" THEN EXIT SUB
    IF dragApp = "" THEN EXIT SUB
    IF DIR(LayoutFilePath(dragApp)) = "" THEN EXIT SUB

    fileDragDropSourceList = sourceList
    fileDragDropDestDir = destDir
    fileDragDropSourceWin = sourceWin
    fileDragDropStatusControl = statusControlName

    ' The drag-drop dialog never performs the file operation automatically.
    ' It only captures the chosen Copy/Move/Cancel response for the pending file list.
    OpenDialogLayoutAndApplyProfile dragApp, destDir, "", 0

    itemCount = DelimitedListCount(sourceList)
