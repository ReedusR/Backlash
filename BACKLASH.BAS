        IF fileControlName = "" THEN fileControlName = AppControlNameValue(winIdx, "FILE_BROWSER_FILE_CONTROL", "")
        IF controlName = "" THEN controlName = AppControlNameValue(winIdx, "FILE_BROWSER_STATUS_CONTROL", "")

