ResetScreensaverIdle
RefreshScreensaverLaunchConfig -1
needRedraw = -1
uiCaretVisible = -1
uiLastCaretBlink = TIMER
taskbarClockLastText = ""
taskbarClockLastCheck = 0
taskbarClockDirtyOnly = 0
startMenuFastOpenPending = 0
startMenuFastClosePending = 0
