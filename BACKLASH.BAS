    LINE (x + 10, y + 4)-(x + 34, y + 32), COL_TEXT, B
    LINE (x + 27, y + 4)-(x + 34, y + 11), COL_TASKBAR, BF
    LINE (x + 27, y + 4)-(x + 34, y + 11), COL_TEXT, B
    LINE (x + 4, y + 24)-(x + 14, y + 34), COL_MISSING
    LINE (x + 14, y + 24)-(x + 4, y + 34), COL_MISSING
END SUB

SUB DrawIconImage(BYVAL idx AS INTEGER)
    DIM x AS INTEGER
    DIM y AS INTEGER
    DIM px AS UINTEGER PTR
    DIM w AS INTEGER
    DIM h AS INTEGER
    DIM ix AS INTEGER
    DIM iy AS INTEGER
    DIM drawX AS INTEGER
    DIM drawY AS INTEGER
    DIM curCol AS UINTEGER
    DIM ixStart AS INTEGER
    DIM iyStart AS INTEGER
    DIM ixEnd AS INTEGER
    DIM iyEnd AS INTEGER
    DIM runStart AS INTEGER
    DIM runCol AS UINTEGER
    DIM screenY AS INTEGER
    DIM runIdx AS INTEGER
    DIM sx1 AS INTEGER
    DIM sx2 AS INTEGER

    x = DesktopIconScreenX(idx)
    y = DesktopIconScreenY(idx)
    px = desktopIcons(idx).pixels
    w = desktopIcons(idx).w
    h = desktopIcons(idx).h

    IF desktopIcons(idx).loaded = 0 OR px = 0 THEN
        DrawDefaultIcon x, y
        EXIT SUB
    END IF

    drawX = x + (ICON_CELL_W - w) \ 2
    drawY = y + (46 - h) \ 2

    IF desktopIcons(idx).imageBuf <> 0 AND desktopIcons(idx).hasTrans = 0 AND _
       drawX >= 0 AND drawY >= 0 AND drawX + w - 1 < SCR_W AND drawY + h - 1 < SCR_H THEN
        PUT (drawX, drawY), desktopIcons(idx).imageBuf, PSET
        EXIT SUB
    END IF

    IF desktopIcons(idx).hasTrans <> 0 AND desktopIcons(idx).runCount > 0 AND _
       desktopIcons(idx).runY <> 0 AND desktopIcons(idx).runX1 <> 0 AND _
       desktopIcons(idx).runX2 <> 0 AND desktopIcons(idx).runCol <> 0 THEN
        FOR runIdx = 0 TO desktopIcons(idx).runCount - 1
            screenY = drawY + desktopIcons(idx).runY[runIdx]
            IF screenY >= 0 AND screenY < SCR_H THEN
                sx1 = drawX + desktopIcons(idx).runX1[runIdx]
                sx2 = drawX + desktopIcons(idx).runX2[runIdx]
                IF sx2 >= 0 AND sx1 < SCR_W THEN
                    IF sx1 < 0 THEN sx1 = 0
                    IF sx2 >= SCR_W THEN sx2 = SCR_W - 1
                    LINE (sx1, screenY)-(sx2, screenY), desktopIcons(idx).runCol[runIdx]
                END IF
            END IF
        NEXT
        EXIT SUB
    END IF

    ixStart = 0
    iyStart = 0
    ixEnd = w - 1
    iyEnd = h - 1

    IF drawX < 0 THEN ixStart = -drawX
    IF drawY < 0 THEN iyStart = -drawY
    IF drawX + ixEnd >= SCR_W THEN ixEnd = SCR_W - drawX - 1
    IF drawY + iyEnd >= SCR_H THEN iyEnd = SCR_H - drawY - 1

    IF ixStart > ixEnd OR iyStart > iyEnd THEN EXIT SUB

    FOR iy = iyStart TO iyEnd
        screenY = drawY + iy
        runStart = -1
        runCol = 0
        FOR ix = ixStart TO ixEnd
            curCol = px[CLNG(iy) * w + ix]
            IF IsTransparentBmpColor(curCol) <> 0 THEN
                IF runStart >= 0 THEN
                    LINE (drawX + runStart, screenY)-(drawX + ix - 1, screenY), runCol
                    runStart = -1
                END IF
            ELSEIF runStart < 0 THEN
                runStart = ix
                runCol = curCol
            ELSEIF curCol <> runCol THEN
                LINE (drawX + runStart, screenY)-(drawX + ix - 1, screenY), runCol
                runStart = ix
                runCol = curCol
            END IF
        NEXT
        IF runStart >= 0 THEN LINE (drawX + runStart, screenY)-(drawX + ixEnd, screenY), runCol
    NEXT
END SUB

SUB DrawDesktopIcons()
    DIM i AS INTEGER

    IF cfg.showIcons = 0 THEN EXIT SUB

    ' The desktop cache stores the steady unselected desktop.
    ' Selection is drawn afterward as a small overlay so clicking an icon
    ' does not rebuild and recapture the entire desktop surface.
    FOR i = 1 TO iconCount
        DrawIconImage i
        DrawWrappedCenteredLabel i, 0
    NEXT
END SUB

FUNCTION DesktopCacheSignature() AS LONG
    DIM i AS INTEGER
    DIM sig AS LONG

    sig = CLNG(cfg.showIcons) * 1009 + CLNG(iconCount) * 17
    sig = sig + CLNG(WORK_X + 32768) * 31 + CLNG(WORK_Y + 32768) * 37
    sig = sig + CLNG(WORK_W) * 41 + CLNG(WORK_H) * 43

    FOR i = 1 TO iconCount
        sig = sig + CLNG(desktopIcons(i).x + 32768) * CLNG(i + 3)
        sig = sig + CLNG(desktopIcons(i).y + 32768) * CLNG(i + 11)
        IF desktopIcons(i).loaded <> 0 THEN sig = sig + CLNG(i * 19)
    NEXT

    RETURN sig
END FUNCTION

SUB DrawDesktop()
    DIM sig AS LONG

    ' Desktop composition already invalidates this backing surface at every real
    ' background/icon change. When it is still valid, avoid rescanning the full
    ' desktop icon set just to prove that the cache can be reused.
    IF desktopCache <> 0 AND desktopCacheValid <> 0 THEN
        PUT (0, 0), desktopCache, PSET
    ELSE
        sig = DesktopCacheSignature()

        IF bgCache <> 0 THEN
            PUT (0, 0), bgCache, PSET
        ELSE
            LINE (0, 0)-(SCR_W - 1, SCR_H - 1), COL_DESKTOP, BF
        END IF

        DrawDesktopIcons
        DRAW STRING (WORK_X + 8, WORK_Y + 8), "DOS GUI  " + LTRIM$(STR$(SCR_W)) + "X" + LTRIM$(STR$(SCR_H)) + "X" + LTRIM$(STR$(cfg.colorDepth)), COL_TEXT_INV

        IF desktopCache = 0 THEN desktopCache = ImageCreate(SCR_W, SCR_H, 0)
        IF desktopCache <> 0 THEN
            GET (0, 0)-(SCR_W - 1, SCR_H - 1), desktopCache
            desktopCacheSig = sig
            desktopCacheValid = -1
        END IF
    END IF

    ' Selection is a volatile overlay, not part of the cached desktop base.
    ' This keeps icon click/highlight redraws out of the full desktop rebuild path.
    IF cfg.showIcons <> 0 THEN
        IF selectedIcon >= 1 AND selectedIcon <= iconCount THEN
            DrawIconSelection selectedIcon
            DrawWrappedCenteredLabel selectedIcon, -1
        END IF
    END IF
END SUB

SUB ShowGuiMessageBoxInfo(BYVAL titleText AS STRING, BYVAL msgText AS STRING)
    DIM oldSuppress AS INTEGER

    oldSuppress = guiMessageSuppressErrorSound
    SoundUiEvent "CLICK"
    guiMessageSuppressErrorSound = -1
    ShowGuiMessageBox titleText, msgText
    guiMessageSuppressErrorSound = oldSuppress
END SUB

FUNCTION TaskbarClockText() AS STRING
    DIM rawTime AS STRING
    DIM hourVal AS INTEGER
    DIM displayHour AS INTEGER
    DIM minText AS STRING
    DIM ampmText AS STRING

    rawTime = TIME$
    hourVal = VAL(LEFT$(rawTime, 2))
    minText = MID$(rawTime, 4, 2)

    IF hourVal >= 12 THEN
        ampmText = "PM"
    ELSE
        ampmText = "AM"
    END IF

    displayHour = hourVal MOD 12
    IF displayHour = 0 THEN displayHour = 12

    RETURN LTRIM$(STR$(displayHour)) + ":" + minText + " " + ampmText
END FUNCTION

SUB DrawTaskbarClock()
    DIM clockText AS STRING
    DIM clockW AS INTEGER
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER
    DIM tx AS INTEGER
    DIM ty AS INTEGER

    IF cfg.showTaskbar = 0 THEN EXIT SUB
    IF cfg.showClock = 0 THEN EXIT SUB

    clockText = TaskbarClockText()
    taskbarClockLastText = clockText
    clockW = TASKBAR_CLOCK_X2 - TASKBAR_CLOCK_X1 + 1
    x1 = TASKBAR_CLOCK_X1
    y1 = TASKBAR_CLOCK_Y1
    x2 = TASKBAR_CLOCK_X2
    y2 = TASKBAR_CLOCK_Y2

    IF x1 <= START_X2 + 8 THEN EXIT SUB

    DrawBevelBox x1, y1, x2, y2, -1

    tx = x1 + ((clockW - (LEN(clockText) * 8)) \ 2)
    ty = y1 + (((y2 - y1 + 1) - 8) \ 2)
    IF tx < x1 + 4 THEN tx = x1 + 4
    DRAW STRING (tx, ty), clockText, COL_TEXT
END SUB

SUB GetTaskbarVolumeRect(BYREF x1 AS INTEGER, BYREF y1 AS INTEGER, BYREF x2 AS INTEGER, BYREF y2 AS INTEGER)
    DIM clockX1 AS INTEGER

    x1 = -1
    y1 = -1
    x2 = -1
    y2 = -1

    IF cfg.showTaskbar = 0 THEN EXIT SUB
    IF soundTaskbarVolumeEnabled = 0 THEN EXIT SUB

    IF cfg.showClock <> 0 THEN
        clockX1 = TASKBAR_CLOCK_X1
        x2 = clockX1 - TASKBAR_VOLUME_GAP_W
    ELSE
        x2 = TASKBAR_X2 - 8
    END IF

    x1 = x2 - TASKBAR_VOLUME_W + 1
    y1 = TASKBAR_CLIENT_Y1
    y2 = TASKBAR_CLIENT_Y2

    IF x1 <= START_X2 + 8 THEN
        x1 = -1
        y1 = -1
        x2 = -1
        y2 = -1
    END IF
END SUB

FUNCTION TaskbarVolumeHitFromPoint(BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER) AS INTEGER
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER

    TaskbarVolumeHitFromPoint = 0
    IF cfg.showTaskbar = 0 THEN EXIT FUNCTION
    IF TaskbarHitFromPoint(mouseX, mouseY) = 0 THEN EXIT FUNCTION

    GetTaskbarVolumeRect x1, y1, x2, y2
    IF x1 < 0 THEN EXIT FUNCTION
    IF InRect(mouseX, mouseY, x1, y1, x2, y2) THEN TaskbarVolumeHitFromPoint = -1
END FUNCTION

SUB DrawTaskbarVolumeControl()
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER
    DIM sx AS INTEGER
    DIM sy AS INTEGER
    DIM levelBars AS INTEGER
    DIM colIcon AS UINTEGER

    GetTaskbarVolumeRect x1, y1, x2, y2
    IF x1 < 0 THEN EXIT SUB

    DrawBevelBox x1, y1, x2, y2, soundVolumePopupOpen

    colIcon = COL_TEXT
    IF soundEnabled = 0 OR soundVolumePercent <= 0 THEN colIcon = COL_BEVEL_LO

    sx = x1 + 5
    sy = y1 + ((y2 - y1 + 1) \ 2) - 4

    ' Compact tray speaker icon. Keep this drawn with primitives so the tray
    ' control does not depend on an external bitmap or steal taskbar width.
    LINE (sx, sy + 3)-(sx + 3, sy + 3), colIcon
    LINE (sx, sy + 4)-(sx + 3, sy + 4), colIcon
    LINE (sx, sy + 5)-(sx + 3, sy + 5), colIcon
    LINE (sx + 4, sy + 1)-(sx + 4, sy + 7), colIcon
    LINE (sx + 5, sy + 2)-(sx + 5, sy + 6), colIcon
    LINE (sx + 6, sy + 3)-(sx + 6, sy + 5), colIcon

    IF soundEnabled <> 0 AND soundVolumePercent > 0 THEN
        levelBars = (soundVolumePercent + 24) \ 25
        IF levelBars > 0 THEN LINE (sx + 10, sy + 3)-(sx + 10, sy + 5), colIcon
        IF levelBars > 1 THEN LINE (sx + 12, sy + 2)-(sx + 12, sy + 6), colIcon
        IF levelBars > 2 THEN LINE (sx + 14, sy + 1)-(sx + 14, sy + 7), colIcon
        IF levelBars > 3 THEN LINE (sx + 16, sy)-(sx + 16, sy + 8), colIcon
    ELSE
        LINE (sx + 10, sy + 1)-(sx + 16, sy + 7), COL_BEVEL_LO
        LINE (sx + 10, sy + 7)-(sx + 16, sy + 1), COL_BEVEL_LO
    END IF
END SUB

SUB GetSoundVolumePopupRect(BYREF x1 AS INTEGER, BYREF y1 AS INTEGER, BYREF x2 AS INTEGER, BYREF y2 AS INTEGER)
    DIM trayX1 AS INTEGER
    DIM trayY1 AS INTEGER
    DIM trayX2 AS INTEGER
    DIM trayY2 AS INTEGER

    x1 = -1
    y1 = -1
    x2 = -1
    y2 = -1

    IF cfg.showTaskbar = 0 THEN EXIT SUB
    IF soundTaskbarVolumeEnabled = 0 THEN EXIT SUB

    GetTaskbarVolumeRect trayX1, trayY1, trayX2, trayY2
    IF trayX1 < 0 THEN EXIT SUB

    x2 = trayX2
    x1 = x2 - SOUND_VOLUME_POPUP_W + 1
    IF x1 < 4 THEN x1 = 4
    x2 = x1 + SOUND_VOLUME_POPUP_W - 1
    IF x2 > SCR_W - 5 THEN
        x2 = SCR_W - 5
        x1 = x2 - SOUND_VOLUME_POPUP_W + 1
    END IF

    IF lay.taskbarEdge = TASKBAR_EDGE_TOP THEN
        y1 = TASKBAR_Y2 + 5
        y2 = y1 + SOUND_VOLUME_POPUP_H - 1
        IF y2 > SCR_H - 5 THEN
            y2 = SCR_H - 5
            y1 = y2 - SOUND_VOLUME_POPUP_H + 1
        END IF
    ELSE
        y2 = TASKBAR_Y1 - 5
        y1 = y2 - SOUND_VOLUME_POPUP_H + 1
        IF y1 < 4 THEN y1 = 4
    END IF
END SUB

FUNCTION SoundVolumePopupHitFromPoint(BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER) AS INTEGER
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER

    SoundVolumePopupHitFromPoint = 0
    IF soundVolumePopupOpen = 0 THEN EXIT FUNCTION

    GetSoundVolumePopupRect x1, y1, x2, y2
    IF x1 < 0 THEN EXIT FUNCTION
    IF InRect(mouseX, mouseY, x1, y1, x2, y2) THEN SoundVolumePopupHitFromPoint = -1
END FUNCTION

FUNCTION SoundVolumePopupActionFromPoint(BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER) AS INTEGER
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER
    DIM minusX1 AS INTEGER
    DIM minusY1 AS INTEGER
    DIM plusX1 AS INTEGER
    DIM plusY1 AS INTEGER
    DIM barX1 AS INTEGER
    DIM barY1 AS INTEGER
    DIM barX2 AS INTEGER
    DIM barY2 AS INTEGER

    SoundVolumePopupActionFromPoint = 0
    IF SoundVolumePopupHitFromPoint(mouseX, mouseY) = 0 THEN EXIT FUNCTION

    GetSoundVolumePopupRect x1, y1, x2, y2
    minusX1 = x1 + 12
    minusY1 = y1 + 34
    plusX1 = x2 - 34
    plusY1 = minusY1
    barX1 = x1 + 44
    barX2 = x2 - 44
    barY1 = y1 + 39
    barY2 = y1 + 47

    IF InRect(mouseX, mouseY, minusX1, minusY1, minusX1 + 22, minusY1 + 20) THEN RETURN 1
    IF InRect(mouseX, mouseY, plusX1, plusY1, plusX1 + 22, plusY1 + 20) THEN RETURN 2
    IF InRect(mouseX, mouseY, barX1, barY1, barX2, barY2) THEN RETURN 3
END FUNCTION

SUB SoundSetVolumeFromPopupPoint(BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER)
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER
    DIM barX1 AS INTEGER
    DIM barX2 AS INTEGER
    DIM barW AS INTEGER
    DIM newVol AS INTEGER

    GetSoundVolumePopupRect x1, y1, x2, y2
    IF x1 < 0 THEN EXIT SUB

    barX1 = x1 + 44
    barX2 = x2 - 44
    barW = barX2 - barX1
    IF barW < 1 THEN EXIT SUB

    IF mouseX < barX1 THEN mouseX = barX1
    IF mouseX > barX2 THEN mouseX = barX2

    newVol = ((mouseX - barX1) * 100) \ barW
    SoundSetVolumePercent newVol
END SUB

SUB SoundToggleVolumePopup()
    IF soundVolumePopupOpen = 0 THEN
        ClockClosePopups
        soundVolumePopupOpen = -1
    ELSE
        soundVolumePopupOpen = 0
    END IF
    InvalidateTaskbarCache
END SUB

SUB SoundCloseVolumePopup()
    IF soundVolumePopupOpen = 0 THEN EXIT SUB
    soundVolumePopupOpen = 0
    InvalidateTaskbarCache
END SUB

SUB DrawSoundVolumePopup()
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER
    DIM minusX1 AS INTEGER
    DIM minusY1 AS INTEGER
    DIM plusX1 AS INTEGER
    DIM plusY1 AS INTEGER
    DIM barX1 AS INTEGER
    DIM barY1 AS INTEGER
    DIM barX2 AS INTEGER
    DIM barY2 AS INTEGER
    DIM fillX2 AS INTEGER
    DIM pctText AS STRING
    DIM tx AS INTEGER

    IF soundVolumePopupOpen = 0 THEN EXIT SUB

    GetSoundVolumePopupRect x1, y1, x2, y2
    IF x1 < 0 THEN EXIT SUB

    DrawBevelBox x1, y1, x2, y2, 0
    DRAW STRING (x1 + 10, y1 + 10), "Volume", COL_TEXT

    pctText = LTRIM$(STR$(soundVolumePercent)) + "%"
    tx = x2 - 10 - LEN(pctText) * 8
    IF tx < x1 + 72 THEN tx = x1 + 72
    DRAW STRING (tx, y1 + 10), pctText, COL_TEXT

    minusX1 = x1 + 12
    minusY1 = y1 + 34
    plusX1 = x2 - 34
    plusY1 = minusY1
    barX1 = x1 + 44
    barX2 = x2 - 44
    barY1 = y1 + 39
    barY2 = y1 + 47

    DrawButtonBevelBox minusX1, minusY1, minusX1 + 22, minusY1 + 20, 0
    DRAW STRING (minusX1 + 8, minusY1 + 6), "-", COL_TEXT

    DrawButtonBevelBox plusX1, plusY1, plusX1 + 22, plusY1 + 20, 0
    DRAW STRING (plusX1 + 8, plusY1 + 6), "+", COL_TEXT

    LINE (barX1, barY1)-(barX2, barY2), COL_BEVEL_LO, B
    IF soundVolumePercent > 0 THEN
        fillX2 = barX1 + ((barX2 - barX1 - 1) * soundVolumePercent) \ 100
        IF fillX2 < barX1 THEN fillX2 = barX1
        IF fillX2 > barX2 - 1 THEN fillX2 = barX2 - 1
        LINE (barX1 + 1, barY1 + 1)-(fillX2, barY2 - 1), COL_SELECT, BF
    END IF
END SUB

FUNCTION TaskbarOpenWindowCount() AS INTEGER
    DIM i AS INTEGER
    DIM winCount AS INTEGER

    winCount = 0
    FOR i = LBOUND(layoutWindows) TO UBOUND(layoutWindows)
        IF layoutWindows(i).used <> 0 THEN winCount = winCount + 1
    NEXT

    RETURN winCount
END FUNCTION

FUNCTION TaskbarWindowOrdinal(BYVAL slotIdx AS INTEGER) AS INTEGER
    DIM i AS INTEGER
    DIM curOrdinal AS INTEGER

    IF slotIdx < LBOUND(layoutWindows) OR slotIdx > UBOUND(layoutWindows) THEN RETURN -1
    IF layoutWindows(slotIdx).used = 0 THEN RETURN -1

    curOrdinal = 0
    FOR i = LBOUND(layoutWindows) TO UBOUND(layoutWindows)
        IF layoutWindows(i).used <> 0 THEN
            IF i = slotIdx THEN RETURN curOrdinal
            curOrdinal = curOrdinal + 1
        END IF
    NEXT

    RETURN -1
END FUNCTION

SUB GetTaskbarButtonArea(BYREF areaLeft AS INTEGER, BYREF areaRight AS INTEGER, BYREF scrollNeeded AS INTEGER)
    DIM clockX1 AS INTEGER
    DIM baseLeft AS INTEGER
    DIM baseRight AS INTEGER
    DIM baseW AS INTEGER
    DIM gapW AS INTEGER
    DIM capNoScroll AS INTEGER
    DIM winCount AS INTEGER
    DIM volX1 AS INTEGER
    DIM volY1 AS INTEGER
    DIM volX2 AS INTEGER
    DIM volY2 AS INTEGER

    areaLeft = -1
    areaRight = -1
    scrollNeeded = 0

    IF cfg.showTaskbar = 0 THEN EXIT SUB

    winCount = TaskbarOpenWindowCount()
    IF winCount <= 0 THEN EXIT SUB

    clockX1 = TASKBAR_CLOCK_X1
    baseLeft = START_X2 + 8
    GetTaskbarVolumeRect volX1, volY1, volX2, volY2
    IF volX1 >= 0 THEN
        baseRight = volX1 - 8
    ELSEIF cfg.showClock = 0 THEN
        baseRight = TASKBAR_X2 - 8
    ELSE
        baseRight = clockX1 - 8
    END IF
    IF baseRight <= baseLeft THEN EXIT SUB

    gapW = TASKBAR_BTN_GAP_W
    baseW = baseRight - baseLeft + 1
    capNoScroll = (baseW + gapW) \ (TASKBAR_BTN_MIN_W + gapW)
    IF capNoScroll < 1 AND baseW >= 30 THEN capNoScroll = 1

    IF winCount > capNoScroll AND baseW > ((TASKBAR_SCROLL_W + 4) * 2 + 30) THEN
        scrollNeeded = -1
        areaLeft = baseLeft + TASKBAR_SCROLL_W + 4
        areaRight = baseRight - TASKBAR_SCROLL_W - 4
    ELSE
        areaLeft = baseLeft
        areaRight = baseRight
    END IF
END SUB

FUNCTION TaskbarVisibleCapacity() AS INTEGER
    DIM areaLeft AS INTEGER
    DIM areaRight AS INTEGER
    DIM scrollNeeded AS INTEGER
    DIM areaW AS INTEGER
    DIM gapW AS INTEGER
    DIM capCount AS INTEGER
    DIM winCount AS INTEGER

    winCount = TaskbarOpenWindowCount()
    IF winCount <= 0 THEN RETURN 0

    GetTaskbarButtonArea areaLeft, areaRight, scrollNeeded
    IF areaLeft < 0 OR areaRight < areaLeft THEN RETURN 0

    gapW = TASKBAR_BTN_GAP_W
    areaW = areaRight - areaLeft + 1
    capCount = (areaW + gapW) \ (TASKBAR_BTN_MIN_W + gapW)
    IF capCount < 1 AND areaW >= 30 THEN capCount = 1
    IF capCount > winCount THEN capCount = winCount

    RETURN capCount
END FUNCTION

SUB NormalizeTaskbarScroll()
    DIM winCount AS INTEGER
    DIM capCount AS INTEGER
    DIM maxFirst AS INTEGER

    winCount = TaskbarOpenWindowCount()
    capCount = TaskbarVisibleCapacity()

    IF winCount <= 0 OR capCount <= 0 THEN
        taskbarFirstButton = 0
        EXIT SUB
    END IF

    maxFirst = winCount - capCount
    IF maxFirst < 0 THEN maxFirst = 0

    IF taskbarFirstButton < 0 THEN taskbarFirstButton = 0
    IF taskbarFirstButton > maxFirst THEN taskbarFirstButton = maxFirst
END SUB

SUB GetTaskbarScrollButtonRect(BYVAL direction AS INTEGER, BYREF x1 AS INTEGER, BYREF y1 AS INTEGER, BYREF x2 AS INTEGER, BYREF y2 AS INTEGER)
    DIM clockX1 AS INTEGER
    DIM baseLeft AS INTEGER
    DIM baseRight AS INTEGER
    DIM areaLeft AS INTEGER
    DIM areaRight AS INTEGER
    DIM scrollNeeded AS INTEGER
    DIM volX1 AS INTEGER
    DIM volY1 AS INTEGER
    DIM volX2 AS INTEGER
    DIM volY2 AS INTEGER

    x1 = -1
    y1 = -1
    x2 = -1
    y2 = -1

    IF cfg.showTaskbar = 0 THEN EXIT SUB

    GetTaskbarButtonArea areaLeft, areaRight, scrollNeeded
    IF scrollNeeded = 0 THEN EXIT SUB

    clockX1 = TASKBAR_CLOCK_X1
    baseLeft = START_X2 + 8
    GetTaskbarVolumeRect volX1, volY1, volX2, volY2
    IF volX1 >= 0 THEN
        baseRight = volX1 - 8
    ELSEIF cfg.showClock = 0 THEN
        baseRight = TASKBAR_X2 - 8
    ELSE
        baseRight = clockX1 - 8
    END IF
    IF baseRight <= baseLeft THEN EXIT SUB

    IF direction < 0 THEN
        x1 = baseLeft
        x2 = baseLeft + TASKBAR_SCROLL_W - 1
    ELSE
        x2 = baseRight
        x1 = baseRight - TASKBAR_SCROLL_W + 1
    END IF

    y1 = TASKBAR_CLIENT_Y1
    y2 = TASKBAR_CLIENT_Y2
END SUB

FUNCTION TaskbarScrollButtonFromPoint(BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER) AS INTEGER
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER

    IF cfg.showTaskbar = 0 THEN RETURN 0
    IF TaskbarHitFromPoint(mouseX, mouseY) = 0 THEN RETURN 0

    GetTaskbarScrollButtonRect -1, x1, y1, x2, y2
    IF x1 >= 0 THEN
        IF InRect(mouseX, mouseY, x1, y1, x2, y2) THEN RETURN -1
    END IF

    GetTaskbarScrollButtonRect 1, x1, y1, x2, y2
    IF x1 >= 0 THEN
        IF InRect(mouseX, mouseY, x1, y1, x2, y2) THEN RETURN 1
    END IF

    RETURN 0
END FUNCTION

SUB DrawTaskbarScrollButton(BYVAL direction AS INTEGER)
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER
    DIM capCount AS INTEGER
    DIM maxFirst AS INTEGER
    DIM arrowText AS STRING
    DIM arrowCol AS UINTEGER
    DIM tx AS INTEGER
    DIM ty AS INTEGER

    GetTaskbarScrollButtonRect direction, x1, y1, x2, y2
    IF x1 < 0 THEN EXIT SUB

    NormalizeTaskbarScroll
    capCount = TaskbarVisibleCapacity()
    maxFirst = TaskbarOpenWindowCount() - capCount
    IF maxFirst < 0 THEN maxFirst = 0

    arrowText = ">"
    IF direction < 0 THEN arrowText = "<"

    arrowCol = COL_TEXT
    IF direction < 0 AND taskbarFirstButton <= 0 THEN arrowCol = COL_BEVEL_LO
    IF direction > 0 AND taskbarFirstButton >= maxFirst THEN arrowCol = COL_BEVEL_LO

    DrawBevelBox x1, y1, x2, y2, 0
    tx = x1 + (((x2 - x1 + 1) - 8) \ 2)
    ty = y1 + (((y2 - y1 + 1) - 8) \ 2)
    DRAW STRING (tx, ty), arrowText, arrowCol
END SUB

SUB GetTaskbarButtonRect(BYVAL slotIdx AS INTEGER, BYREF x1 AS INTEGER, BYREF y1 AS INTEGER, BYREF x2 AS INTEGER, BYREF y2 AS INTEGER)
    DIM areaLeft AS INTEGER
    DIM areaRight AS INTEGER
    DIM areaW AS INTEGER
    DIM gapW AS INTEGER
    DIM btnW AS INTEGER
    DIM winCount AS INTEGER
    DIM visibleCount AS INTEGER
    DIM buttonOrdinal AS INTEGER
    DIM visibleOrdinal AS INTEGER
    DIM scrollNeeded AS INTEGER

    x1 = -1
    y1 = -1
    x2 = -1
    y2 = -1

    IF cfg.showTaskbar = 0 THEN EXIT SUB
    IF slotIdx < LBOUND(layoutWindows) OR slotIdx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(slotIdx).used = 0 THEN EXIT SUB

    NormalizeTaskbarScroll

    winCount = TaskbarOpenWindowCount()
    visibleCount = TaskbarVisibleCapacity()
    IF winCount <= 0 OR visibleCount <= 0 THEN EXIT SUB

    buttonOrdinal = TaskbarWindowOrdinal(slotIdx)
    IF buttonOrdinal < 0 THEN EXIT SUB
    IF buttonOrdinal < taskbarFirstButton THEN EXIT SUB
    IF buttonOrdinal >= taskbarFirstButton + visibleCount THEN EXIT SUB

    GetTaskbarButtonArea areaLeft, areaRight, scrollNeeded
    IF areaLeft < 0 OR areaRight < areaLeft THEN EXIT SUB

    gapW = TASKBAR_BTN_GAP_W
    areaW = areaRight - areaLeft + 1
    btnW = (areaW - ((visibleCount - 1) * gapW)) \ visibleCount
    IF btnW > TASKBAR_BTN_MAX_W THEN btnW = TASKBAR_BTN_MAX_W
    IF btnW < 30 THEN EXIT SUB

    visibleOrdinal = buttonOrdinal - taskbarFirstButton

    x1 = areaLeft + visibleOrdinal * (btnW + gapW)
    y1 = TASKBAR_CLIENT_Y1
    x2 = x1 + btnW - 1
    y2 = TASKBAR_CLIENT_Y2

    IF x2 > areaRight THEN x2 = areaRight
    IF x2 - x1 < 29 THEN
        x1 = -1
        y1 = -1
        x2 = -1
        y2 = -1
    END IF
END SUB

FUNCTION TaskbarButtonFromPoint(BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER) AS INTEGER
    DIM i AS INTEGER
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER

    IF cfg.showTaskbar = 0 THEN RETURN 0
    IF TaskbarHitFromPoint(mouseX, mouseY) = 0 THEN RETURN 0
    IF InRect(mouseX, mouseY, START_X1, START_Y1, START_X2, START_Y2) THEN RETURN 0

    FOR i = LBOUND(layoutWindows) TO UBOUND(layoutWindows)
        GetTaskbarButtonRect i, x1, y1, x2, y2
        IF x1 >= 0 THEN
            IF InRect(mouseX, mouseY, x1, y1, x2, y2) THEN RETURN i
        END IF
    NEXT

    RETURN 0
END FUNCTION

SUB DrawTaskbarButtons()
    DIM i AS INTEGER
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER
    DIM titleText AS STRING
    DIM maxChars AS INTEGER
    DIM tx AS INTEGER
    DIM ty AS INTEGER
    DIM buttonPressed AS INTEGER
    DIM textCol AS UINTEGER
    DIM isActiveOpen AS INTEGER
    DIM isMinimized AS INTEGER

    IF cfg.showTaskbar = 0 THEN EXIT SUB

    NormalizeTaskbarScroll
    DrawTaskbarScrollButton -1
    DrawTaskbarScrollButton 1

    FOR i = LBOUND(layoutWindows) TO UBOUND(layoutWindows)
        IF layoutWindows(i).used <> 0 THEN
            GetTaskbarButtonRect i, x1, y1, x2, y2
            IF x1 >= 0 THEN
                isMinimized = layoutWindows(i).minimized
                isActiveOpen = 0
                IF i = activeLayoutWindow AND layoutWindows(i).active <> 0 AND isMinimized = 0 THEN isActiveOpen = -1

                buttonPressed = 0
                textCol = COL_TEXT

                IF isActiveOpen <> 0 THEN
                    buttonPressed = -1
                    textCol = COL_TEXT_INV
                ELSEIF isMinimized <> 0 THEN
                    buttonPressed = -1
                    textCol = COL_BEVEL_LO
                END IF

                DrawButtonBevelBox x1, y1, x2, y2, buttonPressed

                IF isActiveOpen <> 0 THEN
                    IF x2 > x1 + 5 AND y2 > y1 + 5 THEN LINE (x1 + 2, y1 + 2)-(x2 - 2, y2 - 2), COL_SELECT, B
                ELSEIF isMinimized <> 0 THEN
                    IF x2 > x1 + 5 AND y2 > y1 + 5 THEN LINE (x1 + 2, y1 + 2)-(x2 - 2, y2 - 2), COL_BEVEL_LO, B
                END IF

                titleText = RTRIM$(layoutWindows(i).title)
                maxChars = (x2 - x1 - 12) \ 8
                IF maxChars < 1 THEN maxChars = 1
                IF LEN(titleText) > maxChars THEN
                    IF maxChars > 3 THEN
                        titleText = LEFT$(titleText, maxChars - 3) + "..."
                    ELSE
                        titleText = LEFT$(titleText, maxChars)
                    END IF
                END IF
                tx = x1 + 6
                ty = y1 + (((y2 - y1 + 1) - 8) \ 2)
                IF buttonPressed <> 0 THEN
                    tx = tx + uiStyle.pressedOffset
                    ty = ty + uiStyle.pressedOffset
                END IF
                DRAW STRING (tx, ty), titleText, textCol
            END IF
        END IF
    NEXT
END SUB

FUNCTION TaskbarClockNeedsRedrawAt(BYVAL nowTime AS DOUBLE) AS INTEGER
    DIM elapsedTime AS DOUBLE
    DIM clockTextNow AS STRING

    IF cfg.showTaskbar = 0 THEN RETURN 0
    IF cfg.showClock = 0 THEN RETURN 0

    IF taskbarClockLastCheck <> 0 THEN
        elapsedTime = nowTime - taskbarClockLastCheck
        IF elapsedTime < 0 THEN elapsedTime = elapsedTime + 86400
        IF elapsedTime < 1 THEN RETURN 0
    END IF

    taskbarClockLastCheck = nowTime
    clockTextNow = TaskbarClockText()
    IF clockTextNow <> taskbarClockLastText THEN
        taskbarClockLastText = clockTextNow
        taskbarClockDirtyOnly = -1
        InvalidateTaskbarCache
        RETURN -1
    END IF

    RETURN 0
END FUNCTION

FUNCTION TaskbarClockNeedsRedraw() AS INTEGER
    RETURN TaskbarClockNeedsRedrawAt(TIMER)
END FUNCTION

FUNCTION TaskbarCacheSignature(BYVAL startPressed AS INTEGER) AS LONG
    DIM sig AS LONG
    DIM i AS INTEGER

    sig = CLNG(cfg.showTaskbar) * 1009 + CLNG(startPressed) * 131 + CLNG(SCR_W) * 3 + CLNG(SCR_H) * 5
    sig = sig + CLNG(TASKBAR_Y) * 7 + CLNG(TASKBAR_H) * 11 + CLNG(lay.taskbarEdge) * 12 + CLNG(START_X2) * 13
    sig = sig + CLNG(launchButtonLoaded) * 17 + CLNG(taskbarFirstButton) * 19 + CLNG(activeLayoutWindow) * 29
    sig = sig + CLNG(soundVolumePercent) * 71 + CLNG(soundTaskbarVolumeEnabled) * 73 + CLNG(soundEnabled) * 79
    sig = sig + CLNG(soundVolumePopupOpen) * 83
    sig = sig + UIStyleDrawSignature() * 137
    sig = sig + CLNG(clockCalendarOpen) * 89 + CLNG(clockTimeOpen) * 97
    sig = sig + CLNG(clockCalMonth) * 101 + CLNG(clockCalYear) * 103
    sig = sig + CLNG(clockSetHour) * 107 + CLNG(clockSetMinute) * 109

    FOR i = 1 TO LEN(taskbarClockLastText)
        sig = sig + CLNG(ASC(MID$(taskbarClockLastText, i, 1))) * CLNG(i + 23)
    NEXT

    FOR i = 1 TO LEN(cfg.launchLabel)
        sig = sig + CLNG(ASC(MID$(cfg.launchLabel, i, 1))) * CLNG(i + 41)
    NEXT

    FOR i = LBOUND(layoutWindows) TO UBOUND(layoutWindows)
        IF layoutWindows(i).used <> 0 THEN
            sig = sig + CLNG(i) * 53
            sig = sig + CLNG(layoutWindows(i).minimized) * CLNG(i + 59)
            sig = sig + CLNG(layoutWindows(i).active) * CLNG(i + 61)
            sig = sig + CLNG(layoutWindows(i).maximized) * CLNG(i + 63)
            DIM titleSigText AS STRING
            titleSigText = RTRIM$(layoutWindows(i).title)
            DIM titleSigPos AS INTEGER
            FOR titleSigPos = 1 TO LEN(titleSigText)
                sig = sig + CLNG(ASC(MID$(titleSigText, titleSigPos, 1))) * CLNG(i + titleSigPos + 67)
            NEXT
        END IF
    NEXT

    RETURN sig
END FUNCTION

SUB DrawTaskbar(BYVAL startPressed AS INTEGER)
    DIM sig AS LONG

    IF cfg.showTaskbar = 0 THEN EXIT SUB

    NormalizeTaskbarScroll

    ' The neutral taskbar backing is explicitly invalidated whenever its live
    ' inputs change. On cache hits, reuse it directly instead of rebuilding the
    ' full taskbar signature across every open-window title.
    IF startPressed = 0 THEN
        IF taskbarCache <> 0 AND taskbarCacheValid <> 0 THEN
            PUT (TASKBAR_X1, TASKBAR_Y1), taskbarCache, PSET
            EXIT SUB
        END IF
    END IF

    sig = TaskbarCacheSignature(startPressed)

    IF cfg.colorDepth > 8 AND theme.taskbarGradient <> 0 THEN
        DrawCachedTaskbarGradient
    ELSE
        LINE (TASKBAR_X1, TASKBAR_Y1)-(TASKBAR_X2, TASKBAR_Y2), COL_TASKBAR, BF
    END IF
    IF lay.taskbarEdge = TASKBAR_EDGE_TOP THEN
        LINE (TASKBAR_X1, TASKBAR_Y2 - 1)-(TASKBAR_X2, TASKBAR_Y2 - 1), COL_BEVEL_HI
        LINE (TASKBAR_X1, TASKBAR_Y2)-(TASKBAR_X2, TASKBAR_Y2), COL_BEVEL_LO
    ELSE
        LINE (TASKBAR_X1, TASKBAR_Y1)-(TASKBAR_X2, TASKBAR_Y1), COL_BEVEL_HI
        LINE (TASKBAR_X1, TASKBAR_Y1 + 1)-(TASKBAR_X2, TASKBAR_Y1 + 1), COL_BEVEL_LO
    END IF

    DrawButtonBevelBox START_X1, START_Y1, START_X2, START_Y2, startPressed

    IF DrawLaunchButtonBmp(START_X1, START_Y1, START_X2, START_Y2, startPressed) = 0 THEN
        IF startPressed THEN
            DRAW STRING (START_X1 + 14, START_Y1 + 6), cfg.launchLabel, COL_TEXT
        ELSE
            DRAW STRING (START_X1 + 13, START_Y1 + 5), cfg.launchLabel, COL_TEXT
        END IF
    END IF

    DrawTaskbarButtons
    DrawTaskbarVolumeControl
    DrawTaskbarClock

    IF startPressed = 0 THEN
        IF taskbarCache = 0 THEN taskbarCache = ImageCreate(SCR_W, TASKBAR_H, 0)
        IF taskbarCache <> 0 THEN
            GET (TASKBAR_X1, TASKBAR_Y1)-(TASKBAR_X2, TASKBAR_Y2), taskbarCache
            taskbarCacheSig = sig
            taskbarCacheValid = -1
        END IF
    END IF
END SUB

SUB DrawMenuItemIcon(BYVAL idx AS INTEGER, BYVAL x AS INTEGER, BYVAL y AS INTEGER)
    DIM ix AS INTEGER
    DIM iy AS INTEGER
    DIM curCol AS UINTEGER
    DIM drawX AS INTEGER
    DIM drawY AS INTEGER
    DIM runStart AS INTEGER
    DIM runCol AS UINTEGER
    DIM screenY AS INTEGER
    DIM runIdx AS INTEGER
    DIM sx1 AS INTEGER
    DIM sx2 AS INTEGER

    IF idx < 1 OR idx > menuCount THEN EXIT SUB
    IF menuItems(idx).loaded = 0 OR menuItems(idx).pixels = 0 THEN EXIT SUB

    drawX = x + (16 - menuItems(idx).w) \ 2
    drawY = y + (16 - menuItems(idx).h) \ 2

    IF menuItems(idx).imageBuf <> 0 AND menuItems(idx).hasTrans = 0 AND _
       drawX >= 0 AND drawY >= 0 AND _
       drawX + menuItems(idx).w - 1 < SCR_W AND drawY + menuItems(idx).h - 1 < SCR_H THEN
        PUT (drawX, drawY), menuItems(idx).imageBuf, PSET
        EXIT SUB
    END IF

    IF menuItems(idx).hasTrans <> 0 AND menuItems(idx).runCount > 0 AND _
       menuItems(idx).runY <> 0 AND menuItems(idx).runX1 <> 0 AND _
       menuItems(idx).runX2 <> 0 AND menuItems(idx).runCol <> 0 THEN
        FOR runIdx = 0 TO menuItems(idx).runCount - 1
            screenY = drawY + menuItems(idx).runY[runIdx]
            IF screenY >= 0 AND screenY < SCR_H THEN
                sx1 = drawX + menuItems(idx).runX1[runIdx]
                sx2 = drawX + menuItems(idx).runX2[runIdx]
                IF sx2 >= 0 AND sx1 < SCR_W THEN
                    IF sx1 < 0 THEN sx1 = 0
                    IF sx2 >= SCR_W THEN sx2 = SCR_W - 1
                    LINE (sx1, screenY)-(sx2, screenY), menuItems(idx).runCol[runIdx]
                END IF
            END IF
        NEXT
        EXIT SUB
    END IF

    FOR iy = 0 TO menuItems(idx).h - 1
        screenY = drawY + iy
        IF screenY >= 0 AND screenY < SCR_H THEN
            runStart = -1
            runCol = 0
            FOR ix = 0 TO menuItems(idx).w - 1
                curCol = menuItems(idx).pixels[CLNG(iy) * menuItems(idx).w + ix]
                IF IsTransparentBmpColor(curCol) <> 0 OR drawX + ix < 0 OR drawX + ix >= SCR_W THEN
                    IF runStart >= 0 THEN
                        LINE (drawX + runStart, screenY)-(drawX + ix - 1, screenY), runCol
                        runStart = -1
                    END IF
                ELSEIF runStart < 0 THEN
                    runStart = ix
                    runCol = curCol
                ELSEIF curCol <> runCol THEN
                    LINE (drawX + runStart, screenY)-(drawX + ix - 1, screenY), runCol
                    runStart = ix
                    runCol = curCol
                END IF
            NEXT
            IF runStart >= 0 THEN LINE (drawX + runStart, screenY)-(drawX + menuItems(idx).w - 1, screenY), runCol
        END IF
    NEXT
END SUB

SUB DrawSubmenuArrow(BYVAL x AS INTEGER, BYVAL y AS INTEGER, BYVAL col AS UINTEGER)
    LINE (x, y + 2)-(x, y + 10), col
    LINE (x + 1, y + 3)-(x + 1, y + 9), col
    LINE (x + 2, y + 4)-(x + 2, y + 8), col
    LINE (x + 3, y + 5)-(x + 3, y + 7), col
END SUB

SUB RecordStartMenuPanelRows(BYVAL parentIdx AS INTEGER, BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL level AS INTEGER)
    DIM i AS INTEGER
    DIM curY AS INTEGER
    DIM py1 AS INTEGER
    DIM py2 AS INTEGER
    DIM itemH AS INTEGER
    DIM contentX1 AS INTEGER

    contentX1 = x1
    IF parentIdx = 0 THEN contentX1 = contentX1 + StartStripSpace()

    curY = y1 + MENU_PANEL_PAD_Y
    IF menuChildCacheValid = 0 THEN BuildLaunchMenuCaches

    i = menuFirstChild(parentIdx)
    DO WHILE i <> 0
        itemH = MenuItemPixelHeight(i)
        py1 = curY
        py2 = py1 + itemH - 1

        IF menuItemRowVisible(i) = 0 THEN
            IF menuVisibleRowCount < MAX_MENU_ITEMS THEN
                menuVisibleRowCount = menuVisibleRowCount + 1
                menuVisibleRowItems(menuVisibleRowCount) = i
            END IF
        END IF

        menuItemRowVisible(i) = -1
        menuItemRowX1(i) = contentX1 + 2
        menuItemRowY1(i) = py1
        menuItemRowX2(i) = x2 - 2
        menuItemRowY2(i) = py2
        menuItemRowLevel(i) = level

        curY = curY + itemH
        i = menuNextSibling(i)
    LOOP
END SUB

SUB DrawStartMenuPanelBase(BYVAL parentIdx AS INTEGER, BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER, BYVAL level AS INTEGER)
    DIM i AS INTEGER
    DIM py1 AS INTEGER
    DIM py2 AS INTEGER
    DIM rowH AS INTEGER
    DIM hasIcons AS INTEGER
    DIM textX AS INTEGER
    DIM stripW AS INTEGER
    DIM contentX1 AS INTEGER

    BuildMenuPanelMetrics parentIdx
    hasIcons = menuPanelHasIconsCache(parentIdx)

    stripW = 0
    IF parentIdx = 0 THEN stripW = StartStripSpace()
    contentX1 = x1 + stripW

    DrawBevelBox x1, y1, x2, y2, 0
    LINE (x1 + 1, y1 + 1)-(x2 - 1, y2 - 1), COL_TASKBAR, BF
    LINE (x1, y1)-(x2, y2), COL_TEXT, B
    IF parentIdx = 0 AND stripW > 0 THEN DrawStartStripDecor x1 + 2, y1 + 2, x1 + 1 + stripW, y2 - 2

    IF menuChildCacheValid = 0 THEN BuildLaunchMenuCaches
    i = menuFirstChild(parentIdx)
    DO WHILE i <> 0
        py1 = menuItemRowY1(i)
        py2 = menuItemRowY2(i)
        rowH = py2 - py1 + 1

        IF menuItemIsDivider(i) <> 0 THEN
            LINE (contentX1 + MENU_PAD_X + 2, py1 + rowH \ 2)-(x2 - MENU_PAD_X - 2, py1 + rowH \ 2), COL_BEVEL_LO
            LINE (contentX1 + MENU_PAD_X + 2, py1 + rowH \ 2 + 1)-(x2 - MENU_PAD_X - 2, py1 + rowH \ 2 + 1), COL_BEVEL_HI
        ELSE
            IF hasIcons <> 0 THEN
                DrawMenuItemIcon i, contentX1 + MENU_ICON_X, py1 + MENU_ROW_PAD_Y - 1
                textX = contentX1 + MENU_TEXT_X
            ELSE
                textX = contentX1 + MENU_PAD_X
            END IF

            DRAW STRING (textX, py1 + MENU_ROW_PAD_Y + 1), menuItems(i).caption, COL_TEXT

            IF menuItemHasSubmenu(i) <> 0 THEN
                DrawSubmenuArrow x2 - MENU_ARROW_PAD, py1 + MENU_ROW_PAD_Y + 1, COL_TEXT
            END IF
        END IF

        i = menuNextSibling(i)
    LOOP
END SUB

SUB DrawStartMenuPanelHotRows(BYVAL parentIdx AS INTEGER, BYVAL level AS INTEGER, BYVAL hoverIndex AS INTEGER)
    DIM i AS INTEGER
    DIM isHot AS INTEGER

    IF menuChildCacheValid = 0 THEN BuildLaunchMenuCaches

    i = menuFirstChild(parentIdx)
    DO WHILE i <> 0
        IF menuItemIsDivider(i) = 0 THEN
            isHot = 0
            IF i = hoverIndex THEN isHot = -1
            IF menuItemHasSubmenu(i) <> 0 THEN
                IF level >= 0 AND level <= 8 THEN
                    IF menuOpenItem(level) = i THEN isHot = -1
                END IF
            END IF

            IF isHot <> 0 THEN DrawStartMenuItemRow i, hoverIndex
        END IF

        i = menuNextSibling(i)
    LOOP
END SUB

FUNCTION ListSelectionContains(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER, BYVAL itemValue AS STRING) AS INTEGER
    DIM bag AS STRING
    DIM itemKey AS STRING
    DIM needle AS STRING

    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN RETURN 0
    IF elemIdx < 1 OR elemIdx > 192 THEN RETURN 0

    itemKey = UCASE$(RTRIM$(itemValue))
    IF itemKey = "" THEN RETURN 0

    bag = layoutListMultiSel(winIdx, elemIdx)
    IF bag = "" THEN RETURN 0

    needle = CHR$(1) + itemKey + CHR$(1)
    IF INSTR(CHR$(1) + UCASE$(bag) + CHR$(1), needle) > 0 THEN RETURN -1

    RETURN 0
END FUNCTION
SUB ListSelectionClear(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER)
    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB
    IF elemIdx < 1 OR elemIdx > 192 THEN EXIT SUB
    layoutListMultiSel(winIdx, elemIdx) = ""
END SUB

SUB ListSelectionAdd(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER, BYVAL itemValue AS STRING)
    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB
    IF elemIdx < 1 OR elemIdx > 192 THEN EXIT SUB

    itemValue = RTRIM$(itemValue)
    IF itemValue = "" THEN EXIT SUB
    IF ListSelectionContains(winIdx, elemIdx, itemValue) <> 0 THEN EXIT SUB

    IF layoutListMultiSel(winIdx, elemIdx) <> "" THEN layoutListMultiSel(winIdx, elemIdx) = layoutListMultiSel(winIdx, elemIdx) + CHR$(1)
    layoutListMultiSel(winIdx, elemIdx) = layoutListMultiSel(winIdx, elemIdx) + itemValue
END SUB

SUB ListSelectionToggle(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER, BYVAL itemValue AS STRING)
    DIM bag AS STRING
    DIM originalBag AS STRING
    DIM outBag AS STRING
    DIM token AS STRING
    DIM sepPos AS INTEGER
    DIM itemKey AS STRING
    DIM itemWasFound AS INTEGER

    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB
    IF elemIdx < 1 OR elemIdx > 192 THEN EXIT SUB

    itemValue = RTRIM$(itemValue)
    IF itemValue = "" THEN EXIT SUB

    itemKey = UCASE$(itemValue)
    originalBag = layoutListMultiSel(winIdx, elemIdx)
    bag = originalBag
    outBag = ""
    itemWasFound = 0

    DO WHILE bag <> ""
        sepPos = INSTR(bag, CHR$(1))
        IF sepPos > 0 THEN
            token = LEFT$(bag, sepPos - 1)
            bag = MID$(bag, sepPos + 1)
        ELSE
            token = bag
            bag = ""
        END IF

        token = RTRIM$(token)
        IF UCASE$(token) = itemKey THEN
            itemWasFound = -1
        ELSE
            IF outBag <> "" THEN outBag = outBag + CHR$(1)
            outBag = outBag + token
        END IF
    LOOP

    IF itemWasFound <> 0 THEN
        layoutListMultiSel(winIdx, elemIdx) = outBag
    ELSE
        IF originalBag <> "" THEN originalBag = originalBag + CHR$(1)
        layoutListMultiSel(winIdx, elemIdx) = originalBag + itemValue
    END IF
END SUB
SUB ListSelectionSelectAll(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER)
    DIM i AS INTEGER
    DIM j AS INTEGER
    DIM itemValue AS STRING
    DIM itemKey AS STRING
    DIM outBag AS STRING
    DIM itemCount AS INTEGER
    DIM cacheSlot AS INTEGER
    DIM seenCount AS INTEGER
    DIM itemAlreadySeen AS INTEGER
    DIM seenKeys(1 TO 256) AS STRING

    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB
    IF elemIdx < 1 OR elemIdx > uiCount THEN EXIT SUB

    outBag = ""
    seenCount = 0
    itemCount = ComboFastItemCount(elemIdx, cacheSlot)

    FOR i = 1 TO itemCount
        itemValue = RTRIM$(ComboFastItemValue(cacheSlot, i))
        IF itemValue <> "" THEN
            itemKey = UCASE$(itemValue)
            itemAlreadySeen = 0

            FOR j = 1 TO seenCount
                IF seenKeys(j) = itemKey THEN
                    itemAlreadySeen = -1
                    EXIT FOR
                END IF
            NEXT

            IF itemAlreadySeen = 0 THEN
                seenCount = seenCount + 1
                seenKeys(seenCount) = itemKey
                IF outBag <> "" THEN outBag = outBag + CHR$(1)
                outBag = outBag + itemValue
            END IF
        END IF
    NEXT

    layoutListMultiSel(winIdx, elemIdx) = outBag
END SUB
SUB ListSelectionSelectRange(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER, BYVAL firstIdx AS INTEGER, BYVAL lastIdx AS INTEGER)
    DIM i AS INTEGER
    DIM j AS INTEGER
    DIM loIdx AS INTEGER
    DIM hiIdx AS INTEGER
    DIM itemValue AS STRING
    DIM itemKey AS STRING
    DIM outBag AS STRING
    DIM itemCount AS INTEGER
    DIM cacheSlot AS INTEGER
    DIM seenCount AS INTEGER
    DIM itemAlreadySeen AS INTEGER
    DIM seenKeys(1 TO 256) AS STRING

    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB
    IF elemIdx < 1 OR elemIdx > uiCount THEN EXIT SUB

    itemCount = ComboFastItemCount(elemIdx, cacheSlot)
    IF itemCount < 1 THEN EXIT SUB

    IF firstIdx < 1 OR firstIdx > itemCount THEN firstIdx = lastIdx
    IF lastIdx < 1 OR lastIdx > itemCount THEN lastIdx = firstIdx

    IF firstIdx <= lastIdx THEN
        loIdx = firstIdx
        hiIdx = lastIdx
    ELSE
        loIdx = lastIdx
        hiIdx = firstIdx
    END IF

    outBag = ""
    seenCount = 0

    FOR i = loIdx TO hiIdx
        itemValue = RTRIM$(ComboFastItemValue(cacheSlot, i))
        IF itemValue <> "" THEN
            itemKey = UCASE$(itemValue)
            itemAlreadySeen = 0

            FOR j = 1 TO seenCount
                IF seenKeys(j) = itemKey THEN
                    itemAlreadySeen = -1
                    EXIT FOR
                END IF
            NEXT

            IF itemAlreadySeen = 0 THEN
                seenCount = seenCount + 1
                seenKeys(seenCount) = itemKey
                IF outBag <> "" THEN outBag = outBag + CHR$(1)
                outBag = outBag + itemValue
            END IF
        END IF
    NEXT

    layoutListMultiSel(winIdx, elemIdx) = outBag
END SUB
FUNCTION DelimitedListCount(BYVAL itemList AS STRING) AS INTEGER
    DIM sepPos AS INTEGER
    DIM itemStart AS INTEGER
    DIM itemLen AS INTEGER
    DIM token AS STRING
    DIM itemCount AS INTEGER

    itemCount = 0
    itemLen = LEN(itemList)
    itemStart = 1

    DO WHILE itemStart <= itemLen
        sepPos = INSTR(itemStart, itemList, CHR$(1))
        IF sepPos > 0 THEN
            token = MID$(itemList, itemStart, sepPos - itemStart)
            itemStart = sepPos + 1
        ELSE
            token = MID$(itemList, itemStart)
            itemStart = itemLen + 1
        END IF

        IF TRIM$(token) <> "" THEN itemCount = itemCount + 1
    LOOP

    RETURN itemCount
END FUNCTION
FUNCTION ListSelectionFilePaths(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER, BYVAL fallbackValue AS STRING) AS STRING
    DIM bag AS STRING
    DIM outBag AS STRING
    DIM token AS STRING
    DIM itemPath AS STRING
    DIM sepPos AS INTEGER
    DIM itemStart AS INTEGER
    DIM itemLen AS INTEGER

    outBag = ""

    IF winIdx >= LBOUND(layoutWindows) AND winIdx <= UBOUND(layoutWindows) THEN
        IF elemIdx >= 1 AND elemIdx <= 192 THEN
            bag = layoutListMultiSel(winIdx, elemIdx)
            itemLen = LEN(bag)
            itemStart = 1

            DO WHILE itemStart <= itemLen
                sepPos = INSTR(itemStart, bag, CHR$(1))
                IF sepPos > 0 THEN
                    token = MID$(bag, itemStart, sepPos - itemStart)
                    itemStart = sepPos + 1
                ELSE
                    token = MID$(bag, itemStart)
                    itemStart = itemLen + 1
                END IF

                token = RTRIM$(token)
                IF LEFT$(UCASE$(token), 2) = "F:" THEN
                    itemPath = NormalizePath(MID$(token, 3))
                    IF itemPath <> "" THEN
                        IF outBag <> "" THEN outBag = outBag + CHR$(1)
                        outBag = outBag + itemPath
                    END IF
                END IF
            LOOP
        END IF
    END IF

    IF outBag = "" THEN
        fallbackValue = RTRIM$(fallbackValue)
        IF LEFT$(UCASE$(fallbackValue), 2) = "F:" THEN
            itemPath = NormalizePath(MID$(fallbackValue, 3))
            IF itemPath <> "" THEN outBag = itemPath
        END IF
    END IF

    RETURN outBag
END FUNCTION
FUNCTION ListSelectionBrowserPaths(BYVAL winIdx AS INTEGER, BYVAL elemIdx AS INTEGER, BYVAL fallbackValue AS STRING) AS STRING
    DIM bag AS STRING
    DIM outBag AS STRING
    DIM token AS STRING
    DIM itemPath AS STRING
    DIM sepPos AS INTEGER
    DIM itemStart AS INTEGER
    DIM itemLen AS INTEGER

    outBag = ""

    IF winIdx >= LBOUND(layoutWindows) AND winIdx <= UBOUND(layoutWindows) THEN
        IF elemIdx >= 1 AND elemIdx <= 192 THEN
            bag = layoutListMultiSel(winIdx, elemIdx)
            itemLen = LEN(bag)
            itemStart = 1

            DO WHILE itemStart <= itemLen
                sepPos = INSTR(itemStart, bag, CHR$(1))
                IF sepPos > 0 THEN
                    token = MID$(bag, itemStart, sepPos - itemStart)
                    itemStart = sepPos + 1
                ELSE
                    token = MID$(bag, itemStart)
                    itemStart = itemLen + 1
                END IF

                token = RTRIM$(token)
                IF LEFT$(UCASE$(token), 2) = "F:" THEN
                    itemPath = NormalizePath(MID$(token, 3))
                ELSEIF LEFT$(UCASE$(token), 2) = "D:" THEN
                    itemPath = AbsoluteDirPath(MID$(token, 3))
                ELSE
                    itemPath = ""
                END IF

                IF itemPath <> "" THEN
                    IF outBag <> "" THEN outBag = outBag + CHR$(1)
                    outBag = outBag + itemPath
                END IF
            LOOP
        END IF
    END IF

    IF outBag = "" THEN
        fallbackValue = RTRIM$(fallbackValue)
        IF LEFT$(UCASE$(fallbackValue), 2) = "F:" THEN
            itemPath = NormalizePath(MID$(fallbackValue, 3))
        ELSEIF LEFT$(UCASE$(fallbackValue), 2) = "D:" THEN
            itemPath = AbsoluteDirPath(MID$(fallbackValue, 3))
        ELSE
            itemPath = ""
        END IF
        IF itemPath <> "" THEN outBag = itemPath
    END IF

    RETURN outBag
END FUNCTION

FUNCTION ActiveLayoutListBoxItemValueAtPoint(BYVAL elemIdx AS INTEGER, BYVAL px AS INTEGER, BYVAL py AS INTEGER) AS STRING
    DIM ex AS INTEGER
    DIM ey AS INTEGER
    DIM ew AS INTEGER
    DIM eh AS INTEGER
    DIM itemCount AS INTEGER
    DIM cacheSlot AS INTEGER
    DIM itemH AS INTEGER
    DIM rowsVisible AS INTEGER
    DIM textRight AS INTEGER
    DIM itemIdx AS INTEGER

    IF activeLayoutWindow < LBOUND(layoutWindows) OR activeLayoutWindow > UBOUND(layoutWindows) THEN RETURN ""
    IF layoutWindows(activeLayoutWindow).used = 0 THEN RETURN ""
    IF elemIdx < 1 OR elemIdx > uiCount THEN RETURN ""
    IF uiElems(elemIdx).kindId <> UI_KIND_LISTBOX THEN RETURN ""

    ex = uiWinX + uiElems(elemIdx).x - uiScrollX
    ey = uiWinY + 22 + uiElems(elemIdx).y - uiScrollY
    ew = uiElems(elemIdx).w
    eh = uiElems(elemIdx).h
    IF ew <= 0 THEN ew = 120
    IF eh <= 0 THEN eh = 100

    itemCount = ComboFastItemCount(elemIdx, cacheSlot)
    itemH = 16
    rowsVisible = (eh - 4) \ itemH
    IF rowsVisible < 1 THEN rowsVisible = 1
    comboScrollTop(activeLayoutWindow, elemIdx) = ClampScrollPos(comboScrollTop(activeLayoutWindow, elemIdx), itemCount - rowsVisible)

    textRight = ex + ew - 2
    IF itemCount > rowsVisible THEN textRight = ex + ew - 16
    IF px < ex + 2 OR px > textRight THEN RETURN ""
    IF py < ey + 2 OR py > ey + eh - 2 THEN RETURN ""

    itemIdx = comboScrollTop(activeLayoutWindow, elemIdx) + ((py - (ey + 2)) \ itemH) + 1
    IF itemIdx < 1 OR itemIdx > itemCount THEN RETURN ""

    RETURN ComboFastItemValue(cacheSlot, itemIdx)
END FUNCTION
FUNCTION ContextMenuCfgValue(BYVAL ownerWin AS INTEGER, BYVAL keyName AS STRING, BYVAL defaultValue AS STRING) AS STRING
    DIM appPath AS STRING
    DIM lookupKey AS STRING

    appPath = ""
    IF ownerWin >= LBOUND(layoutWindows) AND ownerWin <= UBOUND(layoutWindows) THEN
        IF layoutWindows(ownerWin).used <> 0 THEN appPath = RTRIM$(layoutWindows(ownerWin).appPath)
    END IF

    IF ctxMenuCfgReady = 0 OR ctxMenuCfgOwnerWin <> ownerWin OR ctxMenuCfgAppPath <> appPath THEN
        ctxMenuCfgOwnerWin = ownerWin
        ctxMenuCfgAppPath = appPath
        ctxMenuCfgOpenText = AppCfgValue(appPath, "CONTEXT_OPEN_TEXT", "Open")
        ctxMenuCfgDirOpenText = AppCfgValue(appPath, "CONTEXT_DIR_OPEN_TEXT", ctxMenuCfgOpenText)
        ctxMenuCfgNewDirText = AppCfgValue(appPath, "CONTEXT_NEW_DIR_TEXT", "New Directory")
        ctxMenuCfgEditText = AppCfgValue(appPath, "CONTEXT_EDIT_TEXT", "Edit")
        ctxMenuCfgCutText = AppCfgValue(appPath, "CONTEXT_CUT_TEXT", "")
        ctxMenuCfgCopyText = AppCfgValue(appPath, "CONTEXT_COPY_TEXT", "")
        ctxMenuCfgDuplicateText = AppCfgValue(appPath, "CONTEXT_DUPLICATE_TEXT", "")
        ctxMenuCfgPasteText = AppCfgValue(appPath, "CONTEXT_PASTE_TEXT", "")
        ctxMenuCfgRenameText = AppCfgValue(appPath, "CONTEXT_RENAME_TEXT", "Rename")
        ctxMenuCfgDeleteText = AppCfgValue(appPath, "CONTEXT_DELETE_TEXT", "Delete")
        ctxMenuCfgPropText = AppCfgValue(appPath, "CONTEXT_PROPERTIES_TEXT", "Properties")
        ctxMenuCfgReady = -1
    END IF

    lookupKey = UCASE$(TRIM$(keyName))
    SELECT CASE lookupKey
    CASE "CONTEXT_OPEN_TEXT"
        RETURN ctxMenuCfgOpenText
    CASE "CONTEXT_DIR_OPEN_TEXT"
        RETURN ctxMenuCfgDirOpenText
    CASE "CONTEXT_NEW_DIR_TEXT"
        RETURN ctxMenuCfgNewDirText
    CASE "CONTEXT_EDIT_TEXT"
        RETURN ctxMenuCfgEditText
    CASE "CONTEXT_CUT_TEXT"
        RETURN ctxMenuCfgCutText
    CASE "CONTEXT_COPY_TEXT"
        RETURN ctxMenuCfgCopyText
    CASE "CONTEXT_DUPLICATE_TEXT"
        RETURN ctxMenuCfgDuplicateText
    CASE "CONTEXT_PASTE_TEXT"
        RETURN ctxMenuCfgPasteText
    CASE "CONTEXT_RENAME_TEXT"
        RETURN ctxMenuCfgRenameText
    CASE "CONTEXT_DELETE_TEXT"
        RETURN ctxMenuCfgDeleteText
    CASE "CONTEXT_PROPERTIES_TEXT"
        RETURN ctxMenuCfgPropText
    END SELECT

    RETURN defaultValue
END FUNCTION

FUNCTION ContextPasteTargetControlName(BYVAL ownerWin AS INTEGER) AS STRING
    DIM appPath AS STRING
    DIM targetName AS STRING

    appPath = ""
    targetName = ""

    IF ownerWin >= LBOUND(layoutWindows) AND ownerWin <= UBOUND(layoutWindows) THEN
        IF layoutWindows(ownerWin).used <> 0 THEN
            appPath = RTRIM$(layoutWindows(ownerWin).appPath)
            targetName = TRIM$(AppCfgValue(appPath, "CONTEXT_PASTE_CONTROL", ""))
            IF targetName = "" THEN targetName = TRIM$(AppCfgValue(appPath, "FILE_BROWSER_FILE_CONTROL", ""))
        END IF
    END IF

    RETURN targetName
END FUNCTION

FUNCTION IsContextPasteTargetControl(BYVAL ownerWin AS INTEGER, BYVAL elemIdx AS INTEGER) AS INTEGER
    DIM targetName AS STRING
    DIM appPath AS STRING

    IF elemIdx < 1 OR elemIdx > uiCount THEN RETURN 0
    IF uiElems(elemIdx).kindKey <> "LISTBOX" THEN RETURN 0

    targetName = ContextPasteTargetControlName(ownerWin)
    IF targetName <> "" THEN
        IF uiElems(elemIdx).nameKey = UCASE$(targetName) THEN RETURN -1
        RETURN 0
    END IF

    IF uiElems(elemIdx).multiSelect = 0 THEN RETURN 0

    IF ownerWin >= LBOUND(layoutWindows) AND ownerWin <= UBOUND(layoutWindows) THEN
        IF layoutWindows(ownerWin).used <> 0 THEN
            appPath = RTRIM$(layoutWindows(ownerWin).appPath)
            IF TRIM$(AppCfgValue(appPath, "CONTEXT_PASTE_ACTION", "")) <> "" THEN RETURN -1
        END IF
    END IF

    RETURN 0
END FUNCTION

FUNCTION ContextMenuRowCount(BYVAL ownerWin AS INTEGER, BYVAL isDir AS INTEGER, BYVAL pasteOnly AS INTEGER) AS INTEGER
    DIM rowCount AS INTEGER

    IF pasteOnly <> 0 THEN RETURN 1

    IF isDir <> 0 THEN
        rowCount = 5
        IF TRIM$(ContextMenuCfgValue(ownerWin, "CONTEXT_COPY_TEXT", "")) <> "" THEN rowCount = rowCount + 1
    ELSE
        rowCount = 5
        IF TRIM$(ContextMenuCfgValue(ownerWin, "CONTEXT_CUT_TEXT", "")) <> "" THEN rowCount = rowCount + 1
        IF TRIM$(ContextMenuCfgValue(ownerWin, "CONTEXT_COPY_TEXT", "")) <> "" THEN rowCount = rowCount + 1
        IF TRIM$(ContextMenuCfgValue(ownerWin, "CONTEXT_DUPLICATE_TEXT", "")) <> "" THEN rowCount = rowCount + 1
    END IF

    RETURN rowCount
END FUNCTION

FUNCTION ContextMenuHeight(BYVAL ownerWin AS INTEGER, BYVAL isDir AS INTEGER, BYVAL pasteOnly AS INTEGER) AS INTEGER
    RETURN (ContextMenuRowCount(ownerWin, isDir, pasteOnly) * 18) + 10
END FUNCTION

SUB DrawSimpleContextMenu(BYVAL menuX AS INTEGER, BYVAL menuY AS INTEGER, BYVAL editEnabled AS INTEGER, BYVAL isDir AS INTEGER, BYVAL ownerWin AS INTEGER, BYVAL pasteOnly AS INTEGER)
    DIM menuW AS INTEGER
    DIM menuH AS INTEGER
    DIM editCol AS UINTEGER
    DIM openText AS STRING
    DIM newDirText AS STRING
    DIM editText AS STRING
    DIM cutText AS STRING
    DIM copyText AS STRING
    DIM duplicateText AS STRING
    DIM pasteText AS STRING
    DIM renameText AS STRING
    DIM deleteText AS STRING
    DIM propText AS STRING
    DIM rowY AS INTEGER

    menuW = 112

    IF isDir <> 0 THEN
        openText = ContextMenuCfgValue(ownerWin, "CONTEXT_DIR_OPEN_TEXT", ContextMenuCfgValue(ownerWin, "CONTEXT_OPEN_TEXT", "Open"))
    ELSE
        openText = ContextMenuCfgValue(ownerWin, "CONTEXT_OPEN_TEXT", "Open")
    END IF
    newDirText = ContextMenuCfgValue(ownerWin, "CONTEXT_NEW_DIR_TEXT", "New Directory")
    editText = ContextMenuCfgValue(ownerWin, "CONTEXT_EDIT_TEXT", "Edit")
    cutText = ContextMenuCfgValue(ownerWin, "CONTEXT_CUT_TEXT", "")
    copyText = ContextMenuCfgValue(ownerWin, "CONTEXT_COPY_TEXT", "")
    duplicateText = ContextMenuCfgValue(ownerWin, "CONTEXT_DUPLICATE_TEXT", "")
    pasteText = ContextMenuCfgValue(ownerWin, "CONTEXT_PASTE_TEXT", "")
    renameText = ContextMenuCfgValue(ownerWin, "CONTEXT_RENAME_TEXT", "Rename")
    deleteText = ContextMenuCfgValue(ownerWin, "CONTEXT_DELETE_TEXT", "Delete")
    propText = ContextMenuCfgValue(ownerWin, "CONTEXT_PROPERTIES_TEXT", "Properties")

    menuH = ContextMenuHeight(ownerWin, isDir, pasteOnly)

    IF menuX + menuW > SCR_W - 1 THEN menuX = SCR_W - 1 - menuW
    IF menuY + menuH - 1 > WORK_BOTTOM THEN menuY = WORK_BOTTOM - menuH + 1
    IF menuX < 0 THEN menuX = 0
    IF menuY < WORK_Y THEN menuY = WORK_Y

    DrawBevelBox menuX, menuY, menuX + menuW, menuY + menuH, 0
    LINE (menuX + 2, menuY + 2)-(menuX + menuW - 2, menuY + menuH - 2), COL_TASKBAR, BF

    rowY = menuY + 8

    IF pasteOnly <> 0 THEN
        DRAW STRING (menuX + 8, rowY), pasteText, COL_TEXT
        EXIT SUB
    END IF

    DRAW STRING (menuX + 8, rowY), openText, COL_TEXT
    rowY = rowY + 18

    IF isDir <> 0 THEN
        DRAW STRING (menuX + 8, rowY), newDirText, COL_TEXT
        rowY = rowY + 18
        IF TRIM$(copyText) <> "" THEN
            DRAW STRING (menuX + 8, rowY), copyText, COL_TEXT
            rowY = rowY + 18
        END IF
    END IF

    IF isDir = 0 THEN
        IF editEnabled <> 0 THEN
            editCol = COL_TEXT
        ELSE
            editCol = MakeCol(128, 128, 128)
        END IF
        DRAW STRING (menuX + 8, rowY), editText, editCol
        rowY = rowY + 18

        IF TRIM$(cutText) <> "" THEN
            DRAW STRING (menuX + 8, rowY), cutText, COL_TEXT
            rowY = rowY + 18
        END IF
        IF TRIM$(copyText) <> "" THEN
            DRAW STRING (menuX + 8, rowY), copyText, COL_TEXT
            rowY = rowY + 18
        END IF
        IF TRIM$(duplicateText) <> "" THEN
            DRAW STRING (menuX + 8, rowY), duplicateText, COL_TEXT
            rowY = rowY + 18
        END IF
    END IF

    DRAW STRING (menuX + 8, rowY), renameText, COL_TEXT
    rowY = rowY + 18
    DRAW STRING (menuX + 8, rowY), deleteText, COL_TEXT
    rowY = rowY + 18
    DRAW STRING (menuX + 8, rowY), propText, COL_TEXT
END SUB

SUB DrawMenuPanel(BYVAL parentIdx AS INTEGER, BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL level AS INTEGER, BYVAL hoverIndex AS INTEGER)
    DIM y2 AS INTEGER
    DIM py1 AS INTEGER
    DIM x2 AS INTEGER
    DIM panelH AS INTEGER
    DIM panelW AS INTEGER
    DIM childX AS INTEGER
    DIM childY AS INTEGER
    DIM childW AS INTEGER
    DIM childH AS INTEGER
    DIM i AS INTEGER
    DIM roomRight AS INTEGER
    DIM roomLeft AS INTEGER
    DIM imgW AS INTEGER
    DIM imgH AS INTEGER

    panelW = MenuPanelWidth(parentIdx)
    panelH = MenuPanelHeight(parentIdx)
    x2 = x1 + panelW
    y2 = y1 + panelH

    IF y1 < WORK_Y THEN
        y1 = WORK_Y
        y2 = y1 + panelH
    END IF
    IF y2 > WORK_BOTTOM THEN
        y1 = WORK_BOTTOM - panelH
        y2 = y1 + panelH
    END IF
    IF x1 < 0 THEN
        x1 = 0
        x2 = x1 + panelW
    END IF
    IF x2 > SCR_W - 1 THEN
        x1 = SCR_W - 1 - panelW
        x2 = x1 + panelW
    END IF

    menuPanels(level).parentIdx = parentIdx
    menuPanels(level).x1 = x1
    menuPanels(level).y1 = y1
    menuPanels(level).x2 = x2
    menuPanels(level).y2 = y2
    menuPanels(level).level = level
    startMenuNearPanelCacheValid = 0
    IF level > menuPanelCount THEN menuPanelCount = level

    BuildMenuPanelMetrics parentIdx
    RecordStartMenuPanelRows parentIdx, x1, y1, x2, level

    imgW = x2 - x1 + 1
    imgH = y2 - y1 + 1

    CaptureStartMenuBranchBackBuffer level, x1, y1, x2, y2

    IF PutStartMenuPanelBaseFromCache(parentIdx, x1, y1, imgW, imgH) = 0 THEN
        DrawStartMenuPanelBase parentIdx, x1, y1, x2, y2, level
        CaptureStartMenuPanelBaseCache parentIdx, x1, y1, x2, y2
    END IF

    DrawStartMenuPanelHotRows parentIdx, level, hoverIndex

    IF level <= 7 AND menuOpenItem(level) > 0 THEN
        i = menuOpenItem(level)
        IF i >= 1 AND i <= menuCount THEN
            IF menuItemHasSubmenu(i) <> 0 AND menuItems(i).parentIdx = parentIdx AND menuItemRowVisible(i) <> 0 THEN
                py1 = menuItemRowY1(i)
                childW = MenuPanelWidth(i)
                childH = MenuPanelHeight(i)

                roomRight = (SCR_W - 1) - (x2 - 3)
                roomLeft = x1

                IF roomRight >= childW THEN
                    childX = x2 - 3
                ELSEIF roomLeft >= childW THEN
                    childX = x1 - childW + 3
                ELSEIF roomRight >= roomLeft THEN
                    childX = x2 - 3
                ELSE
                    childX = x1 - childW + 3
                END IF

                childY = py1 - 1

                IF childX < 0 THEN childX = 0
                IF childX + childW > SCR_W - 1 THEN childX = SCR_W - 1 - childW
                IF childY + childH - 1 > WORK_BOTTOM THEN childY = WORK_BOTTOM - childH + 1
                IF childY < WORK_Y THEN childY = WORK_Y

                DrawMenuPanel i, childX, childY, level + 1, hoverIndex
            END IF
        END IF
    END IF
END SUB

' ---------------------------
' Start menu backing, launch menu context, and desktop right-click menus
' ---------------------------

SUB AddStartMenuBackRect(BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER, BYREF rx1 AS INTEGER, BYREF ry1 AS INTEGER, BYREF rx2 AS INTEGER, BYREF ry2 AS INTEGER)
    IF x1 < 0 THEN x1 = 0
    IF y1 < 0 THEN y1 = 0
    IF x2 > SCR_W - 1 THEN x2 = SCR_W - 1
    IF y2 > SCR_H - 1 THEN y2 = SCR_H - 1
    IF x2 < x1 OR y2 < y1 THEN EXIT SUB

    IF rx1 < 0 THEN
        rx1 = x1
        ry1 = y1
        rx2 = x2
        ry2 = y2
    ELSE
        IF x1 < rx1 THEN rx1 = x1
        IF y1 < ry1 THEN ry1 = y1
        IF x2 > rx2 THEN rx2 = x2
        IF y2 > ry2 THEN ry2 = y2
    END IF
END SUB

SUB ComputeStartMenuBackRect(BYVAL parentIdx AS INTEGER, BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL level AS INTEGER, BYREF rx1 AS INTEGER, BYREF ry1 AS INTEGER, BYREF rx2 AS INTEGER, BYREF ry2 AS INTEGER)
    DIM panelW AS INTEGER
    DIM panelH AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER
    DIM i AS INTEGER
    DIM curY AS INTEGER
    DIM itemH AS INTEGER
    DIM py1 AS INTEGER
    DIM childW AS INTEGER
    DIM childH AS INTEGER
    DIM childX AS INTEGER
    DIM childY AS INTEGER
    DIM roomRight AS INTEGER
    DIM roomLeft AS INTEGER

    panelW = MenuPanelWidth(parentIdx)
    panelH = MenuPanelHeight(parentIdx)
    x2 = x1 + panelW
    y2 = y1 + panelH

    IF y1 < WORK_Y THEN
        y1 = WORK_Y
        y2 = y1 + panelH
    END IF
    IF y2 > WORK_BOTTOM THEN
        y1 = WORK_BOTTOM - panelH
        y2 = y1 + panelH
    END IF
    IF x1 < 0 THEN
        x1 = 0
        x2 = x1 + panelW
    END IF
    IF x2 > SCR_W - 1 THEN
        x1 = SCR_W - 1 - panelW
        x2 = x1 + panelW
    END IF

    AddStartMenuBackRect x1, y1, x2, y2, rx1, ry1, rx2, ry2

    IF level <= 7 AND menuOpenItem(level) > 0 THEN
        i = menuOpenItem(level)
        IF i >= 1 AND i <= menuCount THEN
            IF menuItems(i).isSubmenu <> 0 AND menuItems(i).parentIdx = parentIdx THEN
                py1 = -1

                ' When the parent panel is already on screen, reuse the exact stored row Y.
                ' This removes the normal submenu-hover rescan from the backing-rect path.
                IF menuItemRowVisible(i) <> 0 AND menuItemRowLevel(i) = level THEN
                    py1 = menuItemRowY1(i)
                ELSE
                    curY = y1 + MENU_PANEL_PAD_Y
                    IF menuChildCacheValid = 0 THEN BuildLaunchMenuCaches
                    i = menuFirstChild(parentIdx)
                    DO WHILE i <> 0
                        itemH = MenuItemPixelHeight(i)
                        IF i = menuOpenItem(level) THEN
                            py1 = curY
                            EXIT DO
                        END IF
                        curY = curY + itemH
                        i = menuNextSibling(i)
                    LOOP
                    i = menuOpenItem(level)
                END IF

                IF py1 >= 0 THEN
                    childW = MenuPanelWidth(i)
                    childH = MenuPanelHeight(i)
                    roomRight = (SCR_W - 1) - (x2 - 3)
                    roomLeft = x1

                    IF roomRight >= childW THEN
                        childX = x2 - 3
                    ELSEIF roomLeft >= childW THEN
                        childX = x1 - childW + 3
                    ELSEIF roomRight >= roomLeft THEN
                        childX = x2 - 3
                    ELSE
                        childX = x1 - childW + 3
                    END IF

                    childY = py1 - 1

                    IF childX < 0 THEN childX = 0
                    IF childX + childW > SCR_W - 1 THEN childX = SCR_W - 1 - childW
                    IF childY + childH - 1 > WORK_BOTTOM THEN childY = WORK_BOTTOM - childH + 1
                    IF childY < WORK_Y THEN childY = WORK_Y

                    ComputeStartMenuBackRect i, childX, childY, level + 1, rx1, ry1, rx2, ry2
                END IF
            END IF
        END IF
    END IF
END SUB



FUNCTION StartMenuBackBufferCoversOpenBranch() AS INTEGER
    DIM rx1 AS INTEGER
    DIM ry1 AS INTEGER
    DIM rx2 AS INTEGER
    DIM ry2 AS INTEGER

    IF startMenuBackBuffer = 0 OR startMenuBackValid = 0 THEN RETURN 0

    rx1 = -1
    ry1 = -1
    rx2 = -1
    ry2 = -1
    ComputeStartMenuBackRect 0, MENU_X1, MenuY1(), 0, rx1, ry1, rx2, ry2

    IF rx1 < 0 OR ry1 < 0 OR rx2 < rx1 OR ry2 < ry1 THEN RETURN 0
    IF startMenuBackX > rx1 THEN RETURN 0
    IF startMenuBackY > ry1 THEN RETURN 0
    IF startMenuBackX + startMenuBackW - 1 < rx2 THEN RETURN 0
    IF startMenuBackY + startMenuBackH - 1 < ry2 THEN RETURN 0

    RETURN -1
END FUNCTION

SUB ClearStartMenuRowsFromLevel(BYVAL firstLevel AS INTEGER)
    DIM rowPos AS INTEGER
    DIM writePos AS INTEGER
    DIM itemIdx AS INTEGER
    DIM clearCount AS INTEGER
    DIM lvl AS INTEGER

    InvalidateStartMenuHitCache

    IF firstLevel < 0 THEN firstLevel = 0
    IF firstLevel > 8 THEN EXIT SUB

    clearCount = menuVisibleRowCount
    IF clearCount < 0 THEN clearCount = 0
    IF clearCount > MAX_MENU_ITEMS THEN clearCount = MAX_MENU_ITEMS

    writePos = 0
    FOR rowPos = 1 TO clearCount
        itemIdx = menuVisibleRowItems(rowPos)
        IF itemIdx >= 1 AND itemIdx <= MAX_MENU_ITEMS THEN
            IF menuItemRowVisible(itemIdx) <> 0 AND menuItemRowLevel(itemIdx) >= firstLevel THEN
                menuItemRowVisible(itemIdx) = 0
                menuItemRowX1(itemIdx) = 0
                menuItemRowY1(itemIdx) = 0
                menuItemRowX2(itemIdx) = 0
                menuItemRowY2(itemIdx) = 0
                menuItemRowLevel(itemIdx) = 0
            ELSE
                writePos = writePos + 1
                menuVisibleRowItems(writePos) = itemIdx
            END IF
        END IF
    NEXT

    FOR rowPos = writePos + 1 TO clearCount
        menuVisibleRowItems(rowPos) = 0
    NEXT
    menuVisibleRowCount = writePos

    FOR lvl = firstLevel TO 8
        menuPanels(lvl).parentIdx = 0
        menuPanels(lvl).x1 = 0
        menuPanels(lvl).y1 = 0
        menuPanels(lvl).x2 = 0
        menuPanels(lvl).y2 = 0
        menuPanels(lvl).level = 0
    NEXT

    IF firstLevel <= 0 THEN
        menuPanelCount = 0
    ELSEIF menuPanelCount >= firstLevel THEN
        menuPanelCount = firstLevel - 1
    END IF
END SUB

SUB CaptureStartMenuBranchBackBuffer(BYVAL level AS INTEGER, BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER)
    DIM newW AS INTEGER
    DIM newH AS INTEGER

    IF level < 0 OR level > 8 THEN EXIT SUB
    IF x1 < 0 THEN x1 = 0
    IF y1 < 0 THEN y1 = 0
    IF x2 > SCR_W - 1 THEN x2 = SCR_W - 1
    IF y2 > SCR_H - 1 THEN y2 = SCR_H - 1
    IF x2 < x1 OR y2 < y1 THEN
        startMenuBranchBackValid(level) = 0
        EXIT SUB
    END IF

    newW = x2 - x1 + 1
    newH = y2 - y1 + 1

    IF startMenuBranchBackImg(level) = 0 OR startMenuBranchBackW(level) <> newW OR startMenuBranchBackH(level) <> newH THEN
        IF startMenuBranchBackImg(level) <> 0 THEN
            ImageDestroy startMenuBranchBackImg(level)
            startMenuBranchBackImg(level) = 0
        END IF
        startMenuBranchBackImg(level) = ImageCreate(newW, newH, 0)
        startMenuBranchBackW(level) = newW
        startMenuBranchBackH(level) = newH
    END IF

    IF startMenuBranchBackImg(level) = 0 THEN
        startMenuBranchBackValid(level) = 0
        EXIT SUB
    END IF

    startMenuBranchBackX(level) = x1
    startMenuBranchBackY(level) = y1
    GET (x1, y1)-(x2, y2), startMenuBranchBackImg(level)
    startMenuBranchBackValid(level) = -1
END SUB

FUNCTION RestoreStartMenuBranchFromLevel(BYVAL firstLevel AS INTEGER) AS INTEGER
    DIM lvl AS INTEGER

    IF firstLevel < 1 THEN firstLevel = 1
    IF firstLevel > 8 THEN RETURN -1

    IF startMenuBranchOldItem <> 0 THEN
        IF startMenuBranchBackValid(firstLevel) = 0 OR startMenuBranchBackImg(firstLevel) = 0 THEN RETURN 0
    END IF

    FOR lvl = 8 TO firstLevel STEP -1
        IF startMenuBranchBackValid(lvl) <> 0 AND startMenuBranchBackImg(lvl) <> 0 THEN
            PUT (startMenuBranchBackX(lvl), startMenuBranchBackY(lvl)), startMenuBranchBackImg(lvl), PSET
            startMenuBranchBackValid(lvl) = 0
        END IF
    NEXT

    RETURN -1
END FUNCTION

SUB RedrawStartMenuRowsThroughLevel(BYVAL maxLevel AS INTEGER, BYVAL hoverIndex AS INTEGER)
    DIM rowPos AS INTEGER
    DIM itemIdx AS INTEGER
    DIM clearCount AS INTEGER

    IF maxLevel < 0 THEN EXIT SUB
    IF maxLevel > 8 THEN maxLevel = 8

    clearCount = menuVisibleRowCount
    IF clearCount < 0 THEN clearCount = 0
    IF clearCount > MAX_MENU_ITEMS THEN clearCount = MAX_MENU_ITEMS

    FOR rowPos = 1 TO clearCount
        itemIdx = menuVisibleRowItems(rowPos)
        IF itemIdx >= 1 AND itemIdx <= menuCount THEN
            IF menuItemRowVisible(itemIdx) <> 0 THEN
                IF menuItemRowLevel(itemIdx) <= maxLevel THEN DrawStartMenuItemRow itemIdx, hoverIndex
            END IF
        END IF
    NEXT
END SUB

FUNCTION DrawStartMenuChildBranchFromLevel(BYVAL parentLevel AS INTEGER, BYVAL hoverIndex AS INTEGER) AS INTEGER
    DIM itemIdx AS INTEGER
    DIM x1 AS INTEGER
    DIM x2 AS INTEGER
    DIM py1 AS INTEGER
    DIM childW AS INTEGER
    DIM childH AS INTEGER
    DIM childX AS INTEGER
    DIM childY AS INTEGER
    DIM roomRight AS INTEGER
    DIM roomLeft AS INTEGER

    IF parentLevel < 0 OR parentLevel > 7 THEN RETURN -1
    itemIdx = menuOpenItem(parentLevel)
    IF itemIdx = 0 THEN RETURN -1
    IF itemIdx < 1 OR itemIdx > menuCount THEN RETURN 0
    IF menuItemHasSubmenu(itemIdx) = 0 THEN RETURN -1
    IF menuItemRowVisible(itemIdx) = 0 THEN RETURN 0
    IF menuItemRowLevel(itemIdx) <> parentLevel THEN RETURN 0

    x1 = menuPanels(parentLevel).x1
    x2 = menuPanels(parentLevel).x2
    IF x2 < x1 THEN RETURN 0

    py1 = menuItemRowY1(itemIdx)
    childW = MenuPanelWidth(itemIdx)
    childH = MenuPanelHeight(itemIdx)

    roomRight = (SCR_W - 1) - (x2 - 3)
    roomLeft = x1

    IF roomRight >= childW THEN
        childX = x2 - 3
    ELSEIF roomLeft >= childW THEN
        childX = x1 - childW + 3
    ELSEIF roomRight >= roomLeft THEN
        childX = x2 - 3
    ELSE
        childX = x1 - childW + 3
    END IF

    childY = py1 - 1

    IF childX < 0 THEN childX = 0
    IF childX + childW > SCR_W - 1 THEN childX = SCR_W - 1 - childW
    IF childY + childH - 1 > WORK_BOTTOM THEN childY = WORK_BOTTOM - childH + 1
    IF childY < WORK_Y THEN childY = WORK_Y

    DrawMenuPanel itemIdx, childX, childY, parentLevel + 1, hoverIndex
    RETURN -1
END FUNCTION

FUNCTION DrawStartMenuBranchOnly(BYVAL hoverIndex AS INTEGER, BYVAL mx AS INTEGER, BYVAL my AS INTEGER) AS INTEGER
    DIM parentLevel AS INTEGER
    DIM firstChildLevel AS INTEGER
    DIM drawOk AS INTEGER

    IF startMenuOpen = 0 THEN RETURN 0
    IF startMenuBranchChangeLevel < 0 OR startMenuBranchChangeLevel > 8 THEN RETURN 0
    IF startMenuBackBuffer = 0 OR startMenuBackValid = 0 THEN RETURN 0
    IF StartMenuBackBufferCoversOpenBranch() = 0 THEN RETURN 0

    parentLevel = startMenuBranchChangeLevel
    firstChildLevel = parentLevel + 1
    IF firstChildLevel < 1 THEN firstChildLevel = 1

    SCREENLOCK
    RestoreCursorBackBuffer

    IF RestoreStartMenuBranchFromLevel(firstChildLevel) = 0 THEN
        SaveCursorBackBuffer mx, my
        DrawCursor mx, my
        SCREENUNLOCK
        RETURN 0
    END IF

    ClearStartMenuRowsFromLevel firstChildLevel

    ' Redraw all still-visible parent rows, not just the changed submenu row.
    ' A branch change can happen while the old hover was a different parent row;
    ' redrawing the parent rows clears stale random highlights without rebuilding
    ' the whole Launch menu chain.
    RedrawStartMenuRowsThroughLevel parentLevel, hoverIndex

    drawOk = DrawStartMenuChildBranchFromLevel(parentLevel, hoverIndex)
    IF drawOk = 0 THEN
        SaveCursorBackBuffer mx, my
        DrawCursor mx, my
        SCREENUNLOCK
        RETURN 0
    END IF

    SaveCursorBackBuffer mx, my
    DrawCursor mx, my
    SCREENUNLOCK

    RETURN -1
END FUNCTION
SUB ClearStartMenuRowCache()
    DIM rowPos AS INTEGER
    DIM itemIdx AS INTEGER
    DIM clearCount AS INTEGER

    InvalidateStartMenuHitCache

    clearCount = menuVisibleRowCount
    IF clearCount < 0 THEN clearCount = 0
    IF clearCount > MAX_MENU_ITEMS THEN clearCount = MAX_MENU_ITEMS

    FOR rowPos = 1 TO clearCount
        itemIdx = menuVisibleRowItems(rowPos)
        IF itemIdx >= 1 AND itemIdx <= MAX_MENU_ITEMS THEN
            menuItemRowVisible(itemIdx) = 0
            menuItemRowX1(itemIdx) = 0
            menuItemRowY1(itemIdx) = 0
            menuItemRowX2(itemIdx) = 0
            menuItemRowY2(itemIdx) = 0
            menuItemRowLevel(itemIdx) = 0
        END IF
        menuVisibleRowItems(rowPos) = 0
    NEXT

    menuVisibleRowCount = 0
END SUB


SUB DrawStartMenu(BYVAL hoverIndex AS INTEGER)
    IF cfg.showTaskbar = 0 THEN EXIT SUB
    menuPanelCount = 0
    InvalidateStartMenuBranchBackBuffers
    ClearStartMenuRowCache
    DrawMenuPanel 0, MENU_X1, MenuY1(), 0, hoverIndex
END SUB

SUB OpenLaunchMenuContext(BYVAL menuX AS INTEGER, BYVAL menuY AS INTEGER)
    launchCtxX = menuX
    launchCtxY = menuY

    IF launchCtxX < 0 THEN launchCtxX = 0
    IF launchCtxY < WORK_Y THEN launchCtxY = WORK_Y
    IF launchCtxX + LAUNCH_CTX_W > SCR_W - 1 THEN launchCtxX = SCR_W - 1 - LAUNCH_CTX_W
    IF launchCtxY + LAUNCH_CTX_H - 1 > WORK_BOTTOM THEN launchCtxY = WORK_BOTTOM - LAUNCH_CTX_H + 1
    IF launchCtxX < 0 THEN launchCtxX = 0
    IF launchCtxY < WORK_Y THEN launchCtxY = WORK_Y

    launchCtxOpen = -1
END SUB

FUNCTION LaunchMenuContextHit(BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER) AS INTEGER
    IF launchCtxOpen = 0 THEN RETURN 0
    IF InRect(mouseX, mouseY, launchCtxX, launchCtxY, launchCtxX + LAUNCH_CTX_W, launchCtxY + LAUNCH_CTX_H) THEN RETURN -1
    RETURN 0
END FUNCTION

SUB DrawLaunchMenuContext()
    IF launchCtxOpen = 0 THEN EXIT SUB

    DrawBevelBox launchCtxX, launchCtxY, launchCtxX + LAUNCH_CTX_W, launchCtxY + LAUNCH_CTX_H, 0
    LINE (launchCtxX, launchCtxY)-(launchCtxX + LAUNCH_CTX_W, launchCtxY + LAUNCH_CTX_H), COL_TEXT, B
    DRAW STRING (launchCtxX + 8, launchCtxY + 10), "Launch Menu Editor", COL_TEXT
END SUB

SUB OpenDesktopIconContext(BYVAL menuX AS INTEGER, BYVAL menuY AS INTEGER, BYVAL iconIdx AS INTEGER)
    IF iconIdx < 1 OR iconIdx > iconCount THEN EXIT SUB

    desktopCtxMode = 1
    desktopCtxIcon = iconIdx
    desktopCtxX = menuX
    desktopCtxY = menuY

    IF desktopCtxX < 0 THEN desktopCtxX = 0
    IF desktopCtxY < WORK_Y THEN desktopCtxY = WORK_Y
    IF desktopCtxX + DesktopContextWidth() > SCR_W - 1 THEN desktopCtxX = SCR_W - 1 - DesktopContextWidth()
    IF desktopCtxY + DesktopContextHeight() - 1 > WORK_BOTTOM THEN desktopCtxY = WORK_BOTTOM - DesktopContextHeight() + 1
    IF desktopCtxX < 0 THEN desktopCtxX = 0
    IF desktopCtxY < WORK_Y THEN desktopCtxY = WORK_Y

    selectedIcon = iconIdx
    desktopCtxOpen = -1
END SUB

SUB OpenDesktopEmptyContext(BYVAL menuX AS INTEGER, BYVAL menuY AS INTEGER)
    desktopCtxMode = 2
    desktopCtxIcon = 0
    desktopCtxX = menuX
    desktopCtxY = menuY

    IF desktopCtxX < 0 THEN desktopCtxX = 0
    IF desktopCtxY < WORK_Y THEN desktopCtxY = WORK_Y
    IF desktopCtxX + DesktopContextWidth() > SCR_W - 1 THEN desktopCtxX = SCR_W - 1 - DesktopContextWidth()
    IF desktopCtxY + DesktopContextHeight() - 1 > WORK_BOTTOM THEN desktopCtxY = WORK_BOTTOM - DesktopContextHeight() + 1
    IF desktopCtxX < 0 THEN desktopCtxX = 0
    IF desktopCtxY < WORK_Y THEN desktopCtxY = WORK_Y

    selectedIcon = 0
    desktopCtxOpen = -1
END SUB

FUNCTION DesktopContextRowCount() AS INTEGER
    IF desktopCtxMode = 1 THEN
        IF desktopCtxIcon >= 1 AND desktopCtxIcon <= iconCount THEN
            IF DesktopIconBmpIsTrashAware(desktopIcons(desktopCtxIcon).bmpFile) <> 0 THEN RETURN 1
        END IF
        RETURN 3
    END IF
    IF desktopCtxMode = 2 THEN RETURN 5
    RETURN 0
END FUNCTION

FUNCTION DesktopContextHeight() AS INTEGER
    RETURN DesktopContextRowCount() * DESKTOP_CTX_ROW_H + DESKTOP_CTX_PAD_Y * 2
END FUNCTION

FUNCTION DesktopContextWidth() AS INTEGER
    IF desktopCtxMode = 1 THEN
        IF desktopCtxIcon >= 1 AND desktopCtxIcon <= iconCount THEN
            IF DesktopIconBmpIsTrashAware(desktopIcons(desktopCtxIcon).bmpFile) <> 0 THEN RETURN 144
        END IF
        RETURN 112
    END IF
    RETURN DESKTOP_CTX_W
END FUNCTION

FUNCTION DesktopContextHit(BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER) AS INTEGER
    DIM rowIdx AS INTEGER

    IF desktopCtxOpen = 0 THEN RETURN 0
    IF DesktopContextRowCount() <= 0 THEN RETURN 0
    IF mouseX < desktopCtxX OR mouseX > desktopCtxX + DesktopContextWidth() THEN RETURN 0
    IF mouseY < desktopCtxY + DESKTOP_CTX_PAD_Y THEN RETURN 0
    IF mouseY > desktopCtxY + DESKTOP_CTX_PAD_Y + DesktopContextRowCount() * DESKTOP_CTX_ROW_H - 1 THEN RETURN 0

    rowIdx = ((mouseY - desktopCtxY - DESKTOP_CTX_PAD_Y) \ DESKTOP_CTX_ROW_H) + 1
    IF rowIdx < 1 OR rowIdx > DesktopContextRowCount() THEN RETURN 0

    RETURN rowIdx
END FUNCTION

SUB DrawDesktopContextMenu()
    DIM menuH AS INTEGER
    DIM rowY AS INTEGER

    IF desktopCtxOpen = 0 THEN EXIT SUB
    IF DesktopContextRowCount() <= 0 THEN EXIT SUB

    menuH = DesktopContextHeight()
    DrawBevelBox desktopCtxX, desktopCtxY, desktopCtxX + DesktopContextWidth(), desktopCtxY + menuH, 0
    LINE (desktopCtxX, desktopCtxY)-(desktopCtxX + DesktopContextWidth(), desktopCtxY + menuH), COL_TEXT, B

    rowY = desktopCtxY + DESKTOP_CTX_PAD_Y
    IF desktopCtxMode = 1 THEN
        IF desktopCtxIcon >= 1 AND desktopCtxIcon <= iconCount THEN
            IF DesktopIconBmpIsTrashAware(desktopIcons(desktopCtxIcon).bmpFile) <> 0 THEN
                DRAW STRING (desktopCtxX + 8, rowY + 4), "Empty Waste Basket", COL_TEXT
            ELSE
                DRAW STRING (desktopCtxX + 8, rowY + 4), "Properties", COL_TEXT
                rowY = rowY + DESKTOP_CTX_ROW_H
                DRAW STRING (desktopCtxX + 8, rowY + 4), "Edit", COL_TEXT
                rowY = rowY + DESKTOP_CTX_ROW_H
                DRAW STRING (desktopCtxX + 8, rowY + 4), "Delete", COL_TEXT
            END IF
        END IF
    ELSEIF desktopCtxMode = 2 THEN
        DRAW STRING (desktopCtxX + 8, rowY + 4), "Add App Link", COL_TEXT
        rowY = rowY + DESKTOP_CTX_ROW_H
        DRAW STRING (desktopCtxX + 8, rowY + 4), "Add Program Link", COL_TEXT
        rowY = rowY + DESKTOP_CTX_ROW_H
        DRAW STRING (desktopCtxX + 8, rowY + 4), "Add Directory Link", COL_TEXT
        rowY = rowY + DESKTOP_CTX_ROW_H
        DRAW STRING (desktopCtxX + 8, rowY + 4), "Add Text File Link", COL_TEXT
        rowY = rowY + DESKTOP_CTX_ROW_H
        DRAW STRING (desktopCtxX + 8, rowY + 4), "Properties", COL_TEXT
    END IF
END SUB

