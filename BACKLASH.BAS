        layoutUiWordSelB(idx, i) = 0
        layoutUiLineSelMode(idx, i) = 0
        layoutUiLineSelA(idx, i) = 0
        layoutUiLineSelB(idx, i) = 0
    NEXT

    IF bdbgEnabled <> 0 THEN BDbgWindowEvent "CLOSE_AFTER_SLOT_CLEAR", idx

    FOR i = LBOUND(layoutZOrder) TO UBOUND(layoutZOrder)
        IF layoutZOrder(i) = idx THEN
            layoutZOrder(i) = 0
        END IF
    NEXT

    layoutWindowCount = 0
    FOR i = LBOUND(layoutWindows) TO UBOUND(layoutWindows)
        IF layoutWindows(i).used <> 0 THEN layoutWindowCount = layoutWindowCount + 1
    NEXT

    found = 0
    FOR i = UBOUND(layoutZOrder) TO LBOUND(layoutZOrder) STEP -1
        IF layoutZOrder(i) >= LBOUND(layoutWindows) AND layoutZOrder(i) <= UBOUND(layoutWindows) THEN
            IF layoutWindows(layoutZOrder(i)).used <> 0 AND layoutWindows(layoutZOrder(i)).minimized = 0 THEN
                activeLayoutWindow = layoutZOrder(i)
                found = -1
                EXIT FOR
            END IF
        END IF
    NEXT

    IF found = 0 THEN
        activeLayoutWindow = 0
        uiWindowActive = 0
        uiPressedIndex = 0
        uiFocusIndex = 0
        uiCaretPos = 0
