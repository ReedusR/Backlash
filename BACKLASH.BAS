SUB ApplyBacklash256Palette()
    DIM idx AS INTEGER
    DIM rr AS INTEGER
    DIM gg AS INTEGER
    DIM bb AS INTEGER
    DIM shade AS INTEGER

    IF cfg.colorDepth <> 8 THEN EXIT SUB

    PALETTE 0, 0, 0, 0
    PALETTE 1, 0, 0, 170
    PALETTE 2, 0, 170, 0
    PALETTE 3, 0, 170, 170
    PALETTE 4, 170, 0, 0
    PALETTE 5, 170, 0, 170
    PALETTE 6, 170, 85, 0
    PALETTE 7, 170, 170, 170
    PALETTE 8, 85, 85, 85
    PALETTE 9, 85, 85, 255
    PALETTE 10, 85, 255, 85
    PALETTE 11, 85, 255, 255
    PALETTE 12, 255, 85, 85
    PALETTE 13, 255, 0, 255
    PALETTE 14, 255, 255, 85
    PALETTE 15, 255, 255, 255

    idx = 16
    FOR rr = 0 TO 255 STEP 51
        FOR gg = 0 TO 255 STEP 51
            FOR bb = 0 TO 255 STEP 51
                PALETTE idx, rr, gg, bb
                idx = idx + 1
            NEXT
        NEXT
    NEXT

    FOR idx = 232 TO 255
        shade = 8 + (idx - 232) * 10
        PALETTE idx, shade, shade, shade
    NEXT
END SUB

