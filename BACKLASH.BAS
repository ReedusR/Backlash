    DIM keyAsciiValue AS INTEGER
    DIM keyFlagsValue AS INTEGER
    DIM keyDownName AS STRING
    DIM keyDownVar AS STRING

    IF ParseActionHeaderCached(actIn, actRaw, act, args) = 0 THEN EXIT SUB

    SELECT CASE act
    CASE "APPLY_BINDINGS"
        ApplyBindingsFromControls

    CASE "APPLY_WALLPAPER_FAST"
        ApplyWallpaperFast

    CASE "APPLY_BINDINGS_RELOAD_DISPLAY", "APPLY_BINDINGS_REFRESH_DISPLAY"
        ApplyBindingsFromControls
        RefreshDisplayFromCurrentConfig

    CASE "APPLY_DESKTOP_PROPERTIES"
        ApplyDesktopPropertiesFast

    CASE "CANCEL_BINDINGS", "RESET_BINDINGS"
        ResetBindingsFromConfig

    CASE "REFRESH_BOUND_CONTROLS", "RELOAD_BOUND_CONTROLS"
        RefreshBoundControlsFromConfig

    CASE "REFRESH_MEDIA", "MEDIA_REFRESH"
        ClearComboItemCache
        ClearDirectorySizeCache
        RefreshLaunchRecentMenuItems
        RefreshTrashAwareDesktopIcons
        FOR i = LBOUND(layoutWindows) TO UBOUND(layoutWindows)
            IF layoutWindows(i).used <> 0 THEN MarkLayoutWindowDirty i
        NEXT

    CASE "SOUND_BEEP", "BEEP"
        SoundStartTone soundDefaultFreq, soundDefaultMs

    CASE "SOUND_TONE", "PLAY_TONE"
        DIM soundFreqArg AS INTEGER
        DIM soundMsArg AS INTEGER
        soundFreqArg = VALINT(NextActionToken(args))
        soundMsArg = VALINT(NextActionToken(args))
        SoundStartTone soundFreqArg, soundMsArg

    CASE "SOUND_STOP"
        SoundStop

    CASE "SOUND_STATUS"
        SoundWriteStatus
        ShowGuiMessageBoxInfo "Sound Status", "Wrote " + soundStatusFile

    CASE "SOUND_SBTEST", "SBTEST"
        IF SoundBlasterDirectClick() = 0 THEN ShowGuiMessageBox "Sound Blaster Test", "DSP direct test failed"
        SoundWriteStatus

    CASE "SOUND_SBDMA", "SBDMA"
        IF SoundBlasterDmaTest() = 0 THEN ShowGuiMessageBox "Sound Blaster DMA Test", "8-bit DMA test failed"
        SoundWriteStatus

    CASE "SOUND_WAV", "SOUND_PLAY", "PLAY_WAV"
        soundFileArg = NormalizePath(TRIM$(NextActionToken(args)))
        IF SoundBlasterPlayWav8Mono(soundFileArg) = 0 THEN ShowGuiMessageBox "Sound WAV", "8-bit mono WAV playback failed"
        SoundWriteStatus

    CASE "SOUND_PCM_PLAY"
        soundFileArg = NormalizePath(TRIM$(NextActionToken(args)))
        IF SoundPcmStartRaw16Stereo44100(soundFileArg) = 0 THEN ShowGuiMessageBox "Sound PCM", "PCM playback failed"
        SoundWriteStatus

    CASE "SOUND_PCM_PLAY_EX"
        soundFileArg = NormalizePath(TRIM$(NextActionToken(args)))
        soundRateArg = VALINT(NextActionToken(args))
        soundChannelsArg = VALINT(NextActionToken(args))
        soundBitsArg = VALINT(NextActionToken(args))
        IF SoundPcmStartFile(soundFileArg, soundRateArg, soundChannelsArg, soundBitsArg) = 0 THEN ShowGuiMessageBox "Sound PCM", "PCM playback failed"
        SoundWriteStatus

    CASE "SOUND_PCM_STATUS"
        SoundPcmWriteStatus soundPcmLastStatus
        SoundWriteStatus

    CASE "SOUND_PCM_STOP"
        SoundStop
        SoundPcmWriteStatus "STOPPED"
        SoundWriteStatus

    CASE "SOUND_PCM_PAUSE"
        IF SoundPcmPause() = 0 THEN ShowGuiMessageBox "Sound PCM", "PCM pause failed"
        SoundWriteStatus

    CASE "SOUND_PCM_RESUME"
        IF SoundPcmResume() = 0 THEN ShowGuiMessageBox "Sound PCM", "PCM resume failed"
        SoundWriteStatus

    CASE "REFRESH_SERVICE_CONFIG", "RELOAD_SERVICE_CONFIG"
        serviceConfigName = UCASE$(TRIM$(NextActionToken(args)))
        SELECT CASE serviceConfigName
        CASE "SCREENSAVER"
            RefreshScreensaverLaunchConfig -1
        CASE "SOUND"
            RefreshSoundConfig
        END SELECT

    CASE "INVALIDATE_PREVIEW_CACHE"
        FreePreviewBitmap
        ClearPreviewDimensionCache
        IF winIdx >= LBOUND(layoutWindows) AND winIdx <= UBOUND(layoutWindows) THEN
            IF layoutWindows(winIdx).used <> 0 THEN MarkLayoutWindowDirty winIdx
        END IF

    CASE "RESTORE_DEFAULTS"
        RestoreDefaultsFromMetadata

    CASE "CLOSE_WINDOW"
        IF winIdx >= LBOUND(layoutWindows) AND winIdx <= UBOUND(layoutWindows) THEN
            IF layoutWindows(winIdx).used <> 0 THEN
                RequestLayoutWindowClose winIdx
            END IF
        END IF
    CASE "RUN_HELPER", "RUN_SILENT"
        helperExe = ResolveAppLocalCommand(winIdx, ExpandHelperCommandControls(winIdx, TRIM$(args)))
        IF helperExe <> "" THEN
            RunSilentHelper helperExe
        ELSE
            ShowGuiMessageBox "EMPTY HELPER COMMAND:", actRaw
        END IF

    CASE "RUN_INLINE_HELPER", "RUN_INLINE_SILENT"
        helperExe = ResolveAppLocalCommand(winIdx, ExpandHelperCommandControls(winIdx, TRIM$(args)))
        IF helperExe <> "" THEN
            RunInlineHelper helperExe
        ELSE
            ShowGuiMessageBox "EMPTY HELPER COMMAND:", actRaw
        END IF

    CASE "RUN_DISPLAY_HELPER"
        helperExe = ResolveAppLocalCommand(winIdx, ExpandHelperCommandControls(winIdx, TRIM$(args)))
        IF helperExe <> "" THEN
            RunDisplayHelper helperExe
        ELSE
            ShowGuiMessageBox "EMPTY HELPER COMMAND:", actRaw
        END IF

    CASE "LAUNCH_FROM_CONTROL"
        runCommandControl = NextActionToken(args)
        runExternalControl = NextActionToken(args)
        runStatusControl = NextActionToken(args)
        LaunchFromControl runCommandControl, runExternalControl, runStatusControl

    CASE "CONTROL_MENU_ACTION"
        controlName = NextActionToken(args)
        clearIdx = GetControlIndexByName(controlName)
        IF clearIdx >= 1 AND clearIdx <= uiCount THEN
            sysActionText = ControlValueFromCombo(clearIdx)
            IF TRIM$(uiElems(clearIdx).defaultValue) <> "" THEN
                uiElems(clearIdx).text = uiElems(clearIdx).defaultValue
            ELSE
                uiElems(clearIdx).text = uiElems(clearIdx).name
            END IF
            comboOpenIndex(winIdx) = 0
            SyncLayoutWindowFromGlobals winIdx
            IF TRIM$(sysActionText) <> "" THEN HostAppAction winIdx, sysActionText
        END IF

    CASE "TEXT_NEW"
        textBoxName = NextActionToken(args)
        SetTextboxTextByName textBoxName, ""

    CASE "TEXT_LOAD"
        textBoxName = NextActionToken(args)
        fileBoxName = NextActionToken(args)
        helperExe = NextActionToken(args)
        fileName = ResolveAppLocalPath(winIdx, TRIM$(GetTextboxTextByName(fileBoxName)))
        IF textBoxName <> "" AND fileName <> "" THEN
            dataText = ReadTextFileRaw(fileName)
            SetTextboxTextByName textBoxName, dataText
            MarkLayoutTextSavedBaseline winIdx, textBoxName, fileBoxName
        END IF

    CASE "TEXTBOX_CARET_END", "TEXT_CARET_END", "CONTROL_CARET_END"
        textBoxName = NextActionToken(args)
        IF textBoxName <> "" THEN SetTextboxCaretEndByName textBoxName

    CASE "TEXT_SAVE"
        textBoxName = NextActionToken(args)
        fileBoxName = NextActionToken(args)
        helperExe = NextActionToken(args)
        fileName = ResolveAppLocalPath(winIdx, TRIM$(GetTextboxTextByName(fileBoxName)))
        IF textBoxName <> "" AND fileName <> "" THEN
            dataText = GetTextboxTextByName(textBoxName)
            WriteTextFileRaw fileName, dataText
            saveStatusControlName = ""
            IF winIdx >= LBOUND(layoutWindows) AND winIdx <= UBOUND(layoutWindows) THEN
                IF layoutWindows(winIdx).used <> 0 THEN
                    saveStatusControlName = TRIM$(layoutTextSaveStatusControl(winIdx))
                END IF
            END IF
            IF saveStatusControlName <> "" THEN
                SetControlTextByNameAny saveStatusControlName, FileNameOnly(fileName) + " saved"
            END IF
            MarkLayoutTextSavedBaseline winIdx, textBoxName, fileBoxName
        END IF

    CASE "TEXT_SAVE_AUTO", "TEXT_SAVE_AS"
        textBoxName = NextActionToken(args)
        fileBoxName = NextActionToken(args)
        fileDlgDir = NextActionToken(args)
        fileDlgMask = NextActionToken(args)
        dlgPath = NextActionToken(args)
        fileName = ResolveAppLocalPath(winIdx, TRIM$(GetTextboxTextByName(fileBoxName)))

        IF act = "TEXT_SAVE_AUTO" AND textBoxName <> "" AND fileBoxName <> "" AND fileName <> "" THEN
            dataText = GetTextboxTextByName(textBoxName)
            WriteTextFileRaw fileName, dataText
            saveStatusControlName = ""
            IF winIdx >= LBOUND(layoutWindows) AND winIdx <= UBOUND(layoutWindows) THEN
                IF layoutWindows(winIdx).used <> 0 THEN
                    saveStatusControlName = TRIM$(layoutTextSaveStatusControl(winIdx))
                END IF
            END IF
            IF saveStatusControlName <> "" THEN
                SetControlTextByNameAny saveStatusControlName, FileNameOnly(fileName) + " saved"
            END IF
            MarkLayoutTextSavedBaseline winIdx, textBoxName, fileBoxName
        ELSEIF textBoxName <> "" AND fileBoxName <> "" THEN
            fileDlgNotifyChange = 0
            fileDlgDirectoryMode = 0
            fileDlgSaveTextMode = -1
            fileDlgTargetControl = fileBoxName
            fileDlgLoadControl = textBoxName
            fileDlgTargetWin = winIdx

            IF fileDlgDir = "" THEN fileDlgDir = "."
            fileDlgDir = FileDialogPersistentDir(winIdx, fileDlgDir)
            IF fileName <> "" THEN
                selectedPath = ParentPath(fileName)
                IF selectedPath <> "" THEN fileDlgDir = selectedPath
            END IF
            IF fileDlgMask = "" THEN fileDlgMask = "*.*"
            IF dlgPath = "" THEN dlgPath = AppDialogPath(winIdx, "FILE_NEW_DIALOG", "")
            dlgPath = ResolvePathFromAppWindow(winIdx, dlgPath)

            IF winIdx >= LBOUND(layoutWindows) AND winIdx <= UBOUND(layoutWindows) THEN
                IF layoutWindows(winIdx).used <> 0 THEN
                    uiPressedIndex = 0
                    layoutWindows(winIdx).pressedIndex = 0
                    SyncLayoutWindowFromGlobals winIdx
                END IF
            END IF

            IF dlgPath <> "" THEN
                IF DIR(LayoutFilePath(dlgPath)) <> "" THEN
                    OpenLayoutAppWindow dlgPath
                    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
                        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
                            IF UCASE$(NormalizePath(RTRIM$(layoutWindows(activeLayoutWindow).appPath))) = UCASE$(NormalizePath(dlgPath)) THEN
                                ConfigureNewFileDialogWindow activeLayoutWindow
                            END IF
                        END IF
                    END IF
                END IF
            END IF
        END IF

    CASE "PIPE_ENTRY_APPEND"
        pipeTargetName = NextActionToken(args)
        pipeTypeName = NextActionToken(args)
        pipeNameName = NextActionToken(args)
        pipeActionName = NextActionToken(args)
        pipeIconName = NextActionToken(args)
        pipeStatusName = NextActionToken(args)

        pipeTypeValue = UCASE$(TRIM$(GetControlTextValue(pipeTypeName)))
        pipeNameValue = TRIM$(GetControlTextValue(pipeNameName))
        pipeActionValue = TRIM$(GetControlTextValue(pipeActionName))
        pipeIconValue = TRIM$(GetControlTextValue(pipeIconName))
        pipeLineText = ""
        statusText = ""

        IF pipeTypeValue = "" THEN pipeTypeValue = "ITEM"

        SELECT CASE pipeTypeValue
        CASE "SEPARATOR", "DASH", "LINE", "-"
            pipeLineText = "-"
        CASE "MENU", "FOLDER", "HEADER"
            IF pipeNameValue = "" THEN
                statusText = "Menu name is blank"
            ELSEIF pipeIconValue = "" THEN
                pipeLineText = pipeNameValue + ">"
            ELSE
                pipeLineText = pipeNameValue + ">|" + pipeIconValue
            END IF
        CASE ELSE
            IF pipeNameValue = "" THEN
                statusText = "Name is blank"
            ELSEIF pipeActionValue = "" THEN
                statusText = "Launch file is blank"
            ELSEIF pipeIconValue = "" THEN
                statusText = "Icon file is blank"
            ELSE
                pipeLineText = pipeNameValue + "|" + pipeActionValue + "|" + pipeIconValue
            END IF
        END SELECT

        IF pipeTargetName <> "" THEN
            IF pipeLineText <> "" THEN
                dataText = GetTextboxTextByName(pipeTargetName)
                IF dataText <> "" THEN
                    IF RIGHT$(dataText, 2) <> CHR$(13) + CHR$(10) AND RIGHT$(dataText, 1) <> CHR$(10) AND RIGHT$(dataText, 1) <> CHR$(13) THEN
                        dataText = dataText + CHR$(13) + CHR$(10)
                    END IF
                END IF
                pipeNewText = dataText + pipeLineText
                SetTextboxTextByName pipeTargetName, pipeNewText
                statusText = "Added: " + pipeLineText
            END IF
        END IF

        IF pipeStatusName <> "" THEN SetTextboxTextByName pipeStatusName, statusText

    CASE "TEXT_LINE_DELETE"
        pipeTargetName = NextActionToken(args)
        pipeStatusName = NextActionToken(args)
        clearIdx = GetControlIndexByName(pipeTargetName)
        statusText = ""
        pipeNewText = ""

        IF clearIdx >= 1 AND clearIdx <= uiCount THEN
            IF uiElems(clearIdx).kindId = UI_KIND_TEXTBOX THEN
                dataText = GetTextboxTextByName(pipeTargetName)
                IF LEN(dataText) > 0 THEN
                    lineCaretPos = uiEdit(clearIdx).curPos + 1
                    IF lineCaretPos < 1 THEN lineCaretPos = 1
                    IF lineCaretPos > LEN(dataText) THEN lineCaretPos = LEN(dataText)

                    lineStart = lineCaretPos
                    DO WHILE lineStart > 1
                        IF MID$(dataText, lineStart - 1, 1) = CHR$(10) OR MID$(dataText, lineStart - 1, 1) = CHR$(13) THEN EXIT DO
                        lineStart = lineStart - 1
                    LOOP

                    lineEnd = lineCaretPos
                    DO WHILE lineEnd <= LEN(dataText)
                        IF MID$(dataText, lineEnd, 1) = CHR$(13) OR MID$(dataText, lineEnd, 1) = CHR$(10) THEN EXIT DO
                        lineEnd = lineEnd + 1
                    LOOP

                    lineRemoveEnd = lineEnd
                    IF lineRemoveEnd <= LEN(dataText) THEN
                        IF MID$(dataText, lineRemoveEnd, 1) = CHR$(13) AND lineRemoveEnd < LEN(dataText) THEN
                            IF MID$(dataText, lineRemoveEnd + 1, 1) = CHR$(10) THEN
                                lineRemoveEnd = lineRemoveEnd + 2
                            ELSE
                                lineRemoveEnd = lineRemoveEnd + 1
                            END IF
                        ELSE
                            lineRemoveEnd = lineRemoveEnd + 1
                        END IF
                    END IF

                    pipeNewText = LEFT$(dataText, lineStart - 1) + MID$(dataText, lineRemoveEnd)
                    SetTextboxTextByName pipeTargetName, pipeNewText
                    uiEdit(clearIdx).curPos = lineStart - 1
                    IF uiEdit(clearIdx).curPos > LEN(pipeNewText) THEN uiEdit(clearIdx).curPos = LEN(pipeNewText)
                    Ed_SelClr uiEdit(clearIdx)
                    Ed_SyncGlue uiEdit(clearIdx), uiElems(clearIdx).text, uiCaretPos
                    IF activeLayoutWindow >= 1 AND activeLayoutWindow <= 12 THEN
                        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
                            layoutUiElems(activeLayoutWindow, clearIdx) = uiElems(clearIdx)
                            layoutUiEdit(activeLayoutWindow, clearIdx) = uiEdit(clearIdx)
                            layoutWindows(activeLayoutWindow).focusIndex = clearIdx
                            layoutWindows(activeLayoutWindow).caretPos = uiCaretPos
                        END IF
                    END IF
                    statusText = "Removed current line"
                END IF
            END IF
        END IF

        IF pipeStatusName <> "" THEN SetTextboxTextByName pipeStatusName, statusText
        SyncLayoutWindowFromGlobals activeLayoutWindow

    CASE "TEXT_LINE_MOVE"
        pipeTargetName = NextActionToken(args)
        lineMoveDir = UCASE$(TRIM$(NextActionToken(args)))
        pipeStatusName = NextActionToken(args)
        clearIdx = GetControlIndexByName(pipeTargetName)
        statusText = ""
        pipeNewText = ""

        IF clearIdx >= 1 AND clearIdx <= uiCount THEN
            IF uiElems(clearIdx).kindId = UI_KIND_TEXTBOX THEN
                dataText = GetTextboxTextByName(pipeTargetName)
                IF LEN(dataText) > 0 THEN
                    lineCaretPos = uiEdit(clearIdx).curPos + 1
                    IF lineCaretPos < 1 THEN lineCaretPos = 1
                    IF lineCaretPos > LEN(dataText) THEN lineCaretPos = LEN(dataText)

                    lineStart = lineCaretPos
                    DO WHILE lineStart > 1
                        IF MID$(dataText, lineStart - 1, 1) = CHR$(10) OR MID$(dataText, lineStart - 1, 1) = CHR$(13) THEN EXIT DO
                        lineStart = lineStart - 1
                    LOOP

                    lineEnd = lineCaretPos
                    DO WHILE lineEnd <= LEN(dataText)
                        IF MID$(dataText, lineEnd, 1) = CHR$(13) OR MID$(dataText, lineEnd, 1) = CHR$(10) THEN EXIT DO
                        lineEnd = lineEnd + 1
                    LOOP

                    lineRemoveEnd = lineEnd
                    IF lineRemoveEnd <= LEN(dataText) THEN
                        IF MID$(dataText, lineRemoveEnd, 1) = CHR$(13) AND lineRemoveEnd < LEN(dataText) THEN
                            IF MID$(dataText, lineRemoveEnd + 1, 1) = CHR$(10) THEN
                                lineRemoveEnd = lineRemoveEnd + 2
                            ELSE
                                lineRemoveEnd = lineRemoveEnd + 1
                            END IF
                        ELSE
                            lineRemoveEnd = lineRemoveEnd + 1
                        END IF
                    END IF

                    currentLineText = MID$(dataText, lineStart, lineEnd - lineStart)

                    IF lineMoveDir = "UP" THEN
                        IF lineStart > 1 THEN
                            prevEnd = lineStart - 1
                            DO WHILE prevEnd > 1
                                IF MID$(dataText, prevEnd, 1) <> CHR$(13) AND MID$(dataText, prevEnd, 1) <> CHR$(10) THEN EXIT DO
                                prevEnd = prevEnd - 1
                            LOOP
                            prevStart = prevEnd
                            DO WHILE prevStart > 1
                                IF MID$(dataText, prevStart - 1, 1) = CHR$(10) OR MID$(dataText, prevStart - 1, 1) = CHR$(13) THEN EXIT DO
                                prevStart = prevStart - 1
                            LOOP
                            adjacentLineText = MID$(dataText, prevStart, prevEnd - prevStart + 1)
                            pipeNewText = LEFT$(dataText, prevStart - 1) + currentLineText + CHR$(13) + CHR$(10) + adjacentLineText + MID$(dataText, lineRemoveEnd)
                            SetTextboxTextByName pipeTargetName, pipeNewText
                            uiEdit(clearIdx).curPos = prevStart - 1
                            statusText = "Moved line up"
                        END IF
                    ELSEIF lineMoveDir = "DOWN" THEN
                        IF lineRemoveEnd <= LEN(dataText) THEN
                            nextStart = lineRemoveEnd
                            DO WHILE nextStart <= LEN(dataText)
                                IF MID$(dataText, nextStart, 1) <> CHR$(13) AND MID$(dataText, nextStart, 1) <> CHR$(10) THEN EXIT DO
                                nextStart = nextStart + 1
                            LOOP
                            nextEnd = nextStart
                            DO WHILE nextEnd <= LEN(dataText)
                                IF MID$(dataText, nextEnd, 1) = CHR$(13) OR MID$(dataText, nextEnd, 1) = CHR$(10) THEN EXIT DO
                                nextEnd = nextEnd + 1
                            LOOP
                            IF nextStart <= LEN(dataText) THEN
                                nextRemoveEnd = nextEnd
                                IF nextRemoveEnd <= LEN(dataText) THEN
                                    IF MID$(dataText, nextRemoveEnd, 1) = CHR$(13) AND nextRemoveEnd < LEN(dataText) THEN
                                        IF MID$(dataText, nextRemoveEnd + 1, 1) = CHR$(10) THEN
                                            nextRemoveEnd = nextRemoveEnd + 2
                                        ELSE
                                            nextRemoveEnd = nextRemoveEnd + 1
                                        END IF
                                    ELSE
                                        nextRemoveEnd = nextRemoveEnd + 1
                                    END IF
                                END IF
                                adjacentLineText = MID$(dataText, nextStart, nextEnd - nextStart)
                                pipeNewText = LEFT$(dataText, lineStart - 1) + adjacentLineText + CHR$(13) + CHR$(10) + currentLineText + MID$(dataText, nextRemoveEnd)
                                SetTextboxTextByName pipeTargetName, pipeNewText
                                uiEdit(clearIdx).curPos = lineStart + LEN(adjacentLineText) + 1
                                statusText = "Moved line down"
                            END IF
                        END IF
                    END IF

                    IF pipeNewText <> "" THEN
                        IF uiEdit(clearIdx).curPos > LEN(pipeNewText) THEN uiEdit(clearIdx).curPos = LEN(pipeNewText)
                        IF uiEdit(clearIdx).curPos < 0 THEN uiEdit(clearIdx).curPos = 0
                        Ed_SelClr uiEdit(clearIdx)
                        Ed_SyncGlue uiEdit(clearIdx), uiElems(clearIdx).text, uiCaretPos
                        IF activeLayoutWindow >= 1 AND activeLayoutWindow <= 12 THEN
                            IF layoutWindows(activeLayoutWindow).used <> 0 THEN
                                layoutUiElems(activeLayoutWindow, clearIdx) = uiElems(clearIdx)
                                layoutUiEdit(activeLayoutWindow, clearIdx) = uiEdit(clearIdx)
                                layoutWindows(activeLayoutWindow).focusIndex = clearIdx
                                layoutWindows(activeLayoutWindow).caretPos = uiCaretPos
                            END IF
                        END IF
                    END IF
                END IF
            END IF
        END IF

        IF pipeStatusName <> "" THEN SetTextboxTextByName pipeStatusName, statusText
        SyncLayoutWindowFromGlobals activeLayoutWindow


    CASE "PIPE_LIST_LOAD_FILE"
        pipeListName = NextActionToken(args)
        fileBoxName = NextActionToken(args)
        pipeParentName = NextActionToken(args)
        pipeStatusName = NextActionToken(args)

        fileName = TRIM$(GetTextboxTextByName(fileBoxName))
        pipeSourceText = ""

        IF fileName <> "" THEN
            dataText = ReadTextFileRaw(fileName)
            pipeSourceText = PipeListSourceFromRawText(dataText)
            statusText = "Loaded " + fileName
        ELSE
            statusText = "Launch file is blank"
        END IF

        SetControlSourceItemsByName pipeListName, pipeSourceText, ""
        IF pipeParentName <> "" THEN
            SetControlSourceItemsByName pipeParentName, PipeListParentMenusFromSource(pipeSourceText), "(root)"
        END IF
        IF pipeStatusName <> "" THEN SetTextboxTextByName pipeStatusName, statusText

    CASE "PIPE_LIST_SAVE_FILE"
        pipeListName = NextActionToken(args)
        fileBoxName = NextActionToken(args)
        pipeStatusName = NextActionToken(args)
        pipeTypeName = NextActionToken(args)
        pipeNameName = NextActionToken(args)
        pipeActionName = NextActionToken(args)
        pipeIconName = NextActionToken(args)
        pipeParentName = NextActionToken(args)
        pipeLaunchTypeName = NextActionToken(args)

        pipeListIdx = GetControlIndexByName(pipeListName)
        fileName = TRIM$(GetTextboxTextByName(fileBoxName))
        statusText = ""

        IF pipeListIdx >= 1 AND pipeListIdx <= uiCount AND fileName <> "" THEN
            IF pipeTypeName <> "" THEN
                pipeSelectedIdx = PipeListSelectedIndexByName(pipeListName)
                IF pipeSelectedIdx > 0 THEN
                    pipeTypeValue = GetControlTextValue(pipeTypeName)
                    pipeNameValue = GetControlTextValue(pipeNameName)
                    pipeActionValue = GetControlTextValue(pipeActionName)
                    pipeIconValue = GetControlTextValue(pipeIconName)
                    pipeParentValue = GetControlTextValue(pipeParentName)
                    pipeLineText = PipeBuildRawLineFromValues(pipeTypeValue, pipeNameValue, pipeActionValue, pipeIconValue, pipeParentValue, GetControlTextValue(pipeLaunchTypeName), statusText)
                    IF pipeLineText <> "" THEN
                        pipeSourceText = uiElems(pipeListIdx).sourceItems
                        IF UCASE$(PipeListParentForIndex(pipeSourceText, pipeSelectedIdx)) = UCASE$(pipeParentValue) THEN
                            pipeSourceText = PipeListSetAt(pipeSourceText, pipeSelectedIdx, pipeLineText)
                        ELSE
                            pipeSourceText = PipeListSetAtForParent(pipeSourceText, pipeSelectedIdx, pipeLineText, pipeParentValue)
                        END IF
                        pipeSelectedText = PipeLineDisplayFromRaw(pipeLineText)
                        SetControlSourceItemsByName pipeListName, pipeSourceText, pipeSelectedText
                        IF pipeParentName <> "" THEN SetControlSourceItemsByName pipeParentName, PipeListParentMenusFromSource(pipeSourceText), pipeParentValue
                    END IF
                END IF
            END IF

            IF statusText = "" THEN
                dataText = PipeListRawTextFromSource(uiElems(pipeListIdx).sourceItems)
                IF WriteTextFileRaw(fileName, dataText) <> 0 THEN
                    IF UCASE$(NormalizePath(fileName)) = UCASE$(NormalizePath(PATH_STRTMENU)) THEN
                        LoadStartMenu PATH_STRTMENU
                        statusText = "Saved and refreshed " + fileName
                    ELSE
                        statusText = "Saved " + fileName
                    END IF
                ELSE
                    statusText = "Save failed"
                END IF
            END IF
        ELSE
            statusText = "Save failed"
        END IF

        IF pipeStatusName <> "" THEN SetTextboxTextByName pipeStatusName, statusText

    CASE "PIPE_ENTRY_SELECT"
        pipeListName = NextActionToken(args)
        pipeTypeName = NextActionToken(args)
        pipeNameName = NextActionToken(args)
        pipeActionName = NextActionToken(args)
        pipeIconName = NextActionToken(args)
        pipeParentName = NextActionToken(args)
        pipeLaunchTypeName = NextActionToken(args)
        pipeStatusName = NextActionToken(args)

        pipeSelectedIdx = PipeListSelectedIndexByName(pipeListName)
        IF pipeSelectedIdx > 0 THEN
            PipePopulateEntryFields pipeListName, pipeSelectedIdx, pipeTypeName, pipeNameName, pipeActionName, pipeIconName, pipeParentName, pipeLaunchTypeName, pipeStatusName
        END IF

    CASE "PIPE_LIST_APPEND"
        pipeListName = NextActionToken(args)
        pipeTypeName = NextActionToken(args)
        pipeNameName = NextActionToken(args)
        pipeActionName = NextActionToken(args)
        pipeIconName = NextActionToken(args)
        pipeParentName = NextActionToken(args)
        pipeLaunchTypeName = NextActionToken(args)
        pipeStatusName = NextActionToken(args)
        IF pipeStatusName = "" THEN
            pipeStatusName = pipeLaunchTypeName
            pipeLaunchTypeName = ""
        END IF

        pipeTypeValue = GetControlTextValue(pipeTypeName)
        pipeNameValue = GetControlTextValue(pipeNameName)
        pipeActionValue = GetControlTextValue(pipeActionName)
        pipeIconValue = GetControlTextValue(pipeIconName)
        pipeParentValue = GetControlTextValue(pipeParentName)
        pipeLineText = PipeBuildRawLineFromValues(pipeTypeValue, pipeNameValue, pipeActionValue, pipeIconValue, pipeParentValue, GetControlTextValue(pipeLaunchTypeName), statusText)

        pipeListIdx = GetControlIndexByName(pipeListName)
        IF pipeListIdx >= 1 AND pipeListIdx <= uiCount THEN
            IF pipeLineText <> "" THEN
                pipeSourceText = PipeListSetAtForParent(uiElems(pipeListIdx).sourceItems, 0, pipeLineText, pipeParentValue)
                pipeSelectedText = PipeLineDisplayFromRaw(pipeLineText)
                SetControlSourceItemsByName pipeListName, pipeSourceText, pipeSelectedText
                IF pipeParentName <> "" THEN SetControlSourceItemsByName pipeParentName, PipeListParentMenusFromSource(pipeSourceText), pipeParentValue
                statusText = "Added: " + pipeLineText
            END IF
        END IF

        IF pipeStatusName <> "" THEN SetTextboxTextByName pipeStatusName, statusText

    CASE "PIPE_LIST_DELETE"
        pipeListName = NextActionToken(args)
        pipeParentName = NextActionToken(args)
        pipeStatusName = NextActionToken(args)

        pipeListIdx = GetControlIndexByName(pipeListName)
        pipeSelectedIdx = PipeListSelectedIndexByName(pipeListName)
        statusText = ""

        IF pipeListIdx >= 1 AND pipeListIdx <= uiCount THEN
            IF pipeSelectedIdx > 0 THEN
                pipeRawLine = PipeListRawAt(uiElems(pipeListIdx).sourceItems, pipeSelectedIdx)
                pipeSourceText = PipeListRemoveAt(uiElems(pipeListIdx).sourceItems, pipeSelectedIdx)
                SetControlSourceItemsByName pipeListName, pipeSourceText, ""
                IF pipeParentName <> "" THEN SetControlSourceItemsByName pipeParentName, PipeListParentMenusFromSource(pipeSourceText), "(root)"
                statusText = "Removed: " + PipeLineDisplayFromRaw(pipeRawLine)
            ELSE
                statusText = "No entry selected"
            END IF
        END IF

        IF pipeStatusName <> "" THEN SetTextboxTextByName pipeStatusName, statusText

    CASE "PIPE_LIST_MOVE"
        pipeListName = NextActionToken(args)
        lineMoveDir = UCASE$(TRIM$(NextActionToken(args)))
        pipeParentName = NextActionToken(args)
        pipeStatusName = NextActionToken(args)

        pipeListIdx = GetControlIndexByName(pipeListName)
        pipeSelectedIdx = PipeListSelectedIndexByName(pipeListName)
        statusText = ""

        IF pipeListIdx >= 1 AND pipeListIdx <= uiCount THEN
            IF pipeSelectedIdx > 0 THEN
                pipeSourceText = PipeListMoveAt(uiElems(pipeListIdx).sourceItems, pipeSelectedIdx, lineMoveDir)
                pipeNewIdx = pipeSelectedIdx
                IF lineMoveDir = "UP" AND pipeSelectedIdx > 1 THEN pipeNewIdx = pipeSelectedIdx - 1
                IF lineMoveDir = "DOWN" AND pipeSelectedIdx < PipeListCountSource(uiElems(pipeListIdx).sourceItems) THEN pipeNewIdx = pipeSelectedIdx + 1
                SetControlSourceItemsByName pipeListName, pipeSourceText, PipeListValueAt(pipeSourceText, pipeNewIdx)
                IF pipeParentName <> "" THEN SetControlSourceItemsByName pipeParentName, PipeListParentMenusFromSource(pipeSourceText), PipeListParentForIndex(pipeSourceText, pipeNewIdx)
                statusText = "Moved entry " + LCASE$(lineMoveDir)
            ELSE
                statusText = "No entry selected"
            END IF
        END IF

        IF pipeStatusName <> "" THEN SetTextboxTextByName pipeStatusName, statusText

    CASE "PIPE_LIST_CANCEL"
        pipeListName = NextActionToken(args)
        fileBoxName = NextActionToken(args)
        pipeParentName = NextActionToken(args)
        pipeStatusName = NextActionToken(args)

        fileName = TRIM$(GetTextboxTextByName(fileBoxName))
        pipeSourceText = ""
        IF fileName <> "" THEN
            dataText = ReadTextFileRaw(fileName)
            pipeSourceText = PipeListSourceFromRawText(dataText)
        END IF
        SetControlSourceItemsByName pipeListName, pipeSourceText, ""
        IF pipeParentName <> "" THEN SetControlSourceItemsByName pipeParentName, PipeListParentMenusFromSource(pipeSourceText), "(root)"
        IF pipeStatusName <> "" THEN SetTextboxTextByName pipeStatusName, "Canceled"
        SyncLayoutWindowFromGlobals activeLayoutWindow
        IF winIdx >= LBOUND(layoutWindows) AND winIdx <= UBOUND(layoutWindows) THEN
            IF layoutWindows(winIdx).used <> 0 THEN CloseLayoutWindow winIdx
        END IF

    CASE "SYS_ACTION", "SYS_ACTIONV"
        sysExpandVars = 0
        IF act = "SYS_ACTIONV" THEN sysExpandVars = -1
        sysFileName = ResolveAppLocalFilePath(winIdx, NextActionToken(args))
        sysSectionName = NextActionToken(args)
        sysArg1 = NextActionToken(args)
        sysActionText = ""

        IF sysFileName <> "" AND sysSectionName <> "" THEN
            sysActionIndex = 1
            DO WHILE sysActionIndex <= 32
                IF sysActionIndex = 1 THEN
                    sysActionKey = "ACTION"
                ELSE
                    sysActionKey = "ACTION" + LTRIM$(STR$(sysActionIndex))
                END IF

                sysActionText = ReadCfgValueInSection(sysFileName, sysSectionName, sysActionKey, "")
                sysActionText = SysTextWithArg(sysActionText, sysArg1)
                IF sysExpandVars <> 0 THEN sysActionText = AppVarExpandText(winIdx, sysActionText)
                IF TRIM$(sysActionText) = "" THEN EXIT DO

                HostAppAction winIdx, sysActionText
                sysActionIndex = sysActionIndex + 1
            LOOP

            IF sysActionIndex = 1 THEN
                sysCommandText = UCASE$(TRIM$(SysTextWithArg(ReadCfgValueInSection(sysFileName, sysSectionName, "COMMAND", ""), sysArg1)))
                sysControlName = TRIM$(SysTextWithArg(ReadCfgValueInSection(sysFileName, sysSectionName, "CONTROL", ""), sysArg1))
                sysStatusName = TRIM$(SysTextWithArg(ReadCfgValueInSection(sysFileName, sysSectionName, "STATUS", ""), sysArg1))
                sysValueText = TRIM$(SysTextWithArg(ReadCfgValueInSection(sysFileName, sysSectionName, "VALUE", ""), sysArg1))
                IF sysExpandVars <> 0 THEN
                    sysControlName = AppVarExpandText(winIdx, sysControlName)
                    sysStatusName = AppVarExpandText(winIdx, sysStatusName)
                    sysValueText = AppVarExpandText(winIdx, sysValueText)
                END IF

                SELECT CASE sysCommandText
                CASE "FILECFG_INIT"
                    FileCfgInit sysFileName, sysSectionName
                CASE "FILECFG_SELECT"
                    FileCfgPopulateSelected sysFileName, sysSectionName
                CASE "FILECFG_SAVE"
                    FileCfgSaveSelected sysFileName, sysSectionName
                CASE "FILECFG_CANCEL"
                    FileCfgCancel sysFileName, sysSectionName
                CASE "FILECFG_RUN"
                    FileCfgRunSelected sysFileName, sysSectionName
                CASE "CFG_PRESET_LOAD"
                    CfgPresetLoadControls sysFileName, sysSectionName
                CASE "CFG_PRESET_SAVE", "CFG_PRESET_SAVE_AS"
                    CfgPresetSaveControls sysFileName, sysSectionName
                CASE "CFG_PRESET_APPLY", "PRESET_APPLY"
                    CfgPresetApplyToTarget sysFileName, sysSectionName
                CASE "CFG_BINDINGS_APPLY", "BINDINGS_APPLY"
                    ApplyBindingsFromControlsUsingSys sysFileName, sysSectionName
                CASE "CFG_SET_CONFIRM", "SET_CFG_CONFIRM"
                    SysCfgSetConfirm sysFileName, sysSectionName
                CASE "CONTROL_EDIT_OPEN", "CONTROL_DIALOG_OPEN"
                    ControlEditOpenFromSys winIdx, sysFileName, sysSectionName, sysArg1
                CASE "CONTROL_EDIT_CLOSE", "CONTROL_DIALOG_CLOSE", "CONTROL_DIALOG_APPLY_CLOSE"
                    ControlEditApplyClose winIdx
                CASE "SET_TEXT"
                    SetTextboxTextByName sysControlName, sysValueText
                    IF sysStatusName <> "" THEN SetTextboxTextByName sysStatusName, ""
                CASE "SOUND_PCM_PLAY"
                    soundFileArg = sysValueText
                    IF soundFileArg = "" AND sysControlName <> "" THEN soundFileArg = GetTextboxTextByName(sysControlName)
                    soundFileArg = ResolvePathFromAppWindow(winIdx, soundFileArg)
                    IF SoundPcmStartRaw16Stereo44100(soundFileArg) <> 0 THEN
                        IF sysStatusName <> "" THEN SetTextboxTextByName sysStatusName, "PCM playing"
                    ELSE
                        IF sysStatusName <> "" THEN SetTextboxTextByName sysStatusName, "PCM playback failed"
                    END IF
                CASE "SOUND_PCM_PLAY_EX"
                    soundSpecText = sysValueText
                    IF sysControlName <> "" THEN
                        soundFileArg = GetTextboxTextByName(sysControlName)
                        soundRateArg = VALINT(SoundPcmSpecField(soundSpecText, 1))
                        soundChannelsArg = VALINT(SoundPcmSpecField(soundSpecText, 2))
                        soundBitsArg = VALINT(SoundPcmSpecField(soundSpecText, 3))
                    ELSE
                        soundFileArg = SoundPcmSpecField(soundSpecText, 1)
                        soundRateArg = VALINT(SoundPcmSpecField(soundSpecText, 2))
                        soundChannelsArg = VALINT(SoundPcmSpecField(soundSpecText, 3))
                        soundBitsArg = VALINT(SoundPcmSpecField(soundSpecText, 4))
                    END IF
                    IF soundRateArg <= 0 THEN soundRateArg = SOUND_PCM_DEFAULT_SRC_RATE
                    IF soundChannelsArg <= 0 THEN soundChannelsArg = 2
                    IF soundBitsArg <= 0 THEN soundBitsArg = 16
                    soundFileArg = ResolvePathFromAppWindow(winIdx, soundFileArg)
                    IF SoundPcmStartFile(soundFileArg, soundRateArg, soundChannelsArg, soundBitsArg) <> 0 THEN
                        IF sysStatusName <> "" THEN SetTextboxTextByName sysStatusName, "PCM playing"
                    ELSE
                        IF sysStatusName <> "" THEN SetTextboxTextByName sysStatusName, "PCM playback failed"
                    END IF
                CASE "SOUND_PCM_STATUS"
                    SoundPcmWriteStatus soundPcmLastStatus
                    IF sysStatusName <> "" THEN SetTextboxTextByName sysStatusName, "PCM status refreshed"
                CASE "SOUND_PCM_STOP"
                    SoundStop
                    SoundPcmWriteStatus "STOPPED"
                    IF sysStatusName <> "" THEN SetTextboxTextByName sysStatusName, "PCM stopped"
                CASE "SOUND_PCM_PAUSE"
                    IF SoundPcmPause() <> 0 THEN
                        IF sysStatusName <> "" THEN SetTextboxTextByName sysStatusName, "PCM paused"
                    ELSE
                        IF sysStatusName <> "" THEN SetTextboxTextByName sysStatusName, "PCM pause failed"
                    END IF
                CASE "SOUND_PCM_RESUME"
                    IF SoundPcmResume() <> 0 THEN
                        IF sysStatusName <> "" THEN SetTextboxTextByName sysStatusName, "PCM resumed"
                    ELSE
                        IF sysStatusName <> "" THEN SetTextboxTextByName sysStatusName, "PCM resume failed"
                    END IF
                END SELECT
            END IF
        END IF

