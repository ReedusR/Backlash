SUB MinimizeLayoutWindow(BYVAL idx AS INTEGER)
    DIM i AS INTEGER
    DIM slotIdx AS INTEGER
    DIM found AS INTEGER

    IF idx < LBOUND(layoutWindows) OR idx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(idx).used = 0 THEN EXIT SUB

    IF activeLayoutWindow = idx THEN SyncLayoutWindowFromGlobals idx

    layoutWindows(idx).minimized = -1
    layoutWindows(idx).active = 0
    layoutWindows(idx).pressedIndex = 0
    layoutWindows(idx).focusIndex = 0
    comboOpenIndex(idx) = 0

    found = 0
    FOR i = UBOUND(layoutZOrder) TO LBOUND(layoutZOrder) STEP -1
        slotIdx = layoutZOrder(i)
        IF slotIdx >= LBOUND(layoutWindows) AND slotIdx <= UBOUND(layoutWindows) THEN
            IF layoutWindows(slotIdx).used <> 0 AND layoutWindows(slotIdx).minimized = 0 THEN
                IF slotIdx <> idx THEN
                    found = slotIdx
                    EXIT FOR
                END IF
            END IF
        END IF
    NEXT

    IF found <> 0 THEN
        ActivateLayoutWindow found
    ELSE
        activeLayoutWindow = 0
        uiWindowActive = 0
        uiPressedIndex = 0
        uiFocusIndex = 0
        uiCaretPos = 0
        uiScrollY = 0
        uiScrollX = 0
        uiSelectedTab = 0
        uiCount = 0
        uiTitle = ""
        uiWinX = 0
        uiWinY = 0
        uiWinW = 0
        uiWinH = 0
        uiDesignW = 0
        uiDesignH = 0
        uiResizable = 0
    END IF

    InvalidateTaskbarCache
END SUB

SUB RestoreLayoutWindow(BYVAL idx AS INTEGER)
    IF idx < LBOUND(layoutWindows) OR idx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(idx).used = 0 THEN EXIT SUB

    layoutWindows(idx).minimized = 0

    IF layoutWindows(idx).resizable = 0 THEN
        layoutWindows(idx).maximized = 0
    ELSEIF layoutWindows(idx).maximized <> 0 THEN
        layoutWindows(idx).x = WORK_X
        layoutWindows(idx).y = WORK_Y
        layoutWindows(idx).w = WORK_W
        layoutWindows(idx).h = WORK_H
    END IF

    InvalidateTaskbarCache
    ActivateLayoutWindow idx
    ApplyLayoutAutoFit idx
    SyncLayoutWindowFromGlobals idx
END SUB

SUB ToggleMaximizeLayoutWindow(BYVAL idx AS INTEGER)
    IF idx < LBOUND(layoutWindows) OR idx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(idx).used = 0 THEN EXIT SUB
    IF layoutWindows(idx).resizable = 0 THEN EXIT SUB

    IF activeLayoutWindow <> idx OR layoutWindows(idx).active = 0 THEN
        ActivateLayoutWindow idx
    ELSE
        SyncLayoutWindowFromGlobals idx
    END IF

    IF layoutWindows(idx).maximized <> 0 THEN
        layoutWindows(idx).maximized = 0
        IF layoutWindows(idx).restoreW < 180 THEN layoutWindows(idx).restoreW = 180
        IF layoutWindows(idx).restoreH < 120 THEN layoutWindows(idx).restoreH = 120
        IF layoutWindows(idx).restoreW > WORK_W THEN layoutWindows(idx).restoreW = WORK_W
        IF layoutWindows(idx).restoreH > WORK_H THEN layoutWindows(idx).restoreH = WORK_H
        layoutWindows(idx).x = layoutWindows(idx).restoreX
        layoutWindows(idx).y = layoutWindows(idx).restoreY
        layoutWindows(idx).w = layoutWindows(idx).restoreW
        layoutWindows(idx).h = layoutWindows(idx).restoreH
        IF layoutWindows(idx).x < WORK_X THEN layoutWindows(idx).x = WORK_X
        IF layoutWindows(idx).y < WORK_Y THEN layoutWindows(idx).y = WORK_Y
        IF layoutWindows(idx).x + layoutWindows(idx).w - 1 > WORK_RIGHT THEN layoutWindows(idx).x = WORK_RIGHT - layoutWindows(idx).w + 1
        IF layoutWindows(idx).y + layoutWindows(idx).h - 1 > WORK_BOTTOM THEN layoutWindows(idx).y = WORK_BOTTOM - layoutWindows(idx).h + 1
        IF layoutWindows(idx).x < WORK_X THEN layoutWindows(idx).x = WORK_X
        IF layoutWindows(idx).y < WORK_Y THEN layoutWindows(idx).y = WORK_Y
    ELSE
        layoutWindows(idx).restoreX = layoutWindows(idx).x
        layoutWindows(idx).restoreY = layoutWindows(idx).y
        layoutWindows(idx).restoreW = layoutWindows(idx).w
        layoutWindows(idx).restoreH = layoutWindows(idx).h
        layoutWindows(idx).x = WORK_X
        layoutWindows(idx).y = WORK_Y
        layoutWindows(idx).w = WORK_W
        layoutWindows(idx).h = WORK_H
        layoutWindows(idx).maximized = -1
    END IF

    layoutWindows(idx).minimized = 0
    activeLayoutWindow = idx
    layoutWindows(idx).active = -1
    MoveLayoutWindowToFront idx
    SyncGlobalsFromLayoutWindow idx
    ApplyLayoutAutoFit idx
    SyncLayoutWindowFromGlobals idx
    InvalidateTaskbarCache
END SUB


FUNCTION LayoutWindowContainsPoint(BYVAL winIdx AS INTEGER, BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER) AS INTEGER
    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN RETURN 0
    IF layoutWindows(winIdx).used = 0 THEN RETURN 0
    IF layoutWindows(winIdx).minimized <> 0 THEN RETURN 0

    RETURN InRect(mouseX, mouseY, layoutWindows(winIdx).x, layoutWindows(winIdx).y, _
                  layoutWindows(winIdx).x + layoutWindows(winIdx).w, layoutWindows(winIdx).y + layoutWindows(winIdx).h)
END FUNCTION

FUNCTION LayoutTopWindowAtPoint(BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER) AS INTEGER
    DIM z AS INTEGER
    DIM winIdx AS INTEGER

    FOR z = UBOUND(layoutZOrder) TO LBOUND(layoutZOrder) STEP -1
        winIdx = layoutZOrder(z)
        IF LayoutWindowContainsPoint(winIdx, mouseX, mouseY) <> 0 THEN RETURN winIdx
    NEXT

    RETURN 0
END FUNCTION

FUNCTION LayoutWindowIsModal(BYVAL winIdx AS INTEGER) AS INTEGER
    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN RETURN 0
    IF layoutWindows(winIdx).used = 0 THEN RETURN 0
    IF layoutWindows(winIdx).minimized <> 0 THEN RETURN 0

    RETURN layoutWindows(winIdx).modal
END FUNCTION

FUNCTION TopModalLayoutWindow() AS INTEGER
    DIM z AS INTEGER
    DIM winIdx AS INTEGER

    FOR z = UBOUND(layoutZOrder) TO LBOUND(layoutZOrder) STEP -1
        winIdx = layoutZOrder(z)
        IF winIdx >= LBOUND(layoutWindows) AND winIdx <= UBOUND(layoutWindows) THEN
            IF LayoutWindowIsModal(winIdx) <> 0 THEN RETURN winIdx
        END IF
    NEXT

    RETURN 0
END FUNCTION


