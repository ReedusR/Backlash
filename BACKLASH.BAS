' Config-driven DOS GUI shell with draggable desktop icons
'
' Reads:
'   SYSTEM\DISPLAY.CFG
'   SYSTEM\DESKTOP.CFG
'   SYSTEM\MOUSE.CFG
'   SYSTEM\SHELL.CFG
'   SYSTEM\THEME.CFG
'   SYSTEM\LAYOUT.CFG
'   SYSTEM\DESKTOP.INI
'   SYSTEM\LAUNCH.INI
'
' Desktop entry format:
'   Caption|Action|BmpFile|X|Y
'
' Start menu format:
'   Caption|Action

' UI element normalized-key IDs reduce repeated hot-path control tests.
CONST UI_KIND_NONE = 0
CONST UI_KIND_LABEL = 1
CONST UI_KIND_BUTTON = 2
CONST UI_KIND_COMBO = 3
CONST UI_KIND_TEXTBOX = 4
CONST UI_KIND_LISTBOX = 5
CONST UI_KIND_TAB = 6
CONST UI_KIND_RADIO = 7
CONST UI_KIND_CHECKBOX = 8
CONST UI_KIND_SPLITTER = 9
CONST UI_KIND_APPVIEW = 10
CONST UI_KIND_OVERLAY = 11
CONST UI_KIND_CANVAS = 12

CONST UI_MODE_NONE = 0
CONST UI_MODE_TEXT_STATS = 1
CONST UI_MODE_SYS = 2

CONST UI_SOURCE_NONE = 0
CONST UI_SOURCE_DIRS = 1
CONST UI_SOURCE_FILES = 2

CONST UI_DRAW_NONE = 0
CONST UI_DRAW_PREVIEW = 1
CONST UI_DRAW_ACTUAL = 2
CONST UI_DRAW_BUTTON = 3
CONST UI_DRAW_FOCUS_SELECT = 4

TYPE UIElement
    kind AS STRING
    text AS STRING
    x AS INTEGER
    y AS INTEGER
    w AS INTEGER
    h AS INTEGER
    page AS STRING
    state AS INTEGER
    name AS STRING
    action AS STRING
    enterAction AS STRING
    escAction AS STRING
    keyAction AS STRING
    keyCapture AS INTEGER
    groupName AS STRING
    bindFile AS STRING
    bindSection AS STRING
    bindKey AS STRING
    bindValue AS STRING
    sourceDir AS STRING
    sourceMask AS STRING
    sourceKind AS STRING
    sourceIndex AS STRING
    valuePrefix AS STRING
    sourceControl AS STRING
    modeGroup AS STRING
    dropRows AS INTEGER
    dropW AS INTEGER
    sourceItems AS STRING
    defaultValue AS STRING
    maxLen AS INTEGER
    noEdit AS INTEGER
    multiSelect AS INTEGER
    drawStyle AS STRING
    baseX AS INTEGER
    baseY AS INTEGER
    baseW AS INTEGER
    baseH AS INTEGER
    growW AS INTEGER
    growH AS INTEGER
    moveX AS INTEGER
    moveY AS INTEGER
    wordWrap AS INTEGER
    kindKey AS STRING
    pageKey AS STRING
    nameKey AS STRING
    groupKey AS STRING
    modeKey AS STRING
    sourceControlKey AS STRING
    sourceKindKey AS STRING
    drawStyleKey AS STRING
    kindId AS INTEGER
    modeId AS INTEGER
    sourceKindId AS INTEGER
    drawStyleId AS INTEGER
END TYPE

SUB NormalizeUiElementKeys(BYREF elem AS UIElement)
    elem.kindKey = UCASE$(TRIM$(elem.kind))
    elem.pageKey = UCASE$(TRIM$(elem.page))
    elem.nameKey = UCASE$(TRIM$(elem.name))
    elem.groupKey = UCASE$(TRIM$(elem.groupName))
    elem.modeKey = UCASE$(TRIM$(elem.modeGroup))
    elem.sourceControlKey = UCASE$(TRIM$(elem.sourceControl))
    elem.sourceKindKey = UCASE$(TRIM$(elem.sourceKind))
    elem.drawStyleKey = UCASE$(TRIM$(elem.drawStyle))

    SELECT CASE elem.kindKey
    CASE "LABEL": elem.kindId = UI_KIND_LABEL
    CASE "BUTTON": elem.kindId = UI_KIND_BUTTON
    CASE "COMBO": elem.kindId = UI_KIND_COMBO
    CASE "TEXTBOX": elem.kindId = UI_KIND_TEXTBOX
    CASE "LISTBOX": elem.kindId = UI_KIND_LISTBOX
    CASE "TAB": elem.kindId = UI_KIND_TAB
    CASE "RADIO": elem.kindId = UI_KIND_RADIO
    CASE "CHECKBOX": elem.kindId = UI_KIND_CHECKBOX
    CASE "SPLITTER": elem.kindId = UI_KIND_SPLITTER
    CASE "APPVIEW": elem.kindId = UI_KIND_APPVIEW
    CASE "OVERLAY": elem.kindId = UI_KIND_OVERLAY
    CASE "CANVAS": elem.kindId = UI_KIND_CANVAS
    CASE ELSE: elem.kindId = UI_KIND_NONE
    END SELECT

    SELECT CASE elem.modeKey
    CASE "TEXT_STATS": elem.modeId = UI_MODE_TEXT_STATS
    CASE "SYS": elem.modeId = UI_MODE_SYS
    CASE ELSE: elem.modeId = UI_MODE_NONE
    END SELECT

    SELECT CASE elem.sourceKindKey
    CASE "DIRS": elem.sourceKindId = UI_SOURCE_DIRS
    CASE "FILES": elem.sourceKindId = UI_SOURCE_FILES
    CASE ELSE: elem.sourceKindId = UI_SOURCE_NONE
    END SELECT

    SELECT CASE elem.drawStyleKey
    CASE "PREVIEW": elem.drawStyleId = UI_DRAW_PREVIEW
    CASE "ACTUAL": elem.drawStyleId = UI_DRAW_ACTUAL
    CASE "BUTTON": elem.drawStyleId = UI_DRAW_BUTTON
    CASE "FOCUS_SELECT": elem.drawStyleId = UI_DRAW_FOCUS_SELECT
    CASE ELSE: elem.drawStyleId = UI_DRAW_NONE
    END SELECT
END SUB

