FOR loopIdx = 0 TO 8
    menuOpenItem(loopIdx) = 0
NEXT
menuPanelCount = 0

lastClickIcon = 0
lastClickTime = -1000
lastClickX = -1000
lastClickY = -1000

mouseDownIcon = 0
mouseDownX = 0
mouseDownY = 0
mouseDownIconX = 0
mouseDownIconY = 0
draggingIcon = 0
dragMoved = 0

StartupSplashStatus "Finishing startup", 12, 12
