SUB EnsureDirectoryExists(BYVAL dirName AS STRING)
    dirName = NormalizePath(TRIM$(dirName))
    IF dirName = "" THEN EXIT SUB
    IF PathExistsAny(dirName) <> 0 THEN EXIT SUB

    MKDIR dirName
END SUB

SUB WriteDefaultFileIfMissing(BYVAL fileName AS STRING, BYVAL dataText AS STRING)
    DIM f AS INTEGER
    DIM scanPos AS INTEGER
    DIM nextPos AS INTEGER
    DIM lineOut AS STRING

    fileName = NormalizePath(TRIM$(fileName))
    IF fileName = "" THEN EXIT SUB
    IF PathExistsAny(fileName) <> 0 THEN EXIT SUB

    f = FREEFILE
    IF OPEN(fileName FOR OUTPUT AS #f) <> 0 THEN EXIT SUB

    scanPos = 1
    DO WHILE scanPos <= LEN(dataText)
        nextPos = INSTR(scanPos, dataText, CHR$(10))
        IF nextPos = 0 THEN
            lineOut = MID$(dataText, scanPos)
            IF RIGHT$(lineOut, 1) = CHR$(13) THEN lineOut = LEFT$(lineOut, LEN(lineOut) - 1)
            PRINT #f, lineOut
            EXIT DO
        ELSE
            lineOut = MID$(dataText, scanPos, nextPos - scanPos)
            IF RIGHT$(lineOut, 1) = CHR$(13) THEN lineOut = LEFT$(lineOut, LEN(lineOut) - 1)
            PRINT #f, lineOut
            scanPos = nextPos + 1
        END IF
    LOOP

    CLOSE #f
    InvalidateCfgReadCacheForFile fileName
END SUB

