        layoutUiElems(idx, i).baseY = 0
        layoutUiElems(idx, i).baseW = 0
        layoutUiElems(idx, i).baseH = 0
        layoutUiElems(idx, i).growW = 0
        layoutUiElems(idx, i).growH = 0
        layoutUiElems(idx, i).moveX = 0
        layoutUiElems(idx, i).moveY = 0
        layoutUiElems(idx, i).wordWrap = 0

        layoutBindInitText(idx, i) = ""
        layoutBindInitState(idx, i) = 0

        ResetEditorControlRuntimeState i, ""
        layoutUiEdit(idx, i) = uiEdit(i)
        layoutUiSelAnchor(idx, i) = 0
        layoutUiPrefCol(idx, i) = 0
        layoutUiWordSelMode(idx, i) = 0
