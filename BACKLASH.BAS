FUNCTION WindowFromPoint(BYVAL mx AS INTEGER, BYVAL my AS INTEGER) AS INTEGER
    DIM i AS INTEGER

    IF cfg.showTaskbar <> 0 THEN
        IF my < WORK_Y OR my > WORK_BOTTOM THEN RETURN 0
    END IF

    FOR i = windowCount TO 1 STEP -1
        IF windows(i).used <> 0 THEN
            IF InRect(mx, my, windows(i).x, windows(i).y, _
                      windows(i).x + windows(i).w - 1, windows(i).y + windows(i).h - 1) THEN
                RETURN i
            END IF
        END IF
    NEXT

    RETURN 0
END FUNCTION

FUNCTION WindowTitleHit(BYVAL idx AS INTEGER, BYVAL mx AS INTEGER, BYVAL my AS INTEGER) AS INTEGER
    IF idx < 1 OR idx > windowCount THEN RETURN 0
    RETURN InRect(mx, my, windows(idx).x + 2, windows(idx).y + 2, _
                  windows(idx).x + windows(idx).w - 3, windows(idx).y + 20)
END FUNCTION

FUNCTION WindowResizeHit(BYVAL idx AS INTEGER, BYVAL mx AS INTEGER, BYVAL my AS INTEGER) AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER

    IF idx < 1 OR idx > windowCount THEN RETURN 0

    x2 = windows(idx).x + windows(idx).w - 1
    y2 = windows(idx).y + windows(idx).h - 1

    RETURN InRect(mx, my, x2 - 12, y2 - 12, x2, y2)
END FUNCTION

SUB BringWindowToFront(BYVAL idx AS INTEGER)
    DIM temp AS GUIWINDOW
    DIM i AS INTEGER

    IF idx < 1 OR idx > windowCount THEN EXIT SUB
    IF idx = windowCount THEN
        activeWindow = idx
        EXIT SUB
    END IF

    temp = windows(idx)
    FOR i = idx TO windowCount - 1
        windows(i) = windows(i + 1)
    NEXT
    windows(windowCount) = temp
    activeWindow = windowCount
END SUB



SUB DrawWindowFrame(BYVAL idx AS INTEGER)
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER
    DIM gx AS INTEGER
    DIM gy AS INTEGER

    IF idx < 1 OR idx > windowCount THEN EXIT SUB
    IF windows(idx).used = 0 THEN EXIT SUB

    x1 = windows(idx).x
    y1 = windows(idx).y
    x2 = x1 + windows(idx).w - 1
    y2 = y1 + windows(idx).h - 1

    LINE (x1, y1)-(x2, y2), COL_BACKGROUND, BF

    IF uiStyle.windowModern <> 0 THEN
        LINE (x1, y1)-(x2, y2), uiStyle.windowBorderLoCol, B
        LINE (x1 + 1, y1 + 1)-(x2 - 1, y1 + 1), uiStyle.windowBorderHiCol
        LINE (x1 + 1, y1 + 1)-(x1 + 1, y2 - 1), uiStyle.windowBorderHiCol
        LINE (x1 + 1, y2 - 1)-(x2 - 1, y2 - 1), uiStyle.windowBorderLoCol
        LINE (x2 - 1, y1 + 1)-(x2 - 1, y2 - 1), uiStyle.windowBorderLoCol
    ELSE
        LINE (x1, y1)-(x2, y1), uiStyle.windowBorderHiCol
        LINE (x1, y1)-(x1, y2), uiStyle.windowBorderHiCol
        LINE (x1 + 1, y1 + 1)-(x2 - 1, y1 + 1), COL_TEXT_INV
        LINE (x1 + 1, y1 + 1)-(x1 + 1, y2 - 1), COL_TEXT_INV
        LINE (x1, y2)-(x2, y2), COL_TEXT
        LINE (x2, y1)-(x2, y2), COL_TEXT
        LINE (x1 + 1, y2 - 1)-(x2 - 1, y2 - 1), uiStyle.windowBorderLoCol
        LINE (x2 - 1, y1 + 1)-(x2 - 1, y2 - 1), uiStyle.windowBorderLoCol
    END IF

    DrawThemedTitleBar x1 + 3, y1 + 3, x2 - 3, y1 + 20, -1
    DRAW STRING (x1 + 8, y1 + 7), windows(idx).title, COL_TEXT_INV

    LINE (x1 + 3, y1 + 22)-(x2 - 3, y2 - 3), COL_BACKGROUND, BF

    gx = x2 - 10
    gy = y2 - 10
    LINE (gx + 4, gy + 10)-(gx + 10, gy + 4), uiStyle.windowBorderLoCol
    LINE (gx + 7, gy + 10)-(gx + 10, gy + 7), uiStyle.windowBorderLoCol
    LINE (gx + 1, gy + 10)-(gx + 10, gy + 1), uiStyle.windowBorderHiCol
    LINE (gx + 4, gy + 10)-(gx + 10, gy + 4), uiStyle.windowBorderHiCol
END SUB

SUB DrawWindowClient(BYVAL idx AS INTEGER)
    DIM x1 AS INTEGER
    DIM y1 AS INTEGER
    DIM x2 AS INTEGER
    DIM y2 AS INTEGER

    IF idx < 1 OR idx > windowCount THEN EXIT SUB
    IF windows(idx).used = 0 THEN EXIT SUB

    x1 = windows(idx).x + 6
    y1 = windows(idx).y + 26
    x2 = windows(idx).x + windows(idx).w - 7
    y2 = windows(idx).y + windows(idx).h - 7

    LINE (x1, y1)-(x2, y2), COL_BACKGROUND, BF
    DRAW STRING (x1 + 8, y1 + 8), "Window host ready", COL_TEXT
END SUB

SUB DrawWindows()
    DIM i AS INTEGER

    FOR i = 1 TO windowCount
        IF windows(i).used <> 0 THEN
            DrawWindowFrame i
            DrawWindowClient i
        END IF
    NEXT
END SUB

