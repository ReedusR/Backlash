SUB LoadWallpaper()
    FreeWallpaper

    IF theme.wallpaperMode = 0 THEN EXIT SUB
    IF theme.wallpaperPath = "" THEN EXIT SUB

    wallLoaded = LoadBmpColor(theme.wallpaperPath, wallPix, wallW, wallH)
    IF wallLoaded = 0 THEN
        wallPix = 0
        wallW = 0
        wallH = 0
    ELSEIF theme.wallpaperMode = 2 THEN
        wallImage = BuildImageBufferFromPixels(wallPix, wallW, wallH)
    ELSEIF theme.wallpaperMode = 1 AND wallW <= SCR_W AND wallH <= SCR_H THEN
        wallImage = BuildImageBufferFromPixels(wallPix, wallW, wallH)
    ELSEIF theme.wallpaperMode = 3 AND wallW = SCR_W AND wallH = SCR_H THEN
        wallImage = BuildImageBufferFromPixels(wallPix, wallW, wallH)
    END IF
END SUB

