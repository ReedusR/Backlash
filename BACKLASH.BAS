FUNCTION ShellCfgValue2(BYVAL sectionName AS STRING, BYVAL keyName AS STRING, BYVAL legacyKeyName AS STRING, BYVAL defaultValue AS STRING) AS STRING
    DIM cfgText AS STRING

    cfgText = ""
    IF TRIM$(sectionName) <> "" AND TRIM$(keyName) <> "" THEN
        cfgText = TRIM$(ReadCfgValueInSection(PATH_SHELLCFG, sectionName, keyName, ""))
    END IF
    IF cfgText = "" AND TRIM$(legacyKeyName) <> "" THEN
        cfgText = TRIM$(ReadCfgValue(PATH_SHELLCFG, legacyKeyName, ""))
    END IF
    IF cfgText = "" THEN cfgText = defaultValue

    RETURN cfgText
END FUNCTION

FUNCTION ShellCfgPath(BYVAL sectionName AS STRING, BYVAL keyName AS STRING, BYVAL legacyKeyName AS STRING) AS STRING
    RETURN NormalizePath(ShellCfgValue2(sectionName, keyName, legacyKeyName, ""))
END FUNCTION

FUNCTION ShellHandlerPath(BYVAL keyName AS STRING) AS STRING
    RETURN ShellCfgPath("HANDLERS", keyName, "")
END FUNCTION

FUNCTION ShellDesktopPath(BYVAL keyName AS STRING, BYVAL legacyKeyName AS STRING) AS STRING
    RETURN ShellCfgPath("DESKTOP", keyName, legacyKeyName)
END FUNCTION

FUNCTION ShellDesktopTempPath(BYVAL keyName AS STRING, BYVAL legacyKeyName AS STRING) AS STRING
    RETURN ShellCfgPath("DESKTOP", keyName, legacyKeyName)
END FUNCTION

FUNCTION MenuEditorTargetPath() AS STRING
    RETURN ShellHandlerPath("LAUNCH_MENU_EDIT")
END FUNCTION

