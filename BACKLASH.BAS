' ---------------------------
' Resolution / layout
' ---------------------------

SUB ApplyResolution()
    SELECT CASE cfg.resMode
        CASE 1
            SCR_W = 640 : SCR_H = 480
        CASE 2
            SCR_W = 800 : SCR_H = 600
        CASE 3
            SCR_W = 1024 : SCR_H = 768
        CASE ELSE
            SCR_W = 800 : SCR_H = 600
    END SELECT
END SUB

SUB BuildLayout()
    TASKBAR_H = lay.taskbarH
    IF TASKBAR_H < 20 THEN TASKBAR_H = 20
    IF TASKBAR_H > SCR_H - 32 THEN TASKBAR_H = 30
    IF TASKBAR_H > SCR_H - 8 THEN TASKBAR_H = SCR_H - 8

    IF lay.taskbarEdge = TASKBAR_EDGE_TOP THEN
        TASKBAR_Y = 0
    ELSE
        TASKBAR_Y = SCR_H - TASKBAR_H
    END IF

    RebuildTaskbarLayoutCache

    WORK_X = 0
    WORK_W = SCR_W
    IF cfg.showTaskbar <> 0 THEN
        IF lay.taskbarEdge = TASKBAR_EDGE_TOP THEN
            WORK_Y = TASKBAR_Y2 + 1
        ELSE
            WORK_Y = 0
        END IF
        WORK_H = SCR_H - TASKBAR_H
    ELSE
        WORK_Y = 0
        WORK_H = SCR_H
    END IF
    IF WORK_H < 1 THEN
        WORK_Y = 0
        WORK_H = SCR_H
    END IF
    WORK_RIGHT = WORK_X + WORK_W - 1
    WORK_BOTTOM = WORK_Y + WORK_H - 1

    MENU_X1 = 4
    MENU_W = lay.menuW
    ITEM_H = lay.menuItemH

    ICON_CELL_W = lay.iconCellW
    ICON_CELL_H = lay.iconCellH
    ICON_PAD_X = lay.iconPadX
    ICON_PAD_Y = lay.iconPadY
    ICON_TEXT_Y_OFFSET = lay.iconTextYOffset

    START_X1 = 4
    START_Y1 = TASKBAR_CLIENT_Y1
    START_X2 = START_X1 + lay.startW
    START_Y2 = TASKBAR_CLIENT_Y2

    ClearMenuMetricsCache
    InvalidateTaskbarCache
END SUB

' ---------------------------
' BMP loader helpers
' ---------------------------

FUNCTION CountTrailingZeros(BYVAL mask AS UINTEGER) AS INTEGER
    DIM n AS INTEGER

    IF mask = 0 THEN RETURN 0

    n = 0
    DO WHILE (mask AND 1) = 0
        mask = mask SHR 1
        n = n + 1
    LOOP

    RETURN n
END FUNCTION

FUNCTION CountBits(BYVAL mask AS UINTEGER) AS INTEGER
    DIM n AS INTEGER

    n = 0
    DO WHILE mask <> 0
        IF (mask AND 1) <> 0 THEN n = n + 1
        mask = mask SHR 1
    LOOP

    RETURN n
END FUNCTION

FUNCTION ExpandMaskedChannel(BYVAL value AS UINTEGER, BYVAL mask AS UINTEGER) AS INTEGER
    DIM shift AS INTEGER
    DIM bits AS INTEGER
    DIM raw AS UINTEGER
    DIM denom AS LONG

    IF mask = 0 THEN RETURN 0

    shift = CountTrailingZeros(mask)
    bits = CountBits(mask)

    IF bits <= 0 THEN RETURN 0
    IF bits > 16 THEN RETURN 0

    raw = (value AND mask) SHR shift

    SELECT CASE bits
        CASE 1 : RETURN raw * 255
        CASE 2 : RETURN raw * 255 \ 3
        CASE 3 : RETURN raw * 255 \ 7
        CASE 4 : RETURN raw * 255 \ 15
        CASE 5 : RETURN raw * 255 \ 31
        CASE 6 : RETURN raw * 255 \ 63
        CASE 7 : RETURN raw * 255 \ 127
        CASE 8 : RETURN raw
        CASE ELSE
            denom = (1 SHL bits) - 1
            IF denom <= 0 THEN RETURN 0
            RETURN raw * 255 \ denom
    END SELECT
END FUNCTION

FUNCTION Valid16Masks(BYVAL rMask AS UINTEGER, BYVAL gMask AS UINTEGER, BYVAL bMask AS UINTEGER) AS INTEGER
    IF rMask = 0 OR gMask = 0 OR bMask = 0 THEN RETURN 0
    IF (rMask AND gMask) <> 0 THEN RETURN 0
    IF (rMask AND bMask) <> 0 THEN RETURN 0
    IF (gMask AND bMask) <> 0 THEN RETURN 0
    RETURN -1
END FUNCTION


SUB ClearIconBmpCache()
    DIM i AS INTEGER

    FOR i = 1 TO ICON_BMP_CACHE_MAX
        IF iconBmpCachePix(i) <> 0 THEN
            DEALLOCATE iconBmpCachePix(i)
            iconBmpCachePix(i) = 0
        END IF
        iconBmpCacheValid(i) = 0
        iconBmpCacheLoaded(i) = 0
        iconBmpCacheKey(i) = ""
        iconBmpCacheW(i) = 0
        iconBmpCacheH(i) = 0
        iconBmpCacheAge(i) = 0
    NEXT

    iconBmpCacheTick = 0
END SUB

FUNCTION CopyIconPixelBuffer(BYVAL srcPix AS UINTEGER PTR, BYVAL imgW AS INTEGER, BYVAL imgH AS INTEGER) AS UINTEGER PTR
    DIM copyPix AS UINTEGER PTR
    DIM pixCount AS LONG
    DIM i AS LONG

    IF srcPix = 0 THEN RETURN 0
    IF imgW <= 0 OR imgH <= 0 THEN RETURN 0

    pixCount = CLNG(imgW) * CLNG(imgH)
    IF pixCount <= 0 THEN RETURN 0

    copyPix = ALLOCATE(pixCount * SIZEOF(UINTEGER))
    IF copyPix = 0 THEN RETURN 0

    FOR i = 0 TO pixCount - 1
        copyPix[i] = srcPix[i]
    NEXT

    RETURN copyPix
END FUNCTION

FUNCTION LoadIconBmpCached(BYVAL fileName AS STRING, BYREF pix AS UINTEGER PTR, BYREF w AS INTEGER, BYREF h AS INTEGER) AS INTEGER
    DIM normPath AS STRING
    DIM cacheKey AS STRING
    DIM slotIdx AS INTEGER
    DIM oldestSlot AS INTEGER
    DIM i AS INTEGER
    DIM loadedPix AS UINTEGER PTR
    DIM loadedW AS INTEGER
    DIM loadedH AS INTEGER
    DIM cachePix AS UINTEGER PTR
    DIM bestAge AS LONG

    pix = 0
    w = 0
    h = 0

    normPath = NormalizePath(fileName)
    IF normPath = "" THEN RETURN 0

    cacheKey = UCASE$(normPath) + "|" + LTRIM$(STR$(cfg.colorDepth))

    FOR i = 1 TO ICON_BMP_CACHE_MAX
        IF iconBmpCacheValid(i) <> 0 THEN
            IF iconBmpCacheKey(i) = cacheKey THEN
                iconBmpCacheTick = iconBmpCacheTick + 1
                iconBmpCacheAge(i) = iconBmpCacheTick
                IF iconBmpCacheLoaded(i) = 0 THEN RETURN 0
                pix = CopyIconPixelBuffer(iconBmpCachePix(i), iconBmpCacheW(i), iconBmpCacheH(i))
                IF pix = 0 THEN RETURN 0
                w = iconBmpCacheW(i)
                h = iconBmpCacheH(i)
                RETURN -1
            END IF
        END IF
    NEXT

    loadedPix = 0
    loadedW = 0
    loadedH = 0

    slotIdx = 0
    FOR i = 1 TO ICON_BMP_CACHE_MAX
        IF iconBmpCacheValid(i) = 0 THEN
            slotIdx = i
            EXIT FOR
        END IF
    NEXT

    IF slotIdx = 0 THEN
        oldestSlot = 1
        bestAge = iconBmpCacheAge(1)
        FOR i = 2 TO ICON_BMP_CACHE_MAX
            IF iconBmpCacheAge(i) < bestAge THEN
                bestAge = iconBmpCacheAge(i)
                oldestSlot = i
            END IF
        NEXT
        slotIdx = oldestSlot
        IF iconBmpCachePix(slotIdx) <> 0 THEN
            DEALLOCATE iconBmpCachePix(slotIdx)
            iconBmpCachePix(slotIdx) = 0
        END IF
    END IF

    iconBmpCacheTick = iconBmpCacheTick + 1
    iconBmpCacheValid(slotIdx) = -1
    iconBmpCacheLoaded(slotIdx) = 0
    iconBmpCacheKey(slotIdx) = cacheKey
    iconBmpCacheW(slotIdx) = 0
    iconBmpCacheH(slotIdx) = 0
    iconBmpCacheAge(slotIdx) = iconBmpCacheTick

    IF LoadBmpColor(normPath, loadedPix, loadedW, loadedH) = 0 THEN RETURN 0
    IF loadedPix = 0 OR loadedW <= 0 OR loadedH <= 0 THEN
        IF loadedPix <> 0 THEN DEALLOCATE loadedPix
        RETURN 0
    END IF

    cachePix = CopyIconPixelBuffer(loadedPix, loadedW, loadedH)
    IF cachePix <> 0 THEN
        iconBmpCachePix(slotIdx) = cachePix
        iconBmpCacheW(slotIdx) = loadedW
        iconBmpCacheH(slotIdx) = loadedH
        iconBmpCacheLoaded(slotIdx) = -1
    ELSE
        iconBmpCacheValid(slotIdx) = 0
        iconBmpCacheLoaded(slotIdx) = 0
        iconBmpCacheKey(slotIdx) = ""
    END IF

    pix = loadedPix
    w = loadedW
    h = loadedH
    RETURN -1
END FUNCTION

SUB ClearResolvedIconPathCache()
    DIM i AS INTEGER

    ClearIconBmpCache

    resolvedIconPathCacheCount = 0
    FOR i = 1 TO RESOLVED_ICON_PATH_CACHE_MAX
        resolvedIconPathCacheKey(i) = ""
        resolvedIconPathCacheValue(i) = ""
    NEXT
END SUB

FUNCTION ResolveIconBmpPath(BYVAL fileName AS STRING) AS STRING
    DIM p AS STRING
    DIM up AS STRING
    DIM candidate AS STRING
    DIM markAt AS INTEGER
    DIM markLen AS INTEGER
    DIM colorFolder AS STRING
    DIM restPath AS STRING
    DIM cacheKey AS STRING
    DIM resolvedPath AS STRING
    DIM i AS INTEGER
    DIM slotIdx AS INTEGER

    p = NormalizePath(fileName)
    IF p = "" THEN RETURN p

    cacheKey = LTRIM$(STR$(cfg.colorDepth)) + "|" + UCASE$(p)
    FOR i = 1 TO resolvedIconPathCacheCount
        IF resolvedIconPathCacheKey(i) = cacheKey THEN RETURN resolvedIconPathCacheValue(i)
    NEXT

    IF cfg.colorDepth = 4 THEN
        colorFolder = "16COLOR\"
    ELSEIF cfg.colorDepth = 8 THEN
        colorFolder = "256COLOR\"
    ELSE
        resolvedPath = p
        GOTO ResolveIconBmpPathStore
    END IF

    up = UCASE$(p)
    IF INSTR(up, "\" + UCASE$(colorFolder)) > 0 THEN
        resolvedPath = p
        GOTO ResolveIconBmpPathStore
    END IF

    markAt = INSTR(up, "ICONS\16\")
    IF markAt > 0 THEN
        markLen = LEN("ICONS\16\")
        candidate = LEFT$(p, markAt + markLen - 1) + colorFolder + MID$(p, markAt + markLen)
        IF DIR(candidate) <> "" THEN
            resolvedPath = candidate
        ELSE
            resolvedPath = p
        END IF
        GOTO ResolveIconBmpPathStore
    END IF

    markAt = INSTR(up, "ICONS\48\")
    IF markAt > 0 THEN
        markLen = LEN("ICONS\48\")
        candidate = LEFT$(p, markAt + markLen - 1) + colorFolder + MID$(p, markAt + markLen)
        IF DIR(candidate) <> "" THEN
            resolvedPath = candidate
        ELSE
            resolvedPath = p
        END IF
        GOTO ResolveIconBmpPathStore
    END IF

    markAt = INSTR(up, "ICONS\")
    IF markAt > 0 THEN
        markLen = LEN("ICONS\")
        restPath = MID$(p, markAt + markLen)
        IF INSTR(restPath, "\") = 0 THEN
            candidate = LEFT$(p, markAt + markLen - 1) + colorFolder + restPath
            IF DIR(candidate) <> "" THEN
                resolvedPath = candidate
            ELSE
                resolvedPath = p
            END IF
            GOTO ResolveIconBmpPathStore
        END IF
    END IF

    resolvedPath = p

ResolveIconBmpPathStore:
    IF resolvedIconPathCacheCount < RESOLVED_ICON_PATH_CACHE_MAX THEN
        resolvedIconPathCacheCount = resolvedIconPathCacheCount + 1
        slotIdx = resolvedIconPathCacheCount
    ELSE
        slotIdx = 1
    END IF
    resolvedIconPathCacheKey(slotIdx) = cacheKey
    resolvedIconPathCacheValue(slotIdx) = resolvedPath
    ResolveIconBmpPath = resolvedPath
END FUNCTION

' Maps the active theme launch-button bitmap to the correct color-depth folder.
FUNCTION ResolveLaunchButtonBmpPath(BYVAL fileName AS STRING) AS STRING
    DIM p AS STRING
    DIM up AS STRING
    DIM colorFolder AS STRING
    DIM markAt AS INTEGER
    DIM markLen AS INTEGER
    DIM restPath AS STRING
    DIM iconRoot AS STRING

    p = NormalizePath(fileName)
    IF p = "" THEN p = "ICONS\LAUNCH\LAUNCH.BMP"

    up = UCASE$(p)
    IF INSTR(up, "\16COLOR\") > 0 OR INSTR(up, "\256COLOR\") > 0 THEN RETURN p

    IF cfg.colorDepth = 4 THEN
        colorFolder = "16COLOR\LAUNCH\"
    ELSEIF cfg.colorDepth = 8 THEN
        colorFolder = "256COLOR\LAUNCH\"
    ELSE
        colorFolder = "LAUNCH\"
    END IF

    markAt = INSTR(up, "ICONS\LAUNCH\")
    IF markAt > 0 THEN
        markLen = LEN("ICONS\LAUNCH\")
        restPath = MID$(p, markAt + markLen)
        IF INSTR(restPath, "\") = 0 THEN
            iconRoot = LEFT$(p, markAt + LEN("ICONS\") - 1)
            IF cfg.colorDepth = 4 OR cfg.colorDepth = 8 THEN RETURN iconRoot + colorFolder + restPath
            RETURN p
        END IF
    END IF

    markAt = INSTR(up, "ICONS\")
    IF markAt > 0 THEN
        markLen = LEN("ICONS\")
        restPath = MID$(p, markAt + markLen)
        IF INSTR(restPath, "\") = 0 THEN
            RETURN LEFT$(p, markAt + markLen - 1) + colorFolder + restPath
        END IF
    END IF

    RETURN ResolveIconBmpPath(p)
END FUNCTION

FUNCTION ResolveStartStripBmpPath(BYVAL fileName AS STRING) AS STRING
    DIM p AS STRING
    DIM up AS STRING
    DIM candidate AS STRING
    DIM splitAt AS INTEGER
    DIM i AS INTEGER
    DIM ch AS STRING
    DIM colorFolder AS STRING

    p = NormalizePath(fileName)
    IF p = "" THEN RETURN p

    IF cfg.colorDepth = 4 THEN
        colorFolder = "16COLOR\"
    ELSEIF cfg.colorDepth = 8 THEN
        colorFolder = "256COLOR\"
    ELSE
        RETURN p
    END IF

    up = UCASE$(p)
    IF INSTR(up, "\" + UCASE$(colorFolder)) > 0 THEN RETURN p

    splitAt = 0
    FOR i = LEN(p) TO 1 STEP -1
        ch = MID$(p, i, 1)
        IF ch = CHR$(92) OR ch = ":" THEN
            splitAt = i
            EXIT FOR
        END IF
    NEXT

    IF splitAt > 0 THEN
        candidate = LEFT$(p, splitAt) + colorFolder + MID$(p, splitAt + 1)
    ELSE
        candidate = colorFolder + p
    END IF

    IF DIR(candidate) <> "" THEN RETURN candidate
    RETURN p
END FUNCTION

' ---------------------------
' BMP loader
' ---------------------------

' Loads a BMP and converts it to the color format currently used by Backlash.
FUNCTION LoadBmpColor(BYVAL fileName AS STRING, BYREF pix AS UINTEGER PTR, BYREF w AS INTEGER, BYREF h AS INTEGER) AS INTEGER
    DIM f AS INTEGER
    DIM sig AS USHORT
    DIM fileSize AS UINTEGER
    DIM reserved1 AS USHORT
    DIM reserved2 AS USHORT
    DIM dataOffset AS UINTEGER

    DIM infoSize AS UINTEGER
    DIM bmpW AS INTEGER
    DIM bmpH AS INTEGER
    DIM planes AS USHORT
    DIM bitCount AS USHORT
    DIM compression AS UINTEGER
    DIM sizeImage AS UINTEGER
    DIM xppm AS INTEGER
    DIM yppm AS INTEGER
    DIM clrUsed AS UINTEGER
    DIM clrImportant AS UINTEGER

    DIM redMask AS UINTEGER
    DIM greenMask AS UINTEGER
    DIM blueMask AS UINTEGER

    DIM rowSize AS INTEGER
    DIM x AS INTEGER
    DIM y AS INTEGER
    DIM srcY AS INTEGER
    DIM idx AS LONG

    DIM c16 AS USHORT
    DIM c32 AS UINTEGER
    DIM r AS INTEGER
    DIM g AS INTEGER
    DIM b AS INTEGER
    DIM a AS UBYTE
    DIM ub AS UBYTE
    DIM ug AS UBYTE
    DIM ur AS UBYTE
    DIM palR(0 TO 255) AS INTEGER
    DIM palG(0 TO 255) AS INTEGER
    DIM palB(0 TO 255) AS INTEGER
    DIM palColor(0 TO 255) AS UINTEGER
    DIM palCount AS INTEGER
    DIM palIdx AS INTEGER
    DIM nibble AS INTEGER
    DIM bitIdx AS INTEGER
    DIM coreW AS USHORT
    DIM coreH AS USHORT
    DIM corePlanes AS USHORT
    DIM coreBitCount AS USHORT
    DIM isCoreBmp AS INTEGER
    DIM rleCount AS UBYTE
    DIM rleValue AS UBYTE
    DIM rleByte AS UBYTE
    DIM rlePad AS UBYTE
    DIM rleX AS INTEGER
    DIM rleY AS INTEGER
    DIM rleN AS INTEGER
    DIM rleAbsBytes AS INTEGER
    DIM rlePixIdx AS LONG
    DIM rleColorIdx AS INTEGER
    DIM rleDx AS UBYTE
    DIM rleDy AS UBYTE

    fileName = NormalizePath(fileName)

    pix = 0
    w = 0
    h = 0
    redMask = 0
    greenMask = 0
    blueMask = 0

    f = FREEFILE
    IF OPEN(fileName FOR BINARY ACCESS READ AS #f) <> 0 THEN RETURN 0
    IF LOF(f) < 26 THEN
        CLOSE #f
        RETURN 0
    END IF

    GET #f, , sig
    GET #f, , fileSize
    GET #f, , reserved1
    GET #f, , reserved2
    GET #f, , dataOffset

    IF sig <> &H4D42 THEN
        CLOSE #f
        RETURN 0
    END IF

    GET #f, , infoSize
    isCoreBmp = 0
    IF infoSize = 12 THEN
        GET #f, , coreW
        GET #f, , coreH
        GET #f, , corePlanes
        GET #f, , coreBitCount
        bmpW = coreW
        bmpH = coreH
        planes = corePlanes
        bitCount = coreBitCount
        compression = 0
        sizeImage = 0
        xppm = 0
        yppm = 0
        clrUsed = 0
        clrImportant = 0
        isCoreBmp = -1
    ELSEIF infoSize >= 40 THEN
        GET #f, , bmpW
        GET #f, , bmpH
        GET #f, , planes
        GET #f, , bitCount
        GET #f, , compression
        GET #f, , sizeImage
        GET #f, , xppm
        GET #f, , yppm
        GET #f, , clrUsed
        GET #f, , clrImportant
    ELSE
        CLOSE #f
        RETURN 0
    END IF

    IF planes <> 1 THEN
        CLOSE #f
        RETURN 0
    END IF

    IF bitCount <> 1 AND bitCount <> 4 AND bitCount <> 8 AND bitCount <> 16 AND bitCount <> 24 AND bitCount <> 32 THEN
        CLOSE #f
        RETURN 0
    END IF

    IF bitCount = 16 OR bitCount = 32 THEN
        IF compression <> 0 AND compression <> 3 THEN
            CLOSE #f
            RETURN 0
        END IF
    ELSEIF bitCount = 8 THEN
        IF compression <> 0 AND compression <> 1 THEN
            CLOSE #f
            RETURN 0
        END IF
    ELSEIF bitCount = 4 THEN
        IF compression <> 0 AND compression <> 2 THEN
            CLOSE #f
            RETURN 0
        END IF
    ELSE
        IF compression <> 0 THEN
            CLOSE #f
            RETURN 0
        END IF
    END IF

    IF bmpW <= 0 OR bmpH = 0 THEN
        CLOSE #f
        RETURN 0
    END IF

    w = bmpW
    IF bmpH < 0 THEN
        h = -bmpH
    ELSE
        h = bmpH
    END IF

    pix = CALLocate(w * h, SIZEOF(UINTEGER))
    IF pix = 0 THEN
        CLOSE #f
        RETURN 0
    END IF

    IF (bitCount = 16 OR bitCount = 32) AND compression = 3 THEN
        GET #f, , redMask
        GET #f, , greenMask
        GET #f, , blueMask

        IF bitCount = 16 THEN
            IF Valid16Masks(redMask, greenMask, blueMask) = 0 THEN
                redMask = &HF800
                greenMask = &H07E0
                blueMask = &H001F
            END IF
        ELSEIF redMask = 0 OR greenMask = 0 OR blueMask = 0 THEN
            redMask = &H00FF0000
            greenMask = &H0000FF00
            blueMask = &H000000FF
        END IF
    ELSEIF bitCount = 16 THEN
        redMask = &HF800
        greenMask = &H07E0
        blueMask = &H001F
    ELSEIF bitCount = 32 THEN
        redMask = &H00FF0000
        greenMask = &H0000FF00
        blueMask = &H000000FF
    END IF

    IF bitCount = 1 OR bitCount = 4 OR bitCount = 8 THEN
        IF bitCount = 1 THEN
            IF clrUsed > 0 AND clrUsed <= 2 THEN
                palCount = CINT(clrUsed)
            ELSE
                palCount = 2
            END IF
        ELSEIF bitCount = 4 THEN
            IF clrUsed > 0 AND clrUsed <= 16 THEN
                palCount = CINT(clrUsed)
            ELSE
                palCount = 16
            END IF
        ELSE
            IF clrUsed > 0 AND clrUsed <= 256 THEN
                palCount = CINT(clrUsed)
            ELSE
                palCount = 256
            END IF
        END IF
        SEEK #f, CLNG(14) + CLNG(infoSize) + 1
        FOR palIdx = 0 TO palCount - 1
            GET #f, , ub
            GET #f, , ug
            GET #f, , ur
            IF isCoreBmp = 0 THEN GET #f, , a
            palB(palIdx) = ub
            palG(palIdx) = ug
            palR(palIdx) = ur
        NEXT

        FOR palIdx = 0 TO palCount - 1
            r = palR(palIdx)
            g = palG(palIdx)
            b = palB(palIdx)
            IF r = 255 AND g = 0 AND b = 255 THEN
                palColor(palIdx) = RGB(255, 0, 255)
            ELSEIF cfg.colorDepth = 4 AND bitCount = 4 THEN
                palColor(palIdx) = Backlash16ColorIndex(r, g, b)
            ELSEIF cfg.colorDepth = 8 THEN
                palColor(palIdx) = Backlash256ColorIndex(r, g, b)
            ELSE
                palColor(palIdx) = RGB(r, g, b)
            END IF
        NEXT
    END IF

    IF (bitCount = 8 AND compression = 1) OR (bitCount = 4 AND compression = 2) THEN
        IF bmpH < 0 THEN
            CLOSE #f
            IF pix <> 0 THEN DEALLOCATE pix
            pix = 0
            w = 0
            h = 0
            RETURN 0
        END IF

        SEEK #f, dataOffset + 1
        rleX = 0
        rleY = h - 1

        DO WHILE EOF(f) = 0 AND rleY >= 0
            GET #f, , rleCount
            IF EOF(f) THEN EXIT DO
            GET #f, , rleValue

            IF rleCount > 0 THEN
                FOR rleN = 0 TO rleCount - 1
                    IF bitCount = 8 THEN
                        rleColorIdx = rleValue
                    ELSE
                        IF (rleN AND 1) = 0 THEN
                            rleColorIdx = (rleValue SHR 4) AND 15
                        ELSE
                            rleColorIdx = rleValue AND 15
                        END IF
                    END IF

                    IF rleColorIdx < 0 THEN rleColorIdx = 0
                    IF rleColorIdx > 255 THEN rleColorIdx = 0
                    IF rleX >= 0 AND rleX < w AND rleY >= 0 AND rleY < h THEN
                        rlePixIdx = CLNG(rleY) * w + rleX
                        pix[rlePixIdx] = palColor(rleColorIdx)
                    END IF
                    rleX = rleX + 1
                NEXT
            ELSE
                SELECT CASE rleValue
                    CASE 0
                        rleX = 0
                        rleY = rleY - 1

                    CASE 1
                        EXIT DO

                    CASE 2
                        GET #f, , rleDx
                        GET #f, , rleDy
                        rleX = rleX + rleDx
                        rleY = rleY - rleDy

                    CASE ELSE
                        IF bitCount = 8 THEN
                            FOR rleN = 0 TO rleValue - 1
                                GET #f, , rleByte
                                rleColorIdx = rleByte
                                IF rleColorIdx < 0 THEN rleColorIdx = 0
                                IF rleColorIdx > 255 THEN rleColorIdx = 0
                                IF rleX >= 0 AND rleX < w AND rleY >= 0 AND rleY < h THEN
                                    rlePixIdx = CLNG(rleY) * w + rleX
                                    pix[rlePixIdx] = palColor(rleColorIdx)
                                END IF
                                rleX = rleX + 1
                            NEXT
                            IF (rleValue AND 1) <> 0 THEN GET #f, , rlePad
                        ELSE
                            rleAbsBytes = (rleValue + 1) \ 2
                            FOR rleN = 0 TO rleValue - 1
                                IF (rleN AND 1) = 0 THEN GET #f, , rleByte
                                IF (rleN AND 1) = 0 THEN
                                    rleColorIdx = (rleByte SHR 4) AND 15
                                ELSE
                                    rleColorIdx = rleByte AND 15
                                END IF
                                IF rleColorIdx < 0 THEN rleColorIdx = 0
                                IF rleColorIdx > 255 THEN rleColorIdx = 0
                                IF rleX >= 0 AND rleX < w AND rleY >= 0 AND rleY < h THEN
                                    rlePixIdx = CLNG(rleY) * w + rleX
                                    pix[rlePixIdx] = palColor(rleColorIdx)
                                END IF
                                rleX = rleX + 1
                            NEXT
                            IF (rleAbsBytes AND 1) <> 0 THEN GET #f, , rlePad
                        END IF
                END SELECT
            END IF
        LOOP

        CLOSE #f
        RETURN -1
    END IF

    IF bitCount = 1 THEN
        rowSize = ((w + 31) \ 32) * 4
    ELSEIF bitCount = 4 THEN
        rowSize = ((w * 4 + 31) \ 32) * 4
    ELSEIF bitCount = 8 THEN
        rowSize = ((w * 8 + 31) \ 32) * 4
    ELSE
        rowSize = ((w * (bitCount \ 8) + 3) \ 4) * 4
    END IF

    FOR y = 0 TO h - 1
        IF bmpH > 0 THEN
            srcY = h - 1 - y
        ELSE
            srcY = y
        END IF

        SEEK #f, dataOffset + srcY * rowSize + 1

        FOR x = 0 TO w - 1
            idx = CLNG(y) * w + x

            SELECT CASE bitCount
                CASE 1
                    IF (x AND 7) = 0 THEN
                        GET #f, , ub
                    END IF
                    bitIdx = 7 - (x AND 7)
                    palIdx = (ub SHR bitIdx) AND 1
                    pix[idx] = palColor(palIdx)

                CASE 4
                    IF (x AND 1) = 0 THEN
                        GET #f, , ub
                    END IF
                    IF (x AND 1) = 0 THEN
                        nibble = ub SHR 4
                    ELSE
                        nibble = ub AND 15
                    END IF
                    IF nibble < 0 THEN nibble = 0
                    IF nibble > 255 THEN nibble = 0
                    pix[idx] = palColor(nibble)

                CASE 8
                    GET #f, , ub
                    pix[idx] = palColor(ub)

                CASE 16
                    GET #f, , c16
                    c32 = c16
                    r = ExpandMaskedChannel(c32, redMask)
                    g = ExpandMaskedChannel(c32, greenMask)
                    b = ExpandMaskedChannel(c32, blueMask)
                    IF r = 255 AND g = 0 AND b = 255 THEN
                        pix[idx] = RGB(255, 0, 255)
                    ELSEIF cfg.colorDepth = 8 THEN
                        pix[idx] = Backlash256ColorIndex(r, g, b)
                    ELSE
                        pix[idx] = RGB(r, g, b)
                    END IF

                CASE 24
                    GET #f, , ub
                    GET #f, , ug
                    GET #f, , ur
                    IF ur = 255 AND ug = 0 AND ub = 255 THEN
                        pix[idx] = RGB(255, 0, 255)
                    ELSEIF cfg.colorDepth = 8 THEN
                        pix[idx] = Backlash256ColorIndex(ur, ug, ub)
                    ELSE
                        pix[idx] = RGB(ur, ug, ub)
                    END IF

                CASE 32
                    IF compression = 3 THEN
                        GET #f, , c32
                        r = ExpandMaskedChannel(c32, redMask)
                        g = ExpandMaskedChannel(c32, greenMask)
                        b = ExpandMaskedChannel(c32, blueMask)
                        IF r = 255 AND g = 0 AND b = 255 THEN
                            pix[idx] = RGB(255, 0, 255)
                        ELSEIF cfg.colorDepth = 8 THEN
                            pix[idx] = Backlash256ColorIndex(r, g, b)
                        ELSE
                            pix[idx] = RGB(r, g, b)
                        END IF
                    ELSE
                        GET #f, , ub
                        GET #f, , ug
                        GET #f, , ur
                        GET #f, , a
                        IF ur = 255 AND ug = 0 AND ub = 255 THEN
                            pix[idx] = RGB(255, 0, 255)
                        ELSEIF cfg.colorDepth = 8 THEN
                            pix[idx] = Backlash256ColorIndex(ur, ug, ub)
                        ELSE
                            pix[idx] = RGB(ur, ug, ub)
                        END IF
                    END IF
            END SELECT
        NEXT
    NEXT

    CLOSE #f
    RETURN -1
END FUNCTION

FUNCTION IsTransparentBmpColor(BYVAL curCol AS UINTEGER) AS INTEGER
    DIM rr AS INTEGER
    DIM gg AS INTEGER
    DIM bb AS INTEGER

    rr = (curCol SHR 16) AND 255
    gg = (curCol SHR 8) AND 255
    bb = curCol AND 255

    IF rr = 255 AND gg = 0 AND bb = 255 THEN RETURN -1
    IF rr >= 210 AND gg <= 25 AND bb >= 190 THEN RETURN -1
    RETURN 0
END FUNCTION

FUNCTION PixelBufferHasTransparency(BYVAL pix AS UINTEGER PTR, BYVAL w AS INTEGER, BYVAL h AS INTEGER) AS INTEGER
    DIM x AS INTEGER
    DIM y AS INTEGER

    IF pix = 0 OR w <= 0 OR h <= 0 THEN RETURN 0

    FOR y = 0 TO h - 1
        FOR x = 0 TO w - 1
            IF IsTransparentBmpColor(pix[CLNG(y) * w + x]) <> 0 THEN RETURN -1
        NEXT
    NEXT

    RETURN 0
END FUNCTION

SUB FreeTransparentRunCache(BYREF runY AS INTEGER PTR, BYREF runX1 AS INTEGER PTR, BYREF runX2 AS INTEGER PTR, BYREF runCol AS UINTEGER PTR, BYREF runCount AS INTEGER)
    IF runY <> 0 THEN DEALLOCATE runY
    IF runX1 <> 0 THEN DEALLOCATE runX1
    IF runX2 <> 0 THEN DEALLOCATE runX2
    IF runCol <> 0 THEN DEALLOCATE runCol
    runY = 0
    runX1 = 0
    runX2 = 0
    runCol = 0
    runCount = 0
END SUB

SUB BuildTransparentRunCache(BYVAL pix AS UINTEGER PTR, BYVAL w AS INTEGER, BYVAL h AS INTEGER, BYREF runY AS INTEGER PTR, BYREF runX1 AS INTEGER PTR, BYREF runX2 AS INTEGER PTR, BYREF runCol AS UINTEGER PTR, BYREF runCount AS INTEGER)
    DIM x AS INTEGER
    DIM y AS INTEGER
    DIM runStart AS INTEGER
    DIM totalRuns AS INTEGER
    DIM curCol AS UINTEGER
    DIM curRunCol AS UINTEGER
    DIM outIdx AS INTEGER

    FreeTransparentRunCache runY, runX1, runX2, runCol, runCount
    IF pix = 0 OR w <= 0 OR h <= 0 THEN EXIT SUB

    totalRuns = 0
    FOR y = 0 TO h - 1
        runStart = -1
        curRunCol = 0
        FOR x = 0 TO w - 1
            curCol = pix[CLNG(y) * w + x]
            IF IsTransparentBmpColor(curCol) <> 0 THEN
                IF runStart >= 0 THEN
                    totalRuns = totalRuns + 1
                    runStart = -1
                END IF
            ELSEIF runStart < 0 THEN
                runStart = x
                curRunCol = curCol
            ELSEIF curCol <> curRunCol THEN
                totalRuns = totalRuns + 1
                runStart = x
                curRunCol = curCol
            END IF
        NEXT
        IF runStart >= 0 THEN totalRuns = totalRuns + 1
    NEXT

    IF totalRuns <= 0 THEN EXIT SUB

    runY = CAST(INTEGER PTR, ALLOCATE(totalRuns * SIZEOF(INTEGER)))
    runX1 = CAST(INTEGER PTR, ALLOCATE(totalRuns * SIZEOF(INTEGER)))
    runX2 = CAST(INTEGER PTR, ALLOCATE(totalRuns * SIZEOF(INTEGER)))
    runCol = CAST(UINTEGER PTR, ALLOCATE(totalRuns * SIZEOF(UINTEGER)))

    IF runY = 0 OR runX1 = 0 OR runX2 = 0 OR runCol = 0 THEN
        FreeTransparentRunCache runY, runX1, runX2, runCol, runCount
        EXIT SUB
    END IF

    outIdx = 0
    FOR y = 0 TO h - 1
        runStart = -1
        curRunCol = 0
        FOR x = 0 TO w - 1
            curCol = pix[CLNG(y) * w + x]
            IF IsTransparentBmpColor(curCol) <> 0 THEN
                IF runStart >= 0 THEN
                    runY[outIdx] = y
                    runX1[outIdx] = runStart
                    runX2[outIdx] = x - 1
                    runCol[outIdx] = curRunCol
                    outIdx = outIdx + 1
                    runStart = -1
                END IF
            ELSEIF runStart < 0 THEN
                runStart = x
                curRunCol = curCol
            ELSEIF curCol <> curRunCol THEN
                runY[outIdx] = y
                runX1[outIdx] = runStart
                runX2[outIdx] = x - 1
                runCol[outIdx] = curRunCol
                outIdx = outIdx + 1
                runStart = x
                curRunCol = curCol
            END IF
        NEXT
        IF runStart >= 0 THEN
            runY[outIdx] = y
            runX1[outIdx] = runStart
            runX2[outIdx] = w - 1
            runCol[outIdx] = curRunCol
            outIdx = outIdx + 1
        END IF
    NEXT

    runCount = outIdx
END SUB

' Builds a screen image buffer from loaded pixels so Backlash can draw it quickly with PUT.
FUNCTION BuildImageBufferFromPixels(BYVAL pix AS UINTEGER PTR, BYVAL w AS INTEGER, BYVAL h AS INTEGER) AS ANY PTR
    DIM img AS ANY PTR
    DIM x AS INTEGER
    DIM y AS INTEGER
    DIM srcBase AS LONG
    DIM infoW AS INTEGER
    DIM infoH AS INTEGER
    DIM infoBypp AS INTEGER
    DIM infoPitch AS INTEGER
    DIM infoPixels AS ANY PTR
    DIM rowBase AS UBYTE PTR
    DIM row8 AS UBYTE PTR
    DIM row16 AS USHORT PTR
    DIM row32 AS UINTEGER PTR
    DIM directOk AS INTEGER
    DIM curCol AS UINTEGER
    DIM rr AS INTEGER
    DIM gg AS INTEGER
    DIM bb AS INTEGER

    IF pix = 0 OR w <= 0 OR h <= 0 THEN RETURN 0

    img = ImageCreate(w, h, 0)
    IF img = 0 THEN RETURN 0

    IMAGEINFO img, infoW, infoH, infoBypp, infoPitch, infoPixels
    directOk = 0

    IF infoPixels <> 0 AND infoPitch > 0 AND infoW = w AND infoH = h THEN
        IF infoBypp = 4 THEN
            FOR y = 0 TO h - 1
                rowBase = CAST(UBYTE PTR, infoPixels) + CLNG(y) * infoPitch
                row32 = CAST(UINTEGER PTR, rowBase)
                srcBase = CLNG(y) * w
                FOR x = 0 TO w - 1
                    row32[x] = pix[srcBase + x]
                NEXT
            NEXT
            directOk = -1
        ELSEIF infoBypp = 2 THEN
            FOR y = 0 TO h - 1
                rowBase = CAST(UBYTE PTR, infoPixels) + CLNG(y) * infoPitch
                row16 = CAST(USHORT PTR, rowBase)
                srcBase = CLNG(y) * w
                FOR x = 0 TO w - 1
                    curCol = pix[srcBase + x]
                    rr = (curCol SHR 16) AND 255
                    gg = (curCol SHR 8) AND 255
                    bb = curCol AND 255
                    row16[x] = CAST(USHORT, ((rr SHR 3) SHL 11) OR ((gg SHR 2) SHL 5) OR (bb SHR 3))
                NEXT
            NEXT
            directOk = -1
        ELSEIF infoBypp = 1 AND cfg.colorDepth = 8 THEN
            FOR y = 0 TO h - 1
                row8 = CAST(UBYTE PTR, infoPixels) + CLNG(y) * infoPitch
                srcBase = CLNG(y) * w
                FOR x = 0 TO w - 1
                    row8[x] = CAST(UBYTE, pix[srcBase + x] AND &HFF)
                NEXT
            NEXT
            directOk = -1
        END IF
    END IF

    IF directOk <> 0 THEN RETURN img

    FOR y = 0 TO h - 1
        srcBase = CLNG(y) * w
        FOR x = 0 TO w - 1
            PSET img, (x, y), pix[srcBase + x]
        NEXT
    NEXT

    RETURN img
END FUNCTION

' Builds a scaled image buffer for previews or fitted bitmap display.
FUNCTION BuildScaledImageBufferFromPixels(BYVAL pix AS UINTEGER PTR, BYVAL srcW AS INTEGER, BYVAL srcH AS INTEGER, BYVAL destW AS INTEGER, BYVAL destH AS INTEGER) AS ANY PTR
    DIM img AS ANY PTR
    DIM x AS INTEGER
    DIM y AS INTEGER
    DIM sx AS INTEGER
    DIM sy AS INTEGER
    DIM srcBase AS LONG
    DIM xMap AS INTEGER PTR
    DIM infoW AS INTEGER
    DIM infoH AS INTEGER
    DIM infoBypp AS INTEGER
    DIM infoPitch AS INTEGER
    DIM infoPixels AS ANY PTR
    DIM rowBase AS UBYTE PTR
    DIM row8 AS UBYTE PTR
    DIM row16 AS USHORT PTR
    DIM row32 AS UINTEGER PTR
    DIM directOk AS INTEGER
    DIM curCol AS UINTEGER
    DIM rr AS INTEGER
    DIM gg AS INTEGER
    DIM bb AS INTEGER

    IF pix = 0 OR srcW <= 0 OR srcH <= 0 THEN RETURN 0
    IF destW <= 0 OR destH <= 0 THEN RETURN 0

    img = ImageCreate(destW, destH, 0)
    IF img = 0 THEN RETURN 0

    xMap = CAST(INTEGER PTR, ALLOCATE(destW * SIZEOF(INTEGER)))
    IF xMap <> 0 THEN
        FOR x = 0 TO destW - 1
            sx = (CLNG(x) * srcW) \ destW
            IF sx < 0 THEN sx = 0
            IF sx >= srcW THEN sx = srcW - 1
            xMap[x] = sx
        NEXT
    END IF

    IMAGEINFO img, infoW, infoH, infoBypp, infoPitch, infoPixels
    directOk = 0

    IF xMap <> 0 AND infoPixels <> 0 AND infoPitch > 0 AND infoW = destW AND infoH = destH THEN
        IF infoBypp = 4 THEN
            FOR y = 0 TO destH - 1
                sy = (CLNG(y) * srcH) \ destH
                IF sy < 0 THEN sy = 0
                IF sy >= srcH THEN sy = srcH - 1
                srcBase = CLNG(sy) * srcW
                rowBase = CAST(UBYTE PTR, infoPixels) + CLNG(y) * infoPitch
                row32 = CAST(UINTEGER PTR, rowBase)
                FOR x = 0 TO destW - 1
                    row32[x] = pix[srcBase + xMap[x]]
                NEXT
            NEXT
            directOk = -1
        ELSEIF infoBypp = 2 THEN
            FOR y = 0 TO destH - 1
                sy = (CLNG(y) * srcH) \ destH
                IF sy < 0 THEN sy = 0
                IF sy >= srcH THEN sy = srcH - 1
                srcBase = CLNG(sy) * srcW
                rowBase = CAST(UBYTE PTR, infoPixels) + CLNG(y) * infoPitch
                row16 = CAST(USHORT PTR, rowBase)
                FOR x = 0 TO destW - 1
                    curCol = pix[srcBase + xMap[x]]
                    rr = (curCol SHR 16) AND 255
                    gg = (curCol SHR 8) AND 255
                    bb = curCol AND 255
                    row16[x] = CAST(USHORT, ((rr SHR 3) SHL 11) OR ((gg SHR 2) SHL 5) OR (bb SHR 3))
                NEXT
            NEXT
            directOk = -1
        ELSEIF infoBypp = 1 AND cfg.colorDepth = 8 THEN
            FOR y = 0 TO destH - 1
                sy = (CLNG(y) * srcH) \ destH
                IF sy < 0 THEN sy = 0
                IF sy >= srcH THEN sy = srcH - 1
                srcBase = CLNG(sy) * srcW
                row8 = CAST(UBYTE PTR, infoPixels) + CLNG(y) * infoPitch
                FOR x = 0 TO destW - 1
                    row8[x] = CAST(UBYTE, pix[srcBase + xMap[x]] AND &HFF)
                NEXT
            NEXT
            directOk = -1
        END IF
    END IF

    IF xMap <> 0 THEN DEALLOCATE xMap
    IF directOk <> 0 THEN RETURN img

    FOR y = 0 TO destH - 1
        sy = (CLNG(y) * srcH) \ destH
        IF sy < 0 THEN sy = 0
        IF sy >= srcH THEN sy = srcH - 1
        srcBase = CLNG(sy) * srcW
        FOR x = 0 TO destW - 1
            sx = (CLNG(x) * srcW) \ destW
            IF sx < 0 THEN sx = 0
            IF sx >= srcW THEN sx = srcW - 1
            PSET img, (x, y), pix[srcBase + sx]
        NEXT
    NEXT

    RETURN img
END FUNCTION

FUNCTION ReadBmpDimensions(BYVAL fileName AS STRING, BYREF w AS INTEGER, BYREF h AS INTEGER) AS INTEGER
    DIM f AS INTEGER
    DIM sig AS USHORT
    DIM fileSize AS UINTEGER
    DIM reserved1 AS USHORT
    DIM reserved2 AS USHORT
    DIM dataOffset AS UINTEGER
    DIM infoSize AS UINTEGER
    DIM bmpW AS INTEGER
    DIM bmpH AS INTEGER
    DIM planes AS USHORT
    DIM bitCount AS USHORT
    DIM coreW AS USHORT
    DIM coreH AS USHORT
    DIM corePlanes AS USHORT
    DIM coreBitCount AS USHORT

    w = 0
    h = 0
    fileName = NormalizePath(fileName)

    f = FREEFILE
    IF OPEN(fileName FOR BINARY ACCESS READ AS #f) <> 0 THEN RETURN 0
    IF LOF(f) < 26 THEN
        CLOSE #f
        RETURN 0
    END IF

    GET #f, , sig
    GET #f, , fileSize
    GET #f, , reserved1
    GET #f, , reserved2
    GET #f, , dataOffset
    GET #f, , infoSize

    IF sig <> &H4D42 THEN
        CLOSE #f
        RETURN 0
    END IF

    IF infoSize = 12 THEN
        GET #f, , coreW
        GET #f, , coreH
        GET #f, , corePlanes
        GET #f, , coreBitCount
        bmpW = coreW
        bmpH = coreH
        planes = corePlanes
        bitCount = coreBitCount
    ELSEIF infoSize >= 40 THEN
        GET #f, , bmpW
        GET #f, , bmpH
        GET #f, , planes
        GET #f, , bitCount
    ELSE
        CLOSE #f
        RETURN 0
    END IF
    CLOSE #f

    IF planes <> 1 THEN RETURN 0
    IF bitCount <> 1 AND bitCount <> 4 AND bitCount <> 8 AND bitCount <> 16 AND bitCount <> 24 AND bitCount <> 32 THEN RETURN 0
    IF bmpW <= 0 OR bmpH = 0 THEN RETURN 0

    w = bmpW
    IF bmpH < 0 THEN
        h = -bmpH
    ELSE
        h = bmpH
    END IF

    RETURN -1
END FUNCTION

FUNCTION CachedPreviewBmpDimensions(BYVAL bmpPath AS STRING, BYREF w AS INTEGER, BYREF h AS INTEGER) AS INTEGER
    DIM normPath AS STRING
    DIM readW AS INTEGER
    DIM readH AS INTEGER

    w = 0
    h = 0
    normPath = NormalizePath(bmpPath)
    IF normPath = "" THEN RETURN 0

    IF previewDimCacheValid <> 0 THEN
        IF previewDimCachePath = normPath AND previewDimCacheW > 0 AND previewDimCacheH > 0 THEN
            w = previewDimCacheW
            h = previewDimCacheH
            RETURN -1
        END IF
    END IF

    readW = 0
    readH = 0
    IF ReadBmpDimensions(normPath, readW, readH) = 0 THEN RETURN 0
    IF readW < 1 OR readH < 1 THEN RETURN 0

    previewDimCachePath = normPath
    previewDimCacheW = readW
    previewDimCacheH = readH
    previewDimCacheValid = -1
    w = readW
    h = readH
    RETURN -1
END FUNCTION

' Loads a smaller sampled BMP image for previews that do not need full-size pixels.
FUNCTION LoadBmpColorSampled(BYVAL fileName AS STRING, BYREF pix AS UINTEGER PTR, BYREF w AS INTEGER, BYREF h AS INTEGER, BYVAL maxW AS INTEGER, BYVAL maxH AS INTEGER) AS INTEGER
    DIM f AS INTEGER
    DIM sig AS USHORT
    DIM fileSize AS UINTEGER
    DIM reserved1 AS USHORT
    DIM reserved2 AS USHORT
    DIM dataOffset AS UINTEGER

    DIM infoSize AS UINTEGER
    DIM bmpW AS INTEGER
    DIM bmpH AS INTEGER
    DIM planes AS USHORT
    DIM bitCount AS USHORT
    DIM compression AS UINTEGER
    DIM sizeImage AS UINTEGER
    DIM xppm AS INTEGER
    DIM yppm AS INTEGER
    DIM clrUsed AS UINTEGER
    DIM clrImportant AS UINTEGER

    DIM redMask AS UINTEGER
    DIM greenMask AS UINTEGER
    DIM blueMask AS UINTEGER

    DIM srcW AS INTEGER
    DIM srcH AS INTEGER
    DIM destW AS INTEGER
    DIM destH AS INTEGER
    DIM bytesPerPixel AS INTEGER
    DIM rowSize AS INTEGER
    DIM sampleStepX AS INTEGER
    DIM sampleStepY AS INTEGER
    DIM sampleStep AS INTEGER
    DIM x AS INTEGER
    DIM y AS INTEGER
    DIM sx AS INTEGER
    DIM sy AS INTEGER
    DIM srcY AS INTEGER
    DIM idx AS LONG
    DIM filePos AS LONGINT
    DIM rowData AS STRING
    DIM rowPtr AS UBYTE PTR
    DIM rowOfs AS INTEGER

    DIM c16 AS USHORT
    DIM c32 AS UINTEGER
    DIM r AS INTEGER
    DIM g AS INTEGER
    DIM b AS INTEGER
    DIM a AS UBYTE
    DIM ub AS UBYTE
    DIM ug AS UBYTE
    DIM ur AS UBYTE
    DIM palR(0 TO 255) AS INTEGER
    DIM palG(0 TO 255) AS INTEGER
    DIM palB(0 TO 255) AS INTEGER
    DIM palColor(0 TO 255) AS UINTEGER
    DIM palCount AS INTEGER
    DIM palIdx AS INTEGER
    DIM nibble AS INTEGER
    DIM bitIdx AS INTEGER
    DIM coreW AS USHORT
    DIM coreH AS USHORT
    DIM corePlanes AS USHORT
    DIM coreBitCount AS USHORT
    DIM isCoreBmp AS INTEGER

    fileName = NormalizePath(fileName)

    pix = 0
    w = 0
    h = 0
    redMask = 0
    greenMask = 0
    blueMask = 0

    IF maxW < 1 THEN maxW = 1
    IF maxH < 1 THEN maxH = 1

    f = FREEFILE
    IF OPEN(fileName FOR BINARY ACCESS READ AS #f) <> 0 THEN RETURN 0
    IF LOF(f) < 26 THEN
        CLOSE #f
        RETURN 0
    END IF

    GET #f, , sig
    GET #f, , fileSize
    GET #f, , reserved1
    GET #f, , reserved2
    GET #f, , dataOffset

    IF sig <> &H4D42 THEN
        CLOSE #f
        RETURN 0
    END IF

    GET #f, , infoSize
    isCoreBmp = 0
    IF infoSize = 12 THEN
        GET #f, , coreW
        GET #f, , coreH
        GET #f, , corePlanes
        GET #f, , coreBitCount
        bmpW = coreW
        bmpH = coreH
        planes = corePlanes
        bitCount = coreBitCount
        compression = 0
        sizeImage = 0
        xppm = 0
        yppm = 0
        clrUsed = 0
        clrImportant = 0
        isCoreBmp = -1
    ELSEIF infoSize >= 40 THEN
        GET #f, , bmpW
        GET #f, , bmpH
        GET #f, , planes
        GET #f, , bitCount
        GET #f, , compression
        GET #f, , sizeImage
        GET #f, , xppm
        GET #f, , yppm
        GET #f, , clrUsed
        GET #f, , clrImportant
    ELSE
        CLOSE #f
        RETURN 0
    END IF

    IF planes <> 1 THEN
        CLOSE #f
        RETURN 0
    END IF

    IF bitCount <> 1 AND bitCount <> 4 AND bitCount <> 8 AND bitCount <> 16 AND bitCount <> 24 AND bitCount <> 32 THEN
        CLOSE #f
        RETURN 0
    END IF

    IF bitCount = 16 OR bitCount = 32 THEN
        IF compression <> 0 AND compression <> 3 THEN
            CLOSE #f
            RETURN 0
        END IF
    ELSE
        IF compression <> 0 THEN
            CLOSE #f
            RETURN 0
        END IF
    END IF

    IF bmpW <= 0 OR bmpH = 0 THEN
        CLOSE #f
        RETURN 0
    END IF

    srcW = bmpW
    IF bmpH < 0 THEN
        srcH = -bmpH
    ELSE
        srcH = bmpH
    END IF

    IF (bitCount = 16 OR bitCount = 32) AND compression = 3 THEN
        GET #f, , redMask
        GET #f, , greenMask
        GET #f, , blueMask

        IF bitCount = 16 THEN
            IF Valid16Masks(redMask, greenMask, blueMask) = 0 THEN
                redMask = &HF800
                greenMask = &H07E0
                blueMask = &H001F
            END IF
        ELSEIF redMask = 0 OR greenMask = 0 OR blueMask = 0 THEN
            redMask = &H00FF0000
            greenMask = &H0000FF00
            blueMask = &H000000FF
        END IF
    ELSEIF bitCount = 16 THEN
        redMask = &HF800
        greenMask = &H07E0
        blueMask = &H001F
    ELSEIF bitCount = 32 THEN
        redMask = &H00FF0000
        greenMask = &H0000FF00
        blueMask = &H000000FF
    END IF

    IF bitCount = 1 OR bitCount = 4 OR bitCount = 8 THEN
        IF bitCount = 1 THEN
            IF clrUsed > 0 AND clrUsed <= 2 THEN
                palCount = CINT(clrUsed)
            ELSE
                palCount = 2
            END IF
        ELSEIF bitCount = 4 THEN
            IF clrUsed > 0 AND clrUsed <= 16 THEN
                palCount = CINT(clrUsed)
            ELSE
                palCount = 16
            END IF
        ELSE
            IF clrUsed > 0 AND clrUsed <= 256 THEN
                palCount = CINT(clrUsed)
            ELSE
                palCount = 256
            END IF
        END IF
        SEEK #f, CLNG(14) + CLNG(infoSize) + 1
        FOR palIdx = 0 TO palCount - 1
            GET #f, , ub
            GET #f, , ug
            GET #f, , ur
            IF isCoreBmp = 0 THEN GET #f, , a
            palB(palIdx) = ub
            palG(palIdx) = ug
            palR(palIdx) = ur
        NEXT

        FOR palIdx = 0 TO palCount - 1
            r = palR(palIdx)
            g = palG(palIdx)
            b = palB(palIdx)
            IF r = 255 AND g = 0 AND b = 255 THEN
                palColor(palIdx) = RGB(255, 0, 255)
            ELSEIF cfg.colorDepth = 4 AND bitCount = 4 THEN
                palColor(palIdx) = Backlash16ColorIndex(r, g, b)
            ELSEIF cfg.colorDepth = 8 THEN
                palColor(palIdx) = Backlash256ColorIndex(r, g, b)
            ELSE
                palColor(palIdx) = RGB(r, g, b)
            END IF
        NEXT
    END IF

    sampleStepX = (srcW + maxW - 1) \ maxW
    sampleStepY = (srcH + maxH - 1) \ maxH
    sampleStep = sampleStepX
    IF sampleStepY > sampleStep THEN sampleStep = sampleStepY
    IF sampleStep < 1 THEN sampleStep = 1

    destW = (srcW + sampleStep - 1) \ sampleStep
    destH = (srcH + sampleStep - 1) \ sampleStep
    IF destW < 1 THEN destW = 1
    IF destH < 1 THEN destH = 1

    pix = CALLocate(destW * destH, SIZEOF(UINTEGER))
    IF pix = 0 THEN
        CLOSE #f
        RETURN 0
    END IF

    w = destW
    h = destH
    IF bitCount = 1 THEN
        bytesPerPixel = 0
        rowSize = ((srcW + 31) \ 32) * 4
    ELSEIF bitCount = 4 THEN
        bytesPerPixel = 0
        rowSize = ((srcW * 4 + 31) \ 32) * 4
    ELSE
        bytesPerPixel = bitCount \ 8
        rowSize = ((srcW * bytesPerPixel + 3) \ 4) * 4
    END IF
    rowData = SPACE$(rowSize)

    FOR y = 0 TO destH - 1
        sy = y * sampleStep
        IF sy >= srcH THEN sy = srcH - 1

        IF bmpH > 0 THEN
            srcY = srcH - 1 - sy
        ELSE
            srcY = sy
        END IF

        filePos = CLNG(dataOffset) + CLNG(srcY) * rowSize + 1
        SEEK #f, filePos
        GET #f, , rowData
        rowPtr = CAST(UBYTE PTR, STRPTR(rowData))

        FOR x = 0 TO destW - 1
            sx = x * sampleStep
            IF sx >= srcW THEN sx = srcW - 1

            idx = CLNG(y) * destW + x
            IF bitCount = 1 THEN
                rowOfs = sx \ 8
            ELSEIF bitCount = 4 THEN
                rowOfs = sx \ 2
            ELSE
                rowOfs = sx * bytesPerPixel
            END IF

            SELECT CASE bitCount
                CASE 1
                    ub = rowPtr[rowOfs]
                    bitIdx = 7 - (sx AND 7)
                    palIdx = (ub SHR bitIdx) AND 1
                    pix[idx] = palColor(palIdx)

                CASE 4
                    ub = rowPtr[rowOfs]
                    IF (sx AND 1) = 0 THEN
                        nibble = ub SHR 4
                    ELSE
                        nibble = ub AND 15
                    END IF
                    IF nibble < 0 THEN nibble = 0
                    IF nibble > 255 THEN nibble = 0
                    pix[idx] = palColor(nibble)

                CASE 8
                    ub = rowPtr[rowOfs]
                    pix[idx] = palColor(ub)

                CASE 16
                    c16 = CAST(USHORT, rowPtr[rowOfs]) OR CAST(USHORT, rowPtr[rowOfs + 1]) SHL 8
                    c32 = c16
                    r = ExpandMaskedChannel(c32, redMask)
                    g = ExpandMaskedChannel(c32, greenMask)
                    b = ExpandMaskedChannel(c32, blueMask)
                    IF r = 255 AND g = 0 AND b = 255 THEN
                        pix[idx] = RGB(255, 0, 255)
                    ELSEIF cfg.colorDepth = 8 THEN
                        pix[idx] = Backlash256ColorIndex(r, g, b)
                    ELSE
                        pix[idx] = RGB(r, g, b)
                    END IF

                CASE 24
                    ub = rowPtr[rowOfs]
                    ug = rowPtr[rowOfs + 1]
                    ur = rowPtr[rowOfs + 2]
                    IF ur = 255 AND ug = 0 AND ub = 255 THEN
                        pix[idx] = RGB(255, 0, 255)
                    ELSEIF cfg.colorDepth = 8 THEN
                        pix[idx] = Backlash256ColorIndex(ur, ug, ub)
                    ELSE
                        pix[idx] = RGB(ur, ug, ub)
                    END IF

                CASE 32
                    IF compression = 3 THEN
                        c32 = CUINT(rowPtr[rowOfs]) OR _
                              (CUINT(rowPtr[rowOfs + 1]) SHL 8) OR _
                              (CUINT(rowPtr[rowOfs + 2]) SHL 16) OR _
                              (CUINT(rowPtr[rowOfs + 3]) SHL 24)
                        r = ExpandMaskedChannel(c32, redMask)
                        g = ExpandMaskedChannel(c32, greenMask)
                        b = ExpandMaskedChannel(c32, blueMask)
                        IF r = 255 AND g = 0 AND b = 255 THEN
                            pix[idx] = RGB(255, 0, 255)
                        ELSEIF cfg.colorDepth = 8 THEN
                            pix[idx] = Backlash256ColorIndex(r, g, b)
                        ELSE
                            pix[idx] = RGB(r, g, b)
                        END IF
                    ELSE
                        ub = rowPtr[rowOfs]
                        ug = rowPtr[rowOfs + 1]
                        ur = rowPtr[rowOfs + 2]
                        a = rowPtr[rowOfs + 3]
                        IF ur = 255 AND ug = 0 AND ub = 255 THEN
                            pix[idx] = RGB(255, 0, 255)
                        ELSEIF cfg.colorDepth = 8 THEN
                            pix[idx] = Backlash256ColorIndex(ur, ug, ub)
                        ELSE
                            pix[idx] = RGB(ur, ug, ub)
                        END IF
                    END IF
            END SELECT
        NEXT
    NEXT

    CLOSE #f
    RETURN -1
END FUNCTION


