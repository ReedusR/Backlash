                                    END IF
                                    ctxMenuOpen = -1
                                    ctxMenuX = smx
                                    ctxMenuY = smy
                                    IF ctxMenuX + ctxMenuW > SCR_W - 1 THEN ctxMenuX = SCR_W - 1 - ctxMenuW
                                    IF ctxMenuY + ctxMenuH - 1 > WORK_BOTTOM THEN ctxMenuY = WORK_BOTTOM - ctxMenuH + 1
                                    IF ctxMenuY < WORK_Y THEN ctxMenuY = WORK_Y
                                    IF ctxMenuX < 0 THEN ctxMenuX = 0
                                    IF ctxMenuY < WORK_Y THEN ctxMenuY = WORK_Y
                                    ctxMenuWin = activeLayoutWindow
                                    ctxMenuElem = rightHitIndex
                                END IF
                            END IF

                            IF ctxMenuOpen = 0 THEN
