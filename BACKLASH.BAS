SUB ConfigureFileBrowserWindow(BYVAL expWin AS INTEGER, BYVAL dirName AS STRING)
    DIM dirIdx AS INTEGER
    DIM fileIdx AS INTEGER
    DIM pathIdx AS INTEGER
    DIM dirControlName AS STRING
    DIM fileControlName AS STRING
    DIM pathControlName AS STRING
    DIM statsControlName AS STRING
    DIM refreshOldFocus AS INTEGER
    DIM refreshRestoreFocus AS INTEGER
    DIM refreshMatchIdx AS INTEGER
    DIM refreshItemIdx AS INTEGER
    DIM refreshDirSame AS INTEGER
    DIM refreshFileSame AS INTEGER
    DIM refreshDirTop AS INTEGER
    DIM refreshFileTop AS INTEGER
    DIM refreshDirValue AS STRING
    DIM refreshFileValue AS STRING
    DIM refreshDirText AS STRING
    DIM refreshFileText AS STRING
    DIM refreshOldSourceDir AS STRING
    DIM refreshStatsText AS STRING

    IF expWin < LBOUND(layoutWindows) OR expWin > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(expWin).used = 0 THEN EXIT SUB

    SyncGlobalsFromLayoutWindow expWin
    refreshOldFocus = uiFocusIndex
    refreshRestoreFocus = 0

    dirName = AbsoluteDirPath(dirName)
    IF dirName = "" THEN dirName = AbsoluteDirPath(".")

    dirControlName = AppControlNameValue(expWin, "FILE_BROWSER_DIR_CONTROL", "")
    fileControlName = AppControlNameValue(expWin, "FILE_BROWSER_FILE_CONTROL", "")
    pathControlName = AppControlNameValue(expWin, "FILE_BROWSER_PATH_CONTROL", "")
    statsControlName = AppControlNameValue(expWin, "FILE_BROWSER_STATS_CONTROL", "")

    IF dirControlName <> "" THEN
        dirIdx = GetControlIndexByName(dirControlName)
        IF dirIdx >= 1 AND dirIdx <= uiCount THEN
            IF uiElems(dirIdx).kindId = UI_KIND_LISTBOX THEN
                refreshDirSame = 0
                refreshOldSourceDir = AbsoluteDirPath(uiElems(dirIdx).sourceDir)
                IF refreshOldSourceDir <> "" THEN
                    IF UCASE$(refreshOldSourceDir) = UCASE$(dirName) THEN refreshDirSame = -1
                END IF
                IF refreshDirSame <> 0 THEN
                    refreshDirTop = comboScrollTop(expWin, dirIdx)
                    refreshDirValue = ControlValueFromListControl(dirIdx)
                    refreshDirText = RTRIM$(uiElems(dirIdx).text)
                END IF

                uiElems(dirIdx).sourceDir = dirName
                uiElems(dirIdx).sourceMask = "*.*"
                uiElems(dirIdx).sourceItems = ""
                uiElems(dirIdx).text = ""
                comboScrollTop(expWin, dirIdx) = 0
                BuildComboItems dirIdx
                uiElems(dirIdx).sourceItems = BuildSourceItemsFromTemp()

                IF refreshDirSame <> 0 THEN
                    comboScrollTop(expWin, dirIdx) = refreshDirTop
                    refreshMatchIdx = 0
                    FOR refreshItemIdx = 1 TO tempComboItemCount
                        IF refreshDirValue <> "" THEN
                            IF UCASE$(RTRIM$(tempComboValues(refreshItemIdx))) = UCASE$(refreshDirValue) THEN
                                refreshMatchIdx = refreshItemIdx
                                EXIT FOR
                            END IF
                        END IF
                        IF refreshMatchIdx = 0 AND refreshDirText <> "" THEN
                            IF UCASE$(RTRIM$(tempComboItems(refreshItemIdx))) = UCASE$(refreshDirText) THEN
                                refreshMatchIdx = refreshItemIdx
                                EXIT FOR
                            END IF
                        END IF
                    NEXT
                    IF refreshMatchIdx > 0 THEN
                        uiElems(dirIdx).text = RTRIM$(tempComboItems(refreshMatchIdx))
                        layoutListAnchorIdx(expWin, dirIdx) = refreshMatchIdx
                        IF refreshOldFocus = dirIdx THEN refreshRestoreFocus = dirIdx
                    END IF
                END IF

                layoutUiElems(expWin, dirIdx) = uiElems(dirIdx)
                MarkLayoutDirtyElement expWin, dirIdx
            END IF
        END IF
    END IF

    IF fileControlName <> "" THEN
        fileIdx = GetControlIndexByName(fileControlName)
        IF fileIdx >= 1 AND fileIdx <= uiCount THEN
            IF uiElems(fileIdx).kindId = UI_KIND_LISTBOX THEN
                refreshFileSame = 0
                refreshOldSourceDir = AbsoluteDirPath(uiElems(fileIdx).sourceDir)
                IF refreshOldSourceDir <> "" THEN
                    IF UCASE$(refreshOldSourceDir) = UCASE$(dirName) THEN refreshFileSame = -1
                END IF
                IF refreshFileSame <> 0 THEN
                    refreshFileTop = comboScrollTop(expWin, fileIdx)
                    refreshFileValue = ControlValueFromListControl(fileIdx)
                    refreshFileText = RTRIM$(uiElems(fileIdx).text)
                END IF

                uiElems(fileIdx).sourceDir = dirName
                IF TRIM$(uiElems(fileIdx).sourceMask) = "" THEN uiElems(fileIdx).sourceMask = "*.*"
                uiElems(fileIdx).sourceItems = ""
                uiElems(fileIdx).text = ""
                comboScrollTop(expWin, fileIdx) = 0
                ' Reuse the Navigator file scan for the visible list and status line.
                ' The stats cache lets UpdateDirectoryStatsControl avoid a second scan.
                BuildFileBrowserFileItemsFast fileIdx, dirName, refreshStatsText
                uiElems(fileIdx).sourceItems = BuildSourceItemsFromTemp()

                IF refreshFileSame <> 0 THEN
                    comboScrollTop(expWin, fileIdx) = refreshFileTop
                    refreshMatchIdx = 0
                    FOR refreshItemIdx = 1 TO tempComboItemCount
                        IF refreshFileValue <> "" THEN
                            IF UCASE$(RTRIM$(tempComboValues(refreshItemIdx))) = UCASE$(refreshFileValue) THEN
                                refreshMatchIdx = refreshItemIdx
                                EXIT FOR
                            END IF
                        END IF
                        IF refreshMatchIdx = 0 AND refreshFileText <> "" THEN
                            IF UCASE$(RTRIM$(tempComboItems(refreshItemIdx))) = UCASE$(refreshFileText) THEN
                                refreshMatchIdx = refreshItemIdx
                                EXIT FOR
                            END IF
                        END IF
                    NEXT
                    IF refreshMatchIdx > 0 THEN
                        uiElems(fileIdx).text = RTRIM$(tempComboItems(refreshMatchIdx))
                        layoutListAnchorIdx(expWin, fileIdx) = refreshMatchIdx
                        IF refreshOldFocus = fileIdx THEN refreshRestoreFocus = fileIdx
                    END IF
                END IF

                layoutUiElems(expWin, fileIdx) = uiElems(fileIdx)
                MarkLayoutDirtyElement expWin, fileIdx
            END IF
        END IF
    END IF

    IF pathControlName <> "" THEN
        pathIdx = GetControlIndexByName(pathControlName)
        IF pathIdx >= 1 AND pathIdx <= uiCount THEN
            IF uiElems(pathIdx).kindId = UI_KIND_TEXTBOX THEN
                SetTextboxTextByName pathControlName, dirName
                layoutUiElems(expWin, pathIdx) = uiElems(pathIdx)
                layoutUiEdit(expWin, pathIdx) = uiEdit(pathIdx)
                MarkLayoutDirtyElement expWin, pathIdx
            END IF
        END IF
    END IF

    UpdateDirectoryStatsControl expWin, dirName, statsControlName

    comboOpenIndex(expWin) = 0
    uiFocusIndex = refreshRestoreFocus
    uiPressedIndex = 0
    layoutWindows(expWin).focusIndex = refreshRestoreFocus
    layoutWindows(expWin).pressedIndex = 0
    MarkLayoutWindowVisualDirty expWin
    SyncLayoutWindowFromGlobals expWin
END SUB


SUB ShowFileProperties(BYVAL fileName AS STRING, BYVAL dialogAppPath AS STRING, BYVAL itemIsDir AS INTEGER)
    DIM propApp AS STRING

    fileName = NormalizePath(TRIM$(fileName))
    propApp = NormalizePath(TRIM$(dialogAppPath))
    IF fileName = "" THEN EXIT SUB
    IF propApp = "" THEN EXIT SUB
    IF DIR(LayoutFilePath(propApp)) = "" THEN EXIT SUB

    propFilePath = fileName
    propFileIsDir = itemIsDir

    ' The right-click route already saved the source window before this opens.
    ' Use the shared saved-state dialog path instead of redoing that deep copy.
    IF itemIsDir <> 0 THEN
        OpenDialogLayoutAndApplyProfile propApp, fileName, "DIR", -1
    ELSE
        OpenDialogLayoutAndApplyProfile propApp, fileName, "FILE", -1
    END IF
END SUB






FUNCTION DialogInitValue(BYVAL sourcePath AS STRING, BYVAL valueKind AS STRING) AS STRING
    DIM extName AS STRING
    DIM assocText AS STRING
    DIM attrBits AS INTEGER
    DIM sourceCount AS INTEGER

    sourcePath = NormalizePath(TRIM$(sourcePath))

    SELECT CASE UCASE$(TRIM$(valueKind))
    CASE "SOURCE_PATH"
        RETURN sourcePath
    CASE "SOURCE_NAME"
        RETURN FileNameOnly(sourcePath)
    CASE "SOURCE_NAME_OR_COUNT"
        sourceCount = DelimitedListCount(sourcePath)
        IF sourceCount > 1 THEN
            RETURN LTRIM$(STR$(sourceCount)) + " files"
        END IF
        RETURN FileNameOnly(sourcePath)
    CASE "SOURCE_PARENT"
        RETURN ParentPath(sourcePath)
    CASE "SOURCE_EXTENSION_OR_NONE"
        extName = FileExtensionOf(sourcePath)
        IF extName = "" THEN RETURN "(none)"
        RETURN extName
    CASE "SOURCE_SIZE"
        IF DirectoryExistsForSize(sourcePath) <> 0 THEN RETURN DirectorySizeDescription(sourcePath)
        RETURN FileSizeDescription(sourcePath)
    CASE "SOURCE_OPEN_ACTION_OR_NO_ASSOCIATION"
        assocText = LookupFileAssociation(sourcePath)
        IF assocText = "" THEN RETURN "NO ASSOCIATION"
        RETURN assocText
    CASE "SOURCE_EDIT_ACTION_OR_UNAVAILABLE"
        assocText = LookupFileEditAssociation(sourcePath)
        IF assocText = "" THEN RETURN "Unavailable"
        RETURN assocText
    CASE "SOURCE_ATTR_READONLY"
        attrBits = FileAttributeBits(sourcePath)
        IF (attrBits AND &H01) <> 0 THEN RETURN "1"
        RETURN "0"
    CASE "SOURCE_ATTR_ARCHIVE"
        attrBits = FileAttributeBits(sourcePath)
        IF (attrBits AND &H20) <> 0 THEN RETURN "1"
        RETURN "0"
    CASE "SOURCE_ATTR_SYSTEM"
        attrBits = FileAttributeBits(sourcePath)
        IF (attrBits AND &H04) <> 0 THEN RETURN "1"
        RETURN "0"
    CASE "SOURCE_ATTR_HIDDEN"
        attrBits = FileAttributeBits(sourcePath)
        IF (attrBits AND &H02) <> 0 THEN RETURN "1"
        RETURN "0"
    END SELECT

    RETURN valueKind
END FUNCTION
SUB ApplyDialogInitProfile(BYVAL targetWin AS INTEGER, BYVAL sourcePath AS STRING, BYVAL profileMode AS STRING)
    DIM dialogAppPath AS STRING
    DIM modeSuffix AS STRING
    DIM specText AS STRING
    DIM controlName AS STRING
    DIM valueKind AS STRING
    DIM focusControlName AS STRING
    DIM selectAllControlName AS STRING
    DIM clearFocusText AS STRING
    DIM titleText AS STRING
    DIM selectedText AS STRING
    DIM sepPos AS INTEGER
    DIM controlIdx AS INTEGER
    DIM selectAllIdx AS INTEGER
    DIM i AS INTEGER

    DIM dialogCacheFile AS STRING
    DIM dialogProfileSection AS STRING
    DIM dialogScanSection AS STRING
    DIM dialogKey AS STRING
    DIM dialogValue AS STRING
    DIM dialogIndex AS INTEGER
    DIM dialogCacheIdx AS INTEGER
    DIM dialogScanPass AS INTEGER
    DIM useDialogSnapshot AS INTEGER

    DIM showPrefix AS STRING
    DIM hidePrefix AS STRING
    DIM initModePrefix AS STRING
    DIM initBasePrefix AS STRING
    DIM textModePrefix AS STRING
    DIM textBasePrefix AS STRING
    DIM stateModePrefix AS STRING
    DIM stateBasePrefix AS STRING

    DIM showSpec(1 TO 16) AS STRING
    DIM hideSpec(1 TO 16) AS STRING
    DIM initModeSpec(1 TO 16) AS STRING
    DIM initBaseSpec(1 TO 16) AS STRING
    DIM textModeSpec(1 TO 16) AS STRING
    DIM textBaseSpec(1 TO 16) AS STRING
    DIM stateModeSpec(1 TO 16) AS STRING
    DIM stateBaseSpec(1 TO 16) AS STRING

    DIM focusModeText AS STRING
    DIM focusBaseText AS STRING
    DIM selectAllModeText AS STRING
    DIM selectAllBaseText AS STRING
    DIM clearFocusModeText AS STRING
    DIM clearFocusBaseText AS STRING

    IF targetWin < LBOUND(layoutWindows) OR targetWin > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(targetWin).used = 0 THEN EXIT SUB

    ActivateLayoutWindow targetWin
    dialogAppPath = RTRIM$(layoutWindows(targetWin).appPath)

    modeSuffix = UCASE$(TRIM$(profileMode))
    IF modeSuffix <> "" THEN modeSuffix = "_" + modeSuffix

    ' Dialog profiles ask for the same family of DIALOG_* keys over and over.
    ' Read that small profile snapshot once instead of walking AppCfgValue for every slot.
    dialogCacheFile = UCASE$(NormalizePath(LayoutFilePath(dialogAppPath)))
    dialogProfileSection = LayoutProfile(dialogAppPath)
    LoadCfgReadCacheFile dialogAppPath

    useDialogSnapshot = 0
    IF cfgWriteBatchCount = 0 AND dialogCacheFile <> "" THEN
        IF CfgReadFileAlreadyLoaded(dialogAppPath) <> 0 THEN useDialogSnapshot = -1
    END IF

    IF useDialogSnapshot <> 0 THEN
        showPrefix = "DIALOG_SHOW_CONTROL" + modeSuffix + "_"
        hidePrefix = "DIALOG_HIDE_CONTROL" + modeSuffix + "_"
        initModePrefix = "DIALOG_INIT" + modeSuffix + "_"
        initBasePrefix = "DIALOG_INIT_"
        textModePrefix = "DIALOG_TEXT" + modeSuffix + "_"
        textBasePrefix = "DIALOG_TEXT_"
        stateModePrefix = "DIALOG_STATE" + modeSuffix + "_"
        stateBasePrefix = "DIALOG_STATE_"

        ' Pass one keeps ReadCfgValue-style file fallbacks. Pass two overlays
        ' the selected SYS profile so the result stays identical to AppCfgValue.
        FOR dialogScanPass = 1 TO 2
            IF dialogScanPass = 1 THEN
                dialogScanSection = ""
            ELSE
                IF dialogProfileSection = "" THEN EXIT FOR
                dialogScanSection = dialogProfileSection
            END IF

            FOR dialogCacheIdx = 1 TO cfgReadCacheCount
                IF RTRIM$(cfgReadCacheFile(dialogCacheIdx)) = dialogCacheFile AND _
                   RTRIM$(cfgReadCacheSection(dialogCacheIdx)) = dialogScanSection THEN
                    dialogKey = RTRIM$(cfgReadCacheKey(dialogCacheIdx))
                    dialogValue = TRIM$(cfgReadCacheValue(dialogCacheIdx))

                    IF dialogKey = "DIALOG_TITLE" + modeSuffix THEN titleText = dialogValue

                    IF LEFT$(dialogKey, LEN(showPrefix)) = showPrefix THEN
                        dialogIndex = VALINT(MID$(dialogKey, LEN(showPrefix) + 1))
                        IF dialogIndex >= 1 AND dialogIndex <= 16 THEN showSpec(dialogIndex) = dialogValue
                    END IF

                    IF LEFT$(dialogKey, LEN(hidePrefix)) = hidePrefix THEN
                        dialogIndex = VALINT(MID$(dialogKey, LEN(hidePrefix) + 1))
                        IF dialogIndex >= 1 AND dialogIndex <= 16 THEN hideSpec(dialogIndex) = dialogValue
                    END IF

                    IF LEFT$(dialogKey, LEN(initBasePrefix)) = initBasePrefix THEN
                        dialogIndex = VALINT(MID$(dialogKey, LEN(initBasePrefix) + 1))
                        IF dialogIndex >= 1 AND dialogIndex <= 16 THEN initBaseSpec(dialogIndex) = dialogValue
                    END IF

                    IF LEFT$(dialogKey, LEN(initModePrefix)) = initModePrefix THEN
                        dialogIndex = VALINT(MID$(dialogKey, LEN(initModePrefix) + 1))
                        IF dialogIndex >= 1 AND dialogIndex <= 16 THEN initModeSpec(dialogIndex) = dialogValue
                    END IF

                    IF LEFT$(dialogKey, LEN(textBasePrefix)) = textBasePrefix THEN
                        dialogIndex = VALINT(MID$(dialogKey, LEN(textBasePrefix) + 1))
                        IF dialogIndex >= 1 AND dialogIndex <= 16 THEN textBaseSpec(dialogIndex) = dialogValue
                    END IF

                    IF LEFT$(dialogKey, LEN(textModePrefix)) = textModePrefix THEN
                        dialogIndex = VALINT(MID$(dialogKey, LEN(textModePrefix) + 1))
                        IF dialogIndex >= 1 AND dialogIndex <= 16 THEN textModeSpec(dialogIndex) = dialogValue
                    END IF

                    IF LEFT$(dialogKey, LEN(stateBasePrefix)) = stateBasePrefix THEN
                        dialogIndex = VALINT(MID$(dialogKey, LEN(stateBasePrefix) + 1))
                        IF dialogIndex >= 1 AND dialogIndex <= 16 THEN stateBaseSpec(dialogIndex) = dialogValue
                    END IF

                    IF LEFT$(dialogKey, LEN(stateModePrefix)) = stateModePrefix THEN
                        dialogIndex = VALINT(MID$(dialogKey, LEN(stateModePrefix) + 1))
                        IF dialogIndex >= 1 AND dialogIndex <= 16 THEN stateModeSpec(dialogIndex) = dialogValue
                    END IF

                    IF dialogKey = "DIALOG_FOCUS_CONTROL" THEN focusBaseText = dialogValue
                    IF dialogKey = "DIALOG_FOCUS_CONTROL" + modeSuffix THEN focusModeText = dialogValue

                    IF dialogKey = "DIALOG_SELECT_ALL_CONTROL" THEN selectAllBaseText = dialogValue
                    IF dialogKey = "DIALOG_SELECT_ALL_CONTROL" + modeSuffix THEN selectAllModeText = dialogValue

                    IF dialogKey = "DIALOG_CLEAR_FOCUS" THEN clearFocusBaseText = dialogValue
                    IF dialogKey = "DIALOG_CLEAR_FOCUS" + modeSuffix THEN clearFocusModeText = dialogValue
                END IF
            NEXT
        NEXT
    ELSE
        titleText = TRIM$(AppCfgValue(dialogAppPath, "DIALOG_TITLE" + modeSuffix, ""))
    END IF

    IF titleText <> "" THEN uiTitle = titleText

    FOR i = 1 TO 16
        IF useDialogSnapshot <> 0 THEN
            specText = showSpec(i)
        ELSE
            specText = TRIM$(AppCfgValue(dialogAppPath, "DIALOG_SHOW_CONTROL" + modeSuffix + "_" + LTRIM$(STR$(i)), ""))
        END IF

        IF specText <> "" THEN
            controlIdx = GetControlIndexByName(specText)
            IF controlIdx >= 1 AND controlIdx <= uiCount THEN
                uiElems(controlIdx).page = ""
                NormalizeUiElementKeys uiElems(controlIdx)
            END IF
        END IF
    NEXT

    FOR i = 1 TO 16
        IF useDialogSnapshot <> 0 THEN
            specText = hideSpec(i)
        ELSE
            specText = TRIM$(AppCfgValue(dialogAppPath, "DIALOG_HIDE_CONTROL" + modeSuffix + "_" + LTRIM$(STR$(i)), ""))
        END IF

        IF specText <> "" THEN
            controlIdx = GetControlIndexByName(specText)
            IF controlIdx >= 1 AND controlIdx <= uiCount THEN
                uiElems(controlIdx).page = "__HIDE__"
                NormalizeUiElementKeys uiElems(controlIdx)
            END IF
        END IF
    NEXT

    FOR i = 1 TO 16
        IF useDialogSnapshot <> 0 THEN
            specText = initModeSpec(i)
            IF specText = "" THEN specText = initBaseSpec(i)
        ELSE
            specText = TRIM$(AppCfgValue(dialogAppPath, "DIALOG_INIT" + modeSuffix + "_" + LTRIM$(STR$(i)), ""))
            IF specText = "" THEN specText = TRIM$(AppCfgValue(dialogAppPath, "DIALOG_INIT_" + LTRIM$(STR$(i)), ""))
        END IF

        IF specText <> "" THEN
            sepPos = INSTR(specText, "|")
            IF sepPos > 0 THEN
                controlName = TRIM$(LEFT$(specText, sepPos - 1))
                valueKind = TRIM$(MID$(specText, sepPos + 1))
                IF controlName <> "" THEN SetTextboxTextByName controlName, DialogInitValue(sourcePath, valueKind)
            END IF
        END IF
    NEXT

    FOR i = 1 TO 16
        IF useDialogSnapshot <> 0 THEN
            specText = textModeSpec(i)
            IF specText = "" THEN specText = textBaseSpec(i)
        ELSE
            specText = TRIM$(AppCfgValue(dialogAppPath, "DIALOG_TEXT" + modeSuffix + "_" + LTRIM$(STR$(i)), ""))
            IF specText = "" THEN specText = TRIM$(AppCfgValue(dialogAppPath, "DIALOG_TEXT_" + LTRIM$(STR$(i)), ""))
        END IF

        IF specText <> "" THEN
            sepPos = INSTR(specText, "|")
            IF sepPos > 0 THEN
                controlName = TRIM$(LEFT$(specText, sepPos - 1))
                valueKind = TRIM$(MID$(specText, sepPos + 1))
                IF controlName <> "" THEN SetControlTextByNameAny controlName, DialogInitValue(sourcePath, valueKind)
            END IF
        END IF
    NEXT

    FOR i = 1 TO 16
        IF useDialogSnapshot <> 0 THEN
            specText = stateModeSpec(i)
            IF specText = "" THEN specText = stateBaseSpec(i)
        ELSE
            specText = TRIM$(AppCfgValue(dialogAppPath, "DIALOG_STATE" + modeSuffix + "_" + LTRIM$(STR$(i)), ""))
            IF specText = "" THEN specText = TRIM$(AppCfgValue(dialogAppPath, "DIALOG_STATE_" + LTRIM$(STR$(i)), ""))
        END IF

        IF specText <> "" THEN
            sepPos = INSTR(specText, "|")
            IF sepPos > 0 THEN
                controlName = TRIM$(LEFT$(specText, sepPos - 1))
                valueKind = TRIM$(MID$(specText, sepPos + 1))
                IF controlName <> "" THEN SetControlStateByName controlName, VAL(DialogInitValue(sourcePath, valueKind))
            END IF
        END IF
    NEXT

    IF useDialogSnapshot <> 0 THEN
        focusControlName = focusModeText
        IF focusControlName = "" THEN focusControlName = focusBaseText

        selectAllControlName = selectAllModeText
        IF selectAllControlName = "" THEN selectAllControlName = selectAllBaseText

        clearFocusText = UCASE$(clearFocusModeText)
        IF clearFocusText = "" THEN clearFocusText = UCASE$(clearFocusBaseText)
    ELSE
        focusControlName = TRIM$(AppCfgValue(dialogAppPath, "DIALOG_FOCUS_CONTROL" + modeSuffix, ""))
        IF focusControlName = "" THEN focusControlName = TRIM$(AppCfgValue(dialogAppPath, "DIALOG_FOCUS_CONTROL", ""))

        selectAllControlName = TRIM$(AppCfgValue(dialogAppPath, "DIALOG_SELECT_ALL_CONTROL" + modeSuffix, ""))
        IF selectAllControlName = "" THEN selectAllControlName = TRIM$(AppCfgValue(dialogAppPath, "DIALOG_SELECT_ALL_CONTROL", ""))

        clearFocusText = UCASE$(TRIM$(AppCfgValue(dialogAppPath, "DIALOG_CLEAR_FOCUS" + modeSuffix, "")))
        IF clearFocusText = "" THEN clearFocusText = UCASE$(TRIM$(AppCfgValue(dialogAppPath, "DIALOG_CLEAR_FOCUS", "")))
    END IF

    uiPressedIndex = 0
    layoutWindows(targetWin).pressedIndex = 0
    IF clearFocusText = "1" OR clearFocusText = "YES" OR clearFocusText = "TRUE" THEN
        uiFocusIndex = 0
        uiCaretPos = 0
        layoutWindows(targetWin).focusIndex = 0
        layoutWindows(targetWin).caretPos = 0
    END IF
    IF focusControlName <> "" THEN layoutWindows(targetWin).focusIndex = GetControlIndexByName(focusControlName)

    selectAllIdx = GetControlIndexByName(selectAllControlName)
    IF selectAllIdx >= 1 AND selectAllIdx <= uiCount THEN
        IF uiElems(selectAllIdx).kindId = UI_KIND_TEXTBOX AND uiElems(selectAllIdx).noEdit = 0 THEN
            selectedText = uiElems(selectAllIdx).text
            Ed_LoadTxt uiEdit(selectAllIdx), selectedText, LEN(selectedText)
            uiEdit(selectAllIdx).selA = 0
            uiEdit(selectAllIdx).selB = uiEdit(selectAllIdx).txtLen
            uiEdit(selectAllIdx).curPos = uiEdit(selectAllIdx).txtLen
            uiFocusIndex = selectAllIdx
            uiCaretPos = uiEdit(selectAllIdx).curPos
            uiSelAnchor(selectAllIdx) = 0
            uiPrefCol(selectAllIdx) = -1
            comboScrollTop(targetWin, selectAllIdx) = 0
            InvalidateTextboxMetrics selectAllIdx
            layoutWindows(targetWin).focusIndex = selectAllIdx
            layoutWindows(targetWin).caretPos = uiCaretPos
            layoutUiElems(targetWin, selectAllIdx) = uiElems(selectAllIdx)
            layoutUiEdit(targetWin, selectAllIdx) = uiEdit(selectAllIdx)
            layoutUiSelAnchor(targetWin, selectAllIdx) = uiSelAnchor(selectAllIdx)
            layoutUiPrefCol(targetWin, selectAllIdx) = uiPrefCol(selectAllIdx)
        END IF
    END IF

    SyncLayoutWindowFromGlobals targetWin
END SUB

SUB OpenDialogLayoutAndApplyProfile(BYVAL dialogAppPath AS STRING, BYVAL sourcePath AS STRING, BYVAL profileMode AS STRING, BYVAL activeStateAlreadySaved AS INTEGER)
    DIM targetWin AS INTEGER

    ' The caller has already validated and normalized the dialog path.
    ' Keep the open/init work in one place so every SYS dialog follows the same fast path.
    IF activeStateAlreadySaved <> 0 THEN
        OpenLayoutAppWindowFromSavedState dialogAppPath
    ELSE
        OpenLayoutAppWindow dialogAppPath
    END IF

    targetWin = activeLayoutWindow
    IF targetWin < LBOUND(layoutWindows) OR targetWin > UBOUND(layoutWindows) THEN targetWin = 0
    IF targetWin <> 0 THEN
        IF layoutWindows(targetWin).used = 0 THEN targetWin = 0
    END IF
    IF targetWin <> 0 THEN
        IF UCASE$(NormalizePath(RTRIM$(layoutWindows(targetWin).appPath))) <> UCASE$(dialogAppPath) THEN targetWin = 0
    END IF
    IF targetWin = 0 THEN targetWin = FindLayoutWindowByAppPath(dialogAppPath)
    IF targetWin <> 0 THEN ApplyDialogInitProfile targetWin, sourcePath, profileMode
END SUB


SUB ShowFileRename(BYVAL fileName AS STRING, BYVAL dialogAppPath AS STRING, BYVAL sourceWin AS INTEGER)
    DIM renApp AS STRING

    fileName = NormalizePath(TRIM$(fileName))
    renApp = NormalizePath(TRIM$(dialogAppPath))
    IF fileName = "" THEN EXIT SUB
    IF renApp = "" THEN EXIT SUB
    IF DIR(LayoutFilePath(renApp)) = "" THEN EXIT SUB

    renameCreateDirMode = 0
    renameCreateDirParent = ""
    renameFilePath = fileName
    renameSourceWin = sourceWin

    ' The FILE_BROWSER rename action stores the source window state before calling here.
    OpenDialogLayoutAndApplyProfile renApp, fileName, "RENAME", -1
END SUB

SUB ShowDirectoryCreate(BYVAL parentDir AS STRING, BYVAL dialogAppPath AS STRING, BYVAL sourceWin AS INTEGER)
    DIM renApp AS STRING

    parentDir = AbsoluteDirPath(TRIM$(parentDir))
    renApp = NormalizePath(TRIM$(dialogAppPath))
    IF parentDir = "" THEN EXIT SUB
    IF renApp = "" THEN EXIT SUB
    IF PathExistsAny(parentDir) = 0 THEN EXIT SUB
    IF DIR(LayoutFilePath(renApp)) = "" THEN EXIT SUB

    renameCreateDirMode = -1
    renameCreateDirParent = parentDir
    renameFilePath = parentDir
    renameSourceWin = sourceWin

    ' The FILE_BROWSER new-directory action already stored the source window state.
    OpenDialogLayoutAndApplyProfile renApp, parentDir, "CREATE", -1
END SUB



SUB ShowFileDelete(BYVAL fileName AS STRING, BYVAL dialogAppPath AS STRING, BYVAL sourceWin AS INTEGER)
    DIM delApp AS STRING
    DIM firstPath AS STRING
    DIM sepPos AS INTEGER
    DIM itemCount AS INTEGER
    DIM profileMode AS STRING
    DIM itemList AS STRING
    DIM itemPath AS STRING
    DIM hasDir AS INTEGER

    fileName = TRIM$(fileName)
    IF INSTR(fileName, CHR$(1)) = 0 THEN fileName = NormalizePath(fileName)
    delApp = NormalizePath(TRIM$(dialogAppPath))
    IF fileName = "" THEN EXIT SUB
    IF delApp = "" THEN EXIT SUB
    IF DIR(LayoutFilePath(delApp)) = "" THEN EXIT SUB

    deleteFilePath = fileName
    deleteSourceWin = sourceWin
    deleteSourceDir = ""

    firstPath = fileName
    sepPos = INSTR(firstPath, CHR$(1))
    IF sepPos > 0 THEN firstPath = LEFT$(firstPath, sepPos - 1)
    IF LEFT$(UCASE$(firstPath), 2) = "F:" AND INSTR(MID$(firstPath, 3), ":") > 0 THEN firstPath = MID$(firstPath, 3)
    IF LEFT$(UCASE$(firstPath), 2) = "D:" AND INSTR(MID$(firstPath, 3), ":") > 0 THEN firstPath = MID$(firstPath, 3)
    IF TRIM$(firstPath) <> "" THEN deleteSourceDir = ParentPath(NormalizePath(firstPath))
    IF deleteSourceDir = "" THEN deleteSourceDir = FileBrowserWindowCurrentDir(sourceWin)

    itemCount = DelimitedListCount(fileName)
    profileMode = "FILE"
    hasDir = 0

    IF itemCount > 1 THEN
        itemList = fileName
        DO WHILE itemList <> ""
            sepPos = INSTR(itemList, CHR$(1))
            IF sepPos > 0 THEN
                itemPath = LEFT$(itemList, sepPos - 1)
                itemList = MID$(itemList, sepPos + 1)
            ELSE
                itemPath = itemList
                itemList = ""
            END IF

            IF LEFT$(UCASE$(itemPath), 2) = "D:" AND INSTR(MID$(itemPath, 3), ":") > 0 THEN itemPath = MID$(itemPath, 3)
            IF DirectoryExistsForDelete(itemPath) <> 0 THEN hasDir = -1
        LOOP

        IF hasDir <> 0 THEN
            profileMode = "MULTIDIR"
        ELSE
            profileMode = "MULTI"
        END IF
    ELSEIF DirectoryExistsForDelete(fileName) <> 0 THEN
        profileMode = "DIR"
    END IF

    ' Delete can be launched from paths that have not already saved source state.
    ' Let the normal open path do that one required sync, but only once.
    OpenDialogLayoutAndApplyProfile delApp, fileName, profileMode, 0
END SUB

