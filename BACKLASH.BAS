SUB ApplyDesktopPropertiesFast()
    DIM oldResMode AS INTEGER
    DIM oldColorDepth AS INTEGER
    DIM oldShowIcons AS INTEGER
    DIM oldShowTaskbar AS INTEGER
    DIM oldShowClock AS INTEGER
    DIM oldSnapIcons AS INTEGER
    DIM oldTrailEffect AS INTEGER
    DIM oldTaskbarEdge AS INTEGER
    DIM oldTaskbarH AS INTEGER
    DIM oldTaskbarY AS INTEGER
    DIM oldWorkY AS INTEGER
    DIM oldWorkH AS INTEGER
    DIM oldWorkBottom AS INTEGER
    DIM oldIconCellW AS INTEGER
    DIM oldIconCellH AS INTEGER
    DIM oldWallpaperPath AS STRING
    DIM oldWallpaperMode AS INTEGER
    DIM displayChanged AS INTEGER
    DIM wallpaperChanged AS INTEGER
    DIM desktopChanged AS INTEGER
    DIM taskbarChanged AS INTEGER

    oldResMode = cfg.resMode
    oldColorDepth = cfg.colorDepth
    oldShowIcons = cfg.showIcons
    oldShowTaskbar = cfg.showTaskbar
    oldShowClock = cfg.showClock
    oldSnapIcons = cfg.snapIcons
    oldTrailEffect = cfg.trailEffect
    oldTaskbarEdge = lay.taskbarEdge
    oldTaskbarH = TASKBAR_H
    oldTaskbarY = TASKBAR_Y
    oldWorkY = WORK_Y
    oldWorkH = WORK_H
    oldWorkBottom = WORK_BOTTOM
    oldIconCellW = ICON_CELL_W
    oldIconCellH = ICON_CELL_H
    oldWallpaperPath = theme.wallpaperPath
    oldWallpaperMode = theme.wallpaperMode

    SaveBindingsFromControlsOnly

    LoadAllConfig
    ApplyResolution
    BuildLayout

    displayChanged = 0
    IF cfg.resMode <> oldResMode THEN displayChanged = -1
    IF cfg.colorDepth <> oldColorDepth THEN displayChanged = -1

    IF displayChanged <> 0 THEN
        RefreshDisplayFromCurrentConfig
        EXIT SUB
    END IF

    wallpaperChanged = 0
    IF UCASE$(theme.wallpaperPath) <> UCASE$(oldWallpaperPath) THEN wallpaperChanged = -1
    IF theme.wallpaperMode <> oldWallpaperMode THEN wallpaperChanged = -1

    IF wallpaperChanged <> 0 THEN
        LoadWallpaper
        BuildBackgroundCache
        InvalidateDesktopCache
    END IF

    desktopChanged = 0
    IF cfg.showIcons <> oldShowIcons THEN desktopChanged = -1
    IF cfg.snapIcons <> oldSnapIcons THEN desktopChanged = -1
    IF ICON_CELL_W <> oldIconCellW THEN desktopChanged = -1
    IF ICON_CELL_H <> oldIconCellH THEN desktopChanged = -1
    IF WORK_Y <> oldWorkY THEN desktopChanged = -1
    IF WORK_H <> oldWorkH THEN desktopChanged = -1
    IF WORK_BOTTOM <> oldWorkBottom THEN desktopChanged = -1

    IF desktopChanged <> 0 THEN
        ResolveDesktopIconCollisions
        InvalidateDesktopCache
    END IF

    taskbarChanged = 0
    IF cfg.showTaskbar <> oldShowTaskbar THEN taskbarChanged = -1
    IF cfg.showClock <> oldShowClock THEN taskbarChanged = -1
    IF lay.taskbarEdge <> oldTaskbarEdge THEN taskbarChanged = -1
    IF TASKBAR_H <> oldTaskbarH THEN taskbarChanged = -1
    IF TASKBAR_Y <> oldTaskbarY THEN taskbarChanged = -1

    IF taskbarChanged <> 0 THEN
        soundVolumePopupOpen = 0
        InvalidateTaskbarCache
        InvalidateStartMenuBackBuffer
        InvalidateContextOverlayBackBuffer
        InvalidateDesktopCache
    END IF

    IF cfg.trailEffect <> oldTrailEffect THEN
        cursorTrailCount = 0
        cursorBackValid = 0
    END IF

    ApplyBacklash256Palette

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
            SyncLayoutWindowFromGlobals activeLayoutWindow
            SaveBindingSnapshotFromGlobals activeLayoutWindow
        END IF
    END IF
END SUB

SUB ApplyWallpaperFast()
    DIM oldWallpaperPath AS STRING
    DIM oldWallpaperMode AS INTEGER
    DIM wallpaperChanged AS INTEGER

    oldWallpaperPath = theme.wallpaperPath
    oldWallpaperMode = theme.wallpaperMode

    SaveBindingsFromControlsOnly

    LoadThemeConfig
    BuildThemeColors
    LoadUIStyleConfig

    wallpaperChanged = 0
    IF UCASE$(theme.wallpaperPath) <> UCASE$(oldWallpaperPath) THEN wallpaperChanged = -1
    IF theme.wallpaperMode <> oldWallpaperMode THEN wallpaperChanged = -1

    IF wallpaperChanged <> 0 THEN
        LoadWallpaper
        BuildBackgroundCache
        InvalidateDesktopCache
    ELSEIF bgCache = 0 THEN
        BuildBackgroundCache
        InvalidateDesktopCache
    END IF

    ApplyBacklash256Palette

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
            SyncLayoutWindowFromGlobals activeLayoutWindow
            SaveBindingSnapshotFromGlobals activeLayoutWindow
        END IF
    END IF
END SUB

