FUNCTION UIStyleReadColor(BYVAL baseKey AS STRING, BYVAL fallbackCol AS UINTEGER) AS UINTEGER
    DIM idxText AS STRING
    DIM r AS INTEGER
    DIM g AS INTEGER
    DIM b AS INTEGER

    baseKey = LCASE$(TRIM$(baseKey))
    IF baseKey = "" THEN RETURN fallbackCol

    IF cfg.colorDepth = 4 THEN
        idxText = TRIM$(ReadCfgValueInSection(PATH_UISTYLECFG, "COLORS", baseKey + "_idx_4", ""))
        IF idxText <> "" THEN RETURN VALINT(idxText)
        RETURN fallbackCol
    END IF

    r = VALINT(ReadCfgValueInSection(PATH_UISTYLECFG, "COLORS", baseKey + "_r", "-1"))
    g = VALINT(ReadCfgValueInSection(PATH_UISTYLECFG, "COLORS", baseKey + "_g", "-1"))
    b = VALINT(ReadCfgValueInSection(PATH_UISTYLECFG, "COLORS", baseKey + "_b", "-1"))

    IF r < 0 OR g < 0 OR b < 0 THEN RETURN fallbackCol
    IF r > 255 THEN r = 255
    IF g > 255 THEN g = 255
    IF b > 255 THEN b = 255

    RETURN MakeCol(r, g, b)
END FUNCTION

SUB LoadUIStyleConfig()
    LoadCfgReadCacheFile PATH_UISTYLECFG

    uiStyle.styleName = UCASE$(TRIM$(ReadCfgValueInSection(PATH_UISTYLECFG, "UISTYLE", "style", "CLASSIC")))
    IF uiStyle.styleName = "" THEN uiStyle.styleName = "CLASSIC"

    uiStyle.buttonStyle = UCASE$(TRIM$(ReadCfgValueInSection(PATH_UISTYLECFG, "UISTYLE", "button_style", "CLASSIC")))
    IF uiStyle.buttonStyle = "" THEN uiStyle.buttonStyle = "CLASSIC"

    uiStyle.windowStyle = UCASE$(TRIM$(ReadCfgValueInSection(PATH_UISTYLECFG, "UISTYLE", "window_style", "CLASSIC")))
    IF uiStyle.windowStyle = "" THEN uiStyle.windowStyle = "CLASSIC"

    uiStyle.titleStyle = UCASE$(TRIM$(ReadCfgValueInSection(PATH_UISTYLECFG, "UISTYLE", "title_style", "CLASSIC")))
    IF uiStyle.titleStyle = "" THEN uiStyle.titleStyle = "CLASSIC"

    uiStyle.titleButtonStyle = UCASE$(TRIM$(ReadCfgValueInSection(PATH_UISTYLECFG, "UISTYLE", "title_button_style", "CLASSIC")))
    IF uiStyle.titleButtonStyle = "" THEN uiStyle.titleButtonStyle = "CLASSIC"

    uiStyle.styleModern = 0
    IF uiStyle.styleName = "MODERN" OR uiStyle.styleName = "SOFT" OR uiStyle.styleName = "FLAT" THEN uiStyle.styleModern = -1

    uiStyle.buttonStyleId = 1
    SELECT CASE uiStyle.buttonStyle
    CASE "MODERN"
        uiStyle.buttonStyleId = 2
    CASE "SOFT"
        uiStyle.buttonStyleId = 3
    CASE "FLAT"
        uiStyle.buttonStyleId = 4
    CASE "PILL"
        uiStyle.buttonStyleId = 5
    END SELECT

    uiStyle.windowStyleId = 1
    SELECT CASE uiStyle.windowStyle
    CASE "MODERN"
        uiStyle.windowStyleId = 2
    CASE "SOFT"
        uiStyle.windowStyleId = 3
    CASE "FLAT"
        uiStyle.windowStyleId = 4
    END SELECT

    uiStyle.titleStyleId = 1
    SELECT CASE uiStyle.titleStyle
    CASE "MODERN"
        uiStyle.titleStyleId = 2
    CASE "SOFT"
        uiStyle.titleStyleId = 3
    CASE "FLAT"
        uiStyle.titleStyleId = 4
    END SELECT

    uiStyle.titleButtonStyleId = 1
    SELECT CASE uiStyle.titleButtonStyle
    CASE "MODERN"
        uiStyle.titleButtonStyleId = 2
    CASE "SOFT"
        uiStyle.titleButtonStyleId = 3
    CASE "FLAT"
        uiStyle.titleButtonStyleId = 4
    CASE "PILL"
        uiStyle.titleButtonStyleId = 5
    END SELECT

    uiStyle.buttonModern = uiStyle.styleModern
    IF uiStyle.buttonStyleId = 1 THEN uiStyle.buttonModern = 0
    IF uiStyle.buttonStyleId > 1 THEN uiStyle.buttonModern = -1

    uiStyle.windowModern = uiStyle.styleModern
    IF uiStyle.windowStyleId = 1 THEN uiStyle.windowModern = 0
    IF uiStyle.windowStyleId > 1 THEN uiStyle.windowModern = -1

    uiStyle.titleModern = uiStyle.styleModern
    IF uiStyle.titleStyleId = 1 THEN uiStyle.titleModern = 0
    IF uiStyle.titleStyleId > 1 THEN uiStyle.titleModern = -1

    uiStyle.titleButtonModern = uiStyle.styleModern
    IF uiStyle.titleButtonStyleId = 1 THEN uiStyle.titleButtonModern = 0
    IF uiStyle.titleButtonStyleId > 1 THEN uiStyle.titleButtonModern = -1

    uiStyle.bevelDepth = VALINT(ReadCfgValueInSection(PATH_UISTYLECFG, "UISTYLE", "bevel_depth", "1"))
    IF uiStyle.bevelDepth < 0 THEN uiStyle.bevelDepth = 0
    IF uiStyle.bevelDepth > 2 THEN uiStyle.bevelDepth = 2

    uiStyle.pressedOffset = VALINT(ReadCfgValueInSection(PATH_UISTYLECFG, "UISTYLE", "pressed_offset", "1"))
    IF uiStyle.pressedOffset < 0 THEN uiStyle.pressedOffset = 0
    IF uiStyle.pressedOffset > 2 THEN uiStyle.pressedOffset = 2

    uiStyle.panelFaceCol = UIStyleReadColor("panel_face", COL_TASKBAR)
    uiStyle.buttonFaceCol = UIStyleReadColor("button_face", COL_BUTTON)
    uiStyle.bevelHiCol = UIStyleReadColor("bevel_hi", COL_BEVEL_HI)
    uiStyle.bevelLoCol = UIStyleReadColor("bevel_lo", COL_BEVEL_LO)
    uiStyle.windowBorderHiCol = UIStyleReadColor("window_border_hi", COL_BEVEL_HI)
    uiStyle.windowBorderLoCol = UIStyleReadColor("window_border_lo", COL_BEVEL_LO)
    uiStyle.titleActiveCol = UIStyleReadColor("title_active", COL_TITLE)
    uiStyle.titleInactiveCol = UIStyleReadColor("title_inactive", COL_TASKBAR)
    uiStyle.titleButtonFaceCol = UIStyleReadColor("title_button_face", COL_TASKBAR)
    uiStyle.titleButtonSymbolCol = UIStyleReadColor("title_button_symbol", COL_TEXT)
    uiStyle.loaded = -1
END SUB

FUNCTION UIStyleDrawSignature() AS LONG
    DIM sig AS LONG

    sig = 13
    sig = sig + CLNG(uiStyle.bevelDepth) * 3
    sig = sig + CLNG(uiStyle.pressedOffset) * 5
    sig = sig + CLNG(uiStyle.buttonStyleId) * 109
    sig = sig + CLNG(uiStyle.windowStyleId) * 113
    sig = sig + CLNG(uiStyle.titleStyleId) * 127
    sig = sig + CLNG(uiStyle.titleButtonStyleId) * 131
    sig = sig + CLNG(uiStyle.panelFaceCol AND &HFFFF) * 7
    sig = sig + CLNG(uiStyle.buttonFaceCol AND &HFFFF) * 11
    sig = sig + CLNG(uiStyle.bevelHiCol AND &HFFFF) * 13
    sig = sig + CLNG(uiStyle.bevelLoCol AND &HFFFF) * 17
    sig = sig + CLNG(uiStyle.windowBorderHiCol AND &HFFFF) * 19
    sig = sig + CLNG(uiStyle.windowBorderLoCol AND &HFFFF) * 23
    sig = sig + CLNG(uiStyle.titleActiveCol AND &HFFFF) * 29
    sig = sig + CLNG(uiStyle.titleInactiveCol AND &HFFFF) * 31
    sig = sig + CLNG(uiStyle.titleButtonFaceCol AND &HFFFF) * 37
    sig = sig + CLNG(uiStyle.titleButtonSymbolCol AND &HFFFF) * 41
    sig = sig + CLNG(uiStyle.styleModern) * 89
    sig = sig + CLNG(uiStyle.buttonModern) * 97
    sig = sig + CLNG(uiStyle.windowModern) * 101
    sig = sig + CLNG(uiStyle.titleModern) * 103
    sig = sig + CLNG(uiStyle.titleButtonModern) * 107
    sig = sig + CLNG(LEN(uiStyle.styleName)) * 43
    IF LEN(uiStyle.styleName) > 0 THEN sig = sig + CLNG(ASC(LEFT$(uiStyle.styleName, 1))) * 47
    sig = sig + CLNG(LEN(uiStyle.buttonStyle)) * 53
    IF LEN(uiStyle.buttonStyle) > 0 THEN sig = sig + CLNG(ASC(LEFT$(uiStyle.buttonStyle, 1))) * 59
    sig = sig + CLNG(LEN(uiStyle.windowStyle)) * 61
    IF LEN(uiStyle.windowStyle) > 0 THEN sig = sig + CLNG(ASC(LEFT$(uiStyle.windowStyle, 1))) * 67
    sig = sig + CLNG(LEN(uiStyle.titleStyle)) * 71
    IF LEN(uiStyle.titleStyle) > 0 THEN sig = sig + CLNG(ASC(LEFT$(uiStyle.titleStyle, 1))) * 73
    sig = sig + CLNG(LEN(uiStyle.titleButtonStyle)) * 79
    IF LEN(uiStyle.titleButtonStyle) > 0 THEN sig = sig + CLNG(ASC(LEFT$(uiStyle.titleButtonStyle, 1))) * 83

    IF sig > 1000000 THEN sig = sig MOD 1000000
    IF sig < -1000000 THEN sig = sig MOD 1000000
    RETURN sig
END FUNCTION

