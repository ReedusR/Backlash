    BDbgTrace "STARTUP_AFTER_STARTUP_SOUND"
END IF
IF layoutWindowCount > 0 THEN
    FOR loopIdx = LBOUND(layoutWindows) TO UBOUND(layoutWindows)
        IF layoutWindows(loopIdx).used <> 0 THEN
            BDbgWindowEvent "STARTUP_BEFORE_RESUME_WINDOW path=" + RTRIM$(layoutWindows(loopIdx).appPath), loopIdx
            layoutResumeOnly = -1
            ExecuteAppFile RTRIM$(layoutWindows(loopIdx).appPath)
            BDbgWindowEvent "STARTUP_AFTER_RESUME_WINDOW path=" + RTRIM$(layoutWindows(loopIdx).appPath), loopIdx
            EXIT FOR
        END IF
    NEXT
END IF
startupSplashEnabled = 0
BDbgTrace "STARTUP_BEFORE_FREE_SPLASH"
FreeStartupSplashWallpaper
BDbgTrace "STARTUP_AFTER_FREE_SPLASH"
needRedraw = -1
oldMx = -1
oldMy = -1
oldHoverIdx = -1
oldStartPressed = -1

BDbgTrace "MAIN_LOOP_BEGIN"
DO WHILE running
    cursorOnlyRedraw = 0
    menuOnlyRedraw = 0
    menuRowRedraw = 0
    taskbarOnlyRedraw = 0
    layoutOnlyRedraw = 0
    menuStateChanged = 0
    IF startMenuOpen = 0 AND startMenuBackValid <> 0 THEN startMenuBackValid = 0
    IF launchCtxOpen = 0 AND desktopCtxOpen = 0 AND contextOverlayFastClosePending = 0 AND contextOverlayBackValid <> 0 THEN contextOverlayBackValid = 0
    mouseOk = (GETMOUSE(mx, my, mw, mb) = 0)
    nowTime = TIMER
    IF bdbgEnabled <> 0 THEN BDbgHeartbeat "main", nowTime
    IF soundActive <> 0 THEN SoundServiceAt nowTime

    IF mouseOk THEN
        mx = ClampI(mx, 0, SCR_W - 1)
        my = ClampI(my, 0, SCR_H - 1)
    ELSE
        mx = oldMx
        my = oldMy
        mb = 0
    END IF

    IF ssMouseReady = 0 THEN
        ssOldMx = mx
        ssOldMy = my
        ssOldMb = mb
        ssOldMw = mw
        ssMouseReady = -1
        ResetScreensaverIdleAt nowTime
    ELSE
        IF mx <> ssOldMx OR my <> ssOldMy OR mb <> ssOldMb OR mw <> ssOldMw THEN ResetScreensaverIdleAt nowTime
        ssOldMx = mx
        ssOldMy = my
        ssOldMb = mb
        ssOldMw = mw
    END IF

    primaryNow = IsPrimaryButtonPressed(mb)
    IF (mb AND 2) <> 0 THEN
        rightNow = -1
    ELSE
        rightNow = 0
    END IF
    IF bdbgEnabled <> 0 THEN
        IF primaryNow <> prevPrimary THEN BDbgTrace "MAIN_PRIMARY_CHANGE state=" + BDbgNum(primaryNow) + " mx=" + BDbgNum(mx) + " my=" + BDbgNum(my)
        IF rightNow <> prevRight THEN BDbgTrace "MAIN_RIGHT_CHANGE state=" + BDbgNum(rightNow) + " mx=" + BDbgNum(mx) + " my=" + BDbgNum(my)
    END IF
    menuPointerMoved = 0
    IF mx <> oldMx OR my <> oldMy THEN menuPointerMoved = -1

    IF startMenuOpen <> 0 THEN
        IF menuPointerMoved <> 0 OR oldHoverIdx < 0 THEN
            hoverIdx = MenuItemFromPoint(mx, my)
        ELSE
            hoverIdx = oldHoverIdx
        END IF

        IF menuPointerMoved <> 0 OR hoverIdx <> oldHoverIdx OR oldHoverIdx < 0 THEN
            UpdateStartMenuHoverState hoverIdx, mx, my, menuStateChanged
        END IF
    ELSE
        hoverIdx = 0
    END IF

    IF cfg.showTaskbar <> 0 THEN
        IF InRect(mx, my, START_X1, START_Y1, START_X2, START_Y2) AND primaryNow THEN
            startPressed = -1
        ELSE
            startPressed = 0
        END IF
    ELSE
        startPressed = 0
    END IF

    IF rightNow <> 0 AND prevRight = 0 THEN
        DIM desktopRightHandled AS INTEGER
        DIM desktopRightIcon AS INTEGER
        DIM desktopRightStartMenuWasOpen AS INTEGER

        desktopRightHandled = 0
        desktopRightStartMenuWasOpen = startMenuOpen

        IF cfg.showTaskbar <> 0 AND InRect(mx, my, START_X1, START_Y1, START_X2, START_Y2) THEN
            startMenuOpen = 0
            desktopCtxOpen = 0
            FOR loopIdx = 0 TO 8
                menuOpenItem(loopIdx) = 0
            NEXT
            OpenLaunchMenuContext START_X1, TaskbarLaunchContextY()
            desktopRightHandled = -1
            oldHoverIdx = -1
            oldStartPressed = -1
            oldMx = -1
            oldMy = -1
            IF contextOverlayBackValid = 0 AND (desktopRightStartMenuWasOpen = 0 OR startMenuBackValid <> 0) THEN
                SCREENLOCK
                RestoreCursorBackBuffer
                IF desktopRightStartMenuWasOpen <> 0 AND startMenuBackBuffer <> 0 AND startMenuBackValid <> 0 THEN
                    PUT (startMenuBackX, startMenuBackY), startMenuBackBuffer, PSET
                    startMenuBackValid = 0
                    DrawTaskbar startPressed
                END IF
                CaptureContextOverlayBackBuffer launchCtxX, launchCtxY, launchCtxX + LAUNCH_CTX_W, launchCtxY + LAUNCH_CTX_H
                DrawLaunchMenuContext
                SaveCursorBackBuffer mx, my
                DrawCursor mx, my
                SCREENUNLOCK
            ELSE
                needRedraw = -1
            END IF
        ELSEIF startMenuOpen <> 0 AND PointInAnyMenuPanel(mx, my) <> 0 THEN
            startMenuOpen = 0
            desktopCtxOpen = 0
            FOR loopIdx = 0 TO 8
                menuOpenItem(loopIdx) = 0
            NEXT
            OpenLaunchMenuContext mx, my
            desktopRightHandled = -1
            oldHoverIdx = -1
            oldStartPressed = -1
            oldMx = -1
            oldMy = -1
            IF contextOverlayBackValid = 0 AND (desktopRightStartMenuWasOpen = 0 OR startMenuBackValid <> 0) THEN
                SCREENLOCK
                RestoreCursorBackBuffer
                IF desktopRightStartMenuWasOpen <> 0 AND startMenuBackBuffer <> 0 AND startMenuBackValid <> 0 THEN
                    PUT (startMenuBackX, startMenuBackY), startMenuBackBuffer, PSET
                    startMenuBackValid = 0
                    DrawTaskbar startPressed
                END IF
                CaptureContextOverlayBackBuffer launchCtxX, launchCtxY, launchCtxX + LAUNCH_CTX_W, launchCtxY + LAUNCH_CTX_H
                DrawLaunchMenuContext
                SaveCursorBackBuffer mx, my
                DrawCursor mx, my
                SCREENUNLOCK
            ELSE
                needRedraw = -1
            END IF
        ELSEIF launchCtxOpen <> 0 THEN
            launchCtxOpen = 0
            desktopCtxOpen = 0
            desktopRightHandled = -1
            oldHoverIdx = -1
            oldStartPressed = -1
            oldMx = -1
            oldMy = -1
            IF contextOverlayBackValid <> 0 THEN
                contextOverlayFastClosePending = -1
            ELSE
                needRedraw = -1
            END IF
        ELSEIF desktopCtxOpen <> 0 THEN
            desktopCtxOpen = 0
            desktopCtxMode = 0
            desktopCtxIcon = 0
            desktopRightHandled = -1
            oldHoverIdx = -1
            oldStartPressed = -1
            oldMx = -1
            oldMy = -1
            IF contextOverlayBackValid <> 0 THEN
                contextOverlayFastClosePending = -1
            ELSE
                needRedraw = -1
            END IF
        END IF

        IF desktopRightHandled = 0 AND ClockMouseRightAction(mx, my) <> 0 THEN
            startMenuOpen = 0
            desktopCtxOpen = 0
            FOR loopIdx = 0 TO 8
                menuOpenItem(loopIdx) = 0
            NEXT
            SoundUiEvent "CLICK"
            desktopRightHandled = -1
            mouseDownIcon = 0
            draggingIcon = 0
            dragMoved = 0
            oldHoverIdx = -1
            oldStartPressed = -1
            oldMx = -1
            oldMy = -1
            needRedraw = -1
        END IF

        IF desktopRightHandled = 0 AND cfg.showTaskbar <> 0 AND TaskbarVolumeHitFromPoint(mx, my) <> 0 THEN
            startMenuOpen = 0
            desktopCtxOpen = 0
            ClockClosePopups
            FOR loopIdx = 0 TO 8
                menuOpenItem(loopIdx) = 0
            NEXT
            SoundCloseVolumePopup
            SoundOpenTaskbarSettings
            desktopRightHandled = -1
            mouseDownIcon = 0
            draggingIcon = 0
            dragMoved = 0
            oldHoverIdx = -1
            oldStartPressed = -1
            oldMx = -1
            oldMy = -1
        END IF

        IF desktopRightHandled = 0 AND soundVolumePopupOpen <> 0 THEN
            IF SoundVolumePopupHitFromPoint(mx, my) = 0 THEN
                SoundCloseVolumePopup
                needRedraw = -1
            END IF
            desktopRightHandled = -1
            mouseDownIcon = 0
            draggingIcon = 0
            dragMoved = 0
            oldHoverIdx = -1
            oldStartPressed = -1
            oldMx = -1
            oldMy = -1
        END IF

        IF desktopRightHandled = 0 AND startMenuOpen = 0 AND launchCtxOpen = 0 AND my >= WORK_Y AND my <= WORK_BOTTOM THEN
            desktopRightIcon = IconFromPoint(mx, my)
            IF desktopRightIcon > 0 THEN
                OpenDesktopIconContext mx, my, desktopRightIcon
                IF selectedIcon = desktopRightIcon AND contextOverlayBackValid = 0 THEN
                    SCREENLOCK
                    RestoreCursorBackBuffer
                    CaptureContextOverlayBackBuffer desktopCtxX, desktopCtxY, desktopCtxX + DesktopContextWidth(), desktopCtxY + DesktopContextHeight()
                    DrawDesktopContextMenu
                    SaveCursorBackBuffer mx, my
                    DrawCursor mx, my
                    SCREENUNLOCK
                ELSE
                    needRedraw = -1
                END IF
            ELSE
                OpenDesktopEmptyContext mx, my
                IF selectedIcon = 0 AND contextOverlayBackValid = 0 THEN
                    SCREENLOCK
                    RestoreCursorBackBuffer
                    CaptureContextOverlayBackBuffer desktopCtxX, desktopCtxY, desktopCtxX + DesktopContextWidth(), desktopCtxY + DesktopContextHeight()
                    DrawDesktopContextMenu
                    SaveCursorBackBuffer mx, my
                    DrawCursor mx, my
                    SCREENUNLOCK
                ELSE
                    needRedraw = -1
                END IF
            END IF
            desktopRightHandled = -1
            mouseDownIcon = 0
            draggingIcon = 0
            dragMoved = 0
            oldHoverIdx = -1
            oldStartPressed = -1
            oldMx = -1
            oldMy = -1
        END IF
    END IF

    IF primaryNow <> 0 AND prevPrimary = 0 THEN
        DIM desktopPrimaryConsumed AS INTEGER
        desktopPrimaryConsumed = 0

        IF cfg.showTaskbar <> 0 AND InRect(mx, my, START_X1, START_Y1, START_X2, START_Y2) THEN
            dragWindowIndex = 0
            mouseDownIcon = 0
            mouseDownX = mx
            mouseDownY = my
            desktopPrimaryConsumed = -1
        ELSEIF ClockMousePrimaryAction(mx, my) <> 0 THEN
            startMenuOpen = 0
            launchCtxOpen = 0
            desktopCtxOpen = 0
            FOR loopIdx = 0 TO 8
                menuOpenItem(loopIdx) = 0
            NEXT
            SoundUiEvent "CLICK"
            needRedraw = -1
            dragWindowIndex = 0
            mouseDownIcon = 0
            mouseDownX = -1000
            mouseDownY = -1000
            desktopPrimaryConsumed = -1
        ELSEIF cfg.showTaskbar <> 0 AND TaskbarVolumeHitFromPoint(mx, my) <> 0 THEN
            ClockClosePopups
            SoundToggleVolumePopup
            SoundUiEvent "CLICK"
            needRedraw = -1
            dragWindowIndex = 0
            mouseDownIcon = 0
            mouseDownX = -1000
            mouseDownY = -1000
            desktopPrimaryConsumed = -1
        ELSEIF SoundVolumePopupHitFromPoint(mx, my) <> 0 THEN
            SELECT CASE SoundVolumePopupActionFromPoint(mx, my)
            CASE 1
                SoundSetVolumePercent soundVolumePercent - TASKBAR_VOLUME_STEP
            CASE 2
                SoundSetVolumePercent soundVolumePercent + TASKBAR_VOLUME_STEP
            CASE 3
                SoundSetVolumeFromPopupPoint mx, my
            END SELECT
            SoundUiEvent "CLICK"
            needRedraw = -1
            dragWindowIndex = 0
            mouseDownIcon = 0
            mouseDownX = -1000
            mouseDownY = -1000
            desktopPrimaryConsumed = -1
        ELSEIF soundVolumePopupOpen <> 0 THEN
            SoundCloseVolumePopup
            needRedraw = -1
            dragWindowIndex = 0
            mouseDownIcon = 0
            mouseDownX = -1000
            mouseDownY = -1000
            desktopPrimaryConsumed = -1
        ELSEIF launchCtxOpen <> 0 OR desktopCtxOpen <> 0 THEN
            dragWindowIndex = 0
            mouseDownIcon = 0
        ELSE
            dragWindowIndex = WindowFromPoint(mx, my)
        END IF

        IF dragWindowIndex > 0 THEN
            BringWindowToFront dragWindowIndex
            dragWindowIndex = WindowFromPoint(mx, my)

            IF WindowResizeHit(dragWindowIndex, mx, my) THEN
                resizingWindow = -1
                draggingWindow = 0
                resizeStartW = windows(dragWindowIndex).w
                resizeStartH = windows(dragWindowIndex).h
                resizeStartMX = mx
                resizeStartMY = my
                mouseDownIcon = 0
        
            ELSEIF WindowTitleHit(dragWindowIndex, mx, my) THEN
                draggingWindow = -1
                resizingWindow = 0
                windowDragOffX = mx - windows(dragWindowIndex).x
                windowDragOffY = my - windows(dragWindowIndex).y
                mouseDownIcon = 0
        
            ELSE
                draggingWindow = 0
                resizingWindow = 0

            END IF
        END IF

        IF desktopPrimaryConsumed = 0 AND dragWindowIndex = 0 AND draggingWindow = 0 AND resizingWindow = 0 AND startMenuOpen = 0 AND launchCtxOpen = 0 AND desktopCtxOpen = 0 AND _
           mx >= WORK_X AND mx <= WORK_RIGHT AND my >= WORK_Y AND my <= WORK_BOTTOM THEN
            mouseDownIcon = IconFromPoint(mx, my)
            mouseDownX = mx
            mouseDownY = my

            IF mouseDownIcon > 0 THEN
                selectedIcon = mouseDownIcon
                mouseDownIconX = desktopIcons(mouseDownIcon).x
                mouseDownIconY = desktopIcons(mouseDownIcon).y
                dragMoved = 0
                    ELSE
                mouseDownIconX = 0
                mouseDownIconY = 0
            END IF
        ELSE
            mouseDownIcon = 0
        END IF
    END IF

    IF primaryNow <> 0 AND draggingWindow <> 0 AND dragWindowIndex > 0 THEN
        windows(dragWindowIndex).x = mx - windowDragOffX
        windows(dragWindowIndex).y = my - windowDragOffY

        IF windows(dragWindowIndex).x < 0 THEN windows(dragWindowIndex).x = 0
        IF windows(dragWindowIndex).x + windows(dragWindowIndex).w > SCR_W THEN _
            windows(dragWindowIndex).x = SCR_W - windows(dragWindowIndex).w

        ' Keep the title bar inside the work area for legacy windows too.
        windowTitleMinY = WORK_Y
        windowTitleMaxY = WORK_BOTTOM - 18
        IF windowTitleMaxY < windowTitleMinY THEN windowTitleMaxY = windowTitleMinY
        IF windows(dragWindowIndex).y < windowTitleMinY THEN windows(dragWindowIndex).y = windowTitleMinY
        IF windows(dragWindowIndex).y > windowTitleMaxY THEN windows(dragWindowIndex).y = windowTitleMaxY

    END IF

    IF primaryNow <> 0 AND resizingWindow <> 0 AND dragWindowIndex > 0 THEN
        windows(dragWindowIndex).w = resizeStartW + (mx - resizeStartMX)
        windows(dragWindowIndex).h = resizeStartH + (my - resizeStartMY)

        IF windows(dragWindowIndex).w < windows(dragWindowIndex).minW THEN windows(dragWindowIndex).w = windows(dragWindowIndex).minW
        IF windows(dragWindowIndex).h < windows(dragWindowIndex).minH THEN windows(dragWindowIndex).h = windows(dragWindowIndex).minH
        IF windows(dragWindowIndex).x + windows(dragWindowIndex).w > SCR_W THEN _
            windows(dragWindowIndex).w = SCR_W - windows(dragWindowIndex).x
        IF windows(dragWindowIndex).y + windows(dragWindowIndex).h - 1 > WORK_BOTTOM THEN _
            windows(dragWindowIndex).h = WORK_BOTTOM - windows(dragWindowIndex).y + 1

    END IF

    IF primaryNow <> 0 AND mouseDownIcon > 0 AND startMenuOpen = 0 AND launchCtxOpen = 0 AND draggingWindow = 0 AND resizingWindow = 0 THEN
        IF draggingIcon = 0 THEN
            IF AbsI(mx - mouseDownX) >= DRAG_START_SLOP OR AbsI(my - mouseDownY) >= DRAG_START_SLOP THEN
                draggingIcon = mouseDownIcon
                dragMoved = -1
                lastClickIcon = 0
                lastClickTime = -1000
                lastClickX = -1000
                lastClickY = -1000
            END IF
        END IF

        IF draggingIcon > 0 THEN
            desktopIcons(draggingIcon).x = mouseDownIconX + (mx - mouseDownX)
            desktopIcons(draggingIcon).y = mouseDownIconY + (my - mouseDownY)
            ClampIconToDesktop draggingIcon
            InvalidateDesktopCache
            END IF
    END IF

    IF menuPointerMoved <> 0 THEN
        IF primaryNow = 0 AND rightNow = 0 AND _
           draggingWindow = 0 AND resizingWindow = 0 AND draggingIcon = 0 AND mouseDownIcon = 0 THEN
            cursorOnlyRedraw = -1
        ELSE
            needRedraw = -1
        END IF
    END IF
    IF hoverIdx <> oldHoverIdx THEN
        IF startMenuOpen <> 0 THEN
            IF menuStateChanged = 0 AND startMenuBackValid <> 0 AND oldHoverIdx >= 0 THEN
                menuRowRedraw = -1
            ELSE
                menuOnlyRedraw = -1
            END IF
        ELSE
            needRedraw = -1
        END IF
    END IF
    IF menuStateChanged <> 0 THEN
        menuRowRedraw = 0
        IF startMenuOpen <> 0 THEN
            menuOnlyRedraw = -1
        ELSE
            needRedraw = -1
        END IF
    END IF
    IF startPressed <> oldStartPressed THEN taskbarOnlyRedraw = -1
    ' Defer the taskbar clock check while the Launch menu is open.
    ' This prevents clock ticks from repainting under the overlay during menu hover.
    IF startMenuOpen = 0 THEN
        IF TaskbarClockNeedsRedrawAt(nowTime) <> 0 THEN
            taskbarOnlyRedraw = -1
        END IF
    END IF

    IF ActiveFocusedTextbox() <> 0 THEN
        IF nowTime < uiLastCaretBlink THEN uiLastCaretBlink = nowTime
        IF startMenuOpen <> 0 THEN
            ' Keep caret timing from repainting the Launch menu overlay.
            uiLastCaretBlink = nowTime
        ELSEIF (nowTime - uiLastCaretBlink) >= .5 THEN
            uiCaretVisible = NOT uiCaretVisible
            uiLastCaretBlink = nowTime
            IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) AND layoutWindows(activeLayoutWindow).used <> 0 THEN
                layoutOnlyRedraw = -1
            ELSE
                needRedraw = -1
            END IF
        END IF
    ELSE
        IF startMenuOpen <> 0 THEN
            uiLastCaretBlink = nowTime
        ELSE
            IF uiCaretVisible = 0 THEN
                uiCaretVisible = -1
                IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) AND layoutWindows(activeLayoutWindow).used <> 0 THEN
                    layoutOnlyRedraw = -1
                ELSE
                    needRedraw = -1
                END IF
            END IF
            uiLastCaretBlink = nowTime
        END IF
    END IF

    ' If a window/control redraw is pending while the Launch menu is open,
    ' do not let that targeted redraw paint the app over the menu overlay.
    ' Escalate only that case to a normal ordered redraw: desktop/windows,
    ' taskbar, then Launch menu last.
    IF startMenuOpen <> 0 THEN
        IF layoutOnlyRedraw <> 0 THEN
            needRedraw = -1
            layoutOnlyRedraw = 0
            menuOnlyRedraw = 0
            menuRowRedraw = 0
        END IF
    END IF

    IF startMenuFastOpenPending <> 0 THEN
        DrawStartMenuOpenOnly hoverIdx, startPressed, mx, my
        startMenuFastOpenPending = 0
        startMenuFastClosePending = 0
        taskbarOnlyRedraw = 0
        oldMx = mx
        oldMy = my
        oldHoverIdx = hoverIdx
        oldStartPressed = startPressed
    ELSEIF startMenuFastClosePending <> 0 THEN
        DrawStartMenuCloseOnly startPressed, mx, my
        startMenuFastClosePending = 0
        startMenuFastOpenPending = 0
        taskbarOnlyRedraw = 0
        oldMx = mx
        oldMy = my
        oldHoverIdx = hoverIdx
        oldStartPressed = startPressed
    ELSEIF contextOverlayFastClosePending <> 0 THEN
        ' Close the overlay directly, then consume the same highest-priority
        ' targeted redraw that would have run without the overlay close.
        ' This avoids escalating the pair into a whole-screen redraw.
        DrawContextOverlayCloseOnly mx, my
        contextOverlayFastClosePending = 0
        needRedraw = 0
        cursorOnlyRedraw = 0
        IF layoutOnlyRedraw <> 0 THEN
            IF ActiveFocusedTextbox() <> 0 THEN
                DrawActiveFocusedTextboxOnly mx, my
            ELSE
                DrawActiveLayoutWindowOnly mx, my
            END IF
            layoutOnlyRedraw = 0
        ELSEIF menuOnlyRedraw <> 0 THEN
            DrawStartMenuOverlay hoverIdx, mx, my
            menuOnlyRedraw = 0
            menuRowRedraw = 0
        ELSEIF menuRowRedraw <> 0 THEN
            DrawStartMenuRowsOnly oldHoverIdx, hoverIdx, mx, my
            menuRowRedraw = 0
        ELSEIF taskbarOnlyRedraw <> 0 THEN
            DrawTaskbarOnly startPressed, mx, my
            taskbarOnlyRedraw = 0
        END IF
        oldMx = mx
        oldMy = my
        oldHoverIdx = hoverIdx
        oldStartPressed = startPressed
    ELSEIF needRedraw THEN
        DrawScreen hoverIdx, startPressed, mx, my
        needRedraw = 0
        cursorOnlyRedraw = 0
        menuOnlyRedraw = 0
        menuRowRedraw = 0
        taskbarOnlyRedraw = 0
        layoutOnlyRedraw = 0
        startMenuFastOpenPending = 0
        startMenuFastClosePending = 0
        contextOverlayFastClosePending = 0
        oldMx = mx
        oldMy = my
        oldHoverIdx = hoverIdx
        oldStartPressed = startPressed
    ELSEIF layoutOnlyRedraw <> 0 THEN
        IF ActiveFocusedTextbox() <> 0 THEN
            DrawActiveFocusedTextboxOnly mx, my
        ELSE
            DrawActiveLayoutWindowOnly mx, my
        END IF
        layoutOnlyRedraw = 0
        cursorOnlyRedraw = 0
        oldMx = mx
        oldMy = my
        oldHoverIdx = hoverIdx
        oldStartPressed = startPressed
    ELSEIF menuOnlyRedraw <> 0 THEN
        DrawStartMenuOverlay hoverIdx, mx, my
        menuOnlyRedraw = 0
        menuRowRedraw = 0
        cursorOnlyRedraw = 0
        oldMx = mx
        oldMy = my
        oldHoverIdx = hoverIdx
        oldStartPressed = startPressed
    ELSEIF menuRowRedraw <> 0 THEN
        DrawStartMenuRowsOnly oldHoverIdx, hoverIdx, mx, my
        menuRowRedraw = 0
        cursorOnlyRedraw = 0
        oldMx = mx
        oldMy = my
        oldHoverIdx = hoverIdx
        oldStartPressed = startPressed
    ELSEIF taskbarOnlyRedraw <> 0 THEN
        DrawTaskbarOnly startPressed, mx, my
        taskbarOnlyRedraw = 0
        cursorOnlyRedraw = 0
        oldMx = mx
        oldMy = my
        oldHoverIdx = hoverIdx
        oldStartPressed = startPressed
    ELSEIF cursorOnlyRedraw <> 0 THEN
        DrawCursorOnly mx, my
        oldMx = mx
        oldMy = my
        oldHoverIdx = hoverIdx
        oldStartPressed = startPressed
    END IF

    IF primaryNow = 0 AND prevPrimary <> 0 THEN
        IF launchCtxOpen <> 0 THEN
            IF LaunchMenuContextHit(mx, my) <> 0 THEN
                launchCtxOpen = 0
                startMenuOpen = 0
                FOR loopIdx = 0 TO 8
                    menuOpenItem(loopIdx) = 0
                NEXT
                oldHoverIdx = -1
                oldStartPressed = -1
                oldMx = -1
                oldMy = -1
                LaunchMenuEditor
                needRedraw = -1
            ELSE
                launchCtxOpen = 0
                oldHoverIdx = -1
                oldStartPressed = -1
                oldMx = -1
                oldMy = -1
                IF contextOverlayBackValid <> 0 THEN
                    contextOverlayFastClosePending = -1
                ELSE
                    needRedraw = -1
                END IF
            END IF

        ELSEIF desktopCtxOpen <> 0 THEN
            DIM desktopCtxRow AS INTEGER
            desktopCtxRow = DesktopContextHit(mx, my)
            desktopCtxOpen = 0
            oldHoverIdx = -1
            oldStartPressed = -1
            oldMx = -1
            oldMy = -1
            mouseDownIcon = 0
            draggingIcon = 0
            dragMoved = 0
            IF desktopCtxRow > 0 THEN
                HandleDesktopContextAction desktopCtxRow
                needRedraw = -1
            ELSEIF contextOverlayBackValid <> 0 THEN
                contextOverlayFastClosePending = -1
            ELSE
                needRedraw = -1
            END IF
            desktopCtxMode = 0
            desktopCtxIcon = 0

        ELSEIF draggingWindow <> 0 OR resizingWindow <> 0 THEN
            draggingWindow = 0
            resizingWindow = 0
            dragWindowIndex = 0
                oldMx = -1
            oldMy = -1
            oldHoverIdx = -1
            oldStartPressed = -1

        ELSEIF draggingIcon > 0 THEN
            PlaceDesktopIconNoCollision draggingIcon
            InvalidateDesktopCache
            SaveDesktopIcons
            needRedraw = -1

            draggingIcon = 0
            mouseDownIcon = 0
            dragMoved = 0

                oldMx = -1
            oldMy = -1
            oldHoverIdx = -1
            oldStartPressed = -1

        ELSEIF cfg.showTaskbar <> 0 AND InRect(mx, my, START_X1, START_Y1, START_X2, START_Y2) AND _
               InRect(mouseDownX, mouseDownY, START_X1, START_Y1, START_X2, START_Y2) THEN
            startMenuOpen = NOT startMenuOpen
            IF startMenuOpen = 0 THEN
                FOR loopIdx = 0 TO 8
                    menuOpenItem(loopIdx) = 0
                NEXT
                startMenuFastClosePending = -1
                startMenuFastOpenPending = 0
            ELSE
                IF selectedIcon <> 0 THEN
                    ' Keep the old desktop redraw when the click also clears an icon highlight.
                    ' That selection overlay has to be removed before the menu opens.
                    selectedIcon = 0
                    needRedraw = -1
                ELSE
                    startMenuFastOpenPending = -1
                    startMenuFastClosePending = 0
                END IF
            END IF
                oldHoverIdx = -1

        ELSEIF startMenuOpen THEN
            IF hoverIdx > 0 THEN
                IF menuItemHasSubmenu(hoverIdx) = 0 THEN
                    ExecuteMenuAction hoverIdx
                    startMenuOpen = 0
                    FOR loopIdx = 0 TO 8
                        menuOpenItem(loopIdx) = 0
                    NEXT
                END IF
                        oldHoverIdx = -1
                oldStartPressed = -1
                oldMx = -1
                oldMy = -1
            ELSE
                IF PointNearAnyMenuPanel(mx, my) = 0 THEN
                    startMenuOpen = 0
                    FOR loopIdx = 0 TO 8
                        menuOpenItem(loopIdx) = 0
                    NEXT
                                oldHoverIdx = -1
                END IF
            END IF

        ELSE
            IF mx >= WORK_X AND mx <= WORK_RIGHT AND my >= WORK_Y AND my <= WORK_BOTTOM THEN
                clickedIcon = IconFromPoint(mx, my)
            ELSE
                clickedIcon = 0
            END IF

            IF clickedIcon > 0 AND clickedIcon = mouseDownIcon THEN
                selectedIcon = clickedIcon
                oldMx = -1
                oldMy = -1
                oldHoverIdx = -1
                oldStartPressed = -1
        
                IF lastClickIcon = clickedIcon THEN
                    IF ((nowTime - lastClickTime) * 100) <= cfg.doubleClickTime THEN
                        IF AbsI(mx - lastClickX) <= DOUBLE_CLICK_MOVE_SLOP AND _
                           AbsI(my - lastClickY) <= DOUBLE_CLICK_MOVE_SLOP AND _
                           AbsI(mx - mouseDownX) <= DOUBLE_CLICK_MOVE_SLOP AND _
                           AbsI(my - mouseDownY) <= DOUBLE_CLICK_MOVE_SLOP THEN

                            ExecuteIconAction clickedIcon
                            needRedraw = -1

                            lastClickIcon = 0
                            lastClickTime = -1000
                            lastClickX = -1000
                            lastClickY = -1000

                                                oldMx = -1
                            oldMy = -1
                            oldHoverIdx = -1
                            oldStartPressed = -1
                        ELSE
                            lastClickIcon = clickedIcon
                            lastClickTime = nowTime
                            lastClickX = mx
                            lastClickY = my
                        END IF
                    ELSE
                        lastClickIcon = clickedIcon
                        lastClickTime = nowTime
                        lastClickX = mx
                        lastClickY = my
                    END IF
                ELSE
                    lastClickIcon = clickedIcon
                    lastClickTime = nowTime
                    lastClickX = mx
                    lastClickY = my
                END IF
            ELSE
                IF startMenuOpen = 0 THEN
                    selectedIcon = 0
                    oldMx = -1
                    oldMy = -1
                    oldHoverIdx = -1
                    oldStartPressed = -1
                            END IF
                lastClickIcon = 0
                lastClickTime = -1000
                lastClickX = -1000
                lastClickY = -1000
            END IF
        END IF

        dragWindowIndex = 0
        windowDragOffX = 0
        windowDragOffY = 0
        resizeStartW = 0
        resizeStartH = 0
        resizeStartMX = 0
        resizeStartMY = 0
        mouseDownIcon = 0
        mouseDownX = 0
        mouseDownY = 0
        mouseDownIconX = 0
        mouseDownIconY = 0
    END IF

    k = INKEY$
    IF k <> "" THEN
        IF bdbgEnabled <> 0 THEN BDbgTrace "MAIN_KEY len=" + BDbgNum(LEN(k)) + " code1=" + BDbgNum(ASC(LEFT$(k, 1)))
        ResetScreensaverIdle
        IF activeLayoutWindow >= 1 AND activeLayoutWindow <= 12 THEN
            IF layoutWindows(activeLayoutWindow).used <> 0 THEN
                SyncGlobalsFromLayoutWindow activeLayoutWindow
                IF uiFocusIndex >= 1 AND uiFocusIndex <= uiCount THEN
                    IF uiElems(uiFocusIndex).kindId = UI_KIND_TEXTBOX THEN
                        layoutWindows(activeLayoutWindow).focusIndex = uiFocusIndex
                        layoutWindows(activeLayoutWindow).caretPos = uiCaretPos
                        SyncLayoutWindowFromGlobals activeLayoutWindow
                    END IF
                END IF
            END IF
        END IF

        IF k = CHR$(27) THEN
            IF launchCtxOpen <> 0 THEN
                launchCtxOpen = 0
            ELSEIF startMenuOpen THEN
                startMenuOpen = 0
                    ELSEIF activeWindow <= 0 THEN
                BeginGuiShutdown
            END IF
        END IF
    END IF

    IF screenSaverConfigEnabled <> 0 AND screenSaverConfigTimeoutSeconds > 0 THEN
        IF screenSaverLastIdleCheck = 0 OR TimerElapsedSecondsAt(screenSaverLastIdleCheck, nowTime) >= .5 THEN
            IF CheckScreensaverIdleAt(nowTime) <> 0 THEN
                needRedraw = -1
                oldMx = -1
                oldMy = -1
                ssMouseReady = 0
            END IF
        END IF
    END IF

    mainLoopBusy = 0
    IF needRedraw <> 0 THEN mainLoopBusy = -1
    IF cursorOnlyRedraw <> 0 THEN mainLoopBusy = -1
    IF menuOnlyRedraw <> 0 THEN mainLoopBusy = -1
    IF menuRowRedraw <> 0 THEN mainLoopBusy = -1
    IF taskbarOnlyRedraw <> 0 THEN mainLoopBusy = -1
    IF layoutOnlyRedraw <> 0 THEN mainLoopBusy = -1
    IF startMenuFastOpenPending <> 0 THEN mainLoopBusy = -1
    IF startMenuFastClosePending <> 0 THEN mainLoopBusy = -1
    IF contextOverlayFastClosePending <> 0 THEN mainLoopBusy = -1
    IF mx <> oldMx OR my <> oldMy THEN mainLoopBusy = -1
    IF k <> "" THEN mainLoopBusy = -1
    IF primaryNow <> 0 OR rightNow <> 0 THEN mainLoopBusy = -1
    IF draggingWindow <> 0 OR resizingWindow <> 0 THEN mainLoopBusy = -1
    IF draggingIcon <> 0 OR dragMoved <> 0 THEN mainLoopBusy = -1

    prevPrimary = primaryNow
    prevRight = rightNow
    GuiAdaptiveSleep mainLoopBusy
LOOP

BDbgTrace "EXIT_AFTER_MAIN_LOOP"
BDbgTrace "EXIT_BEFORE_SOUNDSTOP"
SoundStop
BDbgTrace "EXIT_AFTER_SOUNDSTOP"
BDbgTrace "EXIT_BEFORE_DMA_RELEASE"
SoundSbDmaBufferRelease
BDbgTrace "EXIT_AFTER_DMA_RELEASE"
BDbgTrace "EXIT_BEFORE_FREE_CURSOR"
FreeCursorBackBuffer
BDbgTrace "EXIT_AFTER_FREE_CURSOR"
BDbgTrace "EXIT_BEFORE_FREE_DESKTOP"
FreeDesktopCache
BDbgTrace "EXIT_AFTER_FREE_DESKTOP"
BDbgTrace "EXIT_BEFORE_FREE_TASKBAR"
FreeTaskbarCache
BDbgTrace "EXIT_AFTER_FREE_TASKBAR"
BDbgTrace "EXIT_BEFORE_FREE_STARTMENU"
FreeStartMenuBackBuffer
BDbgTrace "EXIT_AFTER_FREE_STARTMENU"
BDbgTrace "EXIT_BEFORE_FREE_GRADIENTS"
FreeGradientCaches
BDbgTrace "EXIT_AFTER_FREE_GRADIENTS"
BDbgTrace "EXIT_BEFORE_FREE_BACKGROUND"
FreeBackgroundCache
BDbgTrace "EXIT_AFTER_FREE_BACKGROUND"
BDbgTrace "EXIT_BEFORE_FREE_WALLPAPER"
FreeWallpaper
BDbgTrace "EXIT_AFTER_FREE_WALLPAPER"
BDbgTrace "EXIT_BEFORE_FREE_STARTSTRIP"
FreeStartStrip
BDbgTrace "EXIT_AFTER_FREE_STARTSTRIP"
BDbgTrace "EXIT_BEFORE_FREE_ICONS"
FreeAllIcons
BDbgTrace "EXIT_AFTER_FREE_ICONS"

BDbgTrace "EXIT_BEFORE_SCREEN0"
SCREEN 0
BDbgTrace "EXIT_AFTER_SCREEN0"
WIDTH 80, 25
COLOR 7, 0
CLS
PRINT "Returned to DOS."
BDbgTrace "EXIT_BEFORE_END"
END
