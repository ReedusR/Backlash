        ELSE
            IF activeLayoutWindow < LBOUND(layoutWindows) OR activeLayoutWindow > UBOUND(layoutWindows) THEN activeLayoutWindow = 0
            IF activeLayoutWindow <> 0 THEN
                IF layoutWindows(activeLayoutWindow).used = 0 THEN activeLayoutWindow = 0
            END IF

            IF activeLayoutWindow = 0 THEN
                FOR i = UBOUND(layoutZOrder) TO LBOUND(layoutZOrder) STEP -1
                    IF layoutZOrder(i) >= LBOUND(layoutWindows) AND layoutZOrder(i) <= UBOUND(layoutWindows) THEN
                        IF layoutWindows(layoutZOrder(i)).used <> 0 AND layoutWindows(layoutZOrder(i)).minimized = 0 THEN
                            activeLayoutWindow = layoutZOrder(i)
                            EXIT FOR
                        END IF
                    END IF
                NEXT
            END IF

            IF activeLayoutWindow = 0 THEN
                FOR i = LBOUND(layoutWindows) TO UBOUND(layoutWindows)
                    IF layoutWindows(i).used <> 0 THEN
                        activeLayoutWindow = i
                        EXIT FOR
                    END IF
                NEXT
            END IF

            FOR i = LBOUND(layoutWindows) TO UBOUND(layoutWindows)
                IF layoutWindows(i).used <> 0 THEN layoutWindows(i).active = 0
            NEXT

            IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
                IF layoutWindows(activeLayoutWindow).used <> 0 THEN
                    IF layoutWindows(activeLayoutWindow).minimized = 0 THEN
                        layoutWindows(activeLayoutWindow).active = -1
                        MoveLayoutWindowToFront activeLayoutWindow
                    END IF
                    SyncGlobalsFromLayoutWindow activeLayoutWindow
                END IF
            END IF
        END IF

        prevBtn = 0
        oldWheel = 0
        draggingVScroll = 0
        vScrollDragOffY = 0
        draggingHScroll = 0
        hScrollDragOffX = 0
        draggingComboScroll = 0
        comboScrollDragElem = 0
        comboScrollDragOffY = 0
        draggingListScroll = 0
        listScrollDragElem = 0
        listScrollDragOffY = 0
        draggingTextScroll = 0
        textScrollDragElem = 0
        textScrollDragOffY = 0
        draggingSplitter = 0
        splitterDragElem = 0
        splitterDragOffX = 0
        appViewDragElem = 0
        appViewDragButton = 0
        appViewLastX = -1000
        appViewLastY = -1000
        fileDragCandidateWin = 0
        fileDragCandidateElem = 0
        fileDragCandidateValue = ""
        fileDragCandidateList = ""
        fileDragActive = 0
        fileDragDropValue = ""
        fileDragDropDir = ""
        fileDragDialogPath = ""
        rightBtn = 0
        prevRightBtn = 0
        ctxMenuOpen = 0
        ctxMenuX = 0
        ctxMenuY = 0
        ctxMenuWin = 0
        ctxMenuElem = 0
        ctxMenuW = 112
        ctxMenuH = 100
        ctxFileValue = ""
        ctxMenuEditEnabled = 0
        ctxMenuIsDir = 0
        ctxMenuHasCopy = 0
        ctxMenuPasteOnly = 0
        draggingLayoutWin = 0
        resizingLayoutWin = 0
        layoutResizeMode = 0
        layoutResizeStartX = 0
        layoutResizeStartY = 0
        layoutResizeStartW = 0
        layoutResizeStartH = 0
        layoutDragOffX = 0
        layoutDragOffY = 0
        dragOutlineActive = 0
        dragOutlineLastX = 0
        dragOutlineLastY = 0
        dragOutlineLastW = 0
        dragOutlineLastH = 0
        hoverIdx = 0
        oldHoverIdx = -1
        startPressed = 0
        oldStartPressed = -1
        oldMx = -1
        oldMy = -1
        cursorOnlyRedraw = 0
        ssOldMx = 0
        ssOldMy = 0
        ssOldMb = 0
        ssOldMw = 0
        ssMouseReady = 0
        lastClickIcon = 0
        lastClickTime = -1000
        lastClickX = -1000
        lastClickY = -1000
        lastTextClickIndex = 0
        lastTextClickTime = -1000
        lastTextClickX = -1000
        lastTextClickY = -1000
        lastTextClickCount = 0
        lastListClickWin = 0
        lastListClickIndex = 0
        lastListClickItem = ""
        lastListClickTime = -1000
        lastListClickX = -1000
        lastListClickY = -1000
        listClickIsDouble = 0
        lastGenericClickWin = 0
        lastGenericClickIndex = 0
        lastGenericClickTime = -1000
        lastGenericClickX = -1000
        lastGenericClickY = -1000
        genericClickIsDouble = 0
        mouseDownIcon = 0
        mouseDownX = 0
        mouseDownY = 0
        mouseDownCtrl = 0
        mouseDownShift = 0
        mouseDownIconX = 0
        mouseDownIconY = 0
        draggingIcon = 0
        dragMoved = 0
        layoutCloseClickConsumed = 0
        uiCaretVisible = -1
        uiLastCaretBlink = TIMER
        altTabWasDown = 0

        ' Redraw requests raised during input handling are consumed on the next loop pass.
        ' Do not reset this per-loop or keyboard/text redraws get erased before drawing.
        activeWindowOnlyRedraw = 0
        dirtyElementsOnlyRedraw = 0
        newLayoutWindowOnlyRedraw = 0
        newLayoutWindowRedrawPrevious = 0
        newLayoutWindowRedrawMenuOverlay = 0
        startMenuFastOpenPending = 0
        startMenuFastClosePending = 0
        contextOverlayFastClosePending = 0
        taskbarOnlyRedrawPending = 0

        layoutLoopRunning = -1
        IF bdbgEnabled <> 0 THEN BDbgWindowEvent "LAYOUT_LOOP_ENTER path=" + appPath, activeLayoutWindow

        DO
            cursorOnlyRedraw = 0
            menuOnlyRedraw = 0
            menuRowRedraw = 0
            taskbarOnlyRedraw = 0
            layoutOnlyRedraw = 0
            menuStateChanged = 0
            IF running = 0 THEN EXIT DO
            IF layoutWindowCount = 0 THEN EXIT DO
            IF startMenuOpen = 0 AND startMenuBackValid <> 0 THEN startMenuBackValid = 0
            IF launchCtxOpen = 0 AND ctxMenuOpen = 0 AND desktopCtxOpen = 0 AND contextOverlayFastClosePending = 0 AND contextOverlayBackValid <> 0 THEN contextOverlayBackValid = 0

            GETMOUSE smx, smy, smw, smb
            nowTime = TIMER
            IF bdbgEnabled <> 0 THEN BDbgHeartbeat "layout", nowTime
            IF soundActive <> 0 THEN SoundServiceAt nowTime
            IF CanvasTickActiveWindowAt(nowTime) <> 0 THEN
                dirtyElementsOnlyRedraw = -1
                oldMx = -1
                oldMy = -1
            END IF
            curBtn = smb AND 1
            rightBtn = smb AND 2
            activeFocusTextboxIdx = ActiveFocusedTextboxIndex()

            wheelDelta = smw - oldWheel
            oldWheel = smw

            IF ssMouseReady = 0 THEN
                ssOldMx = smx
                ssOldMy = smy
                ssOldMb = smb
                ssOldMw = smw
                ssMouseReady = -1
                ResetScreensaverIdleAt nowTime
            ELSE
                IF smx <> ssOldMx OR smy <> ssOldMy OR smb <> ssOldMb OR smw <> ssOldMw THEN ResetScreensaverIdleAt nowTime
                ssOldMx = smx
                ssOldMy = smy
                ssOldMb = smb
                ssOldMw = smw
            END IF

            IF wheelDelta <> 0 THEN
                scrollRedrawMode = ScrollHoveredScrollableAtMouse(smx, smy, wheelDelta)
                SELECT CASE scrollRedrawMode
                CASE 1
                    needRedraw = -1
                    oldMx = -1
                    oldMy = -1
                CASE 2
                    dirtyElementsOnlyRedraw = -1
                    oldMx = -1
                    oldMy = -1
                CASE 3
                    activeWindowOnlyRedraw = -1
                    oldMx = -1
                    oldMy = -1
                END SELECT
            END IF
            menuPointerMoved = 0
            IF smx <> oldMx OR smy <> oldMy THEN menuPointerMoved = -1

            IF startMenuOpen <> 0 THEN
                IF menuPointerMoved <> 0 OR oldHoverIdx < 0 THEN
                    hoverIdx = MenuItemFromPoint(smx, smy)
                ELSE
                    hoverIdx = oldHoverIdx
                END IF
            ELSE
                hoverIdx = 0
            END IF

            IF cfg.showTaskbar <> 0 THEN
                IF InRect(smx, smy, START_X1, START_Y1, START_X2, START_Y2) AND curBtn <> 0 THEN
                    startPressed = -1
                ELSE
                    startPressed = 0
                END IF
            ELSE
                startPressed = 0
            END IF

            IF startMenuOpen <> 0 THEN
                IF menuPointerMoved <> 0 OR hoverIdx <> oldHoverIdx OR oldHoverIdx < 0 THEN
                    UpdateStartMenuHoverState hoverIdx, smx, smy, menuStateChanged
                END IF
            END IF

            IF menuPointerMoved <> 0 THEN
                cursorOnlyRedraw = -1
            END IF
            IF hoverIdx <> oldHoverIdx THEN
                IF startMenuOpen <> 0 THEN
                    IF menuStateChanged = 0 AND startMenuBackValid <> 0 AND oldHoverIdx >= 0 THEN
                        menuRowRedraw = -1
                    ELSE
                        menuOnlyRedraw = -1
                    END IF
                ELSE
                    needRedraw = -1
                END IF
            END IF
            IF menuStateChanged <> 0 THEN
                menuRowRedraw = 0
                IF startMenuOpen <> 0 THEN
                    menuOnlyRedraw = -1
                ELSE
                    needRedraw = -1
                END IF
            END IF
            IF startPressed <> oldStartPressed THEN taskbarOnlyRedraw = -1
            ' Do not let the clock timer redraw the taskbar under an open Launch menu.
            ' Leave the clock check untouched until the menu closes, then the next pass
            ' updates the clock without forcing menu-overlay work while hovering.
            IF startMenuOpen = 0 THEN
                IF TaskbarClockNeedsRedrawAt(nowTime) <> 0 THEN
                    taskbarOnlyRedraw = -1
                END IF
            END IF
            IF taskbarOnlyRedrawPending <> 0 THEN taskbarOnlyRedraw = -1

            IF activeFocusTextboxIdx <> 0 THEN
                caretBlinkSelectionActive = 0
                caretBlinkElem = activeFocusTextboxIdx
                IF Ed_SelHas(uiEdit(caretBlinkElem)) <> 0 THEN caretBlinkSelectionActive = -1

                IF nowTime < uiLastCaretBlink THEN uiLastCaretBlink = nowTime
                IF caretBlinkSelectionActive <> 0 THEN
                    ' Keep highlighted text idle without repainting the textbox every blink tick.
                    uiLastCaretBlink = nowTime
                ELSEIF startMenuOpen <> 0 THEN
                    ' Freeze caret blinking behind the Launch menu. Blinking the hidden
                    ' textbox used to force menu-only overlay redraws every timer tick.
                    uiLastCaretBlink = nowTime
                ELSEIF (nowTime - uiLastCaretBlink) >= .5 THEN
                    uiCaretVisible = NOT uiCaretVisible
                    uiLastCaretBlink = nowTime
                    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) AND layoutWindows(activeLayoutWindow).used <> 0 THEN
                        IF caretBlinkElem >= 1 AND caretBlinkElem <= uiCount THEN
                            caretBlinkLine = 0
                            IF TextboxIsMultiline(caretBlinkElem) <> 0 THEN
                                caretBlinkLine = TextboxMetricCaretLine(caretBlinkElem, uiElems(caretBlinkElem).text, uiCaretPos, TextboxCols(caretBlinkElem))
                            END IF
                            IF layoutFastTextboxPending = 0 OR layoutFastTextboxWin <> activeLayoutWindow THEN
                                layoutFastTextboxPending = -1
                                layoutFastTextboxWin = activeLayoutWindow
                                layoutFastTextboxElem = caretBlinkElem
                                layoutFastTextboxLine = caretBlinkLine
                            END IF
                            dirtyElementsOnlyRedraw = -1
                        ELSE
                            layoutOnlyRedraw = -1
                        END IF
                    ELSE
                        needRedraw = -1
                    END IF
                END IF
            ELSE
                IF startMenuOpen <> 0 THEN
                    uiLastCaretBlink = nowTime
                ELSE
                    IF uiCaretVisible = 0 THEN
                        uiCaretVisible = -1
                        IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) AND layoutWindows(activeLayoutWindow).used <> 0 THEN
                            layoutOnlyRedraw = -1
                        ELSE
                            needRedraw = -1
                        END IF
                    END IF
                    uiLastCaretBlink = nowTime
                END IF
            END IF

            ' Keep targeted window redraws from painting over the Launch menu.
            ' Restore the menu backing, redraw only the active window behind it,
            ' then recapture and redraw the menu instead of repainting the whole screen.
            IF startMenuOpen <> 0 THEN
                IF dirtyElementsOnlyRedraw <> 0 OR activeWindowOnlyRedraw <> 0 OR layoutOnlyRedraw <> 0 THEN
                    IF DrawStartMenuProtectedActiveRedraw(hoverIdx, smx, smy, dirtyElementsOnlyRedraw OR activeWindowOnlyRedraw) <> 0 THEN
                        dirtyElementsOnlyRedraw = 0
                        activeWindowOnlyRedraw = 0
                        layoutOnlyRedraw = 0
                        menuOnlyRedraw = 0
                        menuRowRedraw = 0
                        cursorOnlyRedraw = 0
                        oldMx = smx
                        oldMy = smy
                        oldHoverIdx = hoverIdx
                        oldStartPressed = startPressed
                    ELSE
                        needRedraw = -1
                        dirtyElementsOnlyRedraw = 0
                        activeWindowOnlyRedraw = 0
                        layoutOnlyRedraw = 0
                        menuOnlyRedraw = 0
                        menuRowRedraw = 0
                    END IF
                END IF
            END IF

            IF startMenuFastOpenPending <> 0 THEN
                DrawStartMenuOpenOnly hoverIdx, startPressed, smx, smy
                startMenuFastOpenPending = 0
                startMenuFastClosePending = 0
                taskbarOnlyRedraw = 0
                taskbarOnlyRedrawPending = 0
                oldMx = smx
                oldMy = smy
                oldHoverIdx = hoverIdx
                oldStartPressed = startPressed
            ELSEIF startMenuFastClosePending <> 0 THEN
                DrawStartMenuCloseOnly startPressed, smx, smy
                startMenuFastClosePending = 0
                startMenuFastOpenPending = 0
                taskbarOnlyRedraw = 0
                taskbarOnlyRedrawPending = 0
                oldMx = smx
                oldMy = smy
                oldHoverIdx = hoverIdx
                oldStartPressed = startPressed
            ELSEIF contextOverlayFastClosePending <> 0 THEN
                ' Close the overlay directly, then consume the same highest-priority
                ' targeted redraw that would have run without the overlay close.
                ' This avoids escalating the pair into a whole-screen redraw.
                DrawContextOverlayCloseOnly smx, smy
                contextOverlayFastClosePending = 0
                needRedraw = 0
                cursorOnlyRedraw = 0
                IF dirtyElementsOnlyRedraw <> 0 THEN
                    DrawActiveDirtyElementsOnly smx, smy
                    dirtyElementsOnlyRedraw = 0
                    activeWindowOnlyRedraw = 0
                ELSEIF activeWindowOnlyRedraw <> 0 THEN
                    DrawActiveLayoutWindowChangedOnly smx, smy
                    activeWindowOnlyRedraw = 0
                    layoutOnlyRedraw = 0
                ELSEIF layoutOnlyRedraw <> 0 THEN
                    IF activeFocusTextboxIdx <> 0 THEN
                        DrawActiveFocusedTextboxOnly smx, smy
                    ELSE
                        DrawActiveLayoutWindowOnly smx, smy
                    END IF
                    layoutOnlyRedraw = 0
                ELSEIF menuOnlyRedraw <> 0 THEN
                    DrawStartMenuOverlay hoverIdx, smx, smy
                    menuOnlyRedraw = 0
                    menuRowRedraw = 0
                ELSEIF menuRowRedraw <> 0 THEN
                    DrawStartMenuRowsOnly oldHoverIdx, hoverIdx, smx, smy
                    menuRowRedraw = 0
                ELSEIF taskbarOnlyRedraw <> 0 THEN
                    DrawTaskbarOnly startPressed, smx, smy
                    taskbarOnlyRedraw = 0
                    taskbarOnlyRedrawPending = 0
                END IF
                oldMx = smx
                oldMy = smy
                oldHoverIdx = hoverIdx
                oldStartPressed = startPressed
            ELSEIF newLayoutWindowOnlyRedraw <> 0 THEN
                DrawNewLayoutWindowOpenOnly newLayoutWindowRedrawPrevious, newLayoutWindowRedrawMenuOverlay, startPressed, smx, smy
                newLayoutWindowOnlyRedraw = 0
                newLayoutWindowRedrawPrevious = 0
                newLayoutWindowRedrawMenuOverlay = 0
                needRedraw = 0
                cursorOnlyRedraw = 0
                menuOnlyRedraw = 0
                menuRowRedraw = 0
                taskbarOnlyRedraw = 0
                taskbarOnlyRedrawPending = 0
                layoutOnlyRedraw = 0
                activeWindowOnlyRedraw = 0
                dirtyElementsOnlyRedraw = 0
                startMenuFastOpenPending = 0
                startMenuFastClosePending = 0
                contextOverlayFastClosePending = 0
                oldMx = smx
                oldMy = smy
                oldHoverIdx = hoverIdx
                oldStartPressed = startPressed
            ELSEIF needRedraw <> 0 THEN
                SCREENLOCK
                RestoreCursorBackBuffer
                IF dragOutlineActive <> 0 THEN RestoreLayoutDragOutlineBackBuffer
                dragOutlineActive = 0
                DrawDesktop
                IF resizingLayoutWin <> 0 THEN
                    layoutLiveResizeActive = -1
                    layoutLiveResizeWindow = activeLayoutWindow
                ELSE
                    layoutLiveResizeActive = 0
                    layoutLiveResizeWindow = 0
                END IF
                IF draggingLayoutWin <> 0 AND cfg.outlineWindowDrag <> 0 THEN
                    DrawAllLayoutWindowsFastDrag activeLayoutWindow
                ELSE
                    DrawAllLayoutWindows
                END IF
                DrawTaskbar startPressed
                DrawSoundVolumePopup
                IF startMenuOpen THEN
                    CaptureStartMenuBackBuffer 0
                    DrawStartMenu hoverIdx
                END IF
                IF launchCtxOpen <> 0 THEN
                    CaptureContextOverlayBackBuffer launchCtxX, launchCtxY, launchCtxX + LAUNCH_CTX_W, launchCtxY + LAUNCH_CTX_H
                    DrawLaunchMenuContext
                ELSEIF ctxMenuOpen <> 0 THEN
                    CaptureContextOverlayBackBuffer ctxMenuX, ctxMenuY, ctxMenuX + ctxMenuW, ctxMenuY + ctxMenuH
                    DrawSimpleContextMenu ctxMenuX, ctxMenuY, ctxMenuEditEnabled, ctxMenuIsDir, ctxMenuWin, ctxMenuPasteOnly
                ELSEIF desktopCtxOpen <> 0 THEN
                    CaptureContextOverlayBackBuffer desktopCtxX, desktopCtxY, desktopCtxX + DesktopContextWidth(), desktopCtxY + DesktopContextHeight()
                    DrawDesktopContextMenu
                ELSE
                    InvalidateContextOverlayBackBuffer
                END IF
                SaveCursorBackBuffer smx, smy
                DrawCursor smx, smy
                SCREENUNLOCK
                needRedraw = 0
                cursorOnlyRedraw = 0
                menuOnlyRedraw = 0
                menuRowRedraw = 0
                taskbarOnlyRedraw = 0
                taskbarOnlyRedrawPending = 0
                layoutOnlyRedraw = 0
                activeWindowOnlyRedraw = 0
                dirtyElementsOnlyRedraw = 0
                startMenuFastOpenPending = 0
                startMenuFastClosePending = 0
                contextOverlayFastClosePending = 0
                ClearLayoutDirtyElements activeLayoutWindow
                oldMx = smx
                oldMy = smy
                oldHoverIdx = hoverIdx
                oldStartPressed = startPressed
            ELSEIF dirtyElementsOnlyRedraw <> 0 THEN
                ' Known dirty controls can repaint by themselves. This is the fast path
                ' for editor typing and list movement.
                DrawActiveDirtyElementsOnly smx, smy
                dirtyElementsOnlyRedraw = 0
                activeWindowOnlyRedraw = 0
            ELSEIF activeWindowOnlyRedraw <> 0 THEN
                ' Redraw only the active Backlash window for control-only changes.
                ' Keep this flag alive across the loop boundary until this branch consumes it.
                DrawActiveLayoutWindowChangedOnly smx, smy
                activeWindowOnlyRedraw = 0
                layoutOnlyRedraw = 0
                cursorOnlyRedraw = 0
                oldMx = smx
                oldMy = smy
                oldHoverIdx = hoverIdx
                oldStartPressed = startPressed
            ELSEIF layoutOnlyRedraw <> 0 THEN
                IF activeFocusTextboxIdx <> 0 THEN
                    DrawActiveFocusedTextboxOnly smx, smy
                ELSE
                    DrawActiveLayoutWindowOnly smx, smy
                END IF
                layoutOnlyRedraw = 0
                cursorOnlyRedraw = 0
                oldMx = smx
                oldMy = smy
                oldHoverIdx = hoverIdx
                oldStartPressed = startPressed
            ELSEIF menuOnlyRedraw <> 0 THEN
                DrawStartMenuOverlay hoverIdx, smx, smy
                menuOnlyRedraw = 0
                menuRowRedraw = 0
                cursorOnlyRedraw = 0
                oldMx = smx
                oldMy = smy
                oldHoverIdx = hoverIdx
                oldStartPressed = startPressed
            ELSEIF menuRowRedraw <> 0 THEN
                DrawStartMenuRowsOnly oldHoverIdx, hoverIdx, smx, smy
                menuRowRedraw = 0
                cursorOnlyRedraw = 0
                oldMx = smx
                oldMy = smy
                oldHoverIdx = hoverIdx
                oldStartPressed = startPressed
            ELSEIF taskbarOnlyRedraw <> 0 THEN
                DrawTaskbarOnly startPressed, smx, smy
                taskbarOnlyRedraw = 0
                taskbarOnlyRedrawPending = 0
                cursorOnlyRedraw = 0
                oldMx = smx
                oldMy = smy
                oldHoverIdx = hoverIdx
                oldStartPressed = startPressed
            ELSEIF cursorOnlyRedraw <> 0 THEN
                DrawCursorOnly smx, smy
                oldMx = smx
                oldMy = smy
                oldHoverIdx = hoverIdx
                oldStartPressed = startPressed
            END IF

            IF ctxMenuOpen <> 0 AND curBtn <> 0 AND prevBtn = 0 THEN
                DIM ctxClickRow AS INTEGER
                DIM ctxStatusCtrl AS STRING
                DIM ctxStatusSuffix AS STRING
                ctxClickRow = 0
                ctxStatusCtrl = ""
                ctxStatusSuffix = ""

                IF smx >= ctxMenuX AND smx <= ctxMenuX + ctxMenuW AND _
                   smy >= ctxMenuY AND smy <= ctxMenuY + ctxMenuH THEN
                    ctxClickRow = ((smy - ctxMenuY) \ 18) + 1
                    IF ctxClickRow < 1 OR ctxClickRow > ContextMenuRowCount(ctxMenuWin, ctxMenuIsDir, ctxMenuPasteOnly) THEN ctxClickRow = 0

                    IF ctxMenuWin >= LBOUND(layoutWindows) AND ctxMenuWin <= UBOUND(layoutWindows) THEN
                        IF layoutWindows(ctxMenuWin).used <> 0 THEN
                            ActivateLayoutWindow ctxMenuWin
                            ctxStatusCtrl = AppControlNameValue(activeLayoutWindow, "FILE_BROWSER_STATUS_CONTROL", "")
                            ctxStatusSuffix = ""
                            IF ctxStatusCtrl <> "" THEN ctxStatusSuffix = " " + ctxStatusCtrl
                            IF ctxMenuElem >= 1 AND ctxMenuElem <= uiCount THEN
                                IF uiElems(ctxMenuElem).kindId = UI_KIND_LISTBOX THEN
                                    IF ctxMenuPasteOnly <> 0 AND ctxClickRow = 1 THEN
                                        ctxMenuOpen = 0
                                        ' The list/control state was already stored when the menu opened.
                                        ' Do not deep-sync the whole window again just for a menu click.
                                        pasteActionText = AppCfgValue(RTRIM$(layoutWindows(activeLayoutWindow).appPath), "CONTEXT_PASTE_ACTION", "")
                                        IF pasteActionText <> "" THEN HostAppAction activeLayoutWindow, pasteActionText
                                    ELSEIF ctxClickRow > 0 AND RTRIM$(uiElems(ctxMenuElem).text) <> "" THEN
                                        ctxMenuOpen = 0
                                        ' The right-click selection path already saved the current window state.
                                        ' Keep the action fast instead of copying every control again here.
                                        IF ctxMenuIsDir <> 0 THEN
                                            ctxWorkRow = 1
                                            IF ctxClickRow = ctxWorkRow THEN
                                                HostAppAction activeLayoutWindow, "FILE_BROWSER_DIR_OPEN_NEW " + uiElems(ctxMenuElem).name + ctxStatusSuffix
                                            END IF

                                            ctxWorkRow = ctxWorkRow + 1
                                            IF ctxClickRow = ctxWorkRow THEN
                                                HostAppAction activeLayoutWindow, "FILE_BROWSER_DIR_NEW " + uiElems(ctxMenuElem).name + ctxStatusSuffix
                                            END IF

                                            ctxWorkRow = ctxWorkRow + 1
                                            IF TRIM$(AppCfgValue(RTRIM$(layoutWindows(activeLayoutWindow).appPath), "CONTEXT_COPY_TEXT", "")) <> "" THEN
                                                IF ctxClickRow = ctxWorkRow THEN
                                                    HostAppAction activeLayoutWindow, "FILE_BROWSER_DIR_COPY " + uiElems(ctxMenuElem).name + ctxStatusSuffix
                                                END IF
                                                ctxWorkRow = ctxWorkRow + 1
                                            END IF

                                            IF ctxClickRow = ctxWorkRow THEN
                                                HostAppAction activeLayoutWindow, "FILE_BROWSER_FILE_RENAME " + uiElems(ctxMenuElem).name + ctxStatusSuffix
                                            END IF
                                            ctxWorkRow = ctxWorkRow + 1

                                            IF ctxClickRow = ctxWorkRow THEN
                                                IF LEFT$(UCASE$(RTRIM$(uiElems(ctxMenuElem).text)), 5) = "[DIR]" THEN
                                                    HostAppAction activeLayoutWindow, "FILE_BROWSER_FILE_DELETE " + uiElems(ctxMenuElem).name + ctxStatusSuffix
                                                END IF
                                            END IF
                                            ctxWorkRow = ctxWorkRow + 1

                                            IF ctxClickRow = ctxWorkRow THEN
                                                HostAppAction activeLayoutWindow, "FILE_BROWSER_FILE_PROPERTIES " + uiElems(ctxMenuElem).name + ctxStatusSuffix
                                            END IF
                                        ELSE
                                            ctxWorkRow = 1
                                            IF ctxClickRow = ctxWorkRow THEN
                                                AppRuntime_HandleEvent activeLayoutWindow, "DBLCLICK", uiElems(ctxMenuElem).name, uiElems(ctxMenuElem).text, uiElems(ctxMenuElem).action
                                            END IF

                                            ctxWorkRow = ctxWorkRow + 1
                                            IF ctxClickRow = ctxWorkRow AND ctxMenuEditEnabled <> 0 THEN
                                                HostAppAction activeLayoutWindow, "FILE_BROWSER_FILE_EDIT " + uiElems(ctxMenuElem).name + ctxStatusSuffix
                                            END IF

                                            ctxWorkRow = ctxWorkRow + 1
                                            IF TRIM$(AppCfgValue(RTRIM$(layoutWindows(activeLayoutWindow).appPath), "CONTEXT_CUT_TEXT", "")) <> "" THEN
                                                IF ctxClickRow = ctxWorkRow THEN
                                                    cutActionText = AppCfgValue(RTRIM$(layoutWindows(activeLayoutWindow).appPath), "CONTEXT_CUT_ACTION", "")
                                                    IF cutActionText <> "" THEN HostAppAction activeLayoutWindow, cutActionText + " " + uiElems(ctxMenuElem).name + ctxStatusSuffix
                                                END IF
                                                ctxWorkRow = ctxWorkRow + 1
                                            END IF

                                            IF TRIM$(AppCfgValue(RTRIM$(layoutWindows(activeLayoutWindow).appPath), "CONTEXT_COPY_TEXT", "")) <> "" THEN
                                                IF ctxClickRow = ctxWorkRow THEN
                                                    copyActionText = AppCfgValue(RTRIM$(layoutWindows(activeLayoutWindow).appPath), "CONTEXT_COPY_ACTION", "")
                                                    IF copyActionText <> "" THEN HostAppAction activeLayoutWindow, copyActionText + " " + uiElems(ctxMenuElem).name + ctxStatusSuffix
                                                END IF
                                                ctxWorkRow = ctxWorkRow + 1
                                            END IF

                                            IF TRIM$(AppCfgValue(RTRIM$(layoutWindows(activeLayoutWindow).appPath), "CONTEXT_DUPLICATE_TEXT", "")) <> "" THEN
                                                IF ctxClickRow = ctxWorkRow THEN
                                                    duplicateActionText = AppCfgValue(RTRIM$(layoutWindows(activeLayoutWindow).appPath), "CONTEXT_DUPLICATE_ACTION", "")
                                                    IF duplicateActionText <> "" THEN HostAppAction activeLayoutWindow, duplicateActionText + " " + uiElems(ctxMenuElem).name + ctxStatusSuffix
                                                END IF
                                                ctxWorkRow = ctxWorkRow + 1
                                            END IF

                                            IF ctxClickRow = ctxWorkRow THEN
                                                HostAppAction activeLayoutWindow, "FILE_BROWSER_FILE_RENAME " + uiElems(ctxMenuElem).name + ctxStatusSuffix
                                            END IF
                                            ctxWorkRow = ctxWorkRow + 1

                                            IF ctxClickRow = ctxWorkRow THEN
                                                HostAppAction activeLayoutWindow, "FILE_BROWSER_FILE_DELETE " + uiElems(ctxMenuElem).name + ctxStatusSuffix
                                            END IF
                                            ctxWorkRow = ctxWorkRow + 1

                                            IF ctxClickRow = ctxWorkRow THEN
                                                HostAppAction activeLayoutWindow, "FILE_BROWSER_FILE_PROPERTIES " + uiElems(ctxMenuElem).name + ctxStatusSuffix
                                            END IF
                                        END IF
                                    END IF
                                END IF
                            END IF
                        END IF
                    END IF
                END IF
                ctxMenuOpen = 0
                IF ctxClickRow = 0 AND contextOverlayBackValid <> 0 THEN
                    contextOverlayFastClosePending = -1
                ELSE
                    needRedraw = -1
                END IF
                prevBtn = 1
            END IF

            IF rightBtn <> 0 AND prevRightBtn = 0 THEN
                DIM rightHitSlot AS INTEGER
                DIM rightActivePage AS STRING
                DIM rightTabNumber AS INTEGER
                DIM rightHitIndex AS INTEGER
                DIM rightRows AS INTEGER
                DIM rightSelIdx AS INTEGER
                DIM rightTextRight AS INTEGER
                DIM rightItemH AS INTEGER
                DIM rightWinLoop AS INTEGER
                DIM rightContextOverlayClosedFast AS INTEGER
                DIM rightContextOverlayOpenedFast AS INTEGER
                DIM rightHitWasActive AS INTEGER
