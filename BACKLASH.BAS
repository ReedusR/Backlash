                            IF searchStart > LEN(targetText) THEN searchStart = LEN(targetText)

                            foundAt = 0
                            i = INSTR(1, targetCompare, findCompare)
                            DO WHILE i > 0 AND i <= searchStart
                                foundAt = i
                                i = INSTR(i + 1, targetCompare, findCompare)
                            LOOP

                            IF foundAt = 0 THEN
                                i = INSTR(1, targetCompare, findCompare)
                                DO WHILE i > 0
                                    foundAt = i
                                    i = INSTR(i + 1, targetCompare, findCompare)
