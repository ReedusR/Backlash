FUNCTION DrawLaunchButtonBmp(BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER, BYVAL pressed AS INTEGER) AS INTEGER
    DIM ix AS INTEGER
    DIM iy AS INTEGER
    DIM dx AS INTEGER
    DIM dy AS INTEGER
    DIM drawX AS INTEGER
    DIM drawY AS INTEGER
    DIM innerX1 AS INTEGER
    DIM innerY1 AS INTEGER
    DIM innerX2 AS INTEGER
    DIM innerY2 AS INTEGER
    DIM curCol AS UINTEGER
    DIM rr AS INTEGER
    DIM gg AS INTEGER
    DIM bb AS INTEGER
    DIM off AS INTEGER

    IF launchButtonLoaded = 0 OR launchButtonPix = 0 OR launchButtonW <= 0 OR launchButtonH <= 0 THEN RETURN 0

    off = 0
    IF pressed <> 0 THEN off = 1

    innerX1 = x1 + 3
    innerY1 = y1 + 3
    innerX2 = x2 - 3
    innerY2 = y2 - 3

    drawX = innerX1 + ((innerX2 - innerX1 + 1) - launchButtonW) \ 2 + off
    drawY = innerY1 + ((innerY2 - innerY1 + 1) - launchButtonH) \ 2 + off

    IF launchButtonImage <> 0 AND launchButtonHasTrans = 0 AND _
       drawX >= innerX1 AND drawY >= innerY1 AND _
       drawX + launchButtonW - 1 <= innerX2 AND drawY + launchButtonH - 1 <= innerY2 AND _
       drawX >= 0 AND drawY >= 0 AND drawX + launchButtonW - 1 < SCR_W AND drawY + launchButtonH - 1 < SCR_H THEN
        PUT (drawX, drawY), launchButtonImage, PSET
        RETURN -1
    END IF

    FOR iy = 0 TO launchButtonH - 1
        FOR ix = 0 TO launchButtonW - 1
            curCol = launchButtonPix[CLNG(iy) * launchButtonW + ix]
            IF IsTransparentBmpColor(curCol) <> 0 THEN
            ELSE
                dx = drawX + ix
                dy = drawY + iy
                IF dx >= innerX1 AND dx <= innerX2 AND dy >= innerY1 AND dy <= innerY2 AND _
                   dx >= 0 AND dx < SCR_W AND dy >= 0 AND dy < SCR_H THEN
                    PSET (dx, dy), curCol
                END IF
            END IF
        NEXT
    NEXT

    RETURN -1
END FUNCTION

SUB DrawVerticalGradient(BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER, _
                         BYVAL r1 AS INTEGER, BYVAL g1 AS INTEGER, BYVAL b1 AS INTEGER, _
                         BYVAL r2 AS INTEGER, BYVAL g2 AS INTEGER, BYVAL b2 AS INTEGER)
    DIM y AS INTEGER
    DIM h AS INTEGER
    DIM rr AS INTEGER
    DIM gg AS INTEGER
    DIM bb AS INTEGER

    IF x2 < x1 OR y2 < y1 THEN EXIT SUB

    h = y2 - y1
    IF h <= 0 THEN
        LINE (x1, y1)-(x2, y2), MakeCol(r2, g2, b2), BF
        EXIT SUB
    END IF

    FOR y = y1 TO y2
        rr = r1 + (r2 - r1) * (y - y1) \ h
        gg = g1 + (g2 - g1) * (y - y1) \ h
        bb = b1 + (b2 - b1) * (y - y1) \ h
        LINE (x1, y)-(x2, y), MakeCol(rr, gg, bb)
    NEXT
END SUB

' Draws the left strip in the Launch menu behind the startbar bitmap.
SUB DrawStartStripDecor(BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER)
    DIM stripW AS INTEGER
    DIM bmpX AS INTEGER
    DIM bmpY AS INTEGER
    DIM ix AS INTEGER
    DIM iy AS INTEGER
    DIM dx AS INTEGER
    DIM dy AS INTEGER
    DIM curCol AS UINTEGER

    stripW = StartStripSpace()
    IF stripW <= 0 THEN EXIT SUB

    IF cfg.colorDepth <= 8 OR theme.titlebarGradient = 0 THEN
        LINE (x1, y1)-(x1 + stripW - 1, y2), COL_TITLE, BF
    ELSE
        DrawVerticalGradient x1, y1, x1 + stripW - 1, y2, _
            theme.selectR, theme.selectG, theme.selectB, _
            theme.titlebarGradR, theme.titlebarGradG, theme.titlebarGradB
    END IF

    IF startStripLoaded = 0 OR startStripPix = 0 OR startStripW <= 0 OR startStripH <= 0 THEN EXIT SUB

    bmpX = x1
    bmpY = y2 - startStripH + 1 - theme.startStripPadBot + theme.startStripPadTop

    IF startStripImage <> 0 AND startStripHasTrans = 0 AND _
       bmpX >= x1 AND bmpX + startStripW - 1 <= x1 + stripW - 1 AND _
       bmpY >= y1 AND bmpY + startStripH - 1 <= y2 AND _
       bmpX >= 0 AND bmpY >= 0 AND bmpX + startStripW - 1 < SCR_W AND bmpY + startStripH - 1 < SCR_H THEN
        PUT (bmpX, bmpY), startStripImage, PSET
        EXIT SUB
    END IF

    FOR iy = 0 TO startStripH - 1
        FOR ix = 0 TO startStripW - 1
            curCol = startStripPix[CLNG(iy) * startStripW + ix]
            IF IsTransparentBmpColor(curCol) <> 0 THEN
            ELSE
                dx = bmpX + ix
                dy = bmpY + iy
                IF dx >= x1 AND dx <= x1 + stripW - 1 AND dx >= 0 AND dx < SCR_W AND dy >= y1 AND dy <= y2 AND dy >= 0 AND dy < SCR_H THEN
                    PSET (dx, dy), curCol
                END IF
            END IF
        NEXT
    NEXT
END SUB

