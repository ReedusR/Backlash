                                targetCompare = UCASE$(targetText)
                                findCompare = UCASE$(findText)
                            ELSE
                                targetCompare = targetText
                                findCompare = findText
                            END IF

                            ' Search backward from the current match start, then wrap to the end.
                            searchStart = uiEdit(uiFocusIndex).curPos
                            IF Ed_SelHas(uiEdit(uiFocusIndex)) <> 0 THEN
                                Ed_SelNorm uiEdit(uiFocusIndex), selA, selB
                                searchStart = selA
