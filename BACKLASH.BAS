SUB ResumeGuiAfterScreensaver()
    DIM savedActive AS INTEGER
    DIM savedZ(1 TO 12) AS INTEGER
    DIM i AS INTEGER
    DIM z AS INTEGER
    DIM slotIdx AS INTEGER
    DIM present AS INTEGER
    DIM probe AS INTEGER
    DIM topVisibleSlot AS INTEGER

    BDbgTrace "RESUME_SCREENSAVER_BEGIN"
    savedActive = activeLayoutWindow
    FOR i = 1 TO 12
        savedZ(i) = layoutZOrder(i)
    NEXT

    IF activeLayoutWindow >= 1 AND activeLayoutWindow <= 12 THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN SyncLayoutWindowFromGlobals activeLayoutWindow
    END IF

    LoadAllConfig
    InitGUI

    IF bgCache = 0 THEN
        IF wallLoaded = 0 AND theme.wallpaperPath <> "" THEN LoadWallpaper
        BuildBackgroundCache
    END IF

    IF startStripLoaded = 0 AND theme.startStripPath <> "" THEN LoadStartStrip
    IF launchButtonLoaded = 0 THEN LoadLaunchButtonBmp
    IF menuCount <= 0 THEN LoadStartMenu PATH_STRTMENU
    IF iconCount <= 0 THEN
        LoadDesktopIcons PATH_DESKTOPTXT
        IF cfg.snapIcons <> 0 THEN SnapAllIcons
        LoadAllIcons
    END IF

    FOR z = 1 TO 12
        layoutZOrder(z) = 0
    NEXT

    z = 1
    FOR i = 1 TO 12
        slotIdx = savedZ(i)
        IF slotIdx >= 1 AND slotIdx <= 12 THEN
            IF layoutWindows(slotIdx).used <> 0 THEN
                present = 0
                FOR probe = 1 TO 12
                    IF layoutZOrder(probe) = slotIdx THEN
                        present = -1
                        EXIT FOR
                    END IF
                NEXT
                IF present = 0 AND z <= 12 THEN
                    layoutZOrder(z) = slotIdx
                    z = z + 1
                END IF
            END IF
        END IF
    NEXT

    FOR i = 1 TO 12
        IF layoutWindows(i).used <> 0 THEN
            present = 0
            FOR probe = 1 TO 12
                IF layoutZOrder(probe) = i THEN
                    present = -1
                    EXIT FOR
                END IF
            NEXT
            IF present = 0 AND z <= 12 THEN
                layoutZOrder(z) = i
                z = z + 1
            END IF
        END IF
    NEXT

    layoutWindowCount = 0
    FOR i = 1 TO 12
        IF layoutWindows(i).used <> 0 THEN layoutWindowCount = layoutWindowCount + 1
    NEXT

    activeLayoutWindow = 0
    IF savedActive >= 1 AND savedActive <= 12 THEN
        IF layoutWindows(savedActive).used <> 0 AND layoutWindows(savedActive).minimized = 0 THEN activeLayoutWindow = savedActive
    END IF

    topVisibleSlot = 0
    FOR z = 12 TO 1 STEP -1
        slotIdx = layoutZOrder(z)
        IF slotIdx >= 1 AND slotIdx <= 12 THEN
            IF layoutWindows(slotIdx).used <> 0 AND layoutWindows(slotIdx).minimized = 0 THEN
                topVisibleSlot = slotIdx
                EXIT FOR
            END IF
        END IF
    NEXT

    IF activeLayoutWindow = 0 THEN activeLayoutWindow = topVisibleSlot

    uiWindowActive = 0
    uiPressedIndex = 0
    uiFocusIndex = 0
    uiCaretPos = 0

    FOR i = 1 TO 12
        IF layoutWindows(i).used <> 0 THEN
            IF i = activeLayoutWindow THEN
                layoutWindows(i).active = -1
            ELSE
                layoutWindows(i).active = 0
            END IF
            layoutWindows(i).pressedIndex = 0
            layoutWindows(i).focusIndex = 0
            layoutWindows(i).caretPos = 0
            comboOpenIndex(i) = 0
        END IF
    NEXT

    IF activeLayoutWindow >= 1 AND activeLayoutWindow <= 12 THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
            SyncGlobalsFromLayoutWindow activeLayoutWindow
        END IF
    END IF

    drawLayoutWindow = 0
    cursorBackValid = 0
    InvalidateDesktopCache
    InvalidateTaskbarCache
    InvalidateGradientCaches
    ApplyBacklash256Palette
    BDbgTrace "RESUME_SCREENSAVER_DONE"
END SUB


