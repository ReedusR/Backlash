                        hitMinRight = layoutWindows(hitSlot).x + layoutWindows(hitSlot).w - 39
                    ELSE
                        hitMinLeft = layoutWindows(hitSlot).x + layoutWindows(hitSlot).w - 37
                        hitMinRight = layoutWindows(hitSlot).x + layoutWindows(hitSlot).w - 21
                    END IF

