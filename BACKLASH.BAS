                        mouseDownY = -1000
                        uiPressedIndex = 0
                        IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
                            IF layoutWindows(activeLayoutWindow).used <> 0 THEN
                                layoutWindows(activeLayoutWindow).pressedIndex = 0
                            END IF
                        END IF
                        needRedraw = -1
                        oldMx = -1
                        oldMy = -1
                        oldHoverIdx = -1
                        oldStartPressed = -1
                        IF layoutWindowCount = 0 THEN EXIT DO
                    ELSE
                        IF activeLayoutWindow <> hitSlot OR layoutWindows(hitSlot).active = 0 THEN
                            ActivateLayoutWindow hitSlot
                            needRedraw = -1
                            oldMx = -1
                            oldMy = -1
                            oldHoverIdx = -1
                            oldStartPressed = -1
                        ELSE
                            SyncGlobalsFromLayoutWindow activeLayoutWindow
                        END IF
                    END IF
                END IF


                IF layoutCloseClickConsumed = 0 THEN
                mouseDownX = smx
                mouseDownY = smy
                mouseDownCtrl = 0
                mouseDownShift = 0
                IF (MULTIKEY(29) OR MULTIKEY(157)) THEN mouseDownCtrl = -1
                IF (MULTIKEY(42) OR MULTIKEY(54)) THEN mouseDownShift = -1
                mouseDownIcon = 0

                IF hitSlot = activeLayoutWindow AND hitSlot <> 0 THEN
                    IF uiWindowActive = 0 THEN
                        uiWindowActive = -1
                        SyncLayoutWindowFocusOnly activeLayoutWindow
                        activeWindowOnlyRedraw = -1
                        oldMx = -1
                        oldMy = -1
                        oldHoverIdx = -1
                        oldStartPressed = -1
                    END IF
                ELSEIF clickStartButton = 0 AND clickMenuArea = 0 THEN
                    IF uiWindowActive <> 0 OR uiFocusIndex <> 0 THEN
                        uiWindowActive = 0
                        uiFocusIndex = 0
                        IF activeLayoutWindow >= 1 AND activeLayoutWindow <= 12 THEN
                            IF layoutWindows(activeLayoutWindow).used <> 0 THEN
                                layoutWindows(activeLayoutWindow).focusIndex = 0
                            END IF
                        END IF
                        SyncLayoutWindowFocusOnly activeLayoutWindow
                        activeWindowOnlyRedraw = -1
                        oldMx = -1
                        oldMy = -1
                        oldHoverIdx = -1
                        oldStartPressed = -1
                    END IF
                END IF

                IF clickStartButton <> 0 THEN
                    draggingLayoutWin = 0
                    uiPressedIndex = 0
            
                ELSEIF clickMenuArea <> 0 THEN
                    draggingLayoutWin = 0
                    uiPressedIndex = 0
            
                ELSEIF startMenuOpen <> 0 THEN
                    draggingLayoutWin = 0
                    uiPressedIndex = 0
                    uiFocusIndex = 0
                    appViewDragElem = 0
                    appViewDragButton = 0
                    appViewLastX = -1000
                    appViewLastY = -1000

                ELSEIF hitSlot = 0 THEN
                    draggingLayoutWin = 0
                    uiPressedIndex = 0
                    uiFocusIndex = 0
                    IF activeLayoutWindow >= 1 AND activeLayoutWindow <= 12 THEN
                        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
                            layoutWindows(activeLayoutWindow).focusIndex = 0
                        END IF
                    END IF
                    IF smx >= WORK_X AND smx <= WORK_RIGHT AND smy >= WORK_Y AND smy <= WORK_BOTTOM THEN
                        mouseDownIcon = IconFromPoint(smx, smy)
                    ELSE
                        mouseDownIcon = 0
                    END IF
                    IF mouseDownIcon > 0 THEN
                        IF selectedIcon <> mouseDownIcon THEN
                            selectedIcon = mouseDownIcon
                            needRedraw = -1
                        END IF
                        mouseDownIconX = desktopIcons(mouseDownIcon).x
                        mouseDownIconY = desktopIcons(mouseDownIcon).y
                        dragMoved = 0
                                    END IF

                ELSEIF hitSlot = activeLayoutWindow THEN
                    GetLayoutContentExtents contentWLoop, contBottomLoop
                    GetLayoutScrollMetricsFromContent contentWLoop, contBottomLoop, showHScrollLoop, showVScrollLoop, clientWLoop, clientHtLoop, maxScrlXLoop, maxScrlLoop
                    contentRightLoop = LayoutVisibleClientRight(showVScrollLoop)
                    sbLeftLoop = uiWinX + uiWinW - 14
                    sbRightLoop = uiWinX + uiWinW - 2
                    trackTopLoop = uiWinY + 19
                    trackBottomLoop = LayoutVisibleClientBottom(showHScrollLoop)
                    trackHtLoop = trackBottomLoop - trackTopLoop + 1
                    IF trackHtLoop < 1 THEN trackHtLoop = 1
                    thumbHtLoop = CalcScrollThumbSize(clientHtLoop, contBottomLoop, trackHtLoop, 16)
                    thumbTopLoop = CalcScrollThumbTop(uiScrollY, maxScrlLoop, trackTopLoop, trackHtLoop, thumbHtLoop)
                    thumbBottomLoop = thumbTopLoop + thumbHtLoop - 1
                    hTrackLeftLoop = uiWinX + 2
                    hTrackRightLoop = contentRightLoop
                    hTrackWLoop = hTrackRightLoop - hTrackLeftLoop + 1
                    IF hTrackWLoop < 1 THEN hTrackWLoop = 1
                    hThumbWLoop = CalcScrollThumbSize(clientWLoop, contentWLoop, hTrackWLoop, 16)
                    hThumbLeftLoop = CalcScrollThumbTop(uiScrollX, maxScrlXLoop, hTrackLeftLoop, hTrackWLoop, hThumbWLoop)
                    hThumbRightLoop = hThumbLeftLoop + hThumbWLoop - 1

                    IF showVScrollLoop <> 0 AND smx >= sbLeftLoop AND smx <= sbRightLoop AND _
                       smy >= trackTopLoop AND smy <= trackBottomLoop THEN
                        uiPressedIndex = 0
                        IF smy >= thumbTopLoop AND smy <= thumbBottomLoop THEN
                            draggingVScroll = -1
                            vScrollDragOffY = smy - thumbTopLoop
                        ELSE
                            IF smy < thumbTopLoop THEN
                                uiScrollY = ClampScrollPos(uiScrollY - clientHtLoop, maxScrlLoop)
                            ELSE
                                uiScrollY = ClampScrollPos(uiScrollY + clientHtLoop, maxScrlLoop)
                            END IF
                            SyncLayoutWindowScrollOnly activeLayoutWindow
                        END IF
                    ELSEIF showHScrollLoop <> 0 AND smx >= hTrackLeftLoop AND smx <= hTrackRightLoop AND _
                           smy >= uiWinY + uiWinH - 14 AND smy <= uiWinY + uiWinH - 2 THEN
                        uiPressedIndex = 0
                        IF smx >= hThumbLeftLoop AND smx <= hThumbRightLoop THEN
                            draggingHScroll = -1
                            hScrollDragOffX = smx - hThumbLeftLoop
                        ELSE
                            IF smx < hThumbLeftLoop THEN
                                uiScrollX = ClampScrollPos(uiScrollX - clientWLoop, maxScrlXLoop)
                            ELSE
                                uiScrollX = ClampScrollPos(uiScrollX + clientWLoop, maxScrlXLoop)
                            END IF
                            SyncLayoutWindowScrollOnly activeLayoutWindow
                        END IF
                    ELSEIF uiResizable <> 0 AND layoutWindows(activeLayoutWindow).maximized = 0 AND smx >= uiWinX + uiWinW - 14 AND smx <= uiWinX + uiWinW - 2 AND _
                           smy >= uiWinY + uiWinH - 14 AND smy <= uiWinY + uiWinH - 2 THEN
                        resizingLayoutWin = -1
                        layoutResizeMode = 3
                        layoutResizeStartX = smx
                        layoutResizeStartY = smy
                        layoutResizeStartW = uiWinW
                        layoutResizeStartH = uiWinH
                    ELSEIF uiResizable <> 0 AND layoutWindows(activeLayoutWindow).maximized = 0 AND smx >= uiWinX + uiWinW - 3 AND smx <= uiWinX + uiWinW - 1 AND _
                           smy >= uiWinY + 19 AND smy <= uiWinY + uiWinH - 15 THEN
                        resizingLayoutWin = -1
                        layoutResizeMode = 1
                        layoutResizeStartX = smx
                        layoutResizeStartY = smy
                        layoutResizeStartW = uiWinW
                        layoutResizeStartH = uiWinH
                    ELSEIF uiResizable <> 0 AND layoutWindows(activeLayoutWindow).maximized = 0 AND smx >= uiWinX AND smx <= uiWinX + uiWinW - 15 AND _
                           smy >= uiWinY + uiWinH - 3 AND smy <= uiWinY + uiWinH - 1 THEN
                        resizingLayoutWin = -1
                        layoutResizeMode = 2
                        layoutResizeStartX = smx
                        layoutResizeStartY = smy
                        layoutResizeStartW = uiWinW
                        layoutResizeStartH = uiWinH
                    ELSEIF layoutWindows(activeLayoutWindow).maximized = 0 AND smx >= uiWinX AND smx <= uiWinX + uiWinW AND _
                           smy >= uiWinY AND smy <= uiWinY + 18 THEN
                        draggingLayoutWin = -1
                        layoutDragOffX = smx - uiWinX
                        layoutDragOffY = smy - uiWinY
                        dragOutlineActive = 0
                    END IF

                ELSE
                    draggingLayoutWin = 0
                    uiPressedIndex = 0
                END IF

                activePage = ""
                tabNumber = 0
                FOR i = 1 TO uiCount
                    IF uiElems(i).kindId = UI_KIND_TAB THEN
                        tabNumber = tabNumber + 1
                        IF tabNumber = uiSelectedTab THEN
                            activePage = UCASE$(uiElems(i).text)
                            EXIT FOR
                        END IF
                    END IF
                NEXT
                IF activePage = "" THEN
                    FOR i = 1 TO uiCount
                        IF uiElems(i).kindId = UI_KIND_TAB THEN
                            activePage = UCASE$(uiElems(i).text)
                            EXIT FOR
                        END IF
                    NEXT
                END IF

                hitIndex = 0
                showVScrollLoop = 0
                IF uiResizable <> 0 AND maxScrlLoop > 0 THEN showVScrollLoop = -1

                FOR i = 1 TO uiCount
                    ex = uiWinX + uiElems(i).x - uiScrollX
                    ey = uiWinY + 22 + uiElems(i).y - uiScrollY
                    ew = uiElems(i).w
                    eh = uiElems(i).h

                    IF uiElems(i).kindId = UI_KIND_BUTTON OR uiElems(i).kindId = UI_KIND_COMBO OR uiElems(i).kindId = UI_KIND_TEXTBOX OR uiElems(i).kindId = UI_KIND_LISTBOX OR uiElems(i).kindId = UI_KIND_SPLITTER OR uiElems(i).kindId = UI_KIND_APPVIEW OR uiElems(i).kindId = UI_KIND_CANVAS THEN
                        IF ew <= 0 THEN
                            IF uiElems(i).kindId = UI_KIND_COMBO OR uiElems(i).kindId = UI_KIND_TEXTBOX OR uiElems(i).kindId = UI_KIND_LISTBOX OR uiElems(i).kindId = UI_KIND_SPLITTER OR uiElems(i).kindId = UI_KIND_APPVIEW OR uiElems(i).kindId = UI_KIND_CANVAS THEN
                                ew = 120
                            ELSE
                                ew = LEN(uiElems(i).text) * 8 + 20
                            END IF
                        END IF
                        IF eh <= 0 THEN
                            IF uiElems(i).kindId = UI_KIND_LISTBOX OR uiElems(i).kindId = UI_KIND_APPVIEW OR uiElems(i).kindId = UI_KIND_CANVAS THEN
                                eh = 100
                            ELSE
                                eh = 22
                            END IF
                        END IF
                    END IF

                    IF uiElems(i).kindId = UI_KIND_TAB THEN
                        IF RectIntersectsClip(ex, ey, ex + ew, ey + eh, uiWinX + 2, uiWinY + 19, contentRightLoop, LayoutVisibleClientBottom(showHScrollLoop)) <> 0 THEN
                            IF PointInControlClip(smx, smy, ex, ey, ex + ew, ey + eh, uiWinX + 2, uiWinY + 19, contentRightLoop, LayoutVisibleClientBottom(showHScrollLoop)) <> 0 THEN
                                hitIndex = i
                                EXIT FOR
                            END IF
                        END IF
                    ELSE
                        IF uiElems(i).page = "" OR uiElems(i).pageKey = activePage THEN
                            IF uiElems(i).kindId = UI_KIND_RADIO OR uiElems(i).kindId = UI_KIND_CHECKBOX THEN
                                ew = 18 + LEN(uiElems(i).text) * 8
                                IF eh <= 0 THEN eh = 16
                            END IF

                            IF uiElems(i).kindId = UI_KIND_BUTTON OR uiElems(i).kindId = UI_KIND_RADIO OR uiElems(i).kindId = UI_KIND_CHECKBOX OR _
                               uiElems(i).kindId = UI_KIND_TEXTBOX OR uiElems(i).kindId = UI_KIND_LISTBOX OR uiElems(i).kindId = UI_KIND_SPLITTER OR uiElems(i).kindId = UI_KIND_APPVIEW OR uiElems(i).kindId = UI_KIND_CANVAS THEN
                                IF RectIntersectsClip(ex, ey, ex + ew, ey + eh, uiWinX + 2, uiWinY + 19, contentRightLoop, LayoutVisibleClientBottom(showHScrollLoop)) <> 0 THEN
                                    IF PointInControlClip(smx, smy, ex, ey, ex + ew, ey + eh, uiWinX + 2, uiWinY + 19, contentRightLoop, LayoutVisibleClientBottom(showHScrollLoop)) <> 0 THEN
                                        hitIndex = i
                                        EXIT FOR
                                    END IF
                                END IF
                            ELSEIF uiElems(i).kindId = UI_KIND_COMBO THEN
                                IF RectIntersectsClip(ex, ey, ex + ew, ey + eh, uiWinX + 2, uiWinY + 19, contentRightLoop, LayoutVisibleClientBottom(showHScrollLoop)) <> 0 THEN
                                    IF PointInControlClip(smx, smy, ex, ey, ex + ew, ey + eh, uiWinX + 2, uiWinY + 19, contentRightLoop, LayoutVisibleClientBottom(showHScrollLoop)) <> 0 THEN
                                        hitIndex = i
                                        EXIT FOR
                                    END IF
                                END IF
                                IF activeLayoutWindow >= 1 AND activeLayoutWindow <= 12 THEN
                                    IF comboOpenIndex(activeLayoutWindow) = i THEN
                                        listItemCount = ComboFastItemCount(i, listCacheSlot)
                                        comboRowsLoop = EffectiveComboRows(i, ex, ey, ew, eh)
                                        IF listItemCount < comboRowsLoop THEN comboRowsLoop = listItemCount
                                        IF comboRowsLoop < 1 THEN comboRowsLoop = 1
                                        comboItemHLoop = 16
                                        comboHitTop = ey + eh
                                        IF listCacheSlot > 0 THEN
                                            comboHitBottom = comboHitTop + ComboCachedPopupVisibleHeight(listCacheSlot, comboScrollTop(activeLayoutWindow, i), comboRowsLoop)
                                        ELSE
                                            comboHitBottom = comboHitTop + ComboPopupVisibleHeight(comboScrollTop(activeLayoutWindow, i), comboRowsLoop)
                                        END IF
                                        comboPopupWLoop = ComboPopupWidth(i, ew)
                                        IF ex + comboPopupWLoop > contentRightLoop THEN comboPopupWLoop = contentRightLoop - ex
                                        IF comboPopupWLoop < ew THEN comboPopupWLoop = ew
                                        IF smx >= ex AND smx <= ex + comboPopupWLoop AND smy >= comboHitTop AND smy <= comboHitBottom THEN
                                            hitIndex = i
                                            EXIT FOR
                                        END IF
                                    END IF
                                END IF
                            END IF
                        END IF
                    END IF
                NEXT

                IF hitIndex = 0 THEN
                    IF activeLayoutWindow >= 1 AND activeLayoutWindow <= 12 THEN
                        IF comboOpenIndex(activeLayoutWindow) <> 0 THEN
                            comboOpenIndex(activeLayoutWindow) = 0
                                            END IF
                    END IF
                END IF

                IF hitIndex > 0 THEN
                    IF uiElems(hitIndex).kindId = UI_KIND_COMBO THEN
                        IF activeLayoutWindow >= 1 AND activeLayoutWindow <= 12 THEN
                            IF comboOpenIndex(activeLayoutWindow) = hitIndex THEN
                                ex = uiWinX + uiElems(hitIndex).x - uiScrollX
                                ey = uiWinY + 22 + uiElems(hitIndex).y - uiScrollY
                                ew = uiElems(hitIndex).w
                                eh = uiElems(hitIndex).h
                                IF ew <= 0 THEN ew = 120
                                IF eh <= 0 THEN eh = 22
                                listItemCount = ComboFastItemCount(hitIndex, listCacheSlot)
                                comboRowsLoop = EffectiveComboRows(hitIndex, ex, ey, ew, eh)
                                IF listItemCount < comboRowsLoop THEN comboRowsLoop = listItemCount
                                IF comboRowsLoop < 1 THEN comboRowsLoop = 1
                                comboItemHLoop = 16
                                showComboScroll = 0
                                IF listItemCount > comboRowsLoop THEN showComboScroll = -1
                                IF showComboScroll <> 0 THEN
                                    comboHitTop = ey + eh
                                    IF listCacheSlot > 0 THEN
                                        comboHitBottom = comboHitTop + ComboCachedPopupVisibleHeight(listCacheSlot, comboScrollTop(activeLayoutWindow, hitIndex), comboRowsLoop)
                                    ELSE
                                        comboHitBottom = comboHitTop + ComboPopupVisibleHeight(comboScrollTop(activeLayoutWindow, hitIndex), comboRowsLoop)
                                    END IF
                                    comboPopupWLoop = ComboPopupWidth(hitIndex, ew)
                                    IF ex + comboPopupWLoop > contentRightLoop THEN comboPopupWLoop = contentRightLoop - ex
                                    IF comboPopupWLoop < ew THEN comboPopupWLoop = ew
                                    comboScrollLeft = ex + comboPopupWLoop - 14
                                    IF smx >= comboScrollLeft AND smx <= ex + comboPopupWLoop AND smy >= comboHitTop AND smy <= comboHitBottom THEN
                                        comboTrackTop = comboHitTop + 3
                                        comboTrackBottom = comboHitBottom - 3
                                        comboTrackH = comboTrackBottom - comboTrackTop + 1
                                        comboThumbH = CalcScrollThumbSize(comboRowsLoop, listItemCount, comboTrackH, 12)
                                        newTopIdx = ClampScrollPos(comboScrollTop(activeLayoutWindow, hitIndex), listItemCount - comboRowsLoop)
                                        comboThumbTop = CalcScrollThumbTop(newTopIdx, listItemCount - comboRowsLoop, comboTrackTop, comboTrackH, comboThumbH)
                                        comboThumbBottom = comboThumbTop + comboThumbH - 1
                                        IF smy >= comboThumbTop AND smy <= comboThumbBottom THEN
                                            draggingComboScroll = -1
                                            comboScrollDragElem = hitIndex
                                            comboScrollDragOffY = smy - comboThumbTop
                                        END IF
                                    END IF
                                END IF
                            END IF
                        END IF
                    ELSEIF uiElems(hitIndex).kindId = UI_KIND_LISTBOX THEN
                        ex = uiWinX + uiElems(hitIndex).x - uiScrollX
                        ey = uiWinY + 22 + uiElems(hitIndex).y - uiScrollY
                        ew = uiElems(hitIndex).w
                        eh = uiElems(hitIndex).h
                        IF ew <= 0 THEN ew = 120
                        IF eh <= 0 THEN eh = 100
                        listItemCount = ComboFastItemCount(hitIndex, listCacheSlot)
                        comboItemHLoop = 16
                        comboRowsLoop = (eh - 4) \ comboItemHLoop
                        IF comboRowsLoop < 1 THEN comboRowsLoop = 1
                        showComboScroll = 0
                        IF listItemCount > comboRowsLoop THEN showComboScroll = -1
                        IF showComboScroll <> 0 THEN
                            comboScrollLeft = ex + ew - 14
                            IF smx >= comboScrollLeft AND smx <= ex + ew - 2 AND smy >= ey + 2 AND smy <= ey + eh - 2 THEN
                                comboTrackTop = ey + 3
                                comboTrackBottom = ey + eh - 3
                                comboTrackH = comboTrackBottom - comboTrackTop + 1
                                comboThumbH = CalcScrollThumbSize(comboRowsLoop, listItemCount, comboTrackH, 12)
                                newTopIdx = ClampScrollPos(comboScrollTop(activeLayoutWindow, hitIndex), listItemCount - comboRowsLoop)
                                comboThumbTop = CalcScrollThumbTop(newTopIdx, listItemCount - comboRowsLoop, comboTrackTop, comboTrackH, comboThumbH)
                                comboThumbBottom = comboThumbTop + comboThumbH - 1
                                listTopKey = newTopIdx
                                IF smy < comboThumbTop THEN
                                    listTopKey = ClampScrollPos(newTopIdx - comboRowsLoop, listItemCount - comboRowsLoop)
                                ELSEIF smy > comboThumbBottom THEN
                                    listTopKey = ClampScrollPos(newTopIdx + comboRowsLoop, listItemCount - comboRowsLoop)
                                ELSE
                                    draggingListScroll = -1
                                    listScrollDragElem = hitIndex
                                    listScrollDragOffY = smy - comboThumbTop
                                END IF
                                IF draggingListScroll = 0 AND listTopKey <> newTopIdx THEN
                                    comboScrollTop(activeLayoutWindow, hitIndex) = listTopKey
                                    MarkLayoutDirtyElement activeLayoutWindow, hitIndex
                                    dirtyElementsOnlyRedraw = -1
                                END IF
                            END IF
                        END IF
                    END IF
                END IF


                IF draggingComboScroll <> 0 OR draggingListScroll <> 0 OR draggingSplitter <> 0 THEN
                    uiPressedIndex = 0
                ELSE
                    uiPressedIndex = hitIndex
                END IF

                fileDragCandidateWin = 0
                fileDragCandidateElem = 0
                fileDragCandidateValue = ""
                fileDragCandidateList = ""
                fileDragActive = 0
                IF hitIndex > 0 THEN
                    IF uiElems(hitIndex).kindId = UI_KIND_LISTBOX THEN
                        IF uiElems(hitIndex).sourceKindId = UI_SOURCE_FILES OR uiElems(hitIndex).sourceKindId = UI_SOURCE_DIRS THEN
                            fileDragCandidateValue = ActiveLayoutListBoxItemValueAtPoint(hitIndex, smx, smy)
                            IF LEFT$(UCASE$(fileDragCandidateValue), 2) = "F:" OR LEFT$(UCASE$(fileDragCandidateValue), 2) = "D:" THEN
                                fileDragCandidateWin = activeLayoutWindow
                                fileDragCandidateElem = hitIndex
                            END IF
                        END IF
                    END IF
                END IF

                IF hitIndex > 0 THEN

                    IF uiElems(hitIndex).kindId = UI_KIND_SPLITTER THEN
                        draggingSplitter = -1
                        splitterDragElem = hitIndex
                        splitterDragOffX = smx - (uiWinX + uiElems(hitIndex).x)
                        uiPressedIndex = 0
                        uiFocusIndex = 0
                    END IF

                    IF uiElems(hitIndex).kindId = UI_KIND_APPVIEW THEN
                        appViewDragElem = hitIndex
                        appViewDragButton = 1
                        appViewLastX = smx
                        appViewLastY = smy
                        uiFocusIndex = hitIndex
                        DispatchAppViewMouseEvent hitIndex, "LEFT_DOWN", smx, smy, 1
                        IF appViewTool(activeLayoutWindow) < 2 OR appViewTool(activeLayoutWindow) > 4 THEN
                            MarkLayoutDirtyElement activeLayoutWindow, hitIndex
                            dirtyElementsOnlyRedraw = -1
                        END IF
                    END IF

                    IF uiElems(hitIndex).kindId = UI_KIND_TEXTBOX AND uiElems(hitIndex).noEdit = 0 THEN
                        DIM tbColsClick AS INTEGER
                        DIM tbRowsClick AS INTEGER
                        DIM tbColClick AS INTEGER
                        DIM tbRowClick AS INTEGER
                        DIM tbFirstLineClick AS INTEGER
                        DIM tbCaretLineClick AS INTEGER
                        DIM tbStartPosClick AS INTEGER
                        DIM tbLineCountClick AS INTEGER
                        DIM tbMaxTopClick AS INTEGER
                        DIM tbScrollLeftClick AS INTEGER
                        DIM tbScrollHandledClick AS INTEGER
                        DIM tbTrackTopClick AS INTEGER
                        DIM tbTrackBottomClick AS INTEGER
                        DIM tbTrackHClick AS INTEGER
                        DIM tbThumbHClick AS INTEGER
                        DIM tbThumbTopClick AS INTEGER
                        DIM tbThumbBottomClick AS INTEGER
                        DIM tbNewTopClick AS INTEGER

                        tbScrollHandledClick = 0

                        ex = uiWinX + uiElems(hitIndex).x - uiScrollX
                        ey = uiWinY + 22 + uiElems(hitIndex).y - uiScrollY
                        ew = uiElems(hitIndex).w
                        eh = uiElems(hitIndex).h
                        IF ew <= 0 THEN ew = 120
                        IF eh <= 0 THEN eh = 22

                        tbRowsClick = TextboxRows(hitIndex)
                        tbLineCountClick = TextboxDisplayLineCount(hitIndex, uiElems(hitIndex).text)
                        tbMaxTopClick = tbLineCountClick - tbRowsClick
                        IF tbMaxTopClick < 0 THEN tbMaxTopClick = 0

                        IF TextboxIsMultiline(hitIndex) <> 0 AND tbMaxTopClick > 0 THEN
                            tbScrollLeftClick = ex + ew - 14
                            IF smx >= tbScrollLeftClick AND smx <= ex + ew - 2 AND smy >= ey + 2 AND smy <= ey + eh - 2 THEN
                                tbTrackTopClick = ey + 3
                                tbTrackBottomClick = ey + eh - 3
                                tbTrackHClick = tbTrackBottomClick - tbTrackTopClick + 1
                                IF tbTrackHClick < 1 THEN tbTrackHClick = 1
                                tbThumbHClick = CalcScrollThumbSize(tbRowsClick, tbLineCountClick, tbTrackHClick, 12)
                                tbFirstLineClick = ClampScrollPos(comboScrollTop(activeLayoutWindow, hitIndex), tbMaxTopClick)
                                tbThumbTopClick = CalcScrollThumbTop(tbFirstLineClick, tbMaxTopClick, tbTrackTopClick, tbTrackHClick, tbThumbHClick)
                                tbThumbBottomClick = tbThumbTopClick + tbThumbHClick - 1
                                tbNewTopClick = tbFirstLineClick
                                IF smy < tbThumbTopClick THEN
                                    tbNewTopClick = ClampScrollPos(tbFirstLineClick - tbRowsClick, tbMaxTopClick)
                                ELSEIF smy > tbThumbBottomClick THEN
                                    tbNewTopClick = ClampScrollPos(tbFirstLineClick + tbRowsClick, tbMaxTopClick)
                                ELSE
                                    draggingTextScroll = -1
                                    textScrollDragElem = hitIndex
                                    textScrollDragOffY = smy - tbThumbTopClick
                                END IF
                                IF draggingTextScroll = 0 AND tbNewTopClick <> tbFirstLineClick THEN
                                    comboScrollTop(activeLayoutWindow, hitIndex) = tbNewTopClick
                                    MarkLayoutDirtyElement activeLayoutWindow, hitIndex
                                    dirtyElementsOnlyRedraw = -1
                                END IF
                                tbScrollHandledClick = -1
                                uiPressedIndex = 0
                            END IF
                        END IF

                        IF tbScrollHandledClick = 0 THEN
                        uiFocusIndex = hitIndex
                        uiCaretVisible = -1
                        uiLastCaretBlink = nowTime

                        tbColsClick = TextboxCols(hitIndex)
                        IF TextboxIsMultiline(hitIndex) <> 0 THEN
                            uiCaretPos = TextboxPosFromPoint(hitIndex, uiElems(hitIndex).text, smx - (ex + 4), smy - (ey + 4))
                        ELSE
                            uiCaretPos = Ed_MouseClickPos(uiElems(hitIndex).text, uiCaretPos, tbColsClick, tbRowsClick, TextboxIsMultiline(hitIndex), smx - (ex + 4), smy - (ey + 4))
                        END IF

                        uiWordSelMode(hitIndex) = 0
                        uiWordSelA(hitIndex) = 0
                        uiWordSelB(hitIndex) = 0
                        uiLineSelMode(hitIndex) = 0
                        uiLineSelA(hitIndex) = 0
                        uiLineSelB(hitIndex) = 0

                        IF mouseDownShift <> 0 THEN
                            ' Shift+Click extends from the existing caret/selection anchor to the clicked text position.
                            ' Keep the opposite selection edge stable so mouse release preserves the extended range.
                            Ed_MoveCaret uiEdit(hitIndex), uiCaretPos, -1
                            uiCaretPos = uiEdit(hitIndex).curPos
                            uiSelAnchor(hitIndex) = uiEdit(hitIndex).selA
                        ELSE
                            uiSelAnchor(hitIndex) = uiCaretPos
                            uiEdit(hitIndex).curPos = uiCaretPos
                            Ed_SelClr uiEdit(hitIndex)

                            IF lastTextClickIndex = hitIndex THEN
                                IF ((nowTime - lastTextClickTime) * 100) <= cfg.doubleClickTime THEN
                                    IF AbsI(smx - lastTextClickX) <= DOUBLE_CLICK_MOVE_SLOP AND _
                                       AbsI(smy - lastTextClickY) <= DOUBLE_CLICK_MOVE_SLOP THEN
                                        IF lastTextClickCount >= 2 THEN
                                            Ed_SelectLineAt uiEdit(hitIndex)
                                            uiLineSelMode(hitIndex) = -1
                                            uiLineSelA(hitIndex) = uiEdit(hitIndex).selA
                                            uiLineSelB(hitIndex) = uiEdit(hitIndex).selB
                                            uiWordSelMode(hitIndex) = 0
                                        ELSE
                                            Ed_SelectWordAt uiEdit(hitIndex)
                                            uiWordSelMode(hitIndex) = -1
                                            uiWordSelA(hitIndex) = uiEdit(hitIndex).selA
                                            uiWordSelB(hitIndex) = uiEdit(hitIndex).selB
                                            uiLineSelMode(hitIndex) = 0
                                        END IF
                                        uiSelAnchor(hitIndex) = uiEdit(hitIndex).selA
                                        uiCaretPos = uiEdit(hitIndex).curPos
                                    END IF
                                END IF
                            END IF
                        END IF

                        IF activeLayoutWindow >= 1 AND activeLayoutWindow <= 12 THEN
                            IF layoutWindows(activeLayoutWindow).used <> 0 THEN
                                layoutWindows(activeLayoutWindow).focusIndex = hitIndex
                                layoutWindows(activeLayoutWindow).caretPos = uiCaretPos
                            END IF
                        END IF
                        SyncTextboxScrollToCaret hitIndex
                        END IF
                    END IF
