FUNCTION DosRunModeValue(BYVAL modeText AS STRING) AS STRING
    modeText = UCASE$(TRIM$(modeText))

    IF modeText = "UNLOAD" THEN RETURN "UNLOAD"
    IF modeText = "FULL" THEN RETURN "UNLOAD"
    IF modeText = "FULLSCREEN" THEN RETURN "UNLOAD"
    IF modeText = "EXIT" THEN RETURN "UNLOAD"

    IF modeText = "RESIDENT" THEN RETURN "RESIDENT"
    IF modeText = "SHELL" THEN RETURN "RESIDENT"
    IF modeText = "KEEP" THEN RETURN "RESIDENT"

    RETURN ""
END FUNCTION

FUNCTION DosDefaultRunModeForCommand(BYVAL cmdLine AS STRING) AS STRING
    DIM programText AS STRING
    DIM extName AS STRING

    programText = DosCommandProgram(cmdLine)
    IF programText = "" THEN RETURN ""

    IF DosCommandExplicitPath(programText) <> 0 THEN
        extName = UCASE$(FileExtensionOf(programText))
        IF extName = "EXE" THEN RETURN "UNLOAD"
        IF extName = "COM" THEN RETURN "UNLOAD"
        IF extName = "BAT" THEN RETURN "UNLOAD"
        IF extName = "" THEN RETURN "UNLOAD"
    END IF

    RETURN ""
END FUNCTION

FUNCTION DosCommandProgram(BYVAL cmdLine AS STRING) AS STRING
    DIM i AS INTEGER
    DIM ch AS STRING

    cmdLine = TRIM$(cmdLine)
    IF cmdLine = "" THEN RETURN ""

    IF LEFT$(cmdLine, 1) = CHR$(34) THEN
        FOR i = 2 TO LEN(cmdLine)
            IF MID$(cmdLine, i, 1) = CHR$(34) THEN
                RETURN MID$(cmdLine, 2, i - 2)
            END IF
        NEXT
        RETURN MID$(cmdLine, 2)
    END IF

    FOR i = 1 TO LEN(cmdLine)
        ch = MID$(cmdLine, i, 1)
        IF ch = " " OR ch = CHR$(9) THEN
            RETURN LEFT$(cmdLine, i - 1)
        END IF
    NEXT

    RETURN cmdLine
END FUNCTION

FUNCTION DosCommandArgs(BYVAL cmdLine AS STRING) AS STRING
    DIM i AS INTEGER
    DIM ch AS STRING

    cmdLine = TRIM$(cmdLine)
    IF cmdLine = "" THEN RETURN ""

    IF LEFT$(cmdLine, 1) = CHR$(34) THEN
        FOR i = 2 TO LEN(cmdLine)
            IF MID$(cmdLine, i, 1) = CHR$(34) THEN
                IF i < LEN(cmdLine) THEN RETURN TRIM$(MID$(cmdLine, i + 1))
                RETURN ""
            END IF
        NEXT
        RETURN ""
    END IF

    FOR i = 1 TO LEN(cmdLine)
        ch = MID$(cmdLine, i, 1)
        IF ch = " " OR ch = CHR$(9) THEN
            IF i < LEN(cmdLine) THEN RETURN TRIM$(MID$(cmdLine, i + 1))
            RETURN ""
        END IF
    NEXT

    RETURN ""
END FUNCTION

FUNCTION DosCommandExplicitPath(BYVAL programText AS STRING) AS INTEGER
    programText = TRIM$(programText)
    IF programText = "" THEN RETURN 0
    IF INSTR(programText, ":") > 0 THEN RETURN -1
    IF INSTR(programText, CHR$(92)) > 0 THEN RETURN -1
    RETURN 0
END FUNCTION

FUNCTION DosCommandPathHasSpaces(BYVAL programText AS STRING) AS INTEGER
    programText = TRIM$(programText)
    IF programText = "" THEN RETURN 0
    IF INSTR(programText, " ") > 0 THEN RETURN -1
    IF INSTR(programText, CHR$(9)) > 0 THEN RETURN -1
    IF INSTR(programText, CHR$(34)) > 0 THEN RETURN -1
    RETURN 0
END FUNCTION

FUNCTION Dos83ComponentValid(BYVAL partText AS STRING) AS INTEGER
    DIM dotPos AS INTEGER
    DIM secondDot AS INTEGER
    DIM nameText AS STRING
    DIM extText AS STRING

    partText = TRIM$(partText)
    IF partText = "" THEN RETURN 0
    IF partText = "." THEN RETURN -1
    IF partText = ".." THEN RETURN -1
    IF DosCommandPathHasSpaces(partText) <> 0 THEN RETURN 0

    dotPos = INSTR(partText, ".")
    IF dotPos = 0 THEN
        IF LEN(partText) > 8 THEN RETURN 0
        RETURN -1
    END IF

    secondDot = INSTR(dotPos + 1, partText, ".")
    IF secondDot > 0 THEN RETURN 0

    nameText = LEFT$(partText, dotPos - 1)
    extText = MID$(partText, dotPos + 1)

    IF nameText = "" THEN RETURN 0
    IF extText = "" THEN RETURN 0
    IF LEN(nameText) > 8 THEN RETURN 0
    IF LEN(extText) > 3 THEN RETURN 0

    RETURN -1
END FUNCTION

FUNCTION DosCommandPathIs83(BYVAL programText AS STRING) AS INTEGER
    DIM p AS STRING
    DIM i AS INTEGER
    DIM ch AS STRING
    DIM partText AS STRING

    p = NormalizePath(TRIM$(programText))
    IF p = "" THEN RETURN 0
    IF DosCommandPathHasSpaces(p) <> 0 THEN RETURN 0

    IF LEN(p) >= 2 THEN
        IF MID$(p, 2, 1) = ":" THEN
            ch = LEFT$(p, 1)
            IF ch < "A" OR ch > "Z" THEN RETURN 0
            p = MID$(p, 3)
        END IF
    END IF

    partText = ""
    FOR i = 1 TO LEN(p)
        ch = MID$(p, i, 1)
        IF ch = CHR$(92) THEN
            IF partText <> "" THEN
                IF Dos83ComponentValid(partText) = 0 THEN RETURN 0
                partText = ""
            ELSE
                IF i <> 1 THEN RETURN 0
            END IF
        ELSE
            partText = partText + ch
        END IF
    NEXT

    IF partText <> "" THEN
        IF Dos83ComponentValid(partText) = 0 THEN RETURN 0
        RETURN -1
    END IF

    RETURN 0
END FUNCTION

FUNCTION DosCommandExtensionAllowed(BYVAL programText AS STRING) AS INTEGER
    DIM extName AS STRING

    programText = NormalizePath(TRIM$(programText))
    IF programText = "" THEN RETURN 0

    extName = UCASE$(FileExtensionOf(programText))
    IF extName = "" THEN RETURN -1
    IF extName = "EXE" THEN RETURN -1
    IF extName = "COM" THEN RETURN -1
    IF extName = "BAT" THEN RETURN -1

    RETURN 0
END FUNCTION

FUNCTION DosCommandTargetIsDirectory(BYVAL programText AS STRING) AS INTEGER
    programText = NormalizePath(TRIM$(programText))
    IF programText = "" THEN RETURN 0
    IF DosCommandExplicitPath(programText) = 0 THEN RETURN 0
    IF DIR(programText) <> "" THEN RETURN 0
    IF DIR(programText, &H10) <> "" THEN RETURN -1
    RETURN 0
END FUNCTION

FUNCTION DosCommandExistingTarget(BYVAL programText AS STRING) AS STRING
    programText = NormalizePath(TRIM$(programText))
    IF programText = "" THEN RETURN ""
    IF DosCommandExplicitPath(programText) = 0 THEN RETURN programText

    IF DIR(programText) <> "" THEN RETURN programText

    IF FileExtensionOf(programText) = "" THEN
        IF DIR(programText + ".EXE") <> "" THEN RETURN programText + ".EXE"
        IF DIR(programText + ".COM") <> "" THEN RETURN programText + ".COM"
        IF DIR(programText + ".BAT") <> "" THEN RETURN programText + ".BAT"
    END IF

    RETURN ""
END FUNCTION

FUNCTION DosCommandTargetExists(BYVAL programText AS STRING) AS INTEGER
    programText = NormalizePath(TRIM$(programText))
    IF programText = "" THEN RETURN 0
    IF DosCommandExplicitPath(programText) = 0 THEN RETURN -1
    IF DosCommandExistingTarget(programText) <> "" THEN RETURN -1
    RETURN 0
END FUNCTION

SUB ClearDosRequestFile(BYVAL fileName AS STRING)
