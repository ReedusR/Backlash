                        layoutCloseClickConsumed = -1
                        draggingLayoutWin = 0
                        resizingLayoutWin = 0
                        draggingVScroll = 0
                        draggingHScroll = 0
                        draggingComboScroll = 0
                        draggingListScroll = 0
                        draggingTextScroll = 0
