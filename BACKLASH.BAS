' Script-driven preview rendering
' ---------------------------

FUNCTION ScriptPreviewStaticChoiceValue(BYVAL elemIdx AS INTEGER) AS STRING
    DIM selectedText AS STRING
    DIM itemsSpec AS STRING
    DIM itemSpec AS STRING
    DIM itemText AS STRING
    DIM itemValue AS STRING
    DIM sepPos AS INTEGER
    DIM eqPos AS INTEGER
    DIM sepChrPos AS INTEGER

    IF elemIdx < 1 OR elemIdx > uiCount THEN RETURN ""

    selectedText = RTRIM$(uiElems(elemIdx).text)
    IF selectedText = "" THEN RETURN ""

    itemsSpec = uiElems(elemIdx).sourceItems
    DO WHILE itemsSpec <> ""
        sepPos = INSTR(itemsSpec, "|")
        IF sepPos > 0 THEN
            itemSpec = LEFT$(itemsSpec, sepPos - 1)
            itemsSpec = MID$(itemsSpec, sepPos + 1)
        ELSE
            itemSpec = itemsSpec
            itemsSpec = ""
        END IF

        itemText = itemSpec
        itemValue = itemSpec
        sepChrPos = INSTR(itemSpec, CHR$(1))
        eqPos = INSTR(itemSpec, "=")
        IF sepChrPos > 0 THEN
            itemText = LEFT$(itemSpec, sepChrPos - 1)
            itemValue = MID$(itemSpec, sepChrPos + 1)
        ELSEIF eqPos > 0 THEN
            itemText = TRIM$(LEFT$(itemSpec, eqPos - 1))
            itemValue = TRIM$(MID$(itemSpec, eqPos + 1))
        END IF

        IF UCASE$(TRIM$(itemText)) = UCASE$(TRIM$(selectedText)) THEN
            IF uiElems(elemIdx).valuePrefix <> "" THEN RETURN uiElems(elemIdx).valuePrefix + itemValue
            RETURN itemValue
        END IF
    LOOP

    IF uiElems(elemIdx).valuePrefix <> "" THEN RETURN uiElems(elemIdx).valuePrefix + selectedText
    RETURN selectedText
END FUNCTION

FUNCTION ScriptPreviewControlValue(BYVAL keyName AS STRING, BYVAL defaultValue AS STRING, BYVAL targetFile AS STRING) AS STRING
    DIM i AS INTEGER
    DIM targetKey AS STRING
    DIM elemIdx AS INTEGER

    targetKey = UCASE$(TRIM$(keyName))
    IF targetKey <> "" THEN
        BuildScriptPreviewBindCache

        FOR i = 1 TO scriptPreviewBindCacheCount
            IF RTRIM$(scriptPreviewBindCacheKey(i)) = targetKey THEN
                elemIdx = scriptPreviewBindCacheIdx(i)
                IF elemIdx >= 1 AND elemIdx <= uiCount THEN
                    SELECT CASE uiElems(elemIdx).kindKey
                    CASE "TEXTBOX"
                        RETURN Ed_GetTextGlue(uiEdit(elemIdx), uiElems(elemIdx).text)
                    CASE "COMBO", "LISTBOX"
                        RETURN ScriptPreviewStaticChoiceValue(elemIdx)
                    CASE "RADIO"
                        IF uiElems(elemIdx).state <> 0 THEN RETURN uiElems(elemIdx).bindValue
                    CASE "CHECKBOX"
                        IF uiElems(elemIdx).state <> 0 THEN
                            IF TRIM$(uiElems(elemIdx).bindValue) <> "" THEN RETURN uiElems(elemIdx).bindValue
                            RETURN "1"
                        ELSE
                            RETURN "0"
                        END IF
                    CASE ELSE
                        RETURN RTRIM$(uiElems(elemIdx).text)
                    END SELECT
                END IF
            END IF
        NEXT
    END IF

    IF TRIM$(targetFile) <> "" THEN RETURN ReadCfgValue(targetFile, keyName, defaultValue)
    RETURN defaultValue
END FUNCTION

FUNCTION ScriptPreviewIntSpec(BYVAL specText AS STRING, BYVAL defaultValue AS INTEGER, BYVAL targetFile AS STRING) AS INTEGER
    DIM p AS INTEGER
    DIM keyText AS STRING
    DIM defText AS STRING
    DIM firstChar AS STRING

    specText = TRIM$(specText)
    IF specText = "" THEN RETURN defaultValue

    firstChar = LEFT$(specText, 1)
    IF (firstChar >= "0" AND firstChar <= "9") OR firstChar = "-" THEN RETURN VALINT(specText)

    p = INSTR(specText, ":")
    IF p > 0 THEN
        keyText = TRIM$(LEFT$(specText, p - 1))
        defText = TRIM$(MID$(specText, p + 1))
    ELSE
        keyText = specText
        defText = LTRIM$(STR$(defaultValue))
    END IF

    RETURN VALINT(ScriptPreviewControlValue(keyText, defText, targetFile))
END FUNCTION

FUNCTION ScriptPreviewField(BYVAL srcText AS STRING, BYVAL fieldNum AS INTEGER) AS STRING
    DIM i AS INTEGER
    DIM p AS INTEGER
    DIM partText AS STRING

    srcText = srcText + ","
    FOR i = 1 TO fieldNum
        p = INSTR(srcText, ",")
        IF p <= 0 THEN RETURN ""
        partText = LEFT$(srcText, p - 1)
        srcText = MID$(srcText, p + 1)
    NEXT

    RETURN TRIM$(partText)
END FUNCTION

FUNCTION CleanDosBaseName(BYVAL rawName AS STRING, BYVAL fallbackName AS STRING) AS STRING
    DIM outName AS STRING
    DIM i AS INTEGER
    DIM ch AS STRING
    DIM codeVal AS INTEGER

    rawName = UCASE$(TRIM$(rawName))
    outName = ""

    FOR i = 1 TO LEN(rawName)
        ch = MID$(rawName, i, 1)
        codeVal = ASC(ch)
        IF (codeVal >= ASC("A") AND codeVal <= ASC("Z")) OR _
           (codeVal >= ASC("0") AND codeVal <= ASC("9")) THEN
            IF LEN(outName) < 8 THEN outName = outName + ch
        ELSEIF ch = "_" OR ch = "-" THEN
            IF LEN(outName) < 8 THEN outName = outName + "_"
        END IF
    NEXT

    IF outName = "" THEN outName = UCASE$(TRIM$(fallbackName))
    IF outName = "" THEN outName = "CUSTOM"
    IF LEN(outName) > 8 THEN outName = LEFT$(outName, 8)
    RETURN outName

END FUNCTION




FUNCTION ScriptPreviewColor(BYVAL sysFileName AS STRING, BYVAL sectionName AS STRING, BYVAL colorName AS STRING, BYVAL targetFile AS STRING, BYVAL colorMode AS STRING, BYVAL depthVal AS INTEGER) AS UINTEGER
    DIM specText AS STRING
    DIM modeText AS STRING
    DIM payload AS STRING
    DIM p1 AS INTEGER
    DIM p2 AS INTEGER
    DIM rr AS INTEGER
    DIM gg AS INTEGER
    DIM bb AS INTEGER
    DIM aliasName AS STRING

    colorName = UCASE$(TRIM$(colorName))
    IF colorName = "" THEN RETURN COL_TEXT

    specText = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "COLOR_" + colorName, ""))
    IF specText = "" THEN
        IF (LEFT$(colorName, 1) >= "0" AND LEFT$(colorName, 1) <= "9") THEN RETURN VALINT(colorName)
        RETURN COL_TEXT
    END IF

    p1 = INSTR(specText, ":")
    IF p1 <= 0 THEN RETURN VALINT(specText)

    modeText = UCASE$(TRIM$(LEFT$(specText, p1 - 1)))
    payload = TRIM$(MID$(specText, p1 + 1))

    SELECT CASE modeText
    CASE "ALIAS"
        aliasName = UCASE$(TRIM$(payload))
        IF aliasName = colorName THEN RETURN COL_TEXT
        RETURN ScriptPreviewColor(sysFileName, sectionName, aliasName, targetFile, colorMode, depthVal)
    CASE "IDX"
        RETURN ClampI(ScriptPreviewIntSpec(payload, 0, targetFile), 0, 15)
    CASE "RGB"
        p1 = INSTR(payload, ",")
        p2 = 0
        IF p1 > 0 THEN p2 = INSTR(p1 + 1, payload, ",")
        IF p1 <= 0 OR p2 <= 0 THEN RETURN COL_TEXT
        rr = ScriptPreviewIntSpec(LEFT$(payload, p1 - 1), 0, targetFile)
        gg = ScriptPreviewIntSpec(MID$(payload, p1 + 1, p2 - p1 - 1), 0, targetFile)
        bb = ScriptPreviewIntSpec(MID$(payload, p2 + 1), 0, targetFile)
        IF UCASE$(TRIM$(colorMode)) = "RGB256" OR depthVal = 8 THEN RETURN Backlash256ColorIndex(rr, gg, bb)
        RETURN RGB(ClampI(rr, 0, 255), ClampI(gg, 0, 255), ClampI(bb, 0, 255))
    END SELECT

    RETURN COL_TEXT
END FUNCTION

FUNCTION ScriptPreviewCoord(BYVAL exprText AS STRING, BYVAL previewW AS INTEGER, BYVAL previewH AS INTEGER) AS INTEGER
    DIM s AS STRING
    DIM i AS INTEGER
    DIM signVal AS INTEGER
    DIM term AS STRING
    DIM total AS INTEGER
    DIM divPos AS INTEGER
    DIM numerator AS INTEGER
    DIM divisor AS INTEGER

    s = UCASE$(TRIM$(exprText))
    IF s = "" THEN RETURN 0
    s = s + "+"
    signVal = 1
    term = ""
    total = 0

    FOR i = 1 TO LEN(s)
        SELECT CASE MID$(s, i, 1)
        CASE "+", "-"
            IF TRIM$(term) <> "" THEN
                term = TRIM$(term)
                divPos = INSTR(term, "/")
                divisor = 1
                IF divPos > 0 THEN
                    divisor = VALINT(MID$(term, divPos + 1))
                    term = LEFT$(term, divPos - 1)
                    IF divisor = 0 THEN divisor = 1
                END IF
                SELECT CASE term
                CASE "W"
                    numerator = previewW
                CASE "H"
                    numerator = previewH
                CASE ELSE
                    numerator = VALINT(term)
                END SELECT
                total = total + signVal * (numerator \ divisor)
            END IF
            IF MID$(s, i, 1) = "-" THEN signVal = -1 ELSE signVal = 1
            term = ""
        CASE ELSE
            term = term + MID$(s, i, 1)
        END SELECT
    NEXT

    RETURN total
END FUNCTION

SUB ClearScriptPreviewBindCache()
    DIM i AS INTEGER

    scriptPreviewBindCacheValid = 0
    scriptPreviewBindCacheWin = 0
    scriptPreviewBindCacheCount = 0
    scriptPreviewBindCacheApp = ""
    FOR i = 1 TO 192
        scriptPreviewBindCacheKey(i) = ""
        scriptPreviewBindCacheIdx(i) = 0
    NEXT
END SUB

SUB BuildScriptPreviewBindCache()
    DIM i AS INTEGER
    DIM curApp AS STRING

    curApp = ""
    IF drawLayoutWindow >= LBOUND(layoutWindows) AND drawLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(drawLayoutWindow).used <> 0 THEN
            curApp = UCASE$(NormalizePath(layoutWindows(drawLayoutWindow).appPath))
        END IF
    END IF

    IF scriptPreviewBindCacheValid <> 0 THEN
        IF scriptPreviewBindCacheWin = drawLayoutWindow AND _
           scriptPreviewBindCacheCount <= uiCount AND _
           UCASE$(TRIM$(scriptPreviewBindCacheApp)) = curApp THEN EXIT SUB
    END IF

    ClearScriptPreviewBindCache
    scriptPreviewBindCacheWin = drawLayoutWindow
    scriptPreviewBindCacheApp = curApp

    FOR i = 1 TO uiCount
        IF TRIM$(uiElems(i).bindKey) <> "" THEN
            IF scriptPreviewBindCacheCount < 192 THEN
                scriptPreviewBindCacheCount = scriptPreviewBindCacheCount + 1
                scriptPreviewBindCacheKey(scriptPreviewBindCacheCount) = UCASE$(TRIM$(uiElems(i).bindKey))
                scriptPreviewBindCacheIdx(scriptPreviewBindCacheCount) = i
            END IF
        END IF
    NEXT

    scriptPreviewBindCacheValid = -1
END SUB

SUB FreeScriptPreviewCache()
    IF scriptPreviewCacheImg <> 0 THEN
        ImageDestroy scriptPreviewCacheImg
        scriptPreviewCacheImg = 0
    END IF
    scriptPreviewCacheW = 0
    scriptPreviewCacheH = 0
    scriptPreviewCacheKey = ""
END SUB

FUNCTION ScriptPreviewCacheSignature(BYVAL elemIdx AS INTEGER, BYVAL prevW AS INTEGER, BYVAL prevH AS INTEGER, BYVAL sysFileName AS STRING, BYVAL sectionName AS STRING) AS STRING
    DIM activePage AS STRING
    DIM sig AS STRING

    GetLayoutActivePage activePage

    sig = "SCRIPT|" + UCASE$(NormalizePath(sysFileName)) + "|" + UCASE$(TRIM$(sectionName)) + "|" + _
          LTRIM$(STR$(elemIdx)) + "|" + LTRIM$(STR$(prevW)) + "x" + LTRIM$(STR$(prevH)) + "|" + _
          UCASE$(TRIM$(activePage)) + "|" + LTRIM$(STR$(LayoutCurrentColorDepth()))

    IF drawLayoutWindow >= LBOUND(layoutWindows) AND drawLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(drawLayoutWindow).used <> 0 THEN
            sig = sig + "|APP=" + UCASE$(NormalizePath(layoutWindows(drawLayoutWindow).appPath)) + _
                  "|DIRTY=" + LTRIM$(STR$(layoutDirtyVersion(drawLayoutWindow))) + _
                  "|TAB=" + LTRIM$(STR$(layoutWindows(drawLayoutWindow).selectedTab))
        END IF
    ELSE
        sig = sig + "|DIRTY=0|TAB=" + LTRIM$(STR$(uiSelectedTab))
    END IF

    RETURN sig
END FUNCTION

SUB DrawScriptPreviewCommand(BYVAL sysFileName AS STRING, BYVAL sectionName AS STRING, BYVAL targetFile AS STRING, BYVAL colorMode AS STRING, BYVAL depthVal AS INTEGER, BYVAL cmdText AS STRING, BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL previewW AS INTEGER, BYVAL previewH AS INTEGER)
    DIM verbText AS STRING
    DIM argsText AS STRING
    DIM p AS INTEGER
    DIM ax1 AS INTEGER
    DIM ay1 AS INTEGER
    DIM ax2 AS INTEGER
    DIM ay2 AS INTEGER
    DIM colorA AS UINTEGER
    DIM colorB AS UINTEGER
    DIM fillText AS STRING
    DIM dirText AS STRING
    DIM flagSpec AS STRING
    DIM flagVal AS INTEGER
    DIM textVal AS STRING
    DIM gr1 AS INTEGER
    DIM gg1 AS INTEGER
    DIM gb1 AS INTEGER
    DIM gr2 AS INTEGER
    DIM gg2 AS INTEGER
    DIM gb2 AS INTEGER

    cmdText = TRIM$(cmdText)
    IF cmdText = "" THEN EXIT SUB

    p = INSTR(cmdText, " ")
    IF p <= 0 THEN EXIT SUB
    verbText = UCASE$(TRIM$(LEFT$(cmdText, p - 1)))
    argsText = TRIM$(MID$(cmdText, p + 1))

    SELECT CASE verbText
    CASE "RECT"
        ax1 = x1 + ScriptPreviewCoord(ScriptPreviewField(argsText, 1), previewW, previewH)
        ay1 = y1 + ScriptPreviewCoord(ScriptPreviewField(argsText, 2), previewW, previewH)
        ax2 = x1 + ScriptPreviewCoord(ScriptPreviewField(argsText, 3), previewW, previewH)
        ay2 = y1 + ScriptPreviewCoord(ScriptPreviewField(argsText, 4), previewW, previewH)
        colorA = ScriptPreviewColor(sysFileName, sectionName, ScriptPreviewField(argsText, 5), targetFile, colorMode, depthVal)
        fillText = UCASE$(ScriptPreviewField(argsText, 6))
        IF fillText = "B" THEN
            LINE (ax1, ay1)-(ax2, ay2), colorA, B
        ELSE
            LINE (ax1, ay1)-(ax2, ay2), colorA, BF
        END IF
    CASE "LINE"
        ax1 = x1 + ScriptPreviewCoord(ScriptPreviewField(argsText, 1), previewW, previewH)
        ay1 = y1 + ScriptPreviewCoord(ScriptPreviewField(argsText, 2), previewW, previewH)
        ax2 = x1 + ScriptPreviewCoord(ScriptPreviewField(argsText, 3), previewW, previewH)
        ay2 = y1 + ScriptPreviewCoord(ScriptPreviewField(argsText, 4), previewW, previewH)
        colorA = ScriptPreviewColor(sysFileName, sectionName, ScriptPreviewField(argsText, 5), targetFile, colorMode, depthVal)
        LINE (ax1, ay1)-(ax2, ay2), colorA
    CASE "TEXT"
        ax1 = x1 + ScriptPreviewCoord(ScriptPreviewField(argsText, 1), previewW, previewH)
        ay1 = y1 + ScriptPreviewCoord(ScriptPreviewField(argsText, 2), previewW, previewH)
        textVal = ScriptPreviewField(argsText, 3)
        colorA = ScriptPreviewColor(sysFileName, sectionName, ScriptPreviewField(argsText, 4), targetFile, colorMode, depthVal)
        DRAW STRING (ax1, ay1), textVal, colorA
    CASE "GRADRGB"
        ax1 = x1 + ScriptPreviewCoord(ScriptPreviewField(argsText, 1), previewW, previewH)
        ay1 = y1 + ScriptPreviewCoord(ScriptPreviewField(argsText, 2), previewW, previewH)
        ax2 = x1 + ScriptPreviewCoord(ScriptPreviewField(argsText, 3), previewW, previewH)
        ay2 = y1 + ScriptPreviewCoord(ScriptPreviewField(argsText, 4), previewW, previewH)
        gr1 = ScriptPreviewIntSpec(ScriptPreviewField(argsText, 5), 0, targetFile)
        gg1 = ScriptPreviewIntSpec(ScriptPreviewField(argsText, 6), 0, targetFile)
        gb1 = ScriptPreviewIntSpec(ScriptPreviewField(argsText, 7), 0, targetFile)
        gr2 = ScriptPreviewIntSpec(ScriptPreviewField(argsText, 8), 0, targetFile)
        gg2 = ScriptPreviewIntSpec(ScriptPreviewField(argsText, 9), 0, targetFile)
        gb2 = ScriptPreviewIntSpec(ScriptPreviewField(argsText, 10), 0, targetFile)
        dirText = UCASE$(ScriptPreviewField(argsText, 11))
        flagSpec = ScriptPreviewField(argsText, 12)
        flagVal = ScriptPreviewIntSpec(flagSpec, 0, targetFile)
        IF flagVal <> 0 AND UCASE$(TRIM$(colorMode)) <> "INDEX16" THEN
            IF dirText = "V" THEN
                DrawGradientRgbRect ax1, ay1, ax2, ay2, gr1, gg1, gb1, gr2, gg2, gb2, 1
            ELSE
                DrawGradientRgbRect ax1, ay1, ax2, ay2, gr1, gg1, gb1, gr2, gg2, gb2, 0
            END IF
        ELSE
            IF UCASE$(TRIM$(colorMode)) = "RGB256" OR depthVal = 8 THEN
                colorA = Backlash256ColorIndex(gr1, gg1, gb1)
            ELSE
                colorA = RGB(ClampI(gr1, 0, 255), ClampI(gg1, 0, 255), ClampI(gb1, 0, 255))
            END IF
            LINE (ax1, ay1)-(ax2, ay2), colorA, BF
        END IF
    END SELECT
END SUB

SUB DrawScriptPreviewControl(BYVAL elemIdx AS INTEGER, BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER, BYVAL sysFileName AS STRING, BYVAL sectionName AS STRING, BYVAL clipL AS INTEGER, BYVAL clipT AS INTEGER, BYVAL clipR AS INTEGER, BYVAL clipB AS INTEGER)
    DIM targetFile AS STRING
    DIM colorMode AS STRING
    DIM depthVal AS INTEGER
    DIM cmdText AS STRING
    DIM i AS INTEGER
    DIM prevW AS INTEGER
    DIM prevH AS INTEGER
    DIM cacheKey AS STRING
    DIM previewClipL AS INTEGER
    DIM previewClipT AS INTEGER
    DIM previewClipR AS INTEGER
    DIM previewClipB AS INTEGER
    DIM previewFullyVisible AS INTEGER
    DIM canCaptureCache AS INTEGER

    sysFileName = NormalizePath(TRIM$(sysFileName))
    sectionName = TRIM$(sectionName)
    IF sysFileName = "" OR sectionName = "" THEN EXIT SUB

    prevW = x2 - x1 + 1
    prevH = y2 - y1 + 1
    IF prevW < 1 OR prevH < 1 THEN EXIT SUB

    previewClipL = clipL
    previewClipT = clipT
    previewClipR = clipR
    previewClipB = clipB
    IF previewClipL < x1 THEN previewClipL = x1
    IF previewClipT < y1 THEN previewClipT = y1
    IF previewClipR > x2 THEN previewClipR = x2
    IF previewClipB > y2 THEN previewClipB = y2
    IF previewClipR < previewClipL OR previewClipB < previewClipT THEN EXIT SUB

    previewFullyVisible = 0
    IF previewClipL = x1 AND previewClipT = y1 AND previewClipR = x2 AND previewClipB = y2 THEN previewFullyVisible = -1
    canCaptureCache = previewFullyVisible

    LoadCfgReadCacheFile sysFileName
    targetFile = NormalizePath(ReadCfgValueInSection(sysFileName, sectionName, "TARGET_FILE", PATH_THEMECFG))
    colorMode = UCASE$(TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "COLOR_MODE", "RGB")))
    depthVal = VALINT(ReadCfgValueInSection(sysFileName, sectionName, "DEPTH", LTRIM$(STR$(LayoutCurrentColorDepth()))))

    cacheKey = ScriptPreviewCacheSignature(elemIdx, prevW, prevH, sysFileName, sectionName)
    IF scriptPreviewCacheImg <> 0 THEN
        IF scriptPreviewCacheW = prevW AND scriptPreviewCacheH = prevH AND scriptPreviewCacheKey = cacheKey THEN
            VIEW SCREEN (previewClipL, previewClipT)-(previewClipR, previewClipB)
            PUT (x1, y1), scriptPreviewCacheImg, PSET
            VIEW
            EXIT SUB
        END IF
    END IF

    IF scriptPreviewCacheImg <> 0 THEN
        IF scriptPreviewCacheW <> prevW OR scriptPreviewCacheH <> prevH THEN FreeScriptPreviewCache
    END IF

    IF scriptPreviewCacheImg = 0 AND canCaptureCache <> 0 THEN
        scriptPreviewCacheImg = ImageCreate(prevW, prevH, 0)
        scriptPreviewCacheW = prevW
        scriptPreviewCacheH = prevH
        scriptPreviewCacheKey = ""
    END IF

    ' The scripted preview can sit partly outside a resized app window.
    ' Keep the preview geometry intact, but draw only inside the visible client area.
    VIEW SCREEN (previewClipL, previewClipT)-(previewClipR, previewClipB)
    FOR i = 1 TO 80
        cmdText = ReadCfgValueInSection(sysFileName, sectionName, "DRAW" + LTRIM$(STR$(i)), "")
        IF TRIM$(cmdText) = "" THEN EXIT FOR
        DrawScriptPreviewCommand sysFileName, sectionName, targetFile, colorMode, depthVal, cmdText, x1, y1, prevW, prevH
    NEXT
    VIEW

    IF canCaptureCache <> 0 AND scriptPreviewCacheImg <> 0 THEN
        GET (x1, y1)-(x2, y2), scriptPreviewCacheImg
        scriptPreviewCacheKey = cacheKey
        scriptPreviewCacheW = prevW
        scriptPreviewCacheH = prevH
    END IF
END SUB


' Draws a bitmap preview based on the file path stored in another control.
SUB DrawBoundPreview(BYVAL elemIdx AS INTEGER, BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER, BYVAL clipL AS INTEGER, BYVAL clipT AS INTEGER, BYVAL clipR AS INTEGER, BYVAL clipB AS INTEGER)
    DIM innerX1 AS INTEGER
    DIM innerY1 AS INTEGER
    DIM innerX2 AS INTEGER
    DIM innerY2 AS INTEGER
    DIM innerClipL AS INTEGER
    DIM innerClipT AS INTEGER
    DIM innerClipR AS INTEGER
    DIM innerClipB AS INTEGER
    DIM srcIdx AS INTEGER
    DIM bmpPath AS STRING
    DIM modeVal AS INTEGER
    DIM modeText AS STRING
    DIM x AS INTEGER
    DIM y AS INTEGER
    DIM sx AS INTEGER
    DIM sy AS INTEGER
    DIM ox AS INTEGER
    DIM oy AS INTEGER
    DIM tx AS INTEGER
    DIM ty AS INTEGER
    DIM pw AS INTEGER
    DIM ph AS INTEGER
    DIM srcBmpW AS INTEGER
    DIM srcBmpH AS INTEGER
    DIM targetW AS INTEGER
    DIM targetH AS INTEGER
    DIM drawW AS INTEGER
    DIM drawH AS INTEGER
    DIM drawX1 AS INTEGER
    DIM drawY1 AS INTEGER
    DIM liveNormPath AS STRING
    DIM liveKeyPrefix AS STRING
    DIM liveDrawW AS INTEGER
    DIM liveDrawH AS INTEGER
    DIM liveDrawX AS INTEGER
    DIM liveDrawY AS INTEGER
    DIM useLiveCachedPreview AS INTEGER

    innerX1 = x1 + 2
    innerY1 = y1 + 2
    innerX2 = x2 - 2
    innerY2 = y2 - 2
    IF innerX2 < innerX1 OR innerY2 < innerY1 THEN EXIT SUB

    innerClipL = clipL
    innerClipT = clipT
    innerClipR = clipR
    innerClipB = clipB
    IF innerClipL < innerX1 THEN innerClipL = innerX1
    IF innerClipT < innerY1 THEN innerClipT = innerY1
    IF innerClipR > innerX2 THEN innerClipR = innerX2
    IF innerClipB > innerY2 THEN innerClipB = innerY2
    IF innerClipR < innerClipL OR innerClipB < innerClipT THEN EXIT SUB

    IF uiElems(elemIdx).modeId = UI_MODE_SYS THEN
        DIM sysSpec AS STRING
        DIM sysFileName AS STRING
        DIM sysSectionName AS STRING
        DIM sysSep AS INTEGER

        sysSpec = TRIM$(uiElems(elemIdx).sourceControl)
        sysSep = INSTR(sysSpec, "|")
        IF sysSep <= 0 THEN sysSep = INSTR(sysSpec, " ")
        IF sysSep > 0 THEN
            sysFileName = NormalizePath(TRIM$(LEFT$(sysSpec, sysSep - 1)))
            sysSectionName = TRIM$(MID$(sysSpec, sysSep + 1))
            DrawScriptPreviewControl elemIdx, innerX1, innerY1, innerX2, innerY2, sysFileName, sysSectionName, innerClipL, innerClipT, innerClipR, innerClipB
        END IF
        EXIT SUB
    END IF

    FillRectClipped innerX1, innerY1, innerX2, innerY2, innerClipL, innerClipT, innerClipR, innerClipB, COL_BACKGROUND

    srcIdx = GetControlIndexByName(uiElems(elemIdx).sourceControl)
    bmpPath = ""
    IF srcIdx > 0 THEN
        SELECT CASE uiElems(srcIdx).kindId
        CASE UI_KIND_COMBO
            bmpPath = ControlValueFromCombo(srcIdx)
        CASE UI_KIND_LISTBOX
            bmpPath = ControlValueFromListControl(srcIdx)
        CASE UI_KIND_TEXTBOX
            bmpPath = GetTextboxTextByName(uiElems(srcIdx).name)
        CASE ELSE
            bmpPath = RTRIM$(uiElems(srcIdx).text)
        END SELECT
    END IF

    modeText = GetSelectedRadioValue(uiElems(elemIdx).modeGroup)
    modeVal = VALINT(modeText)
    IF modeVal = 0 THEN
        IF UCASE$(TRIM$(uiElems(elemIdx).drawStyle)) = "FIT" OR _
           UCASE$(TRIM$(uiElems(elemIdx).drawStyle)) = "FIT_ASPECT" THEN
            modeVal = 4
        ELSEIF TRIM$(uiElems(elemIdx).modeGroup) = "" THEN
            modeVal = 3
        ELSEIF bmpPath <> "" THEN
            modeVal = 1
        END IF
    END IF

    IF bmpPath = "" OR modeVal = 0 THEN EXIT SUB

    pw = innerX2 - innerX1 + 1
    ph = innerY2 - innerY1 + 1
    IF pw < 1 OR ph < 1 THEN EXIT SUB

    targetW = pw
    targetH = ph
    srcBmpW = 0
    srcBmpH = 0

    IF CachedPreviewBmpDimensions(bmpPath, srcBmpW, srcBmpH) <> 0 THEN
        SELECT CASE modeVal
        CASE 1, 2
            IF SCR_W > 0 THEN
                targetW = (CLNG(srcBmpW) * pw + (SCR_W \ 2)) \ SCR_W
            END IF
            IF SCR_H > 0 THEN
                targetH = (CLNG(srcBmpH) * ph + (SCR_H \ 2)) \ SCR_H
            END IF
        CASE 3
            targetW = pw
            targetH = ph
        CASE 4
            IF srcBmpW > 0 AND srcBmpH > 0 THEN
                IF srcBmpW <= pw AND srcBmpH <= ph THEN
                    targetW = srcBmpW
                    targetH = srcBmpH
                ELSEIF CLNG(srcBmpW) * ph >= CLNG(srcBmpH) * pw THEN
                    targetW = pw
                    targetH = (CLNG(srcBmpH) * pw + (srcBmpW \ 2)) \ srcBmpW
                ELSE
                    targetH = ph
                    targetW = (CLNG(srcBmpW) * ph + (srcBmpH \ 2)) \ srcBmpH
                END IF
            ELSE
                targetW = pw
                targetH = ph
            END IF
        END SELECT
    END IF

    IF targetW < 1 THEN targetW = 1
    IF targetH < 1 THEN targetH = 1

    IF modeVal = 4 AND layoutLiveResizeActive <> 0 AND drawLayoutWindow = layoutLiveResizeWindow THEN
        liveNormPath = NormalizePath(bmpPath)
        liveKeyPrefix = liveNormPath + "|"
        useLiveCachedPreview = 0

        IF previewLoaded <> 0 AND previewImg <> 0 AND previewImgW > 0 AND previewImgH > 0 THEN
            IF LEFT$(previewPath, LEN(liveKeyPrefix)) = liveKeyPrefix THEN useLiveCachedPreview = -1
        END IF

        IF useLiveCachedPreview <> 0 THEN
            liveDrawW = previewImgW
            liveDrawH = previewImgH
            IF liveDrawW <= pw AND liveDrawH <= ph THEN
                liveDrawX = innerX1 + (pw - liveDrawW) \ 2
                liveDrawY = innerY1 + (ph - liveDrawH) \ 2
                VIEW SCREEN (innerClipL, innerClipT)-(innerClipR, innerClipB)
                PUT (liveDrawX, liveDrawY), previewImg, PSET
                VIEW
            ELSE
                DrawStringClipped innerX1 + 6, innerY1 + 6, "Resizing...", COL_TEXT, innerClipL, innerClipT, innerClipR, innerClipB
            END IF
        ELSE
            DrawStringClipped innerX1 + 6, innerY1 + 6, "Resizing...", COL_TEXT, innerClipL, innerClipT, innerClipR, innerClipB
        END IF

        EXIT SUB
    END IF

    EnsurePreviewBitmap bmpPath, targetW, targetH
    IF previewLoaded = 0 OR previewPix = 0 OR previewW <= 0 OR previewH <= 0 THEN
        DrawStringClipped innerX1 + 6, innerY1 + 6, "No Preview", COL_TEXT, innerClipL, innerClipT, innerClipR, innerClipB
        EXIT SUB
    END IF

    SELECT CASE modeVal
    CASE 1
        drawW = previewW
        drawH = previewH
        IF previewImg <> 0 AND previewImgW > 0 AND previewImgH > 0 THEN
            drawW = previewImgW
            drawH = previewImgH
        END IF
        IF drawW < 1 THEN drawW = 1
        IF drawH < 1 THEN drawH = 1
        ox = innerX1 + (pw - drawW) \ 2
        oy = innerY1 + (ph - drawH) \ 2

        IF previewImg <> 0 AND previewImgW = drawW AND previewImgH = drawH AND _
           ox >= innerX1 AND oy >= innerY1 AND ox + drawW - 1 <= innerX2 AND oy + drawH - 1 <= innerY2 THEN
            VIEW SCREEN (innerClipL, innerClipT)-(innerClipR, innerClipB)
            PUT (ox, oy), previewImg, PSET
            VIEW
        ELSE
            FOR y = 0 TO drawH - 1
                IF oy + y >= innerClipT AND oy + y <= innerClipB THEN
                    sy = (CLNG(y) * previewH) \ drawH
                    IF sy < 0 THEN sy = 0
                    IF sy >= previewH THEN sy = previewH - 1
                    FOR x = 0 TO drawW - 1
                        IF ox + x >= innerClipL AND ox + x <= innerClipR THEN
                            sx = (CLNG(x) * previewW) \ drawW
                            IF sx < 0 THEN sx = 0
                            IF sx >= previewW THEN sx = previewW - 1
                            PSET (ox + x, oy + y), previewPix[CLNG(sy) * previewW + sx]
                        END IF
                    NEXT
                END IF
            NEXT
        END IF

    CASE 2
        drawW = previewW
        drawH = previewH
        IF previewImg <> 0 AND previewImgW > 0 AND previewImgH > 0 THEN
            drawW = previewImgW
            drawH = previewImgH
        END IF
        IF drawW < 1 THEN drawW = 1
        IF drawH < 1 THEN drawH = 1

        FOR ty = innerY1 TO innerY2 STEP drawH
            FOR tx = innerX1 TO innerX2 STEP drawW
                IF previewImg <> 0 AND previewImgW = drawW AND previewImgH = drawH AND _
                   tx + drawW - 1 <= innerX2 AND ty + drawH - 1 <= innerY2 THEN
                    VIEW SCREEN (innerClipL, innerClipT)-(innerClipR, innerClipB)
                    PUT (tx, ty), previewImg, PSET
                    VIEW
                ELSE
                    FOR y = 0 TO drawH - 1
                        IF ty + y >= innerClipT AND ty + y <= innerClipB THEN
                            sy = (CLNG(y) * previewH) \ drawH
                            IF sy < 0 THEN sy = 0
                            IF sy >= previewH THEN sy = previewH - 1
                            FOR x = 0 TO drawW - 1
                                IF tx + x >= innerClipL AND tx + x <= innerClipR THEN
                                    sx = (CLNG(x) * previewW) \ drawW
                                    IF sx < 0 THEN sx = 0
                                    IF sx >= previewW THEN sx = previewW - 1
                                    PSET (tx + x, ty + y), previewPix[CLNG(sy) * previewW + sx]
                                END IF
                            NEXT
                        END IF
                    NEXT
                END IF
            NEXT
        NEXT

    CASE 3
        IF previewImg <> 0 AND previewImgW = pw AND previewImgH = ph THEN
            VIEW SCREEN (innerClipL, innerClipT)-(innerClipR, innerClipB)
            PUT (innerX1, innerY1), previewImg, PSET
            VIEW
        ELSE
            FOR y = innerY1 TO innerY2
                IF y >= innerClipT AND y <= innerClipB THEN
                    sy = (CLNG(y - innerY1) * previewH) \ ph
                    IF sy < 0 THEN sy = 0
                    IF sy >= previewH THEN sy = previewH - 1
                    FOR x = innerX1 TO innerX2
                        IF x >= innerClipL AND x <= innerClipR THEN
                            sx = (CLNG(x - innerX1) * previewW) \ pw
                            IF sx < 0 THEN sx = 0
                            IF sx >= previewW THEN sx = previewW - 1
                            PSET (x, y), previewPix[CLNG(sy) * previewW + sx]
                        END IF
                    NEXT
                END IF
            NEXT
        END IF

    CASE 4
        drawW = targetW
        drawH = targetH
        IF drawW < 1 THEN drawW = 1
        IF drawH < 1 THEN drawH = 1
        IF drawW > pw THEN drawW = pw
        IF drawH > ph THEN drawH = ph

        drawX1 = innerX1 + (pw - drawW) \ 2
        drawY1 = innerY1 + (ph - drawH) \ 2

        IF previewImg <> 0 AND previewImgW = drawW AND previewImgH = drawH THEN
            VIEW SCREEN (innerClipL, innerClipT)-(innerClipR, innerClipB)
            PUT (drawX1, drawY1), previewImg, PSET
            VIEW
        ELSE
            FOR y = 0 TO drawH - 1
                IF drawY1 + y >= innerClipT AND drawY1 + y <= innerClipB THEN
                    sy = (CLNG(y) * previewH) \ drawH
                    IF sy < 0 THEN sy = 0
                    IF sy >= previewH THEN sy = previewH - 1
                    FOR x = 0 TO drawW - 1
                        IF drawX1 + x >= innerClipL AND drawX1 + x <= innerClipR THEN
                            sx = (CLNG(x) * previewW) \ drawW
                            IF sx < 0 THEN sx = 0
                            IF sx >= previewW THEN sx = previewW - 1
                            PSET (drawX1 + x, drawY1 + y), previewPix[CLNG(sy) * previewW + sx]
                        END IF
                    NEXT
                END IF
            NEXT
        END IF
    END SELECT
END SUB


