    okPressed = 0
    cancelPressed = 0
    closePressed = 0
    oldMx = mx
    oldMy = my
    ShowGuiConfirmBox = 0

    SCREENLOCK
    cursorBackValid = 0
    DrawDesktop
    IF layoutWindowCount > 0 THEN
        DrawAllLayoutWindows
    ELSE
        DrawWindows
    END IF
    DrawTaskbar 0
    DrawGuiConfirmBox titleText, msgText, x1, y1, x2, y2, okPressed, cancelPressed, closePressed
    SaveCursorBackBuffer mx, my
    DrawCursor mx, my
    SCREENUNLOCK

    DO
        mouseOk = (GETMOUSE(mx, my, mw, mb) = 0)
        IF mouseOk THEN
            mx = ClampI(mx, 0, SCR_W - 1)
            my = ClampI(my, 0, SCR_H - 1)
        ELSE
            mx = oldMx
            my = oldMy
            mb = 0
        END IF

        primaryNow = IsPrimaryButtonPressed(mb)

        IF primaryNow <> 0 AND prevPrimary = 0 THEN
            okPressed = InRect(mx, my, okX1, okY1, okX2, okY2)
            cancelPressed = InRect(mx, my, cancelX1, cancelY1, cancelX2, cancelY2)
            closePressed = GuiMessageCloseHit(mx, my)

            SCREENLOCK
            RestoreCursorBackBuffer
            DrawGuiConfirmBox titleText, msgText, x1, y1, x2, y2, okPressed, cancelPressed, closePressed
            SaveCursorBackBuffer mx, my
            DrawCursor mx, my
            SCREENUNLOCK
        END IF

        IF primaryNow = 0 AND prevPrimary <> 0 THEN
            IF okPressed <> 0 THEN
                ShowGuiConfirmBox = -1
                EXIT DO
            END IF
            IF cancelPressed <> 0 OR closePressed <> 0 THEN
                ShowGuiConfirmBox = 0
                EXIT DO
            END IF

            okPressed = 0
            cancelPressed = 0
            closePressed = 0

            SCREENLOCK
            RestoreCursorBackBuffer
            DrawGuiConfirmBox titleText, msgText, x1, y1, x2, y2, okPressed, cancelPressed, closePressed
            SaveCursorBackBuffer mx, my
            DrawCursor mx, my
            SCREENUNLOCK
        ELSEIF mx <> oldMx OR my <> oldMy THEN
            DrawCursorOnly mx, my
        END IF

        k = INKEY$
        IF k <> "" THEN
            IF k = CHR$(13) THEN
                ShowGuiConfirmBox = -1
                EXIT DO
            END IF
            IF k = CHR$(27) THEN
                ShowGuiConfirmBox = 0
                EXIT DO
            END IF
        END IF

        oldMx = mx
        oldMy = my
        prevPrimary = primaryNow
        SoundServiceAt TIMER
        SLEEP 10
    LOOP

    DO
        mouseOk = (GETMOUSE(mx, my, mw, mb) = 0)
        IF mouseOk = 0 THEN EXIT DO
        IF IsPrimaryButtonPressed(mb) = 0 THEN EXIT DO
        SoundServiceAt TIMER
        SLEEP 10
    LOOP

    SCREENLOCK
    cursorBackValid = 0
    DrawDesktop
    IF layoutWindowCount > 0 THEN
        DrawAllLayoutWindows
    ELSE
        DrawWindows
    END IF
    DrawTaskbar 0
    SaveCursorBackBuffer mx, my
    DrawCursor mx, my
    SCREENUNLOCK
END FUNCTION

SUB DrawGuiThreeButtonBox(BYVAL titleText AS STRING, BYVAL msgText AS STRING, BYVAL leftText AS STRING, BYVAL middleText AS STRING, BYVAL rightText AS STRING, BYVAL boxX1 AS INTEGER, BYVAL boxY1 AS INTEGER, BYVAL boxX2 AS INTEGER, BYVAL boxY2 AS INTEGER, BYVAL leftPressed AS INTEGER, BYVAL middlePressed AS INTEGER, BYVAL rightPressed AS INTEGER, BYVAL closePressed AS INTEGER)
    DIM leftX1 AS INTEGER
    DIM leftY1 AS INTEGER
    DIM leftX2 AS INTEGER
    DIM leftY2 AS INTEGER
    DIM middleX1 AS INTEGER
    DIM middleY1 AS INTEGER
    DIM middleX2 AS INTEGER
    DIM middleY2 AS INTEGER
    DIM rightX1 AS INTEGER
    DIM rightY1 AS INTEGER
    DIM rightX2 AS INTEGER
    DIM rightY2 AS INTEGER
    DIM lineOne AS STRING
    DIM lineTwo AS STRING
    DIM msgWork AS STRING
    DIM totalW AS INTEGER

    DrawBevelBox boxX1, boxY1, boxX2, boxY2, 0
    LINE (boxX1 + 2, boxY1 + 20)-(boxX2 - 2, boxY2 - 2), COL_CONTROL_BG, BF
    DrawThemedTitleBar boxX1 + 1, boxY1 + 1, boxX2 - 1, boxY1 + 18, -1

    IF TRIM$(titleText) <> "" THEN
        DRAW STRING (boxX1 + 8, boxY1 + 6), LEFT$(TRIM$(titleText), 36), COL_TEXT_INV
    ELSE
        DRAW STRING (boxX1 + 8, boxY1 + 6), "Confirm", COL_TEXT_INV
    END IF

    DrawBevelBox boxX2 - 18, boxY1 + 3, boxX2 - 4, boxY1 + 17, closePressed
    DrawCloseGlyph boxX2 - 18, boxY1 + 3, boxX2 - 4, boxY1 + 17

    msgWork = TRIM$(msgText)
    IF LEN(msgWork) <= 38 THEN
        lineOne = msgWork
        lineTwo = ""
    ELSE
        lineOne = LEFT$(msgWork, 38)
        lineTwo = MID$(msgWork, 39, 38)
    END IF

    IF lineOne <> "" THEN DRAW STRING (boxX1 + 18, boxY1 + 40), lineOne, COL_TEXT
    IF lineTwo <> "" THEN DRAW STRING (boxX1 + 18, boxY1 + 54), lineTwo, COL_TEXT

    totalW = 70 + 12 + 96 + 12 + 70
    leftX1 = boxX1 + ((boxX2 - boxX1 - totalW) \ 2)
    leftY1 = boxY2 - 34
    leftX2 = leftX1 + 70
    leftY2 = leftY1 + 22

    middleX1 = leftX2 + 12
    middleY1 = leftY1
    middleX2 = middleX1 + 96
    middleY2 = leftY2

    rightX1 = middleX2 + 12
    rightY1 = leftY1
    rightX2 = rightX1 + 70
    rightY2 = leftY2

    DrawButtonBevelBox leftX1, leftY1, leftX2, leftY2, leftPressed
    DRAW STRING (leftX1 + ((70 - LEN(leftText) * 8) \ 2), leftY1 + 7), leftText, COL_TEXT

    DrawButtonBevelBox middleX1, middleY1, middleX2, middleY2, middlePressed
    DRAW STRING (middleX1 + ((96 - LEN(middleText) * 8) \ 2), middleY1 + 7), middleText, COL_TEXT

    DrawButtonBevelBox rightX1, rightY1, rightX2, rightY2, rightPressed
    DRAW STRING (rightX1 + ((70 - LEN(rightText) * 8) \ 2), rightY1 + 7), rightText, COL_TEXT
END SUB

