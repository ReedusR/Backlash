    DrawClockTimePopup
END SUB



SUB DrawGradientRgbRect(BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER, _
                        BYVAL r1 AS INTEGER, BYVAL g1 AS INTEGER, BYVAL b1 AS INTEGER, _
                        BYVAL r2 AS INTEGER, BYVAL g2 AS INTEGER, BYVAL b2 AS INTEGER, BYVAL vertical AS INTEGER)
    DIM rr AS INTEGER
    DIM gg AS INTEGER
    DIM bb AS INTEGER
    DIM posn AS INTEGER
    DIM span AS INTEGER
    DIM x AS INTEGER
    DIM y AS INTEGER

    IF x2 < x1 OR y2 < y1 THEN EXIT SUB

    r1 = ClampI(r1, 0, 255)
    g1 = ClampI(g1, 0, 255)
    b1 = ClampI(b1, 0, 255)
    r2 = ClampI(r2, 0, 255)
    g2 = ClampI(g2, 0, 255)
    b2 = ClampI(b2, 0, 255)

    IF vertical <> 0 THEN
        span = y2 - y1
        IF span < 1 THEN span = 1
        FOR y = y1 TO y2
            posn = y - y1
            rr = r1 + ((r2 - r1) * posn) \ span
            gg = g1 + ((g2 - g1) * posn) \ span
            bb = b1 + ((b2 - b1) * posn) \ span
            LINE (x1, y)-(x2, y), MakeCol(rr, gg, bb)
        NEXT
    ELSE
        span = x2 - x1
        IF span < 1 THEN span = 1
        FOR x = x1 TO x2
            posn = x - x1
            rr = r1 + ((r2 - r1) * posn) \ span
            gg = g1 + ((g2 - g1) * posn) \ span
            bb = b1 + ((b2 - b1) * posn) \ span
            LINE (x, y1)-(x, y2), MakeCol(rr, gg, bb)
        NEXT
    END IF
END SUB

SUB DrawThemedTitleBar(BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER, BYVAL activeFlag AS INTEGER)
    IF activeFlag = 0 THEN
        LINE (x1, y1)-(x2, y2), uiStyle.titleInactiveCol, BF
        EXIT SUB
    END IF

    IF cfg.colorDepth > 8 AND theme.titlebarGradient <> 0 AND (uiStyle.titleStyle = "CLASSIC" OR uiStyle.titleModern <> 0) THEN
        DrawCachedTitleGradient x1, y1, x2, y2
    ELSE
        LINE (x1, y1)-(x2, y2), uiStyle.titleActiveCol, BF
    END IF
    IF uiStyle.titleModern <> 0 THEN LINE (x1, y2)-(x2, y2), uiStyle.bevelLoCol
END SUB

SUB RebuildTaskbarLayoutCache()
    TASKBAR_X1 = 0
    TASKBAR_X2 = SCR_W - 1
    TASKBAR_Y1 = TASKBAR_Y
    TASKBAR_Y2 = TASKBAR_Y + TASKBAR_H - 1
    IF TASKBAR_Y1 < 0 THEN TASKBAR_Y1 = 0
    IF TASKBAR_Y2 > SCR_H - 1 THEN TASKBAR_Y2 = SCR_H - 1

    TASKBAR_CLIENT_Y1 = TASKBAR_Y1 + 4
    TASKBAR_CLIENT_Y2 = TASKBAR_Y2 - 5
    IF TASKBAR_CLIENT_Y2 < TASKBAR_CLIENT_Y1 THEN TASKBAR_CLIENT_Y2 = TASKBAR_CLIENT_Y1

    TASKBAR_CLOCK_X2 = SCR_W - 5
    TASKBAR_CLOCK_X1 = TASKBAR_CLOCK_X2 - 74 + 1
    TASKBAR_CLOCK_Y1 = TASKBAR_CLIENT_Y1
    TASKBAR_CLOCK_Y2 = TASKBAR_CLIENT_Y2
END SUB

FUNCTION TaskbarHitFromPoint(BYVAL mouseX AS INTEGER, BYVAL mouseY AS INTEGER) AS INTEGER
    IF cfg.showTaskbar = 0 THEN RETURN 0
    IF InRect(mouseX, mouseY, TASKBAR_X1, TASKBAR_Y1, TASKBAR_X2, TASKBAR_Y2) THEN RETURN -1
    RETURN 0
END FUNCTION

FUNCTION TaskbarLaunchContextY() AS INTEGER
    IF lay.taskbarEdge = TASKBAR_EDGE_TOP THEN
        RETURN TASKBAR_Y2 + 2
    END IF
    RETURN TASKBAR_Y1 - LAUNCH_CTX_H - 2
END FUNCTION

FUNCTION TaskbarGradientSignature() AS LONG
    DIM sig AS LONG

    sig = CLNG(cfg.colorDepth) * 1009 + CLNG(SCR_W) * 3 + CLNG(TASKBAR_H) * 5 + CLNG(TASKBAR_Y) * 7
    sig = sig + CLNG(theme.taskbarR) * 7 + CLNG(theme.taskbarG) * 11 + CLNG(theme.taskbarB) * 13
    sig = sig + CLNG(theme.taskbarGradR) * 17 + CLNG(theme.taskbarGradG) * 19 + CLNG(theme.taskbarGradB) * 23
    sig = sig + CLNG(theme.taskbarGradient) * 29

    RETURN sig
END FUNCTION

FUNCTION TitleGradientSignature(BYVAL w AS INTEGER, BYVAL h AS INTEGER) AS LONG
    DIM sig AS LONG

    sig = CLNG(cfg.colorDepth) * 1009 + CLNG(w) * 3 + CLNG(h) * 5
    sig = sig + CLNG(theme.selectR) * 7 + CLNG(theme.selectG) * 11 + CLNG(theme.selectB) * 13
    sig = sig + CLNG(theme.titlebarGradR) * 17 + CLNG(theme.titlebarGradG) * 19 + CLNG(theme.titlebarGradB) * 23
    sig = sig + CLNG(theme.titlebarGradient) * 29

    RETURN sig
END FUNCTION

SUB DrawCachedTaskbarGradient()
    DIM sig AS LONG
    DIM y AS INTEGER
    DIM span AS INTEGER
    DIM rr AS INTEGER
    DIM gg AS INTEGER
    DIM bb AS INTEGER

    sig = TaskbarGradientSignature()

    IF taskbarGradCache <> 0 AND taskbarGradCacheValid <> 0 AND taskbarGradCacheSig = sig THEN
        PUT (TASKBAR_X1, TASKBAR_Y1), taskbarGradCache, PSET
        EXIT SUB
    END IF

    IF taskbarGradCache <> 0 THEN
        ImageDestroy taskbarGradCache
        taskbarGradCache = 0
    END IF

    taskbarGradCache = ImageCreate(SCR_W, TASKBAR_H, COL_TASKBAR)
    IF taskbarGradCache = 0 THEN
        DrawGradientRgbRect TASKBAR_X1, TASKBAR_Y1, TASKBAR_X2, TASKBAR_Y2, theme.taskbarR, theme.taskbarG, theme.taskbarB, _
                            theme.taskbarGradR, theme.taskbarGradG, theme.taskbarGradB, 1
        EXIT SUB
    END IF

    span = TASKBAR_H - 1
    IF span < 1 THEN span = 1

    FOR y = 0 TO TASKBAR_H - 1
        rr = theme.taskbarR + ((theme.taskbarGradR - theme.taskbarR) * y) \ span
        gg = theme.taskbarG + ((theme.taskbarGradG - theme.taskbarG) * y) \ span
        bb = theme.taskbarB + ((theme.taskbarGradB - theme.taskbarB) * y) \ span
        LINE taskbarGradCache, (0, y)-(SCR_W - 1, y), MakeCol(rr, gg, bb)
    NEXT

    taskbarGradCacheSig = sig
    taskbarGradCacheValid = -1

    PUT (TASKBAR_X1, TASKBAR_Y1), taskbarGradCache, PSET
END SUB

SUB DrawCachedTitleGradient(BYVAL x1 AS INTEGER, BYVAL y1 AS INTEGER, BYVAL x2 AS INTEGER, BYVAL y2 AS INTEGER)
    DIM w AS INTEGER
    DIM h AS INTEGER
    DIM sig AS LONG
    DIM x AS INTEGER
    DIM span AS INTEGER
    DIM rr AS INTEGER
    DIM gg AS INTEGER
    DIM bb AS INTEGER

    IF x2 < x1 OR y2 < y1 THEN EXIT SUB

    w = x2 - x1 + 1
    h = y2 - y1 + 1
    IF w <= 0 OR h <= 0 THEN EXIT SUB

    sig = TitleGradientSignature(w, h)

    IF titleGradCache <> 0 AND titleGradCacheValid <> 0 AND titleGradCacheSig = sig AND _
       titleGradCacheW = w AND titleGradCacheH = h THEN
        PUT (x1, y1), titleGradCache, PSET
        EXIT SUB
    END IF

    IF titleGradCache <> 0 THEN
        ImageDestroy titleGradCache
        titleGradCache = 0
    END IF

    titleGradCache = ImageCreate(w, h, COL_TITLE)
    IF titleGradCache = 0 THEN
        DrawGradientRgbRect x1, y1, x2, y2, theme.selectR, theme.selectG, theme.selectB, _
                            theme.titlebarGradR, theme.titlebarGradG, theme.titlebarGradB, 0
        EXIT SUB
    END IF

    span = w - 1
    IF span < 1 THEN span = 1

    FOR x = 0 TO w - 1
        rr = theme.selectR + ((theme.titlebarGradR - theme.selectR) * x) \ span
        gg = theme.selectG + ((theme.titlebarGradG - theme.selectG) * x) \ span
        bb = theme.selectB + ((theme.titlebarGradB - theme.selectB) * x) \ span
        LINE titleGradCache, (x, 0)-(x, h - 1), MakeCol(rr, gg, bb)
    NEXT

    titleGradCacheSig = sig
    titleGradCacheValid = -1
    titleGradCacheW = w
    titleGradCacheH = h

    PUT (x1, y1), titleGradCache, PSET
END SUB

FUNCTION NormalizePath(BYVAL p AS STRING) AS STRING
    DIM srcLen AS INTEGER
    DIM firstPos AS INTEGER
    DIM lastPos AS INTEGER
    DIM i AS INTEGER
    DIM outLen AS INTEGER
    DIM chCode AS INTEGER
    DIM srcPtr AS UBYTE PTR
    DIM dstPtr AS UBYTE PTR
    DIM outp AS STRING

    srcLen = LEN(p)
    IF srcLen <= 0 THEN RETURN ""

    srcPtr = CAST(UBYTE PTR, STRPTR(p))
    IF srcPtr = 0 THEN RETURN ""

    firstPos = 0
    DO WHILE firstPos < srcLen
        IF srcPtr[firstPos] <> 32 THEN EXIT DO
        firstPos = firstPos + 1
    LOOP

    lastPos = srcLen - 1
    DO WHILE lastPos >= firstPos
        IF srcPtr[lastPos] <> 32 THEN EXIT DO
        lastPos = lastPos - 1
    LOOP

    IF lastPos < firstPos THEN RETURN ""

    outp = SPACE$(lastPos - firstPos + 1)
    dstPtr = CAST(UBYTE PTR, STRPTR(outp))
    IF dstPtr = 0 THEN RETURN ""

    outLen = 0
    FOR i = firstPos TO lastPos
        chCode = srcPtr[i]
        IF chCode <> 47 THEN
            IF chCode >= 97 AND chCode <= 122 THEN chCode = chCode - 32
            dstPtr[outLen] = CUBYTE(chCode)
            outLen = outLen + 1
        END IF
    NEXT

    IF outLen <= 0 THEN RETURN ""
    IF outLen < LEN(outp) THEN RETURN LEFT$(outp, outLen)
    RETURN outp
END FUNCTION

FUNCTION LayoutFilePath(BYVAL appPath AS STRING) AS STRING
    DIM p AS INTEGER

    appPath = NormalizePath(appPath)
    p = INSTR(appPath, "#")
    IF p > 0 THEN RETURN LEFT$(appPath, p - 1)
    RETURN appPath
END FUNCTION

FUNCTION LayoutProfile(BYVAL appPath AS STRING) AS STRING
    DIM p AS INTEGER

    appPath = NormalizePath(appPath)
    p = INSTR(appPath, "#")
    IF p > 0 THEN RETURN UCASE$(TRIM$(MID$(appPath, p + 1)))
    RETURN ""
END FUNCTION

' ---------------------------
' Fast CFG cache lookup
' ---------------------------
' Config files are already parsed into memory. This index keeps hot paths like
' previews and app setup from walking the whole cache for every single key.

FUNCTION CfgReadCacheHash(BYREF cacheFile AS STRING, BYREF cacheSection AS STRING, BYREF cacheKey AS STRING) AS INTEGER
    DIM h AS UINTEGER
    DIM i AS INTEGER
    DIM textLen AS INTEGER
    DIM textPtr AS UBYTE PTR

    h = &H811C9DC5

    textLen = LEN(cacheFile)
    IF textLen > 0 THEN
        textPtr = CAST(UBYTE PTR, STRPTR(cacheFile))
        IF textPtr <> 0 THEN
            FOR i = 0 TO textLen - 1
                h = h XOR textPtr[i]
                h = h * 16777619
            NEXT
        END IF
    END IF

    h = h XOR 124
    h = h * 16777619

    textLen = LEN(cacheSection)
    IF textLen > 0 THEN
        textPtr = CAST(UBYTE PTR, STRPTR(cacheSection))
        IF textPtr <> 0 THEN
            FOR i = 0 TO textLen - 1
                h = h XOR textPtr[i]
                h = h * 16777619
            NEXT
        END IF
    END IF

    h = h XOR 124
    h = h * 16777619

    textLen = LEN(cacheKey)
    IF textLen > 0 THEN
        textPtr = CAST(UBYTE PTR, STRPTR(cacheKey))
        IF textPtr <> 0 THEN
            FOR i = 0 TO textLen - 1
                h = h XOR textPtr[i]
                h = h * 16777619
            NEXT
        END IF
    END IF

    RETURN CINT(h MOD CFG_READ_HASH_BUCKETS)
END FUNCTION

FUNCTION FindCfgReadCacheEntry(BYVAL cacheFile AS STRING, BYVAL cacheSection AS STRING, BYVAL cacheKey AS STRING) AS INTEGER
    DIM bucketIdx AS INTEGER
    DIM cacheIdx AS INTEGER

    IF cacheFile = "" OR cacheKey = "" THEN RETURN 0

    bucketIdx = CfgReadCacheHash(cacheFile, cacheSection, cacheKey)
    cacheIdx = cfgReadHashHead(bucketIdx)

    DO WHILE cacheIdx > 0
        IF cacheIdx <= cfgReadCacheCount THEN
            IF RTRIM$(cfgReadCacheFile(cacheIdx)) = cacheFile AND _
               RTRIM$(cfgReadCacheSection(cacheIdx)) = cacheSection AND _
               RTRIM$(cfgReadCacheKey(cacheIdx)) = cacheKey THEN
                RETURN cacheIdx
            END IF
        END IF
        cacheIdx = cfgReadHashNext(cacheIdx)
    LOOP

    RETURN 0
END FUNCTION

SUB ClearCfgReadHashIndex()
    DIM i AS INTEGER

    FOR i = 0 TO CFG_READ_HASH_BUCKETS - 1
        cfgReadHashHead(i) = 0
    NEXT

    FOR i = 1 TO CFG_READ_CACHE_MAX
        cfgReadHashNext(i) = 0
    NEXT
END SUB

SUB ClearCfgReadFileLoadedStorage()
    DIM i AS INTEGER

    FOR i = 1 TO cfgReadFileLoadedCount
        cfgReadFileLoaded(i) = ""
    NEXT

    cfgReadFileLoadedCount = 0
    cfgReadLastLoadedFile = ""
END SUB

SUB ClearCfgReadCacheStorage()
    DIM i AS INTEGER

    FOR i = 1 TO cfgReadCacheCount
        cfgReadCacheFile(i) = ""
        cfgReadCacheSection(i) = ""
        cfgReadCacheKey(i) = ""
        cfgReadCacheValue(i) = ""
        cfgReadHashNext(i) = 0
    NEXT

    cfgReadCacheCount = 0
    ClearCfgReadHashIndex
END SUB

SUB LinkCfgReadCacheEntry(BYVAL cacheIdx AS INTEGER)
    DIM bucketIdx AS INTEGER
    DIM cacheFile AS STRING
    DIM cacheSection AS STRING
    DIM cacheKey AS STRING

    IF cacheIdx < 1 OR cacheIdx > cfgReadCacheCount THEN EXIT SUB

    cacheFile = RTRIM$(cfgReadCacheFile(cacheIdx))
    cacheSection = RTRIM$(cfgReadCacheSection(cacheIdx))
    cacheKey = RTRIM$(cfgReadCacheKey(cacheIdx))
    IF cacheFile = "" OR cacheKey = "" THEN EXIT SUB

    bucketIdx = CfgReadCacheHash(cacheFile, cacheSection, cacheKey)
    cfgReadHashNext(cacheIdx) = cfgReadHashHead(bucketIdx)
    cfgReadHashHead(bucketIdx) = cacheIdx
END SUB

SUB RebuildCfgReadHashIndex()
    DIM i AS INTEGER

    ClearCfgReadHashIndex
    FOR i = 1 TO cfgReadCacheCount
        LinkCfgReadCacheEntry i
    NEXT
END SUB

SUB AddCfgReadCacheEntry(BYVAL cacheFile AS STRING, BYVAL cacheSection AS STRING, BYVAL cacheKey AS STRING, BYVAL cacheValue AS STRING)
    DIM cacheIdx AS INTEGER

    ' All internal callers pass canonicalized cache file/section/key text.
    ' Do not normalize the same strings again for every loaded CFG row.
    IF cacheFile = "" OR cacheKey = "" THEN EXIT SUB

    cacheIdx = FindCfgReadCacheEntry(cacheFile, cacheSection, cacheKey)
    IF cacheIdx > 0 THEN
        cfgReadCacheValue(cacheIdx) = cacheValue
        EXIT SUB
    END IF

    IF cfgReadCacheCount >= CFG_READ_CACHE_MAX THEN
        ClearCfgReadCacheStorage
        ClearCfgReadFileLoadedStorage
        cfgReadCacheOverflowed = -1
    END IF

    cfgReadCacheCount = cfgReadCacheCount + 1
    cfgReadCacheFile(cfgReadCacheCount) = cacheFile
    cfgReadCacheSection(cfgReadCacheCount) = cacheSection
    cfgReadCacheKey(cfgReadCacheCount) = cacheKey
    cfgReadCacheValue(cfgReadCacheCount) = cacheValue
    LinkCfgReadCacheEntry cfgReadCacheCount
END SUB
FUNCTION CfgReadFileAlreadyLoaded(BYVAL fileName AS STRING) AS INTEGER
    DIM cacheFile AS STRING
    DIM i AS INTEGER

    cacheFile = UCASE$(NormalizePath(LayoutFilePath(fileName)))
    IF cacheFile = "" THEN RETURN 0
    IF cfgReadLastLoadedFile = cacheFile THEN RETURN -1

    FOR i = 1 TO cfgReadFileLoadedCount
        IF RTRIM$(cfgReadFileLoaded(i)) = cacheFile THEN
            cfgReadLastLoadedFile = cacheFile
            RETURN -1
        END IF
    NEXT

    RETURN 0
END FUNCTION

SUB MarkCfgReadFileLoaded(BYVAL fileName AS STRING)
    DIM cacheFile AS STRING
    DIM i AS INTEGER

    cacheFile = UCASE$(NormalizePath(LayoutFilePath(fileName)))
    IF cacheFile = "" THEN EXIT SUB
    IF cfgReadLastLoadedFile = cacheFile THEN EXIT SUB

    FOR i = 1 TO cfgReadFileLoadedCount
        IF RTRIM$(cfgReadFileLoaded(i)) = cacheFile THEN
            cfgReadLastLoadedFile = cacheFile
            EXIT SUB
        END IF
    NEXT

    IF cfgReadFileLoadedCount >= CFG_READ_FILE_MAX THEN ClearCfgReadFileLoadedStorage
    cfgReadFileLoadedCount = cfgReadFileLoadedCount + 1
    cfgReadFileLoaded(cfgReadFileLoadedCount) = cacheFile
    cfgReadLastLoadedFile = cacheFile
END SUB

SUB LoadCfgReadCacheFile(BYVAL fileName AS STRING)
    DIM f AS INTEGER
    DIM lineIn AS STRING
    DIM p AS INTEGER
    DIM k AS STRING
    DIM v AS STRING
    DIM activeSection AS STRING
    DIM cacheFile AS STRING

    fileName = LayoutFilePath(fileName)
    cacheFile = UCASE$(NormalizePath(fileName))
    IF cacheFile = "" THEN EXIT SUB
    IF CfgReadFileAlreadyLoaded(fileName) <> 0 THEN EXIT SUB

    cfgReadCacheOverflowed = 0

    f = FREEFILE
    IF OPEN(fileName FOR INPUT AS #f) <> 0 THEN EXIT SUB

    activeSection = ""

    DO WHILE NOT EOF(f)
        LINE INPUT #f, lineIn
        lineIn = TRIM$(lineIn)

        IF lineIn = "" OR LEFT$(lineIn, 1) = "#" OR LEFT$(lineIn, 1) = ";" THEN
        ELSEIF LEFT$(lineIn, 1) = "[" AND RIGHT$(lineIn, 1) = "]" THEN
            activeSection = UCASE$(TRIM$(MID$(lineIn, 2, LEN(lineIn) - 2)))
        ELSE
            p = INSTR(lineIn, "=")
            IF p > 0 THEN
                k = UCASE$(TRIM$(LEFT$(lineIn, p - 1)))
                v = StripOuterQuotes(TRIM$(MID$(lineIn, p + 1)))

                ' Preserve first-match CFG behavior while preloading the full file.
                ' Later duplicate keys must not overwrite the cached first hit.
                IF FindCfgReadCacheEntry(cacheFile, activeSection, k) = 0 THEN
                    AddCfgReadCacheEntry cacheFile, activeSection, k, v
                END IF

                ' ReadCfgValue historically treated the first matching key in a file
                ' as valid even when that key lived inside a section. Keep one
                ' section-free first-hit alias here so fallback reads stay fast.
                IF FindCfgReadCacheEntry(cacheFile, "", k) = 0 THEN
                    AddCfgReadCacheEntry cacheFile, "", k, v
                END IF
            END IF
        END IF
    LOOP

    CLOSE #f
    IF cfgReadCacheOverflowed = 0 THEN MarkCfgReadFileLoaded fileName
END SUB

SUB InvalidateCfgReadCacheForFile(BYVAL fileName AS STRING)
    DIM normFile AS STRING
    DIM i AS INTEGER
    DIM cacheEntryRemoved AS INTEGER

    normFile = UCASE$(NormalizePath(LayoutFilePath(fileName)))
    IF normFile = "" THEN EXIT SUB
    IF cfgReadLastLoadedFile = normFile THEN cfgReadLastLoadedFile = ""

    cacheEntryRemoved = 0
    i = 1
    DO WHILE i <= cfgReadCacheCount
        IF RTRIM$(cfgReadCacheFile(i)) = normFile THEN
            cfgReadCacheFile(i) = cfgReadCacheFile(cfgReadCacheCount)
            cfgReadCacheSection(i) = cfgReadCacheSection(cfgReadCacheCount)
            cfgReadCacheKey(i) = cfgReadCacheKey(cfgReadCacheCount)
            cfgReadCacheValue(i) = cfgReadCacheValue(cfgReadCacheCount)
            cfgReadCacheFile(cfgReadCacheCount) = ""
            cfgReadCacheSection(cfgReadCacheCount) = ""
            cfgReadCacheKey(cfgReadCacheCount) = ""
            cfgReadCacheValue(cfgReadCacheCount) = ""
            cfgReadCacheCount = cfgReadCacheCount - 1
            cacheEntryRemoved = -1
        ELSE
            i = i + 1
        END IF
    LOOP

    i = 1
    DO WHILE i <= cfgReadFileLoadedCount
        IF RTRIM$(cfgReadFileLoaded(i)) = normFile THEN
            cfgReadFileLoaded(i) = cfgReadFileLoaded(cfgReadFileLoadedCount)
            cfgReadFileLoaded(cfgReadFileLoadedCount) = ""
            cfgReadFileLoadedCount = cfgReadFileLoadedCount - 1
        ELSE
            i = i + 1
        END IF
    LOOP

    IF cacheEntryRemoved <> 0 THEN RebuildCfgReadHashIndex
END SUB
FUNCTION ReadCfgValue(BYVAL fileName AS STRING, BYVAL keyName AS STRING, BYVAL defaultValue AS STRING) AS STRING
    DIM f AS INTEGER
    DIM lineIn AS STRING
    DIM p AS INTEGER
    DIM k AS STRING
    DIM v AS STRING
    DIM i AS INTEGER
    DIM cacheFile AS STRING
    DIM cacheKey AS STRING
    DIM resultValue AS STRING

    fileName = LayoutFilePath(ExpandLayoutDynamicText(fileName))
    keyName = ExpandLayoutDynamicText(keyName)
    cacheFile = UCASE$(NormalizePath(fileName))
    cacheKey = UCASE$(TRIM$(keyName))

    IF cfgWriteBatchCount > 0 THEN
        FOR i = cfgWriteBatchCount TO 1 STEP -1
            IF RTRIM$(cfgWriteBatchCmpFile(i)) = cacheFile AND _
               RTRIM$(cfgWriteBatchCmpKey(i)) = cacheKey THEN
                RETURN cfgWriteBatchValue(i)
            END IF
        NEXT
    END IF

    i = FindCfgReadCacheEntry(cacheFile, "", cacheKey)
    IF i > 0 THEN RETURN cfgReadCacheValue(i)

    ' Patch 9: first cache miss loads the whole CFG/SYS file once. Later
    ' key lookups use the parsed cache instead of reopening and rescanning.
    LoadCfgReadCacheFile fileName
    i = FindCfgReadCacheEntry(cacheFile, "", cacheKey)
    IF i > 0 THEN RETURN cfgReadCacheValue(i)

    ' Fully preloaded files already have every usable first-match key cached.
    IF CfgReadFileAlreadyLoaded(fileName) <> 0 THEN
        AddCfgReadCacheEntry cacheFile, "", cacheKey, defaultValue
        RETURN defaultValue
    END IF

    ' If the preload could not complete, keep the old one-key scan fallback.
    f = FREEFILE
    IF OPEN(fileName FOR INPUT AS #f) <> 0 THEN RETURN defaultValue

    resultValue = defaultValue

    DO WHILE NOT EOF(f)
        LINE INPUT #f, lineIn
        lineIn = TRIM$(lineIn)

        IF lineIn <> "" AND LEFT$(lineIn, 1) <> "#" AND LEFT$(lineIn, 1) <> ";" THEN
            p = INSTR(lineIn, "=")
            IF p > 0 THEN
                k = UCASE$(TRIM$(LEFT$(lineIn, p - 1)))
                v = StripOuterQuotes(TRIM$(MID$(lineIn, p + 1)))
                IF k = cacheKey THEN
                    resultValue = v
                    EXIT DO
                END IF
            END IF
        END IF
    LOOP

    CLOSE #f

    AddCfgReadCacheEntry cacheFile, "", cacheKey, resultValue

    RETURN resultValue

END FUNCTION

' Fast direct CFG lookup for one-off list-label reads.
' Unlike ReadCfgValue, this intentionally avoids preloading/caching the entire CFG.
FUNCTION ReadCfgValueNoCache(BYVAL fileName AS STRING, BYVAL keyName AS STRING, BYVAL defaultValue AS STRING) AS STRING
    DIM f AS INTEGER
    DIM lineIn AS STRING
    DIM p AS INTEGER
    DIM k AS STRING
    DIM v AS STRING
    DIM targetKey AS STRING
    DIM resultValue AS STRING

    fileName = LayoutFilePath(ExpandLayoutDynamicText(fileName))
    keyName = ExpandLayoutDynamicText(keyName)
    targetKey = UCASE$(TRIM$(keyName))
    IF fileName = "" OR targetKey = "" THEN RETURN defaultValue

    f = FREEFILE
    IF OPEN(fileName FOR INPUT AS #f) <> 0 THEN RETURN defaultValue

    resultValue = defaultValue

    DO WHILE NOT EOF(f)
        LINE INPUT #f, lineIn
        lineIn = TRIM$(lineIn)

        IF lineIn <> "" AND LEFT$(lineIn, 1) <> "#" AND LEFT$(lineIn, 1) <> ";" THEN
            p = INSTR(lineIn, "=")
            IF p > 0 THEN
                k = UCASE$(TRIM$(LEFT$(lineIn, p - 1)))
                v = StripOuterQuotes(TRIM$(MID$(lineIn, p + 1)))
                IF k = targetKey THEN
                    resultValue = v
                    EXIT DO
                END IF
            END IF
        END IF
    LOOP

    CLOSE #f
    RETURN resultValue
END FUNCTION

FUNCTION BDbgNum(BYVAL n AS INTEGER) AS STRING
    RETURN LTRIM$(STR$(n))
END FUNCTION

FUNCTION BDbgActiveState() AS STRING
    DIM s AS STRING
    DIM winIdx AS INTEGER
    DIM appPath AS STRING

    s = " activeWin=" + BDbgNum(activeLayoutWindow)
    s = s + " layoutCount=" + BDbgNum(layoutWindowCount)
    s = s + " cfgDepth=" + BDbgNum(cfg.colorDepth)
    s = s + " uiTab=" + BDbgNum(uiSelectedTab)
    s = s + " uiCount=" + BDbgNum(uiCount)
    s = s + " uiPressed=" + BDbgNum(uiPressedIndex)
    s = s + " uiFocus=" + BDbgNum(uiFocusIndex)
    s = s + " startMenu=" + BDbgNum(startMenuOpen)

    winIdx = activeLayoutWindow
    IF winIdx >= LBOUND(layoutWindows) AND winIdx <= UBOUND(layoutWindows) THEN
        s = s + " winUsed=" + BDbgNum(layoutWindows(winIdx).used)
        s = s + " winTab=" + BDbgNum(layoutWindows(winIdx).selectedTab)
        s = s + " winPressed=" + BDbgNum(layoutWindows(winIdx).pressedIndex)
        s = s + " winFocus=" + BDbgNum(layoutWindows(winIdx).focusIndex)
        s = s + " comboOpen=" + BDbgNum(comboOpenIndex(winIdx))
        appPath = RTRIM$(layoutWindows(winIdx).appPath)
        IF LEN(appPath) > 0 THEN s = s + " app=" + appPath
    END IF

    RETURN s
END FUNCTION

FUNCTION BDbgWinSlots() AS STRING
    DIM s AS STRING
    DIM z AS STRING
    DIM i AS INTEGER
    DIM winIdx AS INTEGER
    DIM appPath AS STRING

    s = " slots="
    FOR i = LBOUND(layoutWindows) TO UBOUND(layoutWindows)
        IF layoutWindows(i).used <> 0 THEN
            IF s <> " slots=" THEN s = s + ","
            s = s + BDbgNum(i) + ":"
            IF layoutWindows(i).active <> 0 THEN s = s + "A" ELSE s = s + "I"
            IF layoutWindows(i).minimized <> 0 THEN s = s + "M"
            IF layoutWindows(i).maximized <> 0 THEN s = s + "X"
            s = s + "#" + BDbgNum(layoutUiCount(i))
            appPath = RTRIM$(layoutWindows(i).appPath)
            IF appPath <> "" THEN s = s + "[" + appPath + "]"
        END IF
    NEXT

    z = " z="
    FOR i = LBOUND(layoutZOrder) TO UBOUND(layoutZOrder)
        winIdx = layoutZOrder(i)
        IF winIdx <> 0 THEN
            IF z <> " z=" THEN z = z + ","
            z = z + BDbgNum(winIdx)
        END IF
    NEXT

    RETURN s + z
END FUNCTION

SUB BDbgWindowEvent(BYVAL eventText AS STRING, BYVAL winIdx AS INTEGER)
    IF bdbgEnabled = 0 THEN EXIT SUB
    BDbgTrace eventText + " targetWin=" + BDbgNum(winIdx) + BDbgWinSlots()
END SUB

SUB BDbgHeartbeat(BYVAL loopName AS STRING, BYVAL nowTime AS DOUBLE)
    IF bdbgEnabled = 0 THEN EXIT SUB
    IF bdbgLastHeartbeat <> 0 THEN
        IF TimerElapsedSecondsAt(bdbgLastHeartbeat, nowTime) < 2.0 THEN EXIT SUB
    END IF
    bdbgLastHeartbeat = nowTime
    BDbgTrace "HEARTBEAT loop=" + loopName + BDbgWinSlots()
END SUB

SUB BDbgTrace(BYVAL msgText AS STRING)
    DIM f AS INTEGER

    IF bdbgEnabled = 0 THEN EXIT SUB

    f = FREEFILE
    IF OPEN(PATH_DEBUGLOG FOR APPEND AS #f) <> 0 THEN EXIT SUB
    PRINT #f, DATE$ + " " + TIME$ + " " + msgText + BDbgActiveState()
    CLOSE #f
END SUB

SUB BDbgInit()
    DIM flagText AS STRING
    DIM f AS INTEGER

    bdbgEnabled = 0
    bdbgLastHeartbeat = 0
    flagText = UCASE$(TRIM$(ReadCfgValue(PATH_DEBUGCFG, "enabled", "0")))

    IF BDBG_DIAGNOSTIC_FORCE_ENABLED <> 0 THEN
        bdbgEnabled = -1
    ELSEIF flagText = "1" OR flagText = "YES" OR flagText = "TRUE" OR flagText = "ON" THEN
        bdbgEnabled = -1
    END IF

    IF bdbgEnabled = 0 THEN EXIT SUB

    f = FREEFILE
    IF OPEN(PATH_DEBUGLOG FOR OUTPUT AS #f) = 0 THEN
        PRINT #f, DATE$ + " " + TIME$ + " DEBUG_LOG_BEGIN diagnostic_force=" + BDbgNum(BDBG_DIAGNOSTIC_FORCE_ENABLED)
        CLOSE #f
    END IF
END SUB

' ---------------------------
' File associations, file metadata, and associated opens
' ---------------------------

SUB LoadFileAssociations()
    DIM f AS INTEGER
    DIM lineIn AS STRING
    DIM p AS INTEGER
    DIM extName AS STRING
    DIM actionText AS STRING

    assocCount = 0
    assocLoaded = -1

    f = FREEFILE
    IF OPEN(PATH_ASSOCCFG FOR INPUT AS #f) <> 0 THEN EXIT SUB

    DO WHILE NOT EOF(f)
        LINE INPUT #f, lineIn
        lineIn = TRIM$(lineIn)

        IF lineIn <> "" AND LEFT$(lineIn, 1) <> "#" THEN
            p = INSTR(lineIn, "=")
            IF p > 0 THEN
                extName = UCASE$(TRIM$(LEFT$(lineIn, p - 1)))
                actionText = StripOuterQuotes(TRIM$(MID$(lineIn, p + 1)))
                IF LEFT$(extName, 1) = "." THEN extName = MID$(extName, 2)
                IF extName <> "" AND actionText <> "" THEN
                    IF assocCount < 128 THEN
                        assocCount = assocCount + 1
                        assocExt(assocCount) = extName
                        assocAction(assocCount) = actionText
                    END IF
                END IF
            END IF
        END IF
    LOOP

    CLOSE #f
END SUB

FUNCTION FileExtensionOf(BYVAL fileName AS STRING) AS STRING
    DIM i AS INTEGER
    DIM dotPos AS INTEGER
    DIM stopPos AS INTEGER
    DIM chCode AS INTEGER

    fileName = TRIM$(fileName)
    dotPos = 0
    stopPos = 0

    FOR i = LEN(fileName) TO 1 STEP -1
        chCode = ASC(fileName, i)
        IF chCode = 46 AND dotPos = 0 THEN dotPos = i
        IF chCode = 92 OR chCode = 58 THEN
            stopPos = i
            EXIT FOR
        END IF
    NEXT

    IF dotPos > stopPos AND dotPos < LEN(fileName) THEN
        RETURN UCASE$(MID$(fileName, dotPos + 1))
    END IF

    RETURN ""
END FUNCTION

FUNCTION LookupFileAssociation(BYVAL fileName AS STRING) AS STRING
    DIM extName AS STRING
    DIM i AS INTEGER

    IF assocLoaded = 0 THEN LoadFileAssociations

    extName = FileExtensionOf(fileName)
    IF extName = "" THEN RETURN ""

    FOR i = 1 TO assocCount
        IF assocExt(i) = extName THEN RETURN assocAction(i)
    NEXT

    FOR i = 1 TO assocCount
        IF assocExt(i) = "*" THEN RETURN assocAction(i)
    NEXT

    RETURN ""
END FUNCTION

FUNCTION LookupFileEditAssociation(BYVAL fileName AS STRING) AS STRING
    DIM extName AS STRING
    DIM editKey AS STRING
    DIM i AS INTEGER

    IF assocLoaded = 0 THEN LoadFileAssociations

    extName = FileExtensionOf(fileName)
    IF extName = "" THEN RETURN ""

    editKey = extName + "_EDIT"
    FOR i = 1 TO assocCount
        IF assocExt(i) = editKey THEN RETURN assocAction(i)
    NEXT

    RETURN ""
END FUNCTION

FUNCTION FileSupportsEditAssociation(BYVAL fileName AS STRING) AS INTEGER
    IF LookupFileEditAssociation(fileName) <> "" THEN RETURN -1
    RETURN 0
END FUNCTION

FUNCTION FileMaskAllowsFile(BYVAL fileName AS STRING, BYVAL maskText AS STRING) AS INTEGER
    DIM filterText AS STRING
    DIM extName AS STRING
    DIM workText AS STRING
    DIM itemText AS STRING
    DIM sepPos AS INTEGER

    filterText = UCASE$(TRIM$(maskText))
    IF filterText = "" OR filterText = "*.*" THEN RETURN -1
    extName = FileExtensionOf(fileName)
    workText = filterText

    DO WHILE workText <> ""
        sepPos = INSTR(workText, ";")
        IF sepPos > 0 THEN
            itemText = TRIM$(LEFT$(workText, sepPos - 1))
            workText = MID$(workText, sepPos + 1)
        ELSE
            itemText = TRIM$(workText)
            workText = ""
        END IF

        IF itemText = "*.*" THEN RETURN -1
        IF LEFT$(itemText, 2) = "*." THEN
            IF extName = MID$(itemText, 3) THEN RETURN -1
        ELSEIF itemText = extName THEN
            RETURN -1
        END IF
    LOOP

    RETURN 0
END FUNCTION

FUNCTION FileMatchesDialogMask(BYVAL fileName AS STRING, BYVAL maskText AS STRING) AS INTEGER
    DIM filterText AS STRING
    DIM actionText AS STRING
    DIM editActionText AS STRING
    DIM targetApp AS STRING
    DIM targetAppUpper AS STRING
    DIM targetAppNameUpper AS STRING
    DIM actionApp AS STRING
    DIM actionAppUpper AS STRING
    DIM actionAppNameUpper AS STRING
    DIM actionUpper AS STRING
    DIM editActionUpper AS STRING

    filterText = UCASE$(TRIM$(maskText))

    IF filterText = "EDIT_ASSOC" OR filterText = "$EDIT_ASSOC" THEN
        IF fileDlgTargetWin >= LBOUND(layoutWindows) AND fileDlgTargetWin <= UBOUND(layoutWindows) THEN
            IF layoutWindows(fileDlgTargetWin).used <> 0 THEN
                targetApp = NormalizePath(RTRIM$(layoutWindows(fileDlgTargetWin).appPath))
                targetAppUpper = UCASE$(targetApp)
                targetAppNameUpper = UCASE$(FileNameOnly(targetApp))
            END IF
        END IF

        editActionText = LookupFileEditAssociation(fileName)
        actionText = LookupFileAssociation(fileName)
        editActionUpper = UCASE$(editActionText)
        actionUpper = UCASE$(actionText)

        IF targetApp <> "" THEN
            IF LEFT$(editActionUpper, 4) = "APP:" THEN
                actionApp = NormalizePath(TRIM$(MID$(editActionText, 5)))
                actionAppUpper = UCASE$(actionApp)
                actionAppNameUpper = UCASE$(FileNameOnly(actionApp))
                IF actionAppUpper = targetAppUpper THEN RETURN -1
                IF actionAppNameUpper = targetAppNameUpper THEN RETURN -1
            END IF

            IF LEFT$(actionUpper, 4) = "APP:" THEN
                actionApp = NormalizePath(TRIM$(MID$(actionText, 5)))
                actionAppUpper = UCASE$(actionApp)
                actionAppNameUpper = UCASE$(FileNameOnly(actionApp))
                IF actionAppUpper = targetAppUpper THEN RETURN -1
                IF actionAppNameUpper = targetAppNameUpper THEN RETURN -1
            END IF
        END IF

        IF editActionText <> "" THEN RETURN -1
        RETURN 0
    END IF

    RETURN FileMaskAllowsFile(fileName, maskText)
END FUNCTION

FUNCTION FileNameOnly(BYVAL filePath AS STRING) AS STRING
    DIM i AS INTEGER
    DIM ch AS STRING

    filePath = NormalizePath(TRIM$(filePath))
    IF filePath = "" THEN RETURN ""

    FOR i = LEN(filePath) TO 1 STEP -1
        ch = MID$(filePath, i, 1)
        IF ch = CHR$(92) OR ch = ":" THEN
            IF i < LEN(filePath) THEN RETURN MID$(filePath, i + 1)
            RETURN ""
        END IF
    NEXT

    RETURN filePath
END FUNCTION

FUNCTION FileSizeBytes(BYVAL fileName AS STRING) AS LONGINT
    DIM n AS LONGINT

    fileName = NormalizePath(TRIM$(fileName))
    IF fileName = "" THEN RETURN 0

    ' Do not call DIR() here. This helper is used while other DIR() scans are active.
    ' FILELEN asks DOS for the directory-entry size without opening the file contents.
    n = FILELEN(fileName)
    IF n < 0 THEN n = 0

    RETURN n
END FUNCTION

FUNCTION FileSizeDescription(BYVAL fileName AS STRING) AS STRING
    DIM n AS LONGINT

    fileName = NormalizePath(TRIM$(fileName))
    IF fileName = "" THEN RETURN "Unavailable"
    IF DIR(fileName, &H37) = "" THEN RETURN "Unavailable"

    n = FileSizeBytes(fileName)
    RETURN PropertiesFileSizeText(n)
END FUNCTION

' Clears cached directory counts and sizes after files may have changed.
SUB ClearDirectoryStatsCache()
    ' File mutations clear cached visible-folder status text.
    dirStatsCacheCount = 0
    dirStatsCacheClock = 0
END SUB

FUNCTION DirectoryStatsCacheLookup(BYVAL dirName AS STRING, BYREF statsText AS STRING) AS INTEGER
    DIM keyText AS STRING
    DIM i AS INTEGER

    statsText = ""
    keyText = UCASE$(AbsoluteDirPath(TRIM$(dirName)))
    IF keyText = "" THEN RETURN 0

    FOR i = 1 TO dirStatsCacheCount
        IF dirStatsCachePath(i) = keyText THEN
            dirStatsCacheClock = dirStatsCacheClock + 1
            dirStatsCacheAge(i) = dirStatsCacheClock
            statsText = dirStatsCacheText(i)
            RETURN -1
        END IF
    NEXT

    RETURN 0
END FUNCTION

SUB DirectoryStatsCacheStore(BYVAL dirName AS STRING, BYVAL statsText AS STRING)
    DIM keyText AS STRING
    DIM i AS INTEGER
    DIM slotIdx AS INTEGER
    DIM oldestAge AS LONG

    keyText = UCASE$(AbsoluteDirPath(TRIM$(dirName)))
    IF keyText = "" THEN EXIT SUB
    IF TRIM$(statsText) = "" THEN EXIT SUB

    dirStatsCacheClock = dirStatsCacheClock + 1

    FOR i = 1 TO dirStatsCacheCount
        IF dirStatsCachePath(i) = keyText THEN
            dirStatsCacheText(i) = statsText
            dirStatsCacheAge(i) = dirStatsCacheClock
            EXIT SUB
        END IF
    NEXT

    IF dirStatsCacheCount < DIR_STATS_CACHE_MAX THEN
        dirStatsCacheCount = dirStatsCacheCount + 1
        slotIdx = dirStatsCacheCount
    ELSE
        slotIdx = 1
        oldestAge = dirStatsCacheAge(1)
        FOR i = 2 TO DIR_STATS_CACHE_MAX
            IF dirStatsCacheAge(i) < oldestAge THEN
                oldestAge = dirStatsCacheAge(i)
                slotIdx = i
            END IF
        NEXT
    END IF

    dirStatsCachePath(slotIdx) = keyText
    dirStatsCacheText(slotIdx) = statsText
    dirStatsCacheAge(slotIdx) = dirStatsCacheClock
END SUB

' Clears cached directory size totals after file changes.
SUB ClearDirectorySizeCache()
    ' File mutations clear the session size cache so Properties never reuses stale totals.
    dirSizeCacheCount = 0
    dirSizeCacheClock = 0
    ClearDirectoryStatsCache
END SUB

FUNCTION DirectorySizeCacheLookup(BYVAL dirName AS STRING, BYREF sizeBytes AS LONGINT) AS INTEGER
    DIM keyText AS STRING
    DIM i AS INTEGER

    sizeBytes = 0
    keyText = UCASE$(AbsoluteDirPath(TRIM$(dirName)))
    IF keyText = "" THEN RETURN 0

    FOR i = 1 TO dirSizeCacheCount
        IF dirSizeCachePath(i) = keyText THEN
            dirSizeCacheClock = dirSizeCacheClock + 1
            dirSizeCacheAge(i) = dirSizeCacheClock
            sizeBytes = dirSizeCacheBytes(i)
            RETURN -1
        END IF
    NEXT

    RETURN 0
END FUNCTION

SUB DirectorySizeCacheStore(BYVAL dirName AS STRING, BYVAL sizeBytes AS LONGINT)
    DIM keyText AS STRING
    DIM i AS INTEGER
    DIM slotIdx AS INTEGER
    DIM oldestAge AS LONG

    keyText = UCASE$(AbsoluteDirPath(TRIM$(dirName)))
    IF keyText = "" THEN EXIT SUB
    IF sizeBytes < 0 THEN sizeBytes = 0

    dirSizeCacheClock = dirSizeCacheClock + 1

    FOR i = 1 TO dirSizeCacheCount
        IF dirSizeCachePath(i) = keyText THEN
            dirSizeCacheBytes(i) = sizeBytes
            dirSizeCacheAge(i) = dirSizeCacheClock
            EXIT SUB
        END IF
    NEXT

    IF dirSizeCacheCount < DIR_SIZE_CACHE_MAX THEN
        dirSizeCacheCount = dirSizeCacheCount + 1
        slotIdx = dirSizeCacheCount
    ELSE
        slotIdx = 1
        oldestAge = dirSizeCacheAge(1)
        FOR i = 2 TO DIR_SIZE_CACHE_MAX
            IF dirSizeCacheAge(i) < oldestAge THEN
                oldestAge = dirSizeCacheAge(i)
                slotIdx = i
            END IF
        NEXT
    END IF

    dirSizeCachePath(slotIdx) = keyText
    dirSizeCacheBytes(slotIdx) = sizeBytes
    dirSizeCacheAge(slotIdx) = dirSizeCacheClock
END SUB

FUNCTION DirectoryTreeSizeBytesDirect(BYVAL dirName AS STRING) AS LONGINT
    DIM entries AS STRING
    DIM scanPos AS INTEGER
    DIM lineEnd AS INTEGER
    DIM entryLine AS STRING
    DIM tabPos AS INTEGER
    DIM fname AS STRING
    DIM fullName AS STRING
    DIM attrBits AS INTEGER
    DIM totalBytes AS LONGINT
    DIM childBytes AS LONGINT

    dirName = AbsoluteDirPath(TRIM$(dirName))
    IF dirName = "" THEN RETURN 0

    ' Build the current directory list once before recursion so nested scans do not destroy parent enumeration state.
    entries = DirectoryEntryList(dirName)
    totalBytes = 0
    scanPos = 1

    DO WHILE scanPos <= LEN(entries)
        lineEnd = INSTR(scanPos, entries, CHR$(10))
        IF lineEnd = 0 THEN lineEnd = LEN(entries) + 1
        entryLine = MID$(entries, scanPos, lineEnd - scanPos)
        tabPos = INSTR(entryLine, CHR$(9))

        IF tabPos > 0 THEN
            attrBits = VAL(LEFT$(entryLine, tabPos - 1))
            fname = MID$(entryLine, tabPos + 1)
            IF fname <> "." AND fname <> ".." THEN
                fullName = JoinPath(dirName, fname)
                IF (attrBits AND &H10) <> 0 THEN
                    IF DirectorySizeCacheLookup(fullName, childBytes) = 0 THEN
                        childBytes = DirectoryTreeSizeBytesDirect(fullName)
                        DirectorySizeCacheStore fullName, childBytes
                    END IF
                    totalBytes = totalBytes + childBytes
                ELSE
                    totalBytes = totalBytes + FileSizeBytes(fullName)
                END IF
            END IF
        END IF

        scanPos = lineEnd + 1
    LOOP

    DirectorySizeCacheStore dirName, totalBytes
    RETURN totalBytes
END FUNCTION


FUNCTION DirectoryTreeSizeBytes(BYVAL dirName AS STRING) AS LONGINT
    DIM totalBytes AS LONGINT

    dirName = AbsoluteDirPath(TRIM$(dirName))
    IF dirName = "" THEN RETURN 0
    IF DirectoryExistsForSize(dirName) = 0 THEN RETURN 0

    IF DirectorySizeCacheLookup(dirName, totalBytes) <> 0 THEN RETURN totalBytes

    totalBytes = DirectoryTreeSizeBytesDirect(dirName)
    DirectorySizeCacheStore dirName, totalBytes
    RETURN totalBytes
END FUNCTION

FUNCTION HumanFileSizeText(BYVAL sizeBytes AS LONGINT) AS STRING
    DIM unitValue AS LONGINT
    DIM kb AS LONGINT
    DIM mb AS LONGINT
    DIM gb AS LONGINT
    DIM resultText AS STRING
    DIM i AS INTEGER
    DIM slotIdx AS INTEGER
    DIM oldestAge AS LONG

    IF sizeBytes < 0 THEN sizeBytes = 0

    FOR i = 1 TO humanSizeTextCacheCount
        IF humanSizeTextCacheBytes(i) = sizeBytes THEN
            humanSizeTextCacheClock = humanSizeTextCacheClock + 1
            humanSizeTextCacheAge(i) = humanSizeTextCacheClock
            RETURN humanSizeTextCacheText(i)
        END IF
    NEXT

    kb = 1024
    mb = kb * 1024
    gb = mb * 1024

    IF sizeBytes < kb THEN
        resultText = NumberWithCommas(sizeBytes) + " bytes"
    ELSEIF sizeBytes < mb THEN
        unitValue = sizeBytes \ kb
        IF unitValue < 1 THEN unitValue = 1
        resultText = NumberWithCommas(unitValue) + "k"
    ELSEIF sizeBytes < gb THEN
        unitValue = sizeBytes \ mb
        IF unitValue < 1 THEN unitValue = 1
        resultText = NumberWithCommas(unitValue) + "MB"
    ELSE
        unitValue = sizeBytes \ gb
        IF unitValue < 1 THEN unitValue = 1
        resultText = NumberWithCommas(unitValue) + "GB"
    END IF

    humanSizeTextCacheClock = humanSizeTextCacheClock + 1
    IF humanSizeTextCacheCount < HUMAN_SIZE_TEXT_CACHE_MAX THEN
        humanSizeTextCacheCount = humanSizeTextCacheCount + 1
        slotIdx = humanSizeTextCacheCount
    ELSE
        slotIdx = 1
        oldestAge = humanSizeTextCacheAge(1)
        FOR i = 2 TO HUMAN_SIZE_TEXT_CACHE_MAX
            IF humanSizeTextCacheAge(i) < oldestAge THEN
                oldestAge = humanSizeTextCacheAge(i)
                slotIdx = i
            END IF
        NEXT
    END IF

    humanSizeTextCacheBytes(slotIdx) = sizeBytes
    humanSizeTextCacheText(slotIdx) = resultText
    humanSizeTextCacheAge(slotIdx) = humanSizeTextCacheClock

    RETURN resultText
END FUNCTION

FUNCTION DirectorySizeDescription(BYVAL dirName AS STRING) AS STRING
    DIM n AS LONGINT

    dirName = AbsoluteDirPath(TRIM$(dirName))
    IF dirName = "" THEN RETURN "Unavailable"
    IF DirectoryExistsForSize(dirName) = 0 THEN RETURN "Unavailable"

    ' Drive roots and normal folders must both use the recursive file total.
    ' Disk-allocation used-space is not a file total and can report a smaller number than a child folder.
    n = DirectoryTreeSizeBytes(dirName)
    RETURN PropertiesFileSizeText(n)
END FUNCTION

FUNCTION HumanFileSizePreciseText(BYVAL sizeBytes AS LONGINT) AS STRING
    DIM unitBytes AS LONGINT
    DIM unitName AS STRING
    DIM scaledValue AS LONGINT
    DIM wholePart AS LONGINT
    DIM fracPart AS INTEGER
    DIM fracText AS STRING
    DIM kb AS LONGINT
    DIM mb AS LONGINT
    DIM gb AS LONGINT

    IF sizeBytes < 0 THEN sizeBytes = 0

    kb = 1024
    mb = kb * 1024
    gb = mb * 1024

    IF sizeBytes < kb THEN RETURN NumberWithCommas(sizeBytes) + " bytes"

    IF sizeBytes < mb THEN
        unitBytes = kb
        unitName = "k"
    ELSEIF sizeBytes < gb THEN
        unitBytes = mb
        unitName = "MB"
    ELSE
        unitBytes = gb
        unitName = "GB"
    END IF

    scaledValue = (sizeBytes * 100 + (unitBytes \ 2)) \ unitBytes
    wholePart = scaledValue \ 100
    fracPart = scaledValue MOD 100
    fracText = RIGHT$("00" + LTRIM$(STR$(fracPart)), 2)

    RETURN NumberWithCommas(wholePart) + "." + fracText + unitName
END FUNCTION

FUNCTION PropertiesFileSizeText(BYVAL sizeBytes AS LONGINT) AS STRING
    DIM byteText AS STRING

    IF sizeBytes < 0 THEN sizeBytes = 0

    byteText = NumberWithCommas(sizeBytes) + " bytes"
    IF sizeBytes < 1024 THEN RETURN byteText

    RETURN byteText + " (" + HumanFileSizePreciseText(sizeBytes) + ")"
END FUNCTION

FUNCTION NumberWithCommas(BYVAL n AS LONGINT) AS STRING
    DIM rawText AS STRING
    DIM outText AS STRING
    DIM i AS INTEGER
    DIM digitCount AS INTEGER
    DIM slotIdx AS INTEGER
    DIM oldestAge AS LONG

    FOR i = 1 TO numTextCacheCount
        IF numTextCacheValue(i) = n THEN
            numTextCacheClock = numTextCacheClock + 1
            numTextCacheAge(i) = numTextCacheClock
            RETURN numTextCacheText(i)
        END IF
    NEXT

    rawText = LTRIM$(STR$(n))
    outText = ""
    digitCount = 0

    FOR i = LEN(rawText) TO 1 STEP -1
        outText = MID$(rawText, i, 1) + outText
        digitCount = digitCount + 1
        IF i > 1 AND (digitCount MOD 3) = 0 THEN outText = "," + outText
    NEXT

    numTextCacheClock = numTextCacheClock + 1
    IF numTextCacheCount < NUM_TEXT_CACHE_MAX THEN
        numTextCacheCount = numTextCacheCount + 1
        slotIdx = numTextCacheCount
    ELSE
        slotIdx = 1
        oldestAge = numTextCacheAge(1)
        FOR i = 2 TO NUM_TEXT_CACHE_MAX
            IF numTextCacheAge(i) < oldestAge THEN
                oldestAge = numTextCacheAge(i)
                slotIdx = i
            END IF
        NEXT
    END IF

    numTextCacheValue(slotIdx) = n
    numTextCacheText(slotIdx) = outText
    numTextCacheAge(slotIdx) = numTextCacheClock

    RETURN outText
END FUNCTION

FUNCTION FilePaneFormattedSize(BYVAL sizeBytes AS LONGINT) AS STRING
    IF sizeBytes < 0 THEN sizeBytes = 0
    IF sizeBytes < 1024 THEN RETURN NumberWithCommas(sizeBytes) + "b"
    RETURN HumanFileSizeText(sizeBytes)
END FUNCTION

FUNCTION FilePaneSizeField(BYVAL sizeBytes AS LONGINT, BYVAL fieldW AS INTEGER) AS STRING
    DIM sizeText AS STRING

    IF fieldW < 4 THEN fieldW = 4

    sizeText = FilePaneFormattedSize(sizeBytes)
    IF LEN(sizeText) > fieldW THEN
        sizeText = LEFT$(sizeText, fieldW - 1) + "+"
    END IF

    RETURN RIGHT$(SPACE$(fieldW) + sizeText, fieldW)
END FUNCTION

FUNCTION DirectoryStatsText(BYVAL dirName AS STRING) AS STRING
    DIM entries AS STRING
    DIM scanPos AS INTEGER
    DIM lineEnd AS INTEGER
    DIM entryLine AS STRING
    DIM tabPos AS INTEGER
    DIM fname AS STRING
    DIM fullName AS STRING
    DIM attrBits AS INTEGER
    DIM fileCount AS INTEGER
    DIM totalBytes AS LONGINT
    DIM statsText AS STRING

    dirName = AbsoluteDirPath(TRIM$(dirName))
    IF dirName = "" THEN dirName = AbsoluteDirPath(".")

    IF DirectoryStatsCacheLookup(dirName, statsText) <> 0 THEN RETURN statsText

    ' Build the visible directory list before reading file sizes so file-size probes cannot corrupt enumeration.
    entries = DirectoryEntryList(dirName)
    fileCount = 0
    totalBytes = 0
    scanPos = 1

    DO WHILE scanPos <= LEN(entries)
        lineEnd = INSTR(scanPos, entries, CHR$(10))
        IF lineEnd = 0 THEN lineEnd = LEN(entries) + 1
        entryLine = MID$(entries, scanPos, lineEnd - scanPos)
        tabPos = INSTR(entryLine, CHR$(9))
        IF tabPos > 0 THEN
            attrBits = VAL(LEFT$(entryLine, tabPos - 1))
            fname = MID$(entryLine, tabPos + 1)
            IF fname <> "." AND fname <> ".." THEN
                IF (attrBits AND &H10) = 0 THEN
                    fullName = JoinPath(dirName, fname)
                    fileCount = fileCount + 1
                    totalBytes = totalBytes + FileSizeBytes(fullName)
                END IF
            END IF
        END IF
        scanPos = lineEnd + 1
    LOOP

    statsText = "Files: " + LTRIM$(STR$(fileCount)) + "   Total size: " + FilePaneFormattedSize(totalBytes)
    DirectoryStatsCacheStore dirName, statsText
    RETURN statsText
END FUNCTION

SUB BuildFileBrowserFileItemsFast(BYVAL elemIdx AS INTEGER, BYVAL dirName AS STRING, BYREF statsText AS STRING)
    DIM entries AS STRING
    DIM scanPos AS INTEGER
    DIM lineEnd AS INTEGER
    DIM entryLine AS STRING
    DIM tabPos AS INTEGER
    DIM fname AS STRING
    DIM fullName AS STRING
    DIM attrBits AS INTEGER
    DIM fileCount AS INTEGER
    DIM totalBytes AS LONGINT
    DIM fileBytes AS LONGINT

    statsText = ""
    IF elemIdx < 1 OR elemIdx > uiCount THEN EXIT SUB

    dirName = AbsoluteDirPath(TRIM$(dirName))
    IF dirName = "" THEN dirName = AbsoluteDirPath(".")

    ClearTempComboItems

    ' Navigator uses the same folder scan for the file list and status totals.
    ' This avoids rebuilding the directory list again only to count files.
    entries = DirectoryEntryList(dirName)
    fileCount = 0
    totalBytes = 0
    scanPos = 1

    DO WHILE scanPos <= LEN(entries)
        lineEnd = INSTR(scanPos, entries, CHR$(10))
        IF lineEnd = 0 THEN lineEnd = LEN(entries) + 1
        entryLine = MID$(entries, scanPos, lineEnd - scanPos)
        tabPos = INSTR(entryLine, CHR$(9))
        IF tabPos > 0 THEN
            attrBits = VAL(LEFT$(entryLine, tabPos - 1))
            fname = MID$(entryLine, tabPos + 1)
            IF fname <> "." AND fname <> ".." THEN
                IF (attrBits AND &H10) = 0 THEN
                    fullName = JoinPath(dirName, fname)
                    fileBytes = FileSizeBytes(fullName)
                    fileCount = fileCount + 1
                    totalBytes = totalBytes + fileBytes

                    IF FileMatchesDialogMask(fullName, uiElems(elemIdx).sourceMask) <> 0 THEN
                        IF tempComboItemCount < 256 THEN
                            tempComboItemCount = tempComboItemCount + 1
                            tempComboItems(tempComboItemCount) = FileNameOnly(fullName)
                            tempComboValues(tempComboItemCount) = "F:" + fullName
                        END IF
                    END IF
                END IF
            END IF
        END IF
        scanPos = lineEnd + 1
    LOOP

    SortTempComboItems 1, tempComboItemCount

    statsText = "Files: " + LTRIM$(STR$(fileCount)) + "   Total size: " + FilePaneFormattedSize(totalBytes)
    DirectoryStatsCacheStore dirName, statsText
END SUB

SUB UpdateDirectoryStatsControl(BYVAL winIdx AS INTEGER, BYVAL dirName AS STRING, BYVAL statsControlName AS STRING)
    DIM statsIdx AS INTEGER

    statsControlName = TRIM$(statsControlName)
    IF statsControlName = "" THEN EXIT SUB
    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(winIdx).used = 0 THEN EXIT SUB

    statsIdx = GetControlIndexByName(statsControlName)
    IF statsIdx < 1 OR statsIdx > uiCount THEN EXIT SUB

    uiElems(statsIdx).text = DirectoryStatsText(dirName)
    layoutUiElems(winIdx, statsIdx) = uiElems(statsIdx)
    MarkLayoutDirtyElement winIdx, statsIdx
    MarkLayoutWindowVisualDirty winIdx
END SUB


SUB ReadFilePaneMetadata(BYVAL fileName AS STRING, BYREF sizeBytes AS LONGINT, BYREF dateText AS STRING)
    DIM dt AS DOUBLE

    sizeBytes = 0
    dateText = "----------"

    fileName = NormalizePath(TRIM$(fileName))
    IF fileName = "" THEN EXIT SUB

    ' FILELEN avoids opening every visible file row just to build Navigator captions.
    sizeBytes = FileSizeBytes(fileName)

    dt = FileDateTime(fileName)
    IF dt > 0 THEN dateText = FORMAT(dt, "yyyy-mm-dd")
END SUB
FUNCTION FileAttributeBits(BYVAL fileName AS STRING) AS INTEGER
    DIM attrBits AS INTEGER
    DIM foundName AS STRING

    fileName = NormalizePath(TRIM$(fileName))
    IF fileName = "" THEN RETURN 0

    attrBits = 0
    foundName = DIR(fileName, &H37, attrBits)
    IF foundName = "" THEN RETURN 0

    RETURN attrBits
END FUNCTION

FUNCTION FileAttributeLetters(BYVAL attrBits AS INTEGER) AS STRING
    DIM s AS STRING
    DIM cacheIdx AS INTEGER

    cacheIdx = attrBits AND &H27
    IF fileAttrLettersCacheValid(cacheIdx) <> 0 THEN RETURN fileAttrLettersCacheText(cacheIdx)

    s = ""
    IF (cacheIdx AND &H01) <> 0 THEN
        s = s + "R"
    ELSE
        s = s + "-"
    END IF
    IF (cacheIdx AND &H20) <> 0 THEN
        s = s + "A"
    ELSE
        s = s + "-"
    END IF
    IF (cacheIdx AND &H04) <> 0 THEN
        s = s + "S"
    ELSE
        s = s + "-"
    END IF
    IF (cacheIdx AND &H02) <> 0 THEN
        s = s + "H"
    ELSE
        s = s + "-"
    END IF

    fileAttrLettersCacheText(cacheIdx) = s
    fileAttrLettersCacheValid(cacheIdx) = -1
    RETURN s
END FUNCTION

FUNCTION FilePaneCaption(BYVAL fileName AS STRING, BYVAL attrBits AS INTEGER, BYVAL paneW AS INTEGER, BYVAL paneFileSize AS LONGINT, BYVAL fileDateText AS STRING) AS STRING
    DIM nameText AS STRING
    DIM dateText AS STRING
    DIM attrText AS STRING
    DIM sizeText AS STRING
    DIM paddedName AS STRING
    DIM visibleChars AS INTEGER
    DIM nameW AS INTEGER
    DIM sizeW AS INTEGER
    DIM caption AS STRING

    fileName = NormalizePath(TRIM$(fileName))
    nameText = FileNameOnly(fileName)
    IF nameText = "" THEN nameText = fileName

    dateText = TRIM$(fileDateText)
    IF dateText = "" THEN dateText = "----------"
    attrText = FileAttributeLetters(attrBits)

    visibleChars = (paneW - 36) \ 8
    IF visibleChars < 24 THEN visibleChars = 24

    nameW = 12
    sizeW = 8

    paddedName = LEFT$(nameText + SPACE$(nameW), nameW)
    sizeText = FilePaneSizeField(paneFileSize, sizeW)
    caption = paddedName + "  " + sizeText + "  " + dateText + "  " + attrText

    IF LEN(caption) > visibleChars THEN caption = LEFT$(caption, visibleChars)
    RETURN caption
END FUNCTION

SUB SetControlStateByName(BYVAL controlName AS STRING, BYVAL stateFlag AS INTEGER)
    DIM idx AS INTEGER

    idx = GetControlIndexByName(controlName)
    IF idx < 1 OR idx > uiCount THEN EXIT SUB

    IF stateFlag <> 0 THEN
        uiElems(idx).state = -1
    ELSE
        uiElems(idx).state = 0
    END IF

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
            layoutUiElems(activeLayoutWindow, idx) = uiElems(idx)
            MarkLayoutDirtyElement activeLayoutWindow, idx
            MarkLayoutWindowVisualDirty activeLayoutWindow
        END IF
    END IF
END SUB



SUB LoadPropertiesAttributeControls(BYVAL fileName AS STRING)
    DIM attrBits AS INTEGER
    DIM readonlyControlName AS STRING
    DIM archiveControlName AS STRING
    DIM systemControlName AS STRING
    DIM hiddenControlName AS STRING

    attrBits = FileAttributeBits(fileName)

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
            readonlyControlName = TRIM$(AppCfgValue(RTRIM$(layoutWindows(activeLayoutWindow).appPath), "ATTR_READONLY_CONTROL", ""))
            archiveControlName = TRIM$(AppCfgValue(RTRIM$(layoutWindows(activeLayoutWindow).appPath), "ATTR_ARCHIVE_CONTROL", ""))
            systemControlName = TRIM$(AppCfgValue(RTRIM$(layoutWindows(activeLayoutWindow).appPath), "ATTR_SYSTEM_CONTROL", ""))
            hiddenControlName = TRIM$(AppCfgValue(RTRIM$(layoutWindows(activeLayoutWindow).appPath), "ATTR_HIDDEN_CONTROL", ""))
        END IF
    END IF

    IF readonlyControlName <> "" THEN SetControlStateByName readonlyControlName, (attrBits AND &H01)
    IF archiveControlName <> "" THEN SetControlStateByName archiveControlName, (attrBits AND &H20)
    IF systemControlName <> "" THEN SetControlStateByName systemControlName, (attrBits AND &H04)
    IF hiddenControlName <> "" THEN SetControlStateByName hiddenControlName, (attrBits AND &H02)
END SUB

FUNCTION PropertyAttributeBitsFromControls() AS INTEGER
    DIM attrBits AS INTEGER
    DIM readonlyControlName AS STRING
    DIM archiveControlName AS STRING
    DIM systemControlName AS STRING
    DIM hiddenControlName AS STRING

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
            readonlyControlName = TRIM$(AppCfgValue(RTRIM$(layoutWindows(activeLayoutWindow).appPath), "ATTR_READONLY_CONTROL", ""))
            archiveControlName = TRIM$(AppCfgValue(RTRIM$(layoutWindows(activeLayoutWindow).appPath), "ATTR_ARCHIVE_CONTROL", ""))
            systemControlName = TRIM$(AppCfgValue(RTRIM$(layoutWindows(activeLayoutWindow).appPath), "ATTR_SYSTEM_CONTROL", ""))
            hiddenControlName = TRIM$(AppCfgValue(RTRIM$(layoutWindows(activeLayoutWindow).appPath), "ATTR_HIDDEN_CONTROL", ""))
        END IF
    END IF

    attrBits = 0
    IF readonlyControlName <> "" THEN
        IF GetControlStateByName(readonlyControlName) <> 0 THEN attrBits = attrBits OR &H01
    END IF
    IF archiveControlName <> "" THEN
        IF GetControlStateByName(archiveControlName) <> 0 THEN attrBits = attrBits OR &H20
    END IF
    IF systemControlName <> "" THEN
        IF GetControlStateByName(systemControlName) <> 0 THEN attrBits = attrBits OR &H04
    END IF
    IF hiddenControlName <> "" THEN
        IF GetControlStateByName(hiddenControlName) <> 0 THEN attrBits = attrBits OR &H02
    END IF

    RETURN attrBits
END FUNCTION

FUNCTION SetFileAttributesByCommand(BYVAL fileName AS STRING, BYVAL attrBits AS INTEGER) AS INTEGER
    DIM regs AS __dpmi_regs
    DIM pathZ AS STRING
    DIM setBits AS INTEGER

    fileName = NormalizePath(TRIM$(fileName))
    IF fileName = "" THEN RETURN 0
    IF INSTR(fileName, "*") > 0 OR INSTR(fileName, "?") > 0 OR INSTR(fileName, CHR$(34)) > 0 THEN RETURN 0
    IF DIR(fileName, &H37) = "" THEN RETURN 0

    setBits = attrBits AND &H27
    pathZ = fileName + CHR$(0)

    DOSMEMPUT STRPTR(pathZ), LEN(pathZ), __tb

    regs.x.ax = &H4301
    regs.x.cx = setBits
    regs.x.ds = __tb \ 16
    regs.x.dx = __tb AND &H0F
    __dpmi_int( &H21, @regs )

    IF (regs.x.flags AND 1) <> 0 THEN RETURN 0
    IF (FileAttributeBits(fileName) AND &H27) = setBits THEN RETURN -1
    RETURN 0
END FUNCTION

SUB ApplyPropertiesAttributeChange()
    DIM attrBits AS INTEGER
    DIM propWin AS INTEGER
    DIM srcWin AS INTEGER
    DIM parentDir AS STRING
    DIM restoreWin AS INTEGER

    propWin = activeLayoutWindow
    srcWin = propertiesSourceWin
    attrBits = PropertyAttributeBitsFromControls()

    IF SetFileAttributesByCommand(propFilePath, attrBits) = 0 THEN
        LoadPropertiesAttributeControls propFilePath
    END IF

    parentDir = ParentPath(propFilePath)
    IF srcWin >= LBOUND(layoutWindows) AND srcWin <= UBOUND(layoutWindows) THEN
        IF layoutWindows(srcWin).used <> 0 AND parentDir <> "" THEN
            restoreWin = activeLayoutWindow
            ClearComboItemCache
            ConfigureFileBrowserWindow srcWin, parentDir
            activeLayoutWindow = restoreWin
        END IF
    END IF

    IF propWin >= LBOUND(layoutWindows) AND propWin <= UBOUND(layoutWindows) THEN
        IF layoutWindows(propWin).used <> 0 THEN
            activeLayoutWindow = propWin
            SyncGlobalsFromLayoutWindow propWin
            LoadPropertiesAttributeControls propFilePath
            SyncLayoutWindowFromGlobals propWin
        END IF
    END IF
END SUB

SUB OpenTextFileInLayoutApp(BYVAL fileName AS STRING, BYVAL appPath AS STRING)
    DIM fnameIdx AS INTEGER
    DIM editorIdx AS INTEGER
    DIM dataText AS STRING
    DIM savedWin AS INTEGER
    DIM fileControlName AS STRING
    DIM editorControlName AS STRING

    fileName = NormalizePath(TRIM$(fileName))
    appPath = NormalizePath(TRIM$(appPath))
    IF fileName = "" OR appPath = "" THEN EXIT SUB
    IF DIR(appPath) = "" THEN EXIT SUB

    fileControlName = TRIM$(AppCfgValue(appPath, "OPEN_FILE_PATH_CONTROL", ""))
    editorControlName = TRIM$(AppCfgValue(appPath, "OPEN_FILE_CONTENT_CONTROL", ""))
    IF fileControlName = "" OR editorControlName = "" THEN EXIT SUB

    RecentFilesAdd fileName

    savedWin = activeLayoutWindow
    IF savedWin >= LBOUND(layoutWindows) AND savedWin <= UBOUND(layoutWindows) THEN
        IF layoutWindows(savedWin).used <> 0 THEN SyncLayoutWindowFromGlobals savedWin
    END IF

    OpenLayoutAppWindow appPath

    IF activeLayoutWindow < LBOUND(layoutWindows) OR activeLayoutWindow > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(activeLayoutWindow).used = 0 THEN EXIT SUB

    SyncGlobalsFromLayoutWindow activeLayoutWindow

    fnameIdx = GetControlIndexByName(fileControlName)
    editorIdx = GetControlIndexByName(editorControlName)
    IF fnameIdx < 1 OR fnameIdx > uiCount THEN EXIT SUB
    IF editorIdx < 1 OR editorIdx > uiCount THEN EXIT SUB
    IF uiElems(fnameIdx).kindId <> UI_KIND_TEXTBOX THEN EXIT SUB
    IF uiElems(editorIdx).kindId <> UI_KIND_TEXTBOX THEN EXIT SUB

    dataText = ReadTextFileRaw(fileName)
    SetTextboxTextByName fileControlName, fileName
    SetTextboxTextByName editorControlName, dataText
    uiFocusIndex = editorIdx
    uiCaretPos = 0
    uiScrollY = 0
    uiScrollX = 0
    layoutWindows(activeLayoutWindow).focusIndex = editorIdx
    layoutWindows(activeLayoutWindow).caretPos = 0
    layoutWindows(activeLayoutWindow).scrollY = 0
    layoutWindows(activeLayoutWindow).scrollX = 0
    SyncLayoutWindowFromGlobals activeLayoutWindow

    IF layoutLoopRunning = 0 THEN
        layoutResumeOnly = -1
        ExecuteAppFile RTRIM$(layoutWindows(activeLayoutWindow).appPath)
    END IF
END SUB

SUB OpenFileInLayoutViewer(BYVAL fileName AS STRING, BYVAL appPath AS STRING, BYVAL targetControlName AS STRING)
    DIM targetIdx AS INTEGER
    DIM savedWin AS INTEGER
    DIM openFileActionText AS STRING

    fileName = NormalizePath(TRIM$(fileName))
    appPath = NormalizePath(TRIM$(appPath))
    targetControlName = TRIM$(targetControlName)
    IF fileName = "" OR appPath = "" OR targetControlName = "" THEN EXIT SUB
    IF DIR(fileName) = "" THEN EXIT SUB
    IF DIR(appPath) = "" THEN EXIT SUB

    savedWin = activeLayoutWindow
    IF savedWin >= LBOUND(layoutWindows) AND savedWin <= UBOUND(layoutWindows) THEN
        IF layoutWindows(savedWin).used <> 0 THEN SyncLayoutWindowFromGlobals savedWin
    END IF

    OpenLayoutAppWindow appPath

    IF activeLayoutWindow < LBOUND(layoutWindows) OR activeLayoutWindow > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(activeLayoutWindow).used = 0 THEN EXIT SUB

    SyncGlobalsFromLayoutWindow activeLayoutWindow

    targetIdx = GetControlIndexByName(targetControlName)
    IF targetIdx < 1 OR targetIdx > uiCount THEN EXIT SUB

    SetDialogTargetControlText activeLayoutWindow, targetControlName, fileName

    uiFocusIndex = 0
    uiCaretPos = 0
    uiScrollY = 0
    uiScrollX = 0
    layoutWindows(activeLayoutWindow).focusIndex = 0
    layoutWindows(activeLayoutWindow).caretPos = 0
    layoutWindows(activeLayoutWindow).scrollY = 0
    layoutWindows(activeLayoutWindow).scrollX = 0
    SyncLayoutWindowFromGlobals activeLayoutWindow

    openFileActionText = TRIM$(AppCfgValue(RTRIM$(layoutWindows(activeLayoutWindow).appPath), "OPEN_FILE_ACTION", ""))
    IF openFileActionText <> "" THEN HostAppAction activeLayoutWindow, openFileActionText

    IF layoutLoopRunning = 0 THEN
        layoutResumeOnly = -1
        ExecuteAppFile RTRIM$(layoutWindows(activeLayoutWindow).appPath)
    END IF
END SUB

SUB OpenFileByAssociation(BYVAL fileName AS STRING, BYVAL assocActionText AS STRING)
    DIM extName AS STRING
    DIM actionUpper AS STRING
    DIM appPath AS STRING
    DIM savedWin AS INTEGER
    DIM appFileSpec AS STRING
    DIM targetControlName AS STRING
    DIM spacePos AS INTEGER

    fileName = NormalizePath(TRIM$(fileName))
    assocActionText = TRIM$(assocActionText)
    IF fileName = "" OR assocActionText = "" THEN EXIT SUB

    extName = FileExtensionOf(fileName)
    actionUpper = UCASE$(assocActionText)

    IF actionUpper = "RUN" THEN
        IF extName = "EXE" OR extName = "COM" OR extName = "BAT" THEN
            RunAssociatedProgram fileName
        END IF
        EXIT SUB
    END IF

    IF LEFT$(actionUpper, 8) = "APPFILE:" THEN
        appFileSpec = TRIM$(MID$(assocActionText, 9))
        targetControlName = ""
        spacePos = INSTR(appFileSpec, " ")
        IF spacePos > 0 THEN
            targetControlName = TRIM$(MID$(appFileSpec, spacePos + 1))
            appPath = TRIM$(LEFT$(appFileSpec, spacePos - 1))
        ELSE
            appPath = appFileSpec
        END IF
        IF targetControlName = "" THEN EXIT SUB
        OpenFileInLayoutViewer fileName, appPath, targetControlName
        EXIT SUB
    END IF

    IF LEFT$(actionUpper, 4) <> "APP:" THEN EXIT SUB

    IF extName = "APP" THEN
        appPath = TRIM$(MID$(assocActionText, 5))
        IF UCASE$(appPath) <> "OPEN_LAYOUT" THEN EXIT SUB

        savedWin = activeLayoutWindow
        IF savedWin >= LBOUND(layoutWindows) AND savedWin <= UBOUND(layoutWindows) THEN
            IF layoutWindows(savedWin).used <> 0 THEN SyncLayoutWindowFromGlobals savedWin
        END IF

        OpenLayoutAppWindow fileName
        EXIT SUB
    END IF

    appPath = TRIM$(MID$(assocActionText, 5))
    OpenTextFileInLayoutApp fileName, appPath
END SUB

