    LINE (gx2 - 1, gy1)-(gx1 - 1, gy2), uiStyle.titleButtonSymbolCol
    LINE (gx2, gy1 + 1)-(gx1, gy2 + 1), uiStyle.titleButtonSymbolCol
END SUB

SUB DrawCheckMark(BYVAL x AS INTEGER, BYVAL y AS INTEGER)
