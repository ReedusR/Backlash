FUNCTION DesktopIconDisplayNameFromPath(BYVAL filePath AS STRING) AS STRING
    DIM p AS STRING
    DIM baseName AS STRING
    DIM i AS INTEGER
    DIM cutAt AS INTEGER
    DIM dotAt AS INTEGER

    p = NormalizePath(filePath)
    baseName = p
    cutAt = 0

    FOR i = LEN(p) TO 1 STEP -1
        IF MID$(p, i, 1) = "\" OR MID$(p, i, 1) = "/" THEN
            cutAt = i
            EXIT FOR
        END IF
    NEXT

    IF cutAt > 0 THEN baseName = MID$(p, cutAt + 1)

    dotAt = 0
    FOR i = LEN(baseName) TO 1 STEP -1
        IF MID$(baseName, i, 1) = "." THEN
            dotAt = i
            EXIT FOR
        END IF
    NEXT

    IF dotAt > 1 THEN baseName = LEFT$(baseName, dotAt - 1)
    baseName = TRIM$(baseName)

    IF baseName = "" THEN baseName = "New App"
    RETURN baseName
END FUNCTION

