    END IF

    SetTextboxTextByName "DD_SOURCE", summaryText
    SetTextboxTextByName "DD_DEST", destDir
    SyncLayoutWindowFromGlobals activeLayoutWindow
END SUB


' ---------------------------
' Copy, delete, rename, create-directory, and DOS 8.3 path helpers
' ---------------------------

FUNCTION DirectoryEntryList(BYVAL srcDir AS STRING) AS STRING
    DIM pattern AS STRING
    DIM fname AS STRING
    DIM resultText AS STRING
    DIM attrBits AS INTEGER

    srcDir = AbsoluteDirPath(TRIM$(srcDir))
    IF srcDir = "" THEN RETURN ""

    pattern = srcDir
    IF RIGHT$(pattern, 1) <> CHR$(92) THEN pattern = pattern + CHR$(92)
    pattern = pattern + "*.*"

    resultText = ""
    attrBits = 0
    fname = DIR(pattern, &H37, attrBits)
    DO WHILE fname <> ""
        IF fname <> "." AND fname <> ".." THEN
            resultText = resultText + LTRIM$(STR$(attrBits)) + CHR$(9) + fname + CHR$(10)
        END IF
        fname = DIR(attrBits)
    LOOP

    RETURN resultText
END FUNCTION

FUNCTION DirectoryCopyHasItems(BYVAL srcDir AS STRING, BYVAL copyFiles AS INTEGER, BYVAL copySubDirs AS INTEGER, BYVAL copyEmptyDirs AS INTEGER, BYVAL includeHiddenSystem AS INTEGER) AS INTEGER
    DIM entries AS STRING
    DIM scanPos AS INTEGER
    DIM lineEnd AS INTEGER
    DIM entryLine AS STRING
    DIM tabPos AS INTEGER
    DIM fname AS STRING
    DIM fullName AS STRING
    DIM attrBits AS INTEGER

    srcDir = AbsoluteDirPath(TRIM$(srcDir))
    IF srcDir = "" THEN RETURN 0
    IF copyEmptyDirs <> 0 THEN RETURN -1

    entries = DirectoryEntryList(srcDir)
    scanPos = 1
    DO WHILE scanPos <= LEN(entries)
        lineEnd = INSTR(scanPos, entries, CHR$(10))
        IF lineEnd = 0 THEN lineEnd = LEN(entries) + 1
        entryLine = MID$(entries, scanPos, lineEnd - scanPos)
        tabPos = INSTR(entryLine, CHR$(9))
        IF tabPos > 0 THEN
            attrBits = VAL(LEFT$(entryLine, tabPos - 1))
            fname = MID$(entryLine, tabPos + 1)
            IF includeHiddenSystem <> 0 OR (attrBits AND &H06) = 0 THEN
                fullName = JoinPath(srcDir, fname)
                IF (attrBits AND &H10) <> 0 THEN
                    IF copySubDirs <> 0 THEN
                        IF DirectoryCopyHasItems(fullName, copyFiles, copySubDirs, copyEmptyDirs, includeHiddenSystem) <> 0 THEN RETURN -1
                    END IF
                ELSEIF copyFiles <> 0 THEN
                    RETURN -1
                END IF
            END IF
        END IF
        scanPos = lineEnd + 1
    LOOP

    RETURN 0
END FUNCTION

FUNCTION CopyFileSafeOverwrite(BYVAL srcPath AS STRING, BYVAL dstPath AS STRING, BYVAL overwriteExisting AS INTEGER) AS INTEGER
    srcPath = NormalizePath(TRIM$(srcPath))
    dstPath = NormalizePath(TRIM$(dstPath))

    IF srcPath = "" OR dstPath = "" THEN RETURN 0
    IF overwriteExisting <> 0 THEN
        IF DIR(dstPath) <> "" THEN
            KILL dstPath
            ClearDirectorySizeCache
        END IF
    END IF

    RETURN CopyFileSafe(srcPath, dstPath)
END FUNCTION

SUB CopyDirectoryTree(BYVAL srcDir AS STRING, BYVAL dstDir AS STRING, BYVAL copyFiles AS INTEGER, BYVAL copySubDirs AS INTEGER, BYVAL copyEmptyDirs AS INTEGER, BYVAL includeHiddenSystem AS INTEGER, BYVAL overwriteExisting AS INTEGER, BYREF fileCount AS INTEGER, BYREF dirCount AS INTEGER, BYREF failCount AS INTEGER)
    DIM entries AS STRING
    DIM scanPos AS INTEGER
    DIM lineEnd AS INTEGER
    DIM entryLine AS STRING
    DIM tabPos AS INTEGER
    DIM fname AS STRING
    DIM fullName AS STRING
    DIM dstName AS STRING
    DIM attrBits AS INTEGER
    DIM existedBefore AS INTEGER

    srcDir = AbsoluteDirPath(TRIM$(srcDir))
    dstDir = NormalizePath(TRIM$(dstDir))
    IF srcDir = "" OR dstDir = "" THEN
        failCount = failCount + 1
        EXIT SUB
    END IF

    existedBefore = PathExistsAny(dstDir)
    IF existedBefore <> 0 THEN
        IF DIR(dstDir) <> "" AND DirectoryExistsForDelete(dstDir) = 0 THEN
            failCount = failCount + 1
            EXIT SUB
        END IF
    ELSE
        MKDIR dstDir
        IF PathExistsAny(dstDir) = 0 THEN
            failCount = failCount + 1
            EXIT SUB
        END IF
        dirCount = dirCount + 1
        ClearDirectorySizeCache
    END IF

    entries = DirectoryEntryList(srcDir)
    scanPos = 1
    DO WHILE scanPos <= LEN(entries)
        lineEnd = INSTR(scanPos, entries, CHR$(10))
        IF lineEnd = 0 THEN lineEnd = LEN(entries) + 1
        entryLine = MID$(entries, scanPos, lineEnd - scanPos)
        tabPos = INSTR(entryLine, CHR$(9))
        IF tabPos > 0 THEN
            attrBits = VAL(LEFT$(entryLine, tabPos - 1))
            fname = MID$(entryLine, tabPos + 1)
            IF includeHiddenSystem <> 0 OR (attrBits AND &H06) = 0 THEN
                fullName = JoinPath(srcDir, fname)
                dstName = JoinPath(dstDir, fname)
                IF (attrBits AND &H10) <> 0 THEN
                    IF copySubDirs <> 0 THEN
                        IF copyEmptyDirs <> 0 OR DirectoryCopyHasItems(fullName, copyFiles, copySubDirs, copyEmptyDirs, includeHiddenSystem) <> 0 THEN
                            CopyDirectoryTree fullName, dstName, copyFiles, copySubDirs, copyEmptyDirs, includeHiddenSystem, overwriteExisting, fileCount, dirCount, failCount
                        END IF
                    END IF
                ELSEIF copyFiles <> 0 THEN
                    IF CopyFileSafeOverwrite(fullName, dstName, overwriteExisting) <> 0 THEN
                        fileCount = fileCount + 1
                    ELSE
                        failCount = failCount + 1
                    END IF
                END IF
            END IF
        END IF
        scanPos = lineEnd + 1
    LOOP
END SUB


FUNCTION PathExistsAnyDirect(BYVAL itemPath AS STRING) AS INTEGER
    itemPath = NormalizePath(TRIM$(itemPath))
    IF itemPath = "" THEN RETURN 0

    IF LEN(itemPath) = 3 THEN
        IF MID$(itemPath, 2, 1) = ":" AND RIGHT$(itemPath, 1) = CHR$(92) THEN RETURN -1
    END IF

    IF DIR(itemPath) <> "" THEN RETURN -1
    IF DIR(itemPath, &H37) <> "" THEN RETURN -1
    IF DIR(itemPath, &H10) <> "" THEN RETURN -1

    RETURN 0
END FUNCTION

FUNCTION Dos83CleanText(BYVAL partText AS STRING) AS STRING
    DIM i AS INTEGER
    DIM ch AS STRING
    DIM c AS INTEGER
    DIM outText AS STRING

    partText = UCASE$(TRIM$(partText))
    outText = ""

    FOR i = 1 TO LEN(partText)
        ch = MID$(partText, i, 1)
        c = ASC(ch)
        IF c >= 65 AND c <= 90 THEN
            outText = outText + ch
        ELSEIF c >= 48 AND c <= 57 THEN
            outText = outText + ch
        ELSEIF ch = "$" OR ch = "%" OR ch = "'" OR ch = "-" OR ch = "_" OR ch = "@" OR ch = "~" OR _
               ch = "`" OR ch = "!" OR ch = "(" OR ch = ")" OR ch = "{" OR ch = "}" OR ch = "^" OR ch = "#" OR ch = "&" THEN
            outText = outText + ch
        END IF
    NEXT

    RETURN outText
END FUNCTION

FUNCTION Dos83AliasComponent(BYVAL componentText AS STRING, BYVAL seqNum AS INTEGER) AS STRING
    DIM dotPos AS INTEGER
    DIM i AS INTEGER
    DIM baseText AS STRING
    DIM extText AS STRING
    DIM cleanBase AS STRING
    DIM cleanExt AS STRING
    DIM suffixText AS STRING
    DIM baseLen AS INTEGER

    componentText = TRIM$(componentText)
    IF componentText = "" THEN RETURN ""
    IF componentText = "." OR componentText = ".." THEN RETURN ""

    dotPos = 0
    FOR i = LEN(componentText) TO 1 STEP -1
        IF MID$(componentText, i, 1) = "." THEN
            dotPos = i
            EXIT FOR
        END IF
    NEXT

    IF dotPos > 0 THEN
        baseText = LEFT$(componentText, dotPos - 1)
        extText = MID$(componentText, dotPos + 1)
    ELSE
        baseText = componentText
        extText = ""
    END IF

    cleanBase = Dos83CleanText(baseText)
    cleanExt = Dos83CleanText(extText)
    IF cleanBase = "" THEN cleanBase = "_"
    IF LEN(cleanExt) > 3 THEN cleanExt = LEFT$(cleanExt, 3)

    IF seqNum = 0 THEN
        IF LEN(cleanBase) > 8 THEN cleanBase = LEFT$(cleanBase, 8)
        IF cleanExt <> "" THEN RETURN cleanBase + "." + cleanExt
        RETURN cleanBase
    END IF

    suffixText = "~" + LTRIM$(STR$(seqNum))
    baseLen = 8 - LEN(suffixText)
    IF baseLen < 1 THEN RETURN ""
    IF LEN(cleanBase) > baseLen THEN cleanBase = LEFT$(cleanBase, baseLen)

    IF cleanExt <> "" THEN RETURN cleanBase + suffixText + "." + cleanExt
    RETURN cleanBase + suffixText
END FUNCTION

FUNCTION ResolveDos83ComponentInDir(BYVAL dirPath AS STRING, BYVAL componentText AS STRING) AS STRING
    DIM directPath AS STRING
    DIM aliasName AS STRING
    DIM aliasPath AS STRING
    DIM seqNum AS INTEGER

    dirPath = NormalizePath(TRIM$(dirPath))
    componentText = TRIM$(componentText)
    IF componentText = "" THEN RETURN ""

    directPath = JoinPath(dirPath, componentText)
    IF PathExistsAnyDirect(directPath) <> 0 THEN RETURN directPath

    aliasName = Dos83AliasComponent(componentText, 0)
    IF aliasName <> "" THEN
        aliasPath = JoinPath(dirPath, aliasName)
        IF PathExistsAnyDirect(aliasPath) <> 0 THEN RETURN aliasPath
    END IF

    FOR seqNum = 1 TO 999
        aliasName = Dos83AliasComponent(componentText, seqNum)
        IF aliasName = "" THEN EXIT FOR
        aliasPath = JoinPath(dirPath, aliasName)
        IF PathExistsAnyDirect(aliasPath) <> 0 THEN RETURN aliasPath
    NEXT

    RETURN ""
END FUNCTION

FUNCTION ResolveExistingDosPath(BYVAL itemPath AS STRING) AS STRING
    DIM parentDir AS STRING
    DIM fileName AS STRING
    DIM resolvedParent AS STRING

    itemPath = NormalizePath(TRIM$(itemPath))
    IF itemPath = "" THEN RETURN ""
    IF PathExistsAnyDirect(itemPath) <> 0 THEN RETURN itemPath

    parentDir = ParentPath(itemPath)
    fileName = FileNameOnly(itemPath)
    IF parentDir = "" OR fileName = "" THEN RETURN ""

    IF PathExistsAnyDirect(parentDir) <> 0 THEN
        resolvedParent = parentDir
    ELSE
        resolvedParent = ResolveExistingDosPath(parentDir)
    END IF
    IF resolvedParent = "" THEN RETURN ""

    RETURN ResolveDos83ComponentInDir(resolvedParent, fileName)
END FUNCTION
FUNCTION PathExistsAny(BYVAL itemPath AS STRING) AS INTEGER
    itemPath = NormalizePath(TRIM$(itemPath))
    IF itemPath = "" THEN RETURN 0

    IF LEN(itemPath) = 3 THEN
        IF MID$(itemPath, 2, 1) = ":" AND RIGHT$(itemPath, 1) = CHR$(92) THEN RETURN -1
    END IF

    IF DIR(itemPath) <> "" THEN RETURN -1
    IF DIR(itemPath, &H37) <> "" THEN RETURN -1
    IF DIR(itemPath, &H10) <> "" THEN RETURN -1

    RETURN 0
END FUNCTION


FUNCTION CreateDirectoryWithNameSafe(BYVAL parentDir AS STRING, BYVAL dirName AS STRING) AS STRING
    DIM newPath AS STRING

    parentDir = AbsoluteDirPath(TRIM$(parentDir))
    dirName = TRIM$(dirName)

    IF parentDir = "" THEN RETURN ""
    IF dirName = "" THEN RETURN ""
    IF dirName = "." OR dirName = ".." THEN RETURN ""
    IF PathExistsAny(parentDir) = 0 THEN RETURN ""
    IF INSTR(dirName, CHR$(92)) > 0 OR INSTR(dirName, "/") > 0 OR INSTR(dirName, ":") > 0 THEN RETURN ""
    IF INSTR(dirName, "*") > 0 OR INSTR(dirName, "?") > 0 OR INSTR(dirName, CHR$(34)) > 0 THEN RETURN ""
    IF INSTR(dirName, "<") > 0 OR INSTR(dirName, ">") > 0 OR INSTR(dirName, "|") > 0 THEN RETURN ""

    newPath = JoinPath(parentDir, dirName)
    IF PathExistsAny(newPath) <> 0 THEN RETURN ""

    MKDIR newPath

    IF PathExistsAny(newPath) <> 0 THEN
        ClearDirectorySizeCache
        RETURN newPath
    END IF
    RETURN ""
END FUNCTION

FUNCTION RenameFileSafe(BYVAL oldPath AS STRING, BYVAL newPath AS STRING) AS INTEGER
    oldPath = NormalizePath(TRIM$(oldPath))
    newPath = NormalizePath(TRIM$(newPath))

    IF oldPath = "" OR newPath = "" THEN RETURN 0
    IF ParentPath(oldPath) = "" THEN RETURN 0
    IF PathExistsAny(oldPath) = 0 THEN RETURN 0
    IF PathExistsAny(newPath) <> 0 THEN RETURN 0

    NAME oldPath AS newPath

    IF PathExistsAny(newPath) <> 0 THEN
        ClearDirectorySizeCache
        RETURN -1
    END IF
    RETURN 0
END FUNCTION

FUNCTION DirectoryExistsForDelete(BYVAL dirPath AS STRING) AS INTEGER
    DIM pattern AS STRING

    dirPath = NormalizePath(TRIM$(dirPath))
    IF dirPath = "" THEN RETURN 0
    IF dirPath = "." OR dirPath = ".." THEN RETURN 0
    IF INSTR(dirPath, "*") > 0 OR INSTR(dirPath, "?") > 0 THEN RETURN 0
    IF LEN(dirPath) = 3 AND MID$(dirPath, 2, 1) = ":" AND RIGHT$(dirPath, 1) = CHR$(92) THEN RETURN 0

    pattern = dirPath
    IF RIGHT$(pattern, 1) <> CHR$(92) THEN pattern = pattern + CHR$(92)
    pattern = pattern + "*.*"

    IF DIR(pattern, &H10) <> "" THEN RETURN -1
    RETURN 0
END FUNCTION

FUNCTION DirectoryExistsForSize(BYVAL dirPath AS STRING) AS INTEGER
    DIM pattern AS STRING
    DIM probePath AS STRING
    DIM attrBits AS INTEGER

    dirPath = AbsoluteDirPath(TRIM$(dirPath))
    IF dirPath = "" THEN RETURN 0
    IF INSTR(dirPath, "*") > 0 OR INSTR(dirPath, "?") > 0 THEN RETURN 0

    IF LEN(dirPath) = 3 THEN
        IF MID$(dirPath, 2, 1) = ":" AND RIGHT$(dirPath, 1) = CHR$(92) THEN
            IF PathExistsAnyDirect(dirPath) <> 0 THEN RETURN -1
            RETURN 0
        END IF
    END IF

    probePath = dirPath
    DO WHILE LEN(probePath) > 3 AND RIGHT$(probePath, 1) = CHR$(92)
        probePath = LEFT$(probePath, LEN(probePath) - 1)
    LOOP

    attrBits = 0
    IF DIR(probePath, &H37, attrBits) <> "" THEN
        IF (attrBits AND &H10) <> 0 THEN RETURN -1
        RETURN 0
    END IF

    pattern = dirPath
    IF RIGHT$(pattern, 1) <> CHR$(92) THEN pattern = pattern + CHR$(92)
    pattern = pattern + "*.*"

    IF DIR(pattern, &H37) <> "" THEN RETURN -1
    RETURN 0
END FUNCTION

FUNCTION DeleteDirectoryTree(BYVAL dirPath AS STRING, BYREF fileCount AS INTEGER, BYREF dirCount AS INTEGER, BYREF failCount AS INTEGER) AS INTEGER
    DIM entries AS STRING
    DIM scanPos AS INTEGER
    DIM lineEnd AS INTEGER
    DIM entryLine AS STRING
    DIM tabPos AS INTEGER
    DIM fname AS STRING
    DIM fullName AS STRING
    DIM attrBits AS INTEGER
    DIM deletedOk AS INTEGER

    dirPath = ResolveExistingDosPath(AbsoluteDirPath(TRIM$(dirPath)))
    IF dirPath = "" THEN RETURN 0
    IF dirPath = "." OR dirPath = ".." THEN RETURN 0
    IF INSTR(dirPath, "*") > 0 OR INSTR(dirPath, "?") > 0 THEN RETURN 0
    IF LEN(dirPath) = 3 AND MID$(dirPath, 2, 1) = ":" AND RIGHT$(dirPath, 1) = CHR$(92) THEN RETURN 0
    IF DirectoryExistsForDelete(dirPath) = 0 THEN RETURN 0

    entries = DirectoryEntryList(dirPath)
    scanPos = 1
    DO WHILE scanPos <= LEN(entries)
        lineEnd = INSTR(scanPos, entries, CHR$(10))
        IF lineEnd = 0 THEN lineEnd = LEN(entries) + 1
        entryLine = MID$(entries, scanPos, lineEnd - scanPos)
        tabPos = INSTR(entryLine, CHR$(9))
        IF tabPos > 0 THEN
            attrBits = VAL(LEFT$(entryLine, tabPos - 1))
            fname = MID$(entryLine, tabPos + 1)
            IF fname <> "." AND fname <> ".." THEN
                fullName = JoinPath(dirPath, fname)
                IF (attrBits AND &H10) <> 0 THEN
                    deletedOk = DeleteDirectoryTree(fullName, fileCount, dirCount, failCount)
                    IF deletedOk = 0 THEN failCount = failCount + 1
                ELSE
                    IF DeleteFileSafe(fullName) <> 0 THEN
                        fileCount = fileCount + 1
                    ELSE
                        failCount = failCount + 1
                    END IF
                END IF
            END IF
        END IF
        scanPos = lineEnd + 1
    LOOP

    RMDIR dirPath
    IF PathExistsAny(dirPath) = 0 THEN
        dirCount = dirCount + 1
        ClearDirectorySizeCache
        RETURN -1
    END IF

    RETURN 0
END FUNCTION



FUNCTION DeleteFileSafe(BYVAL filePath AS STRING) AS INTEGER
    filePath = ResolveExistingDosPath(TRIM$(filePath))

    IF filePath = "" THEN RETURN 0
    IF INSTR(filePath, "*") > 0 OR INSTR(filePath, "?") > 0 THEN RETURN 0

    IF DirectoryExistsForDelete(filePath) <> 0 THEN
        RMDIR filePath
        IF DirectoryExistsForDelete(filePath) = 0 THEN
            ClearDirectorySizeCache
            RETURN -1
        END IF
        RETURN 0
    END IF

    IF DIR(filePath) = "" THEN RETURN 0

    KILL filePath

    IF DIR(filePath) = "" THEN
        ClearDirectorySizeCache
        RETURN -1
    END IF
    RETURN 0
END FUNCTION


FUNCTION DeletePathPermanent(BYVAL itemPath AS STRING, BYVAL recursiveOk AS INTEGER, BYREF fileCount AS INTEGER, BYREF dirCount AS INTEGER, BYREF failCount AS INTEGER) AS INTEGER
    DIM srcPath AS STRING
    DIM deletedOk AS INTEGER

    srcPath = ResolveExistingDosPath(TRIM$(itemPath))
    IF srcPath = "" THEN RETURN 0
    IF INSTR(srcPath, "*") > 0 OR INSTR(srcPath, "?") > 0 THEN RETURN 0
    IF TrashIsPathProtected(srcPath) <> 0 THEN RETURN 0
    IF PathExistsAny(srcPath) = 0 THEN RETURN 0

    ' Permanent delete keeps the Waste Basket bypass in one safe path.
    ' Directories still honor the recursive checkbox before tree removal.
    IF DirectoryExistsForDelete(srcPath) <> 0 THEN
        IF recursiveOk <> 0 THEN
            deletedOk = DeleteDirectoryTree(srcPath, fileCount, dirCount, failCount)
            IF deletedOk <> 0 THEN RETURN -1
        ELSEIF DeleteFileSafe(srcPath) <> 0 THEN
            dirCount = dirCount + 1
            RETURN -1
        END IF
    ELSEIF DeleteFileSafe(srcPath) <> 0 THEN
        fileCount = fileCount + 1
        RETURN -1
    END IF

    RETURN 0
END FUNCTION

SUB TrashEnsure()
    EnsureDirectoryExists "SYSTEM"
    EnsureDirectoryExists PATH_TRASHDIR
    WriteDefaultFileIfMissing PATH_TRASHIDX, ""
END SUB

' Checks whether the Waste Basket index contains any stored deleted items.
FUNCTION TrashHasItems() AS INTEGER
    DIM f AS INTEGER
    DIM lineIn AS STRING
    DIM trashId AS STRING

    TrashEnsure

    f = FREEFILE
    IF OPEN(PATH_TRASHIDX FOR INPUT AS #f) <> 0 THEN RETURN 0

    DO WHILE NOT EOF(f)
        LINE INPUT #f, lineIn
        trashId = UCASE$(TRIM$(lineIn))
        IF trashId <> "" THEN
            IF DIR(TrashInfoPath(trashId)) <> "" THEN
                CLOSE #f
                RETURN -1
            END IF
        END IF
    LOOP

    CLOSE #f
    RETURN 0
END FUNCTION

FUNCTION TrashIsPathProtected(BYVAL itemPath AS STRING) AS INTEGER
    DIM testPath AS STRING
    DIM trashPath AS STRING

    testPath = UCASE$(NormalizePath(TRIM$(itemPath)))
    trashPath = UCASE$(NormalizePath(PATH_TRASHDIR))
    IF testPath = "" OR trashPath = "" THEN RETURN -1
    IF testPath = trashPath THEN RETURN -1
    IF LEFT$(testPath, LEN(trashPath) + 1) = trashPath + CHR$(92) THEN RETURN -1
    IF LEN(testPath) = 3 AND MID$(testPath, 2, 1) = ":" AND RIGHT$(testPath, 1) = CHR$(92) THEN RETURN -1
    RETURN 0
END FUNCTION


FUNCTION TrashPathIsDirectory(BYVAL itemPath AS STRING) AS INTEGER
    DIM attrBits AS INTEGER
    DIM foundName AS STRING

    itemPath = NormalizePath(TRIM$(itemPath))
    IF itemPath = "" THEN RETURN 0
    IF LEN(itemPath) = 3 AND MID$(itemPath, 2, 1) = ":" AND RIGHT$(itemPath, 1) = CHR$(92) THEN RETURN 0
    IF INSTR(itemPath, "*") > 0 OR INSTR(itemPath, "?") > 0 THEN RETURN 0

    attrBits = 0
    foundName = DIR(itemPath, &H37, attrBits)
    IF foundName <> "" THEN
        IF (attrBits AND &H10) <> 0 THEN RETURN -1
    END IF

    IF DirectoryExistsForDelete(itemPath) <> 0 THEN RETURN -1
    RETURN 0
END FUNCTION

FUNCTION TrashEntryBase(BYVAL seqNum AS INTEGER, BYVAL itemIsDir AS INTEGER) AS STRING
    DIM nText AS STRING

    IF seqNum < 1 THEN seqNum = 1
    IF seqNum > 999999 THEN seqNum = 999999
    nText = RIGHT$("000000" + LTRIM$(STR$(seqNum)), 6)
    IF itemIsDir <> 0 THEN RETURN "T" + nText + "D"
    RETURN "T" + nText + "F"
END FUNCTION

FUNCTION TrashInfoPath(BYVAL trashId AS STRING) AS STRING
    trashId = UCASE$(TRIM$(trashId))
    IF trashId = "" THEN RETURN ""
    RETURN JoinPath(PATH_TRASHDIR, trashId + ".INF")
END FUNCTION

FUNCTION TrashDataPath(BYVAL trashId AS STRING, BYVAL itemType AS STRING) AS STRING
    trashId = UCASE$(TRIM$(trashId))
    IF trashId = "" THEN RETURN ""
    itemType = UCASE$(TRIM$(itemType))
    IF itemType = "DIR" OR itemType = "DIRECTORY" THEN RETURN JoinPath(PATH_TRASHDIR, trashId)
    RETURN JoinPath(PATH_TRASHDIR, trashId + ".DAT")
END FUNCTION

FUNCTION TrashCanRenameDirect(BYVAL srcPath AS STRING, BYVAL dstPath AS STRING) AS INTEGER
    srcPath = NormalizePath(TRIM$(srcPath))
    dstPath = NormalizePath(TRIM$(dstPath))
    IF srcPath = "" OR dstPath = "" THEN RETURN 0
    IF LEN(srcPath) >= 2 AND MID$(srcPath, 2, 1) = ":" AND LEN(dstPath) >= 2 AND MID$(dstPath, 2, 1) = ":" THEN
        IF UCASE$(LEFT$(srcPath, 2)) <> UCASE$(LEFT$(dstPath, 2)) THEN RETURN 0
    END IF
    RETURN -1
END FUNCTION

' Finds an unused Waste Basket ID for the next deleted file or folder.
FUNCTION TrashNextId(BYVAL itemIsDir AS INTEGER) AS STRING
    DIM seqNum AS INTEGER
    DIM baseName AS STRING
    DIM dataPath AS STRING
    DIM infoPath AS STRING

    TrashEnsure

    FOR seqNum = 1 TO 999999
        baseName = TrashEntryBase(seqNum, itemIsDir)
        IF itemIsDir <> 0 THEN
            dataPath = TrashDataPath(baseName, "DIR")
        ELSE
            dataPath = TrashDataPath(baseName, "FILE")
        END IF
        infoPath = TrashInfoPath(baseName)
        IF PathExistsAny(dataPath) = 0 AND DIR(infoPath) = "" THEN RETURN baseName
    NEXT

    RETURN ""
END FUNCTION

SUB TrashAppendIndex(BYVAL trashId AS STRING)
    DIM f AS INTEGER

    trashId = UCASE$(TRIM$(trashId))
    IF trashId = "" THEN EXIT SUB

    TrashEnsure
    f = FREEFILE
    IF OPEN(PATH_TRASHIDX FOR APPEND AS #f) <> 0 THEN EXIT SUB
    PRINT #f, trashId
    CLOSE #f
    InvalidateCfgReadCacheForFile PATH_TRASHIDX
    RefreshTrashAwareDesktopIcons
END SUB

SUB TrashRemoveIndex(BYVAL trashId AS STRING)
    DIM f AS INTEGER
    DIM outFile AS INTEGER
    DIM lineIn AS STRING
    DIM tmpFile AS STRING

    trashId = UCASE$(TRIM$(trashId))
    IF trashId = "" THEN EXIT SUB

    TrashEnsure
    tmpFile = JoinPath(PATH_TRASHDIR, "TRASH.TMP")

    outFile = FREEFILE
    IF OPEN(tmpFile FOR OUTPUT AS #outFile) <> 0 THEN EXIT SUB

    f = FREEFILE
    IF OPEN(PATH_TRASHIDX FOR INPUT AS #f) = 0 THEN
        DO WHILE NOT EOF(f)
            LINE INPUT #f, lineIn
            lineIn = UCASE$(TRIM$(lineIn))
            IF lineIn <> "" AND lineIn <> trashId THEN PRINT #outFile, lineIn
        LOOP
        CLOSE #f
    END IF

    CLOSE #outFile
    IF DIR(PATH_TRASHIDX) <> "" THEN KILL PATH_TRASHIDX
    NAME tmpFile AS PATH_TRASHIDX
    InvalidateCfgReadCacheForFile PATH_TRASHIDX
    RefreshTrashAwareDesktopIcons
END SUB

FUNCTION TrashMoveDesktopIconToTrash(BYVAL iconIdx AS INTEGER) AS INTEGER
    DIM trashId AS STRING
    DIM infoPath AS STRING
    DIM f AS INTEGER

    IF iconIdx < 1 OR iconIdx > iconCount THEN RETURN 0

    trashId = TrashNextId(0)
    IF trashId = "" THEN RETURN 0
    infoPath = TrashInfoPath(trashId)

    f = FREEFILE
    IF OPEN(infoPath FOR OUTPUT AS #f) <> 0 THEN RETURN 0
    PRINT #f, "id=" + trashId
    PRINT #f, "type=DESKTOP_ICON"
    PRINT #f, "original=Desktop Icon: " + desktopIcons(iconIdx).caption
    PRINT #f, "stored="
    PRINT #f, "name=" + desktopIcons(iconIdx).caption
    PRINT #f, "caption=" + desktopIcons(iconIdx).caption
    PRINT #f, "action=" + desktopIcons(iconIdx).action
    PRINT #f, "icon=" + desktopIcons(iconIdx).bmpFile
    PRINT #f, "x=" + LTRIM$(STR$(desktopIcons(iconIdx).x))
    PRINT #f, "y=" + LTRIM$(STR$(desktopIcons(iconIdx).y))
    PRINT #f, "deleted=" + DATE$ + " " + TIME$
    CLOSE #f
    InvalidateCfgReadCacheForFile infoPath

    TrashAppendIndex trashId
    RETURN -1
END FUNCTION

FUNCTION TrashMovePathToTrash(BYVAL itemPath AS STRING, BYVAL recursiveOk AS INTEGER) AS INTEGER
    DIM srcPath AS STRING
    DIM itemIsDir AS INTEGER
    DIM trashId AS STRING
    DIM infoPath AS STRING
    DIM dataPath AS STRING
    DIM f AS INTEGER
    DIM copyFilesDone AS INTEGER
    DIM copyDirsDone AS INTEGER
    DIM copyFails AS INTEGER
    DIM moveOk AS INTEGER

    srcPath = ResolveExistingDosPath(TRIM$(itemPath))
    IF srcPath = "" THEN RETURN 0
    IF INSTR(srcPath, "*") > 0 OR INSTR(srcPath, "?") > 0 THEN RETURN 0
    IF TrashIsPathProtected(srcPath) <> 0 THEN RETURN 0
    IF PathExistsAny(srcPath) = 0 THEN RETURN 0

    itemIsDir = TrashPathIsDirectory(srcPath)
    IF itemIsDir <> 0 AND recursiveOk = 0 THEN
        IF DirectoryEntryList(srcPath) <> "" THEN RETURN 0
    END IF

    trashId = TrashNextId(itemIsDir)
    IF trashId = "" THEN RETURN 0

    IF itemIsDir <> 0 THEN
        dataPath = TrashDataPath(trashId, "DIR")
    ELSE
        dataPath = TrashDataPath(trashId, "FILE")
    END IF
    infoPath = TrashInfoPath(trashId)

    moveOk = 0
    IF TrashCanRenameDirect(srcPath, dataPath) <> 0 THEN
        NAME srcPath AS dataPath
        IF PathExistsAny(dataPath) <> 0 AND PathExistsAny(srcPath) = 0 THEN moveOk = -1
    END IF

    IF moveOk = 0 THEN
        IF itemIsDir <> 0 THEN
            copyFilesDone = 0
            copyDirsDone = 0
            copyFails = 0
            CopyDirectoryTree srcPath, dataPath, -1, -1, -1, -1, 0, copyFilesDone, copyDirsDone, copyFails
            IF copyFails = 0 AND PathExistsAny(dataPath) <> 0 THEN
                copyFilesDone = 0
                copyDirsDone = 0
                copyFails = 0
                IF DeleteDirectoryTree(srcPath, copyFilesDone, copyDirsDone, copyFails) <> 0 AND copyFails = 0 THEN moveOk = -1
                IF moveOk = 0 AND copyFails = 0 AND PathExistsAny(srcPath) <> 0 THEN RMDIR srcPath
                IF moveOk = 0 AND copyFails = 0 AND PathExistsAny(srcPath) = 0 THEN moveOk = -1
            END IF
        ELSE
            IF CopyFileSafe(srcPath, dataPath) <> 0 THEN
                IF DeleteFileSafe(srcPath) <> 0 THEN moveOk = -1
            END IF
        END IF
    END IF

    IF moveOk = 0 THEN
        IF itemIsDir <> 0 THEN
            copyFilesDone = 0
            copyDirsDone = 0
            copyFails = 0
            IF PathExistsAny(dataPath) <> 0 THEN DeleteDirectoryTree dataPath, copyFilesDone, copyDirsDone, copyFails
        ELSE
            IF DIR(dataPath) <> "" THEN KILL dataPath
        END IF
        RETURN 0
    END IF

    ClearDirectorySizeCache

    f = FREEFILE
    IF OPEN(infoPath FOR OUTPUT AS #f) <> 0 THEN RETURN 0
    PRINT #f, "id=" + trashId
    IF itemIsDir <> 0 THEN
        PRINT #f, "type=DIR"
    ELSE
        PRINT #f, "type=FILE"
    END IF
    PRINT #f, "original=" + srcPath
    PRINT #f, "stored=" + dataPath
    PRINT #f, "name=" + FileNameOnly(srcPath)
    PRINT #f, "deleted=" + DATE$ + " " + TIME$
    CLOSE #f
    InvalidateCfgReadCacheForFile infoPath

    TrashAppendIndex trashId
    RETURN -1
END FUNCTION

' Restores one Waste Basket entry only if the original destination is still safe to use.
FUNCTION TrashRestoreId(BYVAL trashId AS STRING) AS INTEGER
    DIM infoPath AS STRING
    DIM itemType AS STRING
    DIM originalPath AS STRING
    DIM storedPath AS STRING
    DIM restoreOk AS INTEGER
    DIM copyFilesDone AS INTEGER
    DIM copyDirsDone AS INTEGER
    DIM copyFails AS INTEGER

    trashId = UCASE$(TRIM$(trashId))
    IF trashId = "" THEN RETURN 0

    infoPath = TrashInfoPath(trashId)
    IF DIR(infoPath) = "" THEN RETURN 0

    itemType = UCASE$(TRIM$(ReadCfgValueNoCache(infoPath, "type", "")))

    IF itemType = "DESKTOP_ICON" THEN
        IF iconCount >= 128 THEN RETURN 0
        iconCount = iconCount + 1
        desktopIcons(iconCount).caption = TRIM$(ReadCfgValueNoCache(infoPath, "caption", ""))
        desktopIcons(iconCount).action = TRIM$(ReadCfgValueNoCache(infoPath, "action", ""))
        desktopIcons(iconCount).bmpFile = NormalizePath(TRIM$(ReadCfgValueNoCache(infoPath, "icon", "")))
        desktopIcons(iconCount).x = VALINT(TRIM$(ReadCfgValueNoCache(infoPath, "x", "0")))
        desktopIcons(iconCount).y = VALINT(TRIM$(ReadCfgValueNoCache(infoPath, "y", "0")))
        desktopIcons(iconCount).pixels = 0
        desktopIcons(iconCount).imageBuf = 0
        desktopIcons(iconCount).runY = 0
        desktopIcons(iconCount).runX1 = 0
        desktopIcons(iconCount).runX2 = 0
        desktopIcons(iconCount).runCol = 0
        desktopIcons(iconCount).runCount = 0
        desktopIcons(iconCount).hasTrans = 0
        desktopIcons(iconCount).w = 0
        desktopIcons(iconCount).h = 0
        desktopIcons(iconCount).loaded = 0
        IF desktopIcons(iconCount).caption = "" THEN desktopIcons(iconCount).caption = "Desktop Icon"
        IF desktopIcons(iconCount).action = "" THEN
            iconCount = iconCount - 1
            RETURN 0
        END IF
        PlaceDesktopIconNoCollision iconCount
        SaveDesktopIcons
        LoadSingleDesktopIcon iconCount
        InvalidateDesktopCache
        IF DIR(infoPath) <> "" THEN KILL infoPath
        TrashRemoveIndex trashId
        RETURN -1
    END IF

    originalPath = NormalizePath(TRIM$(ReadCfgValueNoCache(infoPath, "original", "")))
    storedPath = NormalizePath(TRIM$(ReadCfgValueNoCache(infoPath, "stored", "")))

    IF originalPath = "" OR storedPath = "" THEN RETURN 0
    IF PathExistsAny(storedPath) = 0 THEN RETURN 0
    IF PathExistsAny(originalPath) <> 0 THEN RETURN 0

    restoreOk = 0
    IF TrashCanRenameDirect(storedPath, originalPath) <> 0 THEN
        NAME storedPath AS originalPath
        IF PathExistsAny(originalPath) <> 0 AND PathExistsAny(storedPath) = 0 THEN restoreOk = -1
    END IF

    IF restoreOk = 0 THEN
        IF itemType = "DIR" THEN
            copyFilesDone = 0
            copyDirsDone = 0
            copyFails = 0
            CopyDirectoryTree storedPath, originalPath, -1, -1, -1, -1, 0, copyFilesDone, copyDirsDone, copyFails
            IF copyFails = 0 AND PathExistsAny(originalPath) <> 0 THEN
                copyFilesDone = 0
                copyDirsDone = 0
                copyFails = 0
                IF DeleteDirectoryTree(storedPath, copyFilesDone, copyDirsDone, copyFails) <> 0 AND copyFails = 0 THEN restoreOk = -1
                IF restoreOk = 0 AND copyFails = 0 AND PathExistsAny(storedPath) <> 0 THEN RMDIR storedPath
                IF restoreOk = 0 AND copyFails = 0 AND PathExistsAny(storedPath) = 0 THEN restoreOk = -1
            END IF
        ELSE
            IF CopyFileSafe(storedPath, originalPath) <> 0 THEN
                IF DeleteFileSafe(storedPath) <> 0 THEN restoreOk = -1
            END IF
        END IF
    END IF

    IF restoreOk <> 0 THEN
        ClearDirectorySizeCache
        IF DIR(infoPath) <> "" THEN KILL infoPath
        TrashRemoveIndex trashId
        RETURN -1
    END IF

    RETURN 0
END FUNCTION

FUNCTION TrashDeleteIdPermanent(BYVAL trashId AS STRING) AS INTEGER
    DIM infoPath AS STRING
    DIM itemType AS STRING
    DIM storedPath AS STRING
    DIM deleteFilesDone AS INTEGER
    DIM deleteDirsDone AS INTEGER
    DIM deleteFailsDone AS INTEGER

    trashId = UCASE$(TRIM$(trashId))
    IF trashId = "" THEN RETURN 0

    infoPath = TrashInfoPath(trashId)
    IF DIR(infoPath) = "" THEN RETURN 0

    itemType = UCASE$(TRIM$(ReadCfgValueNoCache(infoPath, "type", "")))
    storedPath = NormalizePath(TRIM$(ReadCfgValueNoCache(infoPath, "stored", "")))

    IF itemType = "DESKTOP_ICON" THEN
        IF DIR(infoPath) <> "" THEN KILL infoPath
        TrashRemoveIndex trashId
        RETURN -1
    END IF

    IF storedPath <> "" THEN
        IF itemType = "DIR" THEN
            deleteFilesDone = 0
            deleteDirsDone = 0
            deleteFailsDone = 0
            DeleteDirectoryTree storedPath, deleteFilesDone, deleteDirsDone, deleteFailsDone
            IF deleteFailsDone <> 0 THEN RETURN 0
            IF PathExistsAny(storedPath) <> 0 THEN RMDIR storedPath
            IF PathExistsAny(storedPath) <> 0 THEN RETURN 0
        ELSEIF DIR(storedPath) <> "" THEN
            IF DeleteFileSafe(storedPath) = 0 THEN RETURN 0
        END IF
    END IF

    ClearDirectorySizeCache
    IF DIR(infoPath) <> "" THEN KILL infoPath
    TrashRemoveIndex trashId
    RETURN -1
END FUNCTION

FUNCTION TrashSourceItemCount(BYVAL sourceText AS STRING) AS INTEGER
    DIM sepPos AS INTEGER
    DIM itemText AS STRING
    DIM itemCount AS INTEGER

    itemCount = 0
    DO WHILE sourceText <> ""
        sepPos = INSTR(sourceText, "|")
        IF sepPos > 0 THEN
            itemText = LEFT$(sourceText, sepPos - 1)
            sourceText = MID$(sourceText, sepPos + 1)
        ELSE
            itemText = sourceText
            sourceText = ""
        END IF
        IF TRIM$(itemText) <> "" THEN itemCount = itemCount + 1
    LOOP
    RETURN itemCount
END FUNCTION

FUNCTION TrashListSourceItems() AS STRING
    DIM f AS INTEGER
    DIM outFile AS INTEGER
    DIM lineIn AS STRING
    DIM trashId AS STRING
    DIM infoPath AS STRING
    DIM itemType AS STRING
    DIM originalPath AS STRING
    DIM deletedText AS STRING
    DIM caption AS STRING
    DIM outText AS STRING
    DIM typeText AS STRING
    DIM keptIds AS STRING
    DIM staleFound AS INTEGER
    DIM tmpFile AS STRING
    DIM lineEndPos AS INTEGER

    TrashEnsure
    outText = ""
    keptIds = ""
    staleFound = 0

    f = FREEFILE
    IF OPEN(PATH_TRASHIDX FOR INPUT AS #f) <> 0 THEN RETURN ""

    DO WHILE NOT EOF(f)
        LINE INPUT #f, lineIn
        trashId = UCASE$(TRIM$(lineIn))
        IF trashId <> "" THEN
            infoPath = TrashInfoPath(trashId)
            IF DIR(infoPath) <> "" THEN
                itemType = UCASE$(TRIM$(ReadCfgValueNoCache(infoPath, "type", "")))
                originalPath = TRIM$(ReadCfgValueNoCache(infoPath, "original", ""))
                deletedText = TRIM$(ReadCfgValueNoCache(infoPath, "deleted", ""))
                IF itemType = "DIR" THEN
                    typeText = "DIR "
                ELSEIF itemType = "DESKTOP_ICON" THEN
                    typeText = "ICON"
                ELSE
                    typeText = "FILE"
                END IF
                caption = typeText + "  " + LEFT$(deletedText + SPACE$(17), 17) + "  " + originalPath
                IF outText <> "" THEN outText = outText + "|"
                outText = outText + caption + "=" + trashId
                IF keptIds <> "" THEN keptIds = keptIds + CHR$(10)
                keptIds = keptIds + trashId
            ELSE
                staleFound = -1
            END IF
        END IF
    LOOP
    CLOSE #f

    IF staleFound <> 0 THEN
        tmpFile = JoinPath(PATH_TRASHDIR, "TRASH.TMP")
        outFile = FREEFILE
        IF OPEN(tmpFile FOR OUTPUT AS #outFile) = 0 THEN
            DO WHILE keptIds <> ""
                lineEndPos = INSTR(keptIds, CHR$(10))
                IF lineEndPos > 0 THEN
                    PRINT #outFile, LEFT$(keptIds, lineEndPos - 1)
                    keptIds = MID$(keptIds, lineEndPos + 1)
                ELSE
                    PRINT #outFile, keptIds
                    keptIds = ""
                END IF
            LOOP
            CLOSE #outFile
            IF DIR(PATH_TRASHIDX) <> "" THEN KILL PATH_TRASHIDX
            NAME tmpFile AS PATH_TRASHIDX
            InvalidateCfgReadCacheForFile PATH_TRASHIDX
            RefreshTrashAwareDesktopIcons
        END IF
    END IF

    RETURN outText
END FUNCTION

SUB TrashRefreshControls(BYVAL winIdx AS INTEGER, BYVAL listControlName AS STRING, BYVAL statusControlName AS STRING)
    DIM listIdx AS INTEGER
    DIM itemCount AS INTEGER
    DIM cacheSlot AS INTEGER
    DIM statusText AS STRING
    DIM sourceText AS STRING

    IF winIdx < LBOUND(layoutWindows) OR winIdx > UBOUND(layoutWindows) THEN EXIT SUB
    IF layoutWindows(winIdx).used = 0 THEN EXIT SUB

    SyncGlobalsFromLayoutWindow winIdx

    sourceText = TrashListSourceItems()
    listIdx = GetControlIndexByName(listControlName)
    IF listIdx >= 1 AND listIdx <= uiCount THEN
        IF uiElems(listIdx).kindId = UI_KIND_LISTBOX THEN
            uiElems(listIdx).sourceItems = sourceText
            uiElems(listIdx).sourceKind = ""
            uiElems(listIdx).sourceKindKey = ""
            uiElems(listIdx).sourceKindId = UI_SOURCE_NONE
            uiElems(listIdx).sourceDir = ""
            uiElems(listIdx).sourceMask = ""
            uiElems(listIdx).text = ""
            comboScrollTop(winIdx, listIdx) = 0
            ListSelectionClear winIdx, listIdx
            layoutListAnchorIdx(winIdx, listIdx) = 0
            ClearComboItemCache
            BuildComboItems listIdx
            itemCount = ComboFastItemCount(listIdx, cacheSlot)
            IF itemCount > 0 THEN
                uiElems(listIdx).text = RTRIM$(ComboFastItemText(cacheSlot, 1))
                layoutListAnchorIdx(winIdx, listIdx) = 1
            END IF
            layoutUiElems(winIdx, listIdx) = uiElems(listIdx)
            SyncLayoutWindowFromGlobals winIdx
        END IF
    END IF

    itemCount = TrashSourceItemCount(sourceText)
    IF itemCount = 1 THEN
        statusText = "Waste Basket: 1 item"
    ELSE
        statusText = "Waste Basket: " + LTRIM$(STR$(itemCount)) + " items"
    END IF
    IF statusControlName <> "" THEN SetTextboxTextByName statusControlName, statusText
    MarkLayoutWindowDirty winIdx
END SUB


FUNCTION CopyFileSafe(BYVAL srcPath AS STRING, BYVAL dstPath AS STRING) AS INTEGER
    DIM inFile AS INTEGER
    DIM outFile AS INTEGER
    DIM remaining AS LONGINT
    DIM takeBytes AS INTEGER
    DIM buffer AS STRING

    srcPath = NormalizePath(TRIM$(srcPath))
    dstPath = NormalizePath(TRIM$(dstPath))

    IF srcPath = "" OR dstPath = "" THEN RETURN 0
    IF INSTR(srcPath, "*") > 0 OR INSTR(srcPath, "?") > 0 THEN RETURN 0
    IF INSTR(dstPath, "*") > 0 OR INSTR(dstPath, "?") > 0 THEN RETURN 0
    IF DIR(srcPath) = "" THEN RETURN 0
    IF PathExistsAny(dstPath) <> 0 THEN RETURN 0

    inFile = FREEFILE
    IF OPEN(srcPath FOR BINARY ACCESS READ AS #inFile) <> 0 THEN RETURN 0

    outFile = FREEFILE
    IF OPEN(dstPath FOR BINARY ACCESS WRITE AS #outFile) <> 0 THEN
        CLOSE #inFile
        RETURN 0
    END IF

    remaining = LOF(inFile)
    DO WHILE remaining > 0
        IF remaining > 8192 THEN
            takeBytes = 8192
        ELSE
            takeBytes = remaining
        END IF
        buffer = SPACE$(takeBytes)
        GET #inFile, , buffer
        PUT #outFile, , buffer
        remaining = remaining - takeBytes
    LOOP

    CLOSE #outFile
    CLOSE #inFile

    IF DIR(dstPath) <> "" THEN
        ClearDirectorySizeCache
        RETURN -1
    END IF
    RETURN 0
END FUNCTION

' ---------------------------
' Bound controls, config apply/save, and fast display updates
' ---------------------------

FUNCTION GetSelectedRadioValue(BYVAL groupName AS STRING) AS STRING
    DIM i AS INTEGER
    DIM target AS STRING

    target = UCASE$(TRIM$(groupName))
    IF target = "" THEN RETURN ""

    FOR i = 1 TO uiCount
        IF uiElems(i).kindId = UI_KIND_RADIO THEN
            IF uiElems(i).groupKey = target THEN
                IF uiElems(i).state <> 0 THEN
                    RETURN uiElems(i).bindValue
                END IF
            END IF
        END IF
    NEXT

    RETURN ""
END FUNCTION

FUNCTION ControlValueFromCombo(BYVAL elemIdx AS INTEGER) AS STRING
    DIM selectedText AS STRING
    DIM prefix AS STRING
    DIM i AS INTEGER
    DIM baseValue AS STRING

    IF elemIdx < 1 OR elemIdx > uiCount THEN RETURN ""
    selectedText = RTRIM$(uiElems(elemIdx).text)
    prefix = ExpandLayoutDynamicText(uiElems(elemIdx).valuePrefix)

    IF selectedText = "" THEN RETURN ""

    BuildComboItems elemIdx
    baseValue = selectedText
    FOR i = 1 TO tempComboItemCount
        IF UCASE$(RTRIM$(tempComboItems(i))) = UCASE$(selectedText) THEN
            baseValue = RTRIM$(tempComboValues(i))
            EXIT FOR
        END IF
    NEXT

    IF prefix = "" THEN RETURN baseValue
    RETURN prefix + baseValue
END FUNCTION


FUNCTION ControlValueFromListControl(BYVAL elemIdx AS INTEGER) AS STRING
    DIM selectedText AS STRING
    DIM i AS INTEGER

    IF elemIdx < 1 OR elemIdx > uiCount THEN RETURN ""
    selectedText = RTRIM$(uiElems(elemIdx).text)
    IF selectedText = "" THEN RETURN ""

    BuildComboItems elemIdx
    FOR i = 1 TO tempComboItemCount
        IF UCASE$(RTRIM$(tempComboValues(i))) = UCASE$(selectedText) THEN
            RETURN RTRIM$(tempComboValues(i))
        END IF
    NEXT
    FOR i = 1 TO tempComboItemCount
        IF UCASE$(RTRIM$(tempComboItems(i))) = UCASE$(selectedText) THEN
            RETURN RTRIM$(tempComboValues(i))
        END IF
    NEXT

    RETURN selectedText
END FUNCTION

SUB SetComboSelectionFromBoundValue(BYVAL elemIdx AS INTEGER, BYVAL boundVal AS STRING)
    DIM i AS INTEGER
    DIM normVal AS STRING
    DIM normItemVal AS STRING
    DIM itemVal AS STRING
    DIM prefix AS STRING

    IF elemIdx < 1 OR elemIdx > uiCount THEN EXIT SUB
    BuildComboItems elemIdx
    uiElems(elemIdx).text = ""
    normVal = NormalizePath(boundVal)
    prefix = ExpandLayoutDynamicText(uiElems(elemIdx).valuePrefix)

    FOR i = 1 TO tempComboItemCount
        itemVal = RTRIM$(tempComboValues(i))
        IF prefix <> "" THEN itemVal = prefix + itemVal
        normItemVal = NormalizePath(itemVal)
        IF normItemVal = normVal OR UCASE$(RTRIM$(tempComboValues(i))) = UCASE$(RTRIM$(boundVal)) OR UCASE$(RTRIM$(tempComboItems(i))) = UCASE$(RTRIM$(boundVal)) THEN
            uiElems(elemIdx).text = RTRIM$(tempComboItems(i))
            EXIT SUB
        END IF
    NEXT
END SUB

SUB PreloadBoundControlCfgFiles()
    DIM i AS INTEGER
    DIM j AS INTEGER
    DIM fileCount AS INTEGER
    DIM fileList(1 TO 32) AS STRING
    DIM fileName AS STRING
    DIM alreadyAdded AS INTEGER

    fileCount = 0
    FOR i = 1 TO uiCount
        IF TRIM$(uiElems(i).bindFile) <> "" THEN
            fileName = NormalizePath(LayoutFilePath(uiElems(i).bindFile))
            IF fileName <> "" THEN
                alreadyAdded = 0
                FOR j = 1 TO fileCount
                    IF UCASE$(RTRIM$(fileList(j))) = UCASE$(fileName) THEN
                        alreadyAdded = -1
                        EXIT FOR
                    END IF
                NEXT

                IF alreadyAdded = 0 THEN
                    IF fileCount < 32 THEN
                        fileCount = fileCount + 1
                        fileList(fileCount) = fileName
                        LoadCfgReadCacheFile fileName
                    END IF
                END IF
            END IF
        END IF
    NEXT
END SUB

SUB InitBoundControlsFromConfig()
    DIM i AS INTEGER
    DIM curVal AS STRING
    DIM checkValue AS STRING

    PreloadBoundControlCfgFiles

    FOR i = 1 TO uiCount
        SELECT CASE uiElems(i).kindKey
        CASE "COMBO"
            IF uiElems(i).bindFile <> "" AND uiElems(i).bindKey <> "" THEN
                curVal = ReadCfgValueInSection(uiElems(i).bindFile, uiElems(i).bindSection, uiElems(i).bindKey, "")
                SetComboSelectionFromBoundValue i, curVal
            END IF

        CASE "RADIO"
            IF uiElems(i).bindFile <> "" AND uiElems(i).bindKey <> "" THEN
                curVal = ReadCfgValueInSection(uiElems(i).bindFile, uiElems(i).bindSection, uiElems(i).bindKey, "")
                IF UCASE$(TRIM$(curVal)) = UCASE$(TRIM$(uiElems(i).bindValue)) THEN
                    uiElems(i).state = -1
                ELSE
                    uiElems(i).state = 0
                END IF
            END IF

        CASE "CHECKBOX"
            IF uiElems(i).bindFile <> "" AND uiElems(i).bindKey <> "" THEN
                checkValue = TRIM$(uiElems(i).bindValue)
                IF checkValue = "" THEN checkValue = "1"
                curVal = ReadCfgValueInSection(uiElems(i).bindFile, uiElems(i).bindSection, uiElems(i).bindKey, "0")
                IF UCASE$(TRIM$(curVal)) = UCASE$(checkValue) THEN
                    uiElems(i).state = -1
                ELSE
                    uiElems(i).state = 0
                END IF
            END IF

        CASE "TEXTBOX"
            IF uiElems(i).bindFile <> "" AND uiElems(i).bindKey <> "" THEN
                curVal = ReadCfgValueInSection(uiElems(i).bindFile, uiElems(i).bindSection, uiElems(i).bindKey, uiElems(i).text)
                uiElems(i).text = curVal
            END IF
        END SELECT
    NEXT
END SUB

SUB ResetBindingsFromConfig()
    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
            RestoreBindingSnapshotToGlobals activeLayoutWindow
            comboOpenIndex(activeLayoutWindow) = 0
            SyncLayoutWindowFromGlobals activeLayoutWindow
            EXIT SUB
        END IF
    END IF

    InitBoundControlsFromConfig
END SUB
SUB RefreshBoundControlsFromConfig()
    DIM i AS INTEGER
    DIM j AS INTEGER
    DIM bindFileName AS STRING
    DIM bindFileKey AS STRING
    DIM refreshCaret AS INTEGER
    DIM invalidatedFileCount AS INTEGER
    DIM invalidatedFile(1 TO 32) AS STRING
    DIM alreadyInvalidated AS INTEGER

    invalidatedFileCount = 0
    FOR i = 1 TO uiCount
        bindFileName = TRIM$(uiElems(i).bindFile)
        IF bindFileName <> "" THEN
            bindFileKey = UCASE$(NormalizePath(LayoutFilePath(bindFileName)))
            IF bindFileKey <> "" THEN
                alreadyInvalidated = 0
                FOR j = 1 TO invalidatedFileCount
                    IF RTRIM$(invalidatedFile(j)) = bindFileKey THEN
                        alreadyInvalidated = -1
                        EXIT FOR
                    END IF
                NEXT

                IF alreadyInvalidated = 0 THEN
                    InvalidateCfgReadCacheForFile bindFileName
                    IF invalidatedFileCount < 32 THEN
                        invalidatedFileCount = invalidatedFileCount + 1
                        invalidatedFile(invalidatedFileCount) = bindFileKey
                    END IF
                END IF
            END IF
        END IF
    NEXT

    InitBoundControlsFromConfig

    FOR i = 1 TO uiCount
        IF uiElems(i).kindId = UI_KIND_TEXTBOX THEN
            IF TRIM$(uiElems(i).bindFile) <> "" AND TRIM$(uiElems(i).bindKey) <> "" THEN
                refreshCaret = LEN(uiElems(i).text)
                Ed_SetTextGlue uiEdit(i), uiElems(i).text, uiElems(i).text, refreshCaret
                InvalidateTextboxMetrics i
                IF uiFocusIndex = i THEN uiCaretPos = refreshCaret
            END IF
        END IF
    NEXT

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
            comboOpenIndex(activeLayoutWindow) = 0
            SyncLayoutWindowFromGlobals activeLayoutWindow
            SaveBindingSnapshotFromGlobals activeLayoutWindow
            MarkLayoutWindowDirty activeLayoutWindow
        END IF
    END IF
END SUB


SUB ApplyBindingsFromControls()
    DIM i AS INTEGER
    DIM cfgValue AS STRING

    BeginCfgWriteBatch

    FOR i = 1 TO uiCount
        SELECT CASE uiElems(i).kindKey
        CASE "COMBO"
            IF uiElems(i).bindFile <> "" AND uiElems(i).bindKey <> "" THEN
                cfgValue = ControlValueFromCombo(i)
                SetCfgValueInSection uiElems(i).bindFile, uiElems(i).bindSection, uiElems(i).bindKey, cfgValue
            END IF

        CASE "RADIO"
            IF uiElems(i).state <> 0 THEN
                IF uiElems(i).bindFile <> "" AND uiElems(i).bindKey <> "" THEN
                    SetCfgValueInSection uiElems(i).bindFile, uiElems(i).bindSection, uiElems(i).bindKey, uiElems(i).bindValue
                END IF
            END IF

        CASE "CHECKBOX"
            IF uiElems(i).bindFile <> "" AND uiElems(i).bindKey <> "" THEN
                cfgValue = TRIM$(uiElems(i).bindValue)
                IF cfgValue = "" THEN cfgValue = "1"
                IF uiElems(i).state = 0 THEN cfgValue = "0"
                SetCfgValueInSection uiElems(i).bindFile, uiElems(i).bindSection, uiElems(i).bindKey, cfgValue
            END IF

        CASE "TEXTBOX"
            IF uiElems(i).bindFile <> "" AND uiElems(i).bindKey <> "" THEN
                cfgValue = uiElems(i).text
                IF TRIM$(uiElems(i).name) <> "" THEN cfgValue = GetTextboxTextByName(uiElems(i).name)
                SetCfgValueInSection uiElems(i).bindFile, uiElems(i).bindSection, uiElems(i).bindKey, cfgValue
            END IF
        END SELECT
    NEXT

        FlushCfgWriteBatch

    LoadAllConfig
    BuildLayout
    ReloadShellAssets

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
            SyncLayoutWindowFromGlobals activeLayoutWindow
            SaveBindingSnapshotFromGlobals activeLayoutWindow
        END IF
    END IF
END SUB


SUB ApplyBindingsFromControlsUsingSys(BYVAL sysFileName AS STRING, BYVAL sectionName AS STRING)
    DIM i AS INTEGER
    DIM cfgValue AS STRING
    DIM targetFileName AS STRING
    DIM activePageOnly AS INTEGER
    DIM reloadDisplay AS INTEGER
    DIM activePage AS STRING
    DIM elemPage AS STRING
    DIM includeElem AS INTEGER
    DIM presetControlName AS STRING
    DIM presetTargetFile AS STRING
    DIM presetKey AS STRING
    DIM presetPath AS STRING
    DIM presetIdx AS INTEGER
    DIM depthVal AS INTEGER
    DIM presetKeyTemplate AS STRING
    DIM presetCleanFast AS INTEGER
    DIM directPresetCopy AS INTEGER
    DIM skipKeys AS STRING

    LoadCfgReadCacheFile sysFileName

    targetFileName = NormalizePath(ReadCfgValueInSection(sysFileName, sectionName, "TARGET_FILE", ""))
    activePageOnly = VALINT(ReadCfgValueInSection(sysFileName, sectionName, "ACTIVE_PAGE_ONLY", "0"))
    reloadDisplay = VALINT(ReadCfgValueInSection(sysFileName, sectionName, "RELOAD_DISPLAY", "0"))
    presetControlName = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "STORE_PRESET_CONTROL", ""))
    presetTargetFile = NormalizePath(ReadCfgValueInSection(sysFileName, sectionName, "STORE_PRESET_FILE", targetFileName))
    presetKeyTemplate = TRIM$(ReadCfgValueInSection(sysFileName, sectionName, "STORE_PRESET_KEY", ""))

    activePage = ""
    IF activePageOnly <> 0 THEN GetLayoutActivePage activePage
    activePage = UCASE$(TRIM$(activePage))

    BeginCfgWriteBatch

    FOR i = 1 TO uiCount
        IF TRIM$(uiElems(i).bindFile) <> "" AND TRIM$(uiElems(i).bindKey) <> "" THEN
            includeElem = -1

            IF targetFileName <> "" THEN
                IF UCASE$(NormalizePath(uiElems(i).bindFile)) <> UCASE$(targetFileName) THEN includeElem = 0
            END IF

            IF includeElem <> 0 AND activePageOnly <> 0 THEN
                elemPage = uiElems(i).pageKey
                IF elemPage <> "" THEN
                    IF elemPage <> activePage THEN includeElem = 0
                END IF
            END IF

            IF includeElem <> 0 THEN
                SELECT CASE uiElems(i).kindKey
                CASE "COMBO"
                    cfgValue = ControlValueFromCombo(i)
                    SetCfgValueInSection uiElems(i).bindFile, uiElems(i).bindSection, uiElems(i).bindKey, cfgValue

                CASE "RADIO"
                    IF uiElems(i).state <> 0 THEN
                        SetCfgValueInSection uiElems(i).bindFile, uiElems(i).bindSection, uiElems(i).bindKey, uiElems(i).bindValue
                    END IF

                CASE "CHECKBOX"
                    cfgValue = TRIM$(uiElems(i).bindValue)
                    IF cfgValue = "" THEN cfgValue = "1"
                    IF uiElems(i).state = 0 THEN cfgValue = "0"
                    SetCfgValueInSection uiElems(i).bindFile, uiElems(i).bindSection, uiElems(i).bindKey, cfgValue

                CASE "TEXTBOX"
                    cfgValue = uiElems(i).text
                    IF TRIM$(uiElems(i).name) <> "" THEN cfgValue = GetTextboxTextByName(uiElems(i).name)
                    SetCfgValueInSection uiElems(i).bindFile, uiElems(i).bindSection, uiElems(i).bindKey, cfgValue
                END SELECT
            END IF
        END IF
    NEXT

    IF presetControlName <> "" AND presetTargetFile <> "" THEN
        depthVal = CfgPresetDepthForAction(sysFileName, sectionName)
        presetKey = ExpandLayoutDynamicText(presetKeyTemplate)

        IF presetKey <> "" THEN
            presetPath = ""
            presetIdx = GetControlIndexByName(presetControlName)
            IF presetIdx >= 1 AND presetIdx <= uiCount THEN
                presetPath = ControlValueFromCombo(presetIdx)
                IF LEFT$(UCASE$(presetPath), 2) = "F:" THEN presetPath = MID$(presetPath, 3)
                presetPath = NormalizePath(presetPath)
            END IF
            SetCfgValueInSection presetTargetFile, "", presetKey, presetPath
        END IF
    END IF

    FlushCfgWriteBatch

    IF reloadDisplay <> 0 THEN
        RefreshVisualConfigFast
    END IF

    IF activeLayoutWindow >= LBOUND(layoutWindows) AND activeLayoutWindow <= UBOUND(layoutWindows) THEN
        IF layoutWindows(activeLayoutWindow).used <> 0 THEN
            SyncLayoutWindowFromGlobals activeLayoutWindow
            SaveBindingSnapshotFromGlobals activeLayoutWindow
        END IF
    END IF
END SUB

