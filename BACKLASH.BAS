        EXIT SUB
    END IF

    startMenuOpen = 0
    launchCtxOpen = 0
    desktopCtxOpen = 0
    ExecuteAppFile dlgPath
END SUB

SUB ApplyDesktopIconEditFromControls(BYVAL winIdx AS INTEGER)
    DIM editName AS STRING
    DIM editTarget AS STRING
    DIM editIcon AS STRING
    DIM editX AS STRING
    DIM editY AS STRING

    IF desktopEditIconIdx < 1 OR desktopEditIconIdx > iconCount THEN EXIT SUB

    IF winIdx >= LBOUND(layoutWindows) AND winIdx <= UBOUND(layoutWindows) THEN
        IF layoutWindows(winIdx).used <> 0 THEN
            IF activeLayoutWindow = winIdx THEN SyncLayoutWindowFromGlobals winIdx
            activeLayoutWindow = winIdx
            SyncGlobalsFromLayoutWindow winIdx
        END IF
    END IF

    editName = TRIM$(GetDialogBoundControlTextValue(winIdx, DesktopIconEditTempPath(), "ICON", "DISPLAY"))
    editTarget = TRIM$(GetDialogBoundControlTextValue(winIdx, DesktopIconEditTempPath(), "ICON", "TARGET"))
    editIcon = TRIM$(GetDialogBoundControlTextValue(winIdx, DesktopIconEditTempPath(), "ICON", "ICON"))
    editX = TRIM$(GetDialogBoundControlTextValue(winIdx, DesktopIconEditTempPath(), "ICON", "X"))
    editY = TRIM$(GetDialogBoundControlTextValue(winIdx, DesktopIconEditTempPath(), "ICON", "Y"))

    IF editName = "" THEN editName = TRIM$(ReadCfgValueInSection(DesktopIconEditTempPath(), "ICON", "DISPLAY", desktopIcons(desktopEditIconIdx).caption))
    IF editTarget = "" THEN editTarget = TRIM$(ReadCfgValueInSection(DesktopIconEditTempPath(), "ICON", "TARGET", desktopIcons(desktopEditIconIdx).action))
    IF editIcon = "" THEN editIcon = TRIM$(ReadCfgValueInSection(DesktopIconEditTempPath(), "ICON", "ICON", desktopIcons(desktopEditIconIdx).bmpFile))
    IF editX = "" THEN editX = TRIM$(ReadCfgValueInSection(DesktopIconEditTempPath(), "ICON", "X", LTRIM$(STR$(desktopIcons(desktopEditIconIdx).x))))
    IF editY = "" THEN editY = TRIM$(ReadCfgValueInSection(DesktopIconEditTempPath(), "ICON", "Y", LTRIM$(STR$(desktopIcons(desktopEditIconIdx).y))))

    IF DesktopIconValidateBasic(editName, editTarget, editIcon, editX, editY, "TARGET_REQUIRED") = 0 THEN EXIT SUB

    desktopIcons(desktopEditIconIdx).caption = editName
    desktopIcons(desktopEditIconIdx).action = editTarget
    desktopIcons(desktopEditIconIdx).bmpFile = NormalizePath(editIcon)
    desktopIcons(desktopEditIconIdx).x = VALINT(editX)
    desktopIcons(desktopEditIconIdx).y = VALINT(editY)

