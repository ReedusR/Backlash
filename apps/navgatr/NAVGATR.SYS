W=72
H=24
ACTION=CLOSE_WINDOW

[EVENTS]
ON ACTION FILE_BROWSER_ATTR_CLOSE
    HOST FILE_BROWSER_ATTR_APPLY
    HOST CLOSE_WINDOW
END

ON ACTION FILE_BROWSER_RENAME_APPLY REN_PATH REN_NEW
    HOST FILE_BROWSER_RENAME_APPLY REN_PATH REN_NEW REN_STATUS
    HOST CLOSE_WINDOW
END

ON ACTION FILE_BROWSER_DELETE_APPLY
    HOST FILE_BROWSER_DELETE_APPLY DEL_PATH DEL_STATUS DEL_RECURSE DEL_PERMANENT
    HOST CLOSE_WINDOW
END

ON ACTION FILE_BROWSER_DUPLICATE_APPLY DUP_PATH DUP_NEW
    HOST FILE_BROWSER_DUPLICATE_APPLY DUP_PATH DUP_NEW DUP_STATUS
    HOST CLOSE_WINDOW
END

ON ACTION FILE_BROWSER_DIR_COPY_APPLY COPY_SRC COPY_DEST COPY_FILES COPY_SUBDIRS COPY_EMPTY COPY_HIDDEN COPY_OVERWRITE
    HOST FILE_BROWSER_DIR_COPY_APPLY COPY_SRC COPY_DEST COPY_FILES COPY_SUBDIRS COPY_EMPTY COPY_HIDDEN COPY_OVERWRITE
    HOST CLOSE_WINDOW
END

ON ACTION FILE_BROWSER_DRAG_COPY
    HOST FILE_BROWSER_DRAGDROP_APPLY COPY
    HOST CLOSE_WINDOW
END

ON ACTION FILE_BROWSER_DRAG_MOVE
    HOST FILE_BROWSER_DRAGDROP_APPLY MOVE
    HOST CLOSE_WINDOW
END

ON ACTION CLOSE_WINDOW
    HOST CLOSE_WINDOW
END
