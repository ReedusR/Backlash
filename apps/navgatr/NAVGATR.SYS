[DELETE]
title=Waste Basket
ui=LAYOUT
single_instance=1
resizable=0
DIALOG_INIT_FILE_1=DEL_NAME|SOURCE_NAME
DIALOG_INIT_DIR_1=DEL_NAME|SOURCE_NAME
DIALOG_INIT_MULTI_1=DEL_NAME|SOURCE_NAME_OR_COUNT
DIALOG_STATE_1=DEL_RECURSE|0
DIALOG_STATE_2=DEL_PERMANENT|0
DIALOG_CLEAR_FOCUS=1
DIALOG_TEXT_FILE_1=DEL_LABEL|Move to trash?
DIALOG_TEXT_DIR_1=DEL_LABEL|Move to trash?
DIALOG_TEXT_MULTI_1=DEL_LABEL|Move to trash?
DIALOG_TEXT_MULTIDIR_1=DEL_LABEL|Move to trash?
DIALOG_INIT_MULTIDIR_1=DEL_NAME|SOURCE_NAME_OR_COUNT
DIALOG_HIDE_CONTROL_FILE_1=DEL_RECURSE
DIALOG_HIDE_CONTROL_MULTI_1=DEL_RECURSE
DIALOG_SHOW_CONTROL_FILE_1=DEL_PERMANENT
DIALOG_SHOW_CONTROL_MULTI_1=DEL_PERMANENT
