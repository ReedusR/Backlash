DIALOG_HIDE_CONTROL_DIR_10=PROP_ATTR_S
DIALOG_HIDE_CONTROL_DIR_11=PROP_ATTR_H
DIALOG_STATE_FILE_1=PROP_ATTR_R|SOURCE_ATTR_READONLY
DIALOG_STATE_FILE_2=PROP_ATTR_A|SOURCE_ATTR_ARCHIVE
DIALOG_STATE_FILE_3=PROP_ATTR_S|SOURCE_ATTR_SYSTEM
