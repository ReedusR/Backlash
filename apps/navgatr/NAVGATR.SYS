DIALOG_STATE_DIR_1=PROP_ATTR_R|SOURCE_ATTR_READONLY
DIALOG_STATE_DIR_2=PROP_ATTR_A|SOURCE_ATTR_ARCHIVE
DIALOG_STATE_DIR_3=PROP_ATTR_S|SOURCE_ATTR_SYSTEM
DIALOG_STATE_DIR_4=PROP_ATTR_H|SOURCE_ATTR_HIDDEN
DIALOG_CLEAR_FOCUS=1

