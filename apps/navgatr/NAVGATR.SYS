DIALOG_HIDE_CONTROL_DIR_6=PROP_EDIT
DIALOG_HIDE_CONTROL_DIR_7=PROP_ATTR_LABEL
DIALOG_HIDE_CONTROL_DIR_8=PROP_ATTR_R
