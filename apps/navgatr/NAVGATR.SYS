; Action script for NAVGATR. The app calls these sections from buttons, key shortcuts, and event blocks.
;
' NAVGATR.SYS
' Navigator external dialogs

[PROPERTIES]
title=Properties
ui=LAYOUT
single_instance=1
resizable=0
ATTR_READONLY_CONTROL=PROP_ATTR_R
ATTR_ARCHIVE_CONTROL=PROP_ATTR_A
ATTR_SYSTEM_CONTROL=PROP_ATTR_S
ATTR_HIDDEN_CONTROL=PROP_ATTR_H
DIALOG_INIT_FILE_1=PROP_NAME|SOURCE_NAME
DIALOG_INIT_FILE_2=PROP_PATH|SOURCE_PATH
DIALOG_INIT_FILE_3=PROP_EXT|SOURCE_EXTENSION_OR_NONE
DIALOG_INIT_FILE_4=PROP_SIZE|SOURCE_SIZE
DIALOG_INIT_FILE_5=PROP_ASSOC|SOURCE_OPEN_ACTION_OR_NO_ASSOCIATION
DIALOG_INIT_FILE_6=PROP_EDIT|SOURCE_EDIT_ACTION_OR_UNAVAILABLE
DIALOG_INIT_DIR_1=PROP_NAME|SOURCE_NAME
DIALOG_INIT_DIR_2=PROP_PATH|SOURCE_PATH
DIALOG_INIT_DIR_3=PROP_SIZE|SOURCE_SIZE
DIALOG_SHOW_CONTROL_FILE_1=PROP_EXT_LABEL
DIALOG_SHOW_CONTROL_FILE_2=PROP_EXT
DIALOG_SHOW_CONTROL_FILE_3=PROP_ASSOC_LABEL
DIALOG_SHOW_CONTROL_FILE_4=PROP_ASSOC
DIALOG_SHOW_CONTROL_FILE_5=PROP_EDIT_LABEL
DIALOG_SHOW_CONTROL_FILE_6=PROP_EDIT
DIALOG_SHOW_CONTROL_FILE_7=PROP_ATTR_LABEL
DIALOG_SHOW_CONTROL_FILE_8=PROP_ATTR_R
DIALOG_SHOW_CONTROL_FILE_9=PROP_ATTR_A
DIALOG_SHOW_CONTROL_FILE_10=PROP_ATTR_S
DIALOG_SHOW_CONTROL_FILE_11=PROP_ATTR_H
DIALOG_HIDE_CONTROL_DIR_1=PROP_EXT_LABEL
