[TEXTBOX]
NAME=CALC_ACTION
X=-3000
Y=-3000
W=1
H=1
TEXT=
READONLY=1

[TEXTBOX]
NAME=ACTION_FILE
X=-3000
Y=-3000
W=1
H=1
TEXT=ACTION.TMP
READONLY=1
BIND_FILE=ACTION.TMP

[TEXTBOX]
NAME=DISPLAY_FILE
X=-3000
Y=-3000
W=1
H=1
TEXT=DISPLAY.TMP
READONLY=1
BIND_FILE=DISPLAY.TMP

[TEXTBOX]
NAME=STATE_FILE
X=-3000
Y=-3000
W=1
H=1
TEXT=STATE.TMP
READONLY=1
BIND_FILE=STATE.TMP

[TEXTBOX]
NAME=RESULT_FILE
X=-3000
Y=-3000
W=1
H=1
TEXT=RESULT.TMP
READONLY=1
BIND_FILE=RESULT.TMP


[TEXTBOX]
NAME=HISTORY_FILE
X=-3000
Y=-3000
W=1
H=1
TEXT=HISTORY.TMP
READONLY=1
BIND_FILE=HISTORY.TMP

[EVENTS]
ON ACTION CALC_KEY CLEAR
    HOST SYS_ACTION CALC.SYS KEY CLEAR
    HOST TEXT_SAVE CALC_ACTION ACTION_FILE
    HOST RUN_INLINE_HELPER CALCCTL.EXE
    HOST TEXT_LOAD CALC_DISPLAY DISPLAY_FILE
END
ON ACTION CALC_KEY BACK
    HOST SYS_ACTION CALC.SYS KEY BACK
    HOST TEXT_SAVE CALC_ACTION ACTION_FILE
    HOST RUN_INLINE_HELPER CALCCTL.EXE
    HOST TEXT_LOAD CALC_DISPLAY DISPLAY_FILE
END
ON ACTION CALC_KEY LPAREN
