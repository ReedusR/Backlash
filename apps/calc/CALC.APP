; Layout file for the CALC Backlash app. It defines the window, controls, saved bindings, and button actions.
;
title=Calculator
ui=LAYOUT
single_instance=0
resizable=0
mode=BASIC
default_display="               0"
KEY_ACTION=SYS_ACTION CALC.SYS KEYBOARD
SESSION_STATE=GENERIC


[WINDOW]
X=120
Y=70
W=320
H=284

[TEXTBOX]
NAME=CALC_DISPLAY
X=12
Y=12
W=140
H=30
TEXT=0
READONLY=1
BIND_FILE=CALC.APP
BIND_KEY=default_display


[TAB]
TEXT=Basic
X=12
Y=52
W=80
H=22
BIND_FILE=CALC.APP
BIND_KEY=mode
BIND_VALUE=BASIC

[TAB]
TEXT=Scientific
X=96
Y=52
W=112
H=22
BIND_FILE=CALC.APP
BIND_KEY=mode
BIND_VALUE=SCIENTIFIC
ACTION=SYS_ACTION CALC.SYS SCI_MODE

[BUTTON]
TEXT=History
X=212
Y=52
W=92
H=22
ACTION=SYS_ACTION CALC.SYS SHOW_HISTORY

[BUTTON]
TEXT=C
X=12
Y=84
W=52
H=28
ACTION=CALC_KEY CLEAR

[BUTTON]
TEXT=Back
X=72
Y=84
W=52
H=28
ACTION=CALC_KEY BACK

[BUTTON]
TEXT=(
