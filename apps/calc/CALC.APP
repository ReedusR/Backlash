X=192
Y=192
W=52
H=28
ACTION=CALC_KEY PLUS

[BUTTON]
TEXT=0
X=12
Y=228
W=112
H=28
ACTION=CALC_KEY 0

[BUTTON]
TEXT=.
X=132
Y=228
W=52
H=28
ACTION=CALC_KEY DOT

[BUTTON]
TEXT=+/-
X=192
Y=228
W=52
H=28
ACTION=CALC_KEY NEG

[BUTTON]
TEXT==
X=252
Y=120
W=52
H=136
ACTION=CALC_KEY EQUALS

[BUTTON]
PAGE=Scientific
TEXT=sin
