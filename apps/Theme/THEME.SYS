[PROFILE]
COMMAND=CONTROL_EDIT_OPEN
DIALOG=THEME.APP
PROFILE=$1
COPY_1=SAVE_NAME|SAVE_NAME

[SELECT4]
ACTION=SYS_ACTION APPS\THEME\THEME.SYS PROFILE HIDE4A
ACTION2=SYS_ACTION APPS\THEME\THEME.SYS PROFILE HIDE8A
ACTION3=SYS_ACTION APPS\THEME\THEME.SYS PROFILE HIDE8B
ACTION4=SYS_ACTION APPS\THEME\THEME.SYS PROFILE HIDE8C
