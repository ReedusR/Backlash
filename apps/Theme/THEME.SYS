; Action script for THEME. The app calls these sections from buttons, key shortcuts, and event blocks.
;
[LOAD]
ACTION=SYS_ACTION APPS\THEME\THEME.SYS LOAD_PRESET
ACTION2=SYS_ACTION APPS\THEME\THEME.SYS SAVE_CURRENT
ACTION3=INVALIDATE_PREVIEW_CACHE

[LOAD_PRESET]
COMMAND=CFG_PRESET_LOAD
PRESET_CONTROL=PRESET
TARGET_FILE=SYSTEM\THEME.CFG
MATCH_KEY=COLOR_DEPTH
MATCH_VALUE_SOURCE=SELECTED_TAB
MATCH_ALLOW_MISSING=1
STATUS=

[INIT_CURRENT]
ACTION=SYS_ACTION APPS\THEME\THEME.SYS SAVE_CURRENT
ACTION2=SYS_ACTION APPS\THEME\THEME.SYS LOAD_CURRENT
ACTION3=INVALIDATE_PREVIEW_CACHE

[LOAD_CURRENT]
COMMAND=CFG_PRESET_LOAD
PRESET_CONTROL=CURRENT_PATH
TARGET_FILE=SYSTEM\THEME.CFG
MATCH_KEY=COLOR_DEPTH
MATCH_VALUE_SOURCE=SELECTED_TAB
MATCH_ALLOW_MISSING=1
STATUS=

[SAVE_CURRENT]
COMMAND=CFG_PRESET_SAVE
PRESET_CONTROL=CURRENT_NAME
NAME_CONTROL=CURRENT_NAME
STATUS=
TARGET_FILE=SYSTEM\THEME.CFG
TARGET_DIR=SYSTEM
FILE_EXT=THM
PROMPT_IF_EMPTY=0
CONFIRM_OVERWRITE=0
WRITE_NAME_KEY=NAME
WRITE_DEPTH_KEY=COLOR_DEPTH
DEPTH_SOURCE=SELECTED_TAB

[SAVE]
COMMAND=CFG_PRESET_SAVE
PRESET_CONTROL=PRESET
NAME_CONTROL=SAVE_NAME
STATUS=
TARGET_FILE=SYSTEM\THEME.CFG
TARGET_DIR=THEMES\%DEPTHFOLDER%
FILE_EXT=THM
PROMPT_IF_EMPTY=1
PROMPT_TITLE=Theme Manager
PROMPT_MESSAGE=Enter theme file name:
CONFIRM_OVERWRITE=1
OVERWRITE_TITLE=Theme Manager
WRITE_NAME_KEY=NAME
WRITE_DEPTH_KEY=COLOR_DEPTH
DEPTH_SOURCE=SELECTED_TAB

[APPLY]
ACTION=SYS_ACTION APPS\THEME\THEME.SYS APPLY_PRESET
ACTION2=SYS_ACTION APPS\THEME\THEME.SYS SAVE_CURRENT
ACTION3=INVALIDATE_PREVIEW_CACHE

[APPLY_PRESET]
COMMAND=CFG_PRESET_APPLY
PRESET_CONTROL=PRESET
DIRECT_PRESET_COPY=1
SKIP_KEYS=NAME|COLOR_DEPTH
FALLBACK_TO_CONTROLS_ON_DIRTY=1
MATCH_DEPTH=1
MATCH_KEY=COLOR_DEPTH
MATCH_VALUE_SOURCE=SELECTED_TAB
MATCH_ALLOW_MISSING=1
SOURCE_DIR=THEMES\%DEPTHFOLDER%
TARGET_FILE=SYSTEM\THEME.CFG
ACTIVE_PAGE_ONLY=0
RELOAD_DISPLAY=1
DEPTH_SOURCE=SELECTED_TAB
STORE_PRESET_CONTROL=PRESET
STORE_PRESET_FILE=SYSTEM\THEME.CFG
STORE_PRESET_KEY=current_theme_%DEPTH%

[RESET]
ACTION=SYS_ACTION APPS\THEME\THEME.SYS LOAD_CURRENT
ACTION2=INVALIDATE_PREVIEW_CACHE

[DEPTH4]
COMMAND=CFG_SET_CONFIRM
TARGET_FILE=SYSTEM\DISPLAY.CFG
TARGET_KEY=colordepth
TARGET_VALUE=4
CONFIRM_TITLE=Theme Manager
CONFIRM_MESSAGE=Are you sure you wish to change to 16 colors?
RELOAD_DISPLAY=1
REFRESH_PAGE=1

[DEPTH8]
COMMAND=CFG_SET_CONFIRM
TARGET_FILE=SYSTEM\DISPLAY.CFG
TARGET_KEY=colordepth
TARGET_VALUE=8
CONFIRM_TITLE=Theme Manager
CONFIRM_MESSAGE=Are you sure you wish to change to 256 colors?
RELOAD_DISPLAY=1
REFRESH_PAGE=1

[DEPTH16]
COMMAND=CFG_SET_CONFIRM
TARGET_FILE=SYSTEM\DISPLAY.CFG
TARGET_KEY=colordepth
TARGET_VALUE=16
CONFIRM_TITLE=Theme Manager
CONFIRM_MESSAGE=Are you sure you wish to change to high color?
RELOAD_DISPLAY=1
REFRESH_PAGE=1

[DEPTH4TAB]
ACTION=SYS_ACTION APPS\THEME\THEME.SYS DEPTH4
ACTION2=SYS_ACTION APPS\THEME\THEME.SYS PROFILE HIDE4A
ACTION3=SYS_ACTION APPS\THEME\THEME.SYS PROFILE HIDE8A
ACTION4=SYS_ACTION APPS\THEME\THEME.SYS PROFILE HIDE8B
ACTION5=SYS_ACTION APPS\THEME\THEME.SYS PROFILE HIDE8C
ACTION6=SYS_ACTION APPS\THEME\THEME.SYS PROFILE HIDEHA
ACTION7=SYS_ACTION APPS\THEME\THEME.SYS PROFILE HIDEHB
ACTION8=SYS_ACTION APPS\THEME\THEME.SYS PROFILE HIDEHC
ACTION9=SYS_ACTION APPS\THEME\THEME.SYS PROFILE HIDEHD

[DEPTH8TAB]
ACTION=SYS_ACTION APPS\THEME\THEME.SYS DEPTH8
ACTION2=SYS_ACTION APPS\THEME\THEME.SYS PROFILE HIDE4A
ACTION3=SYS_ACTION APPS\THEME\THEME.SYS PROFILE HIDE8A
ACTION4=SYS_ACTION APPS\THEME\THEME.SYS PROFILE HIDE8B
ACTION5=SYS_ACTION APPS\THEME\THEME.SYS PROFILE HIDE8C
ACTION6=SYS_ACTION APPS\THEME\THEME.SYS PROFILE HIDEHA
ACTION7=SYS_ACTION APPS\THEME\THEME.SYS PROFILE HIDEHB
ACTION8=SYS_ACTION APPS\THEME\THEME.SYS PROFILE HIDEHC
ACTION9=SYS_ACTION APPS\THEME\THEME.SYS PROFILE HIDEHD

[DEPTH16TAB]
