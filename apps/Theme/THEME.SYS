ACTION7=SYS_ACTION APPS\THEME\THEME.SYS PROFILE HIDEHC
ACTION8=SYS_ACTION APPS\THEME\THEME.SYS PROFILE HIDEHD
ACTION9=SYS_ACTION APPS\THEME\THEME.SYS PROFILE SHOW_$1
