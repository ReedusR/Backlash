ACTION8=SYS_ACTION APPS\THEME\THEME.SYS PROFILE HIDEHC
ACTION9=SYS_ACTION APPS\THEME\THEME.SYS PROFILE HIDEHD

[PREV4]
TARGET_FILE=SYSTEM\THEME.CFG
DEPTH=4
COLOR_MODE=INDEX16
COLOR_DESKTOP=IDX:desktop_idx_4:1
COLOR_BACKGROUND=ALIAS:DESKTOP
COLOR_TASKBAR=IDX:taskbar_idx_4:7
COLOR_BUTTON=ALIAS:TASKBAR
COLOR_TITLE=IDX:select_idx_4:1
COLOR_SELECTEDBG=ALIAS:TITLE
COLOR_BEVELHI=IDX:bevel_hi_idx_4:15
COLOR_BEVELLO=IDX:bevel_lo_idx_4:8
COLOR_TEXT=IDX:text_idx_4:0
COLOR_TEXTINV=IDX:textinv_idx_4:15
COLOR_SELECTEDTEXT=ALIAS:TEXTINV
COLOR_CONTROLBG=IDX:control_bg_idx_4:15
COLOR_MISSING=IDX:missing_idx_4:12

DRAW1=RECT 0,0,W-1,H-1,DESKTOP,F
DRAW2=RECT 0,H-34,W-1,H-1,TASKBAR,F
DRAW3=LINE 0,H-34,W-1,H-34,BEVELHI
DRAW4=LINE 0,H-33,W-1,H-33,BEVELLO
DRAW5=RECT 8,H-27,88,H-7,BUTTON,F
DRAW6=RECT 8,H-27,88,H-7,BEVELHI,B
DRAW7=TEXT 18,H-20,Launch,TEXT
DRAW8=RECT 8,28,118,H-40,BACKGROUND,F
DRAW9=RECT 8,28,118,H-40,BEVELHI,B
DRAW10=RECT 16,38,110,56,SELECTEDBG,F
DRAW11=TEXT 22,43,Program,SELECTEDTEXT
DRAW12=TEXT 22,68,Settings,TEXT
DRAW13=TEXT 22,90,System,TEXT
DRAW14=RECT W/2-60,42,W-18,H-50,BACKGROUND,F
DRAW15=LINE W/2-60,42,W-18,42,BEVELHI
DRAW16=LINE W/2-60,42,W/2-60,H-50,BEVELHI
DRAW17=LINE W/2-60,H-50,W-18,H-50,BEVELLO
DRAW18=LINE W-18,42,W-18,H-50,BEVELLO
DRAW19=RECT W/2-57,45,W-21,62,TITLE,F
DRAW20=TEXT W/2-52,50,Preview Window,TEXTINV
DRAW21=RECT W/2-52,76,W-26,H-58,CONTROLBG,F
DRAW22=RECT W/2-52,76,W-26,H-58,BEVELLO,B
DRAW23=TEXT W/2-44,86,Sample text,TEXT
DRAW24=RECT W/2-44,104,W/2+46,124,SELECTEDBG,F
DRAW25=TEXT W/2-36,110,Selected,SELECTEDTEXT
DRAW26=RECT W-78,H-82,W-32,H-62,BUTTON,F
DRAW27=RECT W-78,H-82,W-32,H-62,BEVELHI,B
DRAW28=TEXT W-72,H-76,Button,TEXT


