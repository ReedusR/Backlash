FILTER_DIALOG=NAVIGATR.SYS#FILTER

FILE_BROWSER_DIR_CONTROL=DIR_TREE
FILE_BROWSER_FILE_CONTROL=FILE_VIEW
FILE_BROWSER_PATH_CONTROL=PATH_BOX
FILE_BROWSER_STATS_CONTROL=FILE_STATS_LABEL
FILE_BROWSER_STATUS_CONTROL=STATUS_BOX
FILE_BROWSER_PATH_CONTROL_DIR_TREE=PATH_BOX
FILE_BROWSER_PATH_CONTROL_FILE_VIEW=PATH_BOX
