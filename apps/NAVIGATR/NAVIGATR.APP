MOVE_Y=1

[EVENTS]
ON INIT
    HOST FILE_BROWSER_INIT DIR_TREE FILE_VIEW PATH_BOX .
END

ON CHANGE DIR_TREE
    HOST FILE_BROWSER_DIR_SELECT DIR_TREE FILE_VIEW PATH_BOX
END

ON CHANGE FILE_VIEW
    HOST FILE_BROWSER_FILE_SELECT FILE_VIEW STATUS_BOX
END

ON CHANGE COMBINED_VIEW
    HOST FILE_BROWSER_FILE_SELECT COMBINED_VIEW STATUS_BOX
END

ON CHANGE LEFT_VIEW
    HOST FILE_BROWSER_FILE_SELECT LEFT_VIEW STATUS_BOX
END

ON CHANGE RIGHT_VIEW
    HOST FILE_BROWSER_FILE_SELECT RIGHT_VIEW STATUS_BOX
END

ON DBLCLICK FILE_VIEW
    HOST FILE_BROWSER_FILE_OPEN FILE_VIEW STATUS_BOX
END

ON DBLCLICK COMBINED_VIEW
    HOST FILE_BROWSER_PANE_OPEN COMBINED_VIEW COMBINED_PATH_BOX STATUS_BOX
END

ON DBLCLICK LEFT_VIEW
    HOST FILE_BROWSER_PANE_OPEN LEFT_VIEW LEFT_PATH_BOX STATUS_BOX
END

ON DBLCLICK RIGHT_VIEW
    HOST FILE_BROWSER_PANE_OPEN RIGHT_VIEW RIGHT_PATH_BOX STATUS_BOX
END

ON ACTION FILE_BROWSER_REFRESH PATH_BOX
    HOST FILE_BROWSER_REFRESH PATH_BOX
END

ON ACTION CLOSE_WINDOW
    HOST CLOSE_WINDOW
END
