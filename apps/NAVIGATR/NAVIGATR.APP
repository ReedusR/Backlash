APP_MENU_3=View|NAV_VIEW
APP_MENU_4=Sort|NAV_SORT
APP_MENU_5=Filter|NAV_FILTER
APP_MENU_6=Help|NAV_HELP

NAV_FILE_1=Open|FILE_BROWSER_PANE_OPEN ACTIVE FILE_BROWSER_ACTIVE_PATH STATUS_BOX
NAV_FILE_2=Open New Window|FILE_BROWSER_DIR_OPEN_NEW ACTIVE STATUS_BOX
NAV_FILE_3=New Directory|FILE_BROWSER_DIR_NEW PATH_BOX STATUS_BOX
NAV_FILE_4=Copy Directory|FILE_BROWSER_DIR_COPY ACTIVE STATUS_BOX
NAV_FILE_5=-|
NAV_FILE_6=Properties|FILE_BROWSER_FILE_PROPERTIES ACTIVE STATUS_BOX
NAV_FILE_7=-|
NAV_FILE_8=Close|CLOSE_WINDOW

NAV_EDIT_1=Cut|FILE_BROWSER_FILE_CUT ACTIVE STATUS_BOX
NAV_EDIT_2=Copy|FILE_BROWSER_FILE_COPY ACTIVE STATUS_BOX
NAV_EDIT_3=Paste|FILE_BROWSER_FILE_PASTE FILE_BROWSER_CLIPBOARD_DEST_PATH STATUS_BOX
NAV_EDIT_4=Duplicate|FILE_BROWSER_FILE_DUPLICATE ACTIVE STATUS_BOX
NAV_EDIT_5=Rename|FILE_BROWSER_FILE_RENAME ACTIVE STATUS_BOX
NAV_EDIT_6=Delete|FILE_BROWSER_FILE_DELETE ACTIVE STATUS_BOX

NAV_VIEW_1=Split Directories and Files|SYS_ACTION NAVIGATR.SYS SET_VIEW_SPLIT
NAV_VIEW_2=Combined Directories and Files|SYS_ACTION NAVIGATR.SYS SET_VIEW_COMBINED
NAV_VIEW_3=Dual Pane|SYS_ACTION NAVIGATR.SYS SET_VIEW_DUAL
NAV_VIEW_4=-|
NAV_VIEW_5=Toggle Colors|FILE_BROWSER_TOGGLE_COLORS STATUS_BOX
NAV_VIEW_6=-|
NAV_VIEW_7=Refresh|SYS_ACTION NAVIGATR.SYS REFRESH_VIEW

NAV_SORT_1=Name|FILE_BROWSER_SET_SORT NAME STATUS_BOX
NAV_SORT_2=Extension|FILE_BROWSER_SET_SORT EXTENSION STATUS_BOX
NAV_SORT_3=Size|FILE_BROWSER_SET_SORT SIZE STATUS_BOX
NAV_SORT_4=Date|FILE_BROWSER_SET_SORT DATE STATUS_BOX

NAV_FILTER_1=Set Mask...|FILE_BROWSER_MASK_DIALOG STATUS_BOX
NAV_FILTER_2=Clear Mask|FILE_BROWSER_CLEAR_MASK STATUS_BOX

NAV_HELP_1=Navigator Help|LAUNCH_APP NAVHELP.APP


CONTEXT_OPEN_TEXT=Open
CONTEXT_DIR_OPEN_TEXT=Open New
CONTEXT_EDIT_TEXT=Edit
CONTEXT_CUT_TEXT=Cut
CONTEXT_CUT_ACTION=FILE_BROWSER_FILE_CUT
CONTEXT_COPY_TEXT=Copy
CONTEXT_COPY_ACTION=FILE_BROWSER_FILE_COPY
CONTEXT_DUPLICATE_TEXT=Duplicate
CONTEXT_DUPLICATE_ACTION=FILE_BROWSER_FILE_DUPLICATE
CONTEXT_RENAME_TEXT=Rename
CONTEXT_DELETE_TEXT=Delete
CONTEXT_PROPERTIES_TEXT=Properties
CONTEXT_PASTE_TEXT=Paste
CONTEXT_PASTE_CONTROL=FILE_VIEW
CONTEXT_PASTE_ACTION=FILE_BROWSER_FILE_PASTE FILE_BROWSER_CLIPBOARD_DEST_PATH STATUS_BOX
SESSION_STATE=GENERIC
SESSION_RESTORE_ACTION=FILE_BROWSER_REFRESH PATH_BOX


[WINDOW]
X=30
Y=30
W=680
H=450

[MENUBAR]
NAME=MAIN_MENU
X=0
Y=0
W=676
H=20
GROW_W=1


[BUTTON]
NAME=HELP_BUTTON
TEXT=Help
X=622
Y=1
W=50
H=18
GROW_W=0
ACTION=LAUNCH_APP NAVHELP.APP

[LABEL]
TEXT=Path
X=12
Y=30
PAGE=Split

[TEXTBOX]
NAME=PATH_BOX
X=50
Y=26
W=620
H=22
GROW_W=1
TEXT=.
ENTER_ACTION=FILE_BROWSER_PATH_GO PATH_BOX ACTIVE STATUS_BOX
PAGE=Split

[LABEL]
TEXT=Path
X=12
Y=30
PAGE=Combined

[TEXTBOX]
NAME=COMBINED_PATH_BOX
X=50
Y=26
W=620
H=22
GROW_W=1
TEXT=.
ENTER_ACTION=FILE_BROWSER_PATH_GO COMBINED_PATH_BOX COMBINED_VIEW STATUS_BOX
PAGE=Combined


[LISTBOX]
NAME=SPLIT_DRIVES
SOURCE_KIND=DRIVES
STYLE=BUTTON
X=12
Y=52
W=320
H=22
SOURCE_DIR=.
SOURCE_CONTROL=PATH_BOX
ACTION=FILE_BROWSER_DRIVE_SELECT SPLIT_DRIVES PATH_BOX FILE_VIEW STATUS_BOX
PAGE=Split

[LABEL]
NAME=DIR_LABEL
TEXT=Directories
X=12
Y=76
PAGE=Split

[LABEL]
NAME=FILE_LABEL
TEXT=Name              Size  Date        Attr
X=216
Y=76
PAGE=Split

[LISTBOX]
NAME=DIR_TREE
SOURCE_KIND=DIRS
STYLE=FOCUS_SELECT
X=12
Y=94
W=194
H=274
GROW_H=1
SOURCE_DIR=.
SOURCE_MASK=*.*
MULTISELECT=1
ACTION=FILE_BROWSER_DIR_SELECT DIR_TREE FILE_VIEW PATH_BOX
PAGE=Split

[SPLITTER]
NAME=NAV_SPLIT
X=206
Y=94
W=8
H=274
GROW_H=1
ACTION=SPLIT DIR_TREE FILE_VIEW FILE_LABEL 15 14
PAGE=Split

[LISTBOX]
NAME=FILE_VIEW
SOURCE_KIND=FILES
STYLE=FOCUS_SELECT
X=216
Y=94
W=454
H=274
GROW_W=1
GROW_H=1
SOURCE_DIR=.
SOURCE_MASK=*.*
MULTISELECT=1
ACTION=FILE_BROWSER_FILE_SELECT FILE_VIEW STATUS_BOX
PAGE=Split

