KEY_ENTER_ACTION=FILE_BROWSER_PANE_OPEN ACTIVE FILE_BROWSER_ACTIVE_PATH STATUS_BOX
KEY_CTRL_C_ACTION=FILE_BROWSER_FILE_COPY ACTIVE STATUS_BOX
KEY_CTRL_D_ACTION=FILE_BROWSER_FILE_DUPLICATE ACTIVE STATUS_BOX
KEY_CTRL_F_ACTION=FILE_BROWSER_MASK_DIALOG STATUS_BOX
KEY_CTRL_N_ACTION=FILE_BROWSER_DIR_NEW_ACTIVE STATUS_BOX
